Comment: 0,0:00:00.00,0:00:00.00,Main-207+,,0,0,0,,{=10}===============================DIALOGUE============================
Dialogue: 0,0:01:52.59,0:01:54.72,Main-207+,,0,0,0,,Ra... Ra...
Dialogue: 0,0:01:57.18,0:01:57.97,Main-207+,,0,0,0,,Ra...
Dialogue: 0,0:01:58.68,0:02:01.23,Main-207+,,0,0,0,,Rana!
Dialogue: 0,0:02:02.31,0:02:05.56,Main-207+,,0,0,0,,Ma quale "cra", brutta bastarda!
Dialogue: 0,0:02:05.56,0:02:09.53,Main-207+,,0,0,0,,Per colpa del tuo colpo a mano aperta \Nsiamo finiti fuori dai binari!
Dialogue: 0,0:02:10.94,0:02:12.11,Flashbacks-207+,,0,0,0,,{This and next line, W7 20 @ 21:07}Spostati!
Dialogue: 0,0:02:12.11,0:02:13.86,Flashbacks-207+,,0,0,0,,{W7 20 @ 21:11}Ci scontreremo!
Dialogue: 0,0:02:15.37,0:02:18.45,Main-207+,,0,0,0,,{\q2}Stavamo giusto per raggiungere Sanji e gli altri!
Dialogue: 0,0:02:18.45,0:02:20.20,Main-207+,,0,0,0,,Adesso che facciamo?!
Dialogue: 0,0:02:22.37,0:02:24.12,Main-207+,,0,0,0,,Maledizione... Brutta...!
Dialogue: 0,0:02:24.12,0:02:27.38,Main-207+,,0,0,0,,Guarda che ti mangio! Ecco!{ew sull'ecco}
Dialogue: 0,0:02:32.67,0:02:34.34,Main-207+,,0,0,0,,A-A-Ahia...
Dialogue: 0,0:02:34.34,0:02:37.26,Main-207+,,0,0,0,,Che sta succedendo a questo treno marino?
Dialogue: 0,0:02:37.26,0:02:39.10,Main-207+,,0,0,0,,Ehi! State tutti bene voialtri?
Dialogue: 0,0:02:42.43,0:02:44.44,Main-207+,,0,0,0,,Sì... In qualche modo...
Dialogue: 0,0:02:43.64,0:02:44.44,Secondary-207+,,0,0,0,,Ahi, ahi...
Dialogue: 0,0:02:44.44,0:02:46.56,Main-207+,,0,0,0,,L-La mia schiena...{fianchi, vita (<parte del corpo)...}
Dialogue: 0,0:02:51.11,0:02:52.65,Main-207+,,0,0,0,,Oddio...!
Dialogue: 0,0:02:53.03,0:02:55.32,Main-207+,,0,0,0,,I king bull sono spariti!
Dialogue: 0,0:02:55.32,0:02:56.45,Main-207+,,0,0,0,,– Eh?!\N– Eh?!
Dialogue: 0,0:02:56.45,0:02:58.37,Main-207+,,0,0,0,,– Sono spariti?!\N– Sono spariti?!
Dialogue: 0,0:02:58.37,0:03:00.87,Main-207+,,0,0,0,,No, siamo {\i1}noi{\i0} ad essere spariti.
Dialogue: 0,0:03:00.87,0:03:03.41,Main-207+,,0,0,0,,Probabilmente siamo finiti fuori dai binari.
Dialogue: 0,0:03:03.41,0:03:05.71,Main-207+,,0,0,0,,– Ma non è ancora peggio?!\N– Ma non è ancora peggio?!
Dialogue: 0,0:03:05.71,0:03:06.79,Main-207+,,0,0,0,,Cosa facciamo ora?!
Dialogue: 0,0:03:06.79,0:03:08.00,Main-207+,,0,0,0,,Ehi!
Dialogue: 0,0:03:08.00,0:03:08.75,Main-207+,,0,0,0,,Cosa?
Dialogue: 0,0:03:09.46,0:03:11.46,Main-207+,,0,0,0,,Va tutto bene?!
Dialogue: 0,0:03:11.46,0:03:15.47,Main-207+,,0,0,0,,Riusciremo ad arrivare a Enies Lobby, no?!
Dialogue: 0,0:03:15.47,0:03:19.14,Main-207+,,0,0,0,,Ma 'sta un po' zitto! Aspetta un secondo!
Dialogue: 0,0:03:19.51,0:03:24.23,Main-207+,,0,0,0,,Però... siamo finiti su una\N strana corrente marina...
Dialogue: 0,0:03:24.23,0:03:25.89,Main-207+,,0,0,0,,Che succede?
Dialogue: 0,0:03:25.89,0:03:26.73,Main-207+,,0,0,0,,Signora Kokoro.
Dialogue: 0,0:03:26.73,0:03:27.48,Main-207+,,0,0,0,,Sì?
Dialogue: 0,0:03:27.85,0:03:29.90,Main-207+,,0,0,0,,Sai la direzione dell'isola?
Dialogue: 0,0:03:29.90,0:03:30.65,Main-207+,,0,0,0,,Sì.
Dialogue: 0,0:03:30.65,0:03:36.99,Main-207+,,0,0,0,,{\q2}Dopotutto sul treno marino ci sono degli \NEternal Pose per le isole su cui ci sono le stazioni.
Dialogue: 0,0:03:37.45,0:03:38.70,Main-207+,,0,0,0,,Allora è tutto a posto!
Dialogue: 0,0:03:38.70,0:03:40.99,Main-207+,,0,0,0,,Mi occuperò di osservare il mare, \Nlascio a te la guida.{cps}
Dialogue: 0,0:03:40.99,0:03:41.87,Main-207+,,0,0,0,,Eh?
Dialogue: 0,0:03:41.87,0:03:43.33,Main-207+,,0,0,0,,Tu...
Dialogue: 0,0:03:43.33,0:03:44.91,Main-207+,,0,0,0,,Io?
Dialogue: 0,0:03:44.91,0:03:46.08,Main-207+,,0,0,0,,Sono una navigatrice!
Dialogue: 0,0:03:46.41,0:03:47.58,Main-207+,,0,0,0,,Capisco!
Dialogue: 0,0:03:47.58,0:03:50.08,Main-207+,,0,0,0,,Questo sì che è rassicurante!
Dialogue: 0,0:03:52.21,0:03:54.09,Main-207+,,0,0,0,,Ma prima di tutto...
Dialogue: 0,0:03:54.67,0:03:56.80,Main-207+,,0,0,0,,Ehi! Yokozuna!
Dialogue: 0,0:03:56.80,0:03:58.59,Main-207+,,0,0,0,,Vieni qua un secondo!
Dialogue: 0,0:04:06.06,0:04:07.64,Main-207+,,0,0,0,,Ha saltato?!
Dialogue: 0,0:04:12.77,0:04:15.74,Main-207+,,0,0,0,,Ma quale "sono felice che tu stia bene"!
Dialogue: 0,0:04:15.74,0:04:16.86,Main-207+,,0,0,0,,Che diamine!
Dialogue: 0,0:04:17.24,0:04:20.36,Main-207+,,0,0,0,,Non è che sia stata rapita, sai?
Dialogue: 0,0:04:20.36,0:04:21.87,Main-207+,,0,0,0,,Che impaziente che sei!{meh, tipo uno che va sempre a conclusioni affrettate}
Dialogue: 0,0:04:25.12,0:04:28.00,Thoughts-207+,,0,0,0,,La nonna... sta parlando con Yokozuna...
Dialogue: 0,0:04:33.00,0:04:34.67,Main-207+,,0,0,0,,Ma che state facendo?
Dialogue: 0,0:04:34.67,0:04:37.88,Main-207+,,0,0,0,,La vecchia sta parlando con la rana di prima.
Dialogue: 0,0:04:37.88,0:04:40.68,Main-207+,,0,0,0,,Eh?! Ma quindi la vecchia è una rana?!{mamma che odio sta voce per chopper}
Dialogue: 0,0:04:40.68,0:04:43.68,Main-207+,,0,0,0,,{\q2}In effetti, sembra più una rana che una persona.
Dialogue: 0,0:04:43.68,0:04:46.22,Main-207+,,0,0,0,,Più tardi vi farà a pezzi, sapete?{circa}
Dialogue: 0,0:04:46.22,0:04:47.23,Main-207+,,0,0,0,,Infatti.{meh, è solo il loro modo di finire le frasi}
Dialogue: 0,0:04:47.64,0:04:49.02,Main-207+,,0,0,0,,Ehi!
Dialogue: 0,0:04:49.02,0:04:51.23,Main-207+,,0,0,0,,Signor Cappello di Paglia! Rocketman!
Dialogue: 0,0:04:51.56,0:04:52.81,Main-207+,,0,0,0,,Lo avete trovato?
Dialogue: 0,0:04:52.81,0:04:54.32,Main-207+,,0,0,0,,No, non lo vedo!
Dialogue: 0,0:04:54.32,0:04:57.44,Main-207+,,0,0,0,,Maledizione! Quell'enorme rana...
Dialogue: 0,0:04:57.44,0:05:00.07,Main-207+,,0,0,0,,Dove sono stati spazzati via il signor \NCappello di Paglia e gli altri?{evviva i cps}
Dialogue: 0,0:05:00.07,0:05:01.07,Main-207+,,0,0,0,,Voialtri!
Dialogue: 0,0:05:01.07,0:05:02.66,Main-207+,,0,0,0,,Vi pare il momento di perdervi in chiacchiere?!{cps grave}
Dialogue: 0,0:05:03.03,0:05:06.74,Main-207+,,0,0,0,,Siamo partiti per mare per\Nsalvare il nostro fratello Franky!
Dialogue: 0,0:05:06.74,0:05:07.79,Main-207+,,0,0,0,,Esatto!
Dialogue: 0,0:05:07.79,0:05:13.54,Main-207+,,0,0,0,,Fidiamoci del fatto che il Rocketman tornerà \Ne dirigiamoci verso Enies Lobby!
Dialogue: 0,0:05:13.54,0:05:16.34,Main-207+,,0,0,0,,Veloci! Sodoma! Gomorra!
Dialogue: 0,0:05:20.68,0:05:21.51,Main-207+,,0,0,0,,Cos–
Dialogue: 0,0:05:21.51,0:05:23.80,Main-207+,,0,0,0,,Ehi! Ragazzi, guardate lì davanti!
Dialogue: 0,0:05:24.39,0:05:27.81,Main-207+,,0,0,0,,Sui binari davanti a noi c'è un\N altro vagone che si è staccato!
Dialogue: 0,0:05:28.35,0:05:30.27,Main-207+,,0,0,0,,Non sappiamo se siano alleati o nemici!
Dialogue: 0,0:05:30.27,0:05:31.98,Main-207+,,0,0,0,,Tutti pronti a combattere!
Dialogue: 0,0:05:32.40,0:05:35.48,Main-207+,,0,0,0,,– Sì!\N– Sì!
Dialogue: 0,0:05:35.48,0:05:36.73,Main-207+,,0,0,0,,Ehi!
Dialogue: 0,0:05:36.73,0:05:38.90,Main-207+,,0,0,0,,Chi c'è laggiù?!
Dialogue: 0,0:05:38.90,0:05:40.53,Main-207+,,0,0,0,,Noi siamo la Famiglia Franky!
Dialogue: 0,0:05:40.53,0:05:42.41,Main-207+,,0,0,0,,Fatevi vedere!
Dialogue: 0,0:05:43.28,0:05:45.32,Main-207+,,0,0,0,,Ehi! È uscito qualcuno!
Dialogue: 0,0:05:49.83,0:05:51.41,Main-207+,,0,0,0,,È-È vivo?!
Dialogue: 0,0:05:51.96,0:05:55.13,Main-207+,,0,0,0,,Sul serio? Dici sul serio?!
Dialogue: 0,0:05:55.59,0:05:58.59,Main-207+,,0,0,0,,Sì. Così hanno detto.
Dialogue: 0,0:05:59.51,0:06:00.97,Main-207+,,0,0,0,,Ah... Capisco...
Dialogue: 0,0:06:02.09,0:06:03.76,Main-207+,,0,0,0,,Capisco...
Dialogue: 0,0:06:04.18,0:06:05.68,Main-207+,,0,0,0,,Quel maledetto Idioburg...
Dialogue: 0,0:06:05.68,0:06:07.72,Main-207+,,0,0,0,,Credevo che fosse stato ammazzato...!
Dialogue: 0,0:06:07.72,0:06:08.97,Main-207+,,0,0,0,,Capisco...
Dialogue: 0,0:06:08.97,0:06:10.06,Main-207+,,0,0,0,,Che sollievo...{per fortuna/che fortuna}
Dialogue: 0,0:06:10.06,0:06:14.23,Main-207+,,0,0,0,,Credo che il CP9 intendesse ucciderlo.
Dialogue: 0,0:06:14.23,0:06:16.69,Main-207+,,0,0,0,,Sarebbe meglio non parlarne.
Dialogue: 0,0:06:19.48,0:06:20.86,Main-207+,,0,0,0,,Questo...
Dialogue: 0,0:06:20.86,0:06:22.82,Main-207+,,0,0,0,,non si chiama forse "gentilezza"?{??}
Dialogue: 0,0:06:27.58,0:06:29.08,Main-207+,,0,0,0,,Beh, comunque...
Dialogue: 0,0:06:29.70,0:06:33.92,Main-207+,,0,0,0,,Ora il governo ha me che \Npossiedo i progetti dell'arma...
Dialogue: 0,0:06:34.46,0:06:37.88,Main-207+,,0,0,0,,e te che sai far rinascere le armi.
Dialogue: 0,0:06:38.38,0:06:43.13,Main-207+,,0,0,0,,Insomma, sono riusciti ad \Nottenere entrambe le chiavi.
Dialogue: 0,0:06:44.68,0:06:49.60,Main-207+,,0,0,0,,E poi... quando quel potere \Nsarà manifestato nel mondo...
Dialogue: 0,0:06:50.06,0:06:53.52,Main-207+,,0,0,0,,il governo naturalmente potrà \Nportare al termine l'Era dei Pirati.
Dialogue: 0,0:06:54.19,0:06:59.36,Main-207+,,0,0,0,,In seguito, quella potenza bellica incontrollabile \Nsconvolgerà il mondo e lo porterà alla rovina.
Dialogue: 0,0:06:59.36,0:07:02.99,Main-207+,,0,0,0,,{\q2}Questa è la minaccia posta dalle Armi Ancestrali.
Dialogue: 0,0:07:03.53,0:07:07.78,Main-207+,,0,0,0,,Il mio maestro ha dato la vita \Nper proteggere quei progetti.
Dialogue: 0,0:07:08.32,0:07:12.37,Main-207+,,0,0,0,,E non per un futuro così inutile!{ew}
Dialogue: 0,0:07:13.96,0:07:18.50,Main-207+,,0,0,0,,Quindi... se scappassi da solo, \Nsarebbe senza senso.{inutile, ma non volevo riusarlo}
Dialogue: 0,0:07:18.50,0:07:21.96,Main-207+,,0,0,0,,Dovresti tornare da Cappello \Ndi Paglia in qualche modo!
Dialogue: 0,0:07:21.96,0:07:23.21,Main-207+,,0,0,0,,È impossibile.
Dialogue: 0,0:07:24.13,0:07:27.64,Main-207+,,0,0,0,,Solo restando con loro, finirei per ferirli!
Dialogue: 0,0:07:30.05,0:07:32.89,Main-207+,,0,0,0,,Ma non sei tu a ferirli, no?
Dialogue: 0,0:07:32.89,0:07:37.27,Main-207+,,0,0,0,,La gente del governo dice che \Nla tua esistenza è un crimine.
Dialogue: 0,0:07:37.27,0:07:43.28,Main-207+,,0,0,0,,Ma, non importa quali armi si posseggano, \Nil solo esistere non è un crimine.
Dialogue: 0,0:07:44.78,0:07:49.91,Flashbacks-207+,,0,0,0,,{W7 13 - 13:24}Costruire... una nave...
Dialogue: 0,0:07:49.91,0:07:52.58,Flashbacks-207+,,0,0,0,,{W7 13 @ 13:24}non è né giusto né sbagliato!
Dialogue: 0,0:07:53.49,0:07:55.54,Main-207+,,0,0,0,,Per questo...
Dialogue: 0,0:07:56.33,0:07:59.00,Flashbacks-207+,,0,0,0,,{W7 20 - 17:20 (half)}La sua stessa esistenza è un crimine.
Dialogue: 0,0:07:59.00,0:08:00.38,Main-207+,,0,0,0,,No.
Dialogue: 0,0:08:01.00,0:08:04.42,Main-207+,,0,0,0,,La sola esistenza non è un crimine.
Dialogue: 0,0:08:15.14,0:08:17.85,Main-207+,,0,0,0,,Che diamine... Che è quel corpo?!
Dialogue: 0,0:08:18.31,0:08:20.52,Main-207+,,0,0,0,,Sei pieno di ferite!
Dialogue: 0,0:08:20.52,0:08:22.19,Main-207+,,0,0,0,,Tu...
Dialogue: 0,0:08:22.94,0:08:29.32,Main-207+,,0,0,0,,{\q2}Da quel giorno di otto anni fa...Dal giorno che \Nil signor Tom fu portato via per quella questione...
Dialogue: 0,0:08:29.74,0:08:34.66,Main-207+,,0,0,0,,Giorno dopo giorno, \Nhai continuato a sfidare il treno marino...
Dialogue: 0,0:08:46.01,0:08:49.43,Main-207+,,0,0,0,,Eh? Volevi diventare forte, no?
Dialogue: 0,0:08:50.47,0:08:54.56,Main-207+,,0,0,0,,Così da non dover più perdere\N persone importanti per te.
Dialogue: 0,0:08:54.97,0:08:58.81,Main-207+,,0,0,0,,Per proteggere le persone a te care.
Dialogue: 0,0:09:00.73,0:09:02.15,Main-207+,,0,0,0,,Yokozuna.
Dialogue: 0,0:09:02.15,0:09:07.07,Main-207+,,0,0,0,,Se è così, è giunto il momento di mostrare \Ni frutti di quell'allenamento!
Dialogue: 0,0:09:09.53,0:09:15.66,Main-207+,,0,0,0,,Il tuo adorato Franky è stato portato \Nvia proprio come il signor Tom!
Dialogue: 0,0:09:16.87,0:09:20.50,Main-207+,,0,0,0,,Questa nave sta andando\N verso di lui al momento!
Dialogue: 0,0:09:21.58,0:09:24.04,Main-207+,,0,0,0,,{Used as Flashback for Enies Lobby 23 @timestamp 05:15}Vuoi venire con noi?
Dialogue: 0,0:09:28.63,0:09:30.13,Main-207+,,0,0,0,,Cappello di Paglia!
Dialogue: 0,0:09:30.13,0:09:33.01,Main-207+,,0,0,0,,Si è aggiunto un nuovo compagno!{membro se proprio non volete nonostante sia nakama}
Dialogue: 0,0:09:33.01,0:09:34.60,Main-207+,,0,0,0,,Ok, ho capito!
Dialogue: 0,0:09:36.22,0:09:38.47,Main-207+,,0,0,0,,{\q2}Proprio come mi aspettavo dalla vecchia mostro!{ew}
Dialogue: 0,0:09:38.47,0:09:40.81,Main-207+,,0,0,0,,O forse... è la vecchia rana?
Dialogue: 0,0:09:40.81,0:09:43.02,Main-207+,,0,0,0,,Quale sei in realtà?
Dialogue: 0,0:09:45.90,0:09:48.32,Main-207+,,0,0,0,,Ma che importa?
Dialogue: 0,0:09:48.32,0:09:51.78,Main-207+,,0,0,0,,Signora Kokoro! Ho trovato \Nuna buona corrente! È a ore otto!
Dialogue: 0,0:09:51.78,0:09:53.16,Main-207+,,0,0,0,,Ottimo!
Dialogue: 0,0:09:53.16,0:09:56.33,Main-207+,,0,0,0,,Bene! Abbiamo perso un bel po' di tempo!
Dialogue: 0,0:09:56.33,0:09:59.33,Main-207+,,0,0,0,,Lo recupereremo tutto in un attimo!
Dialogue: 0,0:09:59.33,0:10:02.16,Main-207+,,0,0,0,,Andiamo! Rana!
Dialogue: 0,0:10:07.96,0:10:09.34,Main-207+,,0,0,0,,È arrivato il CP9!
Dialogue: 0,0:10:09.34,0:10:10.55,Main-207+,,0,0,0,,Veloci!
Dialogue: 0,0:10:11.26,0:10:13.59,Main-207+,,0,0,0,,Ottimo lavoro per la missione di lunga durata!{ew}
Dialogue: 0,0:10:13.59,0:10:16.47,Main-207+,,0,0,0,,Portate fuori i criminali! \NSono nel primo vagone!
Dialogue: 0,0:10:19.52,0:10:20.85,Main-207+,,0,0,0,,Ah! Brutto bastardo!
Dialogue: 0,0:10:20.85,0:10:23.52,Main-207+,,0,0,0,,Trattami bene, brutto bastardo!
Dialogue: 0,0:10:20.43,0:10:21.93,Secondary-207+,,0,0,0,,Finiscila, ehi!
Dialogue: 0,0:10:23.52,0:10:25.86,Main-207+,,0,0,0,,Chi pensi che sia io?!
Dialogue: 0,0:10:26.23,0:10:28.65,Main-207+,,0,0,0,,Wah! Non venire di qua!
Dialogue: 0,0:10:28.65,0:10:30.48,Main-207+,,0,0,0,,Attenti! 'Sto qua morde!
Dialogue: 0,0:10:33.03,0:10:35.24,Main-207+,,0,0,0,,Che tipo molesto.{chiassoso, turbolento}
Dialogue: 0,0:10:41.95,0:10:43.71,Main-207+,,0,0,0,,Come ci si aspetta dal CP9...
Dialogue: 0,0:10:43.71,0:10:45.58,Main-207+,,0,0,0,,Che impatto incredibile!{meh}
Dialogue: 0,0:10:46.17,0:10:48.71,Main-207+,,0,0,0,,Quello è Cutty Flam, vero?
Dialogue: 0,0:10:48.71,0:10:51.05,Main-207+,,0,0,0,,Allora... quella donna dev'essere...
Dialogue: 0,0:10:51.63,0:10:52.76,Main-207+,,0,0,0,,Nico Robin!
Dialogue: 0,0:10:52.76,0:10:54.84,Main-207+,,0,0,0,,È davvero stupenda!{bellissima}
Dialogue: 0,0:10:55.43,0:10:57.43,Main-207+,,0,0,0,,Aprite l'ingresso principale!
Dialogue: 0,0:11:17.45,0:11:18.66,Main-207+,,0,0,0,,Woah!
Dialogue: 0,0:11:18.66,0:11:20.70,Main-207+,,0,0,0,,Ma che posto è questo?!
Dialogue: 0,0:11:30.00,0:11:32.55,Main-207+,,0,0,0,,Quella è.... una cascata?!
Dialogue: 0,0:11:40.60,0:11:43.77,Main-207+,,0,0,0,,Non si vede il fondo!
Dialogue: 0,0:11:43.77,0:11:46.10,Main-207+,,0,0,0,,Ma 'sta in silenzio...{<kaku... ffs, come fai a essere vecchio anche dicendo ste cose...}
Dialogue: 0,0:11:51.19,0:11:55.07,Main-207+,,0,0,0,,{\q2}Pare che Lucci e gli altri si stiano dirigendo qui.
Dialogue: 0,0:11:59.45,0:12:04.75,Main-207+,,0,0,0,,{\q2}Con il miglior souvenir che ci potessero portare.
Dialogue: 0,0:12:07.00,0:12:08.33,Main-207+,,0,0,0,,Bene...
Dialogue: 0,0:12:08.83,0:12:11.00,Main-207+,,0,0,0,,Oggi, dopo ben cinque anni,
Dialogue: 0,0:12:11.00,0:12:14.13,Main-207+,,0,0,0,,gli otto membri del CP9, me incluso,
Dialogue: 0,0:12:14.13,0:12:17.93,Main-207+,,0,0,0,,potranno rivedersi. \NChe giorno speciale che dovrebbe essere...
Dialogue: 0,0:12:17.93,0:12:20.55,Main-207+,,0,0,0,,Eppure che è questo articolo?!
Dialogue: 0,0:12:22.14,0:12:25.22,Main-207+,,0,0,0,,Per il piano per l'assassinio del capo sezione \Ndell'Armata Rivoluzionaria...{G- gruppi}
Dialogue: 0,0:12:25.22,0:12:28.48,Main-207+,,0,0,0,,{\q2}avrebbero dovute essere sufficienti tre persone!
Dialogue: 0,0:12:28.48,0:12:31.02,Main-207+,,0,0,0,,Ma sono sparite in ben ventitre!
Dialogue: 0,0:12:31.02,0:12:33.11,Main-207+,,0,0,0,,Se avete delle spiegazioni, ditemele!
Dialogue: 0,0:12:35.32,0:12:39.91,Main-207+,,0,0,0,,{\an8}Sono terribilmente spiacente, Comandante.{perché parte di shirei choukan, comandante in capo}
Dialogue: 0,0:12:39.91,0:12:44.41,Main-207+,,0,0,0,,{\an8}È stato tutto per~
Dialogue: 0,0:12:44.41,0:12:46.29,Main-207+,,0,0,0,,{\an8}colpa mia~!
Dialogue: 0,0:12:46.29,0:12:48.04,Main-207+,,0,0,0,,{\an8}Smettila, Kumadori!
Dialogue: 0,0:12:48.04,0:12:50.50,Main-207+,,0,0,0,,{\an8}Un uomo non dovrebbe chinare \Nla testa così facilmente!
Dialogue: 0,0:12:51.00,0:12:54.96,Main-207+,,0,0,0,,{\an8}Spiegherò io le cose al Comandante, tu siediti!
Dialogue: 0,0:12:56.34,0:12:58.22,Main-207+,,0,0,0,,{\an8}Sono spiacente, Comandante!
Dialogue: 0,0:12:58.22,0:13:00.43,Main-207+,,0,0,0,,{\an8}Io... giunti a questo punto...
Dialogue: 0,0:13:00.80,0:13:04.14,Main-207+,,0,0,0,,mi infilzerò la pancia e \Nmi prenderò la responsabilità!
Dialogue: 0,0:13:04.14,0:13:05.56,Main-207+,,0,0,0,,Non dire idiozie!
Dialogue: 0,0:13:06.18,0:13:07.60,Main-207+,,0,0,0,,Si sbaglia, Comandante.
Dialogue: 0,0:13:07.98,0:13:12.23,Main-207+,,0,0,0,,Noi ci siamo infiltrati come previsto \Nper compiere l'assassinio,
Dialogue: 0,0:13:12.23,0:13:15.02,Main-207+,,0,0,0,,ma il piano che nessuno avrebbe \Ndovuto conoscere era stato trapelato!{cps}
Dialogue: 0,0:13:15.02,0:13:18.32,Main-207+,,0,0,0,,Ho finito io per parlare del piano in città!
Dialogue: 0,0:13:19.65,0:13:22.87,Main-207+,,0,0,0,,Cosa?! Ancora tu, Fukuro?!
Dialogue: 0,0:13:22.87,0:13:25.37,Main-207+,,0,0,0,,A che serve quindi quella \Ncerniera che hai alla bocca?!
Dialogue: 0,0:13:25.37,0:13:28.04,Main-207+,,0,0,0,,E quand'è che la smetterai di spifferare tutto?!
Dialogue: 0,0:13:28.04,0:13:30.58,Main-207+,,0,0,0,,Siamo degli agenti segreti con \Nobbligo di assoluta segretezza, sai?!{cps e ridondante, ma volevo lasciarvi tutto}
Dialogue: 0,0:13:30.58,0:13:32.12,Main-207+,,0,0,0,,Ho finito per parlarne~!
Dialogue: 0,0:13:33.13,0:13:34.75,Main-207+,,0,0,0,,Ma quale "chapapa"?!{che poi "chapapa" è come ride Fukuro... fml}
Dialogue: 0,0:13:36.59,0:13:40.30,Main-207+,,0,0,0,,Non prendertela con Fukuro~!
Dialogue: 0,0:13:40.67,0:13:45.05,Main-207+,,0,0,0,,Mi prenderò io la responsabilità~! Seppuku!{<che faccio?}
Dialogue: 0,0:13:45.39,0:13:46.68,Main-207+,,0,0,0,,{\fad(150,150)}Tekkai!
Dialogue: 0,0:13:48.43,0:13:51.14,Main-207+,,0,0,0,,È inutile~! Non muoio~!
Dialogue: 0,0:13:51.14,0:13:54.69,Main-207+,,0,0,0,,E tu muoviti a crepare! Brutto bastardo!
Dialogue: 0,0:13:57.52,0:13:59.49,Main-207+,,0,0,0,,Basta così, voialtri...
Dialogue: 0,0:14:00.36,0:14:04.03,Main-207+,,0,0,0,,Scotta! Ho rovesciato il caffè! Maledizione!
Dialogue: 0,0:14:04.03,0:14:06.74,Main-207+,,0,0,0,,E poi pare che Nero sia stato inutile!{"non sia stato possibile usarlo"}
Dialogue: 0,0:14:07.33,0:14:08.12,Main-207+,,0,0,0,,Oh beh.
Dialogue: 0,0:14:14.00,0:14:15.58,Main-207+,,0,0,0,,Veloci!
Dialogue: 0,0:14:15.58,0:14:17.84,Main-207+,,0,0,0,,Non possiamo andare più veloci?!
Dialogue: 0,0:14:23.22,0:14:28.68,Main-207+,,0,0,0,,Ehi... Ehi, ma quindi... il fratello \NFranky si è sacrificato e...
Dialogue: 0,0:14:29.52,0:14:31.68,Main-207+,,0,0,0,,Sì, esatto.
Dialogue: 0,0:14:32.52,0:14:35.27,Main-207+,,0,0,0,,Ha anche provato a salvare la dolce Robin...
Dialogue: 0,0:14:40.82,0:14:44.32,Main-207+,,0,0,0,,Che persona meravigliosa il fratello!{magnifica? lett è abbagliante, ma è brutto e non rende}
Dialogue: 0,0:14:45.20,0:14:48.20,Main-207+,,0,0,0,,Se non ci sbrighiamo, sarà troppo tardi!
Dialogue: 0,0:14:50.12,0:14:54.29,Main-207+,,0,0,0,,Ehi, la vedo! È la luce dell'isola \Nsenza notte! È Enies Lobby!
Dialogue: 0,0:14:55.71,0:14:57.96,Main-207+,,0,0,0,,Cosa?! Davvero?! Bene!
Dialogue: 0,0:14:57.96,0:14:59.96,Main-207+,,0,0,0,,Possiamo andare a salvare il fratello!
Dialogue: 0,0:15:01.71,0:15:02.67,Main-207+,,0,0,0,,"Isola senza notte"?
Dialogue: 0,0:15:02.67,0:15:05.72,Main-207+,,0,0,0,,Sì, in quell'isola non c'è la notte.
Dialogue: 0,0:15:05.72,0:15:07.22,Main-207+,,0,0,0,,Viene anche detta "isola diurna".
Dialogue: 0,0:15:07.22,0:15:09.81,Main-207+,,0,0,0,,Quella è l'Isola Giudiziaria.
Dialogue: 0,0:15:12.31,0:15:13.77,Main-207+,,0,0,0,,Li ho trovati!
Dialogue: 0,0:15:14.27,0:15:16.40,Main-207+,,0,0,0,,Gli yagara enormi!
Dialogue: 0,0:15:16.40,0:15:19.27,Main-207+,,0,0,0,,Ehi!
Dialogue: 0,0:15:22.73,0:15:24.03,Main-207+,,0,0,0,,– Luffy!\N– Luffy!
Dialogue: 0,0:15:24.40,0:15:27.28,Main-207+,,0,0,0,,Ah! Sanji!
Dialogue: 0,0:15:27.95,0:15:29.83,Main-207+,,0,0,0,,E quello chi è?
Dialogue: 0,0:15:28.82,0:15:30.95,Main-207+,,0,0,0,,{\an8}Da quanto tempo...
Dialogue: 0,0:15:30.95,0:15:34.71,Main-207+,,0,0,0,,È il signor Cappello di Paglia!
Dialogue: 0,0:15:37.54,0:15:39.96,Main-207+,,0,0,0,,Pare che siamo riusciti a \Nritrovarci senza problemi!
Dialogue: 0,0:15:39.96,0:15:43.92,Main-207+,,0,0,0,,{\q2}Sembrano prontissimi a fare irruzione!\NAndiamo verso l'ingresso del Governo Mondiale!{cps}
Dialogue: 0,0:15:43.92,0:15:46.01,Main-207+,,0,0,0,,{\i1}Sembra piuttosto incoraggiante!
Dialogue: 0,0:15:51.10,0:15:54.43,Main-207+,,0,0,0,,Bene! Anche Enies Lobby \Nè nel mio campo visivo!
Dialogue: 0,0:15:54.43,0:15:57.69,Main-207+,,0,0,0,,A tutti, siate pronti a combattere!
Dialogue: 0,0:16:08.28,0:16:10.99,Main-207+,,0,0,0,,–　Sogeking dell'Isola dei Cecchini?!\N–　Sogeking dell'Isola dei Cecchini?!
Dialogue: 0,0:16:12.20,0:16:13.45,Main-207+,,0,0,0,,Esatto.
Dialogue: 0,0:16:13.45,0:16:15.25,Main-207+,,0,0,0,,Sono il miglior amico di Usopp e
Dialogue: 0,0:16:15.25,0:16:18.46,Main-207+,,0,0,0,,sono qui su sua richiesta per darvi una mano.
Dialogue: 0,0:16:18.46,0:16:20.42,Main-207+,,0,0,0,,È-È un eroe!{hero}
Dialogue: 0,0:16:20.75,0:16:24.00,Main-207+,,0,0,0,,Visto che ha il mantello, \Navevo immaginato fosse così!
Dialogue: 0,0:16:24.00,0:16:26.51,Main-207+,,0,0,0,,Che figata! \NÈ la prima volta che ne vedo uno!
Dialogue: 0,0:16:26.51,0:16:29.64,Main-207+,,0,0,0,,Capisco! \NQuindi se si ha il mantello, si è eroi?{ah! chopper is back T_T I missed you Ikue Otani T_T}
Dialogue: 0,0:16:29.64,0:16:32.47,Main-207+,,0,0,0,,Esatto!\NAnche i babbuini mantellati sono eroi!{non è una razza di scimmie in italiano, ma non mi viene in mente nessun animale che abbia "mantello" nel nome... luffy usa マントヒヒ (mantohihi) che in italiano sono amadriade e non rende (oltre che nessuno sa cosa sono). se trovate opzioni migliori ben venga}
Dialogue: 0,0:16:32.47,0:16:33.31,Main-207+,,0,0,0,,Sul serio?!
Dialogue: 0,0:16:33.31,0:16:36.68,Secondary-207+,,0,0,0,,{\an8}Sì! In genere chi ha un mantello è un eroe!
Dialogue: 0,0:16:33.89,0:16:35.27,Main-207+,,0,0,0,,Ma non è Usopp?
Dialogue: 0,0:16:35.27,0:16:37.64,Main-207+,,0,0,0,,È Usopp. Sono contenta stia bene.
Dialogue: 0,0:16:37.64,0:16:41.40,Main-207+,,0,0,0,,È il naso lungo che ha \Nassaltato la Franky House.
Dialogue: 0,0:16:41.40,0:16:44.40,Main-207+,,0,0,0,,È il naso lungo che era stato \Ncatturato con il fratello.
Dialogue: 0,0:16:44.40,0:16:45.69,Main-207+,,0,0,0,,Infatti.
Dialogue: 0,0:16:45.69,0:16:47.11,Main-207+,,0,0,0,,C-Contiamo su di te.
Dialogue: 0,0:16:47.11,0:16:48.49,Main-207+,,0,0,0,,Ah, certo!
Dialogue: 0,0:16:48.49,0:16:51.24,Main-207+,,0,0,0,,È il ragazzo che abbiamo \Nincontrato a Shift Station...
Dialogue: 0,0:16:52.07,0:16:53.99,Main-207+,,0,0,0,,Un autografo per favore.
Dialogue: 0,0:16:53.28,0:16:53.99,Secondary-207+,,0,0,0,,Sì.
Dialogue: 0,0:16:56.29,0:16:57.79,Main-207+,,0,0,0,,Però, allora...
Dialogue: 0,0:16:57.79,0:17:00.00,Main-207+,,0,0,0,,dov'è andato Usopp?
Dialogue: 0,0:17:00.00,0:17:03.50,Main-207+,,0,0,0,,Lui sta bene. Non serve preoccuparsi.
Dialogue: 0,0:17:03.50,0:17:08.97,Main-207+,,0,0,0,,Ad ogni modo, ha detto di dedicare le \Nforze a salvare Robin e se n'è andato.
Dialogue: 0,0:17:08.97,0:17:10.72,Main-207+,,0,0,0,,Sì. In effetti ha ragione.
Dialogue: 0,0:17:10.72,0:17:12.14,Main-207+,,0,0,0,,L'is–
Dialogue: 0,0:17:12.14,0:17:14.35,Main-207+,,0,0,0,,L'Isola dei Cecchini dov'è?
Dialogue: 0,0:17:14.35,0:17:15.76,Main-207+,,0,0,0,,Giusto...
Dialogue: 0,0:17:16.14,0:17:17.22,Main-207+,,0,0,0,,Vedi...
Dialogue: 0,0:17:17.22,0:17:20.56,Main-207+,,0,0,0,,{\an8\fad(150,150)\bord2.9\shad2\fnKeifont\fs75\b1}{W7 18 - 00:19}♪ Io dall'isola dei cecchin' ♪
Dialogue: 0,0:17:21.77,0:17:22.98,Main-207+,,0,0,0,,È nel...
Dialogue: 0,0:17:23.81,0:17:25.19,Main-207+,,0,0,0,,vostro cuore.
Dialogue: 0,0:17:26.65,0:17:29.36,Main-207+,,0,0,0,,{\an8\fad(150,150)\bord2.9\shad2\fnKeifont\fs75\b1}♪ sono venuto qui  ♪
Dialogue: 0,0:17:27.61,0:17:28.90,Main-207+,,0,0,0,,Nel cuore!
Dialogue: 0,0:17:30.24,0:17:33.87,Main-207+,,0,0,0,,{\an8\fad(150,150)\bord2.9\shad2\fnKeifont\fs75\b1}♪ per voi ♪
Dialogue: 0,0:17:33.87,0:17:34.66,Main-207+,,0,0,0,,Ma dove sarebbe?!
Dialogue: 0,0:17:34.66,0:17:38.45,Secondary-207+,,0,0,0,,{\an8\fad(150,150)\bord2.9\shad2\fnFOT-Greco Std B Strp\fs75\b1}♪ Io dall'isola dei cecchin' ♪
Dialogue: 0,0:17:38.45,0:17:41.08,Secondary-207+,,0,0,0,,{\an8\fad(150,150)\bord2.9\shad2\fnFOT-Greco Std B Strp\fs75\b1}♪ sono venuto qui per voi ♪
Dialogue: 0,0:17:41.08,0:17:41.79,Secondary-207+,,0,0,0,,{\an8}P-Prego!
Dialogue: 0,0:17:41.79,0:17:44.79,Secondary-207+,,0,0,0,,{\an8\fad(150,150)\bord2.9\shad2\fnFOT-Greco Std B Strp\fs75\b1}♪ sono venuto qui per voi ♪
Dialogue: 0,0:17:44.79,0:17:45.63,Secondary-207+,,0,0,0,,{\an8}Bene!
Dialogue: 0,0:17:45.63,0:17:46.84,Secondary-207+,,0,0,0,,{\an8\fad(150,150)\bord2.9\shad2\fnFOT-Greco Std B Strp\fs75\b1}♪ Cento colpi ♪
Dialogue: 0,0:17:46.84,0:17:47.34,Secondary-207+,,0,0,0,,{\an8}Prego!
Dialogue: 0,0:17:47.34,0:17:49.05,Secondary-207+,,0,0,0,,{\an8\fad(150,150)\bord2.9\shad2\fnFOT-Greco Std B Strp\fs75\b1}♪ Cento colpi ♪
Dialogue: 0,0:17:49.05,0:17:49.59,Secondary-207+,,0,0,0,,{\an8\fad(150,150)\bord2.9\shad2\fnFOT-Greco Std B Strp\fs75\b1}♪ cento ♪
Dialogue: 0,0:17:49.59,0:17:49.97,Secondary-207+,,0,0,0,,{\an8}Prego!
Dialogue: 0,0:17:49.97,0:17:50.76,Secondary-207+,,0,0,0,,{\an8\fad(150,150)\bord2.9\shad2\fnFOT-Greco Std B Strp\fs75\b1}♪ cento ♪
Dialogue: 0,0:17:50.76,0:17:51.22,Secondary-207+,,0,0,0,,{\an8\fad(150,150)\bord2.9\shad2\fnFOT-Greco Std B Strp\fs75\b1}♪ centri ♪
Dialogue: 0,0:17:51.22,0:17:51.55,Secondary-207+,,0,0,0,,{\an8}Prego!
Dialogue: 0,0:17:51.55,0:17:52.18,Secondary-207+,,0,0,0,,{\an8\fad(150,150)\bord2.9\shad2\fnFOT-Greco Std B Strp\fs75\b1}♪ centri ♪
Dialogue: 0,0:17:44.59,0:17:45.25,Main-207+,,0,0,0,,Cara Nami.
Dialogue: 0,0:17:45.25,0:17:46.50,Main-207+,,0,0,0,,Eh?
Dialogue: 0,0:17:46.50,0:17:48.17,Main-207+,,0,0,0,,Che c'è, Sanji?
Dialogue: 0,0:17:49.34,0:17:52.18,Main-207+,,0,0,0,,E voialtri idioti.{eccetto Nami, mi sembra ridondante}
Dialogue: 0,0:17:52.18,0:17:52.68,Main-207+,,0,0,0,,Eh?
Dialogue: 0,0:17:52.68,0:17:56.26,Main-207+,,0,0,0,,Prima di salvare Robin, ascoltate questo.
Dialogue: 0,0:18:03.65,0:18:05.02,Main-207+,,0,0,0,,Questo è quanto.
Dialogue: 0,0:18:05.02,0:18:09.61,Main-207+,,0,0,0,,Pare che, in qualche modo, \Nquel CP9 abbiano in pugno Robin.
Dialogue: 0,0:18:10.19,0:18:12.99,Main-207+,,0,0,0,,Non è che stia cercando una \Nscusa per non recuperarla, ma...
Dialogue: 0,0:18:13.53,0:18:16.28,Main-207+,,0,0,0,,anche se stiamo per fare \Nirruzione in territorio nemico,
Dialogue: 0,0:18:16.28,0:18:19.95,Main-207+,,0,0,0,,non è detto che Robin si affidi a noi.
Dialogue: 0,0:18:21.46,0:18:23.62,Main-207+,,0,0,0,,E questo che importa?!
Dialogue: 0,0:18:23.62,0:18:26.63,Main-207+,,0,0,0,,Non la perdonerò mai!
Dialogue: 0,0:18:28.13,0:18:29.09,Main-207+,,0,0,0,,Maledetta Robin!
Dialogue: 0,0:18:29.09,0:18:30.67,Main-207+,,0,0,0,,Ma perché?!
Dialogue: 0,0:18:31.01,0:18:32.51,Main-207+,,0,0,0,,Ma è così, no?!
Dialogue: 0,0:18:32.51,0:18:35.05,Main-207+,,0,0,0,,Perché non le va che andiamo a salvarla?!
Dialogue: 0,0:18:35.43,0:18:39.43,Main-207+,,0,0,0,,Robin soffre pensando a cosa succederà a \Nquesta ciurma dopo che l'avremo salvata!
Dialogue: 0,0:18:39.43,0:18:40.97,Main-207+,,0,0,0,,Questo io non lo so!
Dialogue: 0,0:18:41.39,0:18:43.77,Main-207+,,0,0,0,,Se lasciamo perdere, Robin verrà uccisa, no?!
Dialogue: 0,0:18:43.77,0:18:46.23,Main-207+,,0,0,0,,{\q2}Dato che non è che voglia morire, la salveremo!
Dialogue: 0,0:18:46.69,0:18:48.94,Main-207+,,0,0,0,,Beh, questo è ovvio, però...!
Dialogue: 0,0:18:48.94,0:18:50.07,Main-207+,,0,0,0,,Lascia perdere.
Dialogue: 0,0:18:50.07,0:18:52.94,Main-207+,,0,0,0,,Non cambia ciò che dobbiamo fare.
Dialogue: 0,0:18:53.53,0:18:54.99,Main-207+,,0,0,0,,Dobbiamo solo salvarla.
Dialogue: 0,0:18:54.99,0:18:57.57,Main-207+,,0,0,0,,{Used as flashback in Enies Lobby 05 @05:20}Gonfierò tutti e tutto di botte!{ew}
Dialogue: 0,0:18:58.16,0:19:00.54,Main-207+,,0,0,0,,E ho anche una tecnica che voglio provare!
Dialogue: 0,0:19:05.92,0:19:08.00,Main-207+,,0,0,0,,Voialtri, guardate un secondo.
Dialogue: 0,0:19:08.34,0:19:12.17,Main-207+,,0,0,0,,Sono già venuto qui una volta per \Nlavori di manutenzione sui binari.
Dialogue: 0,0:19:12.51,0:19:15.01,Main-207+,,0,0,0,,Questa l'ho disegnata io a memoria, ma...
Dialogue: 0,0:19:15.59,0:19:18.26,Main-207+,,0,0,0,,è una mappa approssimativa di Enies Lobby.
Dialogue: 0,0:19:23.85,0:19:29.31,Main-207+,,0,0,0,,{\q2}Le Porte della Giustizia sono nella parte posteriore e \Npare siano raggiungibili sono dalla Torre della Giustizia.
Dialogue: 0,0:19:29.31,0:19:31.69,Main-207+,,0,0,0,,E questo cos'è? Cos'è la roba nera?
Dialogue: 0,0:19:31.69,0:19:33.49,Main-207+,,0,0,0,,Il nero è la cascata.
Dialogue: 0,0:19:33.49,0:19:34.82,Main-207+,,0,0,0,,"Cascata"?
Dialogue: 0,0:19:34.82,0:19:36.99,Main-207+,,0,0,0,,Beh, lo capirete appena varcato l'ingresso.
Dialogue: 0,0:19:37.45,0:19:40.70,Main-207+,,0,0,0,,Se non recuperiamo Nico Robin \Ne Franky su questo rettilineo tra
Dialogue: 0,0:19:40.70,0:19:44.66,Main-207+,,0,0,0,,l'ingresso e il cancello principali, avremo perso.
Dialogue: 0,0:19:45.00,0:19:46.16,Main-207+,,0,0,0,,Perché?
Dialogue: 0,0:19:46.16,0:19:50.21,Main-207+,,0,0,0,,Dobbiamo solo continuare a seguire Robin \Nindipendentemente da dove la portano, no?{ew}
Dialogue: 0,0:19:50.21,0:19:53.00,Main-207+,,0,0,0,,L'hanno detto prima di \Npartire da Water Seven, no?!{e io non mi ricordo se gliel'ha detto lei o chi l'abbia detto e il jp è generico}
Dialogue: 0,0:19:53.00,0:19:57.88,Main-207+,,0,0,0,,{\q2}Oltrepassate quelle porte, le destinazioni sono solo \Nil Quartier Generale della Marina o la prigione sottomarina!{non mi ricordo come l'avevo messa e non la trovo...}
Dialogue: 0,0:19:58.26,0:20:02.56,Main-207+,,0,0,0,,Dobbiamo assolutamente risolvere \Nla questione prima di allora!
Dialogue: 0,0:20:02.56,0:20:04.56,Main-207+,,0,0,0,,Proprio così.
Dialogue: 0,0:20:04.56,0:20:08.10,Main-207+,,0,0,0,,Detto questo, anche se \Nirrompessimo tutti sull'isola
Dialogue: 0,0:20:08.10,0:20:11.82,Main-207+,,0,0,0,,gli unici in grado di vincere \Nse ci imbattessimo nel CP9
Dialogue: 0,0:20:11.82,0:20:13.48,Main-207+,,0,0,0,,siete voi.
Dialogue: 0,0:20:13.48,0:20:17.15,Main-207+,,0,0,0,,Ho capito bene quanto siate forti dopo aver \Nviaggiato con voi su questo treno marino.{cps}
Dialogue: 0,0:20:17.15,0:20:20.49,Main-207+,,0,0,0,,Per questo, aspettate qui \Nin mare per cinque minuti.
Dialogue: 0,0:20:20.49,0:20:24.12,Main-207+,,0,0,0,,Fate irruzione con questo Rocketman \Nnell'ingresso principale e andate sull'isola!{cps}
Dialogue: 0,0:20:24.12,0:20:28.33,Main-207+,,0,0,0,,Noi vi procederemo e forzeremo \Nl'ingresso e il cancello principali
Dialogue: 0,0:20:28.33,0:20:30.71,Main-207+,,0,0,0,,così che il treno possa passare.
Dialogue: 0,0:20:31.13,0:20:36.59,Main-207+,,0,0,0,,{\q2}In seguito, vorremo che continuasse a procedere \Nindipendentemente da quanti di noi cadranno.
Dialogue: 0,0:20:38.72,0:20:41.22,Main-207+,,0,0,0,,Siamo poco più che una sessantina.
Dialogue: 0,0:20:41.22,0:20:44.56,Main-207+,,0,0,0,,I nemici saranno più che due o tremila.
Dialogue: 0,0:20:45.43,0:20:50.98,Main-207+,,0,0,0,,Voi Cappello di Paglia dovreste evitare \Nle lotte inutili e puntare solo al CP9!
Dialogue: 0,0:20:50.98,0:20:52.98,Main-207+,,0,0,0,,Sì! Ho capito!
Dialogue: 0,0:20:52.98,0:20:54.48,Main-207+,,0,0,0,,{\i1}Bene, voialtri!
Dialogue: 0,0:20:54.48,0:20:57.15,Main-207+,,0,0,0,,{\i1}Siamo davanti all'isola!
Dialogue: 0,0:20:57.15,0:21:01.07,Main-207+,,0,0,0,,Guardate bene il cielo sul retro di Enies Lobby!
Dialogue: 0,0:21:02.53,0:21:04.91,Main-207+,,0,0,0,,Quelle sono le Porte della Giustizia!
Dialogue: 0,0:21:04.91,0:21:10.83,Main-207+,,0,0,0,,–　Woah! Sono enormi!\N–　Woah! Sono enormi!
Dialogue: 0,0:21:13.75,0:21:16.80,Main-207+,,0,0,0,,Non vengono mai aperte del tutto.
Dialogue: 0,0:21:16.80,0:21:21.84,Main-207+,,0,0,0,,Si aprono leggermente solo quando \Nè il momento che un criminale passi.
Dialogue: 0,0:21:22.30,0:21:26.18,Main-207+,,0,0,0,,E, oltre a quella porta, \Nc'è un nido di Re dei Mari
Dialogue: 0,0:21:26.18,0:21:30.19,Main-207+,,0,0,0,,{\q2}simile alla Calm Belt che circonda la Grand Line.
Dialogue: 0,0:21:30.56,0:21:33.40,Main-207+,,0,0,0,,Una semplice nave non sopravviverebbe.
Dialogue: 0,0:21:33.40,0:21:35.77,Main-207+,,0,0,0,,Non so come fanno, ma...
Dialogue: 0,0:21:35.77,0:21:39.82,Main-207+,,0,0,0,,{\i1}la Marina ha i mezzi necessari \Nper attraversarlo in sicurezza.
Dialogue: 0,0:21:39.82,0:21:43.62,Main-207+,,0,0,0,,{\i1}In altre parole, proprio come \Nha detto la ragazza pirata,
Dialogue: 0,0:21:43.62,0:21:46.66,Main-207+,,0,0,0,,se volete riprendervi un criminale,
Dialogue: 0,0:21:46.66,0:21:50.41,Main-207+,,0,0,0,,il limite sarà finché non \Navrà superato quelle porte!{ewwww}
Dialogue: 0,0:21:50.41,0:21:53.46,Main-207+,,0,0,0,,Bene! Non c'è tempo da perdere!
Dialogue: 0,0:21:55.96,0:21:58.67,Main-207+,,0,0,0,,Allora noi vi precederemo come da piano!
Dialogue: 0,0:21:59.51,0:22:01.51,Main-207+,,0,0,0,,Lasciate a noi il supporto!{ew}
Dialogue: 0,0:22:01.51,0:22:04.72,Main-207+,,0,0,0,,Ehi! Quei due non dovrebbero \Nessere dalla nostra parte?!
Dialogue: 0,0:22:10.18,0:22:11.89,Main-207+,,0,0,0,,Eh? E Luffy?
Dialogue: 0,0:22:11.89,0:22:14.52,Main-207+,,0,0,0,,Eh? Era qui fino a un attimo fa...
Dialogue: 0,0:22:20.69,0:22:21.95,Main-207+,,0,0,0,,Quello è il signor Cappello di Paglia?
Dialogue: 0,0:22:21.95,0:22:23.53,Main-207+,,0,0,0,,Eh?!
Dialogue: 0,0:22:26.87,0:22:29.33,Main-207+,,0,0,0,,– Eeh?!\N– Eeh?!
Dialogue: 0,0:22:29.33,0:22:32.66,Main-207+,,0,0,0,,Ma che sta facendo quel tizio di testa sua?!
Dialogue: 0,0:22:32.66,0:22:35.46,Main-207+,,0,0,0,,Non ha capito per niente il piano!
Dialogue: 0,0:22:37.21,0:22:38.96,Main-207+,,0,0,0,,È inutile...
Dialogue: 0,0:22:38.96,0:22:40.92,Main-207+,,0,0,0,,Aveva detto "ho capito".
Dialogue: 0,0:22:40.92,0:22:43.55,Main-207+,,0,0,0,,Aspettare cinque minuti è impossibile per lui.
Dialogue: 0,0:22:43.55,0:22:45.14,Main-207+,,0,0,0,,In effetti...
Dialogue: 0,0:22:46.97,0:22:49.81,Main-207+,,0,0,0,,Che tipo impaziente.
Dialogue: 0,0:22:49.81,0:22:52.23,Main-207+,,0,0,0,,Vai! Fratello pirata!{ragazzo pirata, idk}
Dialogue: 0,0:22:56.10,0:22:59.36,Main-207+,,0,0,0,,Non restate indietro, Sodoma, Gomorra!
Dialogue: 0,0:22:59.36,0:23:03.03,Main-207+,,0,0,0,,Arrampicatevi sulla ringhiera di ferro \Ne sfondate l'ingresso principale!
Dialogue: 0,0:23:06.32,0:23:09.62,Main-207+,,0,0,0,,– Sì!\N– Sì!
Dialogue: 0,0:23:10.08,0:23:12.45,Main-207+,,0,0,0,,{\fad(150,150)}Gum Gum...
Dialogue: 0,0:23:12.45,0:23:15.04,Main-207+,,0,0,0,,{\fad(150,150)}Rocket!
Dialogue: 0,0:23:16.12,0:23:17.08,Main-207+,,0,0,0,,Cosa?
Dialogue: 0,0:23:18.96,0:23:20.21,Main-207+,,0,0,0,,Qualcosa stava volando...
Dialogue: 0,0:23:24.47,0:23:26.05,Main-207+,,0,0,0,,Ma che posto è questo?
Dialogue: 0,0:23:26.05,0:23:27.72,Main-207+,,0,0,0,,Che buco assurdo!
Dialogue: 0,0:23:27.72,0:23:29.76,Main-207+,,0,0,0,,Sembra che l'isola voli!
Dialogue: 0,0:23:31.31,0:23:32.77,Main-207+,,0,0,0,,C'è qualcosa sull'ingresso!
Dialogue: 0,0:23:32.77,0:23:35.23,Main-207+,,0,0,0,,Un intruso! Abbattetelo!
Dialogue: 0,0:23:35.94,0:23:37.73,Main-207+,,0,0,0,,Mi hanno visto!
Dialogue: 0,0:23:40.73,0:23:42.61,Main-207+,,0,0,0,,È entrato dall'ingresso!
Dialogue: 0,0:23:47.99,0:23:50.28,Main-207+,,0,0,0,,{\i1}Qui parla l'ingresso principale!\NQui parla l'ingresso principale!
Dialogue: 0,0:23:50.28,0:23:52.58,Main-207+,,0,0,0,,{\i1}Al Comandante e al cancello principale!
Dialogue: 0,0:23:53.20,0:23:55.83,Main-207+,,0,0,0,,{\i1}Qui parla l'ingresso principale! \NSi prega di rispondere!
Dialogue: 0,0:23:57.17,0:23:59.33,Main-207+,,0,0,0,,Che c'è? Che succede?
Dialogue: 0,0:23:59.71,0:24:04.05,Main-207+,,0,0,0,,{\i1}C'è un intruso! Ha superato l'ingresso \Nprincipale e si dirige al cancello principale!
Dialogue: 0,0:24:04.05,0:24:07.72,Main-207+,,0,0,0,,Ma che vuoi che sia? \NÈ un unico intruso. Calmatevi e
Dialogue: 0,0:24:07.72,0:24:08.51,Main-207+,,0,0,0,,{\i1}fatelo fuori.
Dialogue: 0,0:24:08.51,0:24:10.60,Main-207+,,0,0,0,,{\i1}No, ecco...!
Dialogue: 0,0:24:10.60,0:24:12.51,Main-207+,,0,0,0,,{\i1}Qui parla il cancello principale!
Dialogue: 0,0:24:12.51,0:24:14.10,Main-207+,,0,0,0,,{\i1}Abbiamo rilevato l'intruso.
Dialogue: 0,0:24:14.10,0:24:16.73,Main-207+,,0,0,0,,{\i1}Lo faremo fuori subito. Non si preoccupi.
Dialogue: 0,0:24:19.15,0:24:21.73,Main-207+,,0,0,0,,Ehi, ehi, tu. Dai, fermati.
Dialogue: 0,0:24:21.73,0:24:23.69,Main-207+,,0,0,0,,Sai dove ti trovi?
Dialogue: 0,0:24:23.69,0:24:25.61,Main-207+,,0,0,0,,{\i1}Occupatevene con cautela!
Dialogue: 0,0:24:25.61,0:24:27.86,Main-207+,,0,0,0,,{\i1}Se non mi sono sbagliato, quell'uomo...
Dialogue: 0,0:24:29.91,0:24:31.62,Main-207+,,0,0,0,,{\i1}è Luffy Cappello di Paglia!
Dialogue: 0,0:24:37.41,0:24:39.54,Main-207+,,0,0,0,,Cosa?! Cos'hai appena detto?!
Dialogue: 0,0:24:39.54,0:24:41.21,Main-207+,,0,0,0,,Quello con la taglia da centro milioni?!
Dialogue: 0,0:24:42.96,0:24:46.26,Main-207+,,0,0,0,,Credo sia il pirata Cappello di Paglia!
Dialogue: 0,0:24:51.43,0:24:52.76,Main-207+,,0,0,0,,E Robin?
Dialogue: 0,0:25:08.28,0:25:12.24,Main-207+,,0,0,0,,Dov'è Robin?!
