Comment: 0,0:00:00.00,0:00:00.00,Main-207+,,0,0,0,,{=69}===============================DIALOGUE============================
Dialogue: 0,0:01:52.59,0:01:54.72,Main-207+,,0,0,0,,K... K...
Dialogue: 0,0:01:57.18,0:01:57.97,Main-207+,,0,0,0,,K...
Dialogue: 0,0:01:58.68,0:02:01.23,Main-207+,,0,0,0,,Kurbağa!
Dialogue: 0,0:02:02.31,0:02:05.56,Main-207+,,0,0,0,,Bana "vırak" deme, seni pislik!
Dialogue: 0,0:02:05.56,0:02:09.53,Main-207+,,0,0,0,,Sumo şamarınla bizi raydan çıkardın!
Dialogue: 0,0:02:10.94,0:02:12.11,Flashbacks-207+,,0,0,0,,Lan, çekil, çekil!{This and next line, W7 20 @ 21:07}
Dialogue: 0,0:02:12.11,0:02:13.86,Flashbacks-207+,,0,0,0,,Çarpacağız!
Dialogue: 0,0:02:15.37,0:02:18.45,Main-207+,,0,0,0,,Neredeyse Sanjilere erişmiştik.
Dialogue: 0,0:02:18.45,0:02:20.20,Main-207+,,0,0,0,,Şimdi ne olacak?!
Dialogue: 0,0:02:22.37,0:02:24.12,Main-207+,,0,0,0,,Yetti artık!
Dialogue: 0,0:02:24.12,0:02:27.38,Main-207+,,0,0,0,,Seni çiğ çiğ yiyeceğim ulan!
Dialogue: 0,0:02:32.67,0:02:34.34,Main-207+,,0,0,0,,Of, of, of...
Dialogue: 0,0:02:34.34,0:02:37.26,Main-207+,,0,0,0,,Bu deniz trenine neler oluyor?
Dialogue: 0,0:02:37.26,0:02:39.10,Main-207+,,0,0,0,,Hey, iyi misiniz?
Dialogue: 0,0:02:42.43,0:02:44.44,Main-207+,,0,0,0,,Sanırım.
Dialogue: 0,0:02:43.64,0:02:44.44,Secondary-207+,,0,0,0,,Ay, ay...
Dialogue: 0,0:02:44.44,0:02:46.56,Main-207+,,0,0,0,,S-Sırtım...
Dialogue: 0,0:02:51.11,0:02:52.65,Main-207+,,0,0,0,,Bu da ne böyle?!
Dialogue: 0,0:02:53.03,0:02:55.32,Main-207+,,0,0,0,,Bizim kral boğalar ortada yok!
Dialogue: 0,0:02:55.32,0:02:56.45,Main-207+,,0,0,0,,– Ne?!\N– Ne?!
Dialogue: 0,0:02:56.45,0:02:58.37,Main-207+,,0,0,0,,– Kayıp mı oldular?!\N– Kayıp mı oldular?!
Dialogue: 0,0:02:58.37,0:03:00.87,Main-207+,,0,0,0,,Hayır, kaybolmadılar.
Dialogue: 0,0:03:00.87,0:03:03.41,Main-207+,,0,0,0,,Raylardan uzaklaşmış olmalıyız.
Dialogue: 0,0:03:03.41,0:03:05.71,Main-207+,,0,0,0,,– Öf! Bu daha da kötü!\N– Öf! Bu daha da kötü!
Dialogue: 0,0:03:05.71,0:03:06.79,Main-207+,,0,0,0,,Ne yapacağız?!
Dialogue: 0,0:03:06.79,0:03:08.00,Main-207+,,0,0,0,,Hey!
Dialogue: 0,0:03:08.00,0:03:08.75,Main-207+,,0,0,0,,Ha?
Dialogue: 0,0:03:09.46,0:03:11.46,Main-207+,,0,0,0,,İyi misiniz?
Dialogue: 0,0:03:11.46,0:03:15.47,Main-207+,,0,0,0,,Enies Lobby'ye hâlâ ulaşabiliriz, değil mi?!
Dialogue: 0,0:03:15.47,0:03:19.14,Main-207+,,0,0,0,,Kes şu dırdırı da bekle biraz!
Dialogue: 0,0:03:19.51,0:03:24.23,Main-207+,,0,0,0,,Tuhaf bir akıntıya girdiğimiz kesin.
Dialogue: 0,0:03:24.23,0:03:25.89,Main-207+,,0,0,0,,Neler oluyor acaba?
Dialogue: 0,0:03:25.89,0:03:26.73,Main-207+,,0,0,0,,Kokoro-{\i1}san{\i0}.
Dialogue: 0,0:03:26.73,0:03:27.48,Main-207+,,0,0,0,,Heh?
Dialogue: 0,0:03:27.85,0:03:29.90,Main-207+,,0,0,0,,Hâlâ doğru yöne mi gidiyoruz?
Dialogue: 0,0:03:29.90,0:03:30.65,Main-207+,,0,0,0,,Evet.
Dialogue: 0,0:03:30.65,0:03:36.99,Main-207+,,0,0,0,,İstasyonu olan her adanın daimi pusulası bu trende mevcut.
Dialogue: 0,0:03:37.45,0:03:38.70,Main-207+,,0,0,0,,O hâlde sorun yok.
Dialogue: 0,0:03:38.70,0:03:40.99,Main-207+,,0,0,0,,Ben denizi gözlerim, sen dümene geç!
Dialogue: 0,0:03:40.99,0:03:41.87,Main-207+,,0,0,0,,Hım?
Dialogue: 0,0:03:41.87,0:03:43.33,Main-207+,,0,0,0,,Sen...
Dialogue: 0,0:03:43.33,0:03:44.91,Main-207+,,0,0,0,,Ben mi?
Dialogue: 0,0:03:44.91,0:03:46.08,Main-207+,,0,0,0,,Rotacıyım!
Dialogue: 0,0:03:46.41,0:03:47.58,Main-207+,,0,0,0,,Öyle mi?
Dialogue: 0,0:03:47.58,0:03:50.08,Main-207+,,0,0,0,,İçim rahatladı!
Dialogue: 0,0:03:52.21,0:03:54.09,Main-207+,,0,0,0,,Oh, ondan önce...
Dialogue: 0,0:03:54.67,0:03:56.80,Main-207+,,0,0,0,,Hey, Yokozuna!
Dialogue: 0,0:03:56.80,0:03:58.59,Main-207+,,0,0,0,,Buraya gel!
Dialogue: 0,0:04:06.06,0:04:07.64,Main-207+,,0,0,0,,Zıpladı!
Dialogue: 0,0:04:12.77,0:04:15.74,Main-207+,,0,0,0,,Demek iyi olduğumuza sevindin?!
Dialogue: 0,0:04:15.74,0:04:16.86,Main-207+,,0,0,0,,Cidden...
Dialogue: 0,0:04:17.24,0:04:20.36,Main-207+,,0,0,0,,Kaçırıldığım falan yok!
Dialogue: 0,0:04:20.36,0:04:21.87,Main-207+,,0,0,0,,Hemen hükme varma!
Dialogue: 0,0:04:25.12,0:04:28.00,Thoughts-207+,,0,0,0,,Ninem Yokozuna ile konuşabiliyor mu?
Dialogue: 0,0:04:33.00,0:04:34.67,Main-207+,,0,0,0,,Ne yapıyorsunuz?
Dialogue: 0,0:04:34.67,0:04:37.88,Main-207+,,0,0,0,,Kurbağa ve nine konuşuyor.
Dialogue: 0,0:04:37.88,0:04:40.68,Main-207+,,0,0,0,,Ne?! O hâlde nine kurbağa mı?!
Dialogue: 0,0:04:40.68,0:04:43.68,Main-207+,,0,0,0,,İnsandan çok kurbağaya benzediği doğru...
Dialogue: 0,0:04:43.68,0:04:46.22,Main-207+,,0,0,0,,Bunu duyarsa kemiklerini kırar.
Dialogue: 0,0:04:46.22,0:04:47.23,Main-207+,,0,0,0,,Kırar.
Dialogue: 0,0:04:47.64,0:04:49.02,Main-207+,,0,0,0,,Hey!
Dialogue: 0,0:04:49.02,0:04:51.23,Main-207+,,0,0,0,,Hasır Şapka-{\i1}san{\i0}! Roket Adam!
Dialogue: 0,0:04:51.56,0:04:52.81,Main-207+,,0,0,0,,Görüyor musunuz?!
Dialogue: 0,0:04:52.81,0:04:54.32,Main-207+,,0,0,0,,Hayır, görmüyorum!
Dialogue: 0,0:04:54.32,0:04:57.44,Main-207+,,0,0,0,,Kahrolası koca kurbağa!
Dialogue: 0,0:04:57.44,0:05:00.07,Main-207+,,0,0,0,,Hasır Şapkaları nereye savurdu böyle?
Dialogue: 0,0:05:00.07,0:05:01.07,Main-207+,,0,0,0,,Beyler!
Dialogue: 0,0:05:01.07,0:05:02.66,Main-207+,,0,0,0,,Çene çalacak zaman değil!
Dialogue: 0,0:05:03.03,0:05:06.74,Main-207+,,0,0,0,,Franky Reis'i kurtarmak için yola düştük.
Dialogue: 0,0:05:06.74,0:05:07.79,Main-207+,,0,0,0,,Aynen öyle!
Dialogue: 0,0:05:07.79,0:05:13.54,Main-207+,,0,0,0,,Roket Adam'ı beklerken\Nbir yandan da Enies Lobby'ye yardıralım!
Dialogue: 0,0:05:13.54,0:05:16.34,Main-207+,,0,0,0,,Acele edin! Sodom, Gomorrah!
Dialogue: 0,0:05:20.68,0:05:21.51,Main-207+,,0,0,0,,Heh?!
Dialogue: 0,0:05:21.51,0:05:23.80,Main-207+,,0,0,0,,Hey, şuna bakın!
Dialogue: 0,0:05:24.39,0:05:27.81,Main-207+,,0,0,0,,Önümüzde ayrılmış başka bir vagon duruyor!
Dialogue: 0,0:05:28.35,0:05:30.27,Main-207+,,0,0,0,,Dost mu düşman mı teyit edemedim!
Dialogue: 0,0:05:30.27,0:05:31.98,Main-207+,,0,0,0,,Herkes savaşa hazır olsun!
Dialogue: 0,0:05:32.40,0:05:35.48,Main-207+,,0,0,0,,– Evet!\N– Evet!
Dialogue: 0,0:05:35.48,0:05:36.73,Main-207+,,0,0,0,,Hey!
Dialogue: 0,0:05:36.73,0:05:38.90,Main-207+,,0,0,0,,Orada kimse var mı?!
Dialogue: 0,0:05:38.90,0:05:40.53,Main-207+,,0,0,0,,Karşınızda Franky Ailesi var!
Dialogue: 0,0:05:40.53,0:05:42.41,Main-207+,,0,0,0,,Çıkın ortaya!
Dialogue: 0,0:05:43.28,0:05:45.32,Main-207+,,0,0,0,,Hey, biri çıktı!
Dialogue: 0,0:05:49.83,0:05:51.41,Main-207+,,0,0,0,,Y-Yaşıyor mu?!
Dialogue: 0,0:05:51.96,0:05:55.13,Main-207+,,0,0,0,,Cidden... Doğru mu?
Dialogue: 0,0:05:55.59,0:05:58.59,Main-207+,,0,0,0,,Evet, öyle dediler.
Dialogue: 0,0:05:59.51,0:06:00.97,Main-207+,,0,0,0,,Demek öyle...
Dialogue: 0,0:06:02.09,0:06:03.76,Main-207+,,0,0,0,,Yani...
Dialogue: 0,0:06:04.18,0:06:05.68,Main-207+,,0,0,0,,Kahrolası Aptalburg!
Dialogue: 0,0:06:05.68,0:06:07.72,Main-207+,,0,0,0,,Geberdiğinden emindim!
Dialogue: 0,0:06:07.72,0:06:08.97,Main-207+,,0,0,0,,Cidden...
Dialogue: 0,0:06:08.97,0:06:10.06,Main-207+,,0,0,0,,Şükürler olsun.
Dialogue: 0,0:06:10.06,0:06:14.23,Main-207+,,0,0,0,,CP9 onun işini bitirdiğini düşünüyor olmalı.
Dialogue: 0,0:06:14.23,0:06:16.69,Main-207+,,0,0,0,,Bu konuda ağzını açmasan iyi olur.
Dialogue: 0,0:06:19.48,0:06:20.86,Main-207+,,0,0,0,,Bak sen.
Dialogue: 0,0:06:20.86,0:06:22.82,Main-207+,,0,0,0,,Demek iyi de olabiliyorsun!
Dialogue: 0,0:06:27.58,0:06:29.08,Main-207+,,0,0,0,,Sonuçta...
Dialogue: 0,0:06:29.70,0:06:33.92,Main-207+,,0,0,0,,hükûmet aradığı iki anahtarı da ele geçirdi:
Dialogue: 0,0:06:34.46,0:06:37.88,Main-207+,,0,0,0,,Silahı uyandıracak uzmanlığa sahip olan seni...
Dialogue: 0,0:06:38.38,0:06:43.13,Main-207+,,0,0,0,,ve onu inşa edecek planlara sahip olan beni.
Dialogue: 0,0:06:44.68,0:06:49.60,Main-207+,,0,0,0,,O güç gerçekten ortaya çıktığında...
Dialogue: 0,0:06:50.06,0:06:53.52,Main-207+,,0,0,0,,hükûmetin bu korsan çağının\Nkökünü kazıyacağına kalıbımı basarım!
Dialogue: 0,0:06:54.19,0:06:59.36,Main-207+,,0,0,0,,Ardından bu askeri gücü kimse durduramayacak ve dünyayı yok edecek!
Dialogue: 0,0:06:59.36,0:07:02.99,Main-207+,,0,0,0,,Antik silahlar bu kadar korkunç işte.
Dialogue: 0,0:07:03.53,0:07:07.78,Main-207+,,0,0,0,,Ustam, böyle saçma bir gelecek\Niçin planları koruyarak...
Dialogue: 0,0:07:08.32,0:07:12.37,Main-207+,,0,0,0,,hayatını feda etmedi!
Dialogue: 0,0:07:13.96,0:07:18.50,Main-207+,,0,0,0,,Yani, yalnız kaçmamın bir anlamı yok.
Dialogue: 0,0:07:18.50,0:07:21.96,Main-207+,,0,0,0,,Bir şekilde, sen de\NHasır Şapkalara geri dönmelisin!
Dialogue: 0,0:07:21.96,0:07:23.21,Main-207+,,0,0,0,,Dönemem.
Dialogue: 0,0:07:24.13,0:07:27.64,Main-207+,,0,0,0,,Sırf yanlarında durmam bile\Nonlara kötülük getiriyor.
Dialogue: 0,0:07:30.05,0:07:32.89,Main-207+,,0,0,0,,Onlara kötülük eden sen değilsin ki.
Dialogue: 0,0:07:32.89,0:07:37.27,Main-207+,,0,0,0,,Hükûmet senin varlığını günah saysa da...
Dialogue: 0,0:07:37.27,0:07:43.28,Main-207+,,0,0,0,,ne kadar tehlikeli olursan ol,\Nyaşamak senin de hakkın.
Dialogue: 0,0:07:44.78,0:07:49.91,Flashbacks-207+,,0,0,0,,Ne tür bir gemi olursa olsun, gemi yapımında...{W7 13 - 13:24}
Dialogue: 0,0:07:49.91,0:07:52.58,Flashbacks-207+,,0,0,0,,iyi ya da kötü diye bir şey yoktur!
Dialogue: 0,0:07:53.49,0:07:55.54,Main-207+,,0,0,0,,Bu yüzden...
Dialogue: 0,0:07:56.33,0:07:59.00,Flashbacks-207+,,0,0,0,,Var olması bile büyük bir günah.{W7 20 - 17:20}
Dialogue: 0,0:07:59.00,0:08:00.38,Main-207+,,0,0,0,,Hayır!
Dialogue: 0,0:08:01.00,0:08:04.42,Main-207+,,0,0,0,,Varlığın günah falan değil!
Dialogue: 0,0:08:15.14,0:08:17.85,Main-207+,,0,0,0,,Cidden, vücuduna ne olmuş böyle?
Dialogue: 0,0:08:18.31,0:08:20.52,Main-207+,,0,0,0,,Her yerin yara bere içinde!
Dialogue: 0,0:08:20.52,0:08:22.19,Main-207+,,0,0,0,,Tam sekiz yıldır,
Dialogue: 0,0:08:22.94,0:08:29.32,Main-207+,,0,0,0,,Tom-{\i1}san{\i0}'ı götürdüklerinden beri...
Dialogue: 0,0:08:29.74,0:08:34.66,Main-207+,,0,0,0,,şu trene kafa tutuyorsun!
Dialogue: 0,0:08:46.01,0:08:49.43,Main-207+,,0,0,0,,Daha mı güçlü olmak istiyordun?
Dialogue: 0,0:08:50.47,0:08:54.56,Main-207+,,0,0,0,,Artık sevdiklerini kaybetmeye dayanamıyordun.
Dialogue: 0,0:08:54.97,0:08:58.81,Main-207+,,0,0,0,,Sadece sevdiklerini korumak istedin!
Dialogue: 0,0:09:00.73,0:09:02.15,Main-207+,,0,0,0,,Yokozuna,
Dialogue: 0,0:09:02.15,0:09:07.07,Main-207+,,0,0,0,,artık çalışmalarının sonucunu gösterme vakti!
Dialogue: 0,0:09:09.53,0:09:15.66,Main-207+,,0,0,0,,Sevgili Franky'in, Tom-{\i1}san{\i0}'ın götürüldüğü gibi götürüldü.
Dialogue: 0,0:09:16.87,0:09:20.50,Main-207+,,0,0,0,,Bu tren, şu an Franky'yi kurtarmaya gidiyor!
Dialogue: 0,0:09:21.58,0:09:24.04,Main-207+,,0,0,0,,Bize katılmak ister misin?{Used as Flashback for Enies Lobby 23 @timestamp 05:15}
Dialogue: 0,0:09:28.63,0:09:30.13,Main-207+,,0,0,0,,Hasır Şapka!
Dialogue: 0,0:09:30.13,0:09:33.01,Main-207+,,0,0,0,,Bir dostumuz daha katıldı!
Dialogue: 0,0:09:33.01,0:09:34.60,Main-207+,,0,0,0,,İyi bakalım, güzel!
Dialogue: 0,0:09:36.22,0:09:38.47,Main-207+,,0,0,0,,Canavar nine yine yaptı yapacağını!
Dialogue: 0,0:09:38.47,0:09:40.81,Main-207+,,0,0,0,,Yoksa kurbağa nine mi demeliydim?
Dialogue: 0,0:09:40.81,0:09:43.02,Main-207+,,0,0,0,,Hangisi olsun?
Dialogue: 0,0:09:45.90,0:09:48.32,Main-207+,,0,0,0,,Kimin umurunda?
Dialogue: 0,0:09:48.32,0:09:51.78,Main-207+,,0,0,0,,Kokoro-{\i1}san{\i0}! Saat sekiz yönünde\Ngüzel bir akıntı buldum!
Dialogue: 0,0:09:51.78,0:09:53.16,Main-207+,,0,0,0,,Pekâlâ!
Dialogue: 0,0:09:53.16,0:09:56.33,Main-207+,,0,0,0,,Çok fazla zaman kaybettik,
Dialogue: 0,0:09:56.33,0:09:59.33,Main-207+,,0,0,0,,hadi telafi edelim!
Dialogue: 0,0:09:59.33,0:10:02.16,Main-207+,,0,0,0,,Gidelim, kurbağa!
Dialogue: 0,0:10:07.96,0:10:09.34,Main-207+,,0,0,0,,CP9 geldi!
Dialogue: 0,0:10:09.34,0:10:10.55,Main-207+,,0,0,0,,Acele edin!
Dialogue: 0,0:10:11.26,0:10:13.59,Main-207+,,0,0,0,,Tebrikler CP9, iyi iş çıkardınız!
Dialogue: 0,0:10:13.59,0:10:16.47,Main-207+,,0,0,0,,Suçluları dışarı çıkarın!\N1 numaralı vagondalar!
Dialogue: 0,0:10:19.52,0:10:20.85,Main-207+,,0,0,0,,Seni piç kurusu!
Dialogue: 0,0:10:20.85,0:10:23.52,Main-207+,,0,0,0,,Bana nazik davran, gerzek!
Dialogue: 0,0:10:20.43,0:10:21.93,Secondary-207+,,0,0,0,,Yapma!
Dialogue: 0,0:10:23.52,0:10:25.86,Main-207+,,0,0,0,,Kim olduğumu sanıyorsun?!
Dialogue: 0,0:10:26.23,0:10:28.65,Main-207+,,0,0,0,,Hey! Bu tarafa yanaşma!
Dialogue: 0,0:10:28.65,0:10:30.48,Main-207+,,0,0,0,,Dikkatli olun, bu ısırıyor!
Dialogue: 0,0:10:33.03,0:10:35.24,Main-207+,,0,0,0,,Tam bir baş belası.
Dialogue: 0,0:10:41.95,0:10:43.71,Main-207+,,0,0,0,,Tam da beklediğim gibiler.
Dialogue: 0,0:10:43.71,0:10:45.58,Main-207+,,0,0,0,,Bayağı göz korkutucular.
Dialogue: 0,0:10:46.17,0:10:48.71,Main-207+,,0,0,0,,Bahsedilen Cutty Flam o mu?
Dialogue: 0,0:10:48.71,0:10:51.05,Main-207+,,0,0,0,,Öyleyse o kadın da...
Dialogue: 0,0:10:51.63,0:10:52.76,Main-207+,,0,0,0,,Nico Robin olmalı?!
Dialogue: 0,0:10:52.76,0:10:54.84,Main-207+,,0,0,0,,Bu ne güzellik!
Dialogue: 0,0:10:55.43,0:10:57.43,Main-207+,,0,0,0,,Ana kapıyı açın!
Dialogue: 0,0:11:17.45,0:11:18.66,Main-207+,,0,0,0,,Çüş lan!
Dialogue: 0,0:11:18.66,0:11:20.70,Main-207+,,0,0,0,,Bu yer de ne böyle?!
Dialogue: 0,0:11:30.00,0:11:32.55,Main-207+,,0,0,0,,Bu... şelale mi?
Dialogue: 0,0:11:40.60,0:11:43.77,Main-207+,,0,0,0,,Dibini göremiyorum!
Dialogue: 0,0:11:43.77,0:11:46.10,Main-207+,,0,0,0,,Amma kafa ütüledin be!
Dialogue: 0,0:11:51.19,0:11:55.07,Main-207+,,0,0,0,,Lucci ve diğerleri bize doğru geliyor,
Dialogue: 0,0:11:59.45,0:12:04.75,Main-207+,,0,0,0,,üstelik elleri de boş değil!
Dialogue: 0,0:12:07.00,0:12:08.33,Main-207+,,0,0,0,,Şimdi...
Dialogue: 0,0:12:08.83,0:12:11.00,Main-207+,,0,0,0,,bugün harika bir gün.
Dialogue: 0,0:12:11.00,0:12:14.13,Main-207+,,0,0,0,,Ben dahil sekiz CP9 üyesinin hepsi,
Dialogue: 0,0:12:14.13,0:12:17.93,Main-207+,,0,0,0,,tam beş yılın ardından\Nilk defa bir araya geliyoruz!
Dialogue: 0,0:12:17.93,0:12:20.55,Main-207+,,0,0,0,,Ama bu yazı de ne demek oluyor?!
Dialogue: 0,0:12:22.14,0:12:25.22,Main-207+,,0,0,0,,Göreviniz sadece\Nüç Devrim Ordusu liderini öldürmekti,
Dialogue: 0,0:12:25.22,0:12:28.48,Main-207+,,0,0,0,,nasıl becerdiyseniz...
Dialogue: 0,0:12:28.48,0:12:31.02,Main-207+,,0,0,0,,23 kişiyi birden indirmişsiniz!
Dialogue: 0,0:12:31.02,0:12:33.11,Main-207+,,0,0,0,,Mazeretlerinizi duyalım bakalım!
Dialogue: 0,0:12:35.32,0:12:39.91,Main-207+,,0,0,0,,{\an8}Özürlerimi sunarım, Başkan!
Dialogue: 0,0:12:39.91,0:12:44.41,Main-207+,,0,0,0,,{\an8}Kabahat tamamen...
Dialogue: 0,0:12:44.41,0:12:46.29,Main-207+,,0,0,0,,{\an8}benim!
Dialogue: 0,0:12:46.29,0:12:48.04,Main-207+,,0,0,0,,{\an8}Kes şunu, Kumadori!
Dialogue: 0,0:12:48.04,0:12:50.50,Main-207+,,0,0,0,,{\an8}Bir erkek başını o kadar kolay eğmemeli!
Dialogue: 0,0:12:51.00,0:12:54.96,Main-207+,,0,0,0,,{\an8}Başkana ben açıklarım,\Nsiz sesinizi çıkarmayın yeter!
Dialogue: 0,0:12:56.34,0:12:58.22,Main-207+,,0,0,0,,{\an8}Gerçekten üzgünüm, Başkan!
Dialogue: 0,0:12:58.22,0:13:00.43,Main-207+,,0,0,0,,{\an8}İşler o noktaya kadar gelirse...
Dialogue: 0,0:13:00.80,0:13:04.14,Main-207+,,0,0,0,,{\i1}seppuku{\i0} yapıp tüm sorumluluğu üstleneceğim!
Dialogue: 0,0:13:04.14,0:13:05.56,Main-207+,,0,0,0,,Salak salak konuşmasana!
Dialogue: 0,0:13:06.18,0:13:07.60,Main-207+,,0,0,0,,Öyle değil, Başkan!
Dialogue: 0,0:13:07.98,0:13:12.23,Main-207+,,0,0,0,,Planlandığı gibi suikasti gerçekleştirmek üzereydik...
Dialogue: 0,0:13:12.23,0:13:15.02,Main-207+,,0,0,0,,ama nasıl olduysa planımız sızdırılmış!
Dialogue: 0,0:13:15.02,0:13:18.32,Main-207+,,0,0,0,,Suikast planından şehirde bahsetmiştim!
Dialogue: 0,0:13:19.65,0:13:22.87,Main-207+,,0,0,0,,Ne? Yine mi sen, Fukuro?!
Dialogue: 0,0:13:22.87,0:13:25.37,Main-207+,,0,0,0,,Ağzındaki fermuar ne işe yarıyor be?!
Dialogue: 0,0:13:25.37,0:13:28.04,Main-207+,,0,0,0,,Şu gevşek ağzını sahip çıkacak mısın artık?!
Dialogue: 0,0:13:28.04,0:13:30.58,Main-207+,,0,0,0,,Biz çok gizli bir istihbarat teşkilatıyız!
Dialogue: 0,0:13:30.58,0:13:32.12,Main-207+,,0,0,0,,Kazara bahsettim.
Dialogue: 0,0:13:33.13,0:13:34.75,Main-207+,,0,0,0,,Bana "{\i1}cha-pa-pa{\i0}" deme!
Dialogue: 0,0:13:36.59,0:13:40.30,Main-207+,,0,0,0,,Lütfen onu suçlama!
Dialogue: 0,0:13:40.67,0:13:45.05,Main-207+,,0,0,0,,Tüm sorumluluğu üstlenip {\i1}seppuku{\i0} yapacağım.
Dialogue: 0,0:13:45.39,0:13:46.68,Main-207+,,0,0,0,,{\fad(150,150)}Demir Vücut.
Dialogue: 0,0:13:48.43,0:13:51.14,Main-207+,,0,0,0,,Ne kadar acı! Ölemiyorum.
Dialogue: 0,0:13:51.14,0:13:54.69,Main-207+,,0,0,0,,Bir an önce geber, seni embesil!
Dialogue: 0,0:13:57.52,0:13:59.49,Main-207+,,0,0,0,,Bu kadar yeter, beyler.
Dialogue: 0,0:14:00.36,0:14:04.03,Main-207+,,0,0,0,,Of be! Kahvemi döktüm! Kahretsin!
Dialogue: 0,0:14:04.03,0:14:06.74,Main-207+,,0,0,0,,Nero'nun hiçbir işe yaramadığını da duydum!
Dialogue: 0,0:14:07.33,0:14:08.12,Main-207+,,0,0,0,,Aman be.
Dialogue: 0,0:14:14.00,0:14:15.58,Main-207+,,0,0,0,,Acele edin!
Dialogue: 0,0:14:15.58,0:14:17.84,Main-207+,,0,0,0,,Daha hızlı gidemez miyiz?
Dialogue: 0,0:14:23.22,0:14:28.68,Main-207+,,0,0,0,,Yani Franky Reis bizim için\Nkendini mi feda etti?
Dialogue: 0,0:14:29.52,0:14:31.68,Main-207+,,0,0,0,,Evet, öyle oldu.
Dialogue: 0,0:14:32.52,0:14:35.27,Main-207+,,0,0,0,,Robin-{\i1}chan{\i0}'ı kurtarmaya çalışıyordu.
Dialogue: 0,0:14:40.82,0:14:44.32,Main-207+,,0,0,0,,Reisimiz gerçekten harika biri!
Dialogue: 0,0:14:45.20,0:14:48.20,Main-207+,,0,0,0,,Acele etmeliyiz yoksa geç kalacağız.
Dialogue: 0,0:14:50.12,0:14:54.29,Main-207+,,0,0,0,,Hey, bakın! Asla gece olmayan ada,\NEnies Lobby'nin ışığı!
Dialogue: 0,0:14:55.71,0:14:57.96,Main-207+,,0,0,0,,Ne?! Cidden mi? Pekâlâ!
Dialogue: 0,0:14:57.96,0:14:59.96,Main-207+,,0,0,0,,Reisimizi kurtarmaya gidelim!
Dialogue: 0,0:15:01.71,0:15:02.67,Main-207+,,0,0,0,,Gecesi olmayan mı?
Dialogue: 0,0:15:02.67,0:15:05.72,Main-207+,,0,0,0,,Aynen. Bu adada hiç gece olmaz.
Dialogue: 0,0:15:05.72,0:15:07.22,Main-207+,,0,0,0,,Gündüz adası diyoruz!
Dialogue: 0,0:15:07.22,0:15:09.81,Main-207+,,0,0,0,,Bu, Yargı Adası!
Dialogue: 0,0:15:12.31,0:15:13.77,Main-207+,,0,0,0,,Buldum onları!
Dialogue: 0,0:15:14.27,0:15:16.40,Main-207+,,0,0,0,,Kral boğaları!
Dialogue: 0,0:15:16.40,0:15:19.27,Main-207+,,0,0,0,,Ahoy!
Dialogue: 0,0:15:22.73,0:15:24.03,Main-207+,,0,0,0,,– Luffy!\N– Luffy!
Dialogue: 0,0:15:24.40,0:15:27.28,Main-207+,,0,0,0,,Oo! Sanji!
Dialogue: 0,0:15:27.95,0:15:29.83,Main-207+,,0,0,0,,Yanındaki de kim?
Dialogue: 0,0:15:28.82,0:15:30.95,Main-207+,,0,0,0,,{\an8}Epey zaman oldu.
Dialogue: 0,0:15:30.95,0:15:34.71,Main-207+,,0,0,0,,Hasır Şapka-{\i1}san{\i0}!
Dialogue: 0,0:15:37.54,0:15:39.96,Main-207+,,0,0,0,,Raylara geri döndük.
Dialogue: 0,0:15:39.96,0:15:43.92,Main-207+,,0,0,0,,Dünya Hükûmeti'nin kapılarına dayanmaya\Nepey niyetliler sanki!
Dialogue: 0,0:15:43.92,0:15:46.01,Main-207+,,0,0,0,,{\i1}Bu umut verici işte!
Dialogue: 0,0:15:51.10,0:15:54.43,Main-207+,,0,0,0,,Pekâlâ! Enies Lobby sonunda göründü!
Dialogue: 0,0:15:54.43,0:15:57.69,Main-207+,,0,0,0,,Herkes nihai savaşa hazır olsun!
Dialogue: 0,0:16:08.28,0:16:10.99,Main-207+,,0,0,0,,– Keskin Nişancı Adası'ndan Sogeking mi?\N– Keskin Nişancı Adası'ndan Sogeking mi?
Dialogue: 0,0:16:12.20,0:16:13.45,Main-207+,,0,0,0,,Aynen öyle.
Dialogue: 0,0:16:13.45,0:16:15.25,Main-207+,,0,0,0,,Usopp-{\i1}kun{\i0}'un en yakın dostuyum.
Dialogue: 0,0:16:15.25,0:16:18.46,Main-207+,,0,0,0,,Yolculuğunuzda size destek olmak için geldim.
Dialogue: 0,0:16:18.46,0:16:20.42,Main-207+,,0,0,0,,B-Bir kahraman!
Dialogue: 0,0:16:20.75,0:16:24.00,Main-207+,,0,0,0,,Pelerini olduğu için başından beri biliyordum!
Dialogue: 0,0:16:24.00,0:16:26.51,Main-207+,,0,0,0,,Müthiş! İlk kez bir kahraman görüyorum!
Dialogue: 0,0:16:26.51,0:16:29.64,Main-207+,,0,0,0,,Anladım! Pelerin taktığı için mi kahraman?
Dialogue: 0,0:16:29.64,0:16:32.47,Main-207+,,0,0,0,,Aynen öyle! Pelerin eşittir kahraman!
Dialogue: 0,0:16:32.47,0:16:33.31,Main-207+,,0,0,0,,Cidden mi?!
Dialogue: 0,0:16:33.31,0:16:36.68,Secondary-207+,,0,0,0,,{\an8}Aynen öyle, pelerini olan biri\Ngenelde kahraman olur.
Dialogue: 0,0:16:33.89,0:16:35.27,Main-207+,,0,0,0,,Usopp değil mi o?
Dialogue: 0,0:16:35.27,0:16:37.64,Main-207+,,0,0,0,,Usopp! İyi olmasına sevindim.
Dialogue: 0,0:16:37.64,0:16:41.40,Main-207+,,0,0,0,,Franky Evi'ne dalan\Nşu uzun burunlu herif!
Dialogue: 0,0:16:41.40,0:16:44.40,Main-207+,,0,0,0,,Reisle birlikte yakalanan uzun burun.
Dialogue: 0,0:16:44.40,0:16:45.69,Main-207+,,0,0,0,,Aynen o.
Dialogue: 0,0:16:45.69,0:16:47.11,Main-207+,,0,0,0,,M-Memnun oldum!
Dialogue: 0,0:16:47.11,0:16:48.49,Main-207+,,0,0,0,,Ben de.
Dialogue: 0,0:16:48.49,0:16:51.24,Main-207+,,0,0,0,,Vardiya İstasyonu'ndaki abi.
Dialogue: 0,0:16:52.07,0:16:53.99,Main-207+,,0,0,0,,Bir imzanızı alabilir miyim?
Dialogue: 0,0:16:53.28,0:16:53.99,Secondary-207+,,0,0,0,,Tabii.
Dialogue: 0,0:16:56.29,0:16:57.79,Main-207+,,0,0,0,,Peki o zaman...
Dialogue: 0,0:16:57.79,0:17:00.00,Main-207+,,0,0,0,,Usopp nereye gitti?
Dialogue: 0,0:17:00.00,0:17:03.50,Main-207+,,0,0,0,,O güvende. Endişelenmenize hiç gerek yok.
Dialogue: 0,0:17:03.50,0:17:08.97,Main-207+,,0,0,0,,Neyse, tüm gücümüzü şimdilik Robin-{\i1}kun{\i0}'u\Nkurtarmaya odaklamamızı söyledi.
Dialogue: 0,0:17:08.97,0:17:10.72,Main-207+,,0,0,0,,Kesinlikle haklı!
Dialogue: 0,0:17:10.72,0:17:12.14,Main-207+,,0,0,0,,B-Bu...
Dialogue: 0,0:17:12.14,0:17:14.35,Main-207+,,0,0,0,,Keskin Nişancı Adası nerede?
Dialogue: 0,0:17:14.35,0:17:15.76,Main-207+,,0,0,0,,Şey...
Dialogue: 0,0:17:16.14,0:17:17.22,Main-207+,,0,0,0,,Orası...
Dialogue: 0,0:17:17.22,0:17:20.56,Main-207+,,0,0,0,,{\an8\fad(150,150)\bord2.9\shad2\fs75\b1}♪ Keskin Nişancı Adası'dır... {W7 18 - 00:19}
Dialogue: 0,0:17:21.77,0:17:22.98,Main-207+,,0,0,0,,...kalplerinizin...
Dialogue: 0,0:17:23.81,0:17:25.19,Main-207+,,0,0,0,,içinde.
Dialogue: 0,0:17:26.65,0:17:29.36,Main-207+,,0,0,0,,{\an8\fad(150,150)\bord2.9\shad2\fs75\b1}...benim...
Dialogue: 0,0:17:27.61,0:17:28.90,Main-207+,,0,0,0,,Kalplerimizde!
Dialogue: 0,0:17:30.24,0:17:33.87,Main-207+,,0,0,0,,{\an8\fad(150,150)\bord2.9\shad2\fs75\b1}vatanım. ♪
Dialogue: 0,0:17:33.87,0:17:34.66,Main-207+,,0,0,0,,Tam neresi?!
Dialogue: 0,0:17:34.66,0:17:38.45,Secondary-207+,,0,0,0,,{\an8\fad(150,150)\bord2.9\shad2\fs75\b1}– ♪ Keskin Nişancı Adası'dır...\N– ♪ Keskin Nişancı Adası'dır...
Dialogue: 0,0:17:38.45,0:17:41.08,Secondary-207+,,0,0,0,,{\an8\fad(150,150)\bord2.9\shad2\fs75\b1}...benim vatanım. ♪
Dialogue: 0,0:17:41.08,0:17:41.79,Secondary-207+,,0,0,0,,{\an8}Hadi!
Dialogue: 0,0:17:41.79,0:17:44.79,Secondary-207+,,0,0,0,,{\an8\fad(150,150)\bord2.9\shad2\fs75\b1}– ...benim vatanım. ♪\N– ...benim vatanım. ♪
Dialogue: 0,0:17:44.79,0:17:45.63,Secondary-207+,,0,0,0,,{\an8}Hadi!
Dialogue: 0,0:17:45.63,0:17:46.84,Secondary-207+,,0,0,0,,{\an8\fad(150,150)\bord2.9\shad2\fs75\b1}♪ On ikiden...
Dialogue: 0,0:17:46.84,0:17:47.34,Secondary-207+,,0,0,0,,{\an8}Hadi!
Dialogue: 0,0:17:47.34,0:17:49.05,Secondary-207+,,0,0,0,,{\an8\fad(150,150)\bord2.9\shad2\fs75\b1}– ♪ On ikiden... \N– ♪ On ikiden...
Dialogue: 0,0:17:49.05,0:17:49.59,Secondary-207+,,0,0,0,,{\an8\fad(150,150)\bord2.9\shad2\fs75\b1}...vurmaktır...
Dialogue: 0,0:17:49.59,0:17:49.97,Secondary-207+,,0,0,0,,{\an8}Hadi!
Dialogue: 0,0:17:49.97,0:17:50.76,Secondary-207+,,0,0,0,,{\an8\fad(150,150)\bord2.9\shad2\fs75\b1}– ...vurmaktır...\N– ...vurmaktır...
Dialogue: 0,0:17:50.76,0:17:51.22,Secondary-207+,,0,0,0,,{\an8\fad(150,150)\bord2.9\shad2\fs75\b1}...şanım! ♪
Dialogue: 0,0:17:51.22,0:17:51.55,Secondary-207+,,0,0,0,,{\an8}Hadi!
Dialogue: 0,0:17:51.55,0:17:52.18,Secondary-207+,,0,0,0,,{\an8\fad(150,150)\bord2.9\shad2\fs75\b1}– ...şanım! ♪\N– ...şanım! ♪
Dialogue: 0,0:17:44.59,0:17:45.25,Main-207+,,0,0,0,,Nami-{\i1}san{\i0}...
Dialogue: 0,0:17:45.25,0:17:46.50,Main-207+,,0,0,0,,Hım?
Dialogue: 0,0:17:46.50,0:17:48.17,Main-207+,,0,0,0,,Ne oldu, Sanji-{\i1}kun{\i0}?
Dialogue: 0,0:17:49.34,0:17:52.18,Main-207+,,0,0,0,,...ve Nami-{\i1}san{\i0} dışındaki aptallar.
Dialogue: 0,0:17:52.18,0:17:52.68,Main-207+,,0,0,0,,Heh?
Dialogue: 0,0:17:52.68,0:17:56.26,Main-207+,,0,0,0,,Gidip Robin-{\i1}chan{\i0}'ı kurtarmadan önce\Naz kulak verin.
Dialogue: 0,0:18:03.65,0:18:05.02,Main-207+,,0,0,0,,Durum bu.
Dialogue: 0,0:18:05.02,0:18:09.61,Main-207+,,0,0,0,,Robin'in karanlık geçmişi, CP9'ın elinde bir koz.
Dialogue: 0,0:18:10.19,0:18:12.99,Main-207+,,0,0,0,,Onu kaderine terk edelim demiyorum tabii.
Dialogue: 0,0:18:13.53,0:18:16.28,Main-207+,,0,0,0,,Oraya kadar gitsek de...
Dialogue: 0,0:18:16.28,0:18:19.95,Main-207+,,0,0,0,,Robin-{\i1}chan{\i0}'ın\N"gelin beni kurtarın" diyeceği şüpheli.
Dialogue: 0,0:18:21.46,0:18:23.62,Main-207+,,0,0,0,,Bunların hiçbir önemi yok!
Dialogue: 0,0:18:23.62,0:18:26.63,Main-207+,,0,0,0,,Buna pabuç bırakacak değilim!
Dialogue: 0,0:18:28.13,0:18:29.09,Main-207+,,0,0,0,,Robin aptalı!
Dialogue: 0,0:18:29.09,0:18:30.67,Main-207+,,0,0,0,,Niye öyle dedin?!
Dialogue: 0,0:18:31.01,0:18:32.51,Main-207+,,0,0,0,,Derim tabii!
Dialogue: 0,0:18:32.51,0:18:35.05,Main-207+,,0,0,0,,Neden kurtarılmak istemiyormuş ulan?!
Dialogue: 0,0:18:35.43,0:18:39.43,Main-207+,,0,0,0,,Onu kurtardıktan sonra başımıza bir şey gelmesinden korkuyor!
Dialogue: 0,0:18:39.43,0:18:40.97,Main-207+,,0,0,0,,Vız gelir tırıs gider!
Dialogue: 0,0:18:41.39,0:18:43.77,Main-207+,,0,0,0,,Hiçbir şey yapmazsak öldürülecek, değil mi?
Dialogue: 0,0:18:43.77,0:18:46.23,Main-207+,,0,0,0,,Canına susamış değil ya, gidip alacağız onu!
Dialogue: 0,0:18:46.69,0:18:48.94,Main-207+,,0,0,0,,Elbette öyle ama...
Dialogue: 0,0:18:48.94,0:18:50.07,Main-207+,,0,0,0,,Sal gitsin.
Dialogue: 0,0:18:50.07,0:18:52.94,Main-207+,,0,0,0,,Artık ok yaydan çıktı, dönüş yok.
Dialogue: 0,0:18:53.53,0:18:54.99,Main-207+,,0,0,0,,Sadece onu kurtarmalıyız.
Dialogue: 0,0:18:54.99,0:18:57.57,Main-207+,,0,0,0,,Orayı onlara dar edeceğim!{Used as flashback in Enies Lobby 05 @05:20}
Dialogue: 0,0:18:58.16,0:19:00.54,Main-207+,,0,0,0,,Denemek istediğim yeni bir tekniğim var.
Dialogue: 0,0:19:05.92,0:19:08.00,Main-207+,,0,0,0,,Biraz buraya bakın.
Dialogue: 0,0:19:08.34,0:19:12.17,Main-207+,,0,0,0,,Bir ara rayların bakımı için\NEnies Lobby'ye yolum düşmüştü.
Dialogue: 0,0:19:12.51,0:19:15.01,Main-207+,,0,0,0,,Hatırladığım ne varsa döktüm kağıda.
Dialogue: 0,0:19:15.59,0:19:18.26,Main-207+,,0,0,0,,Enies Lobby'nin kaba bir taslağı bu.
Dialogue: 0,0:19:23.85,0:19:29.31,Main-207+,,0,0,0,,Adalet Kapıları'na varmak için\NAdalet Kulesi'ni geçmek şart.
Dialogue: 0,0:19:29.31,0:19:31.69,Main-207+,,0,0,0,,O da ne? O siyah şey?
Dialogue: 0,0:19:31.69,0:19:33.49,Main-207+,,0,0,0,,Siyah yer bir şelale.
Dialogue: 0,0:19:33.49,0:19:34.82,Main-207+,,0,0,0,,Şelale mi?
Dialogue: 0,0:19:34.82,0:19:36.99,Main-207+,,0,0,0,,Kapıdan geçtiğimizde anlayacaksınız.
Dialogue: 0,0:19:37.45,0:19:40.70,Main-207+,,0,0,0,,Robin'le Franky'yi şu iki kapı arasında\Nkurtardık kurtardık,
Dialogue: 0,0:19:40.70,0:19:44.66,Main-207+,,0,0,0,,yoksa hepimiz hapı yutarız!
Dialogue: 0,0:19:45.00,0:19:46.16,Main-207+,,0,0,0,,Niye be?!
Dialogue: 0,0:19:46.16,0:19:50.21,Main-207+,,0,0,0,,Robin nereye götürülürse götürülsün,\Nonu kurtarana dek peşinden gitmeliyiz!
Dialogue: 0,0:19:50.21,0:19:53.00,Main-207+,,0,0,0,,Water Seven'da ayrılmadan anlatmıştım ya!
Dialogue: 0,0:19:53.00,0:19:57.88,Main-207+,,0,0,0,,O kapıların arkası, ya Denizci Karargâhı'na\Nya da sualtı hapishanesine çıkıyor.
Dialogue: 0,0:19:58.26,0:20:02.56,Main-207+,,0,0,0,,Ne olursa olsun,\Nonlar oraya varmadan bu işi bitirmeliyiz!
Dialogue: 0,0:20:02.56,0:20:04.56,Main-207+,,0,0,0,,Aynen öyle.
Dialogue: 0,0:20:04.56,0:20:08.10,Main-207+,,0,0,0,,Ama hepimiz adaya çıksak bile,
Dialogue: 0,0:20:08.10,0:20:11.82,Main-207+,,0,0,0,,CP9 karşısında gerçekten kazanma şansı olanlar...
Dialogue: 0,0:20:11.82,0:20:13.48,Main-207+,,0,0,0,,sizsiniz.
Dialogue: 0,0:20:13.48,0:20:17.15,Main-207+,,0,0,0,,Trende gördüklerim yetti;\Nhepiniz harbi güçlüymüşsünüz.
Dialogue: 0,0:20:17.15,0:20:20.49,Main-207+,,0,0,0,,Kısaca beş dakika geride bekleyip...
Dialogue: 0,0:20:20.49,0:20:24.12,Main-207+,,0,0,0,,Roket Adam'la ana girişten yardırmanızı istiyoruz!
Dialogue: 0,0:20:24.12,0:20:28.33,Main-207+,,0,0,0,,Önce biz önden dalıp\Nkapıları size ardına kadar açacağız.
Dialogue: 0,0:20:28.33,0:20:30.71,Main-207+,,0,0,0,,Trenin önü açılır böylece.
Dialogue: 0,0:20:31.13,0:20:36.59,Main-207+,,0,0,0,,Daha sonra kaçımız düşersek düşelim,\Ndevam etmenizi istiyoruz.
Dialogue: 0,0:20:38.72,0:20:41.22,Main-207+,,0,0,0,,60 küsur kişiyiz...
Dialogue: 0,0:20:41.22,0:20:44.56,Main-207+,,0,0,0,,ama karşı taraf,\Nrahat 2.000 ya da 3.000 kişi vardır.
Dialogue: 0,0:20:45.43,0:20:50.98,Main-207+,,0,0,0,,Siz sadece CP9'a odaklanın,\Nboş heriflerle vakit kaybetmeyin!
Dialogue: 0,0:20:50.98,0:20:52.98,Main-207+,,0,0,0,,Tamam, anladım.
Dialogue: 0,0:20:52.98,0:20:54.48,Main-207+,,0,0,0,,{\i1}Pekâlâ, çocuklar!
Dialogue: 0,0:20:54.48,0:20:57.15,Main-207+,,0,0,0,,{\i1}Sonunda adanın dibine vardık!
Dialogue: 0,0:20:57.15,0:21:01.07,Main-207+,,0,0,0,,Enies Lobby'nin arkasındaki gökyüzüne iyi bakın.
Dialogue: 0,0:21:02.53,0:21:04.91,Main-207+,,0,0,0,,İşte meşhur Adalet Kapıları.
Dialogue: 0,0:21:04.91,0:21:10.83,Main-207+,,0,0,0,,– Ohaa! Kocaman!\N– Ohaa! Kocaman!
Dialogue: 0,0:21:13.75,0:21:16.80,Main-207+,,0,0,0,,O kapılar asla ardına kadar açılmaz.
Dialogue: 0,0:21:16.80,0:21:21.84,Main-207+,,0,0,0,,Suçlular geçerken kapı sadece hafifçe aralanır.
Dialogue: 0,0:21:22.30,0:21:26.18,Main-207+,,0,0,0,,O kapıların ardında\NGrand Line'ın iki tarafında da uzanan...
Dialogue: 0,0:21:26.18,0:21:30.19,Main-207+,,0,0,0,,Calm Belt'teki gibi devasa deniz kralları var.
Dialogue: 0,0:21:30.56,0:21:33.40,Main-207+,,0,0,0,,Sıradan gemiler oradan geçemezler.
Dialogue: 0,0:21:33.40,0:21:35.77,Main-207+,,0,0,0,,Bunu nasıl yapıyorlar bilmiyorum...
Dialogue: 0,0:21:35.77,0:21:39.82,Main-207+,,0,0,0,,{\i1}ama Denizciler o kapılardan hiç yara almadan geçebiliyor.
Dialogue: 0,0:21:39.82,0:21:43.62,Main-207+,,0,0,0,,{\i1}Diğer bir deyişle, korsan kızın da dediği gibi...
Dialogue: 0,0:21:43.62,0:21:46.66,Main-207+,,0,0,0,,Buraya getirilen bir suçluyu kurtaracaksan...
Dialogue: 0,0:21:46.66,0:21:50.41,Main-207+,,0,0,0,,o kapılardan geçmeden hemen önce yapman lazım!
Dialogue: 0,0:21:50.41,0:21:53.46,Main-207+,,0,0,0,,Şimdi, kaybedecek vakit yok!
Dialogue: 0,0:21:55.96,0:21:58.67,Main-207+,,0,0,0,,Pekâlâ! Plana sadık kalıp önden biz dalıyoruz!
Dialogue: 0,0:21:59.51,0:22:01.51,Main-207+,,0,0,0,,Yolu sizin için temizleyeceğiz.
Dialogue: 0,0:22:01.51,0:22:04.72,Main-207+,,0,0,0,,Hey! O ikisi bizimle gelmeyecek mi?
Dialogue: 0,0:22:10.18,0:22:11.89,Main-207+,,0,0,0,,Luffy nerede?
Dialogue: 0,0:22:11.89,0:22:14.52,Main-207+,,0,0,0,,Heh? Demin buradaydı.
Dialogue: 0,0:22:20.69,0:22:21.95,Main-207+,,0,0,0,,Hasır Şapka-{\i1}san{\i0} mı?
Dialogue: 0,0:22:21.95,0:22:23.53,Main-207+,,0,0,0,,Ne?!
Dialogue: 0,0:22:26.87,0:22:29.33,Main-207+,,0,0,0,,– Ne?!\N– Ne?!
Dialogue: 0,0:22:29.33,0:22:32.66,Main-207+,,0,0,0,,Ne diye tek başına iş çeviriyor bu?!
Dialogue: 0,0:22:32.66,0:22:35.46,Main-207+,,0,0,0,,Herif planı zerre anlamamış!
Dialogue: 0,0:22:37.21,0:22:38.96,Main-207+,,0,0,0,,Yazık oldu...
Dialogue: 0,0:22:38.96,0:22:40.92,Main-207+,,0,0,0,,"Anladım" dememiş miydi?
Dialogue: 0,0:22:40.92,0:22:43.55,Main-207+,,0,0,0,,Onun beş dakika beklemesi mümkün değildi.
Dialogue: 0,0:22:43.55,0:22:45.14,Main-207+,,0,0,0,,Tahmin etmeliydik.
Dialogue: 0,0:22:46.97,0:22:49.81,Main-207+,,0,0,0,,Ne kadar da tez canlı!
Dialogue: 0,0:22:49.81,0:22:52.23,Main-207+,,0,0,0,,Yürü be, korsan abi!
Dialogue: 0,0:22:56.10,0:22:59.36,Main-207+,,0,0,0,,Sakın geride kalmayın, Sodom ve Gomorrah!
Dialogue: 0,0:22:59.36,0:23:03.03,Main-207+,,0,0,0,,Şu demir parmaklıkları aşıp\Nana kapıyı parçalayın!
Dialogue: 0,0:23:06.32,0:23:09.62,Main-207+,,0,0,0,,– Evet!\N– Evet!
Dialogue: 0,0:23:10.08,0:23:12.45,Main-207+,,0,0,0,,{\fad(150,150)}Lastik-Lastik...
Dialogue: 0,0:23:12.45,0:23:15.04,Main-207+,,0,0,0,,{\fad(150,150)}Roket!
Dialogue: 0,0:23:16.12,0:23:17.08,Main-207+,,0,0,0,,O neydi?
Dialogue: 0,0:23:18.96,0:23:20.21,Main-207+,,0,0,0,,Bir şey uçup geçti.
Dialogue: 0,0:23:24.47,0:23:26.05,Main-207+,,0,0,0,,Burası da ne böyle?
Dialogue: 0,0:23:26.05,0:23:27.72,Main-207+,,0,0,0,,Amma da büyük bir delik!
Dialogue: 0,0:23:27.72,0:23:29.76,Main-207+,,0,0,0,,Ada resmen havada asılı duruyor.
Dialogue: 0,0:23:31.31,0:23:32.77,Main-207+,,0,0,0,,Yukarıda biri var!
Dialogue: 0,0:23:32.77,0:23:35.23,Main-207+,,0,0,0,,Sızan biri var! İndirin şunu aşağı!
Dialogue: 0,0:23:35.94,0:23:37.73,Main-207+,,0,0,0,,Fark edildim!
Dialogue: 0,0:23:40.73,0:23:42.61,Main-207+,,0,0,0,,Kapıyı aştı bile!
Dialogue: 0,0:23:47.99,0:23:50.28,Main-207+,,0,0,0,,{\i1}Burası ana kapı! Burası ana kapı!
Dialogue: 0,0:23:50.28,0:23:52.58,Main-207+,,0,0,0,,{\i1}Başkana ve ada kapısına bildiriyorum!
Dialogue: 0,0:23:53.20,0:23:55.83,Main-207+,,0,0,0,,{\i1}Burası ana kapı! Cevap verin lütfen!
Dialogue: 0,0:23:57.17,0:23:59.33,Main-207+,,0,0,0,,Ne istiyorsun? Neler oluyor?
Dialogue: 0,0:23:59.71,0:24:04.05,Main-207+,,0,0,0,,{\i1}İçeri sızan biri, ana kapıyı aştı ve hızla ada kapısına doğru ilerliyor!
Dialogue: 0,0:24:04.05,0:24:07.72,Main-207+,,0,0,0,,Topu topu bir kişi yani.\NPanik yapmayın ve işini bitirin.
Dialogue: 0,0:24:07.72,0:24:08.51,Main-207+,,0,0,0,,{\i1}Topu topu bir kişi yani.\NPanik yapmayın ve işini bitirin.
Dialogue: 0,0:24:08.51,0:24:10.60,Main-207+,,0,0,0,,{\i1}Evet ama...
Dialogue: 0,0:24:10.60,0:24:12.51,Main-207+,,0,0,0,,{\i1}Burası ada kapısı.
Dialogue: 0,0:24:12.51,0:24:14.10,Main-207+,,0,0,0,,{\i1}Hedef tespit edildi!
Dialogue: 0,0:24:14.10,0:24:16.73,Main-207+,,0,0,0,,{\i1}Hemen ilgileniyoruz, müsterih olun.
Dialogue: 0,0:24:19.15,0:24:21.73,Main-207+,,0,0,0,,Hey, çocuk. Dur artık.
Dialogue: 0,0:24:21.73,0:24:23.69,Main-207+,,0,0,0,,Nerede olduğunu biliyor musun?
Dialogue: 0,0:24:23.69,0:24:25.61,Main-207+,,0,0,0,,{\i1}Onu hafife almasanız iyi olur.
Dialogue: 0,0:24:25.61,0:24:27.86,Main-207+,,0,0,0,,{\i1}Yanlış görmediysem o herif...
Dialogue: 0,0:24:29.91,0:24:31.62,Main-207+,,0,0,0,,{\i1}Hasır Şapkalı Luffy olabilir!
Dialogue: 0,0:24:37.41,0:24:39.54,Main-207+,,0,0,0,,Ne?! Az önce ne dedin?!
Dialogue: 0,0:24:39.54,0:24:41.21,Main-207+,,0,0,0,,Hedef Hasır Şapka olabilir!
Dialogue: 0,0:24:42.96,0:24:46.26,Main-207+,,0,0,0,,Başında 100 milyonluk ödül olan korsan!
Dialogue: 0,0:24:51.43,0:24:52.76,Main-207+,,0,0,0,,Robin...
Dialogue: 0,0:25:08.28,0:25:12.24,Main-207+,,0,0,0,,Robin nerede ulan?!
