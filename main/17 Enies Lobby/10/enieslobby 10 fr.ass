Dialogue: 0,0:01:50.75,0:01:52.40,Flashbacks-207+,,0,0,0,,Arrête, Sauro !
Dialogue: 0,0:01:52.55,0:01:53.78,Flashbacks-207+,,0,0,0,,Accrochez-vous.
Dialogue: 0,0:01:53.96,0:01:58.47,Flashbacks-207+,,0,0,0,,Parce que quand on me cherche,\Non me trouve !
Dialogue: 0,0:02:10.52,0:02:11.74,Main-207+,,0,0,0,,Il se passe quoi ?
Dialogue: 0,0:02:11.94,0:02:13.52,Main-207+,,0,0,0,,C'est le Vice-amiral Sauro !
Dialogue: 0,0:02:13.91,0:02:18.60,Main-207+,,0,0,0,,Ce déserteur a aidé Olvia à s'enfuir\Net maintenant, il nous attaque !
Dialogue: 0,0:02:19.51,0:02:20.94,Main-207+,,0,0,0,,Que fiche-t-il ici ?
Dialogue: 0,0:02:21.12,0:02:22.63,Main-207+,,0,0,0,,J'en sais rien !
Dialogue: 0,0:02:26.20,0:02:27.72,Main-207+,,0,0,0,,Cette île est condamnée !
Dialogue: 0,0:02:27.90,0:02:29.50,Main-207+,,0,0,0,,Tout va brûler.
Dialogue: 0,0:02:29.75,0:02:32.23,Main-207+,,0,0,0,,N'abandonnez pas.\NSortez tous les livres !
Dialogue: 0,0:02:32.41,0:02:34.17,Main-207+,,0,0,0,,Transmettons l'Histoire !
Dialogue: 0,0:02:35.38,0:02:37.03,Main-207+,,0,0,0,,Jetez-les dans le lac.
Dialogue: 0,0:02:37.21,0:02:39.72,Main-207+,,0,0,0,,L'eau est encore préférable au feu.\NVite !
Dialogue: 0,0:02:42.91,0:02:44.18,Main-207+,,0,0,0,,Maintenant !
Dialogue: 0,0:02:48.10,0:02:51.06,Main-207+,,0,0,0,,Sauro, arrête !\NIls vont te tuer !
Dialogue: 0,0:02:51.53,0:02:53.89,Main-207+,,0,0,0,,Balancez les livres\Nhors de la bibliothèque.
Dialogue: 0,0:02:54.28,0:02:55.94,Main-207+,,0,0,0,,Le moindre livre compte !
Dialogue: 0,0:02:56.12,0:02:58.82,Main-207+,,0,0,0,,La moindre ligne aussi,\Nsauvons-en un maximum !
Dialogue: 0,0:03:00.08,0:03:02.60,Main-207+,,0,0,0,,Ces témoignages\Nvieux de plusieurs millénaires...
Dialogue: 0,0:03:03.18,0:03:05.37,Main-207+,,0,0,0,,Ils doivent être préservés et transmis.
Dialogue: 0,0:03:09.04,0:03:11.06,Main-207+,,0,0,0,,Robin !\NT'attends quoi ?
Dialogue: 0,0:03:11.24,0:03:13.50,Main-207+,,0,0,0,,File vite au navire d'évacuation !
Dialogue: 0,0:03:13.80,0:03:16.62,Main-207+,,0,0,0,,Si tu restes sur cette île,\Ntu es condamnée !
Dialogue: 0,0:03:51.21,0:03:53.29,Main-207+,,0,0,0,,Maman !
Dialogue: 0,0:03:58.38,0:04:00.30,Main-207+,,0,0,0,,Abattez Sauro !
Dialogue: 0,0:04:01.34,0:04:06.62,Main-207+,,0,0,0,,Robin, enfuis-toi vite !\NT'as oublié ce que ta mère t'a dit ?
Dialogue: 0,0:04:07.07,0:04:08.60,Flashbacks-207+,,0,0,0,,Survis, Robin !
Dialogue: 0,0:04:10.78,0:04:12.60,Main-207+,,0,0,0,,Le navire d'évacuation lève l'ancre !
Dialogue: 0,0:04:13.20,0:04:15.27,Main-207+,,0,0,0,,Attendez, quelqu'un arrive !
Dialogue: 0,0:04:15.91,0:04:16.69,Main-207+,,0,0,0,,Mais c'est...
Dialogue: 0,0:04:17.82,0:04:19.84,Main-207+,,0,0,0,,Hé !\NMais c'est le monstre !
Dialogue: 0,0:04:20.02,0:04:21.11,Main-207+,,0,0,0,,Ouais !
Dialogue: 0,0:04:21.29,0:04:22.68,Main-207+,,0,0,0,,Va-t'en, monstros !
Dialogue: 0,0:04:22.86,0:04:24.69,Main-207+,,0,0,0,,Ça suffit, dites pas de bêtises !
Dialogue: 0,0:04:24.87,0:04:25.98,Main-207+,,0,0,0,,Non, attendez.
Dialogue: 0,0:04:26.16,0:04:30.96,Main-207+,,0,0,0,,C'est la fille d'Olvia, la criminelle\Nqui avait son portrait dans le journal !
Dialogue: 0,0:04:31.25,0:04:35.11,Main-207+,,0,0,0,,Oui, si on la laisse monter,\Nils s'en prendront peut-être à nous.
Dialogue: 0,0:04:35.29,0:04:37.23,Main-207+,,0,0,0,,Ça va pas ?\NC'est juste une gamine.
Dialogue: 0,0:04:37.23,0:04:38.45,Main-207+,,0,0,0,,Vite, qu'elle monte.
Dialogue: 0,0:04:38.63,0:04:41.57,Main-207+,,0,0,0,,{\i1}Hé ! Le navire d'évacuation !\NNe la laissez pas monter.
Dialogue: 0,0:04:41.77,0:04:42.54,Main-207+,,0,0,0,,Hein ?
Dialogue: 0,0:04:43.08,0:04:45.35,Main-207+,,0,0,0,,C'est une archéologue, malgré son âge.
Dialogue: 0,0:04:45.55,0:04:47.68,Main-207+,,0,0,0,,Si elle monte à bord, on vous canarde !
Dialogue: 0,0:04:47.88,0:04:51.00,Main-207+,,0,0,0,,Commandant Spandine,\Nvous êtes vraiment sérieux ?
Dialogue: 0,0:04:51.18,0:04:54.02,Main-207+,,0,0,0,,Vous voyez !\NElle aurait causé notre mort.
Dialogue: 0,0:04:54.39,0:04:55.58,Main-207+,,0,0,0,,Robin !
Dialogue: 0,0:04:56.10,0:04:58.69,Main-207+,,0,0,0,,Le CP9 ?\NQuelle bande d'affreux.
Dialogue: 0,0:04:59.19,0:05:02.19,Main-207+,,0,0,0,,Commandant,\Nle Vice-amiral Sauro se dirige par ici !
Dialogue: 0,0:05:02.37,0:05:06.02,Main-207+,,0,0,0,,Vraiment ? Inutile de questionner Olvia\Npour le trouver, alors.
Dialogue: 0,0:05:06.20,0:05:07.99,Main-207+,,0,0,0,,Feu !\NPilonnez-le au canon !
Dialogue: 0,0:05:11.18,0:05:12.37,Main-207+,,0,0,0,,{\fad(150,150)}Ice Block...
Dialogue: 0,0:05:12.85,0:05:13.91,Main-207+,,0,0,0,,{\fad(150,150)}Partisan !
Dialogue: 0,0:05:17.80,0:05:18.67,Main-207+,,0,0,0,,Sauro !
Dialogue: 0,0:05:27.18,0:05:28.51,Main-207+,,0,0,0,,Monsieur Kuzan ?
Dialogue: 0,0:05:29.35,0:05:30.64,Main-207+,,0,0,0,,Kuzan.
Dialogue: 0,0:05:31.00,0:05:32.04,Main-207+,,0,0,0,,Ah, là là...
Dialogue: 0,0:05:32.22,0:05:36.23,Main-207+,,0,0,0,,Un ancien officier de la Marine\Nqui fait obstruction au Buster Call,
Dialogue: 0,0:05:36.41,0:05:38.06,Main-207+,,0,0,0,,ça fait mauvais genre.
Dialogue: 0,0:05:38.36,0:05:39.75,Main-207+,,0,0,0,,Kuzan.
Dialogue: 0,0:05:40.05,0:05:43.61,Main-207+,,0,0,0,,Tu vas pas me dire\Nque tu es fier de cette attaque ?
Dialogue: 0,0:05:43.86,0:05:45.28,Main-207+,,0,0,0,,Quittez cette île !
Dialogue: 0,0:05:45.64,0:05:46.89,Main-207+,,0,0,0,,C'est louche !
Dialogue: 0,0:05:47.07,0:05:50.03,Main-207+,,0,0,0,,Tu sais comme moi\Nque c'est juste pour l'exemple.
Dialogue: 0,0:05:50.21,0:05:53.30,Main-207+,,0,0,0,,Ils vont détruire Ohara\Npour donner une leçon au monde.
Dialogue: 0,0:05:53.50,0:05:56.80,Main-207+,,0,0,0,,Si c'est pour le bien du monde à venir,\Non n'y peut rien.
Dialogue: 0,0:05:57.16,0:06:00.11,Main-207+,,0,0,0,,Et puis les archéologues ont vraiment\Nenfreint la loi.
Dialogue: 0,0:06:00.47,0:06:04.00,Main-207+,,0,0,0,,La justice est subjective,\Nelle varie d'une personne à l'autre.
Dialogue: 0,0:06:04.32,0:06:07.00,Main-207+,,0,0,0,,Je ne vais donc pas critiquer\Ntes convictions.
Dialogue: 0,0:06:07.52,0:06:10.68,Main-207+,,0,0,0,,Mais, si tu te dresses\Nen travers de notre chemin,
Dialogue: 0,0:06:11.10,0:06:12.43,Main-207+,,0,0,0,,je me dois de réagir.
Dialogue: 0,0:06:21.69,0:06:23.57,Main-207+,,0,0,0,,Le navire d'évacuation a explosé !
Dialogue: 0,0:06:23.73,0:06:25.47,Main-207+,,0,0,0,,Pou... Pourquoi ?
Dialogue: 0,0:06:25.65,0:06:27.65,Main-207+,,0,0,0,,Un tir d'un navire de la Marine.
Dialogue: 0,0:06:27.83,0:06:30.25,Main-207+,,0,0,0,,Ça provenait du navire\Ndu Vice-amiral Sakazuki.
Dialogue: 0,0:06:31.20,0:06:32.52,Main-207+,,0,0,0,,Quel imbécile.
Dialogue: 0,0:06:33.15,0:06:35.32,Main-207+,,0,0,0,,Faut pas faire les choses à moitié.
Dialogue: 0,0:06:35.58,0:06:39.17,Main-207+,,0,0,0,,Si un archéologue\Navait réussi à se faufiler à bord,
Dialogue: 0,0:06:39.80,0:06:42.33,Main-207+,,0,0,0,,tous ces sacrifices auraient été vains.
Dialogue: 0,0:06:42.92,0:06:46.48,Main-207+,,0,0,0,,Il ne faut pas laisser au mal\Nla moindre chance de proliférer.
Dialogue: 0,0:06:46.68,0:06:48.67,Main-207+,,0,0,0,,C'est ça, l'œuvre de la justice ?
Dialogue: 0,0:06:48.84,0:06:51.18,Main-207+,,0,0,0,,Tu vas me dire\Nque tu cautionnes ça, aussi ?
Dialogue: 0,0:06:51.61,0:06:53.93,Main-207+,,0,0,0,,Non, cet idiot en fait bien trop.
Dialogue: 0,0:06:54.52,0:06:56.18,Main-207+,,0,0,0,,On doit partir, Robin.
Dialogue: 0,0:06:56.39,0:06:58.85,Main-207+,,0,0,0,,Kuzan a une force hors du commun.
Dialogue: 0,0:06:59.02,0:07:00.31,Main-207+,,0,0,0,,Sauro s'est enfui !
Dialogue: 0,0:07:00.48,0:07:02.36,Main-207+,,0,0,0,,Il a une archéologue avec lui.
Dialogue: 0,0:07:05.07,0:07:07.19,Main-207+,,0,0,0,,{\fad(150,150)}Ice Time Capsule.
Dialogue: 0,0:07:11.78,0:07:13.41,Main-207+,,0,0,0,,Sauro, ça va ?
Dialogue: 0,0:07:15.87,0:07:18.00,Main-207+,,0,0,0,,Robin, sauve-toi vite.
Dialogue: 0,0:07:23.00,0:07:24.92,Main-207+,,0,0,0,,Cours de toutes tes forces.
Dialogue: 0,0:07:25.09,0:07:27.38,Main-207+,,0,0,0,,Si tu restes sur cette île,\Ntu mourras.
Dialogue: 0,0:07:27.55,0:07:29.47,Main-207+,,0,0,0,,Prends la mer avec mon radeau.
Dialogue: 0,0:07:29.92,0:07:30.76,Main-207+,,0,0,0,,Et toi ?
Dialogue: 0,0:07:30.93,0:07:34.60,Main-207+,,0,0,0,,C'est fini pour moi.\NIl m'a eu.
Dialogue: 0,0:07:35.64,0:07:36.60,Main-207+,,0,0,0,,File !
Dialogue: 0,0:07:36.76,0:07:39.18,Main-207+,,0,0,0,,Je veux pas !\NIl n'y a personne, en mer.
Dialogue: 0,0:07:39.35,0:07:41.19,Main-207+,,0,0,0,,Écoute-moi bien, Robin.
Dialogue: 0,0:07:42.35,0:07:44.27,Main-207+,,0,0,0,,Tu es toute seule, là.
Dialogue: 0,0:07:44.48,0:07:47.53,Main-207+,,0,0,0,,Mais un jour, c'est sûr,\Ntu te feras des amis.
Dialogue: 0,0:07:51.03,0:07:52.15,Main-207+,,0,0,0,,Des amis ?
Dialogue: 0,0:07:52.41,0:07:54.99,Main-207+,,0,0,0,,Oui.\NLa mer est vaste.
Dialogue: 0,0:07:55.16,0:07:56.78,Main-207+,,0,0,0,,Un jour, j'en suis convaincu,
Dialogue: 0,0:07:57.99,0:08:01.16,Main-207+,,0,0,0,,tu trouveras des amis\Nqui te protégeront.
Dialogue: 0,0:08:01.37,0:08:05.75,Main-207+,,0,0,0,,La solitude n'existe pas,\Ndans ce bas monde.
Dialogue: 0,0:08:09.26,0:08:12.38,Main-207+,,0,0,0,,Cours, Robin ! Sans te retourner.
Dialogue: 0,0:08:12.55,0:08:14.68,Main-207+,,0,0,0,,Je t'ai dit quoi faire quand ça va pas.
Dialogue: 0,0:08:14.84,0:08:16.72,Main-207+,,0,0,0,,Il faut rire, comme moi.
Dialogue: 0,0:08:17.05,0:08:18.18,Main-207+,,0,0,0,,Sauro, attention.
Dialogue: 0,0:08:21.60,0:08:23.08,Main-207+,,0,0,0,,{\fad(150,150)}Ice Time.
Dialogue: 0,0:08:25.53,0:08:26.47,Main-207+,,0,0,0,,Sauro !
Dialogue: 0,0:08:28.11,0:08:31.53,Thoughts-207+,,0,0,0,,Sur un océan, quelque part,\Ntes amis t'attendent.
Dialogue: 0,0:08:31.75,0:08:33.82,Thoughts-207+,,0,0,0,,Va vite les rejoindre, Robin.
Dialogue: 0,0:08:38.08,0:08:41.04,Thoughts-207+,,0,0,0,,Partage ta vie avec eux.
Dialogue: 0,0:08:55.13,0:08:56.26,Main-207+,,0,0,0,,C'est la fin.
Dialogue: 0,0:08:56.43,0:08:59.68,Thoughts-207+,,0,0,0,,C'est donc cela,\Nl'Histoire choisie par les Hommes ?
Dialogue: 0,0:09:00.68,0:09:03.27,Thoughts-207+,,0,0,0,,Quelle folie !
Dialogue: 0,0:09:04.48,0:09:06.60,Thoughts-207+,,0,0,0,,Pardonne-moi, Robin.
Dialogue: 0,0:09:09.15,0:09:11.53,Thoughts-207+,,0,0,0,,Je n'ai même pas été capable\Nde te laisser...
Dialogue: 0,0:09:13.86,0:09:15.91,Thoughts-207+,,0,0,0,,des paroles dignes d'une mère.
Dialogue: 0,0:09:16.36,0:09:19.70,Main-207+,,0,0,0,,L'Arbre s'effondre... L'Arbre du Savoir !
Dialogue: 0,0:09:27.67,0:09:32.05,Main-207+,,0,0,0,,Une justice trop sévère peut conduire\Nles gens à commettre des folies.
Dialogue: 0,0:09:32.51,0:09:35.17,Main-207+,,0,0,0,,J'ai décidé de te laisser quitter l'île.
Dialogue: 0,0:09:35.55,0:09:39.47,Main-207+,,0,0,0,,Que va devenir la petite graine\Nque Sauro a voulu protéger ?
Dialogue: 0,0:09:39.72,0:09:42.64,Main-207+,,0,0,0,,Tu as le droit de garder rancune\Ncontre qui tu veux.
Dialogue: 0,0:09:42.85,0:09:46.39,Main-207+,,0,0,0,,Estime-toi juste heureuse\Nd'avoir survécu à tout ça.
Dialogue: 0,0:09:46.56,0:09:48.85,Main-207+,,0,0,0,,Je te conseille de te faire oublier.
Dialogue: 0,0:09:49.48,0:09:51.94,Main-207+,,0,0,0,,J'ai tracé un chemin de glace\Nsur la mer.
Dialogue: 0,0:09:52.32,0:09:56.40,Main-207+,,0,0,0,,Si tu rames en suivant la glace,\Ntu atteindras la terre ferme.
Dialogue: 0,0:09:56.61,0:09:58.78,Main-207+,,0,0,0,,Mais tiens-le-toi pour dit.
Dialogue: 0,0:10:00.87,0:10:02.49,Main-207+,,0,0,0,,Je ne suis pas ton allié.
Dialogue: 0,0:10:02.95,0:10:04.79,Main-207+,,0,0,0,,Au moindre crime de ta part,
Dialogue: 0,0:10:04.95,0:10:07.58,Main-207+,,0,0,0,,je serai le premier\Nà me lancer à tes trousses.
Dialogue: 0,0:10:08.29,0:10:10.25,Main-207+,,0,0,0,,Ma maman est toujours ici.
Dialogue: 0,0:10:10.63,0:10:12.38,Main-207+,,0,0,0,,Personne ne survivra.
Dialogue: 0,0:10:12.67,0:10:15.92,Main-207+,,0,0,0,,Si c'est trop dur,\Ntu es libre de choisir la mort.
Dialogue: 0,0:10:17.47,0:10:19.89,Flashbacks-207+,,0,0,0,,C'est la plus grande bibliothèque\Nau monde.
Dialogue: 0,0:10:21.01,0:10:22.39,Flashbacks-207+,,0,0,0,,Tu aimes les livres ?
Dialogue: 0,0:10:22.72,0:10:25.14,Flashbacks-207+,,0,0,0,,Aujourd'hui,\Nc'est l'anniversaire de Robin.
Dialogue: 0,0:10:25.47,0:10:28.27,Flashbacks-207+,,0,0,0,,Bon anniversaire, Robin !
Dialogue: 0,0:10:28.44,0:10:31.86,Flashbacks-207+,,0,0,0,,Robin, tu dois être fière.\NOhara est fantastique.
Dialogue: 0,0:10:32.40,0:10:37.40,Flashbacks-207+,,0,0,0,,Nous n'allons en aucun cas abandonner\Nl'avenir dans lequel vous vivrez.
Dialogue: 0,0:10:37.95,0:10:41.78,Flashbacks-207+,,0,0,0,,Il faut rigoler.\NQuand ça va pas trop, faut rigoler.
Dialogue: 0,0:10:42.37,0:10:44.58,Flashbacks-207+,,0,0,0,,J'aurais l'air bête,\Nà rire si ça va pas.
Dialogue: 0,0:10:44.87,0:10:46.66,Flashbacks-207+,,0,0,0,,Mais non !
Dialogue: 0,0:11:22.39,0:11:25.17,Flashbacks-207+,,0,0,0,,Sur un océan, quelque part,\Ntes amis t'attendent.
Dialogue: 0,0:11:25.32,0:11:27.33,Flashbacks-207+,,0,0,0,,Va vite les rejoindre, Robin !
Dialogue: 0,0:11:45.64,0:11:46.93,Main-207+,,0,0,0,,Des survivants ?
Dialogue: 0,0:11:47.36,0:11:48.56,Main-207+,,0,0,0,,Aucune chance.
Dialogue: 0,0:11:49.48,0:11:49.93,Main-207+,,0,0,0,,Hé !
Dialogue: 0,0:11:50.15,0:11:50.89,Main-207+,,0,0,0,,Hein ?
Dialogue: 0,0:11:51.14,0:11:52.60,Main-207+,,0,0,0,,Regardez, dans le lac.
Dialogue: 0,0:11:54.02,0:11:55.61,Main-207+,,0,0,0,,Mais, c'est...
Dialogue: 0,0:12:01.57,0:12:04.07,Main-207+,,0,0,0,,Il y a tant de livres\Nque le lac en est rempli !
Dialogue: 0,0:12:04.28,0:12:05.99,Main-207+,,0,0,0,,Ils l'ont fait exprès ?
Dialogue: 0,0:12:06.49,0:12:10.16,Main-207+,,0,0,0,,Ouais, c'est elle ! Aucun doute.
Dialogue: 0,0:12:10.41,0:12:12.33,Main-207+,,0,0,0,,Elle était où ?\NVous l'avez eue ?
Dialogue: 0,0:12:12.50,0:12:15.21,Main-207+,,0,0,0,,Non.\NOn cherchait une fillette suspecte.
Dialogue: 0,0:12:15.42,0:12:20.42,Main-207+,,0,0,0,,Elle était sur un navire provenant\Nd'une île loin au nord-est d'Ohara.
Dialogue: 0,0:12:20.63,0:12:22.30,Main-207+,,0,0,0,,Mais elle a disparu.
Dialogue: 0,0:12:23.47,0:12:25.47,Main-207+,,0,0,0,,Quelle chance insolente.
Dialogue: 0,0:12:25.64,0:12:28.60,Main-207+,,0,0,0,,Ce jour-là, alors qu'Ohara\Nétait dévorée par les flammes,
Dialogue: 0,0:12:28.76,0:12:31.31,Main-207+,,0,0,0,,j'ai vu cette morveuse\Ns'enfuir à bord d'une barque,
Dialogue: 0,0:12:31.48,0:12:33.39,Main-207+,,0,0,0,,je l'ai vue de mes propres yeux.
Dialogue: 0,0:12:34.06,0:12:35.69,Main-207+,,0,0,0,,Quand j'ai voulu la poursuivre,
Dialogue: 0,0:12:35.85,0:12:39.07,Main-207+,,0,0,0,,mon gouvernail s'est figé,\Nil était comme gelé.
Dialogue: 0,0:12:39.23,0:12:42.49,Main-207+,,0,0,0,,Sauro a dû l'aider à s'enfuir\Navant de mourir.
Dialogue: 0,0:12:43.15,0:12:45.74,Main-207+,,0,0,0,,Elle peut déchiffrer les ponéglyphes.
Dialogue: 0,0:12:45.95,0:12:48.83,Main-207+,,0,0,0,,Elle a beau être jeune,\Nelle est dangereuse.
Dialogue: 0,0:12:49.49,0:12:53.04,Main-207+,,0,0,0,,Peu importe les moyens utilisés,\Nil faut la capturer au plus vite.
Dialogue: 0,0:12:53.21,0:12:55.79,Main-207+,,0,0,0,,Ou toute cette opération aura été vaine.
Dialogue: 0,0:13:00.17,0:13:02.05,Main-207+,,0,0,0,,79 Millions de Berrys ?
Dialogue: 0,0:13:02.21,0:13:05.01,Main-207+,,0,0,0,,Une telle somme,\Npour une fillette de 8 ans ?
Dialogue: 0,0:13:05.18,0:13:07.80,Main-207+,,0,0,0,,Il paraît que c'est une survivante\Ndes démons d'Ohara
Dialogue: 0,0:13:07.97,0:13:10.22,Main-207+,,0,0,0,,qui voulaient détruire le monde.
Dialogue: 0,0:13:10.39,0:13:11.85,Main-207+,,0,0,0,,Ces fous d'Ohara ?
Dialogue: 0,0:13:12.22,0:13:17.02,Main-207+,,0,0,0,,Je sais pas comment elle a fait,\Nelle a coulé six cuirassés de la Marine.
Dialogue: 0,0:13:17.19,0:13:18.77,Main-207+,,0,0,0,,Ça explique la prime.
Dialogue: 0,0:13:19.36,0:13:22.69,Main-207+,,0,0,0,,Le Gouvernement et le QG\Nen font une affaire personnelle.
Dialogue: 0,0:13:23.19,0:13:27.03,Main-207+,,0,0,0,,Elle a hérité des convictions\Ndes archéologues exécutés à Ohara.
Dialogue: 0,0:13:27.24,0:13:28.66,Main-207+,,0,0,0,,On doit l'arrêter.
Dialogue: 0,0:13:29.12,0:13:32.91,Main-207+,,0,0,0,,Cette gamine, c'est une démone,\Nelle ne doit pas vivre !
Dialogue: 0,0:13:34.50,0:13:37.04,Main-207+,,0,0,0,,Merci beaucoup,\Ntu m'aides toujours.
Dialogue: 0,0:13:37.29,0:13:40.21,Main-207+,,0,0,0,,De rien.\NMerci de me laisser travailler.
Dialogue: 0,0:13:40.46,0:13:44.92,Main-207+,,0,0,0,,Au fait, j'ai une surprise,\Navant de passer à table.
Dialogue: 0,0:13:46.51,0:13:47.47,Main-207+,,0,0,0,,Coincez-la !
Dialogue: 0,0:13:47.63,0:13:51.43,Main-207+,,0,0,0,,Allez, donnez-moi l'argent.\NJe vous ai fourni l'information !
Dialogue: 0,0:13:52.14,0:13:54.77,Main-207+,,0,0,0,,Elle est petite,\Nmais elle travaille dur.
Dialogue: 0,0:13:56.98,0:13:59.15,Main-207+,,0,0,0,,Eh bien, tu ne dors pas encore ?
Dialogue: 0,0:13:59.52,0:14:02.61,Main-207+,,0,0,0,,Demain on se lève tôt\Npour les livraisons, dors.
Dialogue: 0,0:14:02.78,0:14:03.61,Main-207+,,0,0,0,,Oui.
Dialogue: 0,0:14:04.23,0:14:07.61,Main-207+,,0,0,0,,C'est une bonne petite,\Nmais elle nous met en danger.
Dialogue: 0,0:14:08.16,0:14:10.53,Main-207+,,0,0,0,,Et regarde-moi cette prime.
Dialogue: 0,0:14:11.70,0:14:14.04,Main-207+,,0,0,0,,Chéri !\NElle a quitté la maison !
Dialogue: 0,0:14:14.20,0:14:17.25,Main-207+,,0,0,0,,Merde !\NElle s'est douté de quelque chose ?
Dialogue: 0,0:14:23.80,0:14:26.26,Main-207+,,0,0,0,,Désolée,\Nje n'ai rien à te donner à manger.
Dialogue: 0,0:14:32.30,0:14:35.22,Main-207+,,0,0,0,,J'ai entendu parler de toi, Nico Robin.
Dialogue: 0,0:14:35.81,0:14:38.06,Main-207+,,0,0,0,,Moi aussi je suis mis à prix, tu sais.
Dialogue: 0,0:14:38.52,0:14:41.23,Main-207+,,0,0,0,,Occupe-toi des corvées\Net on te nourrira.
Dialogue: 0,0:14:43.98,0:14:44.69,Main-207+,,0,0,0,,Capitaine ?
Dialogue: 0,0:14:44.86,0:14:47.40,Main-207+,,0,0,0,,Le QG de la Marine ! Où est Robin ?
Dialogue: 0,0:14:47.61,0:14:49.95,Main-207+,,0,0,0,,Il faut la livrer au QG, bon sang !
Dialogue: 0,0:14:50.11,0:14:51.70,Main-207+,,0,0,0,,Elle porte la poisse !
Dialogue: 0,0:14:55.08,0:14:57.16,Flashbacks-207+,,0,0,0,,Ton existence est un crime !
Dialogue: 0,0:14:58.37,0:15:00.83,Flashbacks-207+,,0,0,0,,Quoi ?\NNico Robin est dans notre ville ?
Dialogue: 0,0:15:01.25,0:15:03.65,Flashbacks-207+,,0,0,0,,Trouvons-la !\NIl faut la livrer au Gouvernement.
Dialogue: 0,0:15:08.01,0:15:11.05,Main-207+,,0,0,0,,J'en ai trouvé un...\NUn ponéglyphe.
Dialogue: 0,0:15:11.34,0:15:14.60,Main-207+,,0,0,0,,Entre pas !\NJe ne te vendrai rien !
Dialogue: 0,0:15:15.64,0:15:17.93,Main-207+,,0,0,0,,J'ai 16 ans, je suis prête à tout.
Dialogue: 0,0:15:18.10,0:15:20.06,Main-207+,,0,0,0,,Prenez-moi dans votre organisation.
Dialogue: 0,0:15:20.23,0:15:23.19,Flashbacks-207+,,0,0,0,,Tu m'as trahi, Robin !
Dialogue: 0,0:15:23.81,0:15:27.53,Main-207+,,0,0,0,,Nico Robin,\Nj'aimerais avoir recours à tes services.
Dialogue: 0,0:15:29.78,0:15:32.74,Main-207+,,0,0,0,,Il paraît\Nque tu peux lire les ponéglyphes.
Dialogue: 0,0:15:36.16,0:15:40.50,Main-207+,,0,0,0,,Ici et maintenant,\Nsi tu déclenches le Buster Call,
Dialogue: 0,0:15:41.75,0:15:43.92,Main-207+,,0,0,0,,c'est Enies Lobby dans son ensemble...
Dialogue: 0,0:15:47.75,0:15:50.38,Main-207+,,0,0,0,,qui sera réduite en cendres,\Net vous tous avec.
Dialogue: 0,0:15:50.97,0:15:52.89,Main-207+,,0,0,0,,De quoi ? Ça va pas ?
Dialogue: 0,0:15:53.39,0:15:55.93,Main-207+,,0,0,0,,Pourquoi une attaque alliée\Nnous porterait préjudice ?
Dialogue: 0,0:15:56.10,0:15:57.47,Main-207+,,0,0,0,,Tu débloques.
Dialogue: 0,0:15:58.35,0:16:01.73,Main-207+,,0,0,0,,Il y a 20 ans,\Ncette attaque m'a tout pris.
Dialogue: 0,0:16:02.69,0:16:05.23,Main-207+,,0,0,0,,Elle a bouleversé la vie\Nde nombreuses personnes.
Dialogue: 0,0:16:06.06,0:16:09.57,Main-207+,,0,0,0,,Tout ça\Nen un seul et unique Buster Call.
Dialogue: 0,0:16:10.40,0:16:11.86,Main-207+,,0,0,0,,À présent, cette attaque
Dialogue: 0,0:16:12.28,0:16:15.91,Main-207+,,0,0,0,,menace les amis sincères\Nque j'ai enfin rencontrés.
Dialogue: 0,0:16:16.28,0:16:19.62,Main-207+,,0,0,0,,Plus j'ai envie de rester à vos côtés,
Dialogue: 0,0:16:19.91,0:16:23.17,Main-207+,,0,0,0,,plus mon destin risque de vous broyer.
Dialogue: 0,0:16:23.71,0:16:26.38,Main-207+,,0,0,0,,Peu importe le nombre d'océans\Nque je traverse,
Dialogue: 0,0:16:26.59,0:16:29.25,Main-207+,,0,0,0,,j'ai à mes trousses un ennemi acharné !
Dialogue: 0,0:16:29.88,0:16:34.01,Main-207+,,0,0,0,,Cet ennemi, c'est le monde entier\Net les ténèbres qu'il recèle.
Dialogue: 0,0:16:34.55,0:16:37.68,Main-207+,,0,0,0,,D'abord Aokiji\Net maintenant, cette histoire.
Dialogue: 0,0:16:38.22,0:16:40.35,Main-207+,,0,0,0,,C'est la seconde fois que ça arrive.
Dialogue: 0,0:16:41.35,0:16:45.31,Main-207+,,0,0,0,,Vous avez beau être indulgents,\Nsi ça continue comme ça...
Dialogue: 0,0:16:47.73,0:16:49.53,Main-207+,,0,0,0,,Un jour, vous en aurez assez !
Dialogue: 0,0:16:49.82,0:16:52.86,Main-207+,,0,0,0,,Un jour, vous me trahirez\Net vous m'abandonnerez !
Dialogue: 0,0:16:53.07,0:16:54.95,Main-207+,,0,0,0,,Voilà ce qui me terrifie vraiment !
Dialogue: 0,0:16:55.16,0:16:58.08,Main-207+,,0,0,0,,C'est pour ça que je ne voulais pas\Nque vous me sauviez.
Dialogue: 0,0:16:58.37,0:16:59.99,Main-207+,,0,0,0,,Quitte à mourir un jour,
Dialogue: 0,0:17:00.24,0:17:03.33,Main-207+,,0,0,0,,je préfère encore mourir\Nici et maintenant !
Dialogue: 0,0:17:07.54,0:17:08.46,Main-207+,,0,0,0,,Robin.
Dialogue: 0,0:17:08.75,0:17:10.09,Main-207+,,0,0,0,,Robin d'amour...
Dialogue: 0,0:17:11.51,0:17:12.38,Main-207+,,0,0,0,,Robin.
Dialogue: 0,0:17:13.76,0:17:15.84,Main-207+,,0,0,0,,C'était donc ça.
Dialogue: 0,0:17:18.85,0:17:21.85,Main-207+,,0,0,0,,Je vois, tu as tout à fait raison.
Dialogue: 0,0:17:22.02,0:17:23.31,Main-207+,,0,0,0,,Après tout,
Dialogue: 0,0:17:23.52,0:17:27.48,Main-207+,,0,0,0,,il faudrait être débile pour ne pas voir\Nque tu es un gros boulet.
Dialogue: 0,0:17:29.44,0:17:31.86,Main-207+,,0,0,0,,Sales pirates,\Nregardez bien ce drapeau !
Dialogue: 0,0:17:34.99,0:17:38.57,Main-207+,,0,0,0,,Cet emblème représente\Nl'union de pays répartis sur Grand Line
Dialogue: 0,0:17:38.74,0:17:42.74,Main-207+,,0,0,0,,et sur les quatre océans :\Nune coalition de plus de 170 nations.
Dialogue: 0,0:17:42.91,0:17:44.75,Main-207+,,0,0,0,,Ce drapeau, c'est le monde.
Dialogue: 0,0:17:45.12,0:17:49.71,Main-207+,,0,0,0,,Vous comprenez à qui vous vous opposez,\Nmisérables larves ?
Dialogue: 0,0:17:50.79,0:17:54.05,Main-207+,,0,0,0,,La toute-puissance de l'organisation\Nqui poursuit cette femme,
Dialogue: 0,0:17:54.26,0:17:55.80,Main-207+,,0,0,0,,vous arrivez à la saisir ?
Dialogue: 0,0:17:56.84,0:17:59.43,Main-207+,,0,0,0,,J'ai bien pigé\Nqui est l'ennemi de Robin.
Dialogue: 0,0:18:00.22,0:18:01.22,Main-207+,,0,0,0,,Sniperking.
Dialogue: 0,0:18:01.43,0:18:02.22,Main-207+,,0,0,0,,Oui ?
Dialogue: 0,0:18:03.14,0:18:05.35,Main-207+,,0,0,0,,Dégomme-moi ce drapeau.
Dialogue: 0,0:18:05.64,0:18:06.77,Main-207+,,0,0,0,,Bien reçu.
Dialogue: 0,0:18:08.40,0:18:11.69,Main-207+,,0,0,0,,Je vais utiliser le Kabuto,\Nma toute nouvelle fronde géante !
Dialogue: 0,0:18:12.15,0:18:14.15,Main-207+,,0,0,0,,Admirez sa puissance !
Dialogue: 0,0:18:14.65,0:18:17.61,Main-207+,,0,0,0,,{\fad(150,150)}Firebird Star !
Dialogue: 0,0:18:26.83,0:18:27.75,Main-207+,,0,0,0,,Je rêve...
Dialogue: 0,0:18:31.38,0:18:32.50,Main-207+,,0,0,0,,Mission accomplie.
Dialogue: 0,0:18:36.55,0:18:38.09,Main-207+,,0,0,0,,Ils... Ils ont osé !
Dialogue: 0,0:18:38.26,0:18:42.10,Main-207+,,0,0,0,,Ils réalisent vraiment\Nce qu'ils viennent de faire ?
Dialogue: 0,0:18:42.76,0:18:45.60,Main-207+,,0,0,0,,Ces pirates\Nviennent de déclarer la guerre totale
Dialogue: 0,0:18:45.81,0:18:48.06,Main-207+,,0,0,0,,au Gouvernement Mondial !
Dialogue: 0,0:18:48.60,0:18:50.10,Main-207+,,0,0,0,,Ça va pas bien ?
Dialogue: 0,0:18:50.27,0:18:53.77,Main-207+,,0,0,0,,Si vous partez en guerre\Ncontre le monde entier, vous crèverez !
Dialogue: 0,0:18:53.94,0:18:58.28,Main-207+,,0,0,0,,C'est ce qu'on va voir !
Dialogue: 0,0:19:08.71,0:19:09.92,Main-207+,,0,0,0,,Robin !
Dialogue: 0,0:19:11.58,0:19:14.38,Main-207+,,0,0,0,,J'attends toujours\Nque tu me le dises !
Dialogue: 0,0:19:19.05,0:19:22.47,Main-207+,,0,0,0,,Dis que tu veux vivre !
Dialogue: 0,0:19:25.85,0:19:26.68,Main-207+,,0,0,0,,Robin.
Dialogue: 0,0:19:31.48,0:19:32.40,Main-207+,,0,0,0,,Robin.
Dialogue: 0,0:19:34.86,0:19:36.11,Thoughts-207+,,0,0,0,,Vivre ?
Dialogue: 0,0:19:37.15,0:19:40.70,Flashbacks-207+,,0,0,0,,Tu n'as pas le droit\Nde vivre dans ce monde, Robin.
Dialogue: 0,0:19:41.07,0:19:44.91,Flashbacks-207+,,0,0,0,,Ton existence même\Nest un crime abject, Robin !
Dialogue: 0,0:19:46.49,0:19:49.91,Thoughts-207+,,0,0,0,,Je croyais que je n'avais pas le droit\Nde vouloir vivre.
Dialogue: 0,0:19:52.54,0:19:55.67,Thoughts-207+,,0,0,0,,Personne ne m'en avait donné le droit.
Dialogue: 0,0:19:56.38,0:19:58.34,Flashbacks-207+,,0,0,0,,Moi, je veux juste mourir !
Dialogue: 0,0:19:58.84,0:20:00.76,Flashbacks-207+,,0,0,0,,La mer est vaste.
Dialogue: 0,0:20:00.97,0:20:02.84,Flashbacks-207+,,0,0,0,,Un jour, j'en suis convaincu,
Dialogue: 0,0:20:03.14,0:20:06.93,Flashbacks-207+,,0,0,0,,tu trouveras des amis\Nqui te protégeront.
Dialogue: 0,0:20:14.40,0:20:16.19,Flashbacks-207+,,0,0,0,,Tu dois avoir foi en Luffy.
Dialogue: 0,0:20:18.61,0:20:23.36,Thoughts-207+,,0,0,0,,Si j'ai le droit d'exprimer ma volonté,\Nne serait-ce qu'une fois,
Dialogue: 0,0:20:25.03,0:20:26.20,Thoughts-207+,,0,0,0,,alors...
Dialogue: 0,0:20:29.12,0:20:30.91,Main-207+,,0,0,0,,Je veux vivre !
Dialogue: 0,0:20:31.54,0:20:35.75,Main-207+,,0,0,0,,Je veux naviguer avec vous,\Nemmenez-moi !
Dialogue: 0,0:20:59.90,0:21:03.90,Main-207+,,0,0,0,,Ce que je peux vous aimer, les petits !\NBon sang de bonsoir !
Dialogue: 0,0:21:05.78,0:21:06.68,Main-207+,,0,0,0,,C'est parti !
Dialogue: 2,0:01:56.89,0:02:00.85,Title,,0,0,0,,{\fscx120\fscy120\bord0\c&HE5E6E6&\blur0.6\fad(477,0)\pos(960,750)}Déclaration de Guerre
Dialogue: 1,0:01:56.89,0:02:00.85,Title,,0,0,0,,{\fscx120\fscy120\1c&H010101&\3c&H010101&\1a&HFF&\blur0.6\fad(477,0)\t(436,477,\1a&H00&)\pos(960,750)}Déclaration de Guerre
