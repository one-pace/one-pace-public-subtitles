Comment: 0,0:01:49.88,0:01:49.88,Main-207+,chptr,0,0,0,,{Episode}
Comment: 0,0:00:46.11,0:00:46.15,Main-207+,OP,0,0,0,,
Dialogue: 0,0:01:50.75,0:01:52.55,Recuerdo,,0,0,0,,¡Detente, Saul!
Dialogue: 0,0:01:52.55,0:01:53.96,Recuerdo,,0,0,0,,¡Prepárense!
Dialogue: 0,0:01:53.96,0:01:58.47,Recuerdo,,0,0,0,,Si te conviertes en mi enemigo, ¡más vale estar preparado para las consecuencias!
Dialogue: 0,0:02:10.52,0:02:11.94,Recuerdo,,0,0,0,,¡¿Qué está sucediendo?!
Dialogue: 0,0:02:11.94,0:02:13.52,Recuerdo,,0,0,0,,¡Es el Vicealmirante Saul!
Dialogue: 0,0:02:13.53,0:02:18.99,Recuerdo,,0,0,0,,¡El Vicealmirante Saul, \Nquien escapó con Olvia, nos está atacando!
Dialogue: 0,0:02:19.61,0:02:21.12,Recuerdo,,0,0,0,,¡¿Qué está haciendo aquí?!
Dialogue: 0,0:02:21.12,0:02:22.99,Recuerdo,,0,0,0,,¡N-No lo sé!
Dialogue: 0,0:02:26.20,0:02:27.87,Recuerdo,,0,0,0,,¡Esta isla está acabada!
Dialogue: 0,0:02:27.87,0:02:29.50,Recuerdo,,0,0,0,,¡Todo quedará reducido a cenizas!
Dialogue: 0,0:02:29.50,0:02:30.88,Recuerdo,,0,0,0,,¡No se den por vencidos!
Dialogue: 0,0:02:30.88,0:02:32.34,Recuerdo,,0,0,0,,¡Tenemos que rescatar los libros!
Dialogue: 0,0:02:32.34,0:02:33.84,Recuerdo,,0,0,0,,¡Hay que preservar la historia!
Dialogue: 0,0:02:35.38,0:02:37.22,Recuerdo,,0,0,0,,¡Tírenlos por la ventana al lago!
Dialogue: 0,0:02:37.22,0:02:39.09,Recuerdo,,0,0,0,,¡Será mejor que dejar que se quemen!
Dialogue: 0,0:02:39.09,0:02:39.72,Recuerdo,,0,0,0,,¡Apúrense!
Dialogue: 0,0:02:42.93,0:02:44.18,Recuerdo,,0,0,0,,¡Ahora!
Dialogue: 0,0:02:47.89,0:02:50.10,Recuerdo,,0,0,0,,¡Saul, detente!
Dialogue: 0,0:02:50.10,0:02:51.06,Recuerdo,,0,0,0,,¡Te matarán!
Dialogue: 0,0:02:51.06,0:02:54.07,Recuerdo,,0,0,0,,¡Saquen esos textos de la biblioteca!
Dialogue: 0,0:02:54.07,0:02:58.82,Recuerdo,,0,0,0,,¡Todos los que puedan! ¡Tienen que salvar hasta la última palabra!
Dialogue: 0,0:02:59.98,0:03:03.28,Recuerdo,,0,0,0,,¡Para que el mensaje de nuestros\Nantepasados, de hace miles de años...
Dialogue: 0,0:03:03.28,0:03:05.37,Recuerdo,,0,0,0,,...pueda llegar al futuro!
Dialogue: 0,0:03:09.00,0:03:09.54,Recuerdo,,0,0,0,,¡Robin!
Dialogue: 0,0:03:09.54,0:03:11.25,Recuerdo,,0,0,0,,¡¿Qué estás haciendo ahí?!
Dialogue: 0,0:03:11.25,0:03:13.50,Recuerdo,,0,0,0,,¡Tienes que abordar el barco de evacuación!
Dialogue: 0,0:03:13.51,0:03:16.80,Recuerdo,,0,0,0,,¡No sobrevivirás si te quedas en esta isla!
Dialogue: 0,0:03:51.21,0:03:53.29,Recuerdo,,0,0,0,,{\fad(0,1100)}¡Madre!
Dialogue: 0,0:03:58.38,0:04:00.30,Recuerdo,,0,0,0,,¡Dispárenle a Saul!
Dialogue: 0,0:04:01.34,0:04:03.72,Recuerdo,,0,0,0,,¡Robin, tienes que huir rápido!
Dialogue: 0,0:04:03.72,0:04:06.80,Recuerdo,,0,0,0,,¡¿Cuál crees que es el deseo de tu madre?!
Dialogue: 0,0:04:06.81,0:04:08.60,Recuerdo,,0,0,0,,{\fad(0,1300}¡Sobrevive, Robin!
Dialogue: 0,0:04:10.60,0:04:13.02,Recuerdo,,0,0,0,,¡El barco de evacuación va a partir!
Dialogue: 0,0:04:13.02,0:04:14.02,Recuerdo,,0,0,0,,¡Espera!
Dialogue: 0,0:04:14.02,0:04:15.27,Recuerdo,,0,0,0,,¡Alguien viene!
Dialogue: 0,0:04:15.73,0:04:16.69,Recuerdo,,0,0,0,,¿Acaso no es...?
Dialogue: 0,0:04:17.82,0:04:20.03,Recuerdo,,0,0,0,,¿N-No es ese monstruo?
Dialogue: 0,0:04:20.03,0:04:21.11,Recuerdo,,0,0,0,,¡Es cierto!
Dialogue: 0,0:04:21.11,0:04:22.86,Recuerdo,,0,0,0,,¡Vete monstruo!
Dialogue: 0,0:04:22.86,0:04:24.78,Recuerdo,,0,0,0,,¡Oigan! ¡Cállense, maleducados!
Dialogue: 0,0:04:24.78,0:04:26.16,Recuerdo,,0,0,0,,No... Esperen...
Dialogue: 0,0:04:26.16,0:04:29.33,Recuerdo,,0,0,0,,Esa chica... creo que es la hija de Olvia, la mujer que aparece en el periódico de recién.
Dialogue: 0,0:04:29.33,0:04:30.66,Recuerdo,,0,0,0,,¡¿Es la hija de la criminal?!
Dialogue: 0,0:04:30.66,0:04:32.25,Recuerdo,,0,0,0,,¡Es cierto!
Dialogue: 0,0:04:32.25,0:04:35.29,Recuerdo,,0,0,0,,¡Si dejamos que suba al barco, también nos atacarán a nosotros!
Dialogue: 0,0:04:35.29,0:04:36.25,Recuerdo,,0,0,0,,¡No seas estúpido!
Dialogue: 0,0:04:36.25,0:04:37.21,Recuerdo,,0,0,0,,¡Es sólo una niña!
Dialogue: 0,0:04:37.21,0:04:38.63,Recuerdo,,0,0,0,,¡Qué esperas para subirla!
Dialogue: 0,0:04:38.63,0:04:41.67,EnmedioArriba,,0,0,0,,¡Al barco de evacuación! ¡No dejen abordar a esa mocosa!
Dialogue: 0,0:04:42.72,0:04:45.55,Recuerdo,,0,0,0,,Puede que sólo sea una niña, pero ya es una arqueóloga.
Dialogue: 0,0:04:45.55,0:04:47.68,Recuerdo,,0,0,0,,¡Es uno de los objetivos del ataque!
Dialogue: 0,0:04:47.68,0:04:49.26,Recuerdo,,0,0,0,,¡Jefe Spandine!
Dialogue: 0,0:04:49.26,0:04:51.18,Recuerdo,,0,0,0,,¿Es eso cierto?
Dialogue: 0,0:04:51.18,0:04:54.02,Recuerdo,,0,0,0,,¡Ves! ¡Si dejamos que suba estaremos en peligro!
Dialogue: 0,0:04:54.02,0:04:56.10,Recuerdo,,0,0,0,,¡Robin!
Dialogue: 0,0:04:56.10,0:04:57.65,Recuerdo,,0,0,0,,¿El CP9?
Dialogue: 0,0:04:57.65,0:04:58.69,Recuerdo,,0,0,0,,Qué estupideces dicen...
Dialogue: 0,0:04:58.69,0:05:02.19,Recuerdo,,0,0,0,,¡Jefe! ¡El Vicealmirante Saul viene hacia nosotros!
Dialogue: 0,0:05:02.19,0:05:03.49,Recuerdo,,0,0,0,,¡¿Lo dices en serio?!
Dialogue: 0,0:05:03.49,0:05:06.11,Recuerdo,,0,0,0,,¡Supongo que ya no hace falta que\Nle preguntemos a Olvia dónde está!
Dialogue: 0,0:05:06.11,0:05:07.11,Recuerdo,,0,0,0,,¡Disparen, disparen!
Dialogue: 0,0:05:07.11,0:05:07.99,Recuerdo,,0,0,0,,¡Acaben con él!
Dialogue: 0,0:05:11.12,0:05:13.91,Recuerdo,,0,0,0,,¡Ice Block Partisan!
Dialogue: 0,0:05:10.91,0:05:14.41,NDTBoard,,0,0,0,,{\clip(0,0,1919,1079)\1a&H80&\be2\fad(300,0)\t(0,300,\fscx570)\move(199.5,97.5,199.5,-85.5,3000,3500)}Mola
