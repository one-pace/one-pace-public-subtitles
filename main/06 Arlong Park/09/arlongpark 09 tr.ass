Comment: 0,0:00:00.00,0:00:00.00,Main-207-,,0,0,0,,{=38}===============================DIALOGUE============================
Dialogue: 0,0:02:29.42,0:02:30.96,Main-207-,,0,0,0,,Kolu iyi mi?
Dialogue: 0,0:02:31.34,0:02:34.47,Main-207-,,0,0,0,,Bir adım bile geri çekilseydi,\No kolunu kaybederdi!
Dialogue: 0,0:02:34.47,0:02:39.64,Main-207-,,0,0,0,,Ama dişlerin ona ne yapacağını\Npek düşünmemiştir bence.
Dialogue: 0,0:02:42.39,0:02:44.69,Main-207-,,0,0,0,,Abinin kolu iyi mi?
Dialogue: 0,0:02:56.66,0:02:57.82,Main-207-,,0,0,0,,H-Ha?
Dialogue: 0,0:02:59.20,0:03:00.12,Main-207-,,0,0,0,,Nereye gitti?
Dialogue: 0,0:03:01.29,0:03:02.66,Main-207-,,0,0,0,,Luffy! Denizde!
Dialogue: 0,0:03:02.66,0:03:03.50,Main-207-,,0,0,0,,Deniz mi?
Dialogue: 0,0:03:05.96,0:03:07.42,Main-207-,,0,0,0,,Köpek balığı!
Dialogue: 0,0:03:08.92,0:03:10.63,Main-207-,,0,0,0,,Arlong o!
Dialogue: 0,0:03:13.42,0:03:15.30,Main-207-,,0,0,0,,Ne? Suya mı daldı?
Dialogue: 0,0:03:16.43,0:03:21.35,Main-207-,,0,0,0,,Bu kötü işte!\NSuda iki kat daha güçlü.
Dialogue: 0,0:03:24.68,0:03:29.86,Thoughts-207-,,0,0,0,,Su altında hızlandıktan sonra\Nbeni kimse durduramaz.
Dialogue: 0,0:03:29.86,0:03:34.86,Thoughts-207-,,0,0,0,,Bu yetenek, özellikle\Nbalıkadamlara bahşedildi.
Dialogue: 0,0:03:36.36,0:03:37.82,Main-207-,,0,0,0,,Kaçtı mı?
Dialogue: 0,0:03:43.54,0:03:46.33,Main-207-,,0,0,0,,{\fad(150,150)}Köpek Balığı...
Dialogue: 0,0:03:46.33,0:03:48.67,Main-207-,,0,0,0,,{\fad(150,150)}Oku!
Dialogue: 0,0:03:54.76,0:03:55.92,Main-207-,,0,0,0,,O da neydi?!
Dialogue: 0,0:03:56.67,0:03:58.01,Main-207-,,0,0,0,,Torpido mu?!
Dialogue: 0,0:04:01.26,0:04:03.97,Main-207-,,0,0,0,,Denizden bir şey uçtu!
Dialogue: 0,0:04:04.56,0:04:08.39,Main-207-,,0,0,0,,Ah...! Ah, ah, ah, ah...
Dialogue: 0,0:04:12.90,0:04:16.69,Main-207-,,0,0,0,,Vay, savuşturman etkileyici.
Dialogue: 0,0:04:16.69,0:04:21.70,Main-207-,,0,0,0,,Ama ne kadar çok savuşturursan,\No kadar cehennemi yaşarsın.
Dialogue: 0,0:04:22.95,0:04:28.66,Main-207-,,0,0,0,,{\fad(150,150)}Köpek Balığı Oku!
Dialogue: 0,0:04:38.67,0:04:42.64,Main-207-,,0,0,0,,K-Köpek balığı kemikleri\Nneyden yapılmış ki?!
Dialogue: 0,0:04:43.47,0:04:45.60,Main-207-,,0,0,0,,Burnu yeri parçaladı!
Dialogue: 0,0:04:45.60,0:04:49.85,Main-207-,,0,0,0,,{\fad(150,150)}Köpek Balığı Oku!
Dialogue: 0,0:05:04.83,0:05:09.29,Main-207-,,0,0,0,,Hey Luffy, saklanman lazım!\NArlong tekrar denize girdi!
Dialogue: 0,0:05:10.79,0:05:13.58,Main-207-,,0,0,0,,Abi! Lütfen acele et ve saklan!
Dialogue: 0,0:05:13.58,0:05:15.80,Main-207-,,0,0,0,,Tekrar seni hedefliyor!
Dialogue: 0,0:05:19.76,0:05:21.76,Main-207-,,0,0,0,,Çekil oradan!
Dialogue: 0,0:05:24.39,0:05:26.76,Main-207-,,0,0,0,,H... Hayır...
Dialogue: 0,0:05:27.89,0:05:31.77,Main-207-,,0,0,0,,Aptal olma! Hedef olmak mı\Nistiyorsun?! Siper al!
Dialogue: 0,0:05:32.44,0:05:36.77,Main-207-,,0,0,0,,İstemiyorum!\NOnu yakalayıp burnunu kıracağım!
Dialogue: 0,0:05:37.19,0:05:39.99,Main-207-,,0,0,0,,Gel bakalım, köpek balığı!
Dialogue: 0,0:05:43.45,0:05:45.20,Main-207-,,0,0,0,,Cesaretin varmış.
Dialogue: 0,0:05:45.20,0:05:48.91,Main-207-,,0,0,0,,Yoksa kaçmanın seni\Nkurtarmayacağını mı fark ettin?
Dialogue: 0,0:05:50.25,0:05:53.54,Main-207-,,0,0,0,,Saklanmam gerektiğini\Ngöremiyor musun, Luffy?!
Dialogue: 0,0:05:53.54,0:05:57.55,Main-207-,,0,0,0,,Saldırılarından kıl payı kaçındın\Nve hepsi seni yaraladı!
Dialogue: 0,0:05:57.55,0:06:01.47,Main-207-,,0,0,0,,Eğer o saldırı tüm hızıyla\Nseni vurursa anında ölürsün!
Dialogue: 0,0:06:01.47,0:06:03.34,Main-207-,,0,0,0,,{\fad(150,150)}Lastik-Lastik...
Dialogue: 0,0:06:03.89,0:06:08.39,Main-207-,,0,0,0,,{\fad(150,150)}Kalkan!
Dialogue: 0,0:06:08.39,0:06:10.39,Main-207-,,0,0,0,,O duruş da ne?
Dialogue: 0,0:06:10.39,0:06:12.35,Main-207-,,0,0,0,,Saldırıyı öyle durduracağını mı sanıyor?
Dialogue: 0,0:06:13.31,0:06:15.31,Main-207-,,0,0,0,,İki kat mesafeyle daha da hızlanacağım!
Dialogue: 0,0:06:15.98,0:06:18.48,Main-207-,,0,0,0,,Kalbini deşip geçeceğim!
Dialogue: 0,0:06:18.48,0:06:23.11,Main-207-,,0,0,0,,{\fad(150,150)}Köpek Balığı Oku!
Dialogue: 0,0:06:28.83,0:06:30.70,Main-207-,,0,0,0,,Vuruldu!
Dialogue: 0,0:06:43.51,0:06:45.59,Main-207-,,0,0,0,,Bekleyin, vuruldu mu?!
Dialogue: 0,0:06:46.09,0:06:48.55,Main-207-,,0,0,0,,Hayır! Kendini uzağa fırlattı!
Dialogue: 0,0:06:51.27,0:06:54.48,Main-207-,,0,0,0,,Kaybettin! O saldırı artık işe yaramaz.
Dialogue: 0,0:06:54.48,0:06:58.06,Main-207-,,0,0,0,,{\fad(150,150)}Köpek Balığı Oku!
Dialogue: 0,0:07:03.69,0:07:06.20,Main-207-,,0,0,0,,Şerefsiz! Bu sadece şans eseri tuttu!
Dialogue: 0,0:07:06.20,0:07:07.91,Main-207-,,0,0,0,,Bu bitirici vuruş!
Dialogue: 0,0:07:08.53,0:07:09.87,Main-207-,,0,0,0,,Bana vuramayacaksın!
Dialogue: 0,0:07:10.28,0:07:11.83,Main-207-,,0,0,0,,{\fad(150,150)}Lastik-Lastik...
Dialogue: 0,0:07:12.20,0:07:13.62,Main-207-,,0,0,0,,{\fad(150,150)}Ağ!
Dialogue: 0,0:07:15.75,0:07:17.75,Main-207-,,0,0,0,,Balık! Balık tutuyorum!
Dialogue: 0,0:07:23.51,0:07:25.01,Main-207-,,0,0,0,,Ve...
Dialogue: 0,0:07:28.14,0:07:29.80,Main-207-,,0,0,0,,{\fad(150,150)}Mızrak!
Dialogue: 0,0:07:36.02,0:07:37.90,Main-207-,,0,0,0,,Oha!
Comment: 0,0:07:41.69,0:07:42.86,Main-207-,,0,0,0,,(Something said here in the background)
Dialogue: 0,0:07:43.57,0:07:46.07,Main-207-,,0,0,0,,Hım? Öldü mü?
Dialogue: 0,0:07:48.66,0:07:50.49,Main-207-,,0,0,0,,Arlong’un bakışları değişti!
Dialogue: 0,0:07:50.99,0:07:54.79,Main-207-,,0,0,0,,Bakışları tam deniz krallarının\Nsaldırı öncesi hali gibi.
Dialogue: 0,0:07:55.75,0:07:58.00,Main-207-,,0,0,0,,Luffy'nin saldırısı onu kızdırmış olmalı!
Dialogue: 0,0:08:00.46,0:08:04.42,Main-207-,,0,0,0,,Gözlerini hiç böyle görmemiştim.
Dialogue: 0,0:08:04.80,0:08:07.59,Main-207-,,0,0,0,,Aşağılık insan!
Dialogue: 0,0:08:09.34,0:08:11.51,Main-207-,,0,0,0,,Benim gibi bir balıkadama...
Dialogue: 0,0:08:12.56,0:08:15.22,Main-207-,,0,0,0,,ne yaptığını sanıyorsun?!
Dialogue: 0,0:08:23.32,0:08:25.32,Main-207-,,0,0,0,,Üff, şok ediciydi!
Dialogue: 0,0:08:25.32,0:08:29.28,Main-207-,,0,0,0,,Acımadı ama oldukça sinirlendiği belli.
Dialogue: 0,0:08:39.79,0:08:41.42,Main-207-,,0,0,0,,O da ne öyle?
Dialogue: 0,0:08:41.79,0:08:43.04,Main-207-,,0,0,0,,Kiribachi!
Dialogue: 0,0:08:43.04,0:08:45.42,Main-207-,,0,0,0,,Dev bir testere!
Dialogue: 0,0:09:07.40,0:09:08.74,Main-207-,,0,0,0,,Luffy abi!
Dialogue: 0,0:09:08.74,0:09:10.36,Main-207-,,0,0,0,,Dayan, Luffy!
Dialogue: 0,0:09:10.74,0:09:13.37,Secondary-207-,,0,0,0,,{\an8}Kaç! Dikkat et!
Dialogue: 0,0:09:10.74,0:09:13.37,Main-207-,,0,0,0,,Saldırı hiç dinmiyor. Köşeye sıkıştı!
Dialogue: 0,0:09:21.33,0:09:22.88,Main-207-,,0,0,0,,Binanın içine kaçtı!
Dialogue: 0,0:09:29.92,0:09:33.09,Main-207-,,0,0,0,,En üst kattaki sol pencere.
Dialogue: 0,0:09:34.43,0:09:36.10,Main-207-,,0,0,0,,O oda...
Dialogue: 0,0:09:37.47,0:09:39.48,Main-207-,,0,0,0,,Kaçacak yerin kalmadı.
Dialogue: 0,0:09:40.27,0:09:44.15,Main-207-,,0,0,0,,Bu Arlong Park'ın en üst katı.
Dialogue: 0,0:09:44.65,0:09:46.07,Main-207-,,0,0,0,,Bu oda da ne?
Dialogue: 0,0:09:46.65,0:09:48.03,Main-207-,,0,0,0,,Kağıtlarla dolu.
Dialogue: 0,0:09:48.03,0:09:50.36,Main-207-,,0,0,0,,Onlar sıradan kağıt değiller.
Dialogue: 0,0:09:50.36,0:09:54.49,Main-207-,,0,0,0,,Burası o kıza\Ndeniz haritaları çizdirdiğim oda.
Dialogue: 0,0:09:56.12,0:09:57.49,Thoughts-207-,,0,0,0,,Harita odası!
Dialogue: 0,0:09:58.33,0:09:59.91,Main-207-,,0,0,0,,Nami'nin odası...
Dialogue: 0,0:09:59.91,0:10:03.83,Main-207-,,0,0,0,,Bunların hepsi\NNami'nin çizdiği haritalar.
Dialogue: 0,0:10:05.38,0:10:10.97,Main-207-,,0,0,0,,Tüm dünyada bu kadar isabetli\Nharitalar çizebilen çok az kişi var!
Dialogue: 0,0:10:11.67,0:10:14.47,Main-207-,,0,0,0,,Kızda yetenek var.
Dialogue: 0,0:10:20.72,0:10:24.10,Main-207-,,0,0,0,,Doğuştan gelen bir yeteneğin\Nheba olması kadar...
Dialogue: 0,0:10:24.10,0:10:26.69,Main-207-,,0,0,0,,üzücü ve anlamsız bir şey yok.
Dialogue: 0,0:10:26.69,0:10:32.32,Main-207-,,0,0,0,,Burada kalıp çizmeye devam ettikçe\Ngerçek mutluluğu bulacak!
Dialogue: 0,0:10:32.32,0:10:36.20,Main-207-,,0,0,0,,Bu kalem kanla kaplanmış.
Dialogue: 0,0:10:36.20,0:10:41.41,Main-207-,,0,0,0,,Eğer dünyaya hükmedeceksem,\NNami’nin haritaları şart!
Dialogue: 0,0:10:43.87,0:10:49.42,Main-207-,,0,0,0,,Deniz haritalarını çizmeye devam\Nedecek! Hepsi benim hırsım için!
Dialogue: 0,0:10:49.42,0:10:53.01,Main-207-,,0,0,0,,Bu haritalardan\Ntüm denizleri öğrendiğimiz an,...
Dialogue: 0,0:10:53.01,0:10:58.68,Main-207-,,0,0,0,,biz balıkadamlar dokunulmaz oluruz\Nve imparatorluğum her yere yayılır!
Dialogue: 0,0:11:00.14,0:11:04.77,Main-207-,,0,0,0,,Doğu Mavi ve bu ada,\Nhedefime giden ilk adım!
Dialogue: 0,0:11:07.23,0:11:12.19,Main-207-,,0,0,0,,Onu benim kadar iyi kullanabileceğini mi sanıyorsun?!
Dialogue: 0,0:11:21.24,0:11:22.83,Thoughts-207-,,0,0,0,,Ne...?! Kiribachi'yi...
Dialogue: 0,0:11:23.37,0:11:25.25,Thoughts-207-,,0,0,0,,kımıldatamıyorum!
Dialogue: 0,0:11:29.29,0:11:30.21,Main-207-,,0,0,0,,Ne?!
Dialogue: 0,0:11:32.00,0:11:33.42,Main-207-,,0,0,0,,"Kullanmak" mı?!
Dialogue: 0,0:11:35.38,0:11:37.76,Secondary-207-,,0,0,0,,İçeride neler oluyor?!
Dialogue: 0,0:11:37.76,0:11:41.51,Main-207-,,0,0,0,,Kahretsin... Ne oluyor, Luffy abi?!
Dialogue: 0,0:11:43.02,0:11:45.48,Main-207-,,0,0,0,,Orada neler olduğunu\Nhiç anlayamıyorum.
Dialogue: 0,0:11:48.73,0:11:49.65,Main-207-,,0,0,0,,Luffy...
Dialogue: 0,0:11:50.94,0:11:53.73,Main-207-,,0,0,0,,Onu ne sanıyorsun?!
Dialogue: 0,0:11:55.95,0:11:59.07,Main-207-,,0,0,0,,Aşağılık bir varlık ama zeki kız.
Dialogue: 0,0:11:59.07,0:12:01.74,Main-207-,,0,0,0,,Eğer insanlar lağım faresi olsaydı...
Dialogue: 0,0:12:01.74,0:12:04.70,Main-207-,,0,0,0,,o muhtemelen şımarık bir kedi olurdu.
Dialogue: 0,0:12:04.70,0:12:06.96,Main-207-,,0,0,0,,Sonuçta, sevimli biri.
Dialogue: 0,0:12:07.54,0:12:12.42,Main-207-,,0,0,0,,Onu beslemeye ve sevdiği\Nkıyafetleri almaya devam edeceğim.
Dialogue: 0,0:12:12.42,0:12:16.01,Main-207-,,0,0,0,,Yaşamak için istediği\Nher şeye sahip olacak.
Dialogue: 0,0:12:16.42,0:12:21.26,Main-207-,,0,0,0,,Tek yapması gereken benim için\Nharita çizmeye devam etmesi.
Dialogue: 0,0:12:23.01,0:12:26.39,Main-207-,,0,0,0,,Sonsuza kadar benim malım olacak...
Dialogue: 0,0:12:26.39,0:12:29.85,Main-207-,,0,0,0,,pardon, tayfamın üyesi demek istedim.
Dialogue: 0,0:12:38.65,0:12:39.32,Main-207-,,0,0,0,,O da ne?!
Dialogue: 0,0:12:42.16,0:12:43.49,Main-207-,,0,0,0,,Masa mı?
Dialogue: 0,0:12:44.24,0:12:45.70,Main-207-,,0,0,0,,Bu bir masa!
Dialogue: 0,0:12:47.25,0:12:49.83,Main-207-,,0,0,0,,Oh be! Sadece masaymış.
Dialogue: 0,0:12:49.83,0:12:53.42,Main-207-,,0,0,0,,Ulan, ödüm koptu. Luffy abi sandım...
Dialogue: 0,0:12:53.79,0:12:55.25,Main-207-,,0,0,0,,Bekle, ortak!
Dialogue: 0,0:12:55.25,0:12:58.38,Main-207-,,0,0,0,,Luffy abinin gücüne inanmıyor musun?!
Dialogue: 0,0:12:58.84,0:13:02.34,Main-207-,,0,0,0,,Ne...?!\NSen de korktun, Johnny!
Dialogue: 0,0:13:02.34,0:13:05.68,Main-207-,,0,0,0,,A-Aptal olma!\NBen, yani... biliyorsun...
Dialogue: 0,0:13:05.68,0:13:07.68,Main-207-,,0,0,0,,D-Doğal olarak\Nkahrolası Arlong sandım!
Dialogue: 0,0:13:07.68,0:13:10.77,Main-207-,,0,0,0,,Ha?! Üstüme oynuyor gibisin!
Dialogue: 0,0:13:10.77,0:13:16.01,Main-207-,,0,0,0,,Ne dedin lan?\NTabii ki Luffy abi asla kaybetmez!
Dialogue: 0,0:13:16.15,0:13:17.36,Main-207-,,0,0,0,,Luffy?
Dialogue: 0,0:13:19.11,0:13:20.70,Main-207-,,0,0,0,,Ne yaptığını sanıyorsun?!
Dialogue: 0,0:13:22.70,0:13:26.37,Main-207-,,0,0,0,,Orada neler oluyor öyle?!\NRastgele şeyler uçmaya başladı!
Dialogue: 0,0:13:36.05,0:13:39.34,Flashbacks-207-,,0,0,0,,Pekâlâ!\NBugünden itibaren odan burası!
Dialogue: 0,0:13:39.34,0:13:41.59,Flashbacks-207-,,0,0,0,,Masan, kalemin...
Dialogue: 0,0:13:41.59,0:13:44.47,Flashbacks-207-,,0,0,0,,İhtiyacın olan her şey burada!
Dialogue: 0,0:13:48.43,0:13:49.73,Main-207-,,0,0,0,,Dur artık!
Dialogue: 0,0:13:51.39,0:13:52.81,Main-207-,,0,0,0,,Haritalarım!
Dialogue: 0,0:13:55.11,0:13:56.15,Main-207-,,0,0,0,,Deniz haritalarım!
Dialogue: 0,0:13:59.82,0:14:00.82,Flashbacks-207-,,0,0,0,,Kahrolası velet!
Dialogue: 0,0:14:00.82,0:14:02.40,Flashbacks-207-,,0,0,0,,Sakın yanlış haritalar çizip...
Dialogue: 0,0:14:03.53,0:14:05.74,Flashbacks-207-,,0,0,0,,beni kandırabileceğini düşünme!
Dialogue: 0,0:14:07.79,0:14:11.21,Flashbacks-207-,,0,0,0,,Gizlice böyle şeyler çizecek vaktin mi var?
Dialogue: 0,0:14:14.75,0:14:19.30,Flashbacks-207-,,0,0,0,,Beni bir daha kandırmayı dene,\Nköydekileri tek tek buraya getirip...
Dialogue: 0,0:14:19.30,0:14:22.01,Flashbacks-207-,,0,0,0,,gözünün önünde boyunlarını kırayım!
Dialogue: 0,0:14:22.01,0:14:23.63,Flashbacks-207-,,0,0,0,,Bu kadınla aynı sonu yaşarlar!
Dialogue: 0,0:14:29.22,0:14:31.68,Main-207-,,0,0,0,,Kahrolası!\NBunları çizmesi sekiz yıl sürdü!
Dialogue: 0,0:14:31.68,0:14:34.65,Main-207-,,0,0,0,,Sekiz yılımı ve hırsımı\No haritalara adadım!
Dialogue: 0,0:14:39.02,0:14:40.61,Flashbacks-207-,,0,0,0,,Bell-mère-{\i1}san{\i0}...
Dialogue: 0,0:14:41.82,0:14:43.57,Flashbacks-207-,,0,0,0,,Nojiko...!
Dialogue: 0,0:14:48.83,0:14:52.29,Main-207-,,0,0,0,,Oldukça sert bir mücadele!
Dialogue: 0,0:14:52.29,0:14:54.83,Main-207-,,0,0,0,,Evet! Sanki ölümüne bir savaş gibi!
Dialogue: 0,0:14:54.83,0:14:55.79,Main-207-,,0,0,0,,Kesinlikle!
Dialogue: 0,0:15:04.22,0:15:05.63,Thoughts-207-,,0,0,0,,Teşekkür ederim...!
Dialogue: 0,0:15:11.89,0:15:14.89,Main-207-,,0,0,0,,Çok ileri gittin, lastik bozuntusu!
Dialogue: 0,0:15:16.90,0:15:19.69,Main-207-,,0,0,0,,"Balıkadamlar harika"...
Dialogue: 0,0:15:19.69,0:15:21.40,Main-207-,,0,0,0,,"deniz haritaları" şöyledir,
Dialogue: 0,0:15:22.40,0:15:23.61,Main-207-,,0,0,0,,"koşullar" böyledir...
Dialogue: 0,0:15:23.61,0:15:25.95,Main-207-,,0,0,0,,Bunlar hakkında\Npek bir şey bilmiyorum...
Dialogue: 0,0:15:26.53,0:15:30.78,Main-207-,,0,0,0,,ama sonunda onu\Nnasıl kurtarabileceğimi buldum!
Dialogue: 0,0:15:36.50,0:15:39.63,Main-207-,,0,0,0,,Bu oda yüzünden\Nburayı terk edemiyor!
Dialogue: 0,0:15:39.63,0:15:44.47,Main-207-,,0,0,0,,Burada olmak istemiyor,\No yüzden her şeyi yok edeceğim!
Dialogue: 0,0:15:45.26,0:15:47.34,Main-207-,,0,0,0,,{\fad(150,150)}Lastik-Lastik...
Dialogue: 0,0:15:48.93,0:15:50.55,Main-207-,,0,0,0,,Ukalalık etme!
Dialogue: 0,0:15:50.55,0:15:55.14,Main-207-,,0,0,0,,Senin gibi aşağılıklar\NArlong Park’ı asla yıkamaz!
Dialogue: 0,0:15:55.85,0:15:58.35,Main-207-,,0,0,0,,{\fad(150,150)}Köpek Balığı...
Dialogue: 0,0:15:58.81,0:16:00.48,Main-207-,,0,0,0,,{\fad(150,150)}Diş Matkabı!
Dialogue: 0,0:16:00.86,0:16:02.52,Main-207-,,0,0,0,,{\fad(150,150)}...Savaş Baltası!
Dialogue: 0,0:16:46.19,0:16:48.90,Main-207-,,0,0,0,,Darbenin Arlong Park'a\Nne yaptığına bakın!
Dialogue: 0,0:16:50.61,0:16:51.95,Main-207-,,0,0,0,,İmkânsız! Çöküyor!
Dialogue: 0,0:16:51.95,0:16:53.58,Main-207-,,0,0,0,,Tehlikeli! Herkes geri çekilsin!
Dialogue: 0,0:16:54.83,0:16:56.33,Main-207-,,0,0,0,,Nami abla! Acele et!
Dialogue: 0,0:16:56.33,0:16:57.62,Main-207-,,0,0,0,,Ama Luffy hâlâ içeride!
Dialogue: 0,0:16:57.62,0:16:58.33,Main-207-,,0,0,0,,Abla!
Dialogue: 0,0:16:58.33,0:16:59.83,Main-207-,,0,0,0,,Luffy! Luffy ne olacak?!
Dialogue: 0,0:17:05.75,0:17:07.59,Main-207-,,0,0,0,,Luffy!
Dialogue: 0,0:17:20.27,0:17:21.44,Main-207-,,0,0,0,,Luffy...
Dialogue: 0,0:17:31.49,0:17:33.12,Main-207-,,0,0,0,,Luffy...
Dialogue: 0,0:17:45.50,0:17:49.76,Main-207-,,0,0,0,,Ah... Ahh!
Dialogue: 0,0:17:49.76,0:17:52.43,Main-207-,,0,0,0,,Bu gürültü de ne?
Dialogue: 0,0:17:57.64,0:17:58.47,Main-207-,,0,0,0,,Luffy...
Dialogue: 0,0:18:12.20,0:18:15.28,Main-207-,,0,0,0,,Arlong Park... yıkıldı!
Dialogue: 0,0:18:15.95,0:18:17.03,Main-207-,,0,0,0,,Abi...
Dialogue: 0,0:18:17.70,0:18:20.66,Main-207-,,0,0,0,,İçeride neler oldu öyle?
Dialogue: 0,0:18:21.66,0:18:23.29,Main-207-,,0,0,0,,Kim kazandı?!
Dialogue: 0,0:18:23.29,0:18:26.63,Main-207-,,0,0,0,,Enkaza bakılırsa... Yoksa...!
Dialogue: 0,0:18:28.00,0:18:29.30,Main-207-,,0,0,0,,Luffy...
Dialogue: 0,0:18:40.22,0:18:41.02,Main-207-,,0,0,0,,Luffy!
Dialogue: 0,0:18:41.02,0:18:44.85,Main-207-,,0,0,0,,– Abi!\N– Abi!
Dialogue: 0,0:18:48.90,0:18:51.61,Main-207-,,0,0,0,,O iyi mi?!
Dialogue: 0,0:18:57.62,0:18:59.87,Main-207-,,0,0,0,,Nami!
Dialogue: 0,0:19:05.92,0:19:08.96,Main-207-,,0,0,0,,Sen bizden birisin!!!
Dialogue: 0,0:19:21.72,0:19:22.64,Main-207-,,0,0,0,,Biliyorum!
Comment: 0,0:00:00.00,0:00:00.00,Main-207-,,0,0,0,,{=39}===============================DIALOGUE============================
