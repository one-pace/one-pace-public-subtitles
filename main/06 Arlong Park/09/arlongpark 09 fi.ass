Dialogue: 0,0:02:29.42,0:02:30.96,Main-207-,,0,0,0,,Käsi on ehjä!
Dialogue: 0,0:02:31.34,0:02:34.47,Main-207-,,0,0,0,,{\q2}Jos hän olisi kiskonut,\Nhampaat olisivat repineet sen.
Dialogue: 0,0:02:34.47,0:02:39.64,Main-207-,,0,0,0,,{\q2}Tuskinpa tuo niin pitkälle\Nhain hampaita ajatteli...
Dialogue: 0,0:02:42.39,0:02:44.69,Main-207-,,0,0,0,,Onko Isoveljen käsi kunnossa?
Dialogue: 0,0:02:56.66,0:02:57.82,Main-207-,,0,0,0,,O-Oho?
Dialogue: 0,0:02:59.20,0:03:00.12,Main-207-,,0,0,0,,Minne se meni?
Dialogue: 0,0:03:01.29,0:03:02.66,Main-207-,,0,0,0,,Luffy! Meressä!
Dialogue: 0,0:03:02.66,0:03:03.50,Main-207-,,0,0,0,,Meressä?
Dialogue: 0,0:03:05.96,0:03:07.42,Main-207-,,0,0,0,,Siellä on hai!
Dialogue: 0,0:03:08.92,0:03:10.63,Main-207-,,0,0,0,,Arlong se on!
Dialogue: 0,0:03:13.42,0:03:15.30,Main-207-,,0,0,0,,Häh? Se sukelsi.
Dialogue: 0,0:03:16.43,0:03:21.35,Main-207-,,0,0,0,,{\q2}Ei hyvä! Vedessä hänen voimansa\Nkasvaa entisestään!
Dialogue: 0,0:03:24.68,0:03:29.86,Thoughts-207-,,0,0,0,,{\q2}Vedessä pääsen\Npysäyttämättömään vauhtiin...!
Dialogue: 0,0:03:29.86,0:03:34.86,Thoughts-207-,,0,0,0,,{\q2}Tällainen voima on siunattu\Nvain meille merenmiehille!
Dialogue: 0,0:03:36.36,0:03:37.82,Main-207-,,0,0,0,,Karkasiko se?
Dialogue: 0,0:03:43.54,0:03:46.33,Main-207-,,0,0,0,,{\fad(150,150)}Hai...
Dialogue: 0,0:03:46.33,0:03:48.67,Main-207-,,0,0,0,,{\fad(150,150)}Tikka!
Dialogue: 0,0:03:54.76,0:03:55.92,Main-207-,,0,0,0,,Mitäh?!
Dialogue: 0,0:03:56.67,0:03:58.01,Main-207-,,0,0,0,,Torpedoko se oli?!
Dialogue: 0,0:04:01.26,0:04:03.97,Main-207-,,0,0,0,,Jotain syöksyi merestä!
Dialogue: 0,0:04:04.56,0:04:08.39,Main-207-,,0,0,0,,Ai...! Ai, ai ai ai...
Dialogue: 0,0:04:14.36,0:04:16.69,Main-207-,,0,0,0,,Hyvin väistetty.
Dialogue: 0,0:04:16.69,0:04:21.70,Main-207-,,0,0,0,,{\q2}Mutta mitä enemmän väistelet,\Nsitä kauemmin piinasi jatkuu!
Dialogue: 0,0:04:22.95,0:04:28.66,Main-207-,,0,0,0,,{\fad(150,150)}Haitikka!
Dialogue: 0,0:04:38.67,0:04:42.64,Main-207-,,0,0,0,,{\q2}M-Millainen luusto tuolla\Nhainkummajaisella on?!
Dialogue: 0,0:04:43.47,0:04:45.60,Main-207-,,0,0,0,,Tyyppi iski nenänsä kiven sisään...!
Dialogue: 0,0:04:45.60,0:04:49.85,Main-207-,,0,0,0,,{\fad(150,150)}Haitikka!
Dialogue: 0,0:05:04.83,0:05:09.29,Main-207-,,0,0,0,,{\q2}Piiloudu, Luffy!\NArlong pulahti taas veteen!
Dialogue: 0,0:05:10.79,0:05:13.58,Main-207-,,0,0,0,,Äkkiä piiloon, Isoveli!
Dialogue: 0,0:05:13.58,0:05:15.80,Main-207-,,0,0,0,,Hän tulee taas perääsi!
Dialogue: 0,0:05:19.76,0:05:21.76,Main-207-,,0,0,0,,Häivy jo!
Dialogue: 0,0:05:24.39,0:05:26.76,Main-207-,,0,0,0,,E... Ei käy...
Dialogue: 0,0:05:27.89,0:05:31.77,Main-207-,,0,0,0,,{\q2}Älä typerehdi!\NOlet maalitauluna, suojaudu!
Dialogue: 0,0:05:32.44,0:05:36.77,Main-207-,,0,0,0,,{\q2}Ei käy! Otan sen kiinni ja\Nväännän nenun poikki!
Dialogue: 0,0:05:37.19,0:05:39.99,Main-207-,,0,0,0,,Anti tulla, haikala!
Dialogue: 0,0:05:43.45,0:05:45.20,Main-207-,,0,0,0,,Pelkuri et ole.
Dialogue: 0,0:05:45.20,0:05:48.91,Main-207-,,0,0,0,,{\q2}Vai tajusitko vain\Nettei hyödytä paeta?
Dialogue: 0,0:05:50.25,0:05:53.54,Main-207-,,0,0,0,,{\q2}Kätkeydy jonnekin, tahvo!\NEtkö tajua, Luffy?!
Dialogue: 0,0:05:53.54,0:05:57.55,Main-207-,,0,0,0,,Otat vain osumaa yhä uudestaan!
Dialogue: 0,0:05:57.55,0:06:01.47,Main-207-,,0,0,0,,Yksikin kunnollinen ja olet vainaa!
Dialogue: 0,0:06:01.47,0:06:03.34,Main-207-,,0,0,0,,{\fad(150,150)}Gumigumi...
Dialogue: 0,0:06:03.89,0:06:08.39,Main-207-,,0,0,0,,{\fad(150,150)}Kilpi!
Dialogue: 0,0:06:08.39,0:06:10.39,Main-207-,,0,0,0,,Mikä tuo asento...?
Dialogue: 0,0:06:10.39,0:06:12.35,Main-207-,,0,0,0,,Tuollako hän sen pysäyttää?!
Dialogue: 0,0:06:13.31,0:06:15.31,Main-207-,,0,0,0,,Vauhtia tuplasti pidemmältä!
Dialogue: 0,0:06:15.98,0:06:18.48,Main-207-,,0,0,0,,Sydämesi on pian vartaassa!
Dialogue: 0,0:06:18.48,0:06:23.11,Main-207-,,0,0,0,,{\fad(150,150)}Haitikka!
Dialogue: 0,0:06:28.83,0:06:30.70,Main-207-,,0,0,0,,Suora osuma!
Dialogue: 0,0:06:43.51,0:06:45.59,Main-207-,,0,0,0,,Mitä nyt?! Osuiko se?!
Dialogue: 0,0:06:46.09,0:06:48.55,Main-207-,,0,0,0,,Ei! Jätkä lennätti itsensä sivuun.
Dialogue: 0,0:06:51.27,0:06:54.48,Main-207-,,0,0,0,,{\q2}Se oli siinä!\NTuo temppu ei tepsi enää!
Dialogue: 0,0:06:54.48,0:06:58.06,Main-207-,,0,0,0,,{\fad(150,150)}Haitikka!
Dialogue: 0,0:07:03.69,0:07:06.20,Main-207-,,0,0,0,,Kutale...! Se oli tuuria, eikö vaan?!
Dialogue: 0,0:07:06.20,0:07:07.91,Main-207-,,0,0,0,,Armonisku!
Dialogue: 0,0:07:08.53,0:07:09.87,Main-207-,,0,0,0,,Älä luule!
Dialogue: 0,0:07:10.28,0:07:11.83,Main-207-,,0,0,0,,{\fad(150,150)}Gumigumi...
Dialogue: 0,0:07:12.20,0:07:13.62,Main-207-,,0,0,0,,{\fad(150,150)}Verkko!
Dialogue: 0,0:07:15.75,0:07:17.75,Main-207-,,0,0,0,,Anna Antti ahvenia!
Dialogue: 0,0:07:23.51,0:07:25.01,Main-207-,,0,0,0,,Ja...
Dialogue: 0,0:07:28.14,0:07:29.80,Main-207-,,0,0,0,,{\fad(150,150)}Keihäs!
Dialogue: 0,0:07:36.02,0:07:37.90,Main-207-,,0,0,0,,Jummijammi!
Dialogue: 0,0:07:41.69,0:07:42.86,Secondary-207-,,0,0,0,,Tuo tuntui!
Dialogue: 0,0:07:43.57,0:07:46.07,Main-207-,,0,0,0,,Hä? Kuoliko se?
Dialogue: 0,0:07:48.66,0:07:50.49,Main-207-,,0,0,0,,Arlongin katse muuttui!
Dialogue: 0,0:07:50.99,0:07:54.79,Main-207-,,0,0,0,,{\q2}Sama tuijotus kuin\Nraivostuneilla merihirviöillä.
Dialogue: 0,0:07:55.75,0:07:58.00,Main-207-,,0,0,0,,{\q2}Äskeinen sai Arlongin\Nveren kiehumaan...!
Dialogue: 0,0:08:00.46,0:08:04.42,Main-207-,,0,0,0,,{\q2}En ole koskaan nähnyt häntä\Ntuon näköisenä...
Dialogue: 0,0:08:04.80,0:08:07.59,Main-207-,,0,0,0,,Alhainen ihmisolio!
Dialogue: 0,0:08:09.34,0:08:11.51,Main-207-,,0,0,0,,Mitä luulet tekeväsi...
Dialogue: 0,0:08:12.56,0:08:15.22,Main-207-,,0,0,0,,merenmiehelle?!
Dialogue: 0,0:08:23.32,0:08:25.32,Main-207-,,0,0,0,,Osasipa säikäyttää...
Dialogue: 0,0:08:25.32,0:08:29.28,Main-207-,,0,0,0,,{\q2}Ei tosin sattunut.\NTaisi kaveri suuttua...
Dialogue: 0,0:08:39.79,0:08:41.42,Main-207-,,0,0,0,,Mikä hitsi toi on?
Dialogue: 0,0:08:41.79,0:08:43.04,Main-207-,,0,0,0,,"Hammasrauta"!
Dialogue: 0,0:08:43.04,0:08:45.42,Main-207-,,0,0,0,,Megakokoinen saha!
Dialogue: 0,0:09:07.40,0:09:08.74,Main-207-,,0,0,0,,Isoveli Luffy!
Dialogue: 0,0:09:08.74,0:09:10.36,Main-207-,,0,0,0,,Sinnittele, Luffy!
Dialogue: 0,0:09:10.74,0:09:13.37,Secondary-207-,,0,0,0,,{\an8}Juokse! Varo!
Dialogue: 0,0:09:10.74,0:09:13.37,Main-207-,,0,0,0,,{\q2}Ei edes hengähdystaukoa!\NHänet ajetaan nurkkaan!
Dialogue: 0,0:09:21.33,0:09:22.88,Main-207-,,0,0,0,,Hän väisti sisälle!
Dialogue: 0,0:09:29.92,0:09:33.09,Main-207-,,0,0,0,,Yläkerroksen vasen ikkuna...
Dialogue: 0,0:09:34.43,0:09:36.10,Main-207-,,0,0,0,,Tuo huonehan on...
Dialogue: 0,0:09:37.47,0:09:39.48,Main-207-,,0,0,0,,Pakomatka päättyi tähän.
Dialogue: 0,0:09:40.27,0:09:44.15,Main-207-,,0,0,0,,Tämä on Arlong Parkin ylin kerros.
Dialogue: 0,0:09:44.65,0:09:46.07,Main-207-,,0,0,0,,Mikäs kumman huone?
Dialogue: 0,0:09:46.65,0:09:48.03,Main-207-,,0,0,0,,Pelkkiä papereita.
Dialogue: 0,0:09:48.03,0:09:50.36,Main-207-,,0,0,0,,Ei mitä tahansa paperia.
Dialogue: 0,0:09:50.36,0:09:54.49,Main-207-,,0,0,0,,{\q2}Tänne Nami on pistetty piirtämään\Nmerikarttoja. Tämä on...
Dialogue: 0,0:09:55.97,0:09:57.49,Thoughts-207-,,0,0,0,,...karttahuone...!
Dialogue: 0,0:09:58.33,0:09:59.91,Main-207-,,0,0,0,,Namin huone...
Dialogue: 0,0:09:59.91,0:10:03.83,Main-207-,,0,0,0,,Nämä ovat kaikki hänen piirtämiä.
Dialogue: 0,0:10:05.38,0:10:10.97,Main-207-,,0,0,0,,{\q2}Kuinka moni muu tässä maailmassa\Nosaisikaan piirtää näin tarkkoja karttoja?
Dialogue: 0,0:10:11.67,0:10:14.43,Main-207-,,0,0,0,,Se nainen on nero.
Dialogue: 0,0:10:20.68,0:10:24.06,Main-207-,,0,0,0,,Lahjojen hukkaan valuminen
Dialogue: 0,0:10:24.06,0:10:26.65,Main-207-,,0,0,0,,on surkuteltavin kohtalo!
Dialogue: 0,0:10:26.65,0:10:32.32,Main-207-,,0,0,0,,{\q2}Nami on siis onnellinen\Nsaadessaan piirtää karttoja täällä!
Dialogue: 0,0:10:32.32,0:10:36.16,Main-207-,,0,0,0,,Tähän kynään on pinttynyt verta...
Dialogue: 0,0:10:36.53,0:10:41.37,Main-207-,,0,0,0,,{\q2}Namin kartat ovat elintärkeitä\Nmaailman valloittamiseen!
Dialogue: 0,0:10:43.83,0:10:49.42,Main-207-,,0,0,0,,{\q2}Se nainen tulee jatkamaan merikarttojen\Nkyhäämistä mun tavoitteeni vuoksi!
Dialogue: 0,0:10:49.42,0:10:53.01,Main-207-,,0,0,0,,Maailman meret kartoitettuamme
Dialogue: 0,0:10:53.01,0:10:58.68,Main-207-,,0,0,0,,{\q2}me merenmiehet olemme voittamattomia,\Nja musta tulee maailmanvaltias!
Dialogue: 0,0:11:00.14,0:11:04.77,Main-207-,,0,0,0,,{\q2}Tämä saari ja East Blue\Novat ponnahduslautani!
Dialogue: 0,0:11:07.23,0:11:12.19,Main-207-,,0,0,0,,{\q2}Luuletko pystyväsi käyttämään\Nsitä naista mua paremmin?!
Dialogue: 0,0:11:21.24,0:11:22.83,Thoughts-207-,,0,0,0,,Mitäh...?! Hammasrauta...
Dialogue: 0,0:11:23.37,0:11:25.25,Thoughts-207-,,0,0,0,,ei hievahdakaan!
Dialogue: 0,0:11:29.29,0:11:30.21,Main-207-,,0,0,0,,Mitä?!
Dialogue: 0,0:11:32.00,0:11:33.42,Main-207-,,0,0,0,,"Käyttää"?!
Dialogue: 0,0:11:35.38,0:11:37.76,Secondary-207-,,0,0,0,,Mitä sisällä on meneillään?!
Dialogue: 0,0:11:37.76,0:11:41.51,Main-207-,,0,0,0,,{\q2}Saakura...! Miten\NIsoveli Luffy pärjää?
Dialogue: 0,0:11:43.02,0:11:45.48,Main-207-,,0,0,0,,Tänne alas ei näy yhtään mitään...
Dialogue: 0,0:11:48.73,0:11:49.65,Main-207-,,0,0,0,,Luffy...
Dialogue: 0,0:11:50.94,0:11:53.73,Main-207-,,0,0,0,,Minä sä oikein pidät Namia?!
Dialogue: 0,0:11:55.95,0:11:59.07,Main-207-,,0,0,0,,{\q2}Hän on älykäs,\Nvaikka onkin alempaa rotua...
Dialogue: 0,0:11:59.07,0:12:01.74,Main-207-,,0,0,0,,Jos muut ihmiset ovat rottia,
Dialogue: 0,0:12:01.74,0:12:04.70,Main-207-,,0,0,0,## OVERWIDTH WITH FORCED WRAP ##,{\q2}Nami voisi olla röyhkeä katinretale...
Dialogue: 0,0:12:04.70,0:12:06.96,Main-207-,,0,0,0,,Herttainen otus silti.
Dialogue: 0,0:12:07.54,0:12:12.42,Main-207-,,0,0,0,,{\q2}Ruokimme häntä,\Nostamme hienoja vaatteita...
Dialogue: 0,0:12:12.42,0:12:16.01,Main-207-,,0,0,0,,Häneltä ei puutu mitään!
Dialogue: 0,0:12:16.42,0:12:21.26,Main-207-,,0,0,0,,{\q2}Hänen tarvitsee vain\Ntehdä karttoja mulle.
Dialogue: 0,0:12:23.01,0:12:26.39,Main-207-,,0,0,0,,Hän on näet työkaluni...
Dialogue: 0,0:12:26.39,0:12:27.49,Main-207-,,0,0,0,,Ei...
Dialogue: 0,0:12:28.20,0:12:29.85,Main-207-,,0,0,0,,vaan kumppanini.
Dialogue: 0,0:12:38.65,0:12:39.32,Main-207-,,0,0,0,,Mitä nyt?!
Dialogue: 0,0:12:42.16,0:12:43.49,Main-207-,,0,0,0,,Pöytä...?
Dialogue: 0,0:12:44.24,0:12:45.70,Main-207-,,0,0,0,,Pöytä vain...
Dialogue: 0,0:12:47.25,0:12:49.83,Main-207-,,0,0,0,,N-Niinkö... Pelkkä pöytä...
Dialogue: 0,0:12:49.83,0:12:53.42,Main-207-,,0,0,0,## AUTOMATIC LINEBREAK ##,Huh sentään! Luulin että Isoveli Luffy...
Dialogue: 0,0:12:53.42,0:12:55.25,Main-207-,,0,0,0,,Kuules kamu!
Dialogue: 0,0:12:55.25,0:12:58.38,Main-207-,,0,0,0,,Etkö luota Isoveli Luffyn voimaan?!
Dialogue: 0,0:12:58.84,0:13:02.34,Main-207-,,0,0,0,,Täh?! Itsekin säikyit, Johnny!
Dialogue: 0,0:13:02.34,0:13:04.35,Main-207-,,0,0,0,,Tyhmäkö olet?! Mä, eh...
Dialogue: 0,0:13:04.35,0:13:05.81,Main-207-,,0,0,0,,Tietysti...
Dialogue: 0,0:13:05.81,0:13:07.68,Main-207-,,0,0,0,,Luulin Arlongiksi, tietysti...
Dialogue: 0,0:13:07.68,0:13:10.77,Main-207-,,0,0,0,,{\q2}Täh?! Kuulostaa siltä että\Nkoitat vedättää mua!
Dialogue: 0,0:13:10.77,0:13:16.01,Main-207-,,0,0,0,,{\q2}{\fad(0,2000)}Että mitä?! Isoveli Luffy\Nei tietenkään koskaan häviäisi!
Dialogue: 0,0:13:16.15,0:13:17.36,Main-207-,,0,0,0,,Luffy?
Dialogue: 0,0:13:19.11,0:13:20.70,Main-207-,,0,0,0,,Mitä sä kuvittelet tekeväsi?!
Dialogue: 0,0:13:22.70,0:13:26.37,Main-207-,,0,0,0,,{\q2}Mitä ihmettä...?! Sieltä lentää\Nkamaa ihan solkenaan!
Dialogue: 0,0:13:36.05,0:13:39.34,Flashbacks-207-,,0,0,0,,Tämä on tästedes sun huoneesi.
Dialogue: 0,0:13:39.34,0:13:41.59,Flashbacks-207-,,0,0,0,,Sun pöytäsi, sun kynäsi...
Dialogue: 0,0:13:41.59,0:13:44.47,Flashbacks-207-,,0,0,0,,Täällä on kaikki tarvittava!
Dialogue: 0,0:13:48.43,0:13:49.73,Main-207-,,0,0,0,,Nyt saa riittää!
Dialogue: 0,0:13:51.39,0:13:52.81,Main-207-,,0,0,0,,Merikartat!
Dialogue: 0,0:13:55.11,0:13:56.15,Main-207-,,0,0,0,,M-Mun karttani!
Dialogue: 0,0:13:59.82,0:14:00.82,Flashbacks-207-,,0,0,0,,Senkin kakara!
Dialogue: 0,0:14:00.82,0:14:02.40,Flashbacks-207-,,0,0,0,,Turha yrittää petkuttaa...
Dialogue: 0,0:14:03.53,0:14:05.74,Flashbacks-207-,,0,0,0,,Ei enää valekarttoja!
Dialogue: 0,0:14:07.79,0:14:11.21,Flashbacks-207-,,0,0,0,,{\q2}Miten sinulla on aikaa piirrellä\Ntällaista sontaa salassa?
Dialogue: 0,0:14:14.75,0:14:19.30,Flashbacks-207-,,0,0,0,,{\q2}Jos vielä kerran teet samanlaisen tempun,\Nraahaan kyläläiset tänne yksitellen...
Dialogue: 0,0:14:19.30,0:14:22.01,Flashbacks-207-,,0,0,0,,{\q2}ja pistän sut katsomaan\Nkun päätän heidän päivänsä!
Dialogue: 0,0:14:22.01,0:14:23.63,Flashbacks-207-,,0,0,0,,Hänen laillaan!
Dialogue: 0,0:14:29.22,0:14:31.68,Main-207-,,0,0,0,,Teetin noita Namilla vuosia!
Dialogue: 0,0:14:31.68,0:14:34.65,Main-207-,,0,0,0,,{\q2}Kulutin kahdeksan vuotta niihin\Nkarttoihin! Mun tavoitteeseeni!
Dialogue: 0,0:14:39.02,0:14:40.61,Flashbacks-207-,,0,0,0,,Bell-mère...
Dialogue: 0,0:14:41.82,0:14:43.57,Flashbacks-207-,,0,0,0,,Nojiko...!
Dialogue: 0,0:14:48.83,0:14:52.29,Main-207-,,0,0,0,,Tämä vasta on raju matsi...
Dialogue: 0,0:14:52.29,0:14:54.83,Main-207-,,0,0,0,,Joo! Kuolemaan asti.
Dialogue: 0,0:14:54.83,0:14:55.79,Main-207-,,0,0,0,,Epäilemättä!
Dialogue: 0,0:15:04.22,0:15:05.63,Thoughts-207-,,0,0,0,,Kiitos...
Dialogue: 0,0:15:11.89,0:15:14.89,Main-207-,,0,0,0,,Menit liian pitkälle, kumiretku!
Dialogue: 0,0:15:16.90,0:15:19.69,Main-207-,,0,0,0,,Vähät merenmiehistä...
Dialogue: 0,0:15:19.69,0:15:21.40,Main-207-,,0,0,0,,vähät kartoista...
Dialogue: 0,0:15:22.40,0:15:23.61,Main-207-,,0,0,0,,ja muista höpinöistä...
Dialogue: 0,0:15:23.61,0:15:25.95,Main-207-,,0,0,0,,{\q2}En tajua juttujasi\Neikä kiinnostakaan...
Dialogue: 0,0:15:26.53,0:15:30.78,Main-207-,,0,0,0,,{\q2}mutta tiedän nyt,\Nmiten auttaa Namia...!
Dialogue: 0,0:15:36.50,0:15:39.63,Main-207-,,0,0,0,,{\q2}Tällaista huonetta\Nei saisi olla olemassa!
Dialogue: 0,0:15:39.63,0:15:42.25,Main-207-,,0,0,0,,{\q2}Nami ei tarvitse paikkaa,\Njossa hän ei edes tahdo olla!
Dialogue: 0,0:15:42.25,0:15:44.47,Main-207-,,0,0,0,,Hajotan sen maan tasalle!
Dialogue: 0,0:15:45.26,0:15:47.34,Main-207-,,0,0,0,,{\fad(150,150)}Gumigumi...
Dialogue: 0,0:15:48.93,0:15:50.55,Main-207-,,0,0,0,,Älä luule liikoja!
Dialogue: 0,0:15:50.55,0:15:55.14,Main-207-,,0,0,0,,{\q2}Kaltaisesi mitätön itikka\Nei ikimaailmassa tuhoa Arlong Parkia!
Dialogue: 0,0:15:55.85,0:15:58.35,Main-207-,,0,0,0,,{\fad(150,150)}Hammas...
Dialogue: 0,0:15:58.81,0:16:00.48,Main-207-,,0,0,0,,{\fad(150,150)}Pyörä!
Dialogue: 0,0:16:00.86,0:16:02.52,Main-207-,,0,0,0,,{\fad(150,150)}...Kirves!
Dialogue: 0,0:16:46.19,0:16:48.90,Main-207-,,0,0,0,,{\q2}K-Katsokaa! Äskeinen sai\NArlong Parkin säröille!
Dialogue: 0,0:16:50.61,0:16:51.95,Main-207-,,0,0,0,,Ei voi olla! Se alkaa sortua!
Dialogue: 0,0:16:51.95,0:16:53.58,Main-207-,,0,0,0,,Varokaa! Äkkiä kauemmas!
Dialogue: 0,0:16:54.83,0:16:56.33,Main-207-,,0,0,0,,Pian, Isosisko Nami!
Dialogue: 0,0:16:56.33,0:16:57.62,Main-207-,,0,0,0,,Luffy on vielä sisällä!
Dialogue: 0,0:16:57.62,0:16:58.33,Main-207-,,0,0,0,,Isosisko!
Dialogue: 0,0:16:58.33,0:16:59.83,Main-207-,,0,0,0,,Luffy! Luffy on...!
Dialogue: 0,0:17:05.75,0:17:07.59,Main-207-,,0,0,0,,Luffy!
Dialogue: 0,0:17:20.27,0:17:21.44,Main-207-,,0,0,0,,Luffy...
Dialogue: 0,0:17:31.49,0:17:33.12,Main-207-,,0,0,0,,Luffy...
Dialogue: 0,0:17:45.50,0:17:49.76,Main-207-,,0,0,0,,Au... Auh!
Dialogue: 0,0:17:49.76,0:17:52.43,Main-207-,,0,0,0,,Karsee melske...
Dialogue: 0,0:17:57.64,0:17:58.47,Main-207-,,0,0,0,,Luffy...
Dialogue: 0,0:18:12.20,0:18:15.28,Main-207-,,0,0,0,,Arlong Park... sortui...!
Dialogue: 0,0:18:15.95,0:18:17.03,Main-207-,,0,0,0,,Isoveli...
Dialogue: 0,0:18:17.70,0:18:20.66,Main-207-,,0,0,0,,Mitä sisällä oikein tapahtui?!
Dialogue: 0,0:18:21.66,0:18:23.29,Main-207-,,0,0,0,,Kumpi voitti?!
Dialogue: 0,0:18:23.29,0:18:26.63,Main-207-,,0,0,0,,Tuollainen tuho... Ei kai vain...!
Dialogue: 0,0:18:28.00,0:18:29.30,Main-207-,,0,0,0,,Luffy...
Dialogue: 0,0:18:40.22,0:18:41.02,Main-207-,,0,0,0,,Luffy!
Dialogue: 0,0:18:41.02,0:18:44.85,Main-207-,,0,0,0,,{\q2}– Isoveli!\N– Isoveli!
Dialogue: 0,0:18:48.90,0:18:51.61,Main-207-,,0,0,0,,Pahassa kunnossa...
Dialogue: 0,0:18:57.62,0:18:59.87,Main-207-,,0,0,0,,Nami!
Dialogue: 0,0:19:05.92,0:19:08.96,Main-207-,,0,0,0,,Sä olet mun toverini!
Dialogue: 0,0:19:21.72,0:19:22.64,Main-207-,,0,0,0,,Kyllä!
