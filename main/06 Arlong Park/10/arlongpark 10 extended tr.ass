Comment: 0,0:00:00.00,0:00:00.00,Main-207-,,0,0,0,,{=58}===============================DIALOGUE============================
Dialogue: 0,0:01:53.51,0:01:54.43,Main-207-,,0,0,0,,– Kazandı!\N– Kazandı!
Dialogue: 0,0:01:55.47,0:01:59.43,Main-207-,,0,0,0,,Arlong Park yıkıldı!
Dialogue: 0,0:02:01.06,0:02:02.60,Main-207-,,0,0,0,,Başardık, ablacığım!
Dialogue: 0,0:02:02.06,0:02:02.60,Secondary-207-,,0,0,0,,Gen-{\i1}san{\i0}!
Dialogue: 0,0:02:02.98,0:02:06.69,Main-207-,,0,0,0,,Yoksa... Yoksa rüya mı görüyorum?
Dialogue: 0,0:02:06.69,0:02:08.61,Main-207-,,0,0,0,,Bunun olacağını hiç düşünmemiştim.
Dialogue: 0,0:02:21.79,0:02:25.42,Main-207-,,0,0,0,,Aferin sana, Luffy!\NBen de takdirimi sunuyorum!
Dialogue: 0,0:02:25.42,0:02:31.09,Main-207-,,0,0,0,,Yine de bana daha fazla rol verseydin,\Nseni daha da çok överdim!
Dialogue: 0,0:02:31.76,0:02:34.05,Main-207-,,0,0,0,,Biraz endişelendirdin.
Dialogue: 0,0:02:34.93,0:02:39.51,Main-207-,,0,0,0,,Bir dahakine daha hızlı ol,\Nkahrolası serseri!
Dialogue: 0,0:03:08.33,0:03:10.09,Main-207-,,0,0,0,,Bu harika!
Dialogue: 0,0:03:23.14,0:03:25.14,Main-207-,,0,0,0,,Pekâlâ, bu kadar yeter!
Dialogue: 0,0:03:26.27,0:03:27.10,Main-207-,,0,0,0,,Bu o...!
Dialogue: 0,0:03:28.60,0:03:30.86,Main-207-,,0,0,0,,Bugün şanslı günümdeyim!
Dialogue: 0,0:03:30.86,0:03:34.74,Main-207-,,0,0,0,,Tebrikler.\NSavaşın hepsini izledim.
Dialogue: 0,0:03:34.74,0:03:39.28,Main-207-,,0,0,0,,Şans ya da değil, balık adamların\Nsizin gibi isimsiz korsanlara...
Dialogue: 0,0:03:39.28,0:03:42.08,Main-207-,,0,0,0,,yenileceğini asla düşünmemiştim.
Dialogue: 0,0:03:43.04,0:03:46.62,Main-207-,,0,0,0,,Ancak, sizin sayenizde\NArlong'a vereceğim tüm para...
Dialogue: 0,0:03:46.62,0:03:50.96,Main-207-,,0,0,0,,ve Arlong Park'ta bulunan\Ntüm değerli şeyler artık benim!
Dialogue: 0,0:03:50.96,0:03:52.30,Main-207-,,0,0,0,,Herkes silahını atsın!
Dialogue: 0,0:03:52.30,0:03:55.51,Main-207-,,0,0,0,,Bu olayın başarısı artık bana,\N16. Denizci Üssü Albayı,
Dialogue: 0,0:03:55.51,0:03:57.43,Main-207-,,0,0,0,,Nezumi'ye ait!
Dialogue: 0,0:04:00.01,0:04:00.64,Main-207-,,0,0,0,,Zoro!
Dialogue: 0,0:04:01.10,0:04:04.85,Main-207-,,0,0,0,,Nihayet insanlar mutluyken\Nkeyiflerini kaçırma!
Dialogue: 0,0:04:10.23,0:04:15.15,Main-207-,,0,0,0,,B-Bana dokunursanız, pişman olursunuz.
Dialogue: 0,0:04:15.15,0:04:16.57,Main-207-,,0,0,0,,Hâlâ konuşuyor musun?
Dialogue: 0,0:04:20.28,0:04:22.70,Main-207-,,0,0,0,,Bu Nojiko'yu vurduğun...
Dialogue: 0,0:04:23.28,0:04:27.62,Main-207-,,0,0,0,,ve Bell-mère-{\i1}san'{\i0}ın mandalina\Nbahçesine zarar verdiğin için.
Dialogue: 0,0:04:27.62,0:04:28.12,Main-207-,,0,0,0,,Ha?
Dialogue: 0,0:04:30.96,0:04:32.21,Main-207-,,0,0,0,,Albay!
Dialogue: 0,0:04:36.96,0:04:39.59,Main-207-,,0,0,0,,Sağ ol, Nami! Bu harika hissettirdi!
Dialogue: 0,0:04:39.59,0:04:42.09,Main-207-,,0,0,0,,Bunlardan 1.000 tane daha yolla!
Dialogue: 0,0:04:48.27,0:04:51.65,Main-207-,,0,0,0,,Şimdi siz denizciler, balık adamların\Narkasını toplayacaksınız!
Dialogue: 0,0:04:51.65,0:04:54.02,Main-207-,,0,0,0,,Ve Gosa şehrini yeniden inşa edeceksiniz!
Dialogue: 0,0:04:54.02,0:04:58.11,Main-207-,,0,0,0,,Bir de Arlong Park'ta değerli olan\Nhiçbir şeye dokunmayacaksınız!
Dialogue: 0,0:04:58.11,0:05:00.49,Main-207-,,0,0,0,,O para bu adanın! Anlaşıldı mı?!
Dialogue: 0,0:05:00.49,0:05:04.41,Main-207-,,0,0,0,,Ahh! Ahh! N-Ne dersen yaparım!
Dialogue: 0,0:05:04.41,0:05:05.99,Main-207-,,0,0,0,,Ve bir şey daha!
Dialogue: 0,0:05:06.45,0:05:08.20,Main-207-,,0,0,0,,Paramı geri ver!
Dialogue: 0,0:05:08.54,0:05:13.67,Main-207-,,0,0,0,,Geri vereceğim! Geri vereceğim!\NArtık buna değmez!
Dialogue: 0,0:05:17.00,0:05:19.51,Main-207-,,0,0,0,,Sizi yakalayacağım, rezil korsanlar!
Dialogue: 0,0:05:19.51,0:05:22.09,Main-207-,,0,0,0,,Hasır şapkalı adam!\NAdın Luffy, değil mi?!
Dialogue: 0,0:05:22.47,0:05:25.10,Main-207-,,0,0,0,,Kaptan sensin, değil mi?!\NBunu sakın unutma!
Dialogue: 0,0:05:25.10,0:05:28.06,Main-207-,,0,0,0,,Çok ileri gittiniz!\NZorlu yolculuğunuz yeni başlıyor!
Dialogue: 0,0:05:28.43,0:05:30.43,Main-207-,,0,0,0,,Pişmanlık için çok geç!
Dialogue: 0,0:05:30.43,0:05:34.19,Main-207-,,0,0,0,,İntikamımı alacağım!\NBekleyin ve görün!
Dialogue: 0,0:05:34.19,0:05:36.69,Main-207-,,0,0,0,,Bizi zorlu bir yolculuğun\Nbeklediğini söyledi.
Dialogue: 0,0:05:36.69,0:05:40.07,Main-207-,,0,0,0,,Korsanlar Kralı olacağımı\Nnereden biliyor?
Dialogue: 0,0:05:40.07,0:05:42.95,Main-207-,,0,0,0,,Bunu demek istemedi!\NHarbiden aptalsın!
Dialogue: 0,0:05:42.95,0:05:46.53,Main-207-,,0,0,0,,H-Hey, ne yapacağız?! Ya cidden\Nbaşımız büyük belaya girerse?!
Dialogue: 0,0:05:46.53,0:05:48.58,Main-207-,,0,0,0,,Hey! Hey! Ne yapacağız?!
Dialogue: 0,0:05:49.08,0:05:53.08,Main-207-,,0,0,0,,Pekâlâ, millet!\NSadece biz eğlenemeyiz!
Dialogue: 0,0:05:53.08,0:05:56.34,Main-207-,,0,0,0,,Adadaki herkesin\Nbu destansı olayı bilmesi gerekiyor!
Dialogue: 0,0:05:58.67,0:06:00.13,Main-207-,,0,0,0,,Arlong Park...
Dialogue: 0,0:06:00.13,0:06:02.84,Main-207-,,0,0,0,,Arlong Park yıkıldı!
Dialogue: 0,0:06:04.05,0:06:08.06,Main-207-,,0,0,0,,Hey Zoro, göğsündeki şey ne?
Dialogue: 0,0:06:05.43,0:06:08.06,Secondary-207-,,0,0,0,,Ha? Hey, ne yapıyorsu-?
Dialogue: 0,0:06:17.19,0:06:19.40,Main-207-,,0,0,0,,Aferin sana, Nami!
Dialogue: 0,0:06:20.74,0:06:24.74,Main-207-,,0,0,0,,Korsanlar tarafından\Nkurtarıldığımıza inanamıyorum.
Dialogue: 0,0:06:24.74,0:06:26.74,Main-207-,,0,0,0,,Hayat sürprizlerle dolu.
Dialogue: 0,0:06:43.55,0:06:46.55,Main-207-,,0,0,0,,{\i1}Cidden, Nami?! Hâlâ burada mısın?
Dialogue: 0,0:06:47.30,0:06:49.56,Main-207-,,0,0,0,,Dostların seni arıyor, bilgin olsun.
Dialogue: 0,0:06:51.56,0:06:53.18,Main-207-,,0,0,0,,Baksanıza, Nojiko,
Dialogue: 0,0:06:53.18,0:06:53.68,Main-207-,,0,0,0,,Ha?
Dialogue: 0,0:06:53.68,0:06:54.52,Main-207-,,0,0,0,,...Gen-{\i1}san{\i0}.
Dialogue: 0,0:06:54.52,0:06:55.14,Main-207-,,0,0,0,,Hm?
Dialogue: 0,0:06:55.14,0:06:57.65,Main-207-,,0,0,0,,Bell-mère-{\i1}san{\i0} yaşasaydı,
Dialogue: 0,0:06:57.65,0:07:00.61,Main-207-,,0,0,0,,sizce korsan olmamam için\Nbana engel olur muydu?
Dialogue: 0,0:07:01.23,0:07:02.61,Main-207-,,0,0,0,,Korsan mı?!
Dialogue: 0,0:07:03.24,0:07:04.99,Main-207-,,0,0,0,,Saçma sapan konuşma!
Dialogue: 0,0:07:04.99,0:07:08.24,Main-207-,,0,0,0,,Elbette değerli kızının korsan\Nolmasına izin vermezdi!
Dialogue: 0,0:07:08.24,0:07:09.91,Main-207-,,0,0,0,,Engel olmazdı!
Dialogue: 0,0:07:08.95,0:07:09.91,Secondary-207-,,0,0,0,,Nojiko!
Dialogue: 0,0:07:09.91,0:07:11.08,Main-207-,,0,0,0,,Diyelim engel oldu,
Dialogue: 0,0:07:11.87,0:07:13.54,Main-207-,,0,0,0,,onu dinler miydin?
Dialogue: 0,0:07:15.16,0:07:17.54,Main-207-,,0,0,0,,Kesinlikle dinlemezdim!
Dialogue: 0,0:07:20.42,0:07:21.50,Main-207-,,0,0,0,,Anlıyorum...
Dialogue: 0,0:07:24.17,0:07:25.51,Main-207-,,0,0,0,,Neyin var, Gen-{\i1}san{\i0}?
Dialogue: 0,0:07:28.47,0:07:31.97,Main-207-,,0,0,0,,Siz ikiniz, kesinlikle\NBell-mère'nin çocuklarısınız.
Dialogue: 0,0:07:31.97,0:07:33.27,Main-207-,,0,0,0,,Gen-{\i1}san{\i0}?
Dialogue: 0,0:07:33.27,0:07:34.23,Main-207-,,0,0,0,,Nami.
Dialogue: 0,0:07:34.23,0:07:36.77,Main-207-,,0,0,0,,Kararını çoktan verdin, değil mi?
Dialogue: 0,0:07:36.77,0:07:38.31,Main-207-,,0,0,0,,O zaman istediğin gibi yaşa!
Dialogue: 0,0:07:39.06,0:07:40.98,Main-207-,,0,0,0,,Tıpkı annen gibi!
Dialogue: 0,0:07:47.41,0:07:48.61,Main-207-,,0,0,0,,Hâlâ uğraşıyorlar.
Dialogue: 0,0:07:49.53,0:07:52.41,Main-207-,,0,0,0,,Görünüşe göre Zoro acı içinde.
Dialogue: 0,0:07:52.41,0:07:53.91,Main-207-,,0,0,0,,Evet, öyle.
Dialogue: 0,0:07:53.91,0:07:56.87,Main-207-,,0,0,0,,Normal biri bu yaraları 2 yılda atlatırdı!
Dialogue: 0,0:07:58.62,0:07:59.96,Main-207-,,0,0,0,,Geri zekâlı!
Dialogue: 0,0:08:00.46,0:08:02.92,Main-207-,,0,0,0,,Böyle ciddi bir yarayla\Nkendi başına ilgilenmişsin!
Dialogue: 0,0:08:02.92,0:08:04.09,Main-207-,,0,0,0,,Off!
Dialogue: 0,0:08:04.09,0:08:07.13,Main-207-,,0,0,0,,Hakikaten, sizler\Ngerçekten korsan mısınız?!
Dialogue: 0,0:08:07.13,0:08:08.38,Main-207-,,0,0,0,,Geminizde...
Dialogue: 0,0:08:09.30,0:08:10.47,Main-207-,,0,0,0,,doktor yok mu?!
Dialogue: 0,0:08:10.47,0:08:12.89,Main-207-,,0,0,0,,Doktor mu? O da fena olmaz!
Dialogue: 0,0:08:13.26,0:08:13.76,Main-207-,,0,0,0,,Luffy?
Dialogue: 0,0:08:13.76,0:08:16.14,Main-207-,,0,0,0,,Ama önce müzisyen lazım.\NDeğil mi, Zoro?
Dialogue: 0,0:08:16.14,0:08:17.39,Main-207-,,0,0,0,,Nedenmiş o?!
Dialogue: 0,0:08:17.39,0:08:19.65,Main-207-,,0,0,0,,Korsanlar şarkı söyler, değil mi?
Dialogue: 0,0:08:19.65,0:08:22.31,Main-207-,,0,0,0,,Tamam da neden ilk o?!
Dialogue: 0,0:08:22.31,0:08:24.32,Main-207-,,0,0,0,,Alo?! Alo?!
Dialogue: 0,0:08:24.32,0:08:26.19,Main-207-,,0,0,0,,Evet. Burası Denizci Karargâhı.
Dialogue: 0,0:08:26.19,0:08:27.95,Main-207-,,0,0,0,,{\q2}Karargâh mı?! Denizci Karargâhı mı?!
Dialogue: 0,0:08:27.95,0:08:32.49,Main-207-,,0,0,0,,Alo! Ben 16. Üs'ten Albay Nezumi!
Dialogue: 0,0:08:32.49,0:08:35.08,Main-207-,,0,0,0,,Denizci kodu 00733!
Dialogue: 0,0:08:35.62,0:08:36.95,Main-207-,,0,0,0,,Bir isteğim var!
Dialogue: 0,0:08:36.95,0:08:39.33,Main-207-,,0,0,0,,{\q2\i1}Bağırmana gerek yok. Seni duyabiliyorum.
Dialogue: 0,0:08:39.33,0:08:43.25,Main-207-,,0,0,0,,{\pos(720,1071.3)}Dinleyin! Luffy adında bir korsan var,\Nhasır şapka takıyor!
Dialogue: 0,0:08:43.25,0:08:47.47,Main-207-,,0,0,0,,{\pos(720,1071.3)\i1}Dinleyin! Luffy adında bir korsan var,\Nhasır şapka takıyor!
Dialogue: 0,0:08:47.47,0:08:51.97,Main-207-,,0,0,0,,O ve dört adamı\Nhükûmet düşmanı olarak görülmeli!
Dialogue: 0,0:08:52.43,0:08:57.06,Main-207-,,0,0,0,,{\i1\pos(720,1071.3)}O ve dört adamı\Nhükûmet düşmanı olarak görülmeli!
Dialogue: 0,0:08:57.06,0:08:58.56,Main-207-,,0,0,0,,"Luffy..."
Dialogue: 0,0:08:58.56,0:09:03.94,Main-207-,,0,0,0,,Arlong Parkı'nda yenilmez olduğu iddia\Nedilen, Arlong Korsanları’nı devirdiler!
Dialogue: 0,0:09:03.94,0:09:06.57,Main-207-,,0,0,0,,Tehdit seviyesi nedeniyle, kaptanları...
Dialogue: 0,0:09:06.57,0:09:10.07,Main-207-,,0,0,0,,Hasır Şapkalı Luffy'nin başına\Nbüyük bir ödül koymalıyız!
Dialogue: 0,0:09:10.07,0:09:11.70,Main-207-,,0,0,0,,Fotoğrafı şimdi yolluyorum!
Dialogue: 0,0:09:11.70,0:09:12.78,Main-207-,,0,0,0,,Anlaşıldı.
Dialogue: 0,0:09:16.62,0:09:17.50,Main-207-,,0,0,0,,Ha?!
Dialogue: 0,0:09:17.50,0:09:20.25,Main-207-,,0,0,0,,Daha iyi bir fotoğraf çekemedin mi?!
Dialogue: 0,0:09:20.25,0:09:22.00,Main-207-,,0,0,0,,Hayır, sadece bu var...
Dialogue: 0,0:09:22.37,0:09:26.96,Main-207-,,0,0,0,,Hızlıca kontrol edip onaya göndereceğim.
Dialogue: 0,0:09:27.71,0:09:31.63,Main-207-,,0,0,0,,Unutma sakın! O alçak bir korsan!\N"Ölü" ya da "Diri" istiyorum!
Dialogue: 0,0:09:32.64,0:09:37.18,Main-207-,,0,0,0,,Aranıyor posterini dünyanın\Nher bir köşesine asın!
Dialogue: 0,0:09:49.74,0:09:51.70,Main-207-,,0,0,0,,Öff, patlayacağım!
Dialogue: 0,0:09:52.07,0:09:55.07,Main-207-,,0,0,0,,Yapmak yerine\Nbazen yemek keyifli!
Dialogue: 0,0:09:55.07,0:09:56.95,Main-207-,,0,0,0,,Yaraların nasıl oldu, Zoro?
Dialogue: 0,0:09:56.95,0:09:59.95,Main-207-,,0,0,0,,Önemsiz, bir güzel yer içerim, geçer!
Dialogue: 0,0:09:59.95,0:10:01.37,Main-207-,,0,0,0,,Öyle mi?
Dialogue: 0,0:10:01.37,0:10:04.75,Main-207-,,0,0,0,,Bu aptal parti daha ne kadar sürecek?
Dialogue: 0,0:10:04.75,0:10:06.71,Main-207-,,0,0,0,,Bugün üçüncü gün oluyor!
Dialogue: 0,0:10:06.71,0:10:08.05,Main-207-,,0,0,0,,Yanlış olan ne?
Dialogue: 0,0:10:08.05,0:10:11.67,Main-207-,,0,0,0,,Kutlamak istediğin zaman\Nher şeyinle kutlamalısın.
Dialogue: 0,0:10:12.88,0:10:15.51,Main-207-,,0,0,0,,Hey, Sanji!\NO yediğin kavun!
Dialogue: 0,0:10:15.51,0:10:16.89,Main-207-,,0,0,0,,Üstünde bir şey mi vardı?!
Dialogue: 0,0:10:16.89,0:10:19.27,Main-207-,,0,0,0,,Bütün bu etlerde ne?!
Dialogue: 0,0:10:19.27,0:10:22.73,Main-207-,,0,0,0,,Evet. "Çiğ jambonlu kavun"du,\Nüstünde çiğ jambon vardı.
Dialogue: 0,0:10:22.73,0:10:25.81,Main-207-,,0,0,0,,Çiğ jambonlu kavun mu?! Nefis!\NN-Nereden aldın?!
Dialogue: 0,0:10:25.81,0:10:26.36,Main-207-,,0,0,0,,Bilmem...
Dialogue: 0,0:10:26.98,0:10:31.69,Main-207-,,0,0,0,,Köyün tamamı bir ziyafet yeri,\Naldığım yeri hatırlamıyorum.
Dialogue: 0,0:10:32.36,0:10:33.70,Main-207-,,0,0,0,,Çoktan gitti.
Dialogue: 0,0:10:33.70,0:10:36.03,Main-207-,,0,0,0,,Üç gündür durmadan yiyor!
Dialogue: 0,0:10:36.82,0:10:39.03,Main-207-,,0,0,0,,Tamamdır, yemeğimi yedim.
Dialogue: 0,0:10:39.83,0:10:40.91,Main-207-,,0,0,0,,Şimdi sanırım...
Dialogue: 0,0:10:40.91,0:10:42.58,Main-207-,,0,0,0,,birkaç kız tavlayacağım!
Dialogue: 0,0:10:42.58,0:10:46.58,Main-207-,,0,0,0,,Karşınızda, en güçlü yetkili balık adamı yenen...
Dialogue: 0,0:10:46.58,0:10:50.13,Main-207-,,0,0,0,,sevilesi ve cesur kahraman, Kaptan Usopp!
Dialogue: 0,0:10:45.33,0:10:46.58,Secondary-207-,,0,0,0,,{\an8}Helal olsun, çocuk!
Dialogue: 0,0:10:46.58,0:10:48.34,Secondary-207-,,0,0,0,,{\an8}İmzanı alabilir miyim?!
Dialogue: 0,0:10:50.92,0:10:54.93,Main-207-,,0,0,0,,İşte size Usopp marşı!
Dialogue: 0,0:10:54.93,0:11:00.68,Main-207-,,0,0,0,,{\an8\fad(150,150)\b1\bord1.5\shad1.2\fs53}♫ Kimdi? Kimdi?\NBalık adamı kim yendi? ♫
Comment: 0,0:11:00.68,0:11:07.35,Main-207-,,0,0,0,,{\an8}[More of Usopp's song, untranslated.]
Dialogue: 0,0:10:59.14,0:11:00.68,Main-207-,,0,0,0,,Öf. Çok sıkıcısın.
Dialogue: 0,0:11:01.06,0:11:01.68,Main-207-,,0,0,0,,Ne oldu?
Dialogue: 0,0:11:01.68,0:11:04.23,Main-207-,,0,0,0,,Daha çok üzüleceğini düşünmüştüm.
Dialogue: 0,0:11:04.23,0:11:08.11,Main-207-,,0,0,0,,"Neden bunlar babam ölmeden\Nönce olmadı?!"
Dialogue: 0,0:11:08.52,0:11:09.48,Main-207-,,0,0,0,,Gibi.
Dialogue: 0,0:11:10.44,0:11:13.07,Main-207-,,0,0,0,,Başta böyle düşünmüştüm.
Dialogue: 0,0:11:13.07,0:11:15.99,Main-207-,,0,0,0,,Ama şimdi geleceği düşünüyorum.
Dialogue: 0,0:11:15.99,0:11:17.57,Main-207-,,0,0,0,,Geleceği mi?
Dialogue: 0,0:11:18.07,0:11:21.37,Main-207-,,0,0,0,,Hasır şapkalı abi ve\Narkadaşları bize yardım etti.
Dialogue: 0,0:11:21.74,0:11:26.21,Main-207-,,0,0,0,,Ama yarın, kendi başımıza\Nyeni bir başlangıç yapmamız gerek.
Dialogue: 0,0:11:26.87,0:11:31.42,Main-207-,,0,0,0,,Geçmişi unutmamızın bir yolu yok,\Nzaten buna da gerek yok.
Dialogue: 0,0:11:31.42,0:11:35.51,Main-207-,,0,0,0,,Asıl önemli olan bundan sonrası!
Dialogue: 0,0:11:35.51,0:11:38.59,Main-207-,,0,0,0,,Ne yapmalıyız? Nasıl yapmalıyız?
Dialogue: 0,0:11:39.30,0:11:42.47,Main-207-,,0,0,0,,Artık köylerimizi ayakta\Ntutacak olan bizleriz.
Dialogue: 0,0:11:42.97,0:11:44.77,Main-207-,,0,0,0,,İşte böyle düşünüyorum.
Dialogue: 0,0:11:46.85,0:11:47.60,Main-207-,,0,0,0,,Olgunlaşmısın!
Dialogue: 0,0:11:47.60,0:11:48.85,Main-207-,,0,0,0,,Ayy!
Dialogue: 0,0:11:48.85,0:11:51.86,Main-207-,,0,0,0,,Neden beni çimdikliyorsun?!\NAnlamıyorum! Neden?!
Dialogue: 0,0:11:51.86,0:11:54.11,Main-207-,,0,0,0,,Oysa seninle tekrar\Ndalga geçmeyi umuyordum!
Dialogue: 0,0:11:54.11,0:11:58.11,Main-207-,,0,0,0,,Yeterince dalga geçtin,\Nseni aptal, dövmeli serseri kız!
Dialogue: 0,0:12:04.04,0:12:05.41,Main-207-,,0,0,0,,"Serseri" bana uyar!
Dialogue: 0,0:12:08.83,0:12:09.83,Main-207-,,0,0,0,,Tamamen silinir mi?
Dialogue: 0,0:12:09.83,0:12:13.50,Main-207-,,0,0,0,,"Evet" demeyi çok isterdim ama\Ntamamen silinemez.
Dialogue: 0,0:12:13.50,0:12:15.01,Main-207-,,0,0,0,,Biraz iz kalacak.
Dialogue: 0,0:12:15.63,0:12:16.38,Main-207-,,0,0,0,,Evet.
Dialogue: 0,0:12:16.97,0:12:20.97,Main-207-,,0,0,0,,Kendi aptallığım, farkındayım.\NHayatım boyunca taşıyacağım.
Dialogue: 0,0:12:20.97,0:12:23.76,Flashbacks-207-,,0,0,0,,Kimsenin bunu görmesini istemiyorum!
Dialogue: 0,0:12:24.43,0:12:27.56,Flashbacks-207-,,0,0,0,,Bu... bu dövme...
Dialogue: 0,0:12:27.56,0:12:31.77,Flashbacks-207-,,0,0,0,,Bile isteye Arlong'un\Ntayfasına katılmadım,
Dialogue: 0,0:12:31.77,0:12:34.23,Flashbacks-207-,,0,0,0,,ama şimdi herkes beni korsan sanıyor!
Dialogue: 0,0:12:35.94,0:12:37.24,Flashbacks-207-,,0,0,0,,Nami...
Dialogue: 0,0:12:39.82,0:12:42.20,Flashbacks-207-,,0,0,0,,Nojiko! O da ne?!
Dialogue: 0,0:12:42.20,0:12:43.08,Flashbacks-207-,,0,0,0,,Ah? Bu mu?
Dialogue: 0,0:12:43.87,0:12:47.04,Flashbacks-207-,,0,0,0,,Önemli bir şey değil!\NSadece dekorasyon!
Dialogue: 0,0:12:47.37,0:12:48.96,Flashbacks-207-,,0,0,0,,Şimdi tıpkı senin gibiyim!
Dialogue: 0,0:12:56.01,0:12:57.26,Main-207-,,0,0,0,,Baksana, Doktor.
Dialogue: 0,0:12:57.97,0:13:00.34,Main-207-,,0,0,0,,Yaptırmak istediğim bir dövme var.
Dialogue: 0,0:13:01.80,0:13:02.72,Main-207-,,0,0,0,,İşte.
Dialogue: 0,0:13:03.89,0:13:05.26,Main-207-,,0,0,0,,İkisi dans edebiliyor!
Dialogue: 0,0:13:05.26,0:13:09.18,Main-207-,,0,0,0,,Karşınızda Usopp'un 185 numaralı marşı!
Dialogue: 0,0:13:14.27,0:13:15.90,Main-207-,,0,0,0,,Bell-mère...
Dialogue: 0,0:13:15.90,0:13:20.15,Main-207-,,0,0,0,,Küçük kızların öz güvenli ve onurlu birer kadın oldu.
Dialogue: 0,0:13:21.41,0:13:24.33,Main-207-,,0,0,0,,Bana seni hatırlatıyorlar.
Dialogue: 0,0:13:24.70,0:13:28.79,Main-207-,,0,0,0,,Şu andan itibaren\Nhayatı dolu dolu yaşayacağız.
Dialogue: 0,0:13:29.29,0:13:32.79,Main-207-,,0,0,0,,Çok fazla şey kaybettik ve\Nfedakârlık yaptık.
Dialogue: 0,0:13:32.79,0:13:38.09,Main-207-,,0,0,0,,Bu yüzden bundan sonra\Naptallar gibi gülüp eğleneceğiz.
Dialogue: 0,0:13:39.84,0:13:41.59,Main-207-,,0,0,0,,Jambonlu kavun!
Dialogue: 0,0:13:41.93,0:13:46.60,Main-207-,,0,0,0,,Ha? Burada hiç yiyecek yok.\NOlmaz böyle. Geri döneyim.
Dialogue: 0,0:13:46.60,0:13:47.56,Main-207-,,0,0,0,,Dur, çocuk!
Dialogue: 0,0:13:48.85,0:13:51.85,Main-207-,,0,0,0,,Mezar mı? Biri mi öldü?
Dialogue: 0,0:13:51.85,0:13:54.06,Main-207-,,0,0,0,,Evet. Uzun zaman önce.
Dialogue: 0,0:13:54.69,0:13:59.03,Main-207-,,0,0,0,,Ah, eliniz sağ olsun.
Dialogue: 0,0:13:59.53,0:14:04.16,Main-207-,,0,0,0,,Ha? Ayağınız sağ olsun.\NHa? Gözünüz sağ–
Dialogue: 0,0:14:04.16,0:14:06.41,Main-207-,,0,0,0,,Başınız sağ olsun.
Dialogue: 0,0:14:06.41,0:14:08.12,Main-207-,,0,0,0,,Ondan sağ olsun.
Dialogue: 0,0:14:08.12,0:14:09.41,Main-207-,,0,0,0,,Hey, evlat.
Dialogue: 0,0:14:10.12,0:14:13.96,Main-207-,,0,0,0,,Nami senin gemine binecek.\NKorsan olacak.
Dialogue: 0,0:14:13.96,0:14:15.96,Main-207-,,0,0,0,,Tehlikeli bir yolculuk olacak.
Dialogue: 0,0:14:15.96,0:14:18.09,Main-207-,,0,0,0,,Sorun değil.
Dialogue: 0,0:14:18.09,0:14:20.76,Main-207-,,0,0,0,,Yapacak bir şey yok ama...
Dialogue: 0,0:14:20.76,0:14:24.26,Main-207-,,0,0,0,,gülümsemesini elinden alacak olursanız,
Dialogue: 0,0:14:24.26,0:14:26.72,Main-207-,,0,0,0,,sizi gebertirim!
Dialogue: 0,0:14:26.72,0:14:29.68,Main-207-,,0,0,0,,Evet, öyle bir şey yapmam zaten.
Dialogue: 0,0:14:30.35,0:14:31.14,Main-207-,,0,0,0,,Anladın mı?!
Dialogue: 0,0:14:33.14,0:14:34.10,Main-207-,,0,0,0,,Anladım!
Dialogue: 0,0:15:07.05,0:15:11.31,Flashbacks-207-,,0,0,0,,Ooo! Bugün ziyafet varmış!
Dialogue: 0,0:15:11.31,0:15:14.56,Flashbacks-207-,,0,0,0,,Bugünün anlamını biliyor musunuz?
Dialogue: 0,0:15:14.89,0:15:18.69,Flashbacks-207-,,0,0,0,,Bugün tanışmamızın yıl dönümü!
Dialogue: 0,0:15:19.31,0:15:21.69,Flashbacks-207-,,0,0,0,,Kızlarım olduğunuz gün!
Dialogue: 0,0:15:21.69,0:15:22.57,Flashbacks-207-,,0,0,0,,Vay!
Dialogue: 0,0:15:26.53,0:15:28.41,Flashbacks-207-,,0,0,0,,Hadi ama, ağlamayı bırakın!
Dialogue: 0,0:15:28.41,0:15:31.54,Flashbacks-207-,,0,0,0,,Fırtına bahçeyi dağıtmışsa\Nne olmuş yani?
Dialogue: 0,0:15:31.54,0:15:36.00,Flashbacks-207-,,0,0,0,,Zor zamanlarda bile gülümseyebilen\Ngüçlü kızlar olmalısınız!
Dialogue: 0,0:15:36.54,0:15:40.25,Flashbacks-207-,,0,0,0,,Dediğimi yapın, ardından\Nmutluluk sizi bulacaktır!
Dialogue: 0,0:15:41.71,0:15:43.92,Flashbacks-207-,,0,0,0,,Bulacak, söz veriyorum!
Dialogue: 0,0:15:44.84,0:15:46.76,Flashbacks-207-,,0,0,0,,Nami! Tuz getirebilir misin?
Dialogue: 0,0:15:48.01,0:15:50.72,Flashbacks-207-,,0,0,0,,Deniz haritalarını bitirdin,\Nsıra kara haritalarında mı?
Dialogue: 0,0:15:51.22,0:15:54.27,Flashbacks-207-,,0,0,0,,Yön bulma konusuna da çalışıyorum!
Dialogue: 0,0:15:54.64,0:15:56.39,Flashbacks-207-,,0,0,0,,Onu da mı öğreniyorsun?!
Dialogue: 0,0:15:56.39,0:15:58.35,Flashbacks-207-,,0,0,0,,Nami'nin hayali bu zaten!
Dialogue: 0,0:15:59.06,0:16:02.94,Flashbacks-207-,,0,0,0,,Yön bulma becerilerimi dünyanın tüm\Ndenizlerini aşmak için kullanacağım!
Dialogue: 0,0:16:02.94,0:16:06.57,Flashbacks-207-,,0,0,0,,Sonra gördüğüm her şeyin olduğu\Nbir dünya haritası çizeceğim!
Dialogue: 0,0:16:07.07,0:16:11.53,Flashbacks-207-,,0,0,0,,O zaman bu çizdiğin harita\Nhayaline giden ilk adım mı?
Dialogue: 0,0:16:12.24,0:16:13.04,Flashbacks-207-,,0,0,0,,Evet!
Dialogue: 0,0:16:44.07,0:16:46.74,Main-207-,,0,0,0,,Artık bitti, Bell-mère-{\i1}san{\i0}.
Dialogue: 0,0:16:47.32,0:16:50.82,Main-207-,,0,0,0,,Sekiz yıl sürdü ama sonunda özgürüz!
Dialogue: 0,0:16:50.82,0:16:53.49,Main-207-,,0,0,0,,Ben ve diğer herkes...
Dialogue: 0,0:16:53.49,0:16:55.95,Main-207-,,0,0,0,,Tam da dediğin gibi oldu.
Dialogue: 0,0:16:55.95,0:16:59.83,Main-207-,,0,0,0,,"Yaşadığınız sürece mutluluk sizi\Ner ya da geç bulacaktır!"
Dialogue: 0,0:16:59.83,0:17:01.21,Main-207-,,0,0,0,,Haklıydın!
Dialogue: 0,0:17:01.21,0:17:04.84,Main-207-,,0,0,0,,Tüm köylüler içtenlikle,\Nbüyük bir mutlulukla gülümsüyor!
Dialogue: 0,0:17:07.42,0:17:10.18,Main-207-,,0,0,0,,Bana gelince,\Nadadan ayrılmayı düşünüyorum!
Dialogue: 0,0:17:11.13,0:17:13.93,Main-207-,,0,0,0,,Endişelenme! Sorun yok!
Dialogue: 0,0:17:13.93,0:17:17.64,Main-207-,,0,0,0,,Gerçekten hoş insanlar ve\Noldukça da güçlüler!
Dialogue: 0,0:17:19.27,0:17:23.27,Main-207-,,0,0,0,,Sekiz yıl boyunca birçok harita çizdim,
Dialogue: 0,0:17:23.27,0:17:25.61,Main-207-,,0,0,0,,şimdi ise elimde tek bu kaldı.
Dialogue: 0,0:17:26.36,0:17:32.20,Main-207-,,0,0,0,,Şu andan itibaren, sadece\Nkendim için harita çizeceğim!
Dialogue: 0,0:17:32.20,0:17:36.41,Main-207-,,0,0,0,,Onlarla, dostlarımla birlikte\Ndünyayı gezeceğim!
Dialogue: 0,0:17:37.91,0:17:40.33,Main-207-,,0,0,0,,Bu benim hayalim, bu yüzden...
Dialogue: 0,0:17:41.75,0:17:42.83,Main-207-,,0,0,0,,Bu yüzden...
Dialogue: 0,0:17:44.25,0:17:47.59,Main-207-,,0,0,0,,Bu yüzden bu adaya ne zaman\Ndönerim, bilmiyorum.
Dialogue: 0,0:17:56.39,0:17:58.43,Main-207-,,0,0,0,,Artık... gitme vakti.
Dialogue: 0,0:18:24.79,0:18:26.08,Main-207-,,0,0,0,,Bu son mu?
Dialogue: 0,0:18:26.08,0:18:26.79,Main-207-,,0,0,0,,Evet!
Dialogue: 0,0:18:26.79,0:18:27.38,Main-207-,,0,0,0,,Pekâlâ!
Dialogue: 0,0:18:27.38,0:18:28.63,Main-207-,,0,0,0,,Her şeyi yüklediniz mi?
Dialogue: 0,0:18:28.63,0:18:29.50,Main-207-,,0,0,0,,Evet!
Dialogue: 0,0:18:29.50,0:18:32.38,Main-207-,,0,0,0,,O hâlde... erzaklar tamam!
Dialogue: 0,0:18:32.38,0:18:33.59,Main-207-,,0,0,0,,Hazırız.
Dialogue: 0,0:18:34.72,0:18:36.76,Main-207-,,0,0,0,,Kısa bir süre buradaydık ama...
Dialogue: 0,0:18:36.76,0:18:39.10,Main-207-,,0,0,0,,birçok anı biriktirdik, ha?
Dialogue: 0,0:18:39.43,0:18:40.52,Main-207-,,0,0,0,,Evet!
Dialogue: 0,0:18:47.44,0:18:51.07,Main-207-,,0,0,0,,Yaptığınız her şey için\Nsize çok şey borçluyuz.
Dialogue: 0,0:18:51.07,0:18:54.49,Main-207-,,0,0,0,,Tekrar ödül avcılığına dönüyoruz!
Dialogue: 0,0:18:54.49,0:18:55.41,Main-207-,,0,0,0,,Veda vakti geldi,
Dialogue: 0,0:18:56.11,0:18:58.91,Main-207-,,0,0,0,,ama tekrar görüşeceğimiz günü\Niple çekiyoruz!
Dialogue: 0,0:18:59.91,0:19:00.87,Main-207-,,0,0,0,,Dikkatli olun!
Dialogue: 0,0:19:01.50,0:19:03.12,Main-207-,,0,0,0,,– Siz de!\N– Siz de!
Dialogue: 0,0:19:03.12,0:19:05.33,Main-207-,,0,0,0,,Artık biz de yol alalım!
Dialogue: 0,0:19:06.54,0:19:08.88,Main-207-,,0,0,0,,H-Hey! Bekleyin!\NPeki ya Nami-{\i1}san{\i0}?!
Dialogue: 0,0:19:09.63,0:19:11.05,Main-207-,,0,0,0,,Belki de gelmiyordur?
Dialogue: 0,0:19:11.05,0:19:13.09,Main-207-,,0,0,0,,N...?! Neden gelmesin?!
Dialogue: 0,0:19:13.59,0:19:17.09,Main-207-,,0,0,0,,Seni pislik!\NYine Nami’ye asıldın, değil mi?!
Dialogue: 0,0:19:17.09,0:19:18.35,Main-207-,,0,0,0,,Neden bunu yapayım ki?
Dialogue: 0,0:19:18.35,0:19:20.10,Main-207-,,0,0,0,,Doğru ya.
Dialogue: 0,0:19:20.10,0:19:24.23,Main-207-,,0,0,0,,Amacını gerçekleştirdi,\Nkorsanlığa gerek kalmadı.
Dialogue: 0,0:19:24.23,0:19:27.60,Main-207-,,0,0,0,,Belki de burada daha mutlu olur.
Dialogue: 0,0:19:18.35,0:19:20.10,Secondary-207-,,0,0,0,,{\an8}Hayır, kesinlikle yaptın!
Dialogue: 0,0:19:20.10,0:19:24.23,Secondary-207-,,0,0,0,,{\an8}Nami-{\i1}san{\i0} ve benim sırıl sıklam\Naşkımızı çekemiyorsun!
Dialogue: 0,0:19:24.23,0:19:25.23,Secondary-207-,,0,0,0,,{\an8}Aptal mısın?
Dialogue: 0,0:19:25.23,0:19:26.85,Secondary-207-,,0,0,0,,{\an8}Ne dedin, sen?!
Dialogue: 0,0:19:27.60,0:19:29.06,Main-207-,,0,0,0,,Peki ya benim mutluluğum?!
Dialogue: 0,0:19:29.69,0:19:32.73,Main-207-,,0,0,0,,Nami-{\i1}san{\i0} gelmezse,
Dialogue: 0,0:19:32.73,0:19:36.07,Main-207-,,0,0,0,,o zaman bu gemide olma\Nsebebimin %98.72'sini kaybederim!
Dialogue: 0,0:19:36.07,0:19:39.07,Main-207-,,0,0,0,,Bu arada, jambonlu kavunu\Nhiçbir yerde bulamadım!
Dialogue: 0,0:19:39.57,0:19:40.70,Main-207-,,0,0,0,,Hey! Nacchan nerede?
Dialogue: 0,0:19:40.70,0:19:43.62,Main-207-,,0,0,0,,Sorun da bu! Sabahtan beri\Nonu kimse görmedi!
Dialogue: 0,0:19:43.62,0:19:44.25,Main-207-,,0,0,0,,Ne?!
Dialogue: 0,0:19:44.62,0:19:46.54,Main-207-,,0,0,0,,Bütün parayı arkasında mı bırakıyor?!
Dialogue: 0,0:19:46.54,0:19:48.75,Main-207-,,0,0,0,,100 milyon beli'yi mi?!
Dialogue: 0,0:19:48.75,0:19:51.04,Main-207-,,0,0,0,,Yolculuğa parasız mı çıkmayı düşünüyor?!
Dialogue: 0,0:19:51.04,0:19:53.84,Main-207-,,0,0,0,,Ama hayatını o parayı\Nkazanmak için riske attı!
Dialogue: 0,0:19:53.84,0:19:57.01,Main-207-,,0,0,0,,Sorun olmadığını söyledi\Nçünkü daha fazlasını çalacakmış.
Dialogue: 0,0:19:58.39,0:20:01.01,Main-207-,,0,0,0,,Bir kez konuştu mu\Nfikrini değiştirmek imkânsız.
Dialogue: 0,0:20:01.39,0:20:02.76,Main-207-,,0,0,0,,Aptal!
Dialogue: 0,0:20:02.76,0:20:06.48,Main-207-,,0,0,0,,Ona borçlu olan biziz!
Dialogue: 0,0:20:10.98,0:20:12.90,Main-207-,,0,0,0,,– Nami-{\i1}san{\i0}!\N– Nami-{\i1}san{\i0}!
Dialogue: 0,0:20:12.90,0:20:14.28,Main-207-,,0,0,0,,Nami!
Dialogue: 0,0:20:13.44,0:20:14.28,Secondary-207-,,0,0,0,,Nami!
Dialogue: 0,0:20:14.28,0:20:16.40,Main-207-,,0,0,0,,Nami-{\i1}san{\i0}!
Dialogue: 0,0:20:14.82,0:20:16.40,Secondary-207-,,0,0,0,,Nacchan!
Dialogue: 0,0:20:16.40,0:20:17.74,Main-207-,,0,0,0,,Yelken açın!
Dialogue: 0,0:20:24.29,0:20:26.66,Main-207-,,0,0,0,,Ne? Koşmaya başladı!
Dialogue: 0,0:20:26.66,0:20:27.91,Main-207-,,0,0,0,,Yelken açmamızı söyledi.
Dialogue: 0,0:20:27.91,0:20:28.50,Main-207-,,0,0,0,,Evet, ama...!
Dialogue: 0,0:20:29.96,0:20:31.46,Main-207-,,0,0,0,,Yoksa...
Dialogue: 0,0:20:31.46,0:20:35.30,Main-207-,,0,0,0,,teşekkürümüzü ve\Nvedamızı almadan mı ayrılacak?!
Dialogue: 0,0:20:35.30,0:20:35.88,Main-207-,,0,0,0,,Olamaz!
Dialogue: 0,0:20:36.21,0:20:37.88,Main-207-,,0,0,0,,Yelkenler fora!
Dialogue: 0,0:20:42.76,0:20:44.26,Main-207-,,0,0,0,,H-Hey!
Dialogue: 0,0:20:44.26,0:20:45.93,Main-207-,,0,0,0,,Yelken açıyorlar!
Dialogue: 0,0:20:45.93,0:20:48.69,Main-207-,,0,0,0,,Durun! Henüz doğru dürüst teşekkür edemedik!
Dialogue: 0,0:20:50.40,0:20:51.65,Main-207-,,0,0,0,,Dur, Nacchan!
Dialogue: 0,0:20:51.65,0:20:53.11,Main-207-,,0,0,0,,En azından teşekkür edelim!
Dialogue: 0,0:20:53.94,0:20:54.86,Main-207-,,0,0,0,,– Nacchan!\N– Nami! Sakinleş!
Dialogue: 0,0:20:54.86,0:20:58.86,Main-207-,,0,0,0,,Bekle! Bu şekilde\Ngitmene izin vermeyeceğim!
Dialogue: 0,0:20:58.86,0:21:02.12,Main-207-,,0,0,0,,Hey, böyle ayrılmasına\Nizin vermeli miyiz?
Dialogue: 0,0:21:02.12,0:21:04.83,Main-207-,,0,0,0,,Neden olmasın? Onun kararı.
Dialogue: 0,0:21:23.05,0:21:23.60,Main-207-,,0,0,0,,Nami!
Dialogue: 0,0:21:32.19,0:21:33.31,Main-207-,,0,0,0,,Neden?!
Dialogue: 0,0:21:34.06,0:21:35.07,Main-207-,,0,0,0,,Nami!
Dialogue: 0,0:21:56.42,0:21:56.96,Main-207-,,0,0,0,,Yoksa!
Dialogue: 0,0:21:57.92,0:21:59.71,Main-207-,,0,0,0,,– Ha? Cüzdanım gitmiş!\N– Benim de!
Dialogue: 0,0:22:00.09,0:22:01.05,Main-207-,,0,0,0,,Benim de!
Dialogue: 0,0:22:01.05,0:22:02.26,Main-207-,,0,0,0,,Benim de!
Dialogue: 0,0:22:07.31,0:22:08.89,Main-207-,,0,0,0,,Millet, kendinize iyi bakın!
Dialogue: 0,0:22:08.89,0:22:09.68,Main-207-,,0,0,0,,Nasıl...?!
Dialogue: 0,0:22:09.68,0:22:13.98,Main-207-,,0,0,0,,{{\q2}– Bunu nasıl yaparsın?! Kahrolası velet!\N– Bunu nasıl yaparsın?! Kahrolası velet!
Dialogue: 0,0:22:14.94,0:22:17.94,Main-207-,,0,0,0,,Hey. Bir gram değişmemiş.
Dialogue: 0,0:22:17.94,0:22:19.78,Main-207-,,0,0,0,,Yine ne zaman hainlik yapacak acaba?
Dialogue: 0,0:22:19.78,0:22:21.49,Main-207-,,0,0,0,,Nami-{\i1}san{\i0}! İyi işti!
Dialogue: 0,0:22:24.16,0:22:25.78,Main-207-,,0,0,0,,Seni sinsi yankesici!
Dialogue: 0,0:22:25.78,0:22:26.70,Main-207-,,0,0,0,,Buraya gel!
Dialogue: 0,0:22:26.70,0:22:27.66,Main-207-,,0,0,0,,Cüzdanım!
Dialogue: 0,0:22:27.66,0:22:29.08,Main-207-,,0,0,0,,Serseri!
Dialogue: 0,0:22:29.08,0:22:30.83,Main-207-,,0,0,0,,İstediğin zaman gel!
Dialogue: 0,0:22:30.83,0:22:31.96,Main-207-,,0,0,0,,Kendine iyi bak!
Dialogue: 0,0:22:31.96,0:22:33.71,Main-207-,,0,0,0,,Sizlere minnettarız!
Dialogue: 0,0:22:35.21,0:22:36.59,Main-207-,,0,0,0,,Çocuk!
Dialogue: 0,0:22:37.92,0:22:40.42,Main-207-,,0,0,0,,Sözümüzü unutma!
Dialogue: 0,0:22:44.47,0:22:47.55,Main-207-,,0,0,0,,Hoşça kalın, millet! Tekrar buluşana dek!
Dialogue: 0,0:22:50.85,0:22:52.56,Main-207-,,0,0,0,,Yaptı yapacağını!
Dialogue: 0,0:22:52.56,0:22:55.35,Main-207-,,0,0,0,,Küçük kız kardeşim, işinin ustası!
Dialogue: 0,0:22:56.81,0:22:58.06,Main-207-,,0,0,0,,Keyfini çıkar!
Dialogue: 0,0:23:02.07,0:23:04.32,Main-207-,,0,0,0,,Al, Genzo.
Dialogue: 0,0:23:04.32,0:23:06.62,Main-207-,,0,0,0,,Bu kağıt parçası da ne, Doktor?
Dialogue: 0,0:23:07.20,0:23:11.95,Main-207-,,0,0,0,,{\q2}O aptal kız, asla öğrenmiyor.\NAyrılmadan önce bir dövme daha yaptırdı.
Dialogue: 0,0:23:12.91,0:23:14.29,Main-207-,,0,0,0,,Bu sembol de ne?
Dialogue: 0,0:23:14.75,0:23:17.75,Main-207-,,0,0,0,,Görünüşe göre, mandalina ve rüzgâr gülü.
Dialogue: 0,0:23:19.00,0:23:22.42,Main-207-,,0,0,0,,Ha? Gen-{\i1}san{\i0}!\NRüzgâr gülüne ne oldu?
Dialogue: 0,0:23:26.68,0:23:28.55,Main-207-,,0,0,0,,Artık ona ihtiyacım kalmadı.
Dialogue: 0,0:23:39.31,0:23:41.57,Thoughts-207-,,0,0,0,,Bell-mère-{\i1}san{\i0}, gidiyorum.
Dialogue: 0,0:23:48.11,0:23:51.41,Flashbacks-207-,,0,0,0,,Bekle, Gen-san! Nami'den uzak dur!
Dialogue: 0,0:23:51.87,0:23:55.50,Flashbacks-207-,,0,0,0,,Üzgünüm ama ben de onu\Ngülerken görmek istiyorum!
Dialogue: 0,0:23:55.50,0:23:58.71,Flashbacks-207-,,0,0,0,,Çok korkunç göründüğünden onu ağlatıyorsun.
Dialogue: 0,0:23:58.71,0:24:01.21,Flashbacks-207-,,0,0,0,,Ama ne yapabilirim ki?
Dialogue: 0,0:24:01.84,0:24:02.38,Flashbacks-207-,,0,0,0,,Buldum!
Dialogue: 0,0:24:03.00,0:24:06.30,Flashbacks-207-,,0,0,0,,Bunu hep takarsam\Nseni güldürür, değil mi?!
Dialogue: 0,0:24:06.30,0:24:08.34,Flashbacks-207-,,0,0,0,,Ne dersin, Nami-chan?
Dialogue: 0,0:24:08.34,0:24:11.97,Flashbacks-207-,,0,0,0,,Bak, aptalca bir rüzgâr gülünün\Nonu güldüreceğini...
Dialogue: 0,0:24:19.90,0:24:22.02,Flashbacks-207-,,0,0,0,,Ah, güldü.
Dialogue: 0,0:24:27.70,0:24:31.37,Narrator-207-,,0,0,0,,Gökyüzü açık ve rüzgâr güzel esiyor.
Dialogue: 0,0:24:31.37,0:24:35.16,Narrator-207-,,0,0,0,,Rüzgâr gülü, mutlu bir şekilde dönüyor.
