Comment: 0,0:00:00.00,0:00:00.00,Main-207-,,0,0,0,,{=14}===============================DIALOGUE============================
Dialogue: 0,0:01:53.51,0:01:54.43,Main-207-,,0,0,0,,– Kazandı!\N– Kazandı!
Dialogue: 0,0:01:55.47,0:01:59.43,Main-207-,,0,0,0,,Arlong Park yıkıldı!
Dialogue: 0,0:02:01.06,0:02:02.60,Main-207-,,0,0,0,,Başardık, ablacığım!
Dialogue: 0,0:02:02.06,0:02:02.60,Secondary-207-,,0,0,0,,Gen-{\i1}san{\i0}!
Dialogue: 0,0:02:02.98,0:02:06.69,Main-207-,,0,0,0,,Yoksa... Yoksa rüya mı görüyorum?
Dialogue: 0,0:02:06.69,0:02:08.61,Main-207-,,0,0,0,,Bunun olacağını hiç düşünmemiştim.
Dialogue: 0,0:02:21.79,0:02:25.42,Main-207-,,0,0,0,,Aferin sana, Luffy!\NBen de takdirimi sunuyorum!
Dialogue: 0,0:02:25.42,0:02:31.09,Main-207-,,0,0,0,,Yine de bana daha fazla rol verseydin,\Nseni daha da çok överdim!
Dialogue: 0,0:02:31.76,0:02:34.05,Main-207-,,0,0,0,,Biraz endişelendirdin.
Dialogue: 0,0:02:34.93,0:02:39.51,Main-207-,,0,0,0,,Bir dahakine daha hızlı ol,\Nkahrolası serseri!
Dialogue: 0,0:03:08.33,0:03:10.09,Main-207-,,0,0,0,,Bu harika!
Dialogue: 0,0:03:23.14,0:03:25.14,Main-207-,,0,0,0,,Pekâlâ, bu kadar yeter!
Dialogue: 0,0:03:26.27,0:03:27.10,Main-207-,,0,0,0,,Bu o...!
Dialogue: 0,0:03:28.60,0:03:30.86,Main-207-,,0,0,0,,Bugün şanslı günümdeyim!
Dialogue: 0,0:03:30.86,0:03:34.74,Main-207-,,0,0,0,,Tebrikler.\NSavaşın hepsini izledim.
Dialogue: 0,0:03:34.74,0:03:39.28,Main-207-,,0,0,0,,Şans ya da değil, balık adamların\Nsizin gibi isimsiz korsanlara...
Dialogue: 0,0:03:39.28,0:03:42.08,Main-207-,,0,0,0,,yenileceğini asla düşünmemiştim.
Dialogue: 0,0:03:43.04,0:03:46.62,Main-207-,,0,0,0,,Ancak, sizin sayenizde\NArlong'a vereceğim tüm para...
Dialogue: 0,0:03:46.62,0:03:50.96,Main-207-,,0,0,0,,ve Arlong Park'ta bulunan\Ntüm değerli şeyler artık benim!
Dialogue: 0,0:03:50.96,0:03:52.30,Main-207-,,0,0,0,,Herkes silahını atsın!
Dialogue: 0,0:03:52.30,0:03:55.51,Main-207-,,0,0,0,,Bu olayın başarısı artık bana,\N16. Denizci Üssü Albayı,
Dialogue: 0,0:03:55.51,0:03:57.43,Main-207-,,0,0,0,,Nezumi'ye ait!
Dialogue: 0,0:04:00.01,0:04:00.64,Main-207-,,0,0,0,,Zoro!
Dialogue: 0,0:04:01.10,0:04:04.85,Main-207-,,0,0,0,,Nihayet insanlar mutluyken\Nkeyiflerini kaçırma!
Dialogue: 0,0:04:10.23,0:04:15.15,Main-207-,,0,0,0,,B-Bana dokunursanız, pişman olursunuz.
Dialogue: 0,0:04:15.15,0:04:16.57,Main-207-,,0,0,0,,Hâlâ konuşuyor musun?
Dialogue: 0,0:04:20.28,0:04:22.70,Main-207-,,0,0,0,,Bu Nojiko'yu vurduğun...
Dialogue: 0,0:04:23.28,0:04:27.62,Main-207-,,0,0,0,,ve Bell-mère-{\i1}san'{\i0}ın mandalina\Nbahçesine zarar verdiğin için.
Dialogue: 0,0:04:27.62,0:04:28.12,Main-207-,,0,0,0,,Ha?
Dialogue: 0,0:04:30.96,0:04:32.21,Main-207-,,0,0,0,,Albay!
Dialogue: 0,0:04:36.96,0:04:39.59,Main-207-,,0,0,0,,Sağ ol, Nami! Bu harika hissettirdi!
Dialogue: 0,0:04:39.59,0:04:42.09,Main-207-,,0,0,0,,Bunlardan 1.000 tane daha yolla!
Dialogue: 0,0:04:48.27,0:04:51.65,Main-207-,,0,0,0,,Şimdi siz denizciler, balık adamların\Narkasını toplayacaksınız!
Dialogue: 0,0:04:51.65,0:04:54.02,Main-207-,,0,0,0,,Ve Gosa şehrini yeniden inşa edeceksiniz!
Dialogue: 0,0:04:54.02,0:04:58.11,Main-207-,,0,0,0,,Bir de Arlong Park'ta değerli olan\Nhiçbir şeye dokunmayacaksınız!
Dialogue: 0,0:04:58.11,0:05:00.49,Main-207-,,0,0,0,,O para bu adanın! Anlaşıldı mı?!
Dialogue: 0,0:05:00.49,0:05:04.41,Main-207-,,0,0,0,,Ahh! Ahh! N-Ne dersen yaparım!
Dialogue: 0,0:05:04.41,0:05:05.99,Main-207-,,0,0,0,,Ve bir şey daha!
Dialogue: 0,0:05:06.45,0:05:08.20,Main-207-,,0,0,0,,Paramı geri ver!
Dialogue: 0,0:05:08.54,0:05:13.67,Main-207-,,0,0,0,,Geri vereceğim! Geri vereceğim!\NArtık buna değmez!
Dialogue: 0,0:05:17.00,0:05:19.51,Main-207-,,0,0,0,,Sizi yakalayacağım, rezil korsanlar!
Dialogue: 0,0:05:19.51,0:05:22.09,Main-207-,,0,0,0,,Hasır şapkalı adam!\NAdın Luffy, değil mi?!
Dialogue: 0,0:05:22.47,0:05:25.10,Main-207-,,0,0,0,,Kaptan sensin, değil mi?!\NBunu sakın unutma!
Dialogue: 0,0:05:25.10,0:05:28.06,Main-207-,,0,0,0,,Çok ileri gittiniz!\NZorlu yolculuğunuz yeni başlıyor!
Dialogue: 0,0:05:28.43,0:05:30.43,Main-207-,,0,0,0,,Pişmanlık için çok geç!
Dialogue: 0,0:05:30.43,0:05:34.19,Main-207-,,0,0,0,,İntikamımı alacağım!\NBekleyin ve görün!
Dialogue: 0,0:05:34.19,0:05:36.69,Main-207-,,0,0,0,,Bizi zorlu bir yolculuğun\Nbeklediğini söyledi.
Dialogue: 0,0:05:36.69,0:05:40.07,Main-207-,,0,0,0,,Korsanlar Kralı olacağımı\Nnereden biliyor?
Dialogue: 0,0:05:40.07,0:05:42.95,Main-207-,,0,0,0,,Bunu demek istemedi!\NHarbiden aptalsın!
Dialogue: 0,0:05:42.95,0:05:46.53,Main-207-,,0,0,0,,H-Hey, ne yapacağız?! Ya cidden\Nbaşımız büyük belaya girerse?!
Dialogue: 0,0:05:46.53,0:05:48.58,Main-207-,,0,0,0,,Hey! Hey! Ne yapacağız?!
Dialogue: 0,0:05:49.08,0:05:53.08,Main-207-,,0,0,0,,Pekâlâ, millet!\NSadece biz eğlenemeyiz!
Dialogue: 0,0:05:53.08,0:05:56.34,Main-207-,,0,0,0,,Adadaki herkesin\Nbu destansı olayı bilmesi gerekiyor!
Dialogue: 0,0:05:58.67,0:06:00.13,Main-207-,,0,0,0,,Arlong Park...
Dialogue: 0,0:06:00.13,0:06:02.84,Main-207-,,0,0,0,,Arlong Park yıkıldı!
Dialogue: 0,0:06:04.05,0:06:08.06,Main-207-,,0,0,0,,Hey Zoro, göğsündeki şey ne?
Dialogue: 0,0:06:05.43,0:06:08.06,Secondary-207-,,0,0,0,,Ha? Hey, ne yapıyorsu-?
Dialogue: 0,0:06:17.19,0:06:19.40,Main-207-,,0,0,0,,Aferin sana, Nami!
Dialogue: 0,0:06:20.74,0:06:24.74,Main-207-,,0,0,0,,Korsanlar tarafından\Nkurtarıldığımıza inanamıyorum.
Dialogue: 0,0:06:24.74,0:06:26.74,Main-207-,,0,0,0,,Hayat sürprizlerle dolu.
Dialogue: 0,0:06:40.63,0:06:43.42,Thoughts-207-,,0,0,0,,Artık bitti, Bell-mère-{\i1}san{\i0}.
Dialogue: 0,0:06:43.42,0:06:46.93,Thoughts-207-,,0,0,0,,Sekiz yıl sürdü ama sonunda özgürüz!
Dialogue: 0,0:06:46.93,0:06:48.80,Thoughts-207-,,0,0,0,,Ben ve diğer herkes...
Dialogue: 0,0:06:49.89,0:06:52.89,Main-207-,,0,0,0,,{\i1}Cidden, Nami?! Hâlâ burada mısın?
Dialogue: 0,0:06:53.64,0:06:55.90,Main-207-,,0,0,0,,Dostların seni arıyor, bilgin olsun.
Dialogue: 0,0:06:57.90,0:06:59.52,Main-207-,,0,0,0,,Baksanıza, Nojiko,
Dialogue: 0,0:06:59.52,0:07:00.02,Main-207-,,0,0,0,,Ha?
Dialogue: 0,0:07:00.02,0:07:00.86,Main-207-,,0,0,0,,...Gen-{\i1}san{\i0}.
Dialogue: 0,0:07:00.86,0:07:01.48,Main-207-,,0,0,0,,Hm?
Dialogue: 0,0:07:01.48,0:07:03.99,Main-207-,,0,0,0,,Bell-mère-{\i1}san{\i0} yaşasaydı,
Dialogue: 0,0:07:03.99,0:07:06.95,Main-207-,,0,0,0,,sizce korsan olmamam için\Nbana engel olur muydu?
Dialogue: 0,0:07:07.57,0:07:08.95,Main-207-,,0,0,0,,Korsan mı?!
Dialogue: 0,0:07:09.58,0:07:11.33,Main-207-,,0,0,0,,Saçma sapan konuşma!
Dialogue: 0,0:07:11.33,0:07:14.58,Main-207-,,0,0,0,,Elbette değerli kızının korsan\Nolmasına izin vermezdi!
Dialogue: 0,0:07:14.58,0:07:16.25,Main-207-,,0,0,0,,Engel olmazdı!
Dialogue: 0,0:07:15.29,0:07:16.25,Secondary-207-,,0,0,0,,Nojiko!
Dialogue: 0,0:07:16.25,0:07:17.42,Main-207-,,0,0,0,,Diyelim engel oldu,
Dialogue: 0,0:07:18.21,0:07:19.88,Main-207-,,0,0,0,,onu dinler miydin?
Dialogue: 0,0:07:21.50,0:07:23.88,Main-207-,,0,0,0,,Kesinlikle dinlemezdim!
Dialogue: 0,0:07:26.76,0:07:27.84,Main-207-,,0,0,0,,Anlıyorum...
Dialogue: 0,0:07:30.51,0:07:31.85,Main-207-,,0,0,0,,Neyin var, Gen-{\i1}san{\i0}?
Dialogue: 0,0:07:34.81,0:07:38.31,Main-207-,,0,0,0,,Siz ikiniz, kesinlikle\NBell-mère'nin çocuklarısınız.
Dialogue: 0,0:07:38.31,0:07:39.61,Main-207-,,0,0,0,,Gen-{\i1}san{\i0}?
Dialogue: 0,0:07:39.61,0:07:40.56,Main-207-,,0,0,0,,Nami.
Dialogue: 0,0:07:40.56,0:07:43.11,Main-207-,,0,0,0,,Kararını çoktan verdin, değil mi?
Dialogue: 0,0:07:43.11,0:07:44.65,Main-207-,,0,0,0,,O zaman istediğin gibi yaşa!
Dialogue: 0,0:07:45.40,0:07:47.32,Main-207-,,0,0,0,,Tıpkı annen gibi!
Dialogue: 0,0:07:53.74,0:07:54.95,Main-207-,,0,0,0,,Hâlâ uğraşıyorlar.
Dialogue: 0,0:07:55.87,0:07:58.75,Main-207-,,0,0,0,,Görünüşe göre Zoro acı içinde.
Dialogue: 0,0:07:58.75,0:08:00.25,Main-207-,,0,0,0,,Evet, öyle.
Dialogue: 0,0:08:00.25,0:08:03.21,Main-207-,,0,0,0,,Normal biri bu yaraları 2 yılda atlatırdı!
Dialogue: 0,0:08:04.96,0:08:06.30,Main-207-,,0,0,0,,Geri zekâlı!
Dialogue: 0,0:08:06.80,0:08:09.26,Main-207-,,0,0,0,,Böyle ciddi bir yarayla\Nkendi başına ilgilenmişsin!
Dialogue: 0,0:08:09.26,0:08:10.43,Main-207-,,0,0,0,,Off!
Dialogue: 0,0:08:10.43,0:08:13.47,Main-207-,,0,0,0,,Hakikaten, sizler\Ngerçekten korsan mısınız?!
Dialogue: 0,0:08:13.47,0:08:14.72,Main-207-,,0,0,0,,Geminizde...
Dialogue: 0,0:08:15.64,0:08:16.81,Main-207-,,0,0,0,,doktor yok mu?!
Dialogue: 0,0:08:16.81,0:08:19.23,Main-207-,,0,0,0,,Doktor mu? O da fena olmaz!
Dialogue: 0,0:08:19.60,0:08:20.10,Main-207-,,0,0,0,,Luffy?
Dialogue: 0,0:08:20.10,0:08:22.48,Main-207-,,0,0,0,,Ama önce müzisyen lazım.\NDeğil mi, Zoro?
Dialogue: 0,0:08:22.48,0:08:23.73,Main-207-,,0,0,0,,Nedenmiş o?!
Dialogue: 0,0:08:23.73,0:08:25.99,Main-207-,,0,0,0,,Korsanlar şarkı söyler, değil mi?
Dialogue: 0,0:08:25.99,0:08:28.65,Main-207-,,0,0,0,,Tamam da neden ilk o?!
Dialogue: 0,0:08:28.65,0:08:30.66,Main-207-,,0,0,0,,Alo?! Alo?!
Dialogue: 0,0:08:30.66,0:08:32.53,Main-207-,,0,0,0,,Evet. Burası Denizci Karargâhı.
Dialogue: 0,0:08:32.53,0:08:34.29,Main-207-,,0,0,0,,{\q2}Karargâh mı?! Denizci Karargâhı mı?!
Dialogue: 0,0:08:34.29,0:08:38.83,Main-207-,,0,0,0,,Alo! Ben 16. Üs'ten Albay Nezumi!
Dialogue: 0,0:08:38.83,0:08:41.42,Main-207-,,0,0,0,,Denizci kodu 00733!
Dialogue: 0,0:08:41.96,0:08:43.29,Main-207-,,0,0,0,,Bir isteğim var!
Dialogue: 0,0:08:43.29,0:08:45.67,Main-207-,,0,0,0,,{\q2\i1}Bağırmana gerek yok. Seni duyabiliyorum.
Dialogue: 0,0:08:45.67,0:08:49.59,Main-207-,,0,0,0,,{\pos(720,1071.3)}Dinleyin! Luffy adında bir korsan var,\Nhasır şapka takıyor!
Dialogue: 0,0:08:49.59,0:08:53.80,Main-207-,,0,0,0,,{\pos(720,1071.3)\i1}Dinleyin! Luffy adında bir korsan var,\Nhasır şapka takıyor!
Dialogue: 0,0:08:53.80,0:08:58.31,Main-207-,,0,0,0,,O ve dört adamı\Nhükûmet düşmanı olarak görülmeli!
Dialogue: 0,0:08:58.77,0:09:03.40,Main-207-,,0,0,0,,{\i1\pos(720,1071.3)}O ve dört adamı\Nhükûmet düşmanı olarak görülmeli!
Dialogue: 0,0:09:03.40,0:09:04.90,Main-207-,,0,0,0,,"Luffy..."
Dialogue: 0,0:09:04.90,0:09:10.28,Main-207-,,0,0,0,,Arlong Parkı'nda yenilmez olduğu iddia\Nedilen, Arlong Korsanları’nı devirdiler!
Dialogue: 0,0:09:10.28,0:09:12.91,Main-207-,,0,0,0,,Tehdit seviyesi nedeniyle, kaptanları...
Dialogue: 0,0:09:12.91,0:09:16.41,Main-207-,,0,0,0,,Hasır Şapkalı Luffy'nin başına\Nbüyük bir ödül koymalıyız!
Dialogue: 0,0:09:16.41,0:09:18.04,Main-207-,,0,0,0,,Fotoğrafı şimdi yolluyorum!
Dialogue: 0,0:09:18.04,0:09:19.12,Main-207-,,0,0,0,,Anlaşıldı.
Dialogue: 0,0:09:22.96,0:09:23.83,Main-207-,,0,0,0,,Ha?!
Dialogue: 0,0:09:23.83,0:09:26.59,Main-207-,,0,0,0,,Daha iyi bir fotoğraf çekemedin mi?!
Dialogue: 0,0:09:26.59,0:09:28.34,Main-207-,,0,0,0,,Hayır, sadece bu var...
Dialogue: 0,0:09:28.71,0:09:33.30,Main-207-,,0,0,0,,Hızlıca kontrol edip onaya göndereceğim.
Dialogue: 0,0:09:34.05,0:09:37.97,Main-207-,,0,0,0,,Unutma sakın! O alçak bir korsan!\N"Ölü" ya da "Diri" istiyorum!
Dialogue: 0,0:09:38.97,0:09:43.52,Main-207-,,0,0,0,,Aranıyor posterini dünyanın\Nher bir köşesine asın!
Dialogue: 0,0:09:56.08,0:09:58.04,Main-207-,,0,0,0,,Öff, patlayacağım!
Dialogue: 0,0:09:58.41,0:10:01.41,Main-207-,,0,0,0,,Yapmak yerine\Nbazen yemek keyifli!
Dialogue: 0,0:10:01.41,0:10:03.29,Main-207-,,0,0,0,,Yaraların nasıl oldu, Zoro?
Dialogue: 0,0:10:03.29,0:10:06.29,Main-207-,,0,0,0,,Önemsiz, bir güzel yer içerim, geçer!
Dialogue: 0,0:10:06.29,0:10:07.71,Main-207-,,0,0,0,,Öyle mi?
Dialogue: 0,0:10:07.71,0:10:11.09,Main-207-,,0,0,0,,Bu aptal parti daha ne kadar sürecek?
Dialogue: 0,0:10:11.09,0:10:13.05,Main-207-,,0,0,0,,Bugün üçüncü gün oluyor!
Dialogue: 0,0:10:13.05,0:10:14.39,Main-207-,,0,0,0,,Yanlış olan ne?
Dialogue: 0,0:10:14.39,0:10:18.01,Main-207-,,0,0,0,,Kutlamak istediğin zaman\Nher şeyinle kutlamalısın.
Dialogue: 0,0:10:19.22,0:10:21.85,Main-207-,,0,0,0,,Hey, Sanji!\NO yediğin kavun!
Dialogue: 0,0:10:21.85,0:10:23.23,Main-207-,,0,0,0,,Üstünde bir şey mi vardı?!
Dialogue: 0,0:10:23.23,0:10:25.60,Main-207-,,0,0,0,,Bütün bu etlerde ne?!
Dialogue: 0,0:10:25.60,0:10:29.07,Main-207-,,0,0,0,,Evet. "Çiğ jambonlu kavun"du,\Nüstünde çiğ jambon vardı.
Dialogue: 0,0:10:29.07,0:10:32.15,Main-207-,,0,0,0,,Çiğ jambonlu kavun mu?! Nefis!\NN-Nereden aldın?!
Dialogue: 0,0:10:32.15,0:10:32.70,Main-207-,,0,0,0,,Bilmem...
Dialogue: 0,0:10:33.32,0:10:38.03,Main-207-,,0,0,0,,Köyün tamamı bir ziyafet yeri,\Naldığım yeri hatırlamıyorum.
Dialogue: 0,0:10:38.70,0:10:40.04,Main-207-,,0,0,0,,Çoktan gitti.
Dialogue: 0,0:10:40.04,0:10:42.37,Main-207-,,0,0,0,,Üç gündür durmadan yiyor!
Dialogue: 0,0:10:43.16,0:10:45.37,Main-207-,,0,0,0,,Tamamdır, yemeğimi yedim.
Dialogue: 0,0:10:46.17,0:10:47.25,Main-207-,,0,0,0,,Şimdi sanırım...
Dialogue: 0,0:10:47.25,0:10:48.92,Main-207-,,0,0,0,,birkaç kız tavlayacağım!
Dialogue: 0,0:10:48.92,0:10:52.92,Main-207-,,0,0,0,,Karşınızda, en güçlü yetkili balık adamı yenen...
Dialogue: 0,0:10:52.92,0:10:56.47,Main-207-,,0,0,0,,sevilesi ve cesur kahraman, Kaptan Usopp!
Dialogue: 0,0:10:51.67,0:10:52.92,Secondary-207-,,0,0,0,,{\an8}Helal olsun, çocuk!
Dialogue: 0,0:10:52.92,0:10:54.68,Secondary-207-,,0,0,0,,{\an8}İmzanı alabilir miyim?!
Dialogue: 0,0:10:57.26,0:11:01.27,Main-207-,,0,0,0,,İşte size Usopp marşı!
Dialogue: 0,0:11:01.27,0:11:07.02,Main-207-,,0,0,0,,{\an8\fad(150,150)\b1\bord1.5\shad1.2\fs53}♫ Kimdi? Kimdi?\NBalık adamı kim yendi? ♫
Comment: 0,0:11:07.02,0:11:13.69,Main-207-,,0,0,0,,{\an8}[More of Usopp's song, untranslated.]
Dialogue: 0,0:11:05.48,0:11:07.02,Main-207-,,0,0,0,,Öf. Çok sıkıcısın.
Dialogue: 0,0:11:07.40,0:11:08.02,Main-207-,,0,0,0,,Ne oldu?
Dialogue: 0,0:11:08.02,0:11:10.57,Main-207-,,0,0,0,,Daha çok üzüleceğini düşünmüştüm.
Dialogue: 0,0:11:10.57,0:11:14.45,Main-207-,,0,0,0,,"Neden bunlar babam ölmeden\Nönce olmadı?!"
Dialogue: 0,0:11:14.86,0:11:15.82,Main-207-,,0,0,0,,Gibi.
Dialogue: 0,0:11:16.78,0:11:19.41,Main-207-,,0,0,0,,Başta böyle düşünmüştüm.
Dialogue: 0,0:11:19.41,0:11:22.33,Main-207-,,0,0,0,,Ama şimdi geleceği düşünüyorum.
Dialogue: 0,0:11:22.33,0:11:23.91,Main-207-,,0,0,0,,Geleceği mi?
Dialogue: 0,0:11:24.41,0:11:27.71,Main-207-,,0,0,0,,Hasır şapkalı abi ve\Narkadaşları bize yardım etti.
Dialogue: 0,0:11:28.08,0:11:32.55,Main-207-,,0,0,0,,Ama yarın, kendi başımıza\Nyeni bir başlangıç yapmamız gerek.
Dialogue: 0,0:11:33.21,0:11:37.76,Main-207-,,0,0,0,,Geçmişi unutmamızın bir yolu yok,\Nzaten buna da gerek yok.
Dialogue: 0,0:11:37.76,0:11:41.85,Main-207-,,0,0,0,,Asıl önemli olan bundan sonrası!
Dialogue: 0,0:11:41.85,0:11:44.93,Main-207-,,0,0,0,,Ne yapmalıyız? Nasıl yapmalıyız?
Dialogue: 0,0:11:45.64,0:11:48.81,Main-207-,,0,0,0,,Artık köylerimizi ayakta\Ntutacak olan bizleriz.
Dialogue: 0,0:11:49.31,0:11:51.11,Main-207-,,0,0,0,,İşte böyle düşünüyorum.
Dialogue: 0,0:11:53.19,0:11:53.94,Main-207-,,0,0,0,,Olgunlaşmısın!
Dialogue: 0,0:11:53.94,0:11:55.19,Main-207-,,0,0,0,,Ayy!
Dialogue: 0,0:11:55.19,0:11:58.20,Main-207-,,0,0,0,,Neden beni çimdikliyorsun?!\NAnlamıyorum! Neden?!
Dialogue: 0,0:11:58.20,0:12:00.45,Main-207-,,0,0,0,,Oysa seninle tekrar\Ndalga geçmeyi umuyordum!
Dialogue: 0,0:12:00.45,0:12:04.45,Main-207-,,0,0,0,,Yeterince dalga geçtin,\Nseni aptal, dövmeli serseri kız!
Dialogue: 0,0:12:10.38,0:12:11.75,Main-207-,,0,0,0,,"Serseri" bana uyar!
Dialogue: 0,0:12:15.17,0:12:16.17,Main-207-,,0,0,0,,Tamamen silinir mi?
Dialogue: 0,0:12:16.17,0:12:19.84,Main-207-,,0,0,0,,"Evet" demeyi çok isterdim ama\Ntamamen silinemez.
Dialogue: 0,0:12:19.84,0:12:21.35,Main-207-,,0,0,0,,Biraz iz kalacak.
Dialogue: 0,0:12:21.97,0:12:22.72,Main-207-,,0,0,0,,Evet.
Dialogue: 0,0:12:23.31,0:12:27.31,Main-207-,,0,0,0,,Kendi aptallığım, farkındayım.\NHayatım boyunca taşıyacağım.
Dialogue: 0,0:12:27.31,0:12:30.10,Flashbacks-207-,,0,0,0,,Kimsenin bunu görmesini istemiyorum!
Dialogue: 0,0:12:30.77,0:12:33.90,Flashbacks-207-,,0,0,0,,Bu... bu dövme...
Dialogue: 0,0:12:33.90,0:12:38.11,Flashbacks-207-,,0,0,0,,Bile isteye Arlong'un\Ntayfasına katılmadım,
Dialogue: 0,0:12:38.11,0:12:40.57,Flashbacks-207-,,0,0,0,,ama şimdi herkes beni korsan sanıyor!
Dialogue: 0,0:12:42.28,0:12:43.58,Flashbacks-207-,,0,0,0,,Nami...
Dialogue: 0,0:12:46.16,0:12:48.54,Flashbacks-207-,,0,0,0,,Nojiko! O da ne?!
Dialogue: 0,0:12:48.54,0:12:49.42,Flashbacks-207-,,0,0,0,,Ah? Bu mu?
Dialogue: 0,0:12:50.21,0:12:53.38,Flashbacks-207-,,0,0,0,,Önemli bir şey değil!\NSadece dekorasyon!
Dialogue: 0,0:12:53.71,0:12:55.30,Flashbacks-207-,,0,0,0,,Şimdi tıpkı senin gibiyim!
Dialogue: 0,0:13:02.34,0:13:03.60,Main-207-,,0,0,0,,Baksana, Doktor.
Dialogue: 0,0:13:04.31,0:13:06.68,Main-207-,,0,0,0,,Yaptırmak istediğim bir dövme var.
Dialogue: 0,0:13:08.14,0:13:09.06,Main-207-,,0,0,0,,İşte.
Dialogue: 0,0:13:10.23,0:13:11.60,Main-207-,,0,0,0,,İkisi dans edebiliyor!
Dialogue: 0,0:13:11.60,0:13:15.52,Main-207-,,0,0,0,,Karşınızda Usopp'un 185 numaralı marşı!
Dialogue: 0,0:13:20.61,0:13:22.24,Main-207-,,0,0,0,,Bell-mère...
Dialogue: 0,0:13:22.24,0:13:26.49,Main-207-,,0,0,0,,Küçük kızların öz güvenli ve onurlu birer kadın oldu.
Dialogue: 0,0:13:27.75,0:13:30.66,Main-207-,,0,0,0,,Bana seni hatırlatıyorlar.
Dialogue: 0,0:13:31.04,0:13:35.13,Main-207-,,0,0,0,,Şu andan itibaren\Nhayatı dolu dolu yaşayacağız.
Dialogue: 0,0:13:35.63,0:13:39.13,Main-207-,,0,0,0,,Çok fazla şey kaybettik ve\Nfedakârlık yaptık.
Dialogue: 0,0:13:39.13,0:13:44.43,Main-207-,,0,0,0,,Bu yüzden bundan sonra\Naptallar gibi gülüp eğleneceğiz.
Dialogue: 0,0:13:46.18,0:13:47.93,Main-207-,,0,0,0,,Jambonlu kavun!
Dialogue: 0,0:13:48.27,0:13:52.94,Main-207-,,0,0,0,,Ha? Burada hiç yiyecek yok.\NOlmaz böyle. Geri döneyim.
Dialogue: 0,0:13:52.94,0:13:53.90,Main-207-,,0,0,0,,Dur, çocuk!
Dialogue: 0,0:13:55.19,0:13:58.19,Main-207-,,0,0,0,,Mezar mı? Biri mi öldü?
Dialogue: 0,0:13:58.19,0:14:00.40,Main-207-,,0,0,0,,Evet. Uzun zaman önce.
Dialogue: 0,0:14:01.03,0:14:05.37,Main-207-,,0,0,0,,Ah, eliniz sağ olsun.
Dialogue: 0,0:14:05.87,0:14:10.50,Main-207-,,0,0,0,,Ha? Ayağınız sağ olsun.\NHa? Gözünüz sağ–
Dialogue: 0,0:14:10.50,0:14:12.75,Main-207-,,0,0,0,,Başınız sağ olsun.
Dialogue: 0,0:14:12.75,0:14:14.46,Main-207-,,0,0,0,,Ondan sağ olsun.
Dialogue: 0,0:14:14.46,0:14:15.75,Main-207-,,0,0,0,,Hey, evlat.
Dialogue: 0,0:14:16.46,0:14:20.30,Main-207-,,0,0,0,,Nami senin gemine binecek.\NKorsan olacak.
Dialogue: 0,0:14:20.30,0:14:22.30,Main-207-,,0,0,0,,Tehlikeli bir yolculuk olacak.
Dialogue: 0,0:14:22.30,0:14:24.43,Main-207-,,0,0,0,,Sorun değil.
Dialogue: 0,0:14:24.43,0:14:27.10,Main-207-,,0,0,0,,Yapacak bir şey yok ama...
Dialogue: 0,0:14:27.10,0:14:30.60,Main-207-,,0,0,0,,gülümsemesini elinden alacak olursanız,
Dialogue: 0,0:14:30.60,0:14:33.06,Main-207-,,0,0,0,,sizi gebertirim!
Dialogue: 0,0:14:33.06,0:14:36.02,Main-207-,,0,0,0,,Evet, öyle bir şey yapmam zaten.
Dialogue: 0,0:14:36.69,0:14:37.48,Main-207-,,0,0,0,,Anladın mı?!
Dialogue: 0,0:14:39.48,0:14:40.44,Main-207-,,0,0,0,,Anladım!
Dialogue: 0,0:14:52.29,0:14:53.58,Main-207-,,0,0,0,,Bu son mu?
Dialogue: 0,0:14:53.58,0:14:54.29,Main-207-,,0,0,0,,Evet!
Dialogue: 0,0:14:54.29,0:14:54.87,Main-207-,,0,0,0,,Pekâlâ!
Dialogue: 0,0:14:54.87,0:14:56.13,Main-207-,,0,0,0,,Her şeyi yüklediniz mi?
Dialogue: 0,0:14:56.13,0:14:57.00,Main-207-,,0,0,0,,Evet!
Dialogue: 0,0:14:57.00,0:14:59.88,Main-207-,,0,0,0,,O hâlde... erzaklar tamam!
Dialogue: 0,0:14:59.88,0:15:01.09,Main-207-,,0,0,0,,Hazırız.
Dialogue: 0,0:15:02.21,0:15:04.26,Main-207-,,0,0,0,,Kısa bir süre buradaydık ama...
Dialogue: 0,0:15:04.26,0:15:06.59,Main-207-,,0,0,0,,birçok anı biriktirdik, ha?
Dialogue: 0,0:15:06.93,0:15:08.01,Main-207-,,0,0,0,,Evet!
Dialogue: 0,0:15:14.94,0:15:18.56,Main-207-,,0,0,0,,Yaptığınız her şey için\Nsize çok şey borçluyuz.
Dialogue: 0,0:15:18.56,0:15:21.98,Main-207-,,0,0,0,,Tekrar ödül avcılığına dönüyoruz!
Dialogue: 0,0:15:21.98,0:15:22.90,Main-207-,,0,0,0,,Veda vakti geldi,
Dialogue: 0,0:15:23.61,0:15:26.41,Main-207-,,0,0,0,,ama tekrar görüşeceğimiz günü\Niple çekiyoruz!
Dialogue: 0,0:15:27.41,0:15:28.37,Main-207-,,0,0,0,,Dikkatli olun!
Dialogue: 0,0:15:28.99,0:15:30.62,Main-207-,,0,0,0,,– Siz de!\N– Siz de!
Dialogue: 0,0:15:30.62,0:15:32.83,Main-207-,,0,0,0,,Artık biz de yol alalım!
Dialogue: 0,0:15:34.04,0:15:36.37,Main-207-,,0,0,0,,H-Hey! Bekleyin!\NPeki ya Nami-{\i1}san{\i0}?!
Dialogue: 0,0:15:37.12,0:15:38.54,Main-207-,,0,0,0,,Belki de gelmiyordur?
Dialogue: 0,0:15:38.54,0:15:40.59,Main-207-,,0,0,0,,N...?! Neden gelmesin?!
Dialogue: 0,0:15:41.09,0:15:44.59,Main-207-,,0,0,0,,Seni pislik!\NYine Nami’ye asıldın, değil mi?!
Dialogue: 0,0:15:44.59,0:15:45.84,Main-207-,,0,0,0,,Neden bunu yapayım ki?
Dialogue: 0,0:15:45.84,0:15:47.59,Main-207-,,0,0,0,,Doğru ya.
Dialogue: 0,0:15:47.59,0:15:51.72,Main-207-,,0,0,0,,Amacını gerçekleştirdi,\Nkorsanlığa gerek kalmadı.
Dialogue: 0,0:15:51.72,0:15:55.10,Main-207-,,0,0,0,,Belki de burada daha mutlu olur.
Dialogue: 0,0:15:45.84,0:15:47.59,Secondary-207-,,0,0,0,,{\an8}Hayır, kesinlikle yaptın!
Dialogue: 0,0:15:47.59,0:15:51.72,Secondary-207-,,0,0,0,,{\an8}Nami-{\i1}san{\i0} ve benim sırıl sıklam\Naşkımızı çekemiyorsun!
Dialogue: 0,0:15:51.72,0:15:52.72,Secondary-207-,,0,0,0,,{\an8}Aptal mısın?
Dialogue: 0,0:15:52.72,0:15:54.35,Secondary-207-,,0,0,0,,{\an8}Ne dedin, sen?!
Dialogue: 0,0:15:55.10,0:15:56.56,Main-207-,,0,0,0,,Peki ya benim mutluluğum?!
Dialogue: 0,0:15:57.19,0:16:00.23,Main-207-,,0,0,0,,Nami-{\i1}san{\i0} gelmezse,
Dialogue: 0,0:16:00.23,0:16:03.57,Main-207-,,0,0,0,,o zaman bu gemide olma\Nsebebimin %98.72'sini kaybederim!
Dialogue: 0,0:16:03.57,0:16:06.57,Main-207-,,0,0,0,,Bu arada, jambonlu kavunu\Nhiçbir yerde bulamadım!
Dialogue: 0,0:16:07.07,0:16:08.20,Main-207-,,0,0,0,,Hey! Nacchan nerede?
Dialogue: 0,0:16:08.20,0:16:11.12,Main-207-,,0,0,0,,Sorun da bu! Sabahtan beri\Nonu kimse görmedi!
Dialogue: 0,0:16:11.12,0:16:11.74,Main-207-,,0,0,0,,Ne?!
Dialogue: 0,0:16:12.12,0:16:14.04,Main-207-,,0,0,0,,Bütün parayı arkasında mı bırakıyor?!
Dialogue: 0,0:16:14.04,0:16:16.25,Main-207-,,0,0,0,,100 milyon beli'yi mi?!
Dialogue: 0,0:16:16.25,0:16:18.54,Main-207-,,0,0,0,,Yolculuğa parasız mı çıkmayı düşünüyor?!
Dialogue: 0,0:16:18.54,0:16:21.34,Main-207-,,0,0,0,,Ama hayatını o parayı\Nkazanmak için riske attı!
Dialogue: 0,0:16:21.34,0:16:24.51,Main-207-,,0,0,0,,Sorun olmadığını söyledi\Nçünkü daha fazlasını çalacakmış.
Dialogue: 0,0:16:25.88,0:16:28.51,Main-207-,,0,0,0,,Bir kez konuştu mu\Nfikrini değiştirmek imkânsız.
Dialogue: 0,0:16:28.88,0:16:30.26,Main-207-,,0,0,0,,Aptal!
Dialogue: 0,0:16:30.26,0:16:33.97,Main-207-,,0,0,0,,Ona borçlu olan biziz!
Dialogue: 0,0:16:38.48,0:16:40.40,Main-207-,,0,0,0,,– Nami-{\i1}san{\i0}!\N– Nami-{\i1}san{\i0}!
Dialogue: 0,0:16:40.40,0:16:41.77,Main-207-,,0,0,0,,Nami!
Dialogue: 0,0:16:40.94,0:16:41.77,Secondary-207-,,0,0,0,,Nami!
Dialogue: 0,0:16:41.77,0:16:43.90,Main-207-,,0,0,0,,Nami-{\i1}san{\i0}!
Dialogue: 0,0:16:42.31,0:16:43.90,Secondary-207-,,0,0,0,,Nacchan!
Dialogue: 0,0:16:43.90,0:16:45.23,Main-207-,,0,0,0,,Yelken açın!
Dialogue: 0,0:16:51.78,0:16:54.16,Main-207-,,0,0,0,,Ne? Koşmaya başladı!
Dialogue: 0,0:16:54.16,0:16:55.41,Main-207-,,0,0,0,,Yelken açmamızı söyledi.
Dialogue: 0,0:16:55.41,0:16:55.99,Main-207-,,0,0,0,,Evet, ama...!
Dialogue: 0,0:16:57.45,0:16:58.96,Main-207-,,0,0,0,,Yoksa...
Dialogue: 0,0:16:58.96,0:17:02.79,Main-207-,,0,0,0,,teşekkürümüzü ve\Nvedamızı almadan mı ayrılacak?!
Dialogue: 0,0:17:02.79,0:17:03.38,Main-207-,,0,0,0,,Olamaz!
Dialogue: 0,0:17:03.71,0:17:05.38,Main-207-,,0,0,0,,Yelkenler fora!
Dialogue: 0,0:17:10.26,0:17:11.76,Main-207-,,0,0,0,,H-Hey!
Dialogue: 0,0:17:11.76,0:17:13.43,Main-207-,,0,0,0,,Yelken açıyorlar!
Dialogue: 0,0:17:13.43,0:17:16.18,Main-207-,,0,0,0,,Durun! Henüz doğru dürüst teşekkür edemedik!
Dialogue: 0,0:17:17.89,0:17:19.14,Main-207-,,0,0,0,,Dur, Nacchan!
Dialogue: 0,0:17:19.14,0:17:20.60,Main-207-,,0,0,0,,En azından teşekkür edelim!
Dialogue: 0,0:17:21.44,0:17:22.35,Main-207-,,0,0,0,,– Nacchan!\N– Nami! Sakinleş!
Dialogue: 0,0:17:22.35,0:17:26.36,Main-207-,,0,0,0,,Bekle! Bu şekilde\Ngitmene izin vermeyeceğim!
Dialogue: 0,0:17:26.36,0:17:29.61,Main-207-,,0,0,0,,Hey, böyle ayrılmasına\Nizin vermeli miyiz?
Dialogue: 0,0:17:29.61,0:17:32.32,Main-207-,,0,0,0,,Neden olmasın? Onun kararı.
Dialogue: 0,0:17:50.55,0:17:51.09,Main-207-,,0,0,0,,Nami!
Dialogue: 0,0:17:59.68,0:18:00.81,Main-207-,,0,0,0,,Neden?!
Dialogue: 0,0:18:01.56,0:18:02.56,Main-207-,,0,0,0,,Nami!
Dialogue: 0,0:18:23.92,0:18:24.46,Main-207-,,0,0,0,,Yoksa!
Dialogue: 0,0:18:25.42,0:18:27.21,Main-207-,,0,0,0,,– Ha? Cüzdanım gitmiş!\N– Benim de!
Dialogue: 0,0:18:27.59,0:18:28.55,Main-207-,,0,0,0,,Benim de!
Dialogue: 0,0:18:28.55,0:18:29.76,Main-207-,,0,0,0,,Benim de!
Dialogue: 0,0:18:34.80,0:18:36.39,Main-207-,,0,0,0,,Millet, kendinize iyi bakın!
Dialogue: 0,0:18:36.39,0:18:37.18,Main-207-,,0,0,0,,Nasıl...?!
Dialogue: 0,0:18:37.18,0:18:41.48,Main-207-,,0,0,0,,{{\q2}– Bunu nasıl yaparsın?! Kahrolası velet!\N– Bunu nasıl yaparsın?! Kahrolası velet!
Dialogue: 0,0:18:42.43,0:18:45.44,Main-207-,,0,0,0,,Hey. Bir gram değişmemiş.
Dialogue: 0,0:18:45.44,0:18:47.27,Main-207-,,0,0,0,,Yine ne zaman hainlik yapacak acaba?
Dialogue: 0,0:18:47.27,0:18:48.98,Main-207-,,0,0,0,,Nami-{\i1}san{\i0}! İyi işti!
Dialogue: 0,0:18:51.65,0:18:53.28,Main-207-,,0,0,0,,Seni sinsi yankesici!
Dialogue: 0,0:18:53.28,0:18:54.20,Main-207-,,0,0,0,,Buraya gel!
Dialogue: 0,0:18:54.20,0:18:55.16,Main-207-,,0,0,0,,Cüzdanım!
Dialogue: 0,0:18:55.16,0:18:56.57,Main-207-,,0,0,0,,Serseri!
Dialogue: 0,0:18:56.57,0:18:58.33,Main-207-,,0,0,0,,İstediğin zaman gel!
Dialogue: 0,0:18:58.33,0:18:59.45,Main-207-,,0,0,0,,Kendine iyi bak!
Dialogue: 0,0:18:59.45,0:19:01.20,Main-207-,,0,0,0,,Sizlere minnettarız!
Dialogue: 0,0:19:02.70,0:19:04.08,Main-207-,,0,0,0,,Çocuk!
Dialogue: 0,0:19:05.42,0:19:07.92,Main-207-,,0,0,0,,Sözümüzü unutma!
Dialogue: 0,0:19:11.96,0:19:15.09,Main-207-,,0,0,0,,Hoşça kalın, millet! Tekrar buluşana dek!
Dialogue: 0,0:19:18.35,0:19:20.06,Main-207-,,0,0,0,,Yaptı yapacağını!
Dialogue: 0,0:19:20.06,0:19:22.85,Main-207-,,0,0,0,,Küçük kız kardeşim, işinin ustası!
Dialogue: 0,0:19:24.31,0:19:25.56,Main-207-,,0,0,0,,Keyfini çıkar!
Dialogue: 0,0:19:29.56,0:19:31.82,Main-207-,,0,0,0,,Al, Genzo.
Dialogue: 0,0:19:31.82,0:19:34.11,Main-207-,,0,0,0,,Bu kağıt parçası da ne, Doktor?
Dialogue: 0,0:19:34.70,0:19:39.45,Main-207-,,0,0,0,,{\q2}O aptal kız, asla öğrenmiyor.\NAyrılmadan önce bir dövme daha yaptırdı.
Dialogue: 0,0:19:40.41,0:19:41.79,Main-207-,,0,0,0,,Bu sembol de ne?
Dialogue: 0,0:19:42.24,0:19:45.25,Main-207-,,0,0,0,,Görünüşe göre, mandalina ve rüzgâr gülü.
Dialogue: 0,0:19:46.50,0:19:49.92,Main-207-,,0,0,0,,Ha? Gen-{\i1}san{\i0}!\NRüzgâr gülüne ne oldu?
Dialogue: 0,0:19:54.17,0:19:56.05,Main-207-,,0,0,0,,Artık ona ihtiyacım kalmadı.
Dialogue: 0,0:20:06.81,0:20:09.06,Thoughts-207-,,0,0,0,,Bell-mère-{\i1}san{\i0}, gidiyorum.
Dialogue: 0,0:20:15.61,0:20:18.91,Flashbacks-207-,,0,0,0,,Bekle, Gen-san! Nami'den uzak dur!
Dialogue: 0,0:20:19.36,0:20:22.99,Flashbacks-207-,,0,0,0,,Üzgünüm ama ben de onu\Ngülerken görmek istiyorum!
Dialogue: 0,0:20:22.99,0:20:26.20,Flashbacks-207-,,0,0,0,,Çok korkunç göründüğünden onu ağlatıyorsun.
Dialogue: 0,0:20:26.20,0:20:28.71,Flashbacks-207-,,0,0,0,,Ama ne yapabilirim ki?
Dialogue: 0,0:20:29.33,0:20:29.88,Flashbacks-207-,,0,0,0,,Buldum!
Dialogue: 0,0:20:30.50,0:20:33.80,Flashbacks-207-,,0,0,0,,Bunu hep takarsam\Nseni güldürür, değil mi?!
Dialogue: 0,0:20:33.80,0:20:35.84,Flashbacks-207-,,0,0,0,,Ne dersin, Nami-chan?
Dialogue: 0,0:20:35.84,0:20:39.47,Flashbacks-207-,,0,0,0,,Bak, aptalca bir rüzgâr gülünün\Nonu güldüreceğini...
Dialogue: 0,0:20:47.39,0:20:49.52,Flashbacks-207-,,0,0,0,,Ah, güldü.
Dialogue: 0,0:20:55.19,0:20:58.86,Narrator-207-,,0,0,0,,Gökyüzü açık ve rüzgâr güzel esiyor.
Dialogue: 0,0:20:58.86,0:21:02.66,Narrator-207-,,0,0,0,,Rüzgâr gülü, mutlu bir şekilde dönüyor.
Comment: 0,0:00:00.00,0:00:00.00,Main-207-,,0,0,0,,{=15}===============================DIALOGUE============================
