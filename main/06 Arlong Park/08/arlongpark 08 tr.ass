Comment: 0,0:00:00.00,0:00:00.00,Main-207-,,0,0,0,,{=26}===============================DIALOGUE============================
Dialogue: 0,0:00:17.54,0:00:21.83,Thoughts-207-,,0,0,0,,İçimi döktüm. Yeterince ağladım.
Dialogue: 0,0:00:23.96,0:00:25.46,Thoughts-207-,,0,0,0,,Kararımı verdim!
Dialogue: 0,0:00:27.38,0:00:30.97,Thoughts-207-,,0,0,0,,Gitmem lazım. Herkes savaşıyor!
Dialogue: 0,0:00:32.35,0:00:35.35,Thoughts-207-,,0,0,0,,Lütfen... hayata dön!
Dialogue: 0,0:00:39.56,0:00:42.94,Thoughts-207-,,0,0,0,,Çabuk hayata dön!\NYoksa çok geç olacak!
Dialogue: 0,0:00:42.94,0:00:46.65,Thoughts-207-,,0,0,0,,Arkadaşların... Arkadaşların...!
Dialogue: 0,0:00:51.41,0:00:57.83,Main-207-,,0,0,0,,Kazanabilirler sanmıştım.\NHepsi boş bir düş müydü?
Dialogue: 0,0:00:58.71,0:01:01.00,Main-207-,,0,0,0,,O lanet köpek balığı ne yaptı öyle?
Dialogue: 0,0:01:01.00,0:01:02.29,Main-207-,,0,0,0,,Bilmiyorum.
Dialogue: 0,0:01:02.71,0:01:07.09,Main-207-,,0,0,0,,Sadece biraz su fırlattı ama\Ngeriye uçtular ve kan kustular.
Dialogue: 0,0:01:08.67,0:01:11.34,Main-207-,,0,0,0,,Sizin gibi insanları sadece...
Dialogue: 0,0:01:11.34,0:01:16.93,Main-207-,,0,0,0,,biraz suyla, dokunmadan öldürebilirim.
Dialogue: 0,0:01:16.93,0:01:19.02,Main-207-,,0,0,0,,Balıkadamlarla insanların farkı bu.
Dialogue: 0,0:01:19.02,0:01:20.18,Main-207-,,0,0,0,,Saçmalamayı kes!
Dialogue: 0,0:01:26.98,0:01:29.24,Thoughts-207-,,0,0,0,,Bu şaka değil.
Dialogue: 0,0:01:29.24,0:01:35.07,Thoughts-207-,,0,0,0,,Onun için suyla oynamak,\Nbizim için pompalıyla vurulmak gibi.
Dialogue: 0,0:01:35.07,0:01:37.20,Thoughts-207-,,0,0,0,,Demek bu köpek balığının gücü...
Dialogue: 0,0:01:37.20,0:01:40.29,Thoughts-207-,,0,0,0,,Balıkadamlar arasında bile\Nayrı bir mevkide.
Dialogue: 0,0:01:43.71,0:01:45.59,Thoughts-207-,,0,0,0,,Başka bir seviyede.
Dialogue: 0,0:01:45.59,0:01:47.55,Main-207-,,0,0,0,,Öl artık.
Dialogue: 0,0:01:47.92,0:01:52.51,Main-207-,,0,0,0,,Hayatlarınızın bir önemi yok.
Dialogue: 0,0:01:52.51,0:01:53.47,Main-207-,,0,0,0,,Arlong!
Dialogue: 0,0:01:54.30,0:01:56.10,Main-207-,,0,0,0,,– Nami abla!\N– Nami abla!
Dialogue: 0,0:01:56.10,0:01:57.10,Main-207-,,0,0,0,,Nami-{\i1}san{\i0}!
Dialogue: 0,0:01:57.10,0:01:59.06,Main-207-,,0,0,0,,– Nacchan...\N– Nacchan...
Dialogue: 0,0:01:59.06,0:02:04.98,Main-207-,,0,0,0,,Hey, Nami! Ben de bu\Nkorsancıkları ezmek üzereydim.
Dialogue: 0,0:02:04.98,0:02:07.32,Main-207-,,0,0,0,,Niye geldin?
Dialogue: 0,0:02:12.57,0:02:14.41,Main-207-,,0,0,0,,Seni öldürmeye.
Dialogue: 0,0:04:07.56,0:04:09.02,Main-207-,,0,0,0,,Beni...
Dialogue: 0,0:04:09.65,0:04:11.27,Main-207-,,0,0,0,,öldürmek mi?
Dialogue: 0,0:04:15.61,0:04:17.99,Main-207-,,0,0,0,,Hiç öğrenmiyorsun, değil mi?
Dialogue: 0,0:04:18.36,0:04:22.74,Main-207-,,0,0,0,,Birlikte olduğumuz sekiz yıl boyunca\Nbeni kaç kez öldürmeye kalktın?
Dialogue: 0,0:04:23.95,0:04:27.71,Main-207-,,0,0,0,,Suikasti, zehirlemeyi,\Npusu kurmayı denedin...
Dialogue: 0,0:04:27.71,0:04:29.67,Main-207-,,0,0,0,,ama hâlâ karşındayım.
Dialogue: 0,0:04:30.92,0:04:36.09,Main-207-,,0,0,0,,Sizin gibi basit insanlar\Nbeni asla öldüremeyeceğini bilmeli.
Dialogue: 0,0:04:37.17,0:04:40.09,Main-207-,,0,0,0,,Dinle beni. Seni öldürmeyeceğim,
Dialogue: 0,0:04:41.18,0:04:44.85,Main-207-,,0,0,0,,ama elimden de kurtulamazsın.
Dialogue: 0,0:04:45.52,0:04:46.60,Main-207-,,0,0,0,,Nami...
Dialogue: 0,0:04:47.43,0:04:51.15,Main-207-,,0,0,0,,Sonsuza kadar bizim haritacımız olacaksın.
Dialogue: 0,0:04:52.73,0:04:56.44,Main-207-,,0,0,0,,Ama bildiğiniz gibi, ben iyi biriyimdir.
Dialogue: 0,0:04:56.44,0:05:01.11,Main-207-,,0,0,0,,Mümkünse, kendi isteğinle\Nharitacımız olmanı istiyorum.
Dialogue: 0,0:05:05.37,0:05:08.29,Main-207-,,0,0,0,,Yani, buna ne dersin?
Dialogue: 0,0:05:08.75,0:05:15.29,Main-207-,,0,0,0,,Sen hariç buradaki herkesi\Nöldürmeyi düşünüyorum.
Dialogue: 0,0:05:17.00,0:05:21.63,Main-207-,,0,0,0,,Eğer Arlong Korsanları'na geri dönüp...
Dialogue: 0,0:05:21.63,0:05:24.47,Main-207-,,0,0,0,,yetkilim olarak deniz haritaları\Nçizmeye razı olursan,
Dialogue: 0,0:05:25.35,0:05:30.43,Main-207-,,0,0,0,,Cocoyashi Köyü’ndekilerin\Nyaşamasına göz yumabilirim.
Dialogue: 0,0:05:31.94,0:05:35.86,Main-207-,,0,0,0,,Ama bu adamların işi bitti.
Dialogue: 0,0:05:36.61,0:05:38.44,Main-207-,,0,0,0,,Çok ileriye gittiler.
Dialogue: 0,0:05:38.44,0:05:40.61,Main-207-,,0,0,0,,Asıl soru kimin tarafında olacaksın?
Dialogue: 0,0:05:41.57,0:05:45.58,Main-207-,,0,0,0,,Bana katılırsın ve köylülerle birlikte\Nhayatın bağışlanır,
Dialogue: 0,0:05:46.24,0:05:50.79,Main-207-,,0,0,0,,ya da bu zayıflarla takım olup\Nbenimle yüzleşirsin.
Dialogue: 0,0:05:50.79,0:05:55.67,Main-207-,,0,0,0,,Eğer bu adamlara\Nşimdi güvenirsen,
Dialogue: 0,0:05:55.67,0:05:58.92,Main-207-,,0,0,0,,bu sizin için trajediyle sonuçlanacaktır.
Dialogue: 0,0:06:01.67,0:06:02.97,Main-207-,,0,0,0,,Nami,
Dialogue: 0,0:06:03.55,0:06:06.30,Main-207-,,0,0,0,,benim tayfamdan biri misin?
Dialogue: 0,0:06:06.30,0:06:07.39,Main-207-,,0,0,0,,Yoksa...
Dialogue: 0,0:06:07.93,0:06:09.89,Main-207-,,0,0,0,,onların mı?
Dialogue: 0,0:06:12.77,0:06:14.56,Thoughts-207-,,0,0,0,,Bu haksızlık!
Dialogue: 0,0:06:14.94,0:06:17.27,Thoughts-207-,,0,0,0,,Luffyler'i seçersem....
Dialogue: 0,0:06:17.27,0:06:18.77,Thoughts-207-,,0,0,0,,herkes ölecek.
Dialogue: 0,0:06:19.32,0:06:21.28,Thoughts-207-,,0,0,0,,Ama Arlong'u seçersem,
Dialogue: 0,0:06:21.28,0:06:23.45,Thoughts-207-,,0,0,0,,köydeki herkes kurtulacak.
Dialogue: 0,0:06:23.91,0:06:26.45,Thoughts-207-,,0,0,0,,Her şey bana bağlı!
Dialogue: 0,0:06:29.29,0:06:30.41,Main-207-,,0,0,0,,Bu alçaklık!
Dialogue: 0,0:06:30.41,0:06:33.25,Main-207-,,0,0,0,,Ne seçerse seçsin,\NNami hâlâ zincirli kalacak!
Dialogue: 0,0:06:35.21,0:06:36.67,Thoughts-207-,,0,0,0,,Ama!
Dialogue: 0,0:06:41.38,0:06:42.34,Flashbacks-207-,,0,0,0,,Luffy,
Dialogue: 0,0:06:43.67,0:06:45.05,Flashbacks-207-,,0,0,0,,yardım et!
Dialogue: 0,0:06:45.64,0:06:48.10,Flashbacks-207-,,0,0,0,,Elbette ederim!
Dialogue: 0,0:06:51.56,0:06:55.06,Thoughts-207-,,0,0,0,,Ondan şüphe etmemeliyim!
Dialogue: 0,0:06:59.07,0:07:00.15,Main-207-,,0,0,0,,Millet, üzgünüm!
Dialogue: 0,0:07:00.52,0:07:03.36,Main-207-,,0,0,0,,Lütfen birlikte ölelim!
Dialogue: 0,0:07:05.40,0:07:07.62,Main-207-,,0,0,0,,Tamamdır!
Dialogue: 0,0:07:07.62,0:07:09.16,Main-207-,,0,0,0,,Hallederiz!
Dialogue: 0,0:07:10.41,0:07:12.79,Main-207-,,0,0,0,,Savaşacağız!
Dialogue: 0,0:07:13.83,0:07:15.46,Main-207-,,0,0,0,,Anladım.
Dialogue: 0,0:07:15.46,0:07:18.79,Main-207-,,0,0,0,,Herkes ölmek istiyor.
Dialogue: 0,0:07:25.97,0:07:27.84,Thoughts-207-,,0,0,0,,L-Lütfen! Lütfen!
Dialogue: 0,0:07:28.72,0:07:32.31,Thoughts-207-,,0,0,0,,Yaşa! Yaşa! Yaşa! Yaşa! Yaşa!
Dialogue: 0,0:07:41.15,0:07:42.15,Main-207-,,0,0,0,,Hım?
Dialogue: 0,0:07:42.48,0:07:43.57,Main-207-,,0,0,0,,Ne...?
Dialogue: 0,0:07:46.74,0:07:47.45,Main-207-,,0,0,0,,Sonunda...!
Dialogue: 0,0:07:48.03,0:07:50.70,Main-207-,,0,0,0,,Geriye bacaklarını\Nserbest bırakmak kaldı.
Dialogue: 0,0:07:50.70,0:07:51.70,Main-207-,,0,0,0,,Ne...?
Dialogue: 0,0:07:53.83,0:07:55.33,Main-207-,,0,0,0,,Demek bunu kastetmiştin.
Dialogue: 0,0:07:55.96,0:07:57.08,Main-207-,,0,0,0,,Yoksa?!
Dialogue: 0,0:07:57.08,0:07:58.71,Main-207-,,0,0,0,,Luffy abi!
Dialogue: 0,0:07:58.71,0:07:59.71,Main-207-,,0,0,0,,Ne?!
Dialogue: 0,0:08:00.08,0:08:01.84,Main-207-,,0,0,0,,Hey, dayan biraz!
Dialogue: 0,0:08:01.84,0:08:03.67,Main-207-,,0,0,0,,Kendine gel!
Dialogue: 0,0:08:15.60,0:08:16.98,Main-207-,,0,0,0,,30 saniye!
Dialogue: 0,0:08:16.98,0:08:18.56,Main-207-,,0,0,0,,Daha fazla dayanamam.
Dialogue: 0,0:08:21.44,0:08:22.40,Main-207-,,0,0,0,,Zoro!
Dialogue: 0,0:08:23.02,0:08:24.23,Main-207-,,0,0,0,,Gayet yeterli!
Dialogue: 0,0:08:26.57,0:08:29.53,Main-207-,,0,0,0,,Orada çeşme yok.
Dialogue: 0,0:08:29.53,0:08:31.53,Main-207-,,0,0,0,,Yoksa lastik çocuk mu?!
Dialogue: 0,0:08:36.95,0:08:38.37,Main-207-,,0,0,0,,Endişelenme.
Dialogue: 0,0:08:38.37,0:08:40.67,Main-207-,,0,0,0,,Bir şey değil, seni lanet yarı-balık!
Dialogue: 0,0:08:41.71,0:08:46.34,Main-207-,,0,0,0,,Bu sözleri söylememen\Nkonusunda seni uyarmıştım,
Dialogue: 0,0:08:46.34,0:08:48.63,Main-207-,,0,0,0,,ölü adam!
Dialogue: 0,0:08:53.97,0:08:58.06,Thoughts-207-,,0,0,0,,Eğer o kayayı tekmemle\Nparçalayabilirsem, dövüşebilir.
Dialogue: 0,0:08:58.06,0:09:01.90,Thoughts-207-,,0,0,0,,Luffy, bunu çözebilecek\Ntek kişi sensin!
Dialogue: 0,0:09:04.98,0:09:09.86,Main-207-,,0,0,0,,Denizde şeytan meyvesi\Ngüçleri zayıf kalır,
Dialogue: 0,0:09:09.86,0:09:13.28,Main-207-,,0,0,0,,hayatta kalmak zor,\No çoktan ölmeliydi.
Dialogue: 0,0:09:14.03,0:09:16.87,Main-207-,,0,0,0,,Eğer hâlâ hayattaysa,
Dialogue: 0,0:09:16.87,0:09:21.04,Main-207-,,0,0,0,,bu, birisinin oyunumuza\Nmüdahale ettiği anlamına gelir.
Dialogue: 0,0:09:21.37,0:09:22.54,Main-207-,,0,0,0,,İyi misin?!
Dialogue: 0,0:09:22.54,0:09:23.96,Main-207-,,0,0,0,,İyi olduğuna sevindim!
Dialogue: 0,0:09:24.29,0:09:25.88,Main-207-,,0,0,0,,Evet! Baksana?
Dialogue: 0,0:09:25.88,0:09:27.05,Main-207-,,0,0,0,,Ne?! Ne oldu?!
Dialogue: 0,0:09:28.34,0:09:30.09,Main-207-,,0,0,0,,Amca, rüzgâr gülüne ne oldu?
Dialogue: 0,0:09:30.09,0:09:31.09,Main-207-,,0,0,0,,Harikaydı.
Dialogue: 0,0:09:31.09,0:09:33.47,Main-207-,,0,0,0,,Şu anda bu kimin umurunda ki?!
Dialogue: 0,0:09:34.76,0:09:36.85,Main-207-,,0,0,0,,Müdahale mi?
Dialogue: 0,0:09:36.85,0:09:39.93,Main-207-,,0,0,0,,Başından beri adil bir oyun değildi.
Dialogue: 0,0:09:40.35,0:09:41.85,Main-207-,,0,0,0,,Ne olursa olsun,
Dialogue: 0,0:09:41.85,0:09:44.48,Main-207-,,0,0,0,,yoluma çıkanları\Nkontrol etmek zorundayım.
Dialogue: 0,0:09:45.73,0:09:46.73,Main-207-,,0,0,0,,Yolumdan çekil.
Dialogue: 0,0:09:48.36,0:09:49.40,Main-207-,,0,0,0,,{\fad(150,150)}Yumurta Yıldızı!
Dialogue: 0,0:09:52.57,0:09:54.53,Main-207-,,0,0,0,,Arkanı kolluyorum, Zoro!
Dialogue: 0,0:09:55.03,0:09:56.41,Main-207-,,0,0,0,,Usopp abi!
Dialogue: 0,0:09:56.41,0:09:57.54,Main-207-,,0,0,0,,O iyi mi?!
Dialogue: 0,0:09:57.54,0:10:00.87,Main-207-,,0,0,0,,Ne kadar cesur! Ne destansı giriş!
Dialogue: 0,0:10:01.25,0:10:03.25,Main-207-,,0,0,0,,Sonuna kadar savaş!
Dialogue: 0,0:10:03.25,0:10:05.33,Main-207-,,0,0,0,,Orada mıydın?!
Dialogue: 0,0:10:06.09,0:10:07.29,Main-207-,,0,0,0,,Usopp!
Dialogue: 0,0:10:07.80,0:10:09.05,Main-207-,,0,0,0,,Dinle, Nami!
Dialogue: 0,0:10:09.05,0:10:10.63,Main-207-,,0,0,0,,Yetkili birini yendim!
Dialogue: 0,0:10:10.63,0:10:13.76,Main-207-,,0,0,0,,Yetkili birini! Ben! Onu yendim!
Dialogue: 0,0:10:14.14,0:10:17.22,Main-207-,,0,0,0,,Hey, bu durumdan sıyrılmak için\Nbir şey yapabilir misin?
Dialogue: 0,0:10:17.22,0:10:18.64,Main-207-,,0,0,0,,Hayır, imkansız.
Dialogue: 0,0:10:18.64,0:10:20.47,Main-207-,,0,0,0,,Hiç enerjim kalmadı.
Dialogue: 0,0:10:20.98,0:10:24.31,Thoughts-207-,,0,0,0,,Çık artık! Çık artık! Çık artık!
Dialogue: 0,0:10:27.48,0:10:29.19,Main-207-,,0,0,0,,Aşçı abi!
Dialogue: 0,0:10:29.69,0:10:32.49,Main-207-,,0,0,0,,Suyun içinde ne olduğunu bilmiyorum,
Dialogue: 0,0:10:32.49,0:10:35.32,Main-207-,,0,0,0,,ama dövüşün anahtarı o olmalı!
Dialogue: 0,0:10:35.32,0:10:36.62,Main-207-,,0,0,0,,Zoro abi!
Dialogue: 0,0:10:37.12,0:10:39.45,Main-207-,,0,0,0,,Güçlü dur ve Arlong'u durdur!
Dialogue: 0,0:10:41.62,0:10:42.96,Thoughts-207-,,0,0,0,,Tamam!
Dialogue: 0,0:10:42.96,0:10:47.08,Thoughts-207-,,0,0,0,,Bir şekilde Arlong'un suya girmesini\Nengellememiz gerekiyor, ha?
Dialogue: 0,0:10:47.08,0:10:49.04,Thoughts-207-,,0,0,0,,Hareket etmesine izin vermeyeceğim.
Dialogue: 0,0:10:53.05,0:10:56.68,Main-207-,,0,0,0,,İstediğinizi yapmanıza izin veremem!
Dialogue: 0,0:10:57.09,0:10:59.64,Main-207-,,0,0,0,,Hey, Arlong! Buraya bak!
Dialogue: 0,0:11:02.10,0:11:04.35,Main-207-,,0,0,0,,N...?! Usopp abi!
Dialogue: 0,0:11:04.35,0:11:05.69,Main-207-,,0,0,0,,Ne kadar cesur!
Dialogue: 0,0:11:07.77,0:11:09.61,Main-207-,,0,0,0,,{\fad(150,150)}Usopp'un...
Dialogue: 0,0:11:10.11,0:11:12.48,Main-207-,,0,0,0,,Yolumda durduğuna göre...
Dialogue: 0,0:11:09.98,0:11:11.57,Secondary-207-,,0,0,0,,{\an8\fad(150,150)}...Ölüm Lastiği!
Dialogue: 0,0:11:12.48,0:11:16.32,Main-207-,,0,0,0,,ilk ölmek isteyen\Nsensin gibi, Roronoa Zoro.
Dialogue: 0,0:11:16.70,0:11:18.70,Main-207-,,0,0,0,,Şimdi! Saldır, Zoro!
Dialogue: 0,0:11:18.70,0:11:20.78,Main-207-,,0,0,0,,Ne yapmaya çalışıyorsun?!
Dialogue: 0,0:11:23.41,0:11:28.13,Main-207-,,0,0,0,,O fazlasıyla gurur duyduğun\Nburnunu kıracağım!
Dialogue: 0,0:11:32.25,0:11:33.63,Main-207-,,0,0,0,,Aptal.
Dialogue: 0,0:11:33.63,0:11:36.97,Main-207-,,0,0,0,,Kırılamaz olduğu için gurur duyuyorum.
Dialogue: 0,0:11:38.22,0:11:41.18,Main-207-,,0,0,0,,Eğer tam gücünde olsaydın,
Dialogue: 0,0:11:41.55,0:11:44.89,Main-207-,,0,0,0,,belki çizik atabilirdin.
Dialogue: 0,0:12:00.03,0:12:01.45,Main-207-,,0,0,0,,Abi!
Dialogue: 0,0:12:01.45,0:12:02.99,Main-207-,,0,0,0,,Buraya bak!
Dialogue: 0,0:12:02.99,0:12:04.03,Main-207-,,0,0,0,,Hım?
Dialogue: 0,0:12:04.66,0:12:07.00,Main-207-,,0,0,0,,Aah! Lanet ahtapot ayağa kalkmış!
Dialogue: 0,0:12:09.21,0:12:11.54,Main-207-,,0,0,0,,Ama... ne halt ediyor?
Dialogue: 0,0:12:14.42,0:12:17.59,Main-207-,,0,0,0,,Kahretsin!\NLastik bana vuracak diye sandım!
Dialogue: 0,0:12:17.59,0:12:18.97,Main-207-,,0,0,0,,– Ne?!\N– Ne?!
Dialogue: 0,0:12:18.97,0:12:21.55,Main-207-,,0,0,0,,Ne?!
Dialogue: 0,0:12:23.05,0:12:26.26,Main-207-,,0,0,0,,Gördünüz mü?! Hedefim oydu!
Dialogue: 0,0:12:26.26,0:12:28.52,Main-207-,,0,0,0,,"Arlong" diye bağırmadın mı?
Dialogue: 0,0:12:29.89,0:12:30.98,Main-207-,,0,0,0,,Ahtapot.
Dialogue: 0,0:12:31.69,0:12:36.32,Main-207-,,0,0,0,,Roronoa Zoro! İstediğini\Nyapmana izin vermeyeceğim!
Dialogue: 0,0:12:36.32,0:12:39.99,Main-207-,,0,0,0,,Denize giren arkadaşını yok edeceğim!
Dialogue: 0,0:12:47.08,0:12:51.87,Main-207-,,0,0,0,,Ne de olsa öleceğin için\Nmeraklanmana gerek yok.
Dialogue: 0,0:12:58.96,0:13:01.55,Main-207-,,0,0,0,,– Abi!\N– Abi!
Dialogue: 0,0:13:10.10,0:13:11.85,Thoughts-207-,,0,0,0,,Nami-{\i1}san{\i0}'nın ablası!
Dialogue: 0,0:13:11.85,0:13:13.44,Thoughts-207-,,0,0,0,,Gerisini bana bırak!
Dialogue: 0,0:13:17.73,0:13:18.73,Thoughts-207-,,0,0,0,,Balıkadam!
Dialogue: 0,0:13:21.03,0:13:22.40,Thoughts-207-,,0,0,0,,Ablacığım kenara çekil.
Dialogue: 0,0:13:22.40,0:13:24.11,Thoughts-207-,,0,0,0,,Tekmemle taşı kıracağım!
Dialogue: 0,0:13:30.41,0:13:31.04,Thoughts-207-,,0,0,0,,O ahtapot!
Dialogue: 0,0:13:31.37,0:13:34.83,Main-207-,,0,0,0,,{\fad(150,150)}Takoyaki Yumruğu!
Dialogue: 0,0:13:35.17,0:13:36.38,Thoughts-207-,,0,0,0,,Ablacığım!
Dialogue: 0,0:13:41.63,0:13:43.47,Main-207-,,0,0,0,,Zoro!
Dialogue: 0,0:13:47.43,0:13:49.56,Main-207-,,0,0,0,,Bu kadar mıydı?
Dialogue: 0,0:13:49.56,0:13:51.39,Main-207-,,0,0,0,,Hemen bitti.
Dialogue: 0,0:13:52.35,0:13:54.85,Main-207-,,0,0,0,,Bu bandajların olayı ne?
Dialogue: 0,0:13:57.31,0:13:59.65,Main-207-,,0,0,0,,Yoksa bir yerden mi düştün?
Dialogue: 0,0:14:03.95,0:14:06.45,Thoughts-207-,,0,0,0,,Bu yara da ne böyle?
Dialogue: 0,0:14:20.34,0:14:23.34,Thoughts-207-,,0,0,0,,Böyle bir yarayla\Nnasıl hâlâ hayatta olabilir?
Dialogue: 0,0:14:24.05,0:14:26.93,Thoughts-207-,,0,0,0,,Nasıl ayakta durabiliyor?!
Dialogue: 0,0:14:38.35,0:14:40.31,Thoughts-207-,,0,0,0,,Gözlerindeki bu bakış da ne?
Dialogue: 0,0:14:41.15,0:14:43.57,Thoughts-207-,,0,0,0,,Ölmek üzere olan birinin bakışları mı?
Dialogue: 0,0:14:45.70,0:14:47.82,Thoughts-207-,,0,0,0,,Onu kesinlikle, tam da burada,
Dialogue: 0,0:14:48.32,0:14:53.29,Thoughts-207-,,0,0,0,,şimdi öldürmem lazım!
Dialogue: 0,0:15:00.17,0:15:02.46,Main-207-,,0,0,0,,Hareketsiz kalmak,
Dialogue: 0,0:15:02.46,0:15:05.30,Main-207-,,0,0,0,,bazı yaraların açılmasını önlerdi.
Dialogue: 0,0:15:05.30,0:15:08.05,Main-207-,,0,0,0,,Aynen öyle.
Dialogue: 0,0:15:08.05,0:15:10.22,Main-207-,,0,0,0,,Olduğun durumu eğlenceli mi buluyorsun?
Dialogue: 0,0:15:13.81,0:15:16.23,Main-207-,,0,0,0,,Kendimden bahsetmiyorum.
Dialogue: 0,0:15:16.85,0:15:18.52,Main-207-,,0,0,0,,Ucube ahtapottan bahsediyorum.
Dialogue: 0,0:15:19.77,0:15:20.90,Main-207-,,0,0,0,,Ne?!
Dialogue: 0,0:15:20.90,0:15:22.11,Main-207-,,0,0,0,,Zaten söylemiştim,
Dialogue: 0,0:15:22.65,0:15:25.32,Main-207-,,0,0,0,,bu oyunu biz kazandık!
Dialogue: 0,0:15:35.12,0:15:37.83,Thoughts-207-,,0,0,0,,Kahretsin!
Dialogue: 0,0:15:37.83,0:15:40.54,Thoughts-207-,,0,0,0,,Gerçekten çok korkuttum!
Dialogue: 0,0:15:44.25,0:15:47.76,Thoughts-207-,,0,0,0,,Her şeyi baştan beri\Nbu kadar karmaşıklaştıran sensin!
Dialogue: 0,0:15:50.55,0:15:51.68,Thoughts-207-,,0,0,0,,Başardı!
Dialogue: 0,0:15:52.01,0:15:54.18,Thoughts-207-,,0,0,0,,Git o köpek balığı piçini döv...
Dialogue: 0,0:15:54.60,0:15:57.14,Thoughts-207-,,0,0,0,,seni salak!
Dialogue: 0,0:15:59.10,0:16:00.73,Main-207-,,0,0,0,,Geliyor mu, çocuk?
Dialogue: 0,0:16:00.73,0:16:02.73,Main-207-,,0,0,0,,Geliyor!
Dialogue: 0,0:16:10.15,0:16:15.37,Main-207-,,0,0,0,,Heey! Döndüm!
Dialogue: 0,0:16:17.83,0:16:19.29,Main-207-,,0,0,0,,Lastik çocuk!
Dialogue: 0,0:16:19.66,0:16:22.25,Main-207-,,0,0,0,,Luffy abi!
Dialogue: 0,0:16:29.09,0:16:29.92,Main-207-,,0,0,0,,Luffy!
Dialogue: 0,0:16:33.55,0:16:35.60,Main-207-,,0,0,0,,Lanet olası lastik!
Dialogue: 0,0:16:36.89,0:16:38.60,Main-207-,,0,0,0,,Geç kaldın, aptal!
Dialogue: 0,0:16:40.89,0:16:41.44,Main-207-,,0,0,0,,Zoro!
Dialogue: 0,0:16:42.31,0:16:42.81,Main-207-,,0,0,0,,Ha?
Dialogue: 0,0:16:43.56,0:16:45.31,Main-207-,,0,0,0,,Hey! Yapma!
Dialogue: 0,0:16:45.31,0:16:46.27,Main-207-,,0,0,0,,Olamaz...!
Dialogue: 0,0:16:50.90,0:16:52.95,Main-207-,,0,0,0,,Benim sıram!
Dialogue: 0,0:16:54.74,0:16:56.66,Main-207-,,0,0,0,,– Aptal!\N– Aptal!
Dialogue: 0,0:16:57.16,0:16:59.12,Main-207-,,0,0,0,,{\fad(150,150)}Lastik-Lastik...
Dialogue: 0,0:16:59.70,0:17:01.83,Main-207-,,0,0,0,,{\fad(150,150)}Çan!
Dialogue: 0,0:17:02.54,0:17:03.29,Main-207-,,0,0,0,,Ve...
Dialogue: 0,0:17:03.29,0:17:05.46,Main-207-,,0,0,0,,{\fad(150,150)}Kırbaç!
Dialogue: 0,0:17:12.09,0:17:14.05,Main-207-,,0,0,0,,{\fad(150,150)}Lastik-Lastik...
Dialogue: 0,0:17:14.05,0:17:16.01,Main-207-,,0,0,0,,{\fad(150,150)}Tabanca!
Dialogue: 0,0:17:20.31,0:17:21.85,Main-207-,,0,0,0,,{\fad(150,150)}Mitralyöz!
Dialogue: 0,0:17:31.74,0:17:32.74,Main-207-,,0,0,0,,Pekâlâ!
Dialogue: 0,0:17:49.71,0:17:52.01,Main-207-,,0,0,0,,Bir şey mi yaptın?
Dialogue: 0,0:17:52.38,0:17:54.59,Main-207-,,0,0,0,,Hissetmedi bile!
Dialogue: 0,0:17:55.38,0:17:57.76,Main-207-,,0,0,0,,Heh. Bu ısınma turuydu.
Dialogue: 0,0:17:59.81,0:18:01.72,Main-207-,,0,0,0,,Salak herif!
Dialogue: 0,0:18:01.72,0:18:03.02,Main-207-,,0,0,0,,Onu geberteceğim!
Dialogue: 0,0:18:06.94,0:18:11.11,Main-207-,,0,0,0,,Siz pisliklerin bu kadar zorlukla\Nhayata tutunması takdire şayan.
Dialogue: 0,0:18:11.73,0:18:16.32,Main-207-,,0,0,0,,Yine de denizin dibinde ölseniz\Ndaha mutlu olurdunuz.
Dialogue: 0,0:18:16.32,0:18:17.78,Main-207-,,0,0,0,,Hım? Sanmıyorum.
Dialogue: 0,0:18:17.78,0:18:20.49,Main-207-,,0,0,0,,Beni kurtardıkları için mutluyum.
Dialogue: 0,0:18:23.79,0:18:26.50,Main-207-,,0,0,0,,Öfkemi anlayabiliyor musun?
Dialogue: 0,0:18:26.87,0:18:31.13,Main-207-,,0,0,0,,Kardeşlerimin solucanlar tarafından\Nezilmesine olan öfkem bu!
Dialogue: 0,0:18:31.13,0:18:36.76,Main-207-,,0,0,0,,Yakında ölmüş olmayı dileyeceksin.
Dialogue: 0,0:18:37.26,0:18:40.01,Main-207-,,0,0,0,,Luffy abi iyi olacak mı?
Dialogue: 0,0:18:40.01,0:18:43.39,Main-207-,,0,0,0,,Öfkeli saldırılarının hiçbir etkisi olmadı.
Dialogue: 0,0:18:43.39,0:18:47.23,Main-207-,,0,0,0,,Daha da önemlisi,\NZoro abi nereye uçtu?!
Dialogue: 0,0:18:47.60,0:18:50.86,Main-207-,,0,0,0,,Saldır, Luffy!\NArkanı ben kollarım!
Dialogue: 0,0:18:50.86,0:18:52.44,Main-207-,,0,0,0,,Arkasını dert etme.
Dialogue: 0,0:18:59.70,0:19:03.66,Main-207-,,0,0,0,,Kaybederse hepiniz ölürsünüz.
Dialogue: 0,0:19:04.16,0:19:05.87,Main-207-,,0,0,0,,Evet, öyle.
Dialogue: 0,0:19:05.87,0:19:08.46,Main-207-,,0,0,0,,Öyleyse Doğu Mavi'nin sonudur demektir.
Dialogue: 0,0:19:15.46,0:19:18.93,Main-207-,,0,0,0,,Senin ve benim aramdaki\Nen büyük fark ne?
Dialogue: 0,0:19:20.30,0:19:21.18,Main-207-,,0,0,0,,Burun.
Dialogue: 0,0:19:24.39,0:19:25.35,Main-207-,,0,0,0,,Çene mi?
Dialogue: 0,0:19:27.73,0:19:30.19,Main-207-,,0,0,0,,Abi acaba dalga mı geçiyor?
Dialogue: 0,0:19:30.19,0:19:33.15,Main-207-,,0,0,0,,Hayır... Kesinlikle ciddi.
Dialogue: 0,0:19:33.52,0:19:34.61,Main-207-,,0,0,0,,Perdeli parmak!
Dialogue: 0,0:19:35.94,0:19:37.99,Main-207-,,0,0,0,,Türümüz!
Dialogue: 0,0:19:50.96,0:19:53.42,Main-207-,,0,0,0,,Ne kadar aptal!\NKayayı ısırarak canını acıttı!
Dialogue: 0,0:19:53.42,0:19:55.67,Main-207-,,0,0,0,,Şimdi dişleri kırılacak–
Dialogue: 0,0:19:59.18,0:20:02.89,Main-207-,,0,0,0,,Taş sütunu dişleriyle ezdi!
Dialogue: 0,0:20:02.89,0:20:05.22,Main-207-,,0,0,0,,Aah! Korkunç!
Dialogue: 0,0:20:18.82,0:20:19.90,Main-207-,,0,0,0,,Gücümüzün...
Dialogue: 0,0:20:21.28,0:20:23.91,Main-207-,,0,0,0,,neler yapabileceğini gördün mü?
Dialogue: 0,0:20:23.91,0:20:28.62,Main-207-,,0,0,0,,Gökler sizi, balıkadamlara\Nboyun eğmeniz için yarattı.
Dialogue: 0,0:20:30.12,0:20:32.75,Main-207-,,0,0,0,,Sizler aşağılık yaratıklarsınız.
Dialogue: 0,0:20:32.75,0:20:36.59,Main-207-,,0,0,0,,Doğduğumuz andan beri\Nsizden farklı seviyedeyiz.
Dialogue: 0,0:20:46.64,0:20:52.02,Main-207-,,0,0,0,,{\q2}İnsanların öyle kalın bir sütunu\Ndişleriyle parçalayamayacağı bir gerçek.
Dialogue: 0,0:20:52.02,0:20:55.86,Main-207-,,0,0,0,,Eğer onu ısırırsa,\Nsadece iz bırakmakla kalmaz;
Dialogue: 0,0:21:01.32,0:21:03.57,Main-207-,,0,0,0,,kemiklerini dahi parçalar!
Dialogue: 0,0:21:07.74,0:21:09.75,Main-207-,,0,0,0,,Ne olmuş yani?!
Dialogue: 0,0:21:10.16,0:21:11.41,Main-207-,,0,0,0,,Kendini...
Dialogue: 0,0:21:13.29,0:21:15.54,Main-207-,,0,0,0,,övmeyi bırak!
Dialogue: 0,0:21:18.42,0:21:21.59,Main-207-,,0,0,0,,Isırmadan taş kırabilirim.
Dialogue: 0,0:21:26.26,0:21:28.47,Main-207-,,0,0,0,,Güzel! Luffy abi için bir puan!
Dialogue: 0,0:21:28.47,0:21:31.10,Main-207-,,0,0,0,,Aynen öyle! Sonuç aynı!
Dialogue: 0,0:21:32.35,0:21:35.27,Main-207-,,0,0,0,,D-Dediğimle alakasız!
Dialogue: 0,0:21:35.90,0:21:38.90,Main-207-,,0,0,0,,İnsanlar zayıf ve aptal.
Dialogue: 0,0:21:39.14,0:21:42.25,Main-207-,,0,0,0,,Suyun içine düşüp çıkamazsan...
Dialogue: 0,0:21:42.26,0:21:43.27,Main-207-,,0,0,0,,ne yapabilirsin?!
Dialogue: 0,0:21:46.95,0:21:51.62,Main-207-,,0,0,0,,Hiçbir şey! Bu yüzden\Nyardıma ihtiyacım var!
Dialogue: 0,0:21:56.38,0:21:58.84,Main-207-,,0,0,0,,Hım? Kılıç kullanabiliyor mu?
Dialogue: 0,0:22:02.55,0:22:03.67,Main-207-,,0,0,0,,Al bunu... bunu da... bunu da!
Dialogue: 0,0:22:03.67,0:22:05.80,Main-207-,,0,0,0,,Ne yapıyorsun?
Dialogue: 0,0:22:05.80,0:22:10.43,Main-207-,,0,0,0,,Kılıçları öylece savuruyorsun\Ngibi gözüküyor.
Dialogue: 0,0:22:18.36,0:22:20.86,Main-207-,,0,0,0,,Küçük oyunlarına katılmayı düşünmüyorum.
Dialogue: 0,0:22:30.41,0:22:32.12,Main-207-,,0,0,0,,Bu saçmalıklardan bıktım.
Dialogue: 0,0:22:32.12,0:22:34.83,Main-207-,,0,0,0,,Dişlerini sık!
Dialogue: 0,0:22:56.02,0:22:59.40,Main-207-,,0,0,0,,Ne...?! Arlong'un dişlerini parçaladı!
Dialogue: 0,0:23:02.86,0:23:06.99,Main-207-,,0,0,0,,Kılıç kullanmayı bilmiyorum, şerefsiz!
Dialogue: 0,0:23:06.99,0:23:10.20,Main-207-,,0,0,0,,Ha? Bunu niye söyledi ki?
Dialogue: 0,0:23:13.87,0:23:16.08,Main-207-,,0,0,0,,Nasıl yelken açılacağını bilmiyorum.
Dialogue: 0,0:23:17.37,0:23:19.12,Main-207-,,0,0,0,,Yemek pişiremem.
Dialogue: 0,0:23:20.38,0:23:22.13,Main-207-,,0,0,0,,Yalan da söyleyemem.
Dialogue: 0,0:23:22.13,0:23:23.00,Main-207-,,0,0,0,,Hey.
Dialogue: 0,0:23:23.38,0:23:27.09,Main-207-,,0,0,0,,Yardım almadan yaşayamayacağıma eminim!
Dialogue: 0,0:23:31.51,0:23:34.97,Main-207-,,0,0,0,,Acizliğini tüm çıplaklığıyla kabul etmek...
Dialogue: 0,0:23:34.97,0:23:37.14,Main-207-,,0,0,0,,Kesinlikle dürüstsün.
Dialogue: 0,0:23:37.81,0:23:42.48,Main-207-,,0,0,0,,Eminim tayfan senin gibi\Nbeceriksiz bir kaptana,
Dialogue: 0,0:23:42.48,0:23:45.07,Main-207-,,0,0,0,,sahip olduğu için rahatsızdır.
Dialogue: 0,0:23:45.86,0:23:51.57,Main-207-,,0,0,0,,Tayfanın seni neden\Nçaresizce koruduğunu bilmiyorum.
Dialogue: 0,0:23:52.03,0:23:57.71,Main-207-,,0,0,0,,Senin gibi hiç gururu olmayan\Nbiri nasıl korsan kaptanı olabilir?
Dialogue: 0,0:23:57.71,0:24:00.79,Main-207-,,0,0,0,,Ne yapabilirsin?
Dialogue: 0,0:24:01.29,0:24:02.92,Main-207-,,0,0,0,,Seni yenebilirim!
Dialogue: 0,0:24:06.13,0:24:08.13,Main-207-,,0,0,0,,Aynen öyle, aptal!
Dialogue: 0,0:24:08.47,0:24:11.09,Main-207-,,0,0,0,,Eğer ölürse, onu öldürürüm!
Dialogue: 0,0:24:11.93,0:24:14.05,Main-207-,,0,0,0,,Arkanı kollarım!
Dialogue: 0,0:24:14.05,0:24:16.68,Main-207-,,0,0,0,,İşte bu, Lastik-Lastik!
Dialogue: 0,0:24:16.68,0:24:18.81,Main-207-,,0,0,0,,İşini bitir, Luffy abi!
Dialogue: 0,0:24:18.81,0:24:21.31,Main-207-,,0,0,0,,Başarabilirsin! Aynı seviyedesiniz!
Dialogue: 0,0:24:21.31,0:24:24.57,Main-207-,,0,0,0,,Cehenneme git, solucan!
Dialogue: 0,0:24:25.90,0:24:28.49,Main-207-,,0,0,0,,Vay! Yeni diş çıkardı!
Dialogue: 0,0:24:28.49,0:24:32.49,Main-207-,,0,0,0,,Ben bir köpek balığıyım.\NDişlerim sürekli yenilenir.
Dialogue: 0,0:24:32.49,0:24:36.45,Main-207-,,0,0,0,,Ve yeniler öncekilere göre\Ndaha sağlamdır.
Dialogue: 0,0:24:38.79,0:24:40.41,Main-207-,,0,0,0,,Her seferinde!
Dialogue: 0,0:24:44.79,0:24:46.38,Main-207-,,0,0,0,,Vayy!
Dialogue: 0,0:24:46.38,0:24:48.05,Main-207-,,0,0,0,,İstediğim kadar!
Dialogue: 0,0:24:55.47,0:24:59.43,Main-207-,,0,0,0,,Bu özellik bize\Ngökler tarafından bahşedildi.
Dialogue: 0,0:25:01.06,0:25:02.44,Main-207-,,0,0,0,,Harika!
Dialogue: 0,0:25:03.31,0:25:08.40,Main-207-,,0,0,0,,Balıkadamların ne kadar üstün\Nolduğunu anlamaya başladın mı?
Dialogue: 0,0:25:12.70,0:25:15.32,Main-207-,,0,0,0,,{\fad(150,150)}Diş Saldırısı!
Dialogue: 0,0:25:15.32,0:25:16.74,Main-207-,,0,0,0,,Ha?
Dialogue: 0,0:25:21.46,0:25:22.08,Main-207-,,0,0,0,,Dur!
Dialogue: 0,0:25:31.05,0:25:33.09,Main-207-,,0,0,0,,Luffy abi!
Dialogue: 0,0:25:42.48,0:25:44.39,Main-207-,,0,0,0,,A-Arlong-{\i1}san{\i0},
Dialogue: 0,0:25:45.40,0:25:46.61,Main-207-,,0,0,0,,Ah...
Dialogue: 0,0:25:46.61,0:25:48.86,Main-207-,,0,0,0,,N-Ne...?! K-Kardeşim!
Dialogue: 0,0:25:50.48,0:25:51.49,Main-207-,,0,0,0,,Uf be...
Dialogue: 0,0:25:52.24,0:25:54.95,Main-207-,,0,0,0,,Lanet olası lastik!
Dialogue: 0,0:25:56.16,0:25:59.95,Main-207-,,0,0,0,,Kardeşimi nasıl\Nkalkan olarak kullanırsın?!
Dialogue: 0,0:26:00.33,0:26:01.95,Main-207-,,0,0,0,,Neden bahsediyorsun?
Dialogue: 0,0:26:01.95,0:26:03.91,Main-207-,,0,0,0,,Ona saldıran sensin.
Dialogue: 0,0:26:03.91,0:26:06.88,Main-207-,,0,0,0,,Uff... Korktum.
Dialogue: 0,0:26:11.17,0:26:13.42,Main-207-,,0,0,0,,Yerinde dur,
Dialogue: 0,0:26:13.42,0:26:15.09,Main-207-,,0,0,0,,şerefsiz lastik!
Dialogue: 0,0:26:17.01,0:26:17.64,Main-207-,,0,0,0,,Ahha!
Dialogue: 0,0:26:17.64,0:26:19.26,Main-207-,,0,0,0,,Eğlenceli bir fikrim var.
Dialogue: 0,0:26:19.26,0:26:20.97,Main-207-,,0,0,0,,Eğlenceli fikir mi?
Dialogue: 0,0:26:21.56,0:26:23.27,Main-207-,,0,0,0,,Yine ne yapacak...?
Dialogue: 0,0:26:23.77,0:26:25.94,Main-207-,,0,0,0,,Gizli bir numarası mı var?
Dialogue: 0,0:26:27.23,0:26:29.27,Main-207-,,0,0,0,,{\fad(150,150)}Diş Saldırısı!
Dialogue: 0,0:26:53.21,0:26:54.38,Main-207-,,0,0,0,,İşte oldu!
Dialogue: 0,0:26:56.80,0:26:57.97,Main-207-,,0,0,0,,Aptal,
Dialogue: 0,0:26:59.26,0:27:02.22,Main-207-,,0,0,0,,dişlerimi uçurmanın bir anlamı yok.
Dialogue: 0,0:27:03.64,0:27:05.77,Main-207-,,0,0,0,,Hâlâ anlamadın mı?!
Dialogue: 0,0:27:07.02,0:27:08.77,Main-207-,,0,0,0,,Luffy abi,
Dialogue: 0,0:27:08.77,0:27:11.23,Main-207-,,0,0,0,,bu senin eğlence fikrin değil herhalde.
Dialogue: 0,0:27:11.23,0:27:14.48,Main-207-,,0,0,0,,Bakın! Benim de keskin dişlerim var!
Dialogue: 0,0:27:19.20,0:27:22.74,Thoughts-207-,,0,0,0,,Y-Yani gizli bir numarası yok muydu?
Dialogue: 0,0:27:26.62,0:27:28.67,Main-207-,,0,0,0,,Ne kadar daha,
Dialogue: 0,0:27:29.04,0:27:31.21,Main-207-,,0,0,0,,saçmalayacaksın?!
Dialogue: 0,0:27:33.84,0:27:36.55,Main-207-,,0,0,0,,Köpek balığı beni ısırdı!
Dialogue: 0,0:27:37.38,0:27:39.64,Main-207-,,0,0,0,,– Çünkü oyun oynuyorsun!\N– Çünkü oyun oynuyorsun!
Dialogue: 0,0:27:40.34,0:27:42.80,Main-207-,,0,0,0,,Oyun oynamıyorum.
Dialogue: 0,0:27:42.80,0:27:44.97,Main-207-,,0,0,0,,{\fad(150,150)}Diş Saldırısı!
Dialogue: 0,0:28:08.50,0:28:09.87,Main-207-,,0,0,0,,– Isırıldı!\N– Isırıldı!
Dialogue: 0,0:28:17.71,0:28:20.47,Main-207-,,0,0,0,,Bu nasıldı? Dişe diş!
Dialogue: 0,0:28:22.18,0:28:24.68,Main-207-,,0,0,0,,Dişimi istediğin kadar kullanabilirsin.
Dialogue: 0,0:28:25.93,0:28:28.39,Main-207-,,0,0,0,,Hâlâ zayıf bir çeneye sahipsin.
Dialogue: 0,0:28:29.14,0:28:29.89,Main-207-,,0,0,0,,Dinle.
Dialogue: 0,0:28:30.64,0:28:35.77,Main-207-,,0,0,0,,Bir köpek balığının dişleri\Nancak çenesinin gücü kadar...
Dialogue: 0,0:28:35.77,0:28:37.94,Main-207-,,0,0,0,,et parçalayabilir!
Dialogue: 0,0:28:39.90,0:28:42.61,Main-207-,,0,0,0,,Aah! Abi kolunu kaybedecek!
Dialogue: 0,0:28:43.07,0:28:44.49,Main-207-,,0,0,0,,Luffy!
Comment: 0,0:00:00.00,0:00:00.00,Main-207-,,0,0,0,,{=27}===============================DIALOGUE============================
