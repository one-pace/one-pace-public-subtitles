Comment: 0,0:00:00.00,0:00:00.00,Main-207-,,0,0,0,,{=48}===============================DIALOGUE============================
Dialogue: 0,0:01:52.34,0:01:55.30,Main-207-,,0,0,0,,Spostatevi! Spostatevi! \NSpostatevi! Spostatevi! Spostatevi!
Dialogue: 0,0:01:55.30,0:01:56.30,Main-207-,,0,0,0,,Q-Quelli sono...!
Dialogue: 0,0:02:03.65,0:02:05.31,Main-207-,,0,0,0,,{\t(1475,0,1,\c&HFFFFFF&\3c&HFFFFFF&\4c&HFFFFFF&)}Si fermi, signor Chaka!
Comment: 0,0:02:07.48,0:02:08.44,Main-207-,,0,0,0,,Eh?{già commento -angy}
Dialogue: 0,0:02:08.90,0:02:10.11,Main-207-,,0,0,0,,E voi chi sareste?
Dialogue: 0,0:02:10.53,0:02:11.65,Main-207-,,0,0,0,,Voi...!
Dialogue: 0,0:02:12.03,0:02:13.49,Main-207-,,0,0,0,,La Squadra Artiglio Calciante!
Dialogue: 0,0:02:23.33,0:02:24.83,Main-207-,,0,0,0,,Fermatevi subito!
Dialogue: 0,0:02:25.46,0:02:28.17,Main-207-,,0,0,0,,Non toccate quest'uomo!
Dialogue: 0,0:02:31.80,0:02:33.97,Main-207-,,0,0,0,,L'hanno sfondato!\NSono gli Artigli Calcianti!{-Cora}
Dialogue: 0,0:02:33.97,0:02:35.09,Main-207-,,0,0,0,,Sono l'élite d'altronde!{Cora}
Dialogue: 0,0:02:35.09,0:02:37.26,Main-207-,,0,0,0,,Salvate il re e la principessa Vivi!
Dialogue: 0,0:02:38.26,0:02:39.56,Main-207-,,0,0,0,,Vostra Maestà!
Dialogue: 0,0:02:40.01,0:02:43.98,Main-207-,,0,0,0,,{\q2}Il nostro compito... \Nè difenderla a qualunque costo!
Dialogue: 0,0:02:43.98,0:02:46.06,Main-207-,,0,0,0,,Non possiamo stare in disparte...
Dialogue: 0,0:02:46.81,0:02:49.32,Main-207-,,0,0,0,,{\q2}Se uno dei Sette Corsari\N diventa nostro nemico,
Dialogue: 0,0:02:49.32,0:02:52.32,Main-207-,,0,0,0,,non ci comporteremo da codardi!{Cora}
Dialogue: 0,0:02:52.82,0:02:54.53,Main-207-,,0,0,0,,– Noi quattro...\N– Noi quattro...
Dialogue: 0,0:02:55.03,0:02:56.70,Main-207-,,0,0,0,,porremo fine a questa storia!
Dialogue: 0,0:02:57.12,0:02:58.53,Main-207-,,0,0,0,,Andiamo a prenderlo?{Cora}
Dialogue: 0,0:02:59.66,0:03:02.66,Main-207-,,0,0,0,,A quanto pare siete \Npiuttosto popolari, perciò...
Dialogue: 0,0:03:02.66,0:03:04.25,Main-207-,,0,0,0,,vi farò una concessione...{Cora}
Dialogue: 0,0:03:04.25,0:03:06.79,Main-207-,,0,0,0,,Andatevene, tornate a casa.{Cora}
Dialogue: 0,0:03:06.79,0:03:08.75,Main-207-,,0,0,0,,Non se ne parla!
Comment: 0,0:03:08.58,0:03:09.46,Main-207-,,0,0,0,,
Dialogue: 0,0:03:09.46,0:03:12.26,Main-207-,,0,0,0,,Abbiamo una ragione... \Nper non ritirarci!
Dialogue: 0,0:03:12.84,0:03:14.51,Main-207-,,0,0,0,,"Una ragione"?
Dialogue: 0,0:03:16.68,0:03:21.76,Main-207-,,0,0,0,,Se sei davvero il responsabile\N dell'intera ribellione...
Dialogue: 0,0:03:25.73,0:03:26.98,Main-207-,,0,0,0,,Quella tecnica...!
Dialogue: 0,0:03:29.19,0:03:30.73,Main-207-,,0,0,0,,Non è possibile, voi...!
Dialogue: 0,0:03:34.99,0:03:35.95,Main-207-,,0,0,0,,Me ne occupo io?
Dialogue: 0,0:03:35.95,0:03:38.70,Main-207-,,0,0,0,,No, non importa. \NSono solo degli insetti.
Dialogue: 0,0:03:41.87,0:03:42.66,Main-207-,,0,0,0,,Non è possibile...
Dialogue: 0,0:03:46.00,0:03:47.21,Main-207-,,0,0,0,,Chaka!
Dialogue: 0,0:03:47.21,0:03:48.88,Main-207-,,0,0,0,,Si comportano in modo strano!
Dialogue: 0,0:03:48.88,0:03:51.96,Main-207-,,0,0,0,,{\q2}Per... ottenere temporaneamente più forza,
Dialogue: 0,0:03:52.92,0:03:54.92,Main-207-,,0,0,0,,{\q2}hanno bevuto l'acqua che erode la vita...
Dialogue: 0,0:03:55.55,0:03:57.80,Main-207-,,0,0,0,,hanno bevuto l'Acqua Impetuosa!
Dialogue: 0,0:03:57.80,0:04:00.60,Main-207-,,0,0,0,,Ormai... \Ngli rimangono pochi minuti di vita...!
Dialogue: 0,0:04:00.97,0:04:02.31,Main-207-,,0,0,0,,Non potranno salvarsi!
Dialogue: 0,0:04:02.31,0:04:03.97,Main-207-,,0,0,0,,Oh no!
Dialogue: 0,0:04:05.98,0:04:09.35,Main-207-,,0,0,0,,{\q2}Immaginavo fosse qualcosa del genere.
Dialogue: 0,0:04:09.35,0:04:12.94,Main-207-,,0,0,0,,{\q2}Volete sfidarmi gettando via la vostra vita?
Dialogue: 0,0:04:13.65,0:04:15.19,Main-207-,,0,0,0,,Signor Chaka...
Dialogue: 0,0:04:15.19,0:04:18.36,Main-207-,,0,0,0,,Perdoni il nostro egoismo.
Dialogue: 0,0:04:18.36,0:04:19.91,Main-207-,,0,0,0,,Ma lui deve provare...
Dialogue: 0,0:04:20.74,0:04:23.28,Main-207-,,0,0,0,,il dolore... di questo Paese...
Dialogue: 0,0:04:41.97,0:04:44.31,Main-207-,,0,0,0,,Brutti... idioti...
Dialogue: 0,0:04:45.14,0:04:47.73,Main-207-,,0,0,0,,{\t(1938,0,1,\c&HFFFFFF&\3c&HFFFFFF&\4c&HFFFFFF&)}la collera...
Dialogue: 0,0:04:47.77,0:04:49.48,Main-207-,,0,0,0,,che questo Paese...
Dialogue: 0,0:04:54.48,0:04:56.98,Main-207-,,0,0,0,,prova verso di lui...!
Dialogue: 0,0:05:11.54,0:05:13.79,Main-207-,,0,0,0,,Non siete molto intelligenti, eh?
Dialogue: 0,0:05:14.46,0:05:17.13,Main-207-,,0,0,0,,Dovreste tenervi cara la vita.
Dialogue: 0,0:05:17.76,0:05:19.63,Main-207-,,0,0,0,,{Ma, beh, ormai è troppo tardi, eh? - toglierei il "beh" che con "eh" finale è un po' ridondante "Ma ormai è troppo tardi, eh?" -Chara}Ma ormai è troppo tardi, vero?{cambiato "eh" alla fine perché lo diceva già due righe prima -Cora}{ya mou però è un po' un "ma beh" comunque -angy}
Dialogue: 0,0:05:25.93,0:05:30.43,Main-207-,,0,0,0,,Se morirete comunque, \Nnon ha senso che io intervenga.
Dialogue: 0,0:05:30.81,0:05:33.56,Main-207-,,0,0,0,,Non vuoi nemmeno combattere?!
Dialogue: 0,0:05:49.87,0:05:52.00,Main-207-,,0,0,0,,Signor... Chaka...
Dialogue: 0,0:05:57.96,0:06:01.47,Main-207-,,0,0,0,,{\q2}Questa è proprio la definizione di "stupidità"!
Dialogue: 0,0:06:02.97,0:06:04.84,Main-207-,,0,0,0,,Spregevole...!
Dialogue: 0,0:06:08.39,0:06:10.77,Main-207-,,0,0,0,,{\c&H080804&\3c&H080804&\4c&H080804&\t(20,979,1,\c&HFFFFFF&\3c&H000000&\4c&H000000&)}Bastardo!
Dialogue: 0,0:06:12.85,0:06:14.02,Main-207-,,0,0,0,,Chaka!
Dialogue: 0,0:06:14.40,0:06:16.40,Main-207-,,0,0,0,,Chaka, fermati!
Dialogue: 0,0:06:16.40,0:06:18.65,Main-207-,,0,0,0,,Non puoi morire anche tu!
Dialogue: 0,0:06:19.07,0:06:21.40,Main-207-,,0,0,0,,Oh, uno Zoan.
Dialogue: 0,0:06:21.40,0:06:25.45,Main-207-,,0,0,0,,{Frutto Cane Cane: Modello Jackal! - pongo la domanda solo perchè sono più in là con l'episodio e l'abbiamo tradotto in sciacallo (che a me piace tantissimo <3) mentre parla a Crocodaddy a 15:39: è giusto Jackal o dobbiamo tradurlo? Solo per sicurezza -Chara}Frutto Cane Cane: Modello Sciacallo! {Giusta, osservazione, corretto e aggiornato il gloassario -Cora}{no perché là era parte di una frase, qua è il nome del frutto e chiaramente dice Jackal in inglese. per come abbiamo fatto le cose finora, è modello jackal -angy}
Dialogue: 0,0:06:26.28,0:06:28.41,Main-207-,,0,0,0,,{\fad(150,150)}Zanne Ululanti!
Dialogue: 0,0:06:32.37,0:06:34.00,Main-207-,,0,0,0,,Anche tu...
Dialogue: 0,0:06:34.00,0:06:35.50,Main-207-,,0,0,0,,darai la tua vita...
Dialogue: 0,0:06:36.83,0:06:38.75,Main-207-,,0,0,0,,per gli altri?
Dialogue: 0,0:06:52.98,0:06:54.10,Main-207-,,0,0,0,,Maledizione...
Dialogue: 0,0:06:54.10,0:06:55.73,Main-207-,,0,0,0,,Ho perso troppo sangue...
Dialogue: 0,0:06:56.60,0:06:59.82,Main-207-,,0,0,0,,{\q2}Le ferite non sono così profonde,\N quindi direi che è andata bene...
Dialogue: 0,0:06:59.82,0:07:02.90,Main-207-,,0,0,0,,{\q2}Però... hanno sortito... il loro effetto...{Cora}
Dialogue: 0,0:07:04.86,0:07:06.91,Main-207-,,0,0,0,,Cosa sarà successo agli altri?
Dialogue: 0,0:07:06.91,0:07:09.33,Main-207-,,0,0,0,,Non è morto nessuno, vero?
Dialogue: 0,0:07:09.33,0:07:11.37,Main-207-,,0,0,0,,Voglio sapere cosa sta succedendo!
Dialogue: 0,0:07:11.99,0:07:13.62,Flashbacks-207-,,0,0,0,,Cosa?!
Dialogue: 0,0:07:13.62,0:07:17.83,Flashbacks-207-,,0,0,0,,Devo fare squadra con Matsuge?!
Dialogue: 0,0:07:17.83,0:07:21.46,Flashbacks-207-,,0,0,0,,Ma è un cammello!
Dialogue: 0,0:07:21.46,0:07:24.51,Flashbacks-207-,,0,0,0,,{[/q2]Voialtri...\Nnon dimenticate quante sono debole! - "Voialtri... non dimenticate quanto sono debole!" ho solo corretto "quanto" -Chara}{\q2}Voialtri... \Nvi state dimenticando di quanto sono debole?!{Cora}{perché @cora? sia io che Chara abbiamo messo "non dimenticate quanto sono debole!", non modificare i verbi così. specie perché qua è una delle poche volte in cui non è una domanda in jp -angy}
Dialogue: 0,0:07:24.82,0:07:28.01,Flashbacks-207-,,0,0,0,,{\q2}Hai solo avuto sfortuna nel sorteggio! \NFalla finita!
Dialogue: 0,0:07:28.01,0:07:31.14,Flashbacks-207-,,0,0,0,,Va bene, ho capito! \NMa allora promettimi una cosa!
Dialogue: 0,0:07:31.14,0:07:32.89,Flashbacks-207-,,0,0,0,,Quando saremo in pericolo,{Cora}
Dialogue: 0,0:07:32.89,0:07:34.64,Flashbacks-207-,,0,0,0,,vieni a salvarci per favore!
Dialogue: 0,0:07:34.64,0:07:38.44,Flashbacks-207-,,0,0,0,,Idiota! Io salvo solo le lady.
Dialogue: 0,0:07:40.73,0:07:42.07,Main-207-,,0,0,0,,Usopp...
Dialogue: 0,0:07:44.94,0:07:46.40,Main-207-,,0,0,0,,Ehi, Usopp!
Dialogue: 0,0:07:46.40,0:07:49.37,Main-207-,,0,0,0,,Cretino... perché stai piangendo?
Dialogue: 0,0:07:49.37,0:07:52.54,Main-207-,,0,0,0,,Chi è che starebbe piangendo?! \NIo non sto piangendo!
Dialogue: 0,0:07:52.54,0:07:54.66,Main-207-,,0,0,0,,{È quello che lo dice quello che piange! - ew -angy}{Sarai tu che lo dici che lo starà facendo! - Cora}{"Tu che lo dici stai piangendo!" ...ragazzi non mi piace nessuna delle due scusate HAHA l'og è super confusa e l'adattamento ancora di più. Qua è più tipo un "chi lo dice lo è!", secondo me va resa semplice (forse ancora più semplice della mia). Se vogliamo tenere l'adattamento metterei "Sarai tu che lo dici a starlo facendo!" perchè il doppio futuro mi perplime, ma non posso ripetere abbastanza che secondo me non rende molto HAHA -Chara}Tu che lo dici stai piangendo!{Cora}{onestamente sono tutte orrende, ma non saprei come metterla -angy}
Dialogue: 0,0:07:54.66,0:07:56.66,Main-207-,,0,0,0,,Ma che dici?!{Cora}
Dialogue: 0,0:07:56.66,0:07:58.37,Main-207-,,0,0,0,,Ma...
Dialogue: 0,0:07:58.75,0:08:01.00,Main-207-,,0,0,0,,quella vecchia talpa...
Dialogue: 0,0:08:01.00,0:08:05.34,Main-207-,,0,0,0,,ha detto... che Luffy... è morto...
Dialogue: 0,0:08:05.84,0:08:07.80,Main-207-,,0,0,0,,C-Che sia vero?
Dialogue: 0,0:08:08.55,0:08:10.80,Main-207-,,0,0,0,,Voi due... ci credete pure?
Dialogue: 0,0:08:11.26,0:08:14.14,Main-207-,,0,0,0,,Mica ci credo! Sei scemo o cosa?!
Dialogue: 0,0:08:14.14,0:08:16.93,Main-207-,,0,0,0,,Idem! Anch'io non ci credo per niente!
Dialogue: 0,0:08:18.69,0:08:20.31,Main-207-,,0,0,0,,Ho capito!
Dialogue: 0,0:08:20.31,0:08:24.69,Main-207-,,0,0,0,,{\q2}L'unica cosa che dobbiamo fare ora \Nè raggiungere il palazzo il prima possibile!{Cora}
Dialogue: 0,0:08:25.15,0:08:29.57,Main-207-,,0,0,0,,{\q2}Asciugati il moccolo! Almeno finché\N il casino di questo scontro non sarà terminato!
Dialogue: 0,0:08:31.49,0:08:32.66,Main-207-,,0,0,0,,{\fad(0,523)}Non berlo!
Dialogue: 0,0:08:36.12,0:08:38.04,Flashbacks-207-,,0,0,0,,Ragazzi... vi ringrazio.
Dialogue: 0,0:08:38.79,0:08:40.50,Flashbacks-207-,,0,0,0,,Non è presto per i ringraziamenti?
Dialogue: 0,0:08:40.88,0:08:44.38,Flashbacks-207-,,0,0,0,,Esatto. E se vuoi\N ringraziare noi pirati, dovresti...
Dialogue: 0,0:08:44.38,0:08:46.26,Flashbacks-207-,,0,0,0,,offrirci qualcosa in cambio.{Cora}
Dialogue: 0,0:08:46.26,0:08:49.97,Flashbacks-207-,,0,0,0,,{\fad(0,1025)}Quanto ancora vuoi\N spremere questo Paese?!
Dialogue: 0,0:08:50.22,0:08:51.51,Thoughts-207-,,0,0,0,,Staranno bene?
Dialogue: 0,0:08:51.51,0:08:53.97,Thoughts-207-,,0,0,0,,Nami... sarà riuscita a scappare?
Comment: 0,0:09:00.19,0:09:01.44,Main-207-,,0,0,0,,
Dialogue: 0,0:09:01.44,0:09:02.90,Main-207-,,0,0,0,,{Finalmente sono riuscita a toglierlo. - prenderlo. cps ma così è lett. -angy}{Finalmente l'ho tolto. - Cora}{"Finalmente l'ho sbrogliato/sgrovigliato." solo perchè il cucù era letteralmente attorcigliato a Miss Doublefinger e secondo me da' meglio il senso di "togliere" o "prendere" -Chara}Finalmente l'ho sbrogliato.{Cora}{sbrogliato è bruttino eh... piuttosto sgrovigliato -angy}
Dialogue: 0,0:09:03.27,0:09:07.86,Main-207-,,0,0,0,,Il "pezzo forte" che può essere \Nusato solo una volta era questo, eh?{Cora}
Dialogue: 0,0:09:09.11,0:09:12.57,Main-207-,,0,0,0,,{\q2}L'ondata dei ribelli è già arrivata fin qui.
Dialogue: 0,0:09:17.16,0:09:19.12,Main-207-,,0,0,0,,La situazione è cambiata parecchio,
Dialogue: 0,0:09:19.12,0:09:21.12,Main-207-,,0,0,0,,{\q2}ma devo sbrigarmi a raggiungere il palazzo!{Cora}{cps -angy}
Dialogue: 0,0:09:26.34,0:09:28.05,Thoughts-207-,,0,0,0,,E Vivi dove sarà?
Dialogue: 0,0:09:28.05,0:09:30.88,Thoughts-207-,,0,0,0,,{\fad(0,1019)}Pare sia già cominciata...
Dialogue: 0,0:09:31.72,0:09:33.47,Flashbacks-207-,,0,0,0,,Oh, giusto! Cara Vivi!
Dialogue: 0,0:09:33.47,0:09:35.18,Flashbacks-207-,,0,0,0,,Ricordati almeno di questo.
Dialogue: 0,0:09:35.89,0:09:39.35,Flashbacks-207-,,0,0,0,,Dopo gli scontri, lui mangia un sacco!
Dialogue: 0,0:09:39.85,0:09:41.14,Flashbacks-207-,,0,0,0,,D'accordo.
Dialogue: 0,0:09:41.14,0:09:43.81,Flashbacks-207-,,0,0,0,,{AR 09 - 23:38}Ti aspettiamo ad Alubarna!
Dialogue: 0,0:09:43.81,0:09:47.15,Flashbacks-207-,,0,0,0,,Sì!
Dialogue: 0,0:09:47.15,0:09:49.53,Flashbacks-207-,,0,0,0,,Bene, è il momento della verità!
Dialogue: 0,0:09:51.90,0:09:53.11,Flashbacks-207-,,0,0,0,,Non combinate guai!
Dialogue: 0,0:09:53.74,0:09:55.12,Flashbacks-207-,,0,0,0,,{Ara 09 - 24:40}Andiamo!{non so quel flashback sinceramente, io lì o nei dintorni non l'ho trovato -angy}
Dialogue: 0,0:09:55.12,0:09:57.33,Flashbacks-207-,,0,0,0,,Ci vediamo al palazzo di Alubarna!
Dialogue: 0,0:10:08.88,0:10:09.88,Main-207-,,0,0,0,,Chaka!
Dialogue: 0,0:10:15.89,0:10:17.64,Main-207-,,0,0,0,,Essere deboli...
Dialogue: 0,0:10:18.06,0:10:19.89,Main-207-,,0,0,0,,{è proprio un peccato. - peccato nel senso di sin comunque -angy}è un peccato capitale.{Cora}{peccato e peccato capitale sono due cose di gravità diversa, mi pare eccessivo peccato capitale onestamente -angy}
Dialogue: 0,0:10:23.73,0:10:24.77,Main-207-,,0,0,0,,Vivi!
Dialogue: 0,0:10:41.54,0:10:43.54,Main-207-,,0,0,0,,K-Koza...!
Dialogue: 0,0:10:50.84,0:10:51.92,Main-207-,,0,0,0,,Tu...
Dialogue: 0,0:10:51.92,0:10:54.63,Main-207-,,0,0,0,,Capisco! Hai usato il passaggio \Nsegreto che usavi tempo fa?{Cora}
Dialogue: 0,0:10:56.34,0:10:58.64,Main-207-,,0,0,0,,Ho la vista annebbiata forse?{Cora}
Dialogue: 0,0:11:09.44,0:11:12.57,Main-207-,,0,0,0,,Ero venuto con l'intenzione di \Npersuadere l'esercito reale, ma...
Dialogue: 0,0:11:14.99,0:11:15.91,Main-207-,,0,0,0,,Chaka...
Dialogue: 0,0:11:17.36,0:11:19.58,Main-207-,,0,0,0,,e il re...
Dialogue: 0,0:11:19.91,0:11:22.79,Main-207-,,0,0,0,,{\q2}stanno per essere uccisi dall'eroe del Paese.
Dialogue: 0,0:11:22.79,0:11:25.00,Main-207-,,0,0,0,,È proprio una scena assurda.{Cora}
Dialogue: 0,0:11:27.96,0:11:30.96,Main-207-,,0,0,0,,Le cose si fanno interessanti!
Dialogue: 0,0:11:30.96,0:11:38.14,Main-207-,,0,0,0,,{\q2}Proprio ora, nel pieno dello scontro,\N i leader dei due schieramenti s'incontrano qui.{Cora}
Dialogue: 0,0:11:38.14,0:11:43.02,Main-207-,,0,0,0,,{\q2}A questo punto si tratta ormai di una guerra\N combattuta da due lucertole senza testa.{Cora}
Dialogue: 0,0:11:45.81,0:11:47.56,Main-207-,,0,0,0,,Sembri confuso.
Dialogue: 0,0:11:47.56,0:11:51.27,Main-207-,,0,0,0,, Beh, è una reazione normale, \Nma è piuttosto semplice.
Dialogue: 0,0:11:52.82,0:11:57.40,Main-207-,,0,0,0,,{\q2}Ti basta immaginare il peggior scenario possibile.
Dialogue: 0,0:12:01.87,0:12:05.54,Flashbacks-207-,,0,0,0,,{\t(3355,0,1,\c&HFFFFFF&\3c&HFFFFFF&\4c&HFFFFFF&)}{Z, This line is a flashback to Alabasta 08 @3:13}Non dubitare, Koza.
Dialogue: 0,0:12:12.50,0:12:15.01,Flashbacks-207-,,0,0,0,,{\t(2109,0,1,\c&HFFFFFF&\3c&HFFFFFF&\4c&HFFFFFF&)}{The next flashback lines after are from Alabasta 05 @10:15}Ami questo Paese?
Dialogue: 0,0:12:23.18,0:12:25.85,Flashbacks-207-,,0,0,0,,{\t(2356,0,1,\c&HFFFFFF&\3c&HFFFFFF&\4c&HFFFFFF&)}Sì! È il Paese dove sono nato!{Alabasta 5 at 10:17}
Dialogue: 0,0:12:26.48,0:12:28.31,Flashbacks-207-,,0,0,0,,Anch'io!{Alabasta 05 at 10:20}
Dialogue: 0,0:12:29.85,0:12:30.94,Main-207-,,0,0,0,,Koza, ascolta...
Dialogue: 0,0:12:30.94,0:12:32.19,Main-207-,,0,0,0,,Vivi!
Dialogue: 0,0:12:32.19,0:12:34.94,Main-207-,,0,0,0,,{\q2}Chi ha rubato la pioggia a questo Paese?!
Dialogue: 0,0:12:37.03,0:12:38.15,Main-207-,,0,0,0,,È tutta colpa...
Dialogue: 0,0:12:38.15,0:12:40.16,Main-207-,,0,0,0,,Sono stato io, Koza.{scusate ma qua se dicesse "...mia, Koza." quanto sarebbe figo? Continua la frase di Vivi dando la verità a Koza in quel momento, boh ho avuto un'illuminazione divina HAHA -Chara} {non so se in jap sono due frasi distinte ma credo di sì -Cora}{per rispondevi, ma poi ricordo @cora di cancellare sti commenti inutili, sono due frasi distinte -angy}
Dialogue: 0,0:12:41.03,0:12:45.87,Main-207-,,0,0,0,,Anche il fatto che \Nabbiate incolpato il re...
Dialogue: 0,0:12:45.87,0:12:48.87,Main-207-,,0,0,0,,{\q2}era tutto una trappola \Ndella mia organizzazione.
Dialogue: 0,0:12:48.87,0:12:54.34,Main-207-,,0,0,0,,{\q2}In questi ultimi due anni, vi siete mossi \Ncome volevo. È stato proprio divertente.
Dialogue: 0,0:12:55.63,0:13:01.30,Main-207-,,0,0,0,,La famiglia reale e l'esercito avevano\N iniziato a fiutare le nostre traccie.
Dialogue: 0,0:13:07.06,0:13:11.77,Main-207-,,0,0,0,,Saresti potuto morire felice \Nsenza conoscere questa verità.
Dialogue: 0,0:13:18.24,0:13:20.74,Main-207-,,0,0,0,,Non ascoltarlo, Koza!
Dialogue: 0,0:13:21.99,0:13:23.07,Main-207-,,0,0,0,,Vostra Maestà!
Dialogue: 0,0:13:23.49,0:13:26.24,Main-207-,,0,0,0,,Si può ancora fare molto!
Dialogue: 0,0:13:26.24,0:13:29.04,Main-207-,,0,0,0,,{\q2}Salva il maggior numero di cittadini possibile!
Dialogue: 0,0:13:30.71,0:13:32.50,Main-207-,,0,0,0,,In meno di mezz'ora...
Dialogue: 0,0:13:32.96,0:13:35.96,Main-207-,,0,0,0,,{\q2}la piazza di fronte al palazzo salterà in aria!
Dialogue: 0,0:13:36.38,0:13:37.59,Main-207-,,0,0,0,,Cos'hai detto?!
Dialogue: 0,0:13:38.09,0:13:40.55,Main-207-,,0,0,0,,Quindi sei ancora vivo, eh?
Dialogue: 0,0:13:44.97,0:13:48.02,Main-207-,,0,0,0,,Sbrigati!
Dialogue: 0,0:13:58.90,0:14:00.32,Main-207-,,0,0,0,,Non puoi!
Dialogue: 0,0:14:02.40,0:14:03.86,Main-207-,,0,0,0,,Vivi!
Dialogue: 0,0:14:04.24,0:14:07.03,Main-207-,,0,0,0,,Ah, ehi! Spostati, Vivi!\N Che intenzioni hai?!
Dialogue: 0,0:14:07.03,0:14:09.04,Main-207-,,0,0,0,,Quella piazza a breve sarà\Nun campo di battaglia!{Cora}{still cps}
Dialogue: 0,0:14:09.04,0:14:10.37,Main-207-,,0,0,0,,Se saltasse in aria...!
Dialogue: 0,0:14:10.37,0:14:14.29,Main-207-,,0,0,0,,Non lo permetterò! \NNon diventerà un campo di battaglia!
Dialogue: 0,0:14:17.50,0:14:20.59,Main-207-,,0,0,0,,{Tu sei... ancora sconvolto! - "Tu... sei ancora sconvolto!" non ho un motivo logico dietro a questo suggerimento, mi suona solo meglio -Chara}Tu... sei ancora sconvolto!{Cora}{rispetta meno il jp la pausa in quel punto}
Dialogue: 0,0:14:20.59,0:14:25.47,Main-207-,,0,0,0,,{\q2}Cosa pensi che faranno tutti se gli dicessi\N che la piazza sta per esplodere?!
Dialogue: 0,0:14:25.47,0:14:28.68,Main-207-,,0,0,0,,L'intera piazza andrà nel panico, no?!
Dialogue: 0,0:14:29.31,0:14:31.02,Main-207-,,0,0,0,,E a quel punto...
Dialogue: 0,0:14:31.02,0:14:32.81,Main-207-,,0,0,0,,nessuno potrà fermare lo scontro!{Cora}
Dialogue: 0,0:14:32.81,0:14:34.02,Main-207-,,0,0,0,,Nessuno verrà salvato!{Cora}
Dialogue: 0,0:14:38.23,0:14:39.94,Main-207-,,0,0,0,,Dico bene?
Dialogue: 0,0:14:40.44,0:14:43.95,Main-207-,,0,0,0,,Oh. Che decisione perfetta.
Dialogue: 0,0:14:44.32,0:14:47.45,Main-207-,,0,0,0,,{\q2}Dobbiamo fare ciò che era \Ngiusto fare sin dal principio!
Dialogue: 0,0:14:50.24,0:14:53.37,Main-207-,,0,0,0,,{\q2}Dobbiamo fermare questa \Nribellione orchestrata...!
Dialogue: 0,0:14:54.92,0:14:56.42,Main-207-,,0,0,0,,E questo...
Dialogue: 0,0:14:56.42,0:14:58.92,Main-207-,,0,0,0,,lo puoi fare solo tu!
Dialogue: 0,0:15:18.11,0:15:23.03,Main-207-,,0,0,0,,{\q2}E pensi che io me ne starò zitto a guardare?
Dialogue: 0,0:15:34.66,0:15:35.58,Main-207-,,0,0,0,,Chaka!
Dialogue: 0,0:15:38.21,0:15:39.46,Main-207-,,0,0,0,,Io...
Dialogue: 0,0:15:39.88,0:15:42.30,Main-207-,,0,0,0,,{[/q2]sono la divinità protettrice di Alabasta, Jackal! - ....... vedete voi cosa volete fare -angy}{\q2}sono la divinità protettrice\N di Alabasta, lo sciacallo!{Cora}{qua lo potete anche tradurre se proprio proprio, ma come dicevo prima, il frutto non dovremmo tradurlo imo -angy}
Dialogue: 0,0:15:42.30,0:15:45.38,Main-207-,,0,0,0,,Colui che annienta \Ni nemici della famiglia reale!
Dialogue: 0,0:15:47.47,0:15:50.64,Main-207-,,0,0,0,,{\q2}Finché avrò vita, continuerò a combattere!
Dialogue: 0,0:15:51.56,0:15:54.27,Main-207-,,0,0,0,,Questa è la definizione di stupidità.{Cora}
Dialogue: 0,0:15:54.60,0:15:56.94,Main-207-,,0,0,0,,Voi due, fate come meglio credete!
Dialogue: 0,0:15:56.94,0:16:00.27,Main-207-,,0,0,0,,{\q2}Riuscirò a trattenerlo solo per qualche minuto!
Dialogue: 0,0:16:00.86,0:16:01.77,Main-207-,,0,0,0,,Sì!
Dialogue: 0,0:16:03.44,0:16:04.57,Thoughts-207-,,0,0,0,,Chaka...
Dialogue: 0,0:16:04.57,0:16:07.78,Flashbacks-207-,,0,0,0,,{\t(2813,0,1,\c&HFFFFFF&\3c&HFFFFFF&\4c&HFFFFFF&)}Non sei granché per essere il \Nleader del Gruppo Sabbia Sabbia.
Dialogue: 0,0:16:12.12,0:16:13.70,Flashbacks-207-,,0,0,0,,Dai, che succede?
Dialogue: 0,0:16:18.71,0:16:20.96,Flashbacks-207-,,0,0,0,,Che male...!
Dialogue: 0,0:16:21.50,0:16:25.26,Flashbacks-207-,,0,0,0,,Tu sì che sei maturo, eh! \NDovresti andarci più piano!
Dialogue: 0,0:16:25.26,0:16:27.51,Flashbacks-207-,,0,0,0,,Che ragazzino difficile.
Dialogue: 0,0:16:28.09,0:16:32.47,Flashbacks-207-,,0,0,0,,{\t(4068,0,1,\c&HFFFFFF&\3c&HFFFFFF&\4c&HFFFFFF&)}Sei stato tu a chiedermi di allenarti.{Cora}
Dialogue: 0,0:16:46.65,0:16:48.95,Main-207-,,0,0,0,,{\q2}Qui gruppo di guardia due al quartier generale!
Dialogue: 0,0:16:49.91,0:16:51.91,Main-207-,,0,0,0,,{\q2}Qui gruppo di guardia due al quartier generale!
Dialogue: 0,0:16:51.91,0:16:54.91,Main-207-,,0,0,0,,{\q2}La linea di difesa quattro è stato superata!
Dialogue: 0,0:16:57.12,0:17:00.62,Main-207-,,0,0,0,,{\q2}L'armata ribelle ha superato la piazza \Ncentrale e si dirige al blocco nord!
Dialogue: 0,0:17:00.62,0:17:02.00,Main-207-,,0,0,0,,Raggiungerà il palazzo!
Dialogue: 0,0:17:02.63,0:17:04.34,Main-207-,,0,0,0,,Issate la bandiera bianca di resa!{Cora}
Dialogue: 0,0:17:05.17,0:17:09.17,Main-207-,,0,0,0,,Issatela subito, esercito reale!{Cora}
Dialogue: 0,0:17:09.17,0:17:11.55,Main-207-,,0,0,0,,Principessa Vivi! Cosa sta dicendo?
Dialogue: 0,0:17:11.55,0:17:12.68,Main-207-,,0,0,0,,"Resa"?
Dialogue: 0,0:17:12.68,0:17:16.14,Main-207-,,0,0,0,,Se lo facessimo, \Ncosa succederebbe a questo Paese?
Dialogue: 0,0:17:16.89,0:17:18.52,Main-207-,,0,0,0,,Ehi! Guarda!
Dialogue: 0,0:17:18.52,0:17:19.60,Main-207-,,0,0,0,,Quello è...!
Dialogue: 0,0:17:20.10,0:17:21.48,Main-207-,,0,0,0,,È Koza!
Dialogue: 0,0:17:21.48,0:17:24.31,Main-207-,,0,0,0,,{\q2}Perché il leader dell'armata ribelle è qui?!
Dialogue: 0,0:17:24.94,0:17:27.73,Main-207-,,0,0,0,,{Ascoltate ciò che vi dice Vivi! - "Ascoltate gli ordini di Vivi!" again come negli ep prima, mi piace rendere Vivi autoritaria nei confronti degli altri, specialmente ad Alabasta, ha senso proprio col suo personaggio -Chara}Ascoltate gli ordini di Vivi!{Cora}{iu koto non è ordini però, è "quello che dice". ordini è meirei -angy}
Dialogue: 0,0:17:27.73,0:17:31.41,Main-207-,,0,0,0,,Non desideriamo più \Nné la vittoria né lo scontro!
Dialogue: 0,0:17:31.41,0:17:34.12,Main-207-,,0,0,0,,Vogliamo fermare questa battaglia!
Dialogue: 0,0:17:34.12,0:17:36.70,Main-207-,,0,0,0,,– Eh?\N– Che significa?
Dialogue: 0,0:17:37.79,0:17:43.38,Main-207-,,0,0,0,,{\q2}Dirò io all'armata ribelle... \Nche questo scontro è privo di senso!
Dialogue: 0,0:17:44.46,0:17:48.05,Main-207-,,0,0,0,,Che non c'è più motivo di combattere!
Dialogue: 0,0:17:48.76,0:17:54.01,Main-207-,,0,0,0,,{\q2}Per non spargere altro sangue inutilmente...\N issate bandiera bianca!
Dialogue: 0,0:17:54.01,0:17:55.43,Main-207-,,0,0,0,,Vi prego!
Dialogue: 0,0:17:56.26,0:17:59.22,Main-207-,,0,0,0,,Siamo quasi arrivati alla testa del re!
Comment: 0,0:17:59.22,0:18:02.69,Main-207-,,0,0,0,,
Dialogue: 0,0:18:00.23,0:18:02.69,Main-207-,,0,0,0,,Si vede la torre dell'orologio!
Dialogue: 0,0:18:08.78,0:18:11.32,Main-207-,,0,0,0,,Arriveremo alla piazza del palazzo!
Dialogue: 0,0:18:11.82,0:18:14.28,Main-207-,,0,0,0,,Pronti a sparare!
Dialogue: 0,0:18:23.58,0:18:24.92,Main-207-,,0,0,0,,F-Fermi!
Dialogue: 0,0:18:32.55,0:18:34.05,Main-207-,,0,0,0,,Bandiere bianche...
Dialogue: 0,0:18:34.93,0:18:39.56,Main-207-,,0,0,0,,{\q2}L'esercito reale sta issando\N le bandiere bianche della resa!
Dialogue: 0,0:18:43.94,0:18:45.69,Main-207-,,0,0,0,,Signor Koza!
Dialogue: 0,0:18:45.69,0:18:48.86,Main-207-,,0,0,0,,La battaglia è finita!
Dialogue: 0,0:18:48.86,0:18:50.36,Main-207-,,0,0,0,,A tutte le truppe,
Dialogue: 0,0:18:50.36,0:18:53.32,Main-207-,,0,0,0,,placate gli animi e gettate le armi!{Cora}
Dialogue: 0,0:18:54.28,0:18:57.95,Main-207-,,0,0,0,,{\q2}L'esercito reale...\N non desidera più combattere!
Dialogue: 0,0:19:01.24,0:19:02.58,Thoughts-207-,,0,0,0,,Fermatevi...
Dialogue: 0,0:19:19.72,0:19:21.72,Main-207-,,0,0,0,,Davvero... signor Koza?
Dialogue: 0,0:19:22.10,0:19:25.10,Main-207-,,0,0,0,,Sì. Lo scontro ormai...
Dialogue: 0,0:19:41.91,0:19:47.08,Main-207-,,0,0,0,,Koza!
Dialogue: 0,0:19:51.38,0:19:53.30,Main-207-,,0,0,0,,Koza!
Dialogue: 0,0:19:54.51,0:19:59.55,Flashbacks-207-,,0,0,0,,{Z, This flashback is from Alabasta 05 @04:07}Creeremo una città fantastica\Ne arricchiremo questo Paese!
Dialogue: 0,0:20:00.30,0:20:01.43,Flashbacks-207-,,0,0,0,,Ne sono certo!
Dialogue: 0,0:20:12.27,0:20:15.36,Main-207-,,0,0,0,,N-Non... combattete!
Dialogue: 0,0:20:16.74,0:20:19.32,Main-207-,,0,0,0,,Armata ribelle...
Dialogue: 0,0:20:19.32,0:20:26.25,Main-207-,,0,0,0,,– Signor Koza!\N– Signor Koza!
Dialogue: 0,0:20:26.25,0:20:28.29,Main-207-,,0,0,0,,Come avete osato fare\N questo al signor Koza?!
Dialogue: 0,0:20:28.29,0:20:29.83,Main-207-,,0,0,0,,Fateli fuori!
Dialogue: 0,0:20:35.46,0:20:37.34,Main-207-,,0,0,0,,Baroque Works!
Dialogue: 0,0:20:45.22,0:20:48.23,Main-207-,,0,0,0,,{\q2}Maledetto! Perché hai sparato a Koza?!
Dialogue: 0,0:20:56.07,0:20:58.40,Main-207-,,0,0,0,,Armata ribelle...
Dialogue: 0,0:20:58.40,0:21:00.11,Main-207-,,0,0,0,,A-Ascoltatemi...
Comment: 0,0:21:02.12,0:21:03.12,Main-207-,,0,0,0,,{Gli inglesi mettono "What's going on". io ci sento al massimo woah! il manga riporta "nanda", ma qua io non ce lo sento proprio}
Dialogue: 0,0:21:03.83,0:21:05.49,Main-207-,,0,0,0,,Un polverone di sabbia improvviso!
Dialogue: 0,0:21:07.04,0:21:09.04,Main-207-,,0,0,0,,Armata... ribelle...!
Dialogue: 0,0:21:13.38,0:21:14.46,Main-207-,,0,0,0,,Hanno sparato!
Dialogue: 0,0:21:14.96,0:21:17.51,Main-207-,,0,0,0,,Quei bastardi...!
Dialogue: 0,0:21:24.39,0:21:26.89,Main-207-,,0,0,0,,{\q2}Da dove viene questa folata di sabbia?!
Dialogue: 0,0:21:26.89,0:21:28.35,Main-207-,,0,0,0,,Non si vede niente davanti!
Dialogue: 0,0:21:33.52,0:21:35.73,Main-207-,,0,0,0,,Maledizione! Quei bastardi!
Dialogue: 0,0:21:41.03,0:21:42.41,Main-207-,,0,0,0,,Non sparate a caso!
Dialogue: 0,0:21:42.41,0:21:43.62,Main-207-,,0,0,0,,Che sta succedendo?!
Dialogue: 0,0:21:44.24,0:21:45.99,Main-207-,,0,0,0,,{Niente di più semplice. - meh -angy}{"La risposta è semplice." decisamente più chiaro secondo me -Chara}La risposta è semplice.{Cora}{no, non è uguale imo ed è ovvio anche dalla mia dato che comunque non si ferma qui il suo discorso. dire esplicitamente "risposta" (cosa che non dice per niente) è ancora una volta trattare i viewer come dei deficienti -angy}
Dialogue: 0,0:21:46.62,0:21:51.79,Main-207-,,0,0,0,,{\q2}Noi della Baroque Works ci siamo \Ninfiltrati in entrambi gli eserciti!
Dialogue: 0,0:21:57.17,0:21:58.26,Main-207-,,0,0,0,,È terribile!{Cora}
Dialogue: 0,0:21:58.67,0:22:00.76,Main-207-,,0,0,0,,Ehi! Resisti!{Cora}
Dialogue: 0,0:22:08.10,0:22:10.35,Main-207-,,0,0,0,,Ma quale resa?!
Dialogue: 0,0:22:10.98,0:22:13.85,Main-207-,,0,0,0,,Imbrogliarci con delle bandiere \Nbianche per poi spararci...!
Dialogue: 0,0:22:14.60,0:22:17.82,Main-207-,,0,0,0,,{\q2}È questo il modo di fare dell'esercito reale?!
Dialogue: 0,0:22:18.15,0:22:20.03,Main-207-,,0,0,0,,Stanno soltanto giocando sporco!{Cora}
Dialogue: 0,0:22:25.78,0:22:28.79,Main-207-,,0,0,0,,{\fad(231,0)}Vi prego! Fermatevi tutti!
Dialogue: 0,0:22:28.79,0:22:30.00,Main-207-,,0,0,0,,Non combattete!
Dialogue: 0,0:22:30.54,0:22:33.00,Main-207-,,0,0,0,,{Accorgetevi di me!}Ascoltatemi!{Cora}{non è la stessa cosa. qui chiede escplicitamente che si accorgano che lei è lì, non di ascoltarl -angy}
Dialogue: 0,0:22:35.58,0:22:38.84,Main-207-,,0,0,0,,F-Fermatevi... armata ribelle...
Dialogue: 0,0:22:38.84,0:22:41.67,Main-207-,,0,0,0,,Questo... scontro...
Dialogue: 0,0:22:56.35,0:22:57.44,Main-207-,,0,0,0,,Va tutto bene?!
Dialogue: 0,0:22:59.27,0:23:01.86,Main-207-,,0,0,0,,Contrattaccate, esercito reale!
Dialogue: 0,0:23:34.27,0:23:35.23,Main-207-,,0,0,0,,Fermatevi...{Cora}
Dialogue: 0,0:23:35.73,0:23:37.02,Main-207-,,0,0,0,,Fermatevi...{Cora}
Dialogue: 0,0:23:39.98,0:23:40.94,Main-207-,,0,0,0,,Vi prego...
Dialogue: 0,0:23:42.36,0:23:44.19,Main-207-,,0,0,0,,Fermatevi...{Cora}
Dialogue: 0,0:23:44.95,0:23:47.82,Main-207-,,0,0,0,,Hai combattuto bene, signorina.
Dialogue: 0,0:23:48.53,0:23:49.66,Main-207-,,0,0,0,,Però...
Dialogue: 0,0:23:50.20,0:23:52.87,Main-207-,,0,0,0,,{\q2}Ormai... la tua voce non li può più raggiungere.
Dialogue: 0,0:23:55.58,0:23:57.29,Main-207-,,0,0,0,,È la fine?
Dialogue: 0,0:24:02.25,0:24:03.84,Main-207-,,0,0,0,,Scappa, Vivi!
Dialogue: 0,0:24:04.21,0:24:07.38,Main-207-,,0,0,0,,Scappa lontano... da quell'uomo!
Dialogue: 0,0:24:15.14,0:24:16.14,Main-207-,,0,0,0,,No.
Dialogue: 0,0:24:21.82,0:24:25.28,Main-207-,,0,0,0,,{\q2}Questa tempesta di sabbia... è opera tua.{Cora}
Dialogue: 0,0:24:27.57,0:24:28.57,Main-207-,,0,0,0,,Se solo...
Dialogue: 0,0:24:30.66,0:24:34.49,Main-207-,,0,0,0,,{Se solo... riuscissi a fermare\Nl'attacco nei prossimi quindici minuti... - circa... -angy}{"Se solo... riuscissi a fermare l'esplosione entro quindici minuti..." meglio? almeno si capisce cosa intende -Chara}Se solo... riuscissi a fermare \Nl'esplosione entro quindici minuti...{Cora}{è che nei prossimi implica qualcosa di più urgente imo, rispetto a entro i quindici, ma sarò io. e come dico anche dopo, kougeki è attacco, bakuhatsu è esplosione -angy}
Dialogue: 0,0:24:35.16,0:24:37.12,Main-207-,,0,0,0,,potrei diminuire il numero di vittime!
Dialogue: 0,0:24:42.46,0:24:45.21,Main-207-,,0,0,0,,"Se facessi {\i1}questo{\i0},\N l'armata ribelle si fermerà".{Cora}
Dialogue: 0,0:24:45.21,0:24:47.72,Main-207-,,0,0,0,,"Se facessi {\i1}quello{\i0}, \Nl'armata ribelle si fermerà".{Cora}
Dialogue: 0,0:24:48.17,0:24:50.80,Main-207-,,0,0,0,,Apri gli occhi, principessa.
Dialogue: 0,0:24:51.80,0:24:55.64,Main-207-,,0,0,0,,{Il tuo idealismo non è\Nnient’altro che patetico. - è la cosa più vicina che mi è venuta in mente -angy}{"Il tuo idealismo mi da' il voltastomaco." mi piace di più "patetico" ma odio la doppia negazione :( ci ho provato -Chara}Il tuo idealismo mi dà il voltastomaco.{anche qua ho scoperto che non è più prassi mettere l'apostrofo -Cora}{a me dà fa schifo, mi interessa poco che non sia la prassi dato che per anni a scuola continuavano a dirci che ci va l'apostrofo. però patetico e voltastomaco sono cose diverse -angy}
Dialogue: 0,0:24:59.10,0:25:04.73,Main-207-,,0,0,0,,{\q2}Gli ideali sono solo per coloro\N in grado di renderli realtà.
Dialogue: 0,0:25:05.53,0:25:08.61,Main-207-,,0,0,0,,Tu non ne sei in grado!
Dialogue: 0,0:25:11.82,0:25:14.03,Main-207-,,0,0,0,,{[/q2]Non mi interessa che per te sia patetica! - secondo me anche con la mia ci sta, ma se vogliamo cambiarla perchè non dice più "patetico" Crocodile possiamo mettere "Non mi interessa ciò che pensi!" che è un po' più generale ma boh -Chara}Non mi interessa ciò che pensi!{Cora}{appunto. cambiando quella sopra avete dovuto adattare questa in modo più generico e che si allontana da ciò che è detto -angy}
Dialogue: 0,0:25:15.20,0:25:17.37,Main-207-,,0,0,0,,Non abbandonerò mai i miei ideali!
Dialogue: 0,0:25:20.21,0:25:22.54,Main-207-,,0,0,0,,Tu non capirai mai...!
Dialogue: 0,0:25:23.04,0:25:25.80,Main-207-,,0,0,0,,{\q2}Io sono la principessa di questo Paese!
Dialogue: 0,0:25:25.80,0:25:27.51,Main-207-,,0,0,0,,Non mi arrenderò mai a te!
Dialogue: 0,0:25:33.01,0:25:35.47,Main-207-,,0,0,0,,Sei proprio una donna sgarbata...{Cora}
Dialogue: 0,0:25:36.68,0:25:38.68,Main-207-,,0,0,0,,Pensi che io mi arrenderò?
Dialogue: 0,0:25:39.35,0:25:40.44,Main-207-,,0,0,0,,Io...
Dialogue: 0,0:25:43.40,0:25:47.11,Main-207-,,0,0,0,,Io sono la principessa... \Ndi questo paese...!{Cora}
Dialogue: 0,0:25:53.82,0:25:54.91,Main-207-,,0,0,0,,Vivi!
Dialogue: 0,0:25:59.58,0:26:02.58,Main-207-,,0,0,0,,{Mancano ancora quindici minuti all'attacco sulla piazza. - idem con patate a prima, preferirei dicesse esplicitamente "Mancano ancora quindici minuti all'esplosione in piazza.", in quest'arco si parla fin troppo di attacchi e si rischia di non far capire un tubero HAHA -Chara}Mancano ancora quindici \Nminuti all'esplosione in piazza.{Cora}{è che è kougeki = attacco. esplosione sarebbe bakuhatsu -angy}
Dialogue: 0,0:26:03.33,0:26:08.55,Main-207-,,0,0,0,,{\q2}I rinforzi dell'armata ribelle... \Nsi riuniranno a breve qui.
Dialogue: 0,0:26:09.26,0:26:14.84,Main-207-,,0,0,0,,{\q2}Uno dopo l'altro, periranno per l'esplosione...\N senza sapere neanche cos'è successo.
Dialogue: 0,0:26:24.94,0:26:29.90,Main-207-,,0,0,0,,Se tu prima in piazza avessi detto \Ndella bomba all'esercito reale...
Dialogue: 0,0:26:29.90,0:26:31.90,Main-207-,,0,0,0,,seppur ci sarebbe stato il panico,
Dialogue: 0,0:26:31.90,0:26:36.20,Main-207-,,0,0,0,,migliaia o persino decine di migliaia \Ndi persone si sarebbero salvate.
Dialogue: 0,0:26:37.91,0:26:39.16,Main-207-,,0,0,0,,Fermati!
Dialogue: 0,0:26:39.16,0:26:41.87,Main-207-,,0,0,0,,Fermati, ti prego! Crocodile!
Dialogue: 0,0:26:45.83,0:26:50.84,Main-207-,,0,0,0,,Per colpa della tua patetica\N idea di poter salvare tutti,{Cora}
Dialogue: 0,0:26:50.84,0:26:56.76,Main-207-,,0,0,0,,alla fine hai portato tutti i tuoi \Namati cittadini verso la loro morte.
Dialogue: 0,0:27:02.35,0:27:08.19,Main-207-,,0,0,0,,{[/q2]Il popolo di questo Paese mi ha\Nsaputo davvero intrattenere... - circa}{"Mi sono proprio divertito con il popolo di questo Paese..." è molto più usato, e mi sembra anche più da Crocodile ma qua potrei fare una cappellata -Chara}Mi sono proprio divertito con \Nil popolo di questo Paese...{Cora}{non è uguale il concetto imo -angy}
Dialogue: 0,0:27:08.19,0:27:11.32,Main-207-,,0,0,0,,dall'inizio fino alla fine!
Dialogue: 0,0:27:19.74,0:27:25.33,Main-207-,,0,0,0,,{\q2}Riguardo agli ultimi due anni passati da spia \Nnella mia organizzazione... ottimo lavoro.{Cora}
Dialogue: 0,0:27:27.33,0:27:29.75,Flashbacks-207-,,0,0,0,,{AR 04 - 16:15}Sono io! Non mi riconosci?
Dialogue: 0,0:27:31.00,0:27:32.92,Flashbacks-207-,,0,0,0,,Non c'è da stupirsi!{alabasta 04 at 16:19}
Dialogue: 0,0:27:32.92,0:27:34.88,Flashbacks-207-,,0,0,0,,Sono dimagrito un po' dopotutto!{still 16:19 alabasta 04}
Dialogue: 0,0:27:36.89,0:27:40.85,Main-207-,,0,0,0,,{\q2}Alla fine, non siete riusciti \Na fare proprio niente.
Dialogue: 0,0:27:42.02,0:27:45.56,Main-207-,,0,0,0,,Fermare l'armata ribelle, \Nsalvare l'esercito reale...
Dialogue: 0,0:27:45.56,0:27:49.52,Main-207-,,0,0,0,,Trascinata solo dai tuoi ridicoli ideali...{Cora}
Dialogue: 0,0:27:49.52,0:27:52.73,Main-207-,,0,0,0,,non hai fatto altro che \Naumentare inutilmente le vittime!
Dialogue: 0,0:27:54.99,0:27:56.86,Main-207-,,0,0,0,,Lascia che ti dica una cosa.
Dialogue: 0,0:27:58.66,0:28:00.99,Main-207-,,0,0,0,,Non puoi salvare questo Paese.
Dialogue: 0,0:28:03.45,0:28:05.41,Main-207-,,0,0,0,,Addio, principessa.
Dialogue: 0,0:28:50.33,0:28:51.63,Thoughts-207-,,0,0,0,,Impossibile...
Dialogue: 0,0:28:53.04,0:28:56.80,Main-207-,,0,0,0,,Crocodile!
Dialogue: 0,0:29:00.72,0:29:02.35,Main-207-,,0,0,0,,Luffy!
Dialogue: 0,0:29:05.06,0:29:07.27,Main-207-,,0,0,0,,Cappello di Paglia?!
