Comment: 0,0:00:00.00,0:00:00.00,Main-207-,,0,0,0,,{=10}===============================DIALOGUE============================
Dialogue: 0,0:01:58.26,0:02:00.27,Main-207-,,0,0,0,,"Quest'incubo è finito"...?
Dialogue: 0,0:02:00.64,0:02:01.73,Main-207-,,0,0,0,,Ma non scherziamo!
Dialogue: 0,0:02:02.27,0:02:04.40,Main-207-,,0,0,0,,{\q2}Chiamarlo "incubo" non risolverà le cose!{Cora}
Dialogue: 0,0:02:04.85,0:02:08.57,Main-207-,,0,0,0,,{\q2}Vero! Abbiamo visto con i nostri \Nocchi l'assalto del re a Nanohana!
Dialogue: 0,0:02:08.57,0:02:12.11,Main-207-,,0,0,0,,Esatto! \NHanno anche sparato al signor Koza!
Dialogue: 0,0:02:12.11,0:02:15.91,Main-207-,,0,0,0,,Come spieghi la recente repressione \Nfatta dall'esercito reale?!{Cora}
Dialogue: 0,0:02:16.45,0:02:20.12,Main-207-,,0,0,0,,I caduti di questa ribellione come potranno mai accettare tutto questo?!
Dialogue: 0,0:02:20.12,0:02:21.95,Main-207-,,0,0,0,,Esatto, esatto! Infatti!
Dialogue: 0,0:02:23.87,0:02:26.96,Main-207-,,0,0,0,,Gettate le armi... esercito reale!
Dialogue: 0,0:02:31.71,0:02:32.97,Main-207-,,0,0,0,,Signor Chaka!
Dialogue: 0,0:02:34.88,0:02:36.39,Main-207-,,0,0,0,,Chaka...!
Dialogue: 0,0:02:37.05,0:02:39.06,Main-207-,,0,0,0,,Ehi... che succede?
Dialogue: 0,0:02:39.06,0:02:40.06,Main-207-,,0,0,0,,Anche voi...
Comment: 0,0:02:41.68,0:02:44.38,Main-207-,,0,0,0,,
Dialogue: 0,0:02:44.27,0:02:47.31,Main-207-,,0,0,0,,Anche voi, armata ribelle!
Dialogue: 0,0:02:49.61,0:02:51.53,Main-207-,,0,0,0,,S-Signor Igaram!
Dialogue: 0,0:02:51.53,0:02:53.15,Main-207-,,0,0,0,,Comandante!{Cora}
Dialogue: 0,0:03:00.49,0:03:01.95,Main-207-,,0,0,0,,Igaram...!
Dialogue: 0,0:03:07.58,0:03:09.21,Main-207-,,0,0,0,,Signor Igaram...
Dialogue: 0,0:03:12.96,0:03:16.55,Flashbacks-207-,,0,0,0,,Incontriamoci... sani e salvi in patria. {Flashback di Whisky Peak -Cora}{serve il timestamp -angy}
Dialogue: 0,0:03:19.76,0:03:23.14,Main-207-,,0,0,0,,{\q2}Ma quello è... \Nil vecchio pervertito di Whisky Peak!
Dialogue: 0,0:03:23.14,0:03:24.27,Main-207-,,0,0,0,,È sopravvissuto, eh?!
Dialogue: 0,0:03:24.27,0:03:25.60,Main-207-,,0,0,0,,...Chi?!
Dialogue: 0,0:03:28.02,0:03:29.98,Main-207-,,0,0,0,,Ehi, riesci a parlare?
Dialogue: 0,0:03:31.27,0:03:32.02,Main-207-,,0,0,0,,Sì...
Dialogue: 0,0:03:32.02,0:03:34.28,Main-207-,,0,0,0,,Quello è il bambino di Nanohana...
Dialogue: 0,0:03:34.28,0:03:36.82,Main-207-,,0,0,0,,Giusto! È il bimbo che\N l'esercito reale ha ferito!
Dialogue: 0,0:03:37.24,0:03:39.24,Main-207-,,0,0,0,,Vi sbagliate...
Dialogue: 0,0:03:39.24,0:03:42.74,Main-207-,,0,0,0,,Quelli che mi hanno ferito... \Nsono altri...
Dialogue: 0,0:03:42.74,0:03:45.12,Main-207-,,0,0,0,,Gente! Ascoltatemi! Io l'ho visto!
Dialogue: 0,0:03:47.54,0:03:50.96,Flashbacks-207-,,0,0,0,,Senza questo, non riesco proprio a stare tranquillo!{AR 08 - 10:59}
Dialogue: 0,0:03:54.59,0:03:56.01,Flashbacks-207-,,0,0,0,,Ambiguo~!{AR 08 - 11:41 (partially)}
Dialogue: 0,0:03:59.68,0:04:00.97,Main-207-,,0,0,0,,Proprio così!
Dialogue: 0,0:04:01.55,0:04:05.27,Main-207-,,0,0,0,,Questa battaglia... \Nè stata orchestrata sin dall'inizio.
Dialogue: 0,0:04:07.06,0:04:08.10,Main-207-,,0,0,0,,Signor Koza!
Dialogue: 0,0:04:08.10,0:04:09.15,Main-207-,,0,0,0,,Leader!
Dialogue: 0,0:04:10.31,0:04:13.48,Main-207-,,0,0,0,,{\q2}Lasciate che vi spieghi...{Cora}
Dialogue: 0,0:04:13.98,0:04:16.49,Main-207-,,0,0,0,,tutto ciò che è \Naccaduto a questo Paese.{Cora}
Dialogue: 0,0:04:17.49,0:04:19.45,Main-207-,,0,0,0,,Gettate tutti le armi!
Dialogue: 0,0:04:34.38,0:04:35.51,Main-207-,,0,0,0,,Principessa Vivi!
Dialogue: 0,0:04:38.26,0:04:39.55,Main-207-,,0,0,0,,Ragazzi...
Dialogue: 0,0:04:40.01,0:04:41.34,Main-207-,,0,0,0,,dove siete?
Dialogue: 0,0:04:42.09,0:04:44.72,Main-207-,,0,0,0,,Ehi! Cammina come si deve!
Dialogue: 0,0:04:45.47,0:04:49.14,Main-207-,,0,0,0,,{\q2}Ah, ascolta! Soffro della malattia \N"se cammino ancora, muoio"...{Cora}
Dialogue: 0,0:04:49.14,0:04:50.27,Main-207-,,0,0,0,,Allora sta' dove sei.
Dialogue: 0,0:04:50.27,0:04:53.61,Main-207-,,0,0,0,,Eh?! N-No! F-Fermo! E-E-Ehi!
Dialogue: 0,0:04:53.61,0:04:55.61,Main-207-,,0,0,0,,E-Ehi! Perché dal piede?!
Dialogue: 0,0:04:55.61,0:04:56.23,Main-207-,,0,0,0,,Oh?
Dialogue: 0,0:04:56.23,0:04:57.07,Main-207-,,0,0,0,,Ah, eccolo lì.
Dialogue: 0,0:05:02.03,0:05:03.16,Main-207-,,0,0,0,,Voi siete...?
Dialogue: 0,0:05:04.16,0:05:08.41,Main-207-,,0,0,0,,{\q2}Grazie... per aver portato\N quel tizio sulle spalle.
Dialogue: 0,0:05:08.41,0:05:09.66,Main-207-,,0,0,0,,È dei nostri.
Dialogue: 0,0:05:09.66,0:05:10.87,Main-207-,,0,0,0,,Lo prendiamo noi.{Cora}
Dialogue: 0,0:05:10.87,0:05:16.34,Main-207-,,0,0,0,,Quindi... siete voi i pirati che hanno accompagnato Vivi in questo Paese?{Cora}
Dialogue: 0,0:05:17.59,0:05:18.84,Main-207-,,0,0,0,,Tu chi sei, vecchio?
Dialogue: 0,0:05:18.84,0:05:19.84,Main-207-,,0,0,0,,Papà!
Dialogue: 0,0:05:20.55,0:05:21.80,Main-207-,,0,0,0,,Ragazzi!
Dialogue: 0,0:05:22.47,0:05:24.14,Main-207-,,0,0,0,,Ah, è Vivi!
Dialogue: 0,0:05:25.14,0:05:26.18,Main-207-,,0,0,0,,"Papà"?
Dialogue: 0,0:05:27.47,0:05:29.60,Main-207-,,0,0,0,,Il padre della mia dolce Vivi?!
Dialogue: 0,0:05:30.10,0:05:31.77,Main-207-,,0,0,0,,Tu sei il re?
Dialogue: 0,0:05:32.10,0:05:37.15,Main-207-,,0,0,0,,Ero pronto a morire, \Nma lui mi ha salvato.
Dialogue: 0,0:05:37.65,0:05:40.82,Main-207-,,0,0,0,,{\q2}Esausto, dopo aver \Ncombattuto contro Crocodile,
Dialogue: 0,0:05:40.82,0:05:44.37,Main-207-,,0,0,0,,{\q2}ha trasportato due persone fino in superficie.
Dialogue: 0,0:05:44.37,0:05:47.41,Main-207-,,0,0,0,,Che forza incredibile...
Dialogue: 0,0:05:47.41,0:05:51.54,Main-207-,,0,0,0,,Allora... quel "veleno" non ha più avuto effetto, giusto?
Dialogue: 0,0:05:51.54,0:05:52.62,Main-207-,,0,0,0,,Già.
Dialogue: 0,0:05:52.62,0:05:54.25,Main-207-,,0,0,0,,{Dovrebbe essere stato neutralizzato. - cps T_T}{Dovrebbe essersi neutralizzato. - Cora}{"Dovrebbe aver perso effetto." il veleno mica si neutralizza da solo HAHA -Chara}Dovrebbe aver perso effetto.{Uffa e che ne so io T.T -Cora}{fake news, si usa neutralizzato per il veleno -angy}
Dialogue: 0,0:05:54.25,0:05:57.75,Main-207-,,0,0,0,,{\q2}Però... le sue ferite devono \Nessere trattate a dovere...
Dialogue: 0,0:05:57.75,0:05:58.71,Main-207-,,0,0,0,,e anche le vostre.
Dialogue: 0,0:06:01.97,0:06:03.97,Main-207-,,0,0,0,,Piuttosto... Vivi, muoviti e va'.
Dialogue: 0,0:06:03.97,0:06:04.72,Main-207-,,0,0,0,,Eh?
Dialogue: 0,0:06:04.72,0:06:06.43,Main-207-,,0,0,0,,Torna alla piazza.
Dialogue: 0,0:06:07.56,0:06:08.64,Main-207-,,0,0,0,,Giusto!
Dialogue: 0,0:06:08.64,0:06:11.06,Main-207-,,0,0,0,,{\q2}Ora che la ribellione nel Paese si è fermata,
Dialogue: 0,0:06:11.06,0:06:14.44,Main-207-,,0,0,0,,il re o la principessa dovranno fare per forza un discorso al popolo!{Cora}
Dialogue: 0,0:06:14.94,0:06:16.81,Main-207-,,0,0,0,,Sì, quindi anche voi...
Dialogue: 0,0:06:16.81,0:06:17.94,Main-207-,,0,0,0,,Cara Vivi...
Dialogue: 0,0:06:18.52,0:06:19.78,Main-207-,,0,0,0,,Lo sai, no?
Dialogue: 0,0:06:21.69,0:06:23.78,Main-207-,,0,0,0,,Noi abbiamo una pessima reputazione.{Cora}
Dialogue: 0,0:06:24.66,0:06:27.16,Main-207-,,0,0,0,,E non vogliamo essere\N coinvolti in questioni di Stato!{Cora}
Dialogue: 0,0:06:27.53,0:06:29.54,Main-207-,,0,0,0,,Io ho tanta fame!
Dialogue: 0,0:06:29.54,0:06:32.04,Main-207-,,0,0,0,,Andate al palazzo per primi.
Dialogue: 0,0:06:32.04,0:06:33.25,Main-207-,,0,0,0,,Noi siamo esausti.
Dialogue: 0,0:06:53.52,0:06:54.31,Main-207-,,0,0,0,,Sissignore.
Dialogue: 0,0:06:54.31,0:06:56.94,Main-207-,,0,0,0,,Ricevuto, Capitano Smoker.
Dialogue: 0,0:06:57.48,0:06:59.90,Main-207-,,0,0,0,,Allora è sempre stato Crocodile...
Dialogue: 0,0:07:00.44,0:07:02.86,Main-207-,,0,0,0,,C'era lui dietro tutto questo?{Cora}
Dialogue: 0,0:07:02.86,0:07:04.20,Main-207-,,0,0,0,,È assurdo.
Dialogue: 0,0:07:04.20,0:07:05.40,Main-207-,,0,0,0,,Non posso crederci!
Dialogue: 0,0:07:05.91,0:07:07.37,Main-207-,,0,0,0,,Ehi! Guardate là!
Dialogue: 0,0:07:07.82,0:07:08.99,Main-207-,,0,0,0,,È la Marina!
Dialogue: 0,0:07:15.12,0:07:18.29,Main-207-,,0,0,0,,Pare abbiano trovato la Dance Powder della Baroque Works{Cora}
Dialogue: 0,0:07:18.29,0:07:20.92,Main-207-,,0,0,0,,a bordo di una nave che\N produce pioggia artificiale.{Cora}
Dialogue: 0,0:07:22.59,0:07:25.97,Main-207-,,0,0,0,,{Presidente dell'organizzazione segreta Baroque Works - OG}Capo dell'organizzazione segreta Baroque Works...{Cora}{shacho è presidente, capo è riduttivo in sto caso -angy}
Dialogue: 0,0:07:25.97,0:07:29.30,Main-207-,,0,0,0,,{\q2}e pirata membro dei\N Sette Corsari, Sir Crocodile...
Dialogue: 0,0:07:33.98,0:07:35.89,Flashbacks-207-,,0,0,0,,Dov'è andato... il coccodrillo?!{AR 17 - 07:23}
Dialogue: 0,0:07:39.19,0:07:40.48,Main-207-,,0,0,0,,per ordine conferitomi dal
Dialogue: 0,0:07:40.48,0:07:42.86,Main-207-,,0,0,0,,QG della Marina, \Nal servizio del Governo Mondiale...{Concordo sul timing specie la riga prima a questa -Cora}{QG perché così diminuiamo i CPS -angy}
Dialogue: 0,0:07:42.86,0:07:46.11,Main-207-,,0,0,0,,sarai privato... di tutti i tuoi titoli
Dialogue: 0,0:07:46.11,0:07:50.74,Main-207-,,0,0,0,,{\q2}e di tutti i diritti concessi dal Governo,\N tra cui l'appropriazione delle navi nemiche.
Dialogue: 0,0:08:12.85,0:08:14.10,Main-207-,,0,0,0,,Aspetta e vedrai...
Dialogue: 0,0:08:22.19,0:08:26.57,Main-207-,,0,0,0,,Noi... abbiamo compiuto azioni\Nche non possiamo cancellare.
Dialogue: 0,0:08:26.94,0:08:28.15,Main-207-,,0,0,0,,Leader...
Dialogue: 0,0:08:28.74,0:08:32.16,Main-207-,,0,0,0,,Non mi vengono parole da dir loro...{Cora}
Dialogue: 0,0:08:33.49,0:08:35.83,Main-207-,,0,0,0,,Essere frustrati è naturale...
Dialogue: 0,0:08:35.83,0:08:38.58,Main-207-,,0,0,0,,Così come lo è sentirsi impotenti.
Dialogue: 0,0:08:40.25,0:08:41.50,Main-207-,,0,0,0,,Vostra Maestà!
Dialogue: 0,0:08:41.50,0:08:42.96,Main-207-,,0,0,0,,Vostra Maestà!
Dialogue: 0,0:08:43.29,0:08:45.92,Main-207-,,0,0,0,,Molto è stato perso...
Dialogue: 0,0:08:46.26,0:08:48.38,Main-207-,,0,0,0,,e nulla è stato guadagnato!
Dialogue: 0,0:08:50.89,0:08:53.43,Main-207-,,0,0,0,,Ma... siamo comunque andati avanti!{Cora}
Dialogue: 0,0:08:53.85,0:08:56.10,Main-207-,,0,0,0,,{\q2}Indipendentemente da chi si è combattuto,
Dialogue: 0,0:08:56.10,0:08:59.44,Main-207-,,0,0,0,,{\q2}lo scontro che era iniziato ora è concluso!
Dialogue: 0,0:09:03.40,0:09:04.73,Main-207-,,0,0,0,,Vostra Maestà...
Dialogue: 0,0:09:05.61,0:09:10.03,Main-207-,,0,0,0,,Nessuno può cancellare il passato!
Dialogue: 0,0:09:13.70,0:09:17.66,Main-207-,,0,0,0,,Rialzatevi in piedi da questa \Nguerra e continuate a vivere!
Dialogue: 0,0:09:27.34,0:09:28.63,Main-207-,,0,0,0,,È ineguagliabile...
Dialogue: 0,0:09:32.59,0:09:35.81,Main-207-,,0,0,0,,Regno di Alabasta!
Dialogue: 0,0:09:38.89,0:09:42.35,Narrator-207-,,0,0,0,,E così, la battaglia che \Nrimase scolpita nella storia...
Dialogue: 0,0:09:55.57,0:09:56.95,Narrator-207-,,0,0,0,,e quella di cui...
Dialogue: 0,0:09:57.49,0:10:00.12,Narrator-207-,,0,0,0,,non venne mai raccontato nulla
Dialogue: 0,0:10:02.71,0:10:04.46,Narrator-207-,,0,0,0,,giunsero al loro termine.
Dialogue: 0,0:10:08.42,0:10:10.05,Main-207-,,0,0,0,,Smoker.{Cora}
Dialogue: 0,0:10:10.05,0:10:12.05,Main-207-,,0,0,0,,Cos'è questa pioggia?
Dialogue: 0,0:10:12.05,0:10:15.64,Main-207-,,0,0,0,,Non dirmi che hai utilizzato la Dance Powder, vero?
Dialogue: 0,0:10:16.64,0:10:17.97,Main-207-,,0,0,0,,Cretina.{Cora}
Dialogue: 0,0:10:18.89,0:10:21.52,Main-207-,,0,0,0,,{\q2}So cosa vuol dire commettere un reato.
Dialogue: 0,0:10:22.27,0:10:27.27,Main-207-,,0,0,0,,{\q2}Se persino il re di Alabasta ha difeso i suoi \Nprincipi non toccando mai questa polvere,{Cora}
Dialogue: 0,0:10:27.27,0:10:29.28,Main-207-,,0,0,0,,come potrei infrangerli {\i1}io{\i0} ora?
Dialogue: 0,0:10:30.32,0:10:31.61,Main-207-,,0,0,0,,Chiedo scusa.
Dialogue: 0,0:10:31.61,0:10:32.99,Main-207-,,0,0,0,,Hina si pente.
Dialogue: 0,0:10:34.11,0:10:38.20,Main-207-,,0,0,0,,{\q2}Dici cose piuttosto carine...\N per essere definito il "Cacciatore Bianco".{Cora}
Dialogue: 0,0:10:38.20,0:10:41.45,Main-207-,,0,0,0,,{\q2}Forse ti sei addolcito \Nun po' rispetto al passato?
Dialogue: 0,0:10:41.45,0:10:42.79,Main-207-,,0,0,0,,Non sono affari tuoi.
Dialogue: 0,0:10:43.62,0:10:45.62,Main-207-,,0,0,0,,{\q2}Comunque, non ti sembra di star esagerando?
Dialogue: 0,0:10:46.21,0:10:50.30,Main-207-,,0,0,0,,Non puoi usare le mie truppe d'élite \Nsolamente per cercare una nave!
Dialogue: 0,0:10:50.30,0:10:51.71,Main-207-,,0,0,0,,Sei piuttosto deludente.
Dialogue: 0,0:10:52.88,0:10:54.68,Main-207-,,0,0,0,,Hina è delusa.
Dialogue: 0,0:10:54.68,0:10:56.80,Main-207-,,0,0,0,,Ci siamo arruolati lo stesso anno.{Cora}
Dialogue: 0,0:10:56.80,0:10:57.93,Main-207-,,0,0,0,,Non dire così!
Dialogue: 0,0:10:57.93,0:10:59.31,Main-207-,,0,0,0,,Fai sempre così.
Dialogue: 0,0:10:59.31,0:11:01.93,Main-207-,,0,0,0,,{\q2}Ora capisco perché Tashigi fa così fatica.{Cora}
Dialogue: 0,0:11:03.89,0:11:05.02,Main-207-,,0,0,0,,Piuttosto...
Dialogue: 0,0:11:06.60,0:11:08.98,Main-207-,,0,0,0,,vedi di portar via questa nave della pioggia artificiale.{Cora}{cps}
Dialogue: 0,0:11:08.98,0:11:09.82,Main-207-,,0,0,0,,Perché io?
Dialogue: 0,0:11:10.40,0:11:11.73,Main-207-,,0,0,0,,Inoltre...
Dialogue: 0,0:11:11.73,0:11:14.03,Main-207-,,0,0,0,,Tashigi arriverà per trasportarla...
Dialogue: 0,0:11:14.03,0:11:15.78,Main-207-,,0,0,0,,insieme a Crocodile.
Dialogue: 0,0:11:15.78,0:11:17.53,Main-207-,,0,0,0,,Falla finita.
Dialogue: 0,0:11:17.53,0:11:19.66,Main-207-,,0,0,0,,{\q2}Come ti permetti di parlarmi così?
Dialogue: 0,0:11:23.91,0:11:24.79,Main-207-,,0,0,0,,Testa.
Dialogue: 0,0:11:26.83,0:11:27.83,Main-207-,,0,0,0,,È croce.
Dialogue: 0,0:11:27.83,0:11:29.92,Main-207-,,0,0,0,,Hai perso.
Dialogue: 0,0:11:31.25,0:11:33.63,Main-207-,,0,0,0,,Sei proprio un egoista.{Cora}
Dialogue: 0,0:11:33.63,0:11:36.88,Main-207-,,0,0,0,,{\q2}Non sei cambiato per niente \Ndai tempi dell'arruolamento!
Dialogue: 0,0:11:36.88,0:11:38.43,Main-207-,,0,0,0,,Hina è avvilita.{Cora}
Dialogue: 0,0:11:38.43,0:11:40.39,Main-207-,,0,0,0,,Sì, non m'importa.
Dialogue: 0,0:11:40.39,0:11:41.35,Main-207-,,0,0,0,,Lo sapevo già.
Dialogue: 0,0:11:46.60,0:11:49.06,Main-207-,,0,0,0,,Questo... è un ordine.
Dialogue: 0,0:11:49.06,0:11:50.56,Main-207-,,0,0,0,,Sergente Maggiore!{Cora}
Dialogue: 0,0:11:50.56,0:11:52.36,Main-207-,,0,0,0,,Non avremo un'altra \Nchance come questa!{Cora}{cps}
Dialogue: 0,0:11:52.69,0:11:56.07,Main-207-,,0,0,0,,Se riprendessero conoscenza, noi...
Dialogue: 0,0:11:56.07,0:11:57.57,Main-207-,,0,0,0,,Non ve lo permetterò!
Dialogue: 0,0:11:57.57,0:12:01.03,Main-207-,,0,0,0,,Non vi permetterò di mettere le mani \Nsu quella ciurma in questo momento!
Dialogue: 0,0:12:01.45,0:12:02.95,Main-207-,,0,0,0,,P-Perché?!
Dialogue: 0,0:12:02.95,0:12:06.33,Main-207-,,0,0,0,,Ora che sono tutti assieme e svenuti, \Nsono una preda facile!
Dialogue: 0,0:12:07.96,0:12:09.21,Main-207-,,0,0,0,,Leader...!
Dialogue: 0,0:12:09.21,0:12:11.34,Main-207-,,0,0,0,,Come vanno le ferite?
Dialogue: 0,0:12:12.80,0:12:14.42,Main-207-,,0,0,0,,Non morirai, vero?
Dialogue: 0,0:12:14.42,0:12:17.01,Main-207-,,0,0,0,,Sai, lo zio Toto è... Yuba è...
Dialogue: 0,0:12:17.34,0:12:18.68,Main-207-,,0,0,0,,Vivi!
Dialogue: 0,0:12:18.68,0:12:21.51,Main-207-,,0,0,0,,{\q2}A quanto pare sei rimasta ansiosa come sempre.
Dialogue: 0,0:12:21.51,0:12:22.89,Main-207-,,0,0,0,,Non ho saputo niente su Yuba,
Dialogue: 0,0:12:22.89,0:12:26.98,Main-207-,,0,0,0,,{\q2}ma qualunque cosa sia accaduta,\N so che quel vecchio testardo è duro a morire.{Cora}
Dialogue: 0,0:12:27.48,0:12:28.52,Main-207-,,0,0,0,,Leader...
Dialogue: 0,0:12:28.52,0:12:31.94,Main-207-,,0,0,0,,{\q2}In più... anche in me \Nscorre quello stesso sangue.{Kinda? -Cora}{ye, kinda}
Dialogue: 0,0:12:32.31,0:12:34.94,Main-207-,,0,0,0,,Appena mi sarò ripreso, \Nandrò subito a Yuba.
Dialogue: 0,0:12:35.32,0:12:37.19,Main-207-,,0,0,0,,Rimarremo in contatto.
Dialogue: 0,0:12:37.19,0:12:38.99,Main-207-,,0,0,0,,Non preoccuparti.
Dialogue: 0,0:12:40.70,0:12:41.45,Main-207-,,0,0,0,,Ok...
Dialogue: 0,0:12:42.91,0:12:44.95,Main-207-,,0,0,0,,Sta piovendo!
Dialogue: 0,0:12:44.95,0:12:47.83,Main-207-,,0,0,0,,Pioggia! Sta piovendo dopo tre anni!
Dialogue: 0,0:12:47.83,0:12:49.83,Main-207-,,0,0,0,,Così la ribellione finirà!
Dialogue: 0,0:12:49.83,0:12:52.04,Main-207-,,0,0,0,,{\q2}Anche i nostri sciocchi figli torneranno.
Dialogue: 0,0:12:54.04,0:12:55.63,Main-207-,,0,0,0,,È pioggia!
Dialogue: 0,0:13:10.27,0:13:13.15,Flashbacks-207-,,0,0,0,,{\q2}Per quanto tempo vuoi impuntarti, vecchio?!
Dialogue: 0,0:13:13.56,0:13:15.40,Flashbacks-207-,,0,0,0,,Ormai per Yuba è finita!
Dialogue: 0,0:13:15.40,0:13:19.07,Flashbacks-207-,,0,0,0,,{\q2}Cosa intendi fare rimanendo qui da solo?!
Dialogue: 0,0:13:19.49,0:13:21.66,Flashbacks-207-,,0,0,0,,Vuoi morire insieme a questa città?!
Dialogue: 0,0:13:21.66,0:13:23.74,Flashbacks-207-,,0,0,0,,{\3c&HFFFFFF&\4c&HFFFFFF&\t(0,516,1,\3c&H525252&\4c&H000000&)\t(1392,0,1,\3c&HFFFFFF&\4c&HFFFFFF&)}Vecchio!
Dialogue: 0,0:13:26.33,0:13:27.83,Main-207-,,0,0,0,,Guarda,
Dialogue: 0,0:13:27.83,0:13:28.54,Main-207-,,0,0,0,,Koza!
Dialogue: 0,0:13:29.54,0:13:31.21,Main-207-,,0,0,0,,Sta piovendo.
Dialogue: 0,0:13:32.79,0:13:35.71,Main-207-,,0,0,0,,Ci sono voluti solo... tre anni.
Dialogue: 0,0:13:36.30,0:13:39.21,Main-207-,,0,0,0,,Questo è tutto...
Dialogue: 0,0:13:41.84,0:13:43.26,Main-207-,,0,0,0,,Giusto,
Dialogue: 0,0:13:44.76,0:13:46.26,Main-207-,,0,0,0,,pioggia?
Dialogue: 0,0:13:50.14,0:13:53.60,Narrator-207-,,0,0,0,,La pioggia in modo naturale...{Cora}
Dialogue: 0,0:13:54.73,0:13:57.78,Narrator-207-,,0,0,0,,{\q2}continuò a cadere sul Paese senza fermarsi.
Dialogue: 0,0:14:16.50,0:14:18.17,Main-207-,,0,0,0,,Principessa Vivi.
Dialogue: 0,0:14:18.17,0:14:20.51,Main-207-,,0,0,0,,È ancora sveglia?
Dialogue: 0,0:14:20.51,0:14:21.59,Main-207-,,0,0,0,,Igaram!
Dialogue: 0,0:14:24.64,0:14:26.43,Main-207-,,0,0,0,,Non riesce a dormire?
Dialogue: 0,0:14:26.43,0:14:27.43,Main-207-,,0,0,0,,No.
Dialogue: 0,0:14:28.89,0:14:30.60,Main-207-,,0,0,0,,È solo che non voglio dormire.
Dialogue: 0,0:14:31.85,0:14:35.44,Main-207-,,0,0,0,,{\q2}Voglio stare ancora qui... \Na guardare questa pioggia.
Dialogue: 0,0:14:52.29,0:14:54.29,Main-207-,,0,0,0,,Riguardo Pell...
Dialogue: 0,0:14:55.92,0:14:57.29,Main-207-,,0,0,0,,Quell'uomo...
Dialogue: 0,0:14:57.67,0:15:01.51,Main-207-,,0,0,0,,è stato il guerriero più forte e \Nnobile che io abbia mai conosciuto.{Cora}
Dialogue: 0,0:15:02.05,0:15:02.80,Main-207-,,0,0,0,,Già.
Dialogue: 0,0:15:03.80,0:15:06.97,Main-207-,,0,0,0,,{\q2}"Ti ringrazio"... \Ngli avrei voluto dire solo questo.{Cora}
Dialogue: 0,0:15:08.51,0:15:09.47,Main-207-,,0,0,0,,Per lui...{Cora}
Dialogue: 0,0:15:10.14,0:15:12.43,Main-207-,,0,0,0,,sarebbe stato l'onore più grande.{Cora}
Dialogue: 0,0:15:22.90,0:15:24.82,Main-207-,,0,0,0,,Capitano Smoker! Signorina Hina!
Dialogue: 0,0:15:24.82,0:15:26.78,Main-207-,,0,0,0,,{\q2}Il Sergente Maggiore Tashigi è arrivata!
Dialogue: 0,0:15:27.74,0:15:29.74,Main-207-,,0,0,0,,{– Ottimo lavoro!\N– Ottimo lavoro! - ew -angy}– Congratulazioni!\N– Congratulazioni!{Cora}{non sono lo stesso concetto -angy}
Dialogue: 0,0:15:30.16,0:15:32.41,Main-207-,,0,0,0,,Da quanto tempo, eh, Tashigi?
Dialogue: 0,0:15:33.33,0:15:34.46,Main-207-,,0,0,0,,Signora Hina...
Dialogue: 0,0:15:36.25,0:15:37.46,Main-207-,,0,0,0,,Buongiorno.
Dialogue: 0,0:15:38.00,0:15:42.42,Main-207-,,0,0,0,,Io... sono un po' stanca, \Npenso che andrò a riposarmi.
Dialogue: 0,0:15:45.63,0:15:48.89,Main-207-,,0,0,0,,Capitano Smoker! Sono tornata.
Dialogue: 0,0:15:48.89,0:15:50.97,Main-207-,,0,0,0,,Sì. Ottimo lavoro.
Dialogue: 0,0:15:52.01,0:15:54.10,Main-207-,,0,0,0,,{\q2}Ho sentito dei Cappello di Paglia.
Dialogue: 0,0:15:54.89,0:15:56.23,Main-207-,,0,0,0,,Mi perdoni.{Cora}
Dialogue: 0,0:15:57.14,0:15:58.77,Main-207-,,0,0,0,,Ho collaborato con dei pirati
Dialogue: 0,0:15:58.77,0:16:01.65,Main-207-,,0,0,0,,{\q2}e non li ho catturati quando avrei potuto.
Dialogue: 0,0:16:03.15,0:16:07.40,Main-207-,,0,0,0,,Come marine... \Nè una cosa vergognosa.
Dialogue: 0,0:16:07.78,0:16:09.41,Main-207-,,0,0,0,,Perché ti scusi?
Dialogue: 0,0:16:09.41,0:16:13.16,Main-207-,,0,0,0,,Quello... non era il tuo \Nmodo di vedere la giustizia?
Dialogue: 0,0:16:14.45,0:16:16.29,Main-207-,,0,0,0,,Si sbaglia.
Dialogue: 0,0:16:17.66,0:16:18.71,Main-207-,,0,0,0,,Sergente Maggiore!
Dialogue: 0,0:16:22.88,0:16:24.51,Main-207-,,0,0,0,,Non avevo...
Dialogue: 0,0:16:25.26,0:16:26.84,Main-207-,,0,0,0,,nessun'altra scelta.{Cora}
Dialogue: 0,0:16:27.76,0:16:30.55,Flashbacks-207-,,0,0,0,,{\q2}I perdenti non possono parlare di giustizia.{AR 17 - 06:48}
Dialogue: 0,0:16:31.72,0:16:34.06,Flashbacks-207-,,0,0,0,,{Alabasta 17 - 6:51}{\q2}In questo mare le cose funzionano così.{Cora}
Dialogue: 0,0:16:37.31,0:16:39.02,Flashbacks-207-,,0,0,0,,Dov'è andato il coccodrillo?!{AR 17 - 07:23}
Dialogue: 0,0:16:40.06,0:16:41.98,Flashbacks-207-,,0,0,0,,{\t(1234,0,1,\3c&HFFFFFF&\4c&HFFFFFF&)}Dimmelo!{AR 17 - 7:27}
Dialogue: 0,0:16:43.02,0:16:44.98,Main-207-,,0,0,0,,{\q2}Anche se sapevo la posizione del nemico,
Dialogue: 0,0:16:45.73,0:16:48.03,Main-207-,,0,0,0,,non ho potuto far altro che dirglielo.
Dialogue: 0,0:16:48.95,0:16:50.99,Main-207-,,0,0,0,,Anche sapendo l'ora dell'esplosione,
Dialogue: 0,0:16:51.41,0:16:53.99,Main-207-,,0,0,0,,non sono riuscita a far altro che dar loro supporto.
Dialogue: 0,0:16:54.87,0:16:56.16,Main-207-,,0,0,0,,La mia...
Dialogue: 0,0:16:57.96,0:17:01.12,Main-207-,,0,0,0,,non è stata una scelta...\Nnon ho scelto alcuna giustizia.
Dialogue: 0,0:17:04.80,0:17:08.55,Main-207-,,0,0,0,,{\q2}Quelli che hai considerato come tuoi pari{Cora}
Dialogue: 0,0:17:08.55,0:17:12.09,Main-207-,,0,0,0,,sono diventati ancora più famigerati\N e continuano ad avanzare.{Cora}
Dialogue: 0,0:17:14.05,0:17:19.81,Main-207-,,0,0,0,,{\q2}Loro sanno bene... che se non si faranno \Nstrada in questo mare... moriranno.{Cora}
Dialogue: 0,0:17:20.94,0:17:22.69,Main-207-,,0,0,0,,Avanzare o morire?
Dialogue: 0,0:17:23.56,0:17:26.28,Main-207-,,0,0,0,,Ti ricordo che hai deciso tu\N di venire in questo mare.{Cora}
Dialogue: 0,0:17:31.74,0:17:32.95,Main-207-,,0,0,0,,Mi dispiace.
Dialogue: 0,0:17:33.53,0:17:34.45,Main-207-,,0,0,0,,Io...
Dialogue: 0,0:17:35.03,0:17:36.91,Main-207-,,0,0,0,,vado a riposarmi un po'.
Dialogue: 0,0:17:49.55,0:17:50.55,Main-207-,,0,0,0,,Idiota!
Dialogue: 0,0:17:52.30,0:17:54.64,Main-207-,,0,0,0,,Se per te è così frustrante da arrivare a piangere...
Dialogue: 0,0:17:54.64,0:17:56.64,Main-207-,,0,0,0,,devi diventare più forte!
Dialogue: 0,0:18:06.44,0:18:09.28,Main-207-,,0,0,0,,Lo farò!
Dialogue: 0,0:18:15.37,0:18:18.91,Main-207-,,0,0,0,,{\q2}Vorrei che anche voi aveste il suo fegato.
Dialogue: 0,0:18:19.45,0:18:21.83,Main-207-,,0,0,0,,Forza, portate il detenuto sulla nave!
Dialogue: 0,0:18:21.83,0:18:22.83,Main-207-,,0,0,0,,– Sissignore!\N– Sissignore!
Dialogue: 0,0:18:23.96,0:18:26.46,Main-207-,,0,0,0,,{\q2}Capitano Smoker! \NUna comunicazione dal Quartier Generale!
Dialogue: 0,0:18:27.25,0:18:29.13,Main-207-,,0,0,0,,{\q2\i1}Qui parla il Quartier Generale della Marina.
Dialogue: 0,0:18:29.13,0:18:31.47,Main-207-,,0,0,0,,{\i1}Parlo con il Capitano Smoker?
Dialogue: 0,0:18:31.47,0:18:32.59,Main-207-,,0,0,0,,Sono io.
Dialogue: 0,0:18:32.97,0:18:35.97,Main-207-,,0,0,0,,{\i1}Riguardo la sconfitta di Crocodile,
Dialogue: 0,0:18:35.97,0:18:38.97,Main-207-,,0,0,0,,{\q2\i1}gli alti ranghi del Governo desiderano donare
Dialogue: 0,0:18:38.97,0:18:41.60,Main-207-,,0,0,0,,{\q2\i1}a lei e al Sergente Maggiore \NTashigi delle medaglie.
Dialogue: 0,0:18:41.60,0:18:43.48,Main-207-,,0,0,0,,"Sconfitta"?
Dialogue: 0,0:18:43.48,0:18:45.35,Main-207-,,0,0,0,,Ehi, aspetta un secondo!
Dialogue: 0,0:18:45.35,0:18:49.11,Main-207-,,0,0,0,,{\q2}A battere Crocodile... \Nnon siamo stati mica noi.
Dialogue: 0,0:18:49.11,0:18:51.19,Main-207-,,0,0,0,,Avete ascoltato il rapporto?!
Dialogue: 0,0:18:51.19,0:18:56.37,Main-207-,,0,0,0,,{\i1}Inoltre, è stato deciso che \N salirete entrambi di rango.
Dialogue: 0,0:18:56.37,0:18:58.62,Main-207-,,0,0,0,,Ehi, ma mi stai ascoltando?!
Dialogue: 0,0:18:58.62,0:19:04.00,Main-207-,,0,0,0,,{\q2}A continuare a lottare contro \Nl'organizzazione Baroque Works di Crocodile...
Dialogue: 0,0:19:04.00,0:19:05.75,Main-207-,,0,0,0,,è stata la Ciurma di Cappello di Paglia!
Dialogue: 0,0:19:06.21,0:19:08.00,Main-207-,,0,0,0,,È inutile, Smoker.
Dialogue: 0,0:19:08.00,0:19:11.46,Main-207-,,0,0,0,,Il Governo intende sopprimere \Nla verità di quanto successo!
Dialogue: 0,0:19:12.01,0:19:15.88,Main-207-,,0,0,0,,{\q2}Pensavi davvero che avrebbero permesso di dire \nche la crisi che stava per distruggere Alabasta{tutte cps, questa e le due sotto}
Dialogue: 0,0:19:15.88,0:19:19.55,Main-207-,,0,0,0,,è stata fermata da dei pirati, mentre al Governo nessuno se n'era accorto?{Cora}
Dialogue: 0,0:19:20.31,0:19:23.73,Main-207-,,0,0,0,,{\q2\i1}A tal proposito, entrambi presenzierete\N alla consegna delle medaglie...{Cora}
Dialogue: 0,0:19:23.73,0:19:25.27,Main-207-,,0,0,0,,Non prendermi in giro!
Dialogue: 0,0:19:25.77,0:19:28.15,Main-207-,,0,0,0,,Smoker! Accetta e basta!
Dialogue: 0,0:19:28.15,0:19:30.86,Main-207-,,0,0,0,,Sai cosa succede andando contro i piani alti?!{Cora}
Dialogue: 0,0:19:30.86,0:19:33.53,Main-207-,,0,0,0,,{\q2}E quindi {\i1}noi{\i0} avremmo sconfitto Crocodile?
Dialogue: 0,0:19:34.19,0:19:37.24,Main-207-,,0,0,0,,Una mia sottoposta è in lacrime proprio perché non c'è riuscita!{Cora}{cps}
Dialogue: 0,0:19:37.61,0:19:38.91,Main-207-,,0,0,0,,Ehi, tu.
Dialogue: 0,0:19:39.49,0:19:42.99,Main-207-,,0,0,0,,{\q2}Riferisci questo ai vecchi dei piani alti.
Dialogue: 0,0:19:42.99,0:19:43.50,Main-207-,,0,0,0,,{\i1}Eh?
Dialogue: 0,0:19:43.50,0:19:44.41,Main-207-,,0,0,0,,Smoker!
Dialogue: 0,0:19:44.91,0:19:47.25,Main-207-,,0,0,0,,"Andate a fanculo"!{Cora}
Dialogue: 0,0:19:53.13,0:19:54.30,Main-207-,,0,0,0,,Oh.
Dialogue: 0,0:19:54.30,0:19:56.93,Main-207-,,0,0,0,,Che ottima preparazione!
Dialogue: 0,0:19:56.93,0:20:00.39,Main-207-,,0,0,0,,{\q2}È insolito... \Nma è davvero sensato! Splendido!
Comment: 0,0:20:00.72,0:20:01.64,Main-207-,,0,0,0,,Eh–{già commento}
Dialogue: 0,0:20:02.56,0:20:05.56,Main-207-,,0,0,0,,Dove hai appreso tali abilità mediche?
Dialogue: 0,0:20:05.56,0:20:07.98,Main-207-,,0,0,0,,Tony è un dottore di Drum.
Dialogue: 0,0:20:07.98,0:20:11.73,Main-207-,,0,0,0,,{\q2}Oh! Davvero?! \NDa Drum, la superpotenza medica?
Dialogue: 0,0:20:13.57,0:20:14.94,Main-207-,,0,0,0,,Compiono grandi progressi, eh?{Cora}
Dialogue: 0,0:20:15.44,0:20:17.70,Main-207-,,0,0,0,,{\q2}Faccio il medico da oramai quarant'anni,
Dialogue: 0,0:20:17.70,0:20:20.45,Main-207-,,0,0,0,,ma non ero al corrente \Ndell'esistenza di questa tecnica!
Dialogue: 0,0:20:21.32,0:20:23.58,Main-207-,,0,0,0,,No, davvero, straordinario!
Dialogue: 0,0:20:23.58,0:20:27.37,Main-207-,,0,0,0,,Nonostante la tua giovane età, \Nnon sono affatto al tuo livello!
Dialogue: 0,0:20:28.25,0:20:31.17,Main-207-,,0,0,0,,{\q2}Sta' un po' zitto! \NNon rimanere lì a fissarmi, maledetto~!
Dialogue: 0,0:20:31.17,0:20:33.09,Main-207-,,0,0,0,,Vattene, brutto bastardo~!
Dialogue: 0,0:20:33.09,0:20:37.72,Main-207-,,0,0,0,,{\q2}Posso interpretarlo come \N"bevi del tè e guarda pure con calma"?
Dialogue: 0,0:20:37.72,0:20:39.38,Main-207-,,0,0,0,,Penso di sì.
Dialogue: 0,0:20:39.76,0:20:42.35,Main-207-,,0,0,0,,Sai, è proprio impressionante!
Dialogue: 0,0:20:42.35,0:20:44.26,Main-207-,,0,0,0,,Sta' zitto...
Dialogue: 0,0:20:45.60,0:20:48.10,Main-207-,,0,0,0,,Posso solo dire che è straordinario.
Dialogue: 0,0:20:48.10,0:20:49.69,Main-207-,,0,0,0,,Che abilità straordinarie!{Cora}
Dialogue: 0,0:20:50.06,0:20:52.86,Main-207-,,0,0,0,,Vattene! Sta' zitto, brutto bastardo~!
Dialogue: 0,0:20:59.91,0:21:01.95,Main-207-,,0,0,0,,Ehi! C'è ancora della legna?!
Dialogue: 0,0:21:01.95,0:21:03.33,Main-207-,,0,0,0,,Anche qui non basta!
Dialogue: 0,0:21:03.33,0:21:05.45,Main-207-,,0,0,0,,Qui ne è rimasta un po', usala pure.
Dialogue: 0,0:21:05.45,0:21:06.91,Main-207-,,0,0,0,,Oh, grazie!
Dialogue: 0,0:21:06.91,0:21:08.54,Main-207-,,0,0,0,,Questo Paese è proprio forte, eh?
Dialogue: 0,0:21:08.54,0:21:10.67,Main-207-,,0,0,0,,Questo perché la principessa è carina!
Dialogue: 0,0:21:10.67,0:21:11.54,Main-207-,,0,0,0,,Cosa c'entra?
Dialogue: 0,0:21:11.54,0:21:12.17,Main-207-,,0,0,0,,C'entra eccome!
Dialogue: 0,0:21:12.17,0:21:13.13,Main-207-,,0,0,0,,Maledizione!
Dialogue: 0,0:21:13.46,0:21:15.17,Main-207-,,0,0,0,,{\q2}Hanno trapassato tutte le case!{Cora}
Dialogue: 0,0:21:15.17,0:21:16.34,Main-207-,,0,0,0,,Cos'è 'sto buco?!{angy}
Dialogue: 0,0:21:16.34,0:21:18.55,Main-207-,,0,0,0,,È come se fossero state frantumate a calci!{angy}
Dialogue: 0,0:21:18.55,0:21:19.80,Main-207-,,0,0,0,,Wow! Terribile!
Dialogue: 0,0:21:19.80,0:21:21.13,Main-207-,,0,0,0,,Ah, Usopp! Guarda!
Dialogue: 0,0:21:21.13,0:21:22.89,Main-207-,,0,0,0,,Di là c'è una cosa!
Dialogue: 0,0:21:22.89,0:21:24.01,Main-207-,,0,0,0,,Eh?
Dialogue: 0,0:21:28.06,0:21:29.85,Thoughts-207-,,0,0,0,,Concentrati di più...
Dialogue: 0,0:21:30.85,0:21:34.02,Thoughts-207-,,0,0,0,,Devo riuscire a tirare fuori \Nquella forza in ogni momento...
Dialogue: 0,0:21:34.02,0:21:36.57,Thoughts-207-,,0,0,0,,{\q2}altrimenti non riuscirò a diventare più forte!
Dialogue: 0,0:21:36.98,0:21:39.15,Main-207-,,0,0,0,,Eeh... Quanti libri interessanti!
Dialogue: 0,0:21:39.49,0:21:41.11,Main-207-,,0,0,0,,Posso prenderli davvero?
Dialogue: 0,0:21:41.11,0:21:42.41,Main-207-,,0,0,0,,Sì, certo.
Dialogue: 0,0:21:42.41,0:21:44.12,Main-207-,,0,0,0,,Dopotutto li ho già letti tutti.
Dialogue: 0,0:21:44.45,0:21:45.74,Main-207-,,0,0,0,,Grazie mille!
Dialogue: 0,0:21:45.74,0:21:48.33,Main-207-,,0,0,0,,Allora li prendo tutti!{Cora}
Dialogue: 0,0:21:48.83,0:21:51.50,Main-207-,,0,0,0,,Ho detto che non lo so, \Nnon mi avete sentito?! Andatevene!
Dialogue: 0,0:21:51.92,0:21:54.13,Main-207-,,0,0,0,,Mentire non aiuterà questo Paese!
Dialogue: 0,0:21:54.13,0:21:55.88,Main-207-,,0,0,0,,Nascondere dei pirati è un crimine!
Dialogue: 0,0:21:55.88,0:21:56.88,Main-207-,,0,0,0,,– Yo!\N– Yo! Ottimo lavoro!
Dialogue: 0,0:21:56.88,0:21:58.00,Main-207-,,0,0,0,,Grazie! Bentornati!
Dialogue: 0,0:21:58.34,0:22:01.63,Main-207-,,0,0,0,,{\q2\an8}Considerando com'è messa la città, \nqueste provviste bastano no?{Cora}
Dialogue: 0,0:22:01.63,0:22:02.47,Main-207-,,0,0,0,,{\an8}Ma sì.
Dialogue: 0,0:21:59.76,0:22:02.47,Main-207-,,0,0,0,,{\q2}Avete prove che qui ci sono dei pirati?!
Dialogue: 0,0:22:02.47,0:22:04.43,Main-207-,,0,0,0,,N-No, ecco...
Dialogue: 0,0:22:04.80,0:22:06.35,Main-207-,,0,0,0,,Chissà se si è svegliato.
Dialogue: 0,0:22:06.35,0:22:06.39,Main-207-,,0,0,0,,{\pos(776,1053)}Chissà se si è svegliato.
Dialogue: 0,0:22:06.39,0:22:06.43,Main-207-,,0,0,0,,{\pos(925,1053)}Chissà se si è svegliato.
Dialogue: 0,0:22:06.43,0:22:06.47,Main-207-,,0,0,0,,{\pos(1142,1053)}Chissà se si è svegliato.
Dialogue: 0,0:22:06.47,0:22:06.51,Main-207-,,0,0,0,,{\pos(1399,1053)}Chissà se si è svegliato.
Dialogue: 0,0:22:06.51,0:22:06.56,Main-207-,,0,0,0,,{\pos(1668,1053)}Chissà se si è svegliato.
Dialogue: 0,0:22:06.47,0:22:06.51,Main-207-,,0,0,0,,{\pos(-228,1053)}Se si è svegliato, \Nlo capiremo sicuramente dal casino.
Dialogue: 0,0:22:06.51,0:22:06.56,Main-207-,,0,0,0,,{\pos(40,1053)}Se si è svegliato, \Nlo capiremo sicuramente dal casino.
Dialogue: 0,0:22:06.56,0:22:06.60,Main-207-,,0,0,0,,{\pos(297,1053)}Se si è svegliato, \Nlo capiremo sicuramente dal casino.
Dialogue: 0,0:22:06.60,0:22:06.64,Main-207-,,0,0,0,,{\pos(512,1053)}Se si è svegliato, \Nlo capiremo sicuramente dal casino.
Dialogue: 0,0:22:06.64,0:22:06.68,Main-207-,,0,0,0,,{\pos(662,1053)}Se si è svegliato, \Nlo capiremo sicuramente dal casino.
Dialogue: 0,0:22:06.68,0:22:09.39,Main-207-,,0,0,0,,Se si è svegliato, \Nlo capiremo sicuramente dal casino.
Dialogue: 0,0:22:09.39,0:22:10.93,Main-207-,,0,0,0,,Ehi...!
Dialogue: 0,0:22:10.93,0:22:13.02,Main-207-,,0,0,0,,Che bella dormita!
Dialogue: 0,0:22:15.15,0:22:16.69,Main-207-,,0,0,0,,Eh? Il mio cappello?
Dialogue: 0,0:22:16.69,0:22:18.65,Main-207-,,0,0,0,,Il cappello! Il mio cappello dov'è?!
Dialogue: 0,0:22:18.65,0:22:20.65,Main-207-,,0,0,0,,Che fame~! Colazione!
Dialogue: 0,0:22:20.65,0:22:23.15,Main-207-,,0,0,0,,Ehi, colazione! E il cappello? \NColazione! E il cappello?!
Dialogue: 0,0:22:23.53,0:22:26.03,Main-207-,,0,0,0,,{\q2}Sei proprio rumoroso appena ti svegli!
Dialogue: 0,0:22:26.03,0:22:28.91,Main-207-,,0,0,0,,In più, non è ora di colazione. È sera!
Dialogue: 0,0:22:28.91,0:22:30.79,Main-207-,,0,0,0,,Se cerchi il cappello, è lì.
Dialogue: 0,0:22:30.79,0:22:33.12,Main-207-,,0,0,0,,{\q2}Un soldato l'ha trovato davanti al palazzo.
Dialogue: 0,0:22:33.79,0:22:35.04,Main-207-,,0,0,0,,Oh, che fortuna~!
Dialogue: 0,0:22:35.04,0:22:37.42,Main-207-,,0,0,0,,Sono contenta tu stia bene, Luffy!
Dialogue: 0,0:22:37.42,0:22:40.01,Main-207-,,0,0,0,,"Bene"? Ma sono sempre stato bene!
Dialogue: 0,0:22:40.01,0:22:43.13,Main-207-,,0,0,0,,{\q2}Che scemo che sei... \NTra la febbre e altro, è stata piuttosto dura.
Dialogue: 0,0:22:43.13,0:22:46.26,Main-207-,,0,0,0,,Vivi e Chopper si sono presi \Ncura di te per tutto il tempo!
Dialogue: 0,0:22:46.26,0:22:48.22,Main-207-,,0,0,0,,Davvero? Grazie!
Dialogue: 0,0:22:49.01,0:22:50.64,Main-207-,,0,0,0,,Oh, Luffy! Ti sei svegliato?
Dialogue: 0,0:22:50.64,0:22:52.77,Main-207-,,0,0,0,,Ooh, Zoro! Da quanto tempo!
Dialogue: 0,0:22:52.77,0:22:53.98,Main-207-,,0,0,0,,"Da quanto tempo"?
Dialogue: 0,0:22:53.98,0:22:56.69,Main-207-,,0,0,0,,Ah, tu...! \NTi stavi allenando di nuovo, vero?!
Dialogue: 0,0:22:56.69,0:22:58.32,Main-207-,,0,0,0,,E quindi? Sono affari miei, no?
Dialogue: 0,0:22:58.32,0:23:01.57,Main-207-,,0,0,0,,{\q2}Se dico no è no! Sono il medico di bordo!\N E non devi toglierti le bende!
Dialogue: 0,0:23:01.57,0:23:03.15,Main-207-,,0,0,0,,Ma è difficile muoversi con quelle...
Dialogue: 0,0:23:03.15,0:23:04.82,Main-207-,,0,0,0,,Non devi muoverti infatti!{Cora}
Dialogue: 0,0:23:04.82,0:23:06.82,Main-207-,,0,0,0,,"Da quanto tempo"?
Dialogue: 0,0:23:06.82,0:23:08.03,Main-207-,,0,0,0,,"Da quanto tempo"?
Dialogue: 0,0:23:08.03,0:23:11.79,Main-207-,,0,0,0,,Beh, dopo aver dormito tre giorni, \Nè normale tu ti senta così!
Dialogue: 0,0:23:11.79,0:23:14.04,Main-207-,,0,0,0,,Tre giorni? Ho dormito per tre giorni?!
Dialogue: 0,0:23:14.04,0:23:14.79,Main-207-,,0,0,0,,Ah!
Dialogue: 0,0:23:17.38,0:23:19.00,Main-207-,,0,0,0,,Ho perso quindici pasti!
Dialogue: 0,0:23:19.00,0:23:21.05,Main-207-,,0,0,0,,{\q2}Però per calcolare quello fai subito, vero?!{Cora}
Dialogue: 0,0:23:21.05,0:23:23.01,Main-207-,,0,0,0,,{\q2}E ha pure contato cinque pasti per giorno!
Dialogue: 0,0:23:24.09,0:23:25.72,Main-207-,,0,0,0,,Il capitano si è svegliato?
Dialogue: 0,0:23:26.09,0:23:28.80,Main-207-,,0,0,0,,È quasi ora di cena, \N potresti pazientare un altro po'?
Dialogue: 0,0:23:28.80,0:23:29.39,Main-207-,,0,0,0,,Ah!
Dialogue: 0,0:23:29.39,0:23:31.64,Main-207-,,0,0,0,,{\q2}{\fs70\an8}Nota: "Chikuwa" è un anello di bambù dalla \Nforma tubolare tipico della cucina giapponese.
Dialogue: 0,0:23:29.39,0:23:31.64,Main-207-,,0,0,0,,Oh! Quindi sei vivo, vecchio chikuwa?
Dialogue: 0,0:23:31.64,0:23:33.98,Main-207-,,0,0,0,,T-Tu...! \NHai davvero questo tipo di hobby?!
Dialogue: 0,0:23:33.98,0:23:35.52,Main-207-,,0,0,0,,Vi sbagliate, ragazzi.
Dialogue: 0,0:23:35.52,0:23:37.10,Main-207-,,0,0,0,,Lei è la signora Terracotta.
Dialogue: 0,0:23:37.10,0:23:39.98,Main-207-,,0,0,0,,È la moglie di Igaram ed è \Nla responsabile di sala del palazzo.
Dialogue: 0,0:23:39.98,0:23:41.98,Main-207-,,0,0,0,,Avete aiutato la principessa \NVivi e mio marito, eh?{Cora}
Dialogue: 0,0:23:41.98,0:23:45.32,Main-207-,,0,0,0,,{\q2}Non scherziamo...\N Una coppia non può essere così simile!{Cora}
Dialogue: 0,0:23:45.32,0:23:47.32,Main-207-,,0,0,0,,Ho sentito dire che mangi molto!
Dialogue: 0,0:23:47.32,0:23:51.28,Main-207-,,0,0,0,,{\q2}Ti va un po' di frutta per arrivare fino a cena?
Dialogue: 0,0:23:50.66,0:23:51.28,Main-207-,,0,0,0,,Certo!
Dialogue: 0,0:23:51.87,0:23:53.16,Main-207-,,0,0,0,,– Cos'è?! Un trucco di magia?!\N– Cos'è?! Un trucco di magia?!
Dialogue: 0,0:23:53.54,0:23:55.33,Main-207-,,0,0,0,,{[/q2]Vecchia! Mangerò la quantità di tre giorni! - ew -angy}{\q2}Ehi vecchietta! Devo recuperare quei tre giorni!{Cora}{cps abbastanza grave}
Dialogue: 0,0:23:55.33,0:23:57.92,Main-207-,,0,0,0,,Questo volevo sentire! \NFaccio questo lavoro da trent'anni,
Dialogue: 0,0:23:57.92,0:24:01.59,Main-207-,,0,0,0,,non perderò contro la pancia\Ndi un ragazzino! Mangia quanto vuoi!{Cora}
Dialogue: 0,0:24:07.26,0:24:09.30,Main-207-,,0,0,0,,Neanche un briciolo d'educazione...
Dialogue: 0,0:24:09.30,0:24:13.52,Main-207-,,0,0,0,,{\q2}I pasti in questa sala dovrebbero\N essere decisamente più tranquilli!
Dialogue: 0,0:24:15.23,0:24:17.19,Main-207-,,0,0,0,,{\q2\fad(186,0)}Faceva davvero sul serio! Ma non perderò!
Dialogue: 0,0:24:17.94,0:24:19.65,Main-207-,,0,0,0,,Se non mangio in fretta, sparirà...!
Dialogue: 0,0:24:21.27,0:24:23.11,Main-207-,,0,0,0,,{\q2}Ehi, Luffy!\NMi hai rubato del cibo, vero?!{Cora}
Dialogue: 0,0:24:24.11,0:24:25.07,Main-207-,,0,0,0,,Non sputarlo!
Dialogue: 0,0:24:25.57,0:24:27.74,Main-207-,,0,0,0,,Ehi, ehi! Se mangi così in fretta...
Dialogue: 0,0:24:27.74,0:24:29.16,Main-207-,,0,0,0,,Fai pure, ce n'è ancora molto.{Cora}
Dialogue: 0,0:24:29.28,0:24:32.87,Main-207-,,0,0,0,,{\q2w}Ora vedrai, maledetto Luffy!\NMetto sempre da parte una stella tabasco!
Dialogue: 0,0:24:36.75,0:24:38.37,Main-207-,,0,0,0,,Tu...! Ma da quando...?!
Dialogue: 0,0:24:39.67,0:24:40.88,Main-207-,,0,0,0,,Come si chiama quel piatto?
Dialogue: 0,0:24:40.88,0:24:43.59,Main-207-,,0,0,0,,{\q2}Si chiama {\i1}konafa{\i0}. \NIn pratica si mette la pasta in forno–{angy}
Dialogue: 0,0:24:44.21,0:24:45.55,Main-207-,,0,0,0,,Che buono!
Dialogue: 0,0:24:45.55,0:24:47.72,Main-207-,,0,0,0,,Ecco i prossimi!
Dialogue: 0,0:24:48.09,0:24:50.97,Main-207-,,0,0,0,,Ah, memmio, ma mu mei il mre, eh?\N(Ah, vecchio, ma tu sei il re, eh?){Cora}{no. il manga si può permettere queste parentesi di spiegazione, i sub assolutamente no -angy}
Dialogue: 0,0:24:50.97,0:24:54.10,Main-207-,,0,0,0,,Quinmi mei il mamà di Bibi?\N(Quindi sei il papà di Vivi?){Bellissima trovata quella di Bibi XD -Cora}{again, no parentesi di spiegazione -angy}
Dialogue: 0,0:24:54.10,0:24:56.27,Main-207-,,0,0,0,,{\q2}O-Oh, possiamo parlare dopo mangiato.{Cora}
Dialogue: 0,0:24:56.27,0:24:57.10,Main-207-,,0,0,0,,Sci, musdo.\N(Sì, giusto.){Cora}{again, stessa cosa delle parentesi -angy}
Dialogue: 0,0:24:58.64,0:25:00.52,Main-207-,,0,0,0,,{\fad(101,226)}Potete riempirlo ancora?!
Dialogue: 0,0:25:00.60,0:25:02.11,Main-207-,,0,0,0,,{\fad(101,0)}Ah! Qui serve dell'acqua!
Dialogue: 0,0:25:03.36,0:25:05.48,Main-207-,,0,0,0,,Che razza di pasto chiassoso...
Dialogue: 0,0:25:05.48,0:25:07.44,Main-207-,,0,0,0,,Non riesco a guardare... \NSono troppo volgari!
Dialogue: 0,0:25:11.28,0:25:14.24,Main-207-,,0,0,0,,Come fa la principessa Vivi a trovarlo divertente?
Dialogue: 0,0:25:42.94,0:25:45.11,Main-207-,,0,0,0,,L'ampio bagno comune è\N l'orgoglio del nostro palazzo!
Dialogue: 0,0:25:45.11,0:25:47.61,Main-207-,,0,0,0,,Inizialmente, veniva usato solo nella stagione delle piogge.{Cora}{cps}
Dialogue: 0,0:25:46.78,0:25:47.61,Main-207-,,0,0,0,,{\an8}Che figo!
Dialogue: 0,0:25:47.61,0:25:48.99,Main-207-,,0,0,0,,Bellissimo! Bellissimo!
Dialogue: 0,0:25:48.99,0:25:51.11,Main-207-,,0,0,0,,Sarò io il primo!
Dialogue: 0,0:25:49.94,0:25:51.11,Secondary-207-,,0,0,0,,No, sarò io!
Dialogue: 0,0:25:52.11,0:25:53.41,Main-207-,,0,0,0,,Vi divertite così?!
Dialogue: 0,0:25:53.41,0:25:56.49,Main-207-,,0,0,0,,{\q2}Beh, la cena è stata davvero divertente.
Dialogue: 0,0:25:56.49,0:25:59.50,Main-207-,,0,0,0,,Visto il momento, avevo intenzione \Ndi rimanere composto, ma...
Dialogue: 0,0:25:59.50,0:26:03.37,Main-207-,,0,0,0,,{\q2}stando con voi, \Ntutto sembra diventare una festa.
Dialogue: 0,0:26:03.75,0:26:06.46,Main-207-,,0,0,0,,Ehi, Zoro, guarda!\N Ci alleniamo anche noi!
Dialogue: 0,0:26:06.46,0:26:07.38,Main-207-,,0,0,0,,Allenamento! Allenamento!
Dialogue: 0,0:26:07.38,0:26:08.34,Main-207-,,0,0,0,,Per cosa?!
Dialogue: 0,0:26:09.01,0:26:10.97,Main-207-,,0,0,0,,Quindi? Dov'è il bagno delle donne?
Dialogue: 0,0:26:10.97,0:26:12.84,Main-207-,,0,0,0,,Ma sei scemo! Come se te lo dicessi!
Dialogue: 0,0:26:12.84,0:26:14.34,Main-207-,,0,0,0,,C'è anche la principessa Vivi!
Dialogue: 0,0:26:14.34,0:26:16.30,Main-207-,,0,0,0,,Non fare il guastafeste, dai!
Dialogue: 0,0:26:16.30,0:26:17.89,Main-207-,,0,0,0,,È oltre quel muro!
Dialogue: 0,0:26:17.89,0:26:19.43,Main-207-,,0,0,0,,Vostra Maestà, maledetto!
Dialogue: 0,0:26:19.43,0:26:21.48,Main-207-,,0,0,0,,Oh! Non ti tiri indietro, eh, vecchio?!
Dialogue: 0,0:26:22.35,0:26:23.56,Main-207-,,0,0,0,,Come si sta bene!
Dialogue: 0,0:26:24.10,0:26:26.73,Main-207-,,0,0,0,,Chissà se c'è una nave \Ncon un bagno così grande...
Dialogue: 0,0:26:26.73,0:26:29.69,Main-207-,,0,0,0,,{\q2}Ci sarà sicuramente! Il mare è grande dopotutto!
Dialogue: 0,0:26:30.19,0:26:31.69,Main-207-,,0,0,0,,Ci sono i giganti!
Dialogue: 0,0:26:31.69,0:26:33.07,Main-207-,,0,0,0,,E anche i dinosauri!
Dialogue: 0,0:26:33.07,0:26:35.82,Main-207-,,0,0,0,,{\q2}E in un Paese invernale sono fioriti i ciliegi!
Dialogue: 0,0:26:35.82,0:26:40.16,Main-207-,,0,0,0,,Ci sono sicuramente altre cose\N inimmaginabili lungo i mari!
Dialogue: 0,0:26:43.58,0:26:44.87,Main-207-,,0,0,0,,Ecco...
Dialogue: 0,0:26:44.12,0:26:44.87,Secondary-207-,,0,0,0,,Cambio!
Dialogue: 0,0:26:46.13,0:26:47.29,Main-207-,,0,0,0,,Grazie.
Dialogue: 0,0:26:47.29,0:26:48.59,Main-207-,,0,0,0,,Eh?
Dialogue: 0,0:26:48.59,0:26:50.76,Main-207-,,0,0,0,,Ehi, ragazzi! Che state facendo?!
Dialogue: 0,0:26:51.09,0:26:52.72,Main-207-,,0,0,0,,Che tipi...
Dialogue: 0,0:26:54.30,0:26:57.22,Main-207-,,0,0,0,,{\q2}Ascoltate. Fanno diecimila berry a testa!
Dialogue: 0,0:26:58.01,0:26:58.68,Main-207-,,0,0,0,,Eh?
Dialogue: 0,0:26:58.68,0:27:01.10,Main-207-,,0,0,0,,{\fad(150,150)}Happiness Punch!
Dialogue: 0,0:27:01.10,0:27:02.10,Main-207-,,0,0,0,,Nami!
Dialogue: 0,0:27:08.52,0:27:10.02,Main-207-,,0,0,0,,Sei indecisa, vero?
Dialogue: 0,0:27:10.98,0:27:14.86,Main-207-,,0,0,0,,{\q2}Noi... stavamo pensando \Ndi andarcene stanotte.
Dialogue: 0,0:27:14.86,0:27:15.66,Main-207-,,0,0,0,,Davvero?
Dialogue: 0,0:27:15.66,0:27:18.28,Main-207-,,0,0,0,,{\q2}Dopotutto non c'è più motivo di restare, no?
Dialogue: 0,0:27:18.28,0:27:20.91,Main-207-,,0,0,0,,E al porto probabilmente c'è la Marina.
Dialogue: 0,0:27:20.91,0:27:22.62,Main-207-,,0,0,0,,La nave sarà in pericolo.
Dialogue: 0,0:27:25.71,0:27:26.54,Main-207-,,0,0,0,,Vi ringrazio.
Dialogue: 0,0:27:27.04,0:27:28.08,Main-207-,,0,0,0,,– Vecchio pervertito.\N– Vecchio pervertito.
Dialogue: 0,0:27:28.08,0:27:29.88,Main-207-,,0,0,0,,Non per quello!
Dialogue: 0,0:27:32.01,0:27:33.51,Main-207-,,0,0,0,,Ma per il Paese.
Dialogue: 0,0:27:40.85,0:27:45.02,Main-207-,,0,0,0,,Ehi, ehi, sicuro vada bene \Nper un re fare una cosa simile?
Dialogue: 0,0:27:45.02,0:27:47.60,Main-207-,,0,0,0,,È una cosa seria, Re Cobra.
Dialogue: 0,0:27:47.60,0:27:50.23,Main-207-,,0,0,0,,Il re non dovrebbe abbassare\Nla testa davanti a nessuno.{Cora}
Dialogue: 0,0:27:50.73,0:27:52.61,Main-207-,,0,0,0,,Igaram.
Dialogue: 0,0:27:52.61,0:27:56.03,Main-207-,,0,0,0,,L'autorità non ha a che fare\Ncoi vestiti che s'indossano.{Cora}
Dialogue: 0,0:27:56.45,0:27:58.62,Main-207-,,0,0,0,,Tuttavia... questo è un bagno.
Dialogue: 0,0:27:58.62,0:28:01.33,Main-207-,,0,0,0,,Non esistono re nudi.
Dialogue: 0,0:28:01.33,0:28:06.16,Main-207-,,0,0,0,,{\q2}Non solo in quanto padre... \Nma anche come cittadino di questo Paese,{EH 02 - 15:57}
Dialogue: 0,0:28:06.16,0:28:09.00,Main-207-,,0,0,0,,{\q2}ci tengo davvero a ringraziarvi di cuore.
Dialogue: 0,0:28:13.25,0:28:14.84,Main-207-,,0,0,0,,Grazie mille.
Dialogue: 0,0:28:15.47,0:28:18.30,Main-207-,,0,0,0,,Grazie... davvero!
Dialogue: 0,0:28:24.52,0:28:25.89,Main-207-,,0,0,0,,Stanotte?!
Dialogue: 0,0:28:25.89,0:28:26.85,Main-207-,,0,0,0,,Sì.
Dialogue: 0,0:28:26.85,0:28:28.52,Main-207-,,0,0,0,,C'è ne andiamo da qui?
Dialogue: 0,0:28:28.52,0:28:31.40,Main-207-,,0,0,0,,Beh, anch'io penso sia ragionevole.
Dialogue: 0,0:28:31.40,0:28:33.69,Main-207-,,0,0,0,,{\q2}Non abbiamo motivo di rimanere a lungo.
Dialogue: 0,0:28:33.69,0:28:36.24,Main-207-,,0,0,0,,Giusto. Inoltre, mi preoccupano \Ni movimenti della Marina.
Dialogue: 0,0:28:36.24,0:28:38.07,Main-207-,,0,0,0,,Bene! Luffy! Decidi tu!
Dialogue: 0,0:28:38.07,0:28:40.24,Main-207-,,0,0,0,,Bene! Partiremo da Alabasta dopo aver mangiato di nu–{Cora}{cps}
Dialogue: 0,0:28:40.24,0:28:41.70,Main-207-,,0,0,0,,Andiamo {\i1}adesso{\i0}, brutto idiota!
Dialogue: 0,0:28:41.70,0:28:43.20,Main-207-,,0,0,0,,– Scemo!\N– Ma perché...
Dialogue: 0,0:28:43.58,0:28:45.08,Main-207-,,0,0,0,,Che facciamo, signor Igaram?
Dialogue: 0,0:28:45.08,0:28:46.91,Main-207-,,0,0,0,,Dobbiamo dirglielo subito...
Dialogue: 0,0:28:46.91,0:28:48.50,Main-207-,,0,0,0,,Sì, ovviamente!
Dialogue: 0,0:28:48.50,0:28:49.87,Main-207-,,0,0,0,,Però...
Dialogue: 0,0:28:49.87,0:28:51.88,Main-207-,,0,0,0,,{\q2}La situazione sta diventando seria!
Dialogue: 0,0:28:52.34,0:28:55.00,Main-207-,,0,0,0,,Spero riescano a lasciare \Nl'isola sani e salvi, ma...
Dialogue: 0,0:28:55.00,0:28:56.84,Main-207-,,0,0,0,,Che rapidità!
Dialogue: 0,0:28:58.30,0:29:01.39,Main-207-,,0,0,0,,{\q2}Roronoa Zoro, taglia da sessantamila berry.
Dialogue: 0,0:29:02.51,0:29:05.93,Main-207-,,0,0,0,,{\q2}Monkey D. Luffy, taglia da centomila berry.
Dialogue: 0,0:29:06.52,0:29:07.56,Main-207-,,0,0,0,,Signor Igaram...
Dialogue: 0,0:29:07.56,0:29:08.85,Main-207-,,0,0,0,,Con questi importi,
Dialogue: 0,0:29:08.85,0:29:12.40,Main-207-,,0,0,0,,inizieranno a muoversi anche gli alti ranghi della Marina.{Cora}
Dialogue: 0,0:29:12.77,0:29:15.40,Main-207-,,0,0,0,,Non puoi più tornare indietro, Luffy.
Dialogue: 0,0:29:16.03,0:29:19.53,Main-207-,,0,0,0,,{\q2}Dopotutto, avete abbattuto\N uno dei Sette Corsari!
Comment: 0,0:00:00.00,0:00:00.00,Main-207-,,0,0,0,,{=11}===============================DIALOGUE============================
