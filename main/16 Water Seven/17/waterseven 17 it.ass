Comment: 0,0:00:00.00,0:00:00.00,Main-207+,,0,0,0,,{=10}===============================DIALOGUE============================
Dialogue: 0,0:01:56.60,0:01:58.47,Main-207+,,0,0,0,,L'uscita è vicina.
Dialogue: 0,0:01:58.47,0:02:00.89,Main-207+,,0,0,0,,Andremo giù diretti!{l'idea è quella}
Dialogue: 0,0:02:00.89,0:02:01.89,Main-207+,,0,0,0,,Eh, non ci credo–!
Dialogue: 0,0:02:01.89,0:02:02.64,Main-207+,,0,0,0,,Eh–!
Dialogue: 0,0:02:02.64,0:02:05.27,Main-207+,,0,0,0,,Eh! Eeh!{again, io non capisco quando gli inglesi lasciano 'ste cose}
Dialogue: 0,0:02:24.25,0:02:27.09,Main-207+,,0,0,0,,Bene! Il treno marino sta arrivando!{direbbe che "è uscito"}
Dialogue: 0,0:02:27.09,0:02:30.34,Main-207+,,0,0,0,,Uomini! Anche noi pronti all'azione!
Dialogue: 0,0:02:30.34,0:02:33.01,Main-207+,,0,0,0,,– Sì!\N– Sì!
Dialogue: 0,0:02:33.01,0:02:35.84,Main-207+,,0,0,0,,Saltate, Sodoma, Gomorra!{G - personaggi}
Dialogue: 0,0:02:37.30,0:02:38.51,Main-207+,,0,0,0,,C-Cos'è?!
Dialogue: 0,0:02:41.35,0:02:44.48,Main-207+,,0,0,0,,{\an8}Signor Cappello di Paglia!
Dialogue: 0,0:02:44.48,0:02:48.06,Main-207+,,0,0,0,,{\an8}Tutta la Famiglia Franky
Dialogue: 0,0:02:48.52,0:02:52.07,Main-207+,,0,0,0,,{\q\an8}sarà al tuo servizio!{ew e non proprio, ma è la cosa più vicina che potesse aver senso}
Dialogue: 0,0:02:52.07,0:02:54.15,Main-207+,,0,0,0,,{\an8}Cannoni connessi! Sparate!{ew}
Dialogue: 0,0:03:04.54,0:03:07.00,Main-207+,,0,0,0,,Woah! Che figata!
Dialogue: 0,0:03:07.38,0:03:10.84,Main-207+,,0,0,0,,Quelli sono dei king bull di grado più alto, eh?
Dialogue: 0,0:03:10.84,0:03:12.88,Main-207+,,0,0,0,,Ben fatto!
Dialogue: 0,0:03:15.05,0:03:18.22,Main-207+,,0,0,0,,Maledizione... Brutti bastardi!
Dialogue: 0,0:03:18.22,0:03:20.10,Main-207+,,0,0,0,,Maledetti! Non esagerate!
Dialogue: 0,0:03:20.10,0:03:22.56,Main-207+,,0,0,0,,– Sarà un piacere!\N– Sarà un piacere!{un po' un proseguo di quello che gli dicono prima}
Dialogue: 0,0:03:24.85,0:03:27.23,Main-207+,,0,0,0,,Ci ha trascinato piuttosto lontano...{la corrente intende, ma non lo dice}
Dialogue: 0,0:03:27.69,0:03:31.36,Main-207+,,0,0,0,,Però... io ho seguito il treno \Nmarino sin da suo sviluppo!
Dialogue: 0,0:03:31.36,0:03:33.53,Main-207+,,0,0,0,,Non sottovalutarmi!
Dialogue: 0,0:03:37.91,0:03:38.82,Main-207+,,0,0,0,,Li vedo!
Dialogue: 0,0:03:38.82,0:03:40.16,Main-207+,,0,0,0,,Andiamo!
Dialogue: 0,0:03:43.87,0:03:46.37,Main-207+,,0,0,0,,{\i1}Annuncio d'emergenza dalla cabina di guida.
Comment: 0,0:03:46.37,0:03:48.12,Main-207+,,0,0,0,,{\i1}
Comment: 0,0:03:48.12,0:03:50.46,Main-207+,,0,0,0,,{\i1}
Dialogue: 0,0:03:46.37,0:03:50.46,Main-207+,,0,0,0,,{\i1}Stiamo per afferrare i binari, \Nperciò la velocità aumenterà rapidamente!{le frasi prima commentate sono solo queste spezzate a metà}
Dialogue: 0,0:03:50.46,0:03:54.46,Main-207+,,0,0,0,,{\i1}Cavatevela con dei semplici graffi! \NAggrappatevi bene!
Dialogue: 0,0:03:54.46,0:03:56.84,Main-207+,,0,0,0,,Quindi sicuramente ci faremo male...
Dialogue: 0,0:04:06.23,0:04:07.35,Main-207+,,0,0,0,,Eei!{non è "ehi", è solo un suono che io manco metterei}
Dialogue: 0,0:04:07.35,0:04:08.52,Main-207+,,0,0,0,,Stammi a sentire!{parla al treno}
Dialogue: 0,0:04:08.52,0:04:10.61,Main-207+,,0,0,0,,Nonna! C'eri quasi, c'eri quasi!
Dialogue: 0,0:04:10.61,0:04:12.37,Main-207+,,0,0,0,,Un po' più a destra!
Comment: 0,0:04:12.37,0:04:12.90,Main-207+,,0,0,0,,
Dialogue: 0,0:04:14.69,0:04:15.74,Main-207+,,0,0,0,,Sta' a guardare!
Dialogue: 0,0:04:15.74,0:04:17.36,Main-207+,,0,0,0,,La prossima volta ce la fa–
Dialogue: 0,0:04:17.36,0:04:18.07,Main-207+,,0,0,0,,Eh?!
Dialogue: 0,0:04:18.07,0:04:20.53,Main-207+,,0,0,0,,Chimney! Gonbe!
Dialogue: 0,0:04:21.78,0:04:24.29,Main-207+,,0,0,0,,Voi due, siete venuti con noi?!{ewwwww}
Dialogue: 0,0:04:25.41,0:04:26.95,Main-207+,,0,0,0,,Sì, siamo venuti!
Comment: 0,0:04:26.95,0:04:28.50,Main-207+,,0,0,0,,
Dialogue: 0,0:04:29.96,0:04:31.63,Main-207+,,0,0,0,,Che disastro!
Dialogue: 0,0:04:31.63,0:04:33.25,Main-207+,,0,0,0,,Veloci, entrate dentro!
Dialogue: 0,0:04:33.88,0:04:35.80,Main-207+,,0,0,0,,Sarete sbalzati via!
Dialogue: 0,0:04:36.38,0:04:37.97,Main-207+,,0,0,0,,Staremo bene, staremo bene!
Dialogue: 0,0:04:40.72,0:04:41.89,Main-207+,,0,0,0,,Chimney!
Dialogue: 0,0:04:44.14,0:04:45.35,Main-207+,,0,0,0,,Cado!
Dialogue: 0,0:04:45.35,0:04:48.23,Main-207+,,0,0,0,,N-Non lasciare la presa!
Dialogue: 0,0:04:48.23,0:04:51.00,Main-207+,,0,0,0,,Verrò sbalzata via!
Comment: 0,0:04:51.00,0:04:51.50,Main-207+,,0,0,0,,
Dialogue: 0,0:04:51.94,0:04:53.52,Main-207+,,0,0,0,,A-Aspetta un attimo!
Dialogue: 0,0:04:53.52,0:04:55.19,Main-207+,,0,0,0,,Fermerò il treno!{non direbbe treno, direbbe tipo "ora mi fermo", ma non in io per forza, ovviamente intende il treno}
Dialogue: 0,0:05:01.41,0:05:02.66,Main-207+,,0,0,0,,Ah giusto!
Dialogue: 0,0:05:02.66,0:05:05.91,Main-207+,,0,0,0,,I freni di 'sto coso non funzionano!{circa}
Comment: 0,0:05:07.83,0:05:09.41,Main-207+,,0,0,0,,
Dialogue: 0,0:05:09.41,0:05:11.83,Main-207+,,0,0,0,,Che succede? Sembri divertirti!
Dialogue: 0,0:05:12.83,0:05:14.71,Main-207+,,0,0,0,,È il fratellone dal cappello di paglia!
Dialogue: 0,0:05:14.71,0:05:15.90,Main-207+,,0,0,0,,Ehi!
Comment: 0,0:05:15.90,0:05:16.75,Main-207+,,0,0,0,,
Dialogue: 0,0:05:16.75,0:05:19.67,Main-207+,,0,0,0,,Cappello di Paglia! Veloce, salva Chimney!{e gli altri [aka gonbe]. non arriverebbe a dire il verbo, ma è chiaro da contesto}
Dialogue: 0,0:05:20.05,0:05:23.72,Main-207+,,0,0,0,,Se salissimo sui binari in queste condizioni, \Nverrà sbalzata via!
Dialogue: 0,0:05:24.18,0:05:24.89,Main-207+,,0,0,0,,Ok!
Dialogue: 0,0:06:02.26,0:06:03.84,Main-207+,,0,0,0,,– Pensavo fosse la fine!\N– Pensavo fosse la fine!{di suo è "pensavo sarei morto/a -angy}
Dialogue: 0,0:06:04.34,0:06:06.68,Main-207+,,0,0,0,,Mi pare ovvio, accidenti!
Dialogue: 0,0:06:06.68,0:06:07.85,Main-207+,,0,0,0,,Ve l'avevo detto, no?
Dialogue: 0,0:06:07.85,0:06:09.68,Main-207+,,0,0,0,,Che sareste stati sbalzati via!
Dialogue: 0,0:06:09.68,0:06:10.81,Main-207+,,0,0,0,,Ahi, ahi, ahi...
Dialogue: 0,0:06:10.81,0:06:13.94,Main-207+,,0,0,0,,Comunque che velocità assurda!{nel senso che è velocissimo}
Dialogue: 0,0:06:13.94,0:06:14.77,Main-207+,,0,0,0,,Esatto.{yay al mattaku che vuol dire mille cose se si vuole}
Dialogue: 0,0:06:14.77,0:06:16.90,Main-207+,,0,0,0,,Bene, bene, che spavento che ho preso!
Dialogue: 0,0:06:16.90,0:06:18.90,Main-207+,,0,0,0,,Ho sbattuto la schiena...
Dialogue: 0,0:06:19.40,0:06:20.69,Main-207+,,0,0,0,,Aspettate un attimo...
Dialogue: 0,0:06:20.69,0:06:23.11,Main-207+,,0,0,0,,Ci sono tizi strani in questo vagone.
Dialogue: 0,0:06:23.45,0:06:24.95,Main-207+,,0,0,0,,– Cosa?! E chi sarebbero?!\N– Cosa?! E chi sarebbero?!
Dialogue: 0,0:06:24.95,0:06:26.24,Main-207+,,0,0,0,,Intende voi!
Dialogue: 0,0:06:26.24,0:06:27.58,Main-207+,,0,0,0,,Vale anche per te, no?!
Dialogue: 0,0:06:30.29,0:06:33.75,Main-207+,,0,0,0,,Non importa come ci provassi, \Nnon sono riuscito a fermarvi.
Dialogue: 0,0:06:34.12,0:06:37.25,Main-207+,,0,0,0,,I nemici da cui desiderate così tanto \Nriprendervi la vostra compagna{cps}
Dialogue: 0,0:06:37.25,0:06:41.51,Main-207+,,0,0,0,,per me sono i colpevoli che hanno \Nattentato alla vita del signor Iceburg.
Dialogue: 0,0:06:41.84,0:06:45.18,Main-207+,,0,0,0,,{\q2}Senza contare che ho un sacco di cose da dirgli!
Dialogue: 0,0:06:46.43,0:06:49.06,Main-207+,,0,0,0,,Paulie! Non ti lascerò battermi sul tempo!{onestamente non capisco bene cosa intenda}
Dialogue: 0,0:06:49.06,0:06:53.43,Main-207+,,0,0,0,,{\q2}Abbiamo pensato che standoti alle calcagna, \Navremmo potuto vendicare il signor Iceburg{direbbe tipo che avrebbero incontrato i nemici di iceburg (stando ai kanji), ma "teki" (aka nemico) lo legge come "kataki" (aka vendetta), perciò l'ho messa così}
Dialogue: 0,0:06:53.43,0:06:55.73,Main-207+,,0,0,0,,e così ci siamo nascosti insieme \Nnel vagone del carbone!{cps}
Dialogue: 0,0:06:55.73,0:06:58.40,Main-207+,,0,0,0,,Come previsto, sembra che avessimo ragione.
Dialogue: 0,0:06:58.77,0:07:01.69,Main-207+,,0,0,0,,Ci uniremo anche noi a questo combattimento.
Dialogue: 0,0:07:02.03,0:07:04.15,Main-207+,,0,0,0,,Quei nemici ovviamente...{usa il kanji "teki", ma dice "kataki", vedi sopra}
Dialogue: 0,0:07:04.15,0:07:06.74,Main-207+,,0,0,0,,{\q2}sono gli stessi che hanno rapito il fratello Franky!
Dialogue: 0,0:07:06.74,0:07:10.95,Main-207+,,0,0,0,,{\q2}Esattamente! Sappiamo benissimo di chi si tratti!
Dialogue: 0,0:07:10.95,0:07:14.75,Main-207+,,0,0,0,,{\q2}Sentite, Galley-La! Qualsiasi cosa al fratello Franky, \Ndovreste assumervi le vostre responsabilità!{cps gravissimo}
Dialogue: 0,0:07:14.75,0:07:15.75,Main-207+,,0,0,0,,State zitte!
Dialogue: 0,0:07:15.75,0:07:18.13,Main-207+,,0,0,0,,{\q2}Il signor Iceburg è quello che ha sofferto di più!
Dialogue: 0,0:07:18.75,0:07:20.75,Main-207+,,0,0,0,,Ma di che state parlando?!
Dialogue: 0,0:07:20.75,0:07:23.76,Main-207+,,0,0,0,,Paulie! Per prima cosa, spiegaci! \NCosa sta succedendo?!
Dialogue: 0,0:07:23.76,0:07:25.47,Main-207+,,0,0,0,,Infatti, Paulie.
Dialogue: 0,0:07:25.47,0:07:28.34,Main-207+,,0,0,0,,Tu sai chi è il vero colpevole, no?
Dialogue: 0,0:07:28.34,0:07:30.35,Main-207+,,0,0,0,,Sputa il rospo!{perché "dillo con la tua bocca" è bruttissimo}
Dialogue: 0,0:07:30.35,0:07:32.64,Main-207+,,0,0,0,,Non siamo così ottusi.
Dialogue: 0,0:07:32.64,0:07:34.27,Main-207+,,0,0,0,,Ci siamo fatti un'idea più o meno.
Dialogue: 0,0:07:34.60,0:07:36.69,Main-207+,,0,0,0,,Non ci sorprenderemo.
Dialogue: 0,0:07:37.90,0:07:42.15,Main-207+,,0,0,0,,Beh... Dato che sono spariti all'improvviso\N senza motivo, è naturale capirlo.{non mi veniva meglio di così}
Dialogue: 0,0:07:42.15,0:07:44.49,Main-207+,,0,0,0,,Allora ve lo dirò chiaro e tondo.
Dialogue: 0,0:07:44.49,0:07:47.91,Main-207+,,0,0,0,,Le identità dei tizi con le maschere sono...
Dialogue: 0,0:07:47.91,0:07:52.79,Main-207+,,0,0,0,,Lucci, Kaku, Kalifa... e Blueno del pub!
Dialogue: 0,0:07:53.29,0:07:57.25,Main-207+,,0,0,0,,Loro hanno attentato alla vita \Ndel signor Iceburg.{hanno provato ad uccidere il signor iceburg}
Dialogue: 0,0:07:59.13,0:08:00.96,Main-207+,,0,0,0,,Ma non l'avevate immaginato?!
Dialogue: 0,0:08:00.96,0:08:03.67,Main-207+,,0,0,0,,{W7 15 - 07:49 (solo una reference, non vero flashback)\q2}M-Ma avevi detto che erano tornati al loro paese!
Dialogue: 0,0:08:03.67,0:08:05.09,Main-207+,,0,0,0,,{\q2}Come se lo facessero in un momento così critico!{oddio, quei cps T_T}
Dialogue: 0,0:08:05.09,0:08:08.18,Main-207+,,0,0,0,,Pensavamo fossero stati Micheal e\N Hoicheal dei sobborghi...{nel glossario inglese manco ci sono, G - personaggi}
Dialogue: 0,0:08:08.18,0:08:08.93,Main-207+,,0,0,0,,Esatto, esatto!
Dialogue: 0,0:08:08.93,0:08:09.84,Main-207+,,0,0,0,,Ma chi sarebbero?!
Dialogue: 0,0:08:09.84,0:08:12.43,Main-207+,,0,0,0,,E-Eh?! Non li conosci?!
Dialogue: 0,0:08:12.43,0:08:14.02,Main-207+,,0,0,0,,Sono famosi nei sobborghi!
Dialogue: 0,0:08:14.02,0:08:15.06,Main-207+,,0,0,0,,Esatto, esatto!
Dialogue: 0,0:08:15.06,0:08:17.06,Main-207+,,0,0,0,,Ma chi li conosce! In ogni caso, voi due–!
Dialogue: 0,0:08:17.06,0:08:17.94,Main-207+,,0,0,0,,Bene!
Dialogue: 0,0:08:17.94,0:08:19.94,Main-207+,,0,0,0,,Aah, che mangiata, che mangiata!{ho mangiato sarebbe}
Dialogue: 0,0:08:19.94,0:08:21.86,Main-207+,,0,0,0,,Finalmente ho la pancia piena!
Dialogue: 0,0:08:24.40,0:08:25.94,Main-207+,,0,0,0,,Bene, allora...
Dialogue: 0,0:08:26.78,0:08:30.11,Main-207+,,0,0,0,,Sia con la Famiglia Franky che \Ncon i carpentieri della Galley-La...
Dialogue: 0,0:08:30.53,0:08:35.29,Main-207+,,0,0,0,,ci hanno causato guai in città, ma da qui \Nin avanti abbiamo tutti gli stessi nemici.
Dialogue: 0,0:08:35.79,0:08:40.23,Main-207+,,0,0,0,,Tra quelli che dovremo combattere, \Nil più forte è di sicuro il tizio con il piccione!{G - personaggi}
Dialogue: 0,0:08:40.23,0:08:43.00,Main-207+,,0,0,0,,{EL23 @ 08:59}Di sicuro quello lo gonfierò di botte io!
Dialogue: 0,0:08:43.00,0:08:44.63,Main-207+,,0,0,0,,Hai ragione.
Dialogue: 0,0:08:44.63,0:08:48.38,Main-207+,,0,0,0,,Questo combattimento sarà per riprendere \Nciò che quei quattro ci hanno rubato.{cps}
Dialogue: 0,0:08:48.38,0:08:52.60,Main-207+,,0,0,0,,Ma comunque, se non li raggiungiamo, \Nnon potremo fare nulla.
Dialogue: 0,0:08:53.85,0:08:57.21,Main-207+,,0,0,0,,Nonna, nonna! C'è l'Aqua Laguna!
Comment: 0,0:08:57.21,0:08:57.85,Main-207+,,0,0,0,,
Dialogue: 0,0:08:57.85,0:09:00.19,Main-207+,,0,0,0,,Oh! È già arrivata?
Dialogue: 0,0:09:00.19,0:09:01.56,Main-207+,,0,0,0,,Chimney, fammi vedere un po'!
Dialogue: 0,0:09:06.78,0:09:07.74,Main-207+,,0,0,0,,Oh no!
Dialogue: 0,0:09:08.28,0:09:11.20,Main-207+,,0,0,0,,Signora Kokoro! Puoi davvero allontanarti \Ndalla guida in un momento come questo?!{cps}
Dialogue: 0,0:09:11.20,0:09:13.53,Main-207+,,0,0,0,,Bisogna superare quell'onda alta...
Dialogue: 0,0:09:14.41,0:09:15.41,Main-207+,,0,0,0,,Te l'ho detto, no?
Dialogue: 0,0:09:15.41,0:09:17.87,Main-207+,,0,0,0,,Il Rocketman è fuori controllo.
Dialogue: 0,0:09:17.87,0:09:21.75,Main-207+,,0,0,0,,Anche se guidassi, i freni non funzionano.
Dialogue: 0,0:09:22.12,0:09:25.38,Main-207+,,0,0,0,,Il mio lavoro era quello di \Nportare il treno sui binari.
Dialogue: 0,0:09:25.96,0:09:28.76,Main-207+,,0,0,0,,Pertanto, ora il treno è alla massima potenza.{dice "full throttle" }
Dialogue: 0,0:09:29.26,0:09:31.63,Main-207+,,0,0,0,,Nessuno può più fermarlo!
Dialogue: 0,0:09:31.63,0:09:32.76,Main-207+,,0,0,0,,Non ci credo...
Dialogue: 0,0:09:32.76,0:09:33.64,Main-207+,,0,0,0,,Luffy!
Comment: 0,0:09:33.97,0:09:35.76,Main-207+,,0,0,0,,
Comment: 0,0:09:35.76,0:09:37.39,Main-207+,,0,0,0,,
Dialogue: 0,0:09:33.97,0:09:37.39,Main-207+,,0,0,0,,Di questo passo, il treno verrà travolto– \NEhi, Luffy!
Dialogue: 0,0:09:41.23,0:09:43.85,Main-207+,,0,0,0,,Dato che andiamo tutti dalla stessa parte,{forse "siamo" è più adatto, ma vi lascio il più lett}
Dialogue: 0,0:09:43.85,0:09:46.52,Main-207+,,0,0,0,,sarebbe inutile combattere separati.
Dialogue: 0,0:09:46.52,0:09:47.82,Main-207+,,0,0,0,,Già!
Dialogue: 0,0:09:47.82,0:09:49.19,Main-207+,,0,0,0,,Giusto.
Dialogue: 0,0:09:51.20,0:09:53.66,Main-207+,,0,0,0,,Sentite. Siamo alleati!
Dialogue: 0,0:09:54.12,0:09:55.62,Main-207+,,0,0,0,,Sul treno marino partito prima
Dialogue: 0,0:09:56.16,0:09:58.16,Main-207+,,0,0,0,,c'è anche un nostro compagno!{suppongo intenda Sanji data la frase dopo}
Dialogue: 0,0:09:58.16,0:10:00.62,Main-207+,,0,0,0,,La nostra potenza combattiva aumenterà!
Dialogue: 0,0:10:03.67,0:10:04.92,Main-207+,,0,0,0,,Uomini!
Dialogue: 0,0:10:04.92,0:10:07.38,Main-207+,,0,0,0,,Non fatevi battere dall'enorme onda!
Dialogue: 0,0:10:07.38,0:10:10.05,Main-207+,,0,0,0,,Raggiungeremo tutti il nostro obiettivo!
Dialogue: 0,0:10:10.42,0:10:11.55,Main-207+,,0,0,0,,Andiamo!
Dialogue: 0,0:10:11.55,0:10:14.84,Main-207+,,0,0,0,,– Sì!\N– Sì!
Dialogue: 0,0:10:17.14,0:10:18.26,Main-207+,,0,0,0,,Forza, ragazzi!
Dialogue: 0,0:10:18.26,0:10:20.68,Main-207+,,0,0,0,,Fate qualcosa per quest'onda!
Dialogue: 0,0:10:20.68,0:10:24.27,Main-207+,,0,0,0,,Bene! Per ora, spariamo tutti \Ni cannoni che abbiamo verso l'onda!
Dialogue: 0,0:10:24.27,0:10:27.23,Main-207+,,0,0,0,,{\q2}Woah! Se si tratta di cannoni, lascia fare a me!
Dialogue: 0,0:10:27.57,0:10:30.15,Main-207+,,0,0,0,,Famiglia Franky! Non temete le onde!
Dialogue: 0,0:10:30.48,0:10:31.86,Main-207+,,0,0,0,,Preparete i cannoni!
Dialogue: 0,0:10:31.86,0:10:33.07,Main-207+,,0,0,0,,– Ricevuto!\N– Ricevuto!{solo perché cos'era? whisky peak? mi ricordo che hai detto di far così @cora -angy}
Dialogue: 0,0:10:34.70,0:10:36.37,Main-207+,,0,0,0,,Non perdete tempo!
Dialogue: 0,0:10:36.37,0:10:38.37,Main-207+,,0,0,0,,– Sì!\N– Sì!
Dialogue: 0,0:10:49.63,0:10:51.26,Main-207+,,0,0,0,,Il lumacofono cucciolo sta suonando!{cps}
Dialogue: 0,0:11:07.40,0:11:09.11,Main-207+,,0,0,0,,Ehi, tu!
Dialogue: 0,0:11:09.11,0:11:11.23,Main-207+,,0,0,0,,Mi dica, Capitano T Bone!
Dialogue: 0,0:11:11.57,0:11:13.61,Main-207+,,0,0,0,,Cos'è quella ferita sul braccio?
Dialogue: 0,0:11:15.11,0:11:15.95,Main-207+,,0,0,0,,Aah...
Dialogue: 0,0:11:15.95,0:11:19.95,Main-207+,,0,0,0,,Q-Questa è una puntura d'insetto che \Nmi sono grattato ed è uscito sangue...
Dialogue: 0,0:11:19.95,0:11:22.41,Main-207+,,0,0,0,,Oh no! Dobbiamo subito fermare il sangue!
Dialogue: 0,0:11:24.75,0:11:26.37,Main-207+,,0,0,0,,Per ora, ci accontenteremo di questo.
Dialogue: 0,0:11:26.37,0:11:28.88,Main-207+,,0,0,0,,N-No, il suo importante mantello!
Dialogue: 0,0:11:30.59,0:11:31.96,Main-207+,,0,0,0,,Così va bene.
Dialogue: 0,0:11:31.96,0:11:36.68,Main-207+,,0,0,0,,Quando un subordinato sta sanguinato \Na far male è il mio cuore.{l'ho lasciata nell'ordine in cui è}
Dialogue: 0,0:11:37.72,0:11:39.05,Main-207+,,0,0,0,,Capitano T Bone...
Dialogue: 0,0:11:40.39,0:11:46.89,Main-207+,,0,0,0,,{\an8}Che anche oggi ci sia la pace e \Nche il mondo sia un posto gentile.
Dialogue: 0,0:11:50.02,0:11:52.40,Thoughts-207+,,0,0,0,,– Il suo viso è super spaventoso...\N– Il suo viso è super spaventoso...
Dialogue: 0,0:11:53.03,0:11:53.94,Main-207+,,0,0,0,,Capitano!
Dialogue: 0,0:11:53.94,0:11:55.32,Main-207+,,0,0,0,,Cosa?!
Dialogue: 0,0:11:56.45,0:11:59.49,Main-207+,,0,0,0,,N-Non ho ancora detto nulla...
Dialogue: 0,0:11:59.82,0:12:04.87,Main-207+,,0,0,0,,Se potessi fare qualcosa, \Nanche al costo di perdere questa mia vita...
Dialogue: 0,0:12:06.58,0:12:08.04,Main-207+,,0,0,0,,Ah, no...
Dialogue: 0,0:12:08.58,0:12:11.84,Main-207+,,0,0,0,,I funzionari del sesto e del settimo \Nvagone sono stati abbattuti!{non sapevo che altro verbo usare...}
Dialogue: 0,0:12:11.84,0:12:17.17,Main-207+,,0,0,0,,{\t(5146,0,1,\c&H000000&\3c&H000000&\4c&H000000&)}Inoltre... i detenuti in \Ncustodia cautelare sono scomparsi!
Dialogue: 0,0:12:17.34,0:12:18.55,Main-207+,,0,0,0,,Che hai detto?!
Dialogue: 0,0:12:19.68,0:12:23.56,Main-207+,,0,0,0,,Non sappiamo nemmeno se ci sia un intruso \No se i detenuti sono riusciti a fuggire da soli.
Dialogue: 0,0:12:23.56,0:12:24.93,Main-207+,,0,0,0,,È inaudito!{ew}
Comment: 0,0:12:24.93,0:12:27.81,Main-207+,,0,0,0,,
Comment: 0,0:12:27.81,0:12:29.56,Main-207+,,0,0,0,,
Dialogue: 0,0:12:24.93,0:12:29.56,Main-207+,,0,0,0,,Interveniamo subito per salvare delle vite! \NE segnalate la situazione a tutti i vagoni!
Dialogue: 0,0:12:29.56,0:12:30.52,Main-207+,,0,0,0,,Sì!
Dialogue: 0,0:12:32.02,0:12:33.15,Main-207+,,0,0,0,,Cara Nami!
Dialogue: 0,0:12:33.15,0:12:34.28,Main-207+,,0,0,0,,Cara Nami, mi senti?
Dialogue: 0,0:12:34.28,0:12:36.11,Main-207+,,0,0,0,,{\i1}Ah, sei Sanji, giusto?
Dialogue: 0,0:12:36.53,0:12:40.36,Main-207+,,0,0,0,,Qui la situazione... è peggiorata.
Dialogue: 0,0:12:40.36,0:12:41.95,Main-207+,,0,0,0,,{\i1}"Peggiorata"?
Dialogue: 0,0:12:42.87,0:12:45.33,Main-207+,,0,0,0,,{\i1}Sanji! Cos'era quella voce?!
Dialogue: 0,0:12:45.33,0:12:47.33,Main-207+,,0,0,0,,{\i1}Ehi, cos'è successo?! Sanji!
Dialogue: 0,0:12:47.33,0:12:48.79,Secondary-207+,,0,0,0,,{\an8}Ehi, ehi!
Dialogue: 0,0:12:50.29,0:12:52.46,Main-207+,,0,0,0,,Niente, è colpa di un cretino.
Dialogue: 0,0:12:52.46,0:12:54.00,Main-207+,,0,0,0,,{\i1}U-Un cretino?!
Dialogue: 0,0:12:54.96,0:12:57.09,Main-207+,,0,0,0,,{\i1}Wah! Di nuovo! Che cos'è?!
Dialogue: 0,0:12:57.09,0:12:58.34,Main-207+,,0,0,0,,{\i1}Cosa sta succedendo?!
Dialogue: 0,0:12:58.34,0:13:00.05,Main-207+,,0,0,0,,{\i1}Ehi, va tutto bene, Sanji?!
Dialogue: 0,0:13:00.05,0:13:01.64,Main-207+,,0,0,0,,{\i1}Chi sarebbe il cretino?!
Dialogue: 0,0:12:56.46,0:12:58.34,Secondary-207+,,0,0,0,,{\an8}Va tutto bene? Ehi!
Dialogue: 0,0:12:58.34,0:13:00.05,Secondary-207+,,0,0,0,,{\an8}Scherzetto~!
Dialogue: 0,0:13:00.05,0:13:01.64,Secondary-207+,,0,0,0,,{\an8}Potresti morire!{circa}
Dialogue: 0,0:13:01.64,0:13:03.93,Main-207+,,0,0,0,,No... Sono solo {\i1}due{\i0} cretini.
Dialogue: 0,0:13:07.35,0:13:09.56,Main-207+,,0,0,0,,{\fad(150,150)}Demi Cannon!{G - abilità [famiglia franky]}
Dialogue: 0,0:13:14.40,0:13:15.65,Main-207+,,0,0,0,,– Prendi questo!\N– Prendi questo!
Dialogue: 0,0:13:17.86,0:13:19.82,Main-207+,,0,0,0,,Non si è aperto nemmeno un buco.
Dialogue: 0,0:13:19.82,0:13:21.20,Main-207+,,0,0,0,,Ovviamente...
Dialogue: 0,0:13:21.20,0:13:23.28,Main-207+,,0,0,0,,No, no! Così non basta!
Dialogue: 0,0:13:23.82,0:13:25.41,Main-207+,,0,0,0,,Ragazzi, fatevi indietro!
Dialogue: 0,0:13:25.41,0:13:28.70,Main-207+,,0,0,0,,Lasciate fare al cannone speciale \Ndella Famiglia Franky!
Dialogue: 0,0:13:30.16,0:13:32.67,Main-207+,,0,0,0,,Obiettivo: Aqua Laguna!
Dialogue: 0,0:13:33.29,0:13:34.00,Main-207+,,0,0,0,,Sparate!
Dialogue: 0,0:13:34.00,0:13:36.46,Main-207+,,0,0,0,,{\fad(150,150)}Cannone Super Scrap!{G - abilità [famiglia franky]}
Dialogue: 0,0:13:41.43,0:13:42.97,Main-207+,,0,0,0,,Maledizione!
Dialogue: 0,0:13:42.97,0:13:44.30,Main-207+,,0,0,0,,Non temete!
Dialogue: 0,0:13:44.30,0:13:46.31,Main-207+,,0,0,0,,Continuate a sparare!
Dialogue: 0,0:13:52.56,0:13:54.23,Secondary-207+,,0,0,0,,{\c&H000000&\3c&H000000&\4c&H000000&\t(19,816,1,\c&HFFFFFF&\3c&H000000&\4c&H000000&)}Ricaricate le palle di cannone!
Dialogue: 0,0:13:54.23,0:13:54.90,Secondary-207+,,0,0,0,,Capito!
Dialogue: 0,0:13:54.90,0:13:57.44,Secondary-207+,,0,0,0,,Puntate al centro! \NConcentratevi in un unico punto!
Dialogue: 0,0:13:57.44,0:14:00.44,Main-207+,,0,0,0,,Forza! Ora dei pew pew!{....ew}
Dialogue: 0,0:14:01.28,0:14:02.24,Main-207+,,0,0,0,,Mettetecela tutta.
Dialogue: 0,0:14:02.61,0:14:07.87,Main-207+,,0,0,0,,I binari si sollevano leggermente, \Nma non possono superare l'Aqua Laguna.
Dialogue: 0,0:14:07.87,0:14:12.12,Main-207+,,0,0,0,,Con un colpo diretto, nemmeno questo \NRocketman sarà in grado di scamparla.
Dialogue: 0,0:14:13.25,0:14:15.83,Main-207+,,0,0,0,,Ma quindi moriremo?!{la voce T_T}
Dialogue: 0,0:14:16.42,0:14:19.05,Main-207+,,0,0,0,,Ve l'avevo detto, no? Di prepararvi al peggio.{circa}
Dialogue: 0,0:14:22.05,0:14:24.43,Main-207+,,0,0,0,,Eeh?! Anche noi?!
Comment: 0,0:14:24.43,0:14:25.64,Main-207+,,0,0,0,,
Dialogue: 0,0:14:25.64,0:14:26.72,Main-207+,,0,0,0,,Capisco...
Dialogue: 0,0:14:26.72,0:14:28.43,Main-207+,,0,0,0,,Robin non è ancora...
Dialogue: 0,0:14:30.31,0:14:33.64,Main-207+,,0,0,0,,{\i1}Comunque... \Nlì da te la situazione sembra vivace.{era il modo più vicino che mi venisse in mente}
Dialogue: 0,0:14:33.64,0:14:35.60,Main-207+,,0,0,0,,Ehi, Sanji...
Dialogue: 0,0:14:36.19,0:14:38.86,Main-207+,,0,0,0,,Le ragioni per cui Robin ha fatto questo...
Dialogue: 0,0:14:39.65,0:14:42.82,Main-207+,,0,0,0,,e la nostra situazione attuale...
Dialogue: 0,0:14:42.82,0:14:45.82,Main-207+,,0,0,0,,Ma state zitti!
Dialogue: 0,0:14:47.03,0:14:48.83,Main-207+,,0,0,0,,Senti, Sanji!
Dialogue: 0,0:14:48.83,0:14:53.96,Main-207+,,0,0,0,,{\q2}Ora ti spiegherò tutto riguardo i motivi delle azioni di \NRobin e della nostra situazione attuale!
Dialogue: 0,0:14:53.96,0:14:55.08,Main-207+,,0,0,0,,Ascoltami bene!
Dialogue: 0,0:14:56.79,0:14:58.67,Main-207+,,0,0,0,,Ci colpirà!
Dialogue: 0,0:14:58.67,0:15:00.21,Main-207+,,0,0,0,,Oh no! Morirò!
Dialogue: 0,0:15:00.21,0:15:01.55,Main-207+,,0,0,0,,Moriremo!
Dialogue: 0,0:15:01.55,0:15:03.88,Main-207+,,0,0,0,,Se avete tempo di lamentarvi, sparate!
Dialogue: 0,0:15:03.88,0:15:05.84,Secondary-207+,,0,0,0,,Aprite un varco!
Dialogue: 0,0:15:09.51,0:15:11.10,Main-207+,,0,0,0,,Ehi, Luffy.
Dialogue: 0,0:15:11.10,0:15:12.31,Main-207+,,0,0,0,,Sì.
Dialogue: 0,0:15:12.81,0:15:14.81,Main-207+,,0,0,0,,Andiamo. Zoro.
Dialogue: 0,0:15:25.28,0:15:27.49,Main-207+,,0,0,0,,Ehi! Continuate a sparare al centro!
Dialogue: 0,0:15:27.49,0:15:29.41,Main-207+,,0,0,0,,Voi, che volete fare?!
Dialogue: 0,0:15:38.42,0:15:40.04,Main-207+,,0,0,0,,Spareremo...
Dialogue: 0,0:15:41.80,0:15:42.63,Main-207+,,0,0,0,,un cannone.{<rare volte in cui funziona meglio in italiano imo}
Dialogue: 0,0:15:51.81,0:15:54.10,Main-207+,,0,0,0,,Quanto fa 108 per 2?!
Dialogue: 0,0:15:54.93,0:15:56.35,Main-207+,,0,0,0,,216!{zoro, il genio della matematica}
Dialogue: 0,0:15:56.35,0:15:58.48,Main-207+,,0,0,0,,Ma 216...
Dialogue: 0,0:15:58.48,0:16:00.98,Main-207+,,0,0,0,,è lungo e difficile da dire.
Dialogue: 0,0:16:00.98,0:16:03.23,Main-207+,,0,0,0,,Allora, va bene tutto!
Dialogue: 0,0:16:03.94,0:16:06.57,Main-207+,,0,0,0,,C-Cosa stanno facendo?!
Dialogue: 0,0:16:06.57,0:16:09.20,Main-207+,,0,0,0,,{\q2}Cosa vogliono fare a mani nude e con le spade?
Dialogue: 0,0:16:09.20,0:16:10.91,Main-207+,,0,0,0,,Hanno detto di continuare a sparare.
Dialogue: 0,0:16:10.91,0:16:12.87,Main-207+,,0,0,0,,Va bene tutto, diamogli supporto!{ewwwwwwwwwww}
Dialogue: 0,0:16:13.24,0:16:15.25,Main-207+,,0,0,0,,– Sì!\N– Sì!
Dialogue: 0,0:16:15.79,0:16:18.67,Main-207+,,0,0,0,,Ok! Allora facciamo 300!
Dialogue: 0,0:16:19.29,0:16:20.67,Main-207+,,0,0,0,,Ok!
Dialogue: 0,0:16:20.67,0:16:22.67,Main-207+,,0,0,0,,{\fad(150,150)}Gum Gum...
Dialogue: 0,0:16:22.67,0:16:25.01,Main-207+,,0,0,0,,{\fad(150,150)}Sanbyaku Pondo...
Dialogue: 0,0:16:27.09,0:16:29.59,Main-207+,,0,0,0,,– Ci colpirà!\N– Ci colpirà!
Dialogue: 0,0:16:36.85,0:16:38.27,Main-207+,,0,0,0,,{\fad(150,150)}– Cannon!\N– Cannon!{tutto l'attacco G - abilità [Luffy, Zoro]}{per la nota io non so cosa dirvi... è lo stesso "gioco di parole" di 36 pondo hou... solo con 300 invece che 36}
Dialogue: 0,0:17:30.61,0:17:35.78,Main-207+,,0,0,0,,– S-Siamo passati!\N– S-Siamo passati!
Dialogue: 0,0:17:41.83,0:17:46.34,Main-207+,,0,0,0,,– Abbiamo passato l'Aqua Laguna!\N– Abbiamo passato l'Aqua Laguna!
Dialogue: 0,0:17:49.67,0:17:51.84,Main-207+,,0,0,0,,Pensavo fosse la fine!{vedi Chimney/Luffy all'inizio dell'episodio}
Comment: 0,0:18:01.06,0:18:02.60,Main-207+,,0,0,0,,
Comment: 0,0:18:14.78,0:18:15.87,Main-207+,,0,0,0,,
Dialogue: 0,0:18:15.87,0:18:18.24,Main-207+,,0,0,0,,{\i1}Ehi! Cara Nami, va tutto bene?
Dialogue: 0,0:18:18.24,0:18:20.66,Main-207+,,0,0,0,,Sì... in qualche modo...
Dialogue: 0,0:18:22.50,0:18:24.25,Main-207+,,0,0,0,,Questo sì che è incredibile!
Dialogue: 0,0:18:24.25,0:18:27.63,Main-207+,,0,0,0,,Quindi non siete solo chiacchiere, eh, pirati?{non mi veniva meglio}
Dialogue: 0,0:18:27.96,0:18:30.34,Main-207+,,0,0,0,,Averli come avversari è terrificante, ma...
Dialogue: 0,0:18:30.34,0:18:34.72,Main-207+,,0,0,0,,come alleati non c'è nessuno \Ndi più affidabile di loro!
Dialogue: 0,0:18:34.72,0:18:35.76,Main-207+,,0,0,0,,– Cappello di Paglia!\N– Cappello di Paglia!
Dialogue: 0,0:18:36.26,0:18:39.01,Main-207+,,0,0,0,,Devo ammettere che ero pronto a morire.{mi ero preparato a morire}
Dialogue: 0,0:18:39.01,0:18:40.35,Main-207+,,0,0,0,,Che tizi assurdi...
Dialogue: 0,0:18:40.72,0:18:43.06,Main-207+,,0,0,0,,Non abbassate la guardia.
Dialogue: 0,0:18:43.06,0:18:45.85,Main-207+,,0,0,0,,Non abbiamo ancora passato la tempesta.
Dialogue: 0,0:18:45.85,0:18:47.56,Main-207+,,0,0,0,,– Sì!\N– Sì!
Dialogue: 0,0:18:47.56,0:18:50.03,Main-207+,,0,0,0,,Non c'è più nulla da temere!
Dialogue: 0,0:18:54.66,0:18:56.28,Main-207+,,0,0,0,,È stato divertente!
Dialogue: 0,0:18:56.28,0:18:59.03,Main-207+,,0,0,0,,Cappello di Paglia, sei straordinario!
Dialogue: 0,0:18:59.03,0:19:02.29,Main-207+,,0,0,0,,Non è roba da esseri umani!{ewwwwwwwwwwww}
Dialogue: 0,0:19:04.29,0:19:06.38,Main-207+,,0,0,0,,Ah, scusa, scusa.
Dialogue: 0,0:19:06.38,0:19:08.00,Main-207+,,0,0,0,,Luffy! Vieni qui!
Dialogue: 0,0:19:14.38,0:19:15.63,Main-207+,,0,0,0,,È Sanji.
Dialogue: 0,0:19:16.84,0:19:18.05,Main-207+,,0,0,0,,Yo, Luffy?
Dialogue: 0,0:19:18.05,0:19:19.93,Main-207+,,0,0,0,,{\i1}Oh! Sanji!
Dialogue: 0,0:19:19.93,0:19:21.52,Main-207+,,0,0,0,,{\i1}Come vanno le cose là?
Dialogue: 0,0:19:21.52,0:19:22.89,Main-207+,,0,0,0,,{\i1}E Robin?
Dialogue: 0,0:19:22.89,0:19:26.56,Main-207+,,0,0,0,,Robin... è ancora imprigionata.
Dialogue: 0,0:19:27.06,0:19:29.69,Main-207+,,0,0,0,,Ho appena sentito della situazione da Nami.
Dialogue: 0,0:19:30.11,0:19:32.36,Main-207+,,0,0,0,,Ho sentito... tutto.
Dialogue: 0,0:19:32.36,0:19:33.82,Main-207+,,0,0,0,,Capisco.
Dialogue: 0,0:19:34.36,0:19:35.28,Main-207+,,0,0,0,,Sì.
Dialogue: 0,0:19:35.99,0:19:38.32,Main-207+,,0,0,0,,Beh, così stanno le cose.
Dialogue: 0,0:19:39.12,0:19:41.03,Main-207+,,0,0,0,,Scatenati pure, se vuoi!{no, ma il lett fa schifo... "è ok, puoi scatenarti"}
Dialogue: 0,0:19:41.03,0:19:43.33,Main-207+,,0,0,0,,Luffy, non dire idiozie!
Dialogue: 0,0:19:43.33,0:19:45.66,Main-207+,,0,0,0,,Fallo attendere finché non lo raggiungiamo!
Dialogue: 0,0:19:46.50,0:19:48.42,Main-207+,,0,0,0,,{\i1}Ehi, cuoco! Mi senti?!
Dialogue: 0,0:19:48.42,0:19:50.34,Main-207+,,0,0,0,,{\i1}In quel treno ci sono tizi pericolosi–
Dialogue: 0,0:19:50.34,0:19:51.63,Main-207+,,0,0,0,,{\i1}Va bene così!
Dialogue: 0,0:19:51.63,0:19:52.75,Main-207+,,0,0,0,,Zoro.
Dialogue: 0,0:19:53.17,0:19:55.42,Main-207+,,0,0,0,,Se fossi nei suoi panni, cosa faresti?
Dialogue: 0,0:19:56.55,0:20:02.22,Main-207+,,0,0,0,,Se avessi sentito che Robin è stata \Ncatturata e ha anche mentito per salvarci,
Dialogue: 0,0:20:02.72,0:20:04.81,Main-207+,,0,0,0,,riusciresti a stare fermo?
Dialogue: 0,0:20:07.64,0:20:09.48,Main-207+,,0,0,0,,Anche se volessi fermarlo, sarebbe inutile.{cps}
Dialogue: 0,0:20:10.86,0:20:12.44,Main-207+,,0,0,0,,Tu sì che mi capisci!{circa}
Dialogue: 0,0:20:12.44,0:20:14.53,Main-207+,,0,0,0,,Oh, marimo~!{il ~ solo perché il kun non so come altro mettervelo e ci starebbe tanto qua T_T}
Dialogue: 0,0:20:14.53,0:20:16.53,Main-207+,,0,0,0,,Sei preoccupato per me?
Dialogue: 0,0:20:16.53,0:20:17.78,Main-207+,,0,0,0,,{\i1}Certo, come no!
Dialogue: 0,0:20:18.16,0:20:19.70,Main-207+,,0,0,0,,Ma mi spiace.
Dialogue: 0,0:20:20.53,0:20:24.08,Main-207+,,0,0,0,,Dopo aver sentito cosa prova Robin...
Dialogue: 0,0:20:25.08,0:20:27.62,Main-207+,,0,0,0,,anche se fosse per ordine del capitano...
Dialogue: 0,0:20:27.62,0:20:30.04,Main-207+,,0,0,0,,non mi fermerei!{kakkoi~ ♡}
Dialogue: 0,0:20:32.00,0:20:34.13,Main-207+,,0,0,0,,Ma perché lo rompi?!
Dialogue: 0,0:20:34.13,0:20:37.34,Main-207+,,0,0,0,,Anch'io avevo una cosa da \Nchiedere a Cappello di Paglia!
Dialogue: 0,0:20:37.34,0:20:39.43,Main-207+,,0,0,0,,Eh? Chi se ne frega.
Dialogue: 0,0:20:40.01,0:20:41.76,Main-207+,,0,0,0,,Perché non l'hai detto prima?
Dialogue: 0,0:20:41.76,0:20:43.93,Main-207+,,0,0,0,,Anche senza dirlo, era ovvio, no?!
Dialogue: 0,0:20:43.93,0:20:45.68,Main-207+,,0,0,0,,Non fare il finto tonto!{sarebbe non darti arie o simili, ma mi piace così}
Dialogue: 0,0:20:45.68,0:20:47.39,Main-207+,,0,0,0,,Non lo sto facendo.
Dialogue: 0,0:20:50.65,0:20:52.65,Main-207+,,0,0,0,,Chissà se starà bene...
Dialogue: 0,0:20:52.65,0:20:55.65,Main-207+,,0,0,0,,Vecchia! Fai andare il treno più veloce!
Dialogue: 0,0:20:55.65,0:20:56.65,Main-207+,,0,0,0,,Più veloce?
Dialogue: 0,0:20:56.65,0:21:00.91,Main-207+,,0,0,0,,Sì! Più tipo "fiuu"!{...}
Dialogue: 0,0:21:02.62,0:21:04.37,Main-207+,,0,0,0,,Stai tranquillo.
Dialogue: 0,0:21:04.37,0:21:08.21,Main-207+,,0,0,0,,Abbiamo già superato la velocità \Nmassima della nave.
Dialogue: 0,0:21:10.62,0:21:14.25,Main-207+,,0,0,0,,Ormai non potremo più fermarlo da soli.{idk}
Dialogue: 0,0:21:19.93,0:21:22.26,Main-207+,,0,0,0,,Da quando ho lasciato la ciurma...
Dialogue: 0,0:21:22.93,0:21:25.35,Main-207+,,0,0,0,,è successo tutto questo?
Dialogue: 0,0:21:26.06,0:21:28.31,Main-207+,,0,0,0,,Robin non sa nulla né della Merry
Dialogue: 0,0:21:28.31,0:21:32.65,Main-207+,,0,0,0,,né del grande litigio che hai avuto con Luffy.
Dialogue: 0,0:21:36.48,0:21:41.49,Main-207+,,0,0,0,,{\q2}Ha voluto che noi sei, te incluso, fossimo al sicuro
Dialogue: 0,0:21:41.49,0:21:46.49,Main-207+,,0,0,0,,e così ha sacrificato se stessa e \Nha fatto tutto ciò che volevano loro.
Dialogue: 0,0:21:47.24,0:21:49.04,Main-207+,,0,0,0,,Per il nostro bene.
Dialogue: 0,0:21:51.79,0:21:55.50,Main-207+,,0,0,0,,Ma... che storia emozionante!{direbbe bella}
Dialogue: 0,0:21:57.75,0:21:59.76,Main-207+,,0,0,0,,Ma perché stai piangendo {\i1}tu{\i0}?
Dialogue: 0,0:21:59.76,0:22:02.51,Main-207+,,0,0,0,,Idiota! Non sto piangendo!
Dialogue: 0,0:22:04.47,0:22:07.18,Main-207+,,0,0,0,,Maledizione! Com'è possibile?
Dialogue: 0,0:22:07.18,0:22:12.06,Main-207+,,0,0,0,,{\q2}Stando all'opinione pubblica... Nico Robin dovrebbe \Nessere una donna spietata, crudele e diabolica!
Dialogue: 0,0:22:12.06,0:22:16.57,Main-207+,,0,0,0,,E invece guarda te! \NChe emozionante affetto per i suoi compagni!
Dialogue: 0,0:22:17.44,0:22:19.86,Main-207+,,0,0,0,,Robin è a un passo da noi.
Dialogue: 0,0:22:20.19,0:22:22.40,Main-207+,,0,0,0,,Comunque sia, io andrò a salvarla!
Dialogue: 0,0:22:22.40,0:22:23.36,Main-207+,,0,0,0,,Bene!
Dialogue: 0,0:22:23.36,0:22:26.37,Main-207+,,0,0,0,,Io, capostipite della Famiglia Franky, Franky
Dialogue: 0,0:22:26.37,0:22:28.87,Main-207+,,0,0,0,,ti aiuterò, fratello sopracciglio!{....}
Dialogue: 0,0:22:28.87,0:22:33.92,Main-207+,,0,0,0,,A dire il vero, ho anch'io le mie ragioni per non \Nlasciare che Robin cada nelle mani del governo.
Dialogue: 0,0:22:34.37,0:22:37.88,Main-207+,,0,0,0,,Ma soprattutto, dopo aver \Nsentito una storia così commovente...!
Dialogue: 0,0:22:37.88,0:22:39.88,Main-207+,,0,0,0,,Ehi! Andiamo, naso lungo!
Dialogue: 0,0:22:40.42,0:22:41.80,Main-207+,,0,0,0,,Io...
Dialogue: 0,0:22:42.92,0:22:43.72,Main-207+,,0,0,0,,non vengo.
Dialogue: 0,0:22:46.39,0:22:49.14,Main-207+,,0,0,0,,Non ha più nulla a che fare con me, no?
Dialogue: 0,0:22:49.14,0:22:52.31,Main-207+,,0,0,0,,Se l'avversario alla fine è il Governo Mondiale,
Dialogue: 0,0:22:52.31,0:22:54.23,Main-207+,,0,0,0,,io non voglio essere coinvolto.
Dialogue: 0,0:22:55.90,0:22:58.48,Main-207+,,0,0,0,,Vi riunirete con Luffy e gli altri, no?
Dialogue: 0,0:22:59.27,0:23:02.11,Main-207+,,0,0,0,,{\q2}Dopo la mia arroganza e la figuraccia che ho fatto,
Dialogue: 0,0:23:02.11,0:23:04.78,Main-207+,,0,0,0,,con che coraggio potrei mai restare con voi?!
Dialogue: 0,0:23:08.49,0:23:10.37,Main-207+,,0,0,0,,Mi dispiace per Robin,
Dialogue: 0,0:23:10.37,0:23:14.08,Main-207+,,0,0,0,,ma io... non ho più il diritto di salvarla.
Dialogue: 0,0:23:14.46,0:23:16.21,Main-207+,,0,0,0,,Ho lasciato la ciurma!
Dialogue: 0,0:23:22.34,0:23:23.34,Main-207+,,0,0,0,,Ci vediamo.
Dialogue: 0,0:23:25.68,0:23:28.14,Main-207+,,0,0,0,,E-Ehi! Che intendi con "ci vediamo"?!
Dialogue: 0,0:23:28.14,0:23:31.77,Main-207+,,0,0,0,,Tu! Non ci sono vie di fuga qui!
Dialogue: 0,0:23:31.77,0:23:32.77,Main-207+,,0,0,0,,Lascia stare.
Dialogue: 0,0:23:33.39,0:23:34.52,Main-207+,,0,0,0,,Lascialo perdere.
Dialogue: 0,0:23:38.15,0:23:40.40,Main-207+,,0,0,0,,Ma che testardo...
Dialogue: 0,0:23:41.36,0:23:43.28,Main-207+,,0,0,0,,Cercate con attenzione!
Dialogue: 0,0:23:43.28,0:23:45.74,Main-207+,,0,0,0,,Devono esserci delle prove!
Dialogue: 0,0:23:46.57,0:23:47.36,Main-207+,,0,0,0,,C–
Dialogue: 0,0:23:47.70,0:23:48.87,Main-207+,,0,0,0,,Così non va!
Dialogue: 0,0:23:50.83,0:23:52.29,Main-207+,,0,0,0,,Per ora, ci accontenteremo di questo.{uguale a 11:24 questo ep}
Dialogue: 0,0:23:54.12,0:23:58.21,Main-207+,,0,0,20,,Signor Wanze! Il treno... è in seri guai!
Dialogue: 0,0:23:58.21,0:23:59.33,Main-207+,,0,0,20,,Sta' zitto!
Dialogue: 0,0:23:59.33,0:24:01.80,Main-207+,,0,0,20,,Sono {\i1}io{\i0} ad essere in guai seri!
Dialogue: 0,0:24:03.96,0:24:06.80,Main-207+,,0,0,0,,Signor Nero! I detenuti sono fuggiti!
Dialogue: 0,0:24:22.86,0:24:24.07,Main-207+,,0,0,0,,Li ho trovati!
Dialogue: 0,0:24:24.07,0:24:25.78,Main-207+,,0,0,0,,Ah, merda!
Dialogue: 0,0:24:25.78,0:24:27.20,Main-207+,,0,0,0,,{\fad(150,150)}Metallic Star!{G - abilità [Usopp]}
Dialogue: 0,0:24:34.49,0:24:36.12,Main-207+,,0,0,0,,– Ma chi sei?!\N– Ma chi sei?!
Dialogue: 0,0:24:43.63,0:24:45.76,Main-207+,,0,0,0,,Ho sentito tutta la storia da lui.
Dialogue: 0,0:24:46.13,0:24:48.76,Main-207+,,0,0,0,,Pare vogliate salvare una signorina.
Dialogue: 0,0:24:49.26,0:24:52.76,Main-207+,,0,0,0,,Non ho bisogno di ragioni per aiutarvi!
Dialogue: 0,0:24:53.26,0:24:55.22,Main-207+,,0,0,0,,Combatterò con voi!
Dialogue: 0,0:25:02.02,0:25:03.44,Main-207+,,0,0,0,,Il  mio nome è...
Dialogue: 0,0:25:04.36,0:25:06.03,Main-207+,,0,0,0,,Sogeking!{G - Personaggi}
