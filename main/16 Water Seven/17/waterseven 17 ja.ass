Comment: 0,0:00:00.00,0:00:00.00,Main-207+,,0,0,0,,{=10}===============================DIALOGUE============================
Dialogue: 0,0:01:56.60,0:01:58.47,Main-207+,,0,0,0,,出口が近いね
Dialogue: 0,0:01:58.47,0:02:00.89,Main-207+,,0,0,0,,このまま一気に下るよ
Dialogue: 0,0:02:00.89,0:02:01.89,Main-207+,,0,0,0,,えっ　ウソ…
Dialogue: 0,0:02:01.89,0:02:02.64,Main-207+,,0,0,0,,えっ…
Dialogue: 0,0:02:02.64,0:02:05.27,Main-207+,,0,0,0,,ええっ　ええーっ…
Dialogue: 0,0:02:24.25,0:02:27.09,Main-207+,,0,0,0,,よーし！海列車が出てきたあ！
Dialogue: 0,0:02:27.09,0:02:30.34,Main-207+,,0,0,0,,野郎ども！こっちも出撃だ！
Dialogue: 0,0:02:30.34,0:02:33.01,Main-207+,,0,0,0,,–　おう！\N–　おう！
Dialogue: 0,0:02:33.01,0:02:35.84,Main-207+,,0,0,0,,跳べ！ソドム！ゴモラ！
Dialogue: 0,0:02:37.30,0:02:38.51,Main-207+,,0,0,0,,な…　何だ？
Dialogue: 0,0:02:41.35,0:02:44.48,Main-207+,,0,0,0,,{\an8}麦わらさーん！
Dialogue: 0,0:02:44.48,0:02:48.06,Main-207+,,0,0,0,,{\an8}フランキー一家全員まとめて
Dialogue: 0,0:02:48.52,0:02:52.07,Main-207+,,0,0,0,,{\q\an8}お世話になりまーす！
Dialogue: 0,0:02:52.07,0:02:54.15,Main-207+,,0,0,0,,{\an8}連結砲！撃てーっ！
Dialogue: 0,0:03:04.54,0:03:07.00,Main-207+,,0,0,0,,うっほー！すっげえ！
Dialogue: 0,0:03:07.38,0:03:10.84,Main-207+,,0,0,0,,ありゃ最上ランクのキングブルらねえ
Dialogue: 0,0:03:10.84,0:03:12.88,Main-207+,,0,0,0,,やるなあ！
Dialogue: 0,0:03:15.05,0:03:18.22,Main-207+,,0,0,0,,ちくしょう…　あの野郎ども！
Dialogue: 0,0:03:18.22,0:03:20.10,Main-207+,,0,0,0,,てめえら！ムチャすな！
Dialogue: 0,0:03:20.10,0:03:22.56,Main-207+,,0,0,0,,–　よろしく！\N–　よろしく！
Dialogue: 0,0:03:24.85,0:03:27.23,Main-207+,,0,0,0,,だいぶ流されてるね
Dialogue: 0,0:03:27.69,0:03:31.36,Main-207+,,0,0,0,,だが\N開発から海列車を見てきたあたしを
Dialogue: 0,0:03:31.36,0:03:33.53,Main-207+,,0,0,0,,なめんじゃらいよ
Dialogue: 0,0:03:37.91,0:03:38.82,Main-207+,,0,0,0,,見えた！
Dialogue: 0,0:03:38.82,0:03:40.16,Main-207+,,0,0,0,,行くよ！
Dialogue: 0,0:03:43.87,0:03:46.37,Main-207+,,0,0,0,,{\i1}運転室より緊急連絡ら
Comment: 0,0:03:46.37,0:03:48.12,Main-207+,,0,0,0,,{\i1}これから線路をつかむと
Comment: 0,0:03:48.12,0:03:50.46,Main-207+,,0,0,0,,{\i1}急速に速度が上がるよ
Dialogue: 0,0:03:46.37,0:03:50.46,Main-207+,,0,0,0,,{\i1}これから線路をつかむと\N急速に速度が上がるよ
Dialogue: 0,0:03:50.46,0:03:54.46,Main-207+,,0,0,0,,{\i1}軽い傷で済むよう\Nしっかりしがみついてな！
Dialogue: 0,0:03:54.46,0:03:56.84,Main-207+,,0,0,0,,とりあえずケガはするんだ…
Dialogue: 0,0:04:06.23,0:04:07.35,Main-207+,,0,0,0,,ええい！
Dialogue: 0,0:04:07.35,0:04:08.52,Main-207+,,0,0,0,,言うことを聞きら！
Dialogue: 0,0:04:08.54,0:04:09.31,Main-207+,,0,0,0,,ばあちゃん！惜しい惜しい！
Dialogue: 0,0:04:10.61,0:04:12.37,Main-207+,,0,0,0,,もう少し右～！
Comment: 0,0:04:12.37,0:04:12.90,Main-207+,,0,0,0,,ニャー！
Dialogue: 0,0:04:14.69,0:04:15.74,Main-207+,,0,0,0,,見てらあ！
Dialogue: 0,0:04:15.74,0:04:17.36,Main-207+,,0,0,0,,次は決めて…
Dialogue: 0,0:04:17.36,0:04:18.07,Main-207+,,0,0,0,,えっ！？
Dialogue: 0,0:04:18.07,0:04:20.53,Main-207+,,0,0,0,,チムニー！ゴンベ！
Dialogue: 0,0:04:21.78,0:04:24.29,Main-207+,,0,0,0,,おめえら　ついてきてたのかい？
Dialogue: 0,0:04:25.41,0:04:26.95,Main-207+,,0,0,0,,来てたー！
Comment: 0,0:04:26.95,0:04:28.50,Main-207+,,0,0,0,,ニャー　ニャー
Dialogue: 0,0:04:29.96,0:04:31.63,Main-207+,,0,0,0,,何てこったい！
Dialogue: 0,0:04:31.63,0:04:33.25,Main-207+,,0,0,0,,早く中へ入んな！
Dialogue: 0,0:04:33.88,0:04:35.80,Main-207+,,0,0,0,,吹き飛んじまうよ！
Dialogue: 0,0:04:36.38,0:04:37.97,Main-207+,,0,0,0,,大丈夫大丈夫！
Dialogue: 0,0:04:40.72,0:04:41.89,Main-207+,,0,0,0,,チムニー！
Dialogue: 0,0:04:44.14,0:04:45.35,Main-207+,,0,0,0,,落ちる～！
Dialogue: 0,0:04:45.35,0:04:48.23,Main-207+,,0,0,0,,て…　手を離すんらないよ！
Dialogue: 0,0:04:48.23,0:04:51.00,Main-207+,,0,0,0,,飛ばされる～っ！
Comment: 0,0:04:51.00,0:04:51.50,Main-207+,,0,0,0,,ニャー！
Dialogue: 0,0:04:51.94,0:04:53.52,Main-207+,,0,0,0,,ちょ…　ちょっと待っちらよ
Dialogue: 0,0:04:53.52,0:04:55.19,Main-207+,,0,0,0,,今止めるから
Dialogue: 0,0:05:01.41,0:05:02.66,Main-207+,,0,0,0,,そうら
Dialogue: 0,0:05:02.66,0:05:05.91,Main-207+,,0,0,0,,こいつブレーキ利かなかったんら
Comment: 0,0:05:07.83,0:05:09.41,Main-207+,,0,0,0,,うおっと
Dialogue: 0,0:05:09.41,0:05:11.83,Main-207+,,0,0,0,,何だ？何か楽しそうだな
Dialogue: 0,0:05:12.83,0:05:14.71,Main-207+,,0,0,0,,麦わらの兄ちゃんだ！
Dialogue: 0,0:05:14.71,0:05:15.90,Main-207+,,0,0,0,,おーい！
Comment: 0,0:05:15.90,0:05:16.75,Main-207+,,0,0,0,,ニャー！
Dialogue: 0,0:05:16.75,0:05:19.67,Main-207+,,0,0,0,,麦わら！早くチムニーたちを！
Dialogue: 0,0:05:20.05,0:05:23.72,Main-207+,,0,0,0,,このまま線路に乗ったら\N吹き飛ばされちまうよ！
Dialogue: 0,0:05:24.18,0:05:24.89,Main-207+,,0,0,0,,おう！
Dialogue: 0,0:06:02.26,0:06:03.84,Main-207+,,0,0,0,,–　死ぬかと思った\N–　死ぬかと思った
Dialogue: 0,0:06:04.34,0:06:06.68,Main-207+,,0,0,0,,当たり前らよ　まったく
Dialogue: 0,0:06:06.68,0:06:07.85,Main-207+,,0,0,0,,だから言ったらろ
Dialogue: 0,0:06:07.85,0:06:09.68,Main-207+,,0,0,0,,吹っ飛ばされるって
Dialogue: 0,0:06:09.68,0:06:10.81,Main-207+,,0,0,0,,いたた…
Dialogue: 0,0:06:10.81,0:06:13.94,Main-207+,,0,0,0,,しっかし\Nものすげえ加速だな
Dialogue: 0,0:06:13.94,0:06:14.77,Main-207+,,0,0,0,,まったく
Dialogue: 0,0:06:14.77,0:06:16.90,Main-207+,,0,0,0,,いやいや　ビビった
Dialogue: 0,0:06:16.90,0:06:18.90,Main-207+,,0,0,0,,腰打った…
Dialogue: 0,0:06:19.40,0:06:20.69,Main-207+,,0,0,0,,ちょっと待て
Dialogue: 0,0:06:20.69,0:06:23.11,Main-207+,,0,0,0,,この車両におかしなヤツらがいるぞ
Dialogue: 0,0:06:23.45,0:06:24.95,Main-207+,,0,0,0,,–　何！？そりゃ誰だ！\N–　何！？そりゃ誰だ！
Dialogue: 0,0:06:24.95,0:06:26.24,Main-207+,,0,0,0,,お前らだよ！
Dialogue: 0,0:06:26.24,0:06:27.58,Main-207+,,0,0,0,,おめえもだろ！
Dialogue: 0,0:06:30.29,0:06:33.75,Main-207+,,0,0,0,,お前らはいくら止めようとしても止まらなかった
Dialogue: 0,0:06:34.12,0:06:37.25,Main-207+,,0,0,0,,お前らがそうまでして仲間を奪い返したい敵は
Dialogue: 0,0:06:37.25,0:06:41.51,Main-207+,,0,0,0,,俺にとっても\Nアイスバーグさんの命を狙った犯人でもある
Dialogue: 0,0:06:41.84,0:06:45.18,Main-207+,,0,0,0,,それにあいつらには言ってやりたいことがたくさんあるからな
Dialogue: 0,0:06:46.43,0:06:49.06,Main-207+,,0,0,0,,パウリー\N抜け駆けは許さんぞ
Dialogue: 0,0:06:49.06,0:06:53.43,Main-207+,,0,0,0,,俺たちはお前にくっついてくりゃ\Nアイスバーグさんの敵に会えると踏んで
Dialogue: 0,0:06:53.43,0:06:55.73,Main-207+,,0,0,0,,一緒に炭水車に隠れていたんだ
Dialogue: 0,0:06:55.73,0:06:58.40,Main-207+,,0,0,0,,案の定　そういうことらしいな
Dialogue: 0,0:06:58.77,0:07:01.69,Main-207+,,0,0,0,,この戦い\N俺たちも加えてもらうぞ
Dialogue: 0,0:07:02.03,0:07:04.15,Main-207+,,0,0,0,,その敵ってのは当然
Dialogue: 0,0:07:04.15,0:07:06.74,Main-207+,,0,0,0,,フランキーのアニキを連れ去ったヤツらでもある
Dialogue: 0,0:07:06.74,0:07:10.95,Main-207+,,0,0,0,,そうだわいな\Nあたしらそいつが誰なのかもはっきりと知ってるんだわいな
Dialogue: 0,0:07:10.95,0:07:14.75,Main-207+,,0,0,0,,やいガレーラ！あんたらアニキに何かあったら\Nどう責任取るんだわいな！
Dialogue: 0,0:07:14.75,0:07:15.75,Main-207+,,0,0,0,,黙れ！
Dialogue: 0,0:07:15.75,0:07:18.13,Main-207+,,0,0,0,,一番つらいのはアイスバーグさんだ！
Dialogue: 0,0:07:18.75,0:07:20.75,Main-207+,,0,0,0,,お前ら何をごちゃごちゃと
Dialogue: 0,0:07:20.75,0:07:23.76,Main-207+,,0,0,0,,パウリー！まず俺たちに説明しろ\Nどうなってんだ
Dialogue: 0,0:07:23.76,0:07:25.47,Main-207+,,0,0,0,,そうだぜパウリー
Dialogue: 0,0:07:25.47,0:07:28.34,Main-207+,,0,0,0,,知ってんだろ？真犯人を
Dialogue: 0,0:07:28.34,0:07:30.35,Main-207+,,0,0,0,,お前の口から言ってみな
Dialogue: 0,0:07:30.35,0:07:32.64,Main-207+,,0,0,0,,俺たちもそうそう鈍くねえ
Dialogue: 0,0:07:32.64,0:07:34.27,Main-207+,,0,0,0,,おおかたの見当はついてる
Dialogue: 0,0:07:34.60,0:07:36.69,Main-207+,,0,0,0,,別に驚きゃしねえよ
Dialogue: 0,0:07:37.90,0:07:42.15,Main-207+,,0,0,0,,まあ　急に意味なく姿を消せば\N察しもつくか
Dialogue: 0,0:07:42.15,0:07:44.49,Main-207+,,0,0,0,,じゃあ　はっきり言う
Dialogue: 0,0:07:44.49,0:07:47.91,Main-207+,,0,0,0,,仮面のヤツらの正体は
Dialogue: 0,0:07:47.91,0:07:52.79,Main-207+,,0,0,0,,ルッチ　カク　カリファ\Nそして酒場のブルーノ
Dialogue: 0,0:07:53.29,0:07:57.25,Main-207+,,0,0,0,,あいつらが\Nアイスバーグさんを殺そうとした
Dialogue: 0,0:07:59.13,0:08:00.96,Main-207+,,0,0,0,,想像だにしてなかったのか！
Dialogue: 0,0:08:00.96,0:08:03.67,Main-207+,,0,0,0,,{W7 15 - 07:49}し…　しかし\Nあいつらは里帰りしたって…
Dialogue: 0,0:08:03.67,0:08:05.09,Main-207+,,0,0,0,,するか！この非常時に
Dialogue: 0,0:08:05.09,0:08:08.18,Main-207+,,0,0,0,,俺たちはてっきり\N裏町のマイケルホイケルだと…
Dialogue: 0,0:08:08.18,0:08:08.93,Main-207+,,0,0,0,,そうそう！
Dialogue: 0,0:08:08.93,0:08:09.84,Main-207+,,0,0,0,,誰だよそれ
Dialogue: 0,0:08:09.84,0:08:12.43,Main-207+,,0,0,0,,えっ　ええ！？\Nお前知らねえのか？
Dialogue: 0,0:08:12.43,0:08:14.02,Main-207+,,0,0,0,,裏町じゃ有名だぞ
Dialogue: 0,0:08:14.02,0:08:15.06,Main-207+,,0,0,0,,そうだそうだ！
Dialogue: 0,0:08:15.06,0:08:17.06,Main-207+,,0,0,0,,知るか！大体お前らなあ…
Dialogue: 0,0:08:17.06,0:08:17.94,Main-207+,,0,0,0,,うっし！
Dialogue: 0,0:08:17.94,0:08:19.94,Main-207+,,0,0,0,,あ～　食った食った
Dialogue: 0,0:08:19.94,0:08:21.86,Main-207+,,0,0,0,,やっと腹いっぱいになったぞ
Dialogue: 0,0:08:24.40,0:08:25.94,Main-207+,,0,0,0,,じゃあまあ…
Dialogue: 0,0:08:26.78,0:08:30.11,Main-207+,,0,0,0,,フランキー一家とも\Nガレーラの船大工とも
Dialogue: 0,0:08:30.53,0:08:35.29,Main-207+,,0,0,0,,町じゃゴタゴタあったけど\Nこの先ここにいる全員の敵は同じだ
Dialogue: 0,0:08:35.79,0:08:40.23,Main-207+,,0,0,0,,これから戦う中で\N一番強えのは特にあのハトのヤツだ
Dialogue: 0,0:08:40.23,0:08:43.00,Main-207+,,0,0,0,,{EL23 @ 08:59}あいつは必ず俺がぶっ飛ばす！
Dialogue: 0,0:08:43.00,0:08:44.63,Main-207+,,0,0,0,,そうだな
Dialogue: 0,0:08:44.63,0:08:48.38,Main-207+,,0,0,0,,この戦いは取られたもんを\Nあの４人から奪い返す戦いだ
Dialogue: 0,0:08:48.38,0:08:52.60,Main-207+,,0,0,0,,ともかく　あいつらに追いつかねえことにゃ\N何も終わらねえ
Dialogue: 0,0:08:53.85,0:08:57.21,Main-207+,,0,0,0,,ばあちゃん　ばあちゃん\Nアクア･ラグナだ！
Comment: 0,0:08:57.21,0:08:57.85,Main-207+,,0,0,0,,ニャー
Dialogue: 0,0:08:57.85,0:09:00.19,Main-207+,,0,0,0,,おっ　早速来たかい
Dialogue: 0,0:09:00.19,0:09:01.56,Main-207+,,0,0,0,,チムニー　ちょっと見せて
Dialogue: 0,0:09:06.78,0:09:07.74,Main-207+,,0,0,0,,ヤバい！
Dialogue: 0,0:09:08.28,0:09:11.20,Main-207+,,0,0,0,,ココロさん\Nこんな時に運転室から離れていいの？
Dialogue: 0,0:09:11.20,0:09:13.53,Main-207+,,0,0,0,,どうにかして　あの高波を…
Dialogue: 0,0:09:14.41,0:09:15.41,Main-207+,,0,0,0,,言ったろ
Dialogue: 0,0:09:15.41,0:09:17.87,Main-207+,,0,0,0,,ロケットマンは制御不能
Dialogue: 0,0:09:17.87,0:09:21.75,Main-207+,,0,0,0,,運転しようにも\Nブレーキも何にも利きゃあしねえんら
Dialogue: 0,0:09:22.12,0:09:25.38,Main-207+,,0,0,0,,あたしの仕事は列車を線路にのせるまで
Dialogue: 0,0:09:25.96,0:09:28.76,Main-207+,,0,0,0,,従って\N列車は常にフルスロットル
Dialogue: 0,0:09:29.26,0:09:31.63,Main-207+,,0,0,0,,もう誰にも止められねえんら！
Dialogue: 0,0:09:31.63,0:09:32.76,Main-207+,,0,0,0,,ウソ…
Dialogue: 0,0:09:32.76,0:09:33.64,Main-207+,,0,0,0,,ルフィ！
Comment: 0,0:09:33.97,0:09:35.76,Main-207+,,0,0,0,,このままじゃ列車が大波に
Comment: 0,0:09:35.76,0:09:37.39,Main-207+,,0,0,0,,ねえルフィってば…
Dialogue: 0,0:09:33.97,0:09:37.39,Main-207+,,0,0,0,,このままじゃ列車が大波に…\Nねえ　ルフィってば…
Dialogue: 0,0:09:41.23,0:09:43.85,Main-207+,,0,0,0,,せっかく同じ方向向いてるもんが
Dialogue: 0,0:09:43.85,0:09:46.52,Main-207+,,0,0,0,,バラバラに戦っちゃ意味がねえ
Dialogue: 0,0:09:46.52,0:09:47.82,Main-207+,,0,0,0,,ああ
Dialogue: 0,0:09:47.82,0:09:49.19,Main-207+,,0,0,0,,そうだな
Dialogue: 0,0:09:51.20,0:09:53.66,Main-207+,,0,0,0,,いいか　俺たちは同志だ
Dialogue: 0,0:09:54.12,0:09:55.62,Main-207+,,0,0,0,,先に出た海列車には
Dialogue: 0,0:09:56.16,0:09:58.16,Main-207+,,0,0,0,,俺たちの仲間も乗り込んでる
Dialogue: 0,0:09:58.16,0:10:00.62,Main-207+,,0,0,0,,戦力はまだまだ上がる
Dialogue: 0,0:10:03.67,0:10:04.92,Main-207+,,0,0,0,,お前ら！
Dialogue: 0,0:10:04.92,0:10:07.38,Main-207+,,0,0,0,,大波なんかにやられんな！
Dialogue: 0,0:10:07.38,0:10:10.05,Main-207+,,0,0,0,,全員目的を果たすんだ！
Dialogue: 0,0:10:10.42,0:10:11.55,Main-207+,,0,0,0,,行くぞーっ！
Dialogue: 0,0:10:11.55,0:10:14.84,Main-207+,,0,0,0,,–　おう！\N–　おう！
Dialogue: 0,0:10:17.14,0:10:18.26,Main-207+,,0,0,0,,さあおめえら！
Dialogue: 0,0:10:18.26,0:10:20.68,Main-207+,,0,0,0,,この波何とかしてみせな！
Dialogue: 0,0:10:20.68,0:10:24.27,Main-207+,,0,0,0,,よーし！とにかく\Nありったけの大砲を波に撃ち込むんだ！
Dialogue: 0,0:10:24.27,0:10:27.23,Main-207+,,0,0,0,,うお～っ\N大砲なら任しとけ！
Dialogue: 0,0:10:27.57,0:10:30.15,Main-207+,,0,0,0,,フランキー一家！波にひるむな！
Dialogue: 0,0:10:30.48,0:10:31.86,Main-207+,,0,0,0,,大砲用意！
Dialogue: 0,0:10:31.86,0:10:33.07,Main-207+,,0,0,0,,–　ラジャー！\N–　ラジャー！
Dialogue: 0,0:10:34.70,0:10:36.37,Main-207+,,0,0,0,,もたもたすんな！
Dialogue: 0,0:10:36.37,0:10:38.37,Main-207+,,0,0,0,,–　おう！\N–　おう！
Dialogue: 0,0:10:49.63,0:10:51.26,Main-207+,,0,0,0,,鳴った　子電伝虫
Dialogue: 0,0:11:07.40,0:11:09.11,Main-207+,,0,0,0,,おい　お前
Dialogue: 0,0:11:09.11,0:11:11.23,Main-207+,,0,0,0,,はっ！Ｔボーン大佐
Dialogue: 0,0:11:11.57,0:11:13.61,Main-207+,,0,0,0,,どうした？その腕の傷
Dialogue: 0,0:11:15.11,0:11:15.95,Main-207+,,0,0,0,,ああ
Dialogue: 0,0:11:15.95,0:11:19.95,Main-207+,,0,0,0,,こ…　これはさっき\N虫に刺されてかいたら血が…
Dialogue: 0,0:11:19.95,0:11:22.41,Main-207+,,0,0,0,,いかん！すぐに止血を
Dialogue: 0,0:11:24.75,0:11:26.37,Main-207+,,0,0,0,,これで間に合わせよう
Dialogue: 0,0:11:26.37,0:11:28.88,Main-207+,,0,0,0,,そ…　そんな\N大切なマントを！
Dialogue: 0,0:11:30.59,0:11:31.96,Main-207+,,0,0,0,,これでよい
Dialogue: 0,0:11:31.96,0:11:36.68,Main-207+,,0,0,0,,部下が血を流し\N傷つくのは私の心だ
Dialogue: 0,0:11:37.72,0:11:39.05,Main-207+,,0,0,0,,Ｔボーン大佐…
Dialogue: 0,0:11:40.39,0:11:46.89,Main-207+,,0,0,0,,{\an8}今日も平和で\N世界が優しく　ありますように
Dialogue: 0,0:11:50.02,0:11:52.40,Thoughts-207+,,0,0,0,,–　顔がめっちゃ怖い…\N–　顔がめっちゃ怖い…
Dialogue: 0,0:11:53.03,0:11:53.94,Main-207+,,0,0,0,,大佐！
Dialogue: 0,0:11:53.94,0:11:55.32,Main-207+,,0,0,0,,何！？
Dialogue: 0,0:11:56.45,0:11:59.49,Main-207+,,0,0,0,,ま…　まだ何も言ってませんが…
Dialogue: 0,0:11:59.82,0:12:04.87,Main-207+,,0,0,0,,私にできることなら\Nたとえこの身が滅びようとも
Dialogue: 0,0:12:06.58,0:12:08.04,Main-207+,,0,0,0,,あ…　いえ…
Dialogue: 0,0:12:08.58,0:12:11.84,Main-207+,,0,0,0,,第６第７車両の役人たちが全滅しています
Dialogue: 0,0:12:11.84,0:12:17.17,Main-207+,,0,0,0,,{\t(5146,0,1,\c&H000000&\3c&H000000&\4c&H000000&)}さらに第６車両に勾留中の\N罪人２人の消息も不明です
Dialogue: 0,0:12:17.34,0:12:18.55,Main-207+,,0,0,0,,何だと！？
Dialogue: 0,0:12:19.68,0:12:23.56,Main-207+,,0,0,0,,侵入者がいるのか\N罪人たちの自力の脱走か何も分かりません
Dialogue: 0,0:12:23.56,0:12:24.93,Main-207+,,0,0,0,,何ということだ
Comment: 0,0:12:24.93,0:12:27.81,Main-207+,,0,0,0,,すぐに人命救助！さらにこの事態を
Comment: 0,0:12:27.81,0:12:29.56,Main-207+,,0,0,0,,全車両に報告せよ！
Dialogue: 0,0:12:24.93,0:12:29.56,Main-207+,,0,0,0,,すぐに人命救助！\Nさらにこの事態を全車両に報告せよ！
Dialogue: 0,0:12:29.56,0:12:30.52,Main-207+,,0,0,0,,はっ！
Dialogue: 0,0:12:32.02,0:12:33.15,Main-207+,,0,0,0,,ナミさん
Dialogue: 0,0:12:33.15,0:12:34.28,Main-207+,,0,0,0,,ナミさん聞こえるか？
Dialogue: 0,0:12:34.28,0:12:36.11,Main-207+,,0,0,0,,{\i1}うん！サンジ君ね
Dialogue: 0,0:12:36.53,0:12:40.36,Main-207+,,0,0,0,,こちらはちょっと\Nまずいことになってきた
Dialogue: 0,0:12:40.36,0:12:41.95,Main-207+,,0,0,0,,{\i1}まずいこと？
Dialogue: 0,0:12:42.87,0:12:45.33,Main-207+,,0,0,0,,{\i1}サンジ君何？今の声
Dialogue: 0,0:12:45.33,0:12:47.33,Main-207+,,0,0,0,,{\i1}ねえどうしたの？サンジ君！
Dialogue: 0,0:12:47.33,0:12:48.79,Secondary-207+,,0,0,0,,{\an8}おいおい
Dialogue: 0,0:12:50.29,0:12:52.46,Main-207+,,0,0,0,,ああ　アホのせいで…
Dialogue: 0,0:12:52.46,0:12:54.00,Main-207+,,0,0,0,,{\i1}ア…　アホ？
Dialogue: 0,0:12:54.96,0:12:57.09,Main-207+,,0,0,0,,{\i1}わっ！また！何？
Dialogue: 0,0:12:57.09,0:12:58.34,Main-207+,,0,0,0,,{\i1}何が起こってんの？
Dialogue: 0,0:12:58.34,0:13:00.05,Main-207+,,0,0,0,,{\i1}ねえ大丈夫？サンジ君！
Dialogue: 0,0:13:00.05,0:13:01.64,Main-207+,,0,0,0,,{\i1}アホって誰？
Dialogue: 0,0:12:56.46,0:12:58.34,Secondary-207+,,0,0,0,,{\an8}大丈夫か？お前
Dialogue: 0,0:12:58.34,0:13:00.05,Secondary-207+,,0,0,0,,{\an8}なんてな
Dialogue: 0,0:13:00.05,0:13:01.64,Secondary-207+,,0,0,0,,{\an8}一死だぞ　おい
Dialogue: 0,0:13:01.64,0:13:03.93,Main-207+,,0,0,0,,いや　アホ２人だった
Dialogue: 0,0:13:07.35,0:13:09.56,Main-207+,,0,0,0,,{\fad(150,150)}デミキャノン！
Dialogue: 0,0:13:14.40,0:13:15.65,Main-207+,,0,0,0,,–　食らえ！\N–　食らえ！
Dialogue: 0,0:13:17.86,0:13:19.82,Main-207+,,0,0,0,,穴も開かねえ
Dialogue: 0,0:13:19.82,0:13:21.20,Main-207+,,0,0,0,,当然か…
Dialogue: 0,0:13:21.20,0:13:23.28,Main-207+,,0,0,0,,ダメだダメだ！そんなんじゃ！
Dialogue: 0,0:13:23.82,0:13:25.41,Main-207+,,0,0,0,,みんな下がってろ！
Dialogue: 0,0:13:25.41,0:13:28.70,Main-207+,,0,0,0,,フランキー一家特製大砲に任しとけ！
Dialogue: 0,0:13:30.16,0:13:32.67,Main-207+,,0,0,0,,目標アクア･ラグナ！
Dialogue: 0,0:13:33.29,0:13:34.00,Main-207+,,0,0,0,,撃て！
Dialogue: 0,0:13:34.00,0:13:36.46,Main-207+,,0,0,0,,{\fad(150,150)}スーパースクラップ砲！
Dialogue: 0,0:13:41.43,0:13:42.97,Main-207+,,0,0,0,,クッソ…
Dialogue: 0,0:13:42.97,0:13:44.30,Main-207+,,0,0,0,,ひるむな！
Dialogue: 0,0:13:44.30,0:13:46.31,Main-207+,,0,0,0,,どんどん撃ち込め！
Dialogue: 0,0:13:52.56,0:13:54.23,Secondary-207+,,0,0,0,,{\c&H000000&\3c&H000000&\4c&H000000&\t(19,816,1,\c&HFFFFFF&\3c&H000000&\4c&H000000&)}砲弾の補充を！
Dialogue: 0,0:13:54.23,0:13:54.90,Secondary-207+,,0,0,0,,分かった
Dialogue: 0,0:13:54.90,0:13:57.44,Secondary-207+,,0,0,0,,正面を狙え！一点集中だ！
Dialogue: 0,0:13:57.44,0:14:00.44,Main-207+,,0,0,0,,いっちゃえ～！\Nチューチューだあ！
Dialogue: 0,0:14:01.28,0:14:02.24,Main-207+,,0,0,0,,頑張んな
Dialogue: 0,0:14:02.61,0:14:07.87,Main-207+,,0,0,0,,線路は多少浮上するが\Nアクア･ラグナは越えられない
Dialogue: 0,0:14:07.87,0:14:12.12,Main-207+,,0,0,0,,直撃すりゃ\Nあこのロケットマンもひとったまりもねえや
Dialogue: 0,0:14:13.25,0:14:15.83,Main-207+,,0,0,0,,俺たち死んじまうのか？
Dialogue: 0,0:14:16.42,0:14:19.05,Main-207+,,0,0,0,,だから言ったろ\N覚悟を決めなって
Dialogue: 0,0:14:22.05,0:14:24.43,Main-207+,,0,0,0,,ええっ！？私たちも？
Comment: 0,0:14:24.43,0:14:25.64,Main-207+,,0,0,0,,ニャー
Dialogue: 0,0:14:25.64,0:14:26.72,Main-207+,,0,0,0,,そう…
Dialogue: 0,0:14:26.72,0:14:28.43,Main-207+,,0,0,0,,ロビンは　まだ…
Dialogue: 0,0:14:30.31,0:14:33.64,Main-207+,,0,0,0,,{\i1}しっかし\Nそっちはずいぶんにぎやかだな
Dialogue: 0,0:14:33.64,0:14:35.60,Main-207+,,0,0,0,,ねえ　サンジ君
Dialogue: 0,0:14:36.19,0:14:38.86,Main-207+,,0,0,0,,ロビンの行動の訳と…
Dialogue: 0,0:14:39.65,0:14:42.82,Main-207+,,0,0,0,,あたしたちの今の状況を…
Dialogue: 0,0:14:42.82,0:14:45.82,Main-207+,,0,0,0,,うるさーい！
Dialogue: 0,0:14:47.03,0:14:48.83,Main-207+,,0,0,0,,いい？サンジ君
Dialogue: 0,0:14:48.83,0:14:53.96,Main-207+,,0,0,0,,今からロビンの行動の理由と\Nあたしたちの今の状況を全て話すから
Dialogue: 0,0:14:53.96,0:14:55.08,Main-207+,,0,0,0,,よく聞いて
Dialogue: 0,0:14:56.79,0:14:58.67,Main-207+,,0,0,0,,ぶつかるぞー！
Dialogue: 0,0:14:58.67,0:15:00.21,Main-207+,,0,0,0,,ヤベえ　死ぬ！
Dialogue: 0,0:15:00.21,0:15:01.55,Main-207+,,0,0,0,,死んじまう
Dialogue: 0,0:15:01.55,0:15:03.88,Main-207+,,0,0,0,,泣き言言う暇があったら撃て！
Dialogue: 0,0:15:03.88,0:15:05.84,Secondary-207+,,0,0,0,,活路を開け！
Dialogue: 0,0:15:09.51,0:15:11.10,Main-207+,,0,0,0,,おい　ルフィ
Dialogue: 0,0:15:11.10,0:15:12.31,Main-207+,,0,0,0,,ああ…
Dialogue: 0,0:15:12.81,0:15:14.81,Main-207+,,0,0,0,,行くぞ　ゾロ
Dialogue: 0,0:15:25.28,0:15:27.49,Main-207+,,0,0,0,,おい！正面に撃ち続けろ！
Dialogue: 0,0:15:27.49,0:15:29.41,Main-207+,,0,0,0,,お前ら何する気だ！
Dialogue: 0,0:15:38.42,0:15:40.04,Main-207+,,0,0,0,,大砲を…
Dialogue: 0,0:15:41.80,0:15:42.63,Main-207+,,0,0,0,,撃つ
Dialogue: 0,0:15:51.81,0:15:54.10,Main-207+,,0,0,0,,108を２つでいくつだ？
Dialogue: 0,0:15:54.93,0:15:56.35,Main-207+,,0,0,0,,216
Dialogue: 0,0:15:56.35,0:15:58.48,Main-207+,,0,0,0,,216って
Dialogue: 0,0:15:58.48,0:16:00.98,Main-207+,,0,0,0,,長いし言いにくいぞそれ
Dialogue: 0,0:16:00.98,0:16:03.23,Main-207+,,0,0,0,,なら　何でもいいよ
Dialogue: 0,0:16:03.94,0:16:06.57,Main-207+,,0,0,0,,な…　何やってんだ？あいつら
Dialogue: 0,0:16:06.57,0:16:09.20,Main-207+,,0,0,0,,丸腰と刀でどうしようってんだよ
Dialogue: 0,0:16:09.20,0:16:10.91,Main-207+,,0,0,0,,撃ち続けろって言ってたぞ
Dialogue: 0,0:16:10.91,0:16:12.87,Main-207+,,0,0,0,,何でもいいから援護しろ！
Dialogue: 0,0:16:13.24,0:16:15.25,Main-207+,,0,0,0,,–　おう！\N–　おう！
Dialogue: 0,0:16:15.79,0:16:18.67,Main-207+,,0,0,0,,よし！じゃあ300！
Dialogue: 0,0:16:19.29,0:16:20.67,Main-207+,,0,0,0,,ああ
Dialogue: 0,0:16:20.67,0:16:22.67,Main-207+,,0,0,0,,{\fad(150,150)}ゴムゴムの～
Dialogue: 0,0:16:22.67,0:16:25.01,Main-207+,,0,0,0,,{\fad(150,150)}三百ポンド…
Dialogue: 0,0:16:27.09,0:16:29.59,Main-207+,,0,0,0,,–　ぶつかる～っ！\N–　ぶつかる～っ！
Dialogue: 0,0:16:36.85,0:16:38.27,Main-207+,,0,0,0,,{\fad(150,150)}–　キャノン！\N–　キャノン！
Dialogue: 0,0:17:30.61,0:17:35.78,Main-207+,,0,0,0,,–　ぬ…　抜けた～っ！\N–　ぬ…　抜けた～っ！
Dialogue: 0,0:17:41.83,0:17:46.34,Main-207+,,0,0,0,,–　アクア･ラグナを抜けたぞ～っ！\N–　アクア･ラグナを抜けたぞ～っ！
Dialogue: 0,0:17:49.67,0:17:51.84,Main-207+,,0,0,0,,死ぬかと思った
Comment: 0,0:18:01.06,0:18:02.60,Main-207+,,0,0,0,,イエ～イ！
Comment: 0,0:18:14.78,0:18:15.87,Main-207+,,0,0,0,,った…
Dialogue: 0,0:18:15.87,0:18:18.24,Main-207+,,0,0,0,,{\i1}おい　ナミさん大丈夫かい？
Dialogue: 0,0:18:18.24,0:18:20.66,Main-207+,,0,0,0,,ええ　何とか…
Dialogue: 0,0:18:22.50,0:18:24.25,Main-207+,,0,0,0,,こりゃ大したもんら
Dialogue: 0,0:18:24.25,0:18:27.63,Main-207+,,0,0,0,,だてじゃねえようらね　海賊ども
Dialogue: 0,0:18:27.96,0:18:30.34,Main-207+,,0,0,0,,敵に回すと恐ろしいが
Dialogue: 0,0:18:30.34,0:18:34.72,Main-207+,,0,0,0,,味方となると\Nこれ以上に頼もしいヤツらはいねえな
Dialogue: 0,0:18:34.72,0:18:35.76,Main-207+,,0,0,0,,–　麦わら～！\N–　麦わら～！
Dialogue: 0,0:18:36.26,0:18:39.01,Main-207+,,0,0,0,,さすがに死を覚悟したぜ
Dialogue: 0,0:18:39.01,0:18:40.35,Main-207+,,0,0,0,,なんてヤツらだ
Dialogue: 0,0:18:40.72,0:18:43.06,Main-207+,,0,0,0,,気ぃ抜くんじゃねえよおめえら
Dialogue: 0,0:18:43.06,0:18:45.81,Main-207+,,0,0,0,,嵐はまだ抜けちゃいねえんら
Dialogue: 0,0:18:45.81,0:18:45.85,Main-207+,,0,0,0,,嵐はまだ抜けちゃいねえんら
Dialogue: 0,0:18:45.85,0:18:47.56,Main-207+,,0,0,0,,–　おう！\N–　おう！
Dialogue: 0,0:18:47.56,0:18:50.03,Main-207+,,0,0,0,,もう怖いもんねえぞ！
Dialogue: 0,0:18:54.66,0:18:56.28,Main-207+,,0,0,0,,面白かったあ！
Dialogue: 0,0:18:56.28,0:18:59.03,Main-207+,,0,0,0,,麦わら！すごいわいな
Dialogue: 0,0:18:59.03,0:19:02.29,Main-207+,,0,0,0,,あんたたち\N人間業じゃないわいな
Dialogue: 0,0:19:04.29,0:19:06.38,Main-207+,,0,0,0,,ああ　悪い悪い
Dialogue: 0,0:19:06.38,0:19:08.00,Main-207+,,0,0,0,,ルフィ！こっち来て
Dialogue: 0,0:19:14.38,0:19:15.63,Main-207+,,0,0,0,,サンジ君
Dialogue: 0,0:19:16.84,0:19:18.05,Main-207+,,0,0,0,,ようルフィか
Dialogue: 0,0:19:18.05,0:19:19.93,Main-207+,,0,0,0,,{\i1}おうサンジ！
Dialogue: 0,0:19:19.93,0:19:21.52,Main-207+,,0,0,0,,{\i1}そっちはどうだ？
Dialogue: 0,0:19:21.52,0:19:22.89,Main-207+,,0,0,0,,{\i1}ロビンは？
Dialogue: 0,0:19:22.89,0:19:26.56,Main-207+,,0,0,0,,ロビンちゃんは\Nまだ捕まったままだ
Dialogue: 0,0:19:27.06,0:19:29.69,Main-207+,,0,0,0,,ナミさんから今事情を聞いたところさ
Dialogue: 0,0:19:30.11,0:19:32.36,Main-207+,,0,0,0,,全部…　聞いた
Dialogue: 0,0:19:32.36,0:19:33.82,Main-207+,,0,0,0,,そっか
Dialogue: 0,0:19:34.36,0:19:35.28,Main-207+,,0,0,0,,うん
Dialogue: 0,0:19:35.99,0:19:38.32,Main-207+,,0,0,0,,まあ　そういうことだ
Dialogue: 0,0:19:39.12,0:19:41.03,Main-207+,,0,0,0,,いいぞ　暴れても
Dialogue: 0,0:19:41.03,0:19:43.33,Main-207+,,0,0,0,,ルフィムチャ言うな！
Dialogue: 0,0:19:43.33,0:19:45.66,Main-207+,,0,0,0,,俺たちが追いつくまで\N待たせろ！
Dialogue: 0,0:19:46.50,0:19:48.42,Main-207+,,0,0,0,,{\i1}おいコック！聞こえるか？
Dialogue: 0,0:19:48.42,0:19:50.34,Main-207+,,0,0,0,,{\i1}その列車にはヤベえヤツらが…
Dialogue: 0,0:19:50.34,0:19:51.63,Main-207+,,0,0,0,,{\i1}いいって
Dialogue: 0,0:19:51.63,0:19:52.75,Main-207+,,0,0,0,,ゾロ
Dialogue: 0,0:19:53.17,0:19:55.42,Main-207+,,0,0,0,,お前なら　どうした？
Dialogue: 0,0:19:56.55,0:20:02.22,Main-207+,,0,0,0,,ロビンがウソをついてまで\N俺たちを救うために捕まったと聞かされて
Dialogue: 0,0:20:02.72,0:20:04.81,Main-207+,,0,0,0,,おめえはじっとしてられんのか？
Dialogue: 0,0:20:07.64,0:20:09.48,Main-207+,,0,0,0,,止めたって無駄だ
Dialogue: 0,0:20:10.86,0:20:12.44,Main-207+,,0,0,0,,分かってんなあ
Dialogue: 0,0:20:12.44,0:20:14.53,Main-207+,,0,0,0,,おう　マリモ君
Dialogue: 0,0:20:14.53,0:20:16.53,Main-207+,,0,0,0,,俺を心配してくれてんのかい？
Dialogue: 0,0:20:16.53,0:20:17.78,Main-207+,,0,0,0,,{\i1}するかバカ！
Dialogue: 0,0:20:18.16,0:20:19.70,Main-207+,,0,0,0,,だが残念
Dialogue: 0,0:20:20.53,0:20:24.08,Main-207+,,0,0,0,,そんなロビンちゃんの\N気持ちを聞かされちゃあ
Dialogue: 0,0:20:25.08,0:20:27.62,Main-207+,,0,0,0,,たとえ船長命令でも
Dialogue: 0,0:20:27.62,0:20:30.04,Main-207+,,0,0,0,,俺は止まる気はねえんで！
Dialogue: 0,0:20:32.00,0:20:34.13,Main-207+,,0,0,0,,何で壊しちまうんだよ！
Dialogue: 0,0:20:34.13,0:20:37.34,Main-207+,,0,0,0,,俺も麦わらに\N聞きてえことがあったのに！
Dialogue: 0,0:20:37.34,0:20:39.43,Main-207+,,0,0,0,,あ？知るか
Dialogue: 0,0:20:40.01,0:20:41.76,Main-207+,,0,0,0,,前もって言わねえからだ
Dialogue: 0,0:20:41.76,0:20:43.93,Main-207+,,0,0,0,,言わなくても当然だろうが！
Dialogue: 0,0:20:43.93,0:20:45.68,Main-207+,,0,0,0,,すかしてんじゃねえよ！
Dialogue: 0,0:20:45.68,0:20:47.39,Main-207+,,0,0,0,,すかしてるよ
Dialogue: 0,0:20:50.65,0:20:52.65,Main-207+,,0,0,0,,大丈夫かしら…
Dialogue: 0,0:20:52.65,0:20:55.65,Main-207+,,0,0,0,,ばあさん\N列車もっとスピード出してくれ
Dialogue: 0,0:20:55.65,0:20:56.65,Main-207+,,0,0,0,,もっと？
Dialogue: 0,0:20:56.65,0:21:00.91,Main-207+,,0,0,0,,ああ！もっとビュ～ンと！
Dialogue: 0,0:21:02.62,0:21:04.37,Main-207+,,0,0,0,,安心しな
Dialogue: 0,0:21:04.37,0:21:08.21,Main-207+,,0,0,0,,もう既に船の限界速度を超えてるよ
Dialogue: 0,0:21:10.62,0:21:14.25,Main-207+,,0,0,0,,もう自力じゃ止まれねえほどにね
Dialogue: 0,0:21:19.93,0:21:22.26,Main-207+,,0,0,0,,俺が一味を抜けてる間に
Dialogue: 0,0:21:22.93,0:21:25.35,Main-207+,,0,0,0,,そんなことが起きていたのか…
Dialogue: 0,0:21:26.06,0:21:28.31,Main-207+,,0,0,0,,ロビンちゃんはメリー号の件も
Dialogue: 0,0:21:28.31,0:21:32.65,Main-207+,,0,0,0,,ルフィとお前が大ゲンカしたことも\N何にも知らねえ
Dialogue: 0,0:21:36.48,0:21:41.49,Main-207+,,0,0,0,,お前を含めた俺たち６人が\N全員無事でいられるようにと
Dialogue: 0,0:21:41.49,0:21:46.49,Main-207+,,0,0,0,,ロビンちゃんは自分の身を犠牲にして\Nあいつらの言いなりになって行ったんだ
Dialogue: 0,0:21:47.24,0:21:49.04,Main-207+,,0,0,0,,俺たちのために
Dialogue: 0,0:21:51.79,0:21:55.50,Main-207+,,0,0,0,,いい　話じゃねえか…
Dialogue: 0,0:21:57.75,0:21:59.76,Main-207+,,0,0,0,,何でお前が泣いてんだ
Dialogue: 0,0:21:59.76,0:22:02.51,Main-207+,,0,0,0,,バカ！泣いてねえよ
Dialogue: 0,0:22:04.47,0:22:07.18,Main-207+,,0,0,0,,ちきしょう！何てこったい
Dialogue: 0,0:22:07.18,0:22:12.06,Main-207+,,0,0,0,,ニコ･ロビンってのは　世間に言わせりゃ\N冷酷非道の悪魔の女のはず
Dialogue: 0,0:22:12.06,0:22:16.57,Main-207+,,0,0,0,,それがどうだ！\Nそのほろり仲間慕情！
Dialogue: 0,0:22:17.44,0:22:19.86,Main-207+,,0,0,0,,ロビンちゃんは目と鼻の先にいる
Dialogue: 0,0:22:20.19,0:22:22.40,Main-207+,,0,0,0,,とにかく俺は救出に行くぞ！
Dialogue: 0,0:22:22.40,0:22:23.36,Main-207+,,0,0,0,,よし！
Dialogue: 0,0:22:23.36,0:22:26.37,Main-207+,,0,0,0,,このフランキー一家棟梁\Nフランキー
Dialogue: 0,0:22:26.37,0:22:28.87,Main-207+,,0,0,0,,手を貸すぜ\N眉毛のお兄ちゃん
Dialogue: 0,0:22:28.87,0:22:33.92,Main-207+,,0,0,0,,訳あって実は俺もロビンが政府に\N捕まっちゃあ困る立場にあんのよ
Dialogue: 0,0:22:34.37,0:22:37.88,Main-207+,,0,0,0,,何より\Nそんな人情話聞かされちゃあ…
Dialogue: 0,0:22:37.88,0:22:39.88,Main-207+,,0,0,0,,おい　行くぞ！長っ鼻
Dialogue: 0,0:22:40.42,0:22:41.80,Main-207+,,0,0,0,,俺は…
Dialogue: 0,0:22:42.92,0:22:43.72,Main-207+,,0,0,0,,いいよ
Dialogue: 0,0:22:46.39,0:22:49.14,Main-207+,,0,0,0,,もう俺には関係ねえじゃねえか
Dialogue: 0,0:22:49.14,0:22:52.31,Main-207+,,0,0,0,,いよいよ世界政府そのものが敵になるんだったら
Dialogue: 0,0:22:52.31,0:22:54.23,Main-207+,,0,0,0,,俺は関わりたくねえし
Dialogue: 0,0:22:55.90,0:22:58.48,Main-207+,,0,0,0,,ルフィたちとも\N合流するんだろ？
Dialogue: 0,0:22:59.27,0:23:02.11,Main-207+,,0,0,0,,あれだけたんか切って醜態さらして
Dialogue: 0,0:23:02.11,0:23:04.78,Main-207+,,0,0,0,,どの面下げて\Nお前らと一緒にいられるってんだよ！
Dialogue: 0,0:23:08.49,0:23:10.37,Main-207+,,0,0,0,,ロビンには悪いが
Dialogue: 0,0:23:10.37,0:23:14.08,Main-207+,,0,0,0,,俺にはもう\N助けに行く義理もねえ
Dialogue: 0,0:23:14.46,0:23:16.21,Main-207+,,0,0,0,,俺は一味をやめたんだ！
Dialogue: 0,0:23:22.34,0:23:23.34,Main-207+,,0,0,0,,じゃあな
Dialogue: 0,0:23:25.68,0:23:28.14,Main-207+,,0,0,0,,お…　おい！じゃあなって…
Dialogue: 0,0:23:28.14,0:23:31.77,Main-207+,,0,0,0,,おめえ\Nどこにも逃げ場はねえぞ！
Dialogue: 0,0:23:31.77,0:23:32.77,Main-207+,,0,0,0,,いいよ
Dialogue: 0,0:23:33.39,0:23:34.52,Main-207+,,0,0,0,,ほっとけ
Dialogue: 0,0:23:38.15,0:23:40.40,Main-207+,,0,0,0,,意地張りやがって…
Dialogue: 0,0:23:41.36,0:23:43.28,Main-207+,,0,0,0,,くまなく捜せー！
Dialogue: 0,0:23:43.28,0:23:45.74,Main-207+,,0,0,0,,何か証拠が出るはずだ！
Dialogue: 0,0:23:46.57,0:23:47.36,Main-207+,,0,0,0,,こ…
Dialogue: 0,0:23:47.70,0:23:48.87,Main-207+,,0,0,0,,これはいかん
Dialogue: 0,0:23:50.83,0:23:52.29,Main-207+,,0,0,0,,これで間に合わせよう
Dialogue: 0,0:23:54.12,0:23:58.21,Main-207+,,0,0,20,,ワンゼさん　列車内　今もう大変で…
Dialogue: 0,0:23:58.21,0:23:59.33,Main-207+,,0,0,20,,うるせえ！
Dialogue: 0,0:23:59.33,0:24:01.80,Main-207+,,0,0,20,,もう大変なのはこっちだ！
Dialogue: 0,0:24:03.96,0:24:06.80,Main-207+,,0,0,0,,ネロさん！罪人たちが脱走を
Dialogue: 0,0:24:22.86,0:24:24.07,Main-207+,,0,0,0,,見つけた！
Dialogue: 0,0:24:24.07,0:24:25.78,Main-207+,,0,0,0,,あっ　しまった！
Dialogue: 0,0:24:25.78,0:24:27.20,Main-207+,,0,0,0,,{\fad(150,150)}メタリック･スター！
Dialogue: 0,0:24:34.49,0:24:36.12,Main-207+,,0,0,0,,–　誰だ！\N–　誰だ！
Dialogue: 0,0:24:43.63,0:24:45.76,Main-207+,,0,0,0,,話は全て彼から聞いたよ
Dialogue: 0,0:24:46.13,0:24:48.76,Main-207+,,0,0,0,,お嬢さんを１人助けたいそうだな
Dialogue: 0,0:24:49.26,0:24:52.76,Main-207+,,0,0,0,,そんな君たちに手を貸すのに\N理由はいらない
Dialogue: 0,0:24:53.26,0:24:55.22,Main-207+,,0,0,0,,私も共に戦おう！
Dialogue: 0,0:25:02.02,0:25:03.44,Main-207+,,0,0,0,,私の名は
Dialogue: 0,0:25:04.36,0:25:06.03,Main-207+,,0,0,0,,そげキング！
Comment: 0,0:00:00.00,0:00:00.00,Main-207+,,0,0,0,,{=11}===============================DIALOGUE============================
