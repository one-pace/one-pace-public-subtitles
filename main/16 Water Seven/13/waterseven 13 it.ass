Comment: 0,0:00:00.00,0:00:00.00,Main-207+,,0,0,0,,{=10}===============================DIALOGUE============================
Dialogue: 0,0:01:55.48,0:01:57.86,Main-207+,,0,0,0,,Ehi! Ehi, aspetta, Franky!
Dialogue: 0,0:01:58.39,0:02:00.22,Main-207+,,0,0,0,,Eh? Cos–?!
Dialogue: 0,0:02:00.70,0:02:02.49,Main-207+,,0,0,0,,Mettiti almeno i pantaloni!
Dialogue: 0,0:02:02.49,0:02:05.35,Main-207+,,0,0,0,,Che cavolo... \NNon hai ancora imparato la lezione?
Dialogue: 0,0:02:05.35,0:02:08.94,Main-207+,,0,0,0,,Se vai in città in costume da bagno, verrai \Nnuovamente additato come pervertito, no?!{meh, di suo è tipo che si causerà un nuovo scandalo di perversione? idk, mi suonava male in ogni altro modo... in ogni caso CPS}
Dialogue: 0,0:02:08.94,0:02:12.42,Main-207+,,0,0,0,,{\q2}Ma che rottura, solo per andare a fare compere!
Dialogue: 0,0:02:12.42,0:02:14.41,Main-207+,,0,0,0,,Dai! Sbrigati e vai!
Dialogue: 0,0:02:14.41,0:02:19.51,Main-207+,,0,0,0,,Che diavolo... Che bisogno c'era di un menu \Ncelebrativo solo perché sarà assolto?
Dialogue: 0,0:02:19.51,0:02:22.12,Main-207+,,0,0,0,,Il signor Tom era innocente sin dal principio!
Dialogue: 0,0:02:24.12,0:02:25.08,Main-207+,,0,0,0,,Bene, allora...
Dialogue: 0,0:02:27.91,0:02:31.24,Main-207+,,0,0,0,,Forza, signor Tom, Iceburg! Svegliatevi!
Dialogue: 0,0:02:31.24,0:02:33.22,Main-207+,,0,0,0,,Oggi c'è l'udienza!
Dialogue: 0,0:02:33.22,0:02:35.89,Main-207+,,0,0,0,,Va' a sentire la tua sentenza alla svelta!
Dialogue: 0,0:02:38.50,0:02:40.04,Main-207+,,0,0,0,,Veloci, andiamo al porto!{sbrighiamoci ad andare al porto}
Dialogue: 0,0:02:40.04,0:02:41.85,Main-207+,,0,0,0,,Oggi daranno la sentenza al signor Tom!
Dialogue: 0,0:02:49.90,0:02:52.40,Main-207+,,0,0,0,,{\q2}Sembra ci sia grande interesse per quest'udienza.
Dialogue: 0,0:02:52.74,0:02:56.29,Main-207+,,0,0,0,,Moltissimi spettatori stanno salendo a bordo.
Dialogue: 0,0:02:56.29,0:02:58.32,Main-207+,,0,0,0,,Giudice, è andato a vedere il treno marino?
Dialogue: 0,0:02:58.76,0:03:00.94,Main-207+,,0,0,0,,Sì, ci sono salito una volta.
Dialogue: 0,0:03:00.94,0:03:04.28,Main-207+,,0,0,0,,È proprio ben fatto, un ottimo risultato.
Dialogue: 0,0:03:04.28,0:03:06.59,Main-207+,,0,0,0,,Ora che le quattro isole sono connesse,
Dialogue: 0,0:03:06.59,0:03:10.04,Main-207+,,0,0,0,,nessuno avrà da ridire sulla sua assoluzione.
Dialogue: 0,0:03:10.97,0:03:11.99,Main-207+,,0,0,0,,Tom non è ancora arrivato?{cps}
Dialogue: 0,0:03:11.99,0:03:13.63,Main-207+,,0,0,0,,Non vedo l'ora inizi!{oppure "ma quando inizia?"}
Dialogue: 0,0:03:14.24,0:03:16.68,Main-207+,,0,0,0,,Veloce o i posti per il pubblico termineranno!{ew}
Dialogue: 0,0:03:16.68,0:03:19.85,Main-207+,,0,0,0,,Già! Devo vedere con i\N miei occhi la sua assoluzione!
Dialogue: 0,0:03:20.15,0:03:24.43,Main-207+,,0,0,0,,Ma che nostalgia... \NSono già passati quattordici anni, eh?
Dialogue: 0,0:03:37.11,0:03:39.03,Main-207+,,0,0,0,,Ma cos'è quest'esplosione?!
Dialogue: 0,0:03:45.83,0:03:48.71,Main-207+,,0,0,0,,Scendete dalla nave! Sbrigatevi!
Dialogue: 0,0:03:48.71,0:03:51.29,Main-207+,,0,0,0,,Ma che succede?! È un attacco pirata?!
Dialogue: 0,0:03:54.42,0:03:57.22,Main-207+,,0,0,0,,Maledizione! Ma da dove viene quest'attacco?!
Dialogue: 0,0:03:57.22,0:03:59.58,Main-207+,,0,0,0,,Eh? Laggiù!
Dialogue: 0,0:04:00.15,0:04:01.68,Main-207+,,0,0,0,,Ma cos'è quella flotta?!
Dialogue: 0,0:04:02.97,0:04:03.66,Main-207+,,0,0,0,,Ah–
Dialogue: 0,0:04:08.89,0:04:12.39,Main-207+,,0,0,0,,Non ho mai visto quelle corazzate! \NDi che ciurma pirata sono?!
Dialogue: 0,0:04:14.15,0:04:17.24,Main-207+,,0,0,0,,Ma che cavolo succede?! \NCosa sono quelle navi piene di armi?!
Dialogue: 0,0:04:20.80,0:04:23.36,Main-207+,,0,0,0,,– Allontanatevi dal porto!\N– Veloci, scappate!
Dialogue: 0,0:04:23.36,0:04:24.24,Main-207+,,0,0,0,,Veloci!
Dialogue: 0,0:04:24.24,0:04:26.36,Main-207+,,0,0,0,,Correte verso la città!
Dialogue: 0,0:04:26.36,0:04:29.22,Main-207+,,0,0,0,,Aiutatemi! Mio figlio è rimasto schiacciato!
Dialogue: 0,0:04:39.11,0:04:39.97,Main-207+,,0,0,0,,Perché...
Dialogue: 0,0:04:42.29,0:04:43.93,Main-207+,,0,0,0,,Chi è...
Dialogue: 0,0:04:43.93,0:04:46.47,Main-207+,,0,0,0,,L-Le mie...
Dialogue: 0,0:04:46.47,0:04:48.23,Main-207+,,0,0,0,,Chi sta usando le mie navi?!
Dialogue: 0,0:04:48.64,0:04:50.10,Main-207+,,0,0,0,,Signor Tom! Grossi guai!
Dialogue: 0,0:04:50.10,0:04:51.06,Main-207+,,0,0,0,,Eh?
Dialogue: 0,0:04:51.59,0:04:54.08,Main-207+,,0,0,0,,Le navi di Franky stanno \Nattaccando la nave giudiziaria!{cps}
Dialogue: 0,0:04:54.08,0:04:57.57,Main-207+,,0,0,0,,Aspetta un attimo! Non può essere Franky,\N è appena andato in città...
Dialogue: 0,0:04:57.87,0:05:01.44,Main-207+,,0,0,0,,Lo so bene! \NSo che non farebbe mai una cosa simile!
Dialogue: 0,0:05:01.44,0:05:03.53,Main-207+,,0,0,0,,Per questo sono grossi guai, no?!
Dialogue: 0,0:05:03.53,0:05:05.18,Main-207+,,0,0,0,,Andiamo a fermarle, Iceburg!
Dialogue: 0,0:05:05.18,0:05:05.95,Main-207+,,0,0,0,,Sì!
Dialogue: 0,0:05:07.38,0:05:10.58,Thoughts-207+,,0,0,0,,Pirati? O forse membri del governo?
Dialogue: 0,0:05:13.00,0:05:13.84,Main-207+,,0,0,0,,Evacuate!
Dialogue: 0,0:05:14.22,0:05:16.46,Main-207+,,0,0,0,,Non fermatevi! Presto, verso l'interno!{eh, entroterra mi sembra un po' too much vista la situazione... volendo lo si può adattare in un "allontanatevi dalla costa"}
Dialogue: 0,0:05:18.08,0:05:19.70,Main-207+,,0,0,0,,Allontanatevi dal porto!
Dialogue: 0,0:05:19.70,0:05:21.38,Main-207+,,0,0,0,,Mio padre è ancora dentro la nave!
Dialogue: 0,0:05:24.33,0:05:25.18,Thoughts-207+,,0,0,0,,Maledizione!
Dialogue: 0,0:05:25.18,0:05:26.43,Thoughts-207+,,0,0,0,,Non lo perdonerò mai!{generico in realtà, può essere sia uno che tanti}
Dialogue: 0,0:05:29.26,0:05:31.06,Thoughts-207+,,0,0,0,,Maledizione... Ma chi è?!
Dialogue: 0,0:05:31.06,0:05:33.81,Thoughts-207+,,0,0,0,,Chi sta usando le mie navi di testa sua?!
Dialogue: 0,0:05:41.19,0:05:43.99,Main-207+,,0,0,0,,Giudice, veloce! \NLa nave non resisterà ancora a lungo!
Dialogue: 0,0:05:44.79,0:05:47.56,Main-207+,,0,0,0,,Ma cos'è quella flotta di navi?
Dialogue: 0,0:05:49.66,0:05:52.46,Main-207+,,0,0,0,,{\q2}L'attacco alla nave giudiziaria è stato un successo.
Dialogue: 0,0:05:52.46,0:05:56.46,Main-207+,,0,0,0,,Capisco. Allora passate subito \Nallo scenario successivo.
Dialogue: 0,0:05:56.46,0:05:58.75,Main-207+,,0,0,0,,Questo è un sacrificio in nome della giustizia.
Dialogue: 0,0:05:58.75,0:05:59.55,Main-207+,,0,0,0,,{\i1}Sì!{\i0} {il corsivo non c'era nell'originale eng, ma dato che non è on screen, di solito fanno così}
Dialogue: 0,0:06:03.98,0:06:07.09,Main-207+,,0,0,0,,Bene, allora iniziamo con l'udienza.
Dialogue: 0,0:06:07.67,0:06:09.63,Main-207+,,0,0,0,,Tom's Workers.
Dialogue: 0,0:06:15.61,0:06:18.01,Main-207+,,0,0,0,,La nave giudiziaria affonderà a breve.
Dialogue: 0,0:06:18.01,0:06:20.43,Main-207+,,0,0,0,,Bene! Torniamo all'isola dei relitti!
Dialogue: 0,0:06:20.43,0:06:21.19,Main-207+,,0,0,0,,Sì.
Dialogue: 0,0:06:25.75,0:06:28.09,Main-207+,,0,0,0,,Ehi! La flotta si sta allontanando!
Dialogue: 0,0:06:28.09,0:06:31.66,Main-207+,,0,0,0,,Aspetta un attimo! \NIo... ho già visto quelle navi!
Dialogue: 0,0:06:34.04,0:06:36.88,Main-207+,,0,0,0,,Signor Tom! Le navi stanno tornando qui!
Dialogue: 0,0:06:37.27,0:06:39.34,Main-207+,,0,0,0,,Sono vicine alla costa! \NPotremmo riuscire a prenderle!{cps}
Dialogue: 0,0:06:40.04,0:06:42.63,Main-207+,,0,0,0,,Le hai usate per creare un gran casino!{bohg}
Dialogue: 0,0:06:46.47,0:06:48.55,Main-207+,,0,0,0,,Stanno arrivando di corsa \Nin due dall'isola dei relitti!{cps gravissimo}
Dialogue: 0,0:06:48.91,0:06:50.39,Main-207+,,0,0,0,,Quello è Tom!
Dialogue: 0,0:06:50.76,0:06:53.14,Main-207+,,0,0,0,,Bene! Allontaniamoci dalla nave!
Dialogue: 0,0:07:00.56,0:07:01.61,Main-207+,,0,0,0,,Eh?! Ma come?!
Dialogue: 0,0:07:02.23,0:07:03.88,Main-207+,,0,0,0,,Non c'è nessuno.
Dialogue: 0,0:07:03.88,0:07:06.49,Main-207+,,0,0,0,,Vale lo stesso per questa. \NNon c'è nessuno in nessuna nave.{cps}
Dialogue: 0,0:07:07.12,0:07:09.41,Thoughts-207+,,0,0,0,,Beh... Ma cosa significa?
Dialogue: 0,0:07:11.56,0:07:12.54,Main-207+,,0,0,0,,Anche quelle sono di Franky...{cps}
Dialogue: 0,0:07:12.94,0:07:15.16,Main-207+,,0,0,0,,Ah! Iceburg, sta' attento!
Dialogue: 0,0:07:29.53,0:07:30.79,Main-207+,,0,0,0,,Maledizione...
Dialogue: 0,0:07:30.79,0:07:33.78,Main-207+,,0,0,0,,Le Battle Franky sono... state ridotte a pezzi!
Comment: 0,0:07:37.02,0:07:37.65,Main-207+,,0,0,0,,Ah...
Dialogue: 0,0:07:42.32,0:07:44.57,Main-207+,,0,0,0,,Iceburg! Signor Tom!
Dialogue: 0,0:07:45.15,0:07:47.07,Main-207+,,0,0,0,,Ehi! Voi due!
Dialogue: 0,0:07:47.07,0:07:50.13,Main-207+,,0,0,0,,Che c'è?! Cos'è successo?!
Dialogue: 0,0:07:54.41,0:07:56.87,Main-207+,,0,0,0,,Va tutto bene?!
Dialogue: 0,0:07:56.87,0:07:58.21,Main-207+,,0,0,0,,Dai, Iceburg!
Dialogue: 0,0:08:01.50,0:08:03.21,Main-207+,,0,0,0,,Brutto idiota!
Dialogue: 0,0:08:09.22,0:08:13.01,Main-207+,,0,0,0,,{\q2}Quegli agenti segreti che sono passati l'altro giorno...
Dialogue: 0,0:08:13.91,0:08:16.81,Main-207+,,0,0,0,,Sono stati loro a sfruttare le tue corazzate!{meh}
Dialogue: 0,0:08:17.35,0:08:20.81,Main-207+,,0,0,0,,S-Sono state le mie navi a farvi questo?{circa}
Dialogue: 0,0:08:21.36,0:08:22.72,Main-207+,,0,0,0,,Te l'avevo detto.
Dialogue: 0,0:08:23.36,0:08:25.44,Main-207+,,0,0,0,,Un sacco di volte... Un sacco di volte...
Dialogue: 0,0:08:26.36,0:08:30.45,Flashbacks-207+,,0,0,0,,{\c&HFFFFFF&\3c&HFFFFFF&\4c&HFFFFFF&\t(21,300,1,\c&HFFFFFF&\3c&H525252&\4c&H000000&)}{Gaijin - Flashback to W7 12 @21:40}Non capisco proprio come tu possa \Nlasciare in giro decine di queste navi!
Dialogue: 0,0:08:31.55,0:08:35.16,Flashbacks-207+,,0,0,0,,{arch - W7 12 @21:49}Ti sto solo dicendo di renderti \Nconto di aver creato armi letali, Cretinky!
Dialogue: 0,0:08:35.72,0:08:38.83,Main-207+,,0,0,0,,Per colpa delle mie navi... il signor Tom...
Dialogue: 0,0:08:39.84,0:08:40.88,Main-207+,,0,0,0,,Ascoltami bene.
Dialogue: 0,0:08:41.77,0:08:44.68,Main-207+,,0,0,0,,Le nostre abilità possono portare \Narmi letali in questo mondo.
Dialogue: 0,0:08:44.68,0:08:47.84,Main-207+,,0,0,0,,Anche se non è tua intenzione...
Dialogue: 0,0:08:48.62,0:08:51.39,Main-207+,,0,0,0,,quelle armi sicuramente \Ncauseranno danno a qualcuno.
Dialogue: 0,0:08:51.90,0:08:55.24,Main-207+,,0,0,0,,E potrebbe succedere anche \Na persone per te importanti!{circa, ma altrimenti non si legava bene al discorso}
Dialogue: 0,0:08:56.54,0:09:00.15,Main-207+,,0,0,0,,Siamo stati... incastrati dal governo.
Dialogue: 0,0:09:00.15,0:09:03.23,Main-207+,,0,0,0,,Verremo ritenuti responsabili \Ndell'attacco alla nave giudiziaria.{cps}
Dialogue: 0,0:09:03.23,0:09:09.07,Main-207+,,0,0,0,,Questo perché vogliono i progetti e vogliono \Ninterrogare il signor Tom come un criminale.
Dialogue: 0,0:09:09.07,0:09:14.04,Main-207+,,0,0,0,,Puoi davvero dire che non hai alcuna colpa \Nsul come sono andate le cose?!{ew}
Dialogue: 0,0:09:14.04,0:09:17.54,Main-207+,,0,0,0,,Se il signor Tom venisse portato via \Nda quei tizi in queste condizioni...
Dialogue: 0,0:09:18.55,0:09:20.37,Main-207+,,0,0,0,,Io non...
Dialogue: 0,0:09:20.70,0:09:23.00,Main-207+,,0,0,0,,potrò mai perdonarti per tutta la vita, Franky!
Dialogue: 0,0:09:28.61,0:09:29.75,Main-207+,,0,0,0,,Io non potrò...
Dialogue: 0,0:09:29.75,0:09:31.26,Main-207+,,0,0,0,,Smettila!
Dialogue: 0,0:09:31.26,0:09:32.60,Main-207+,,0,0,0,,Signor Tom!
Dialogue: 0,0:09:32.60,0:09:35.97,Main-207+,,0,0,0,,Non rimproverarlo, Iceburg.{tipo incolparlo, o biasimarlo...}
Dialogue: 0,0:09:35.97,0:09:38.31,Main-207+,,0,0,0,,Non è colpa di Franky.
Dialogue: 0,0:09:38.31,0:09:40.83,Main-207+,,0,0,0,,Giunti a questo punto, \Ncontinui ancora con questa storia?!{cps}
Dialogue: 0,0:09:41.47,0:09:42.44,Main-207+,,0,0,0,,Signor Tom!
Dialogue: 0,0:09:44.36,0:09:46.77,Main-207+,,0,0,0,,Scusa! Questa è una lancia che ho creato io!
Dialogue: 0,0:09:46.77,0:09:50.37,Main-207+,,0,0,0,,L'ho fatta in modo che \Nnon sia possibile rimuoverla!
Dialogue: 0,0:09:51.07,0:09:51.99,Main-207+,,0,0,0,,Maledizione!
Dialogue: 0,0:09:53.28,0:09:56.95,Main-207+,,0,0,0,,Non scusarti. Non mi sono fatto niente!{è un modo di dire il suo. lett è tipo "non mi fa né male né prurito", inteso come non ha avuto effetto}
Dialogue: 0,0:09:57.20,0:09:58.79,Main-207+,,0,0,0,,Guardate! Laggiù!
Dialogue: 0,0:09:59.28,0:10:00.87,Main-207+,,0,0,0,,Tom è a terra!
Dialogue: 0,0:10:00.87,0:10:02.57,Main-207+,,0,0,0,,Ma perché ha una ferita così grave?!
Dialogue: 0,0:10:02.57,0:10:05.75,Main-207+,,0,0,0,,L'attacco non era opera loro?!
Dialogue: 0,0:10:06.56,0:10:08.12,Main-207+,,0,0,0,,Sono i cittadini...{i tizi della città}
Dialogue: 0,0:10:11.61,0:10:13.13,Main-207+,,0,0,0,,Bene, allora...
Dialogue: 0,0:10:13.13,0:10:16.10,Main-207+,,0,0,0,,Che ne dite di dirigerci anche noi in città?
Dialogue: 0,0:10:16.10,0:10:17.72,Main-207+,,0,0,0,,Maledetto! Spanda!
Dialogue: 0,0:10:18.10,0:10:20.09,Main-207+,,0,0,0,,È SpandaM!{maiuscolo perché è molto evidenziato in jp}
Dialogue: 0,0:10:20.86,0:10:23.27,Main-207+,,0,0,0,,Miei cari criminali.
Dialogue: 0,0:10:24.62,0:10:27.31,Main-207+,,0,0,0,,Sono i colpevoli dell'attacco!
Dialogue: 0,0:10:27.94,0:10:29.88,Main-207+,,0,0,0,,Non temete, signori e signore.
Dialogue: 0,0:10:29.88,0:10:34.32,Main-207+,,0,0,0,,{\q2}Noi del CP5 li abbiamo neutralizzati dopo l'attacco.
Dialogue: 0,0:10:34.32,0:10:36.28,Main-207+,,0,0,0,,Non possono più muoversi.
Dialogue: 0,0:10:36.53,0:10:39.79,Main-207+,,0,0,0,,Se avesse atteso l'udienza di oggi, \Nil suo crimine sarebbe sparito...
Dialogue: 0,0:10:39.79,0:10:42.00,Main-207+,,0,0,0,,{\q2}Ma perché Tom avrebbe dovuto fare una cosa simile?
Dialogue: 0,0:10:42.36,0:10:45.21,Main-207+,,0,0,0,,Dunque alla fine era un \Ncompagno del Re dei Pirati?
Dialogue: 0,0:10:45.67,0:10:47.92,Main-207+,,0,0,0,,Piacere di conoscerla.
Dialogue: 0,0:10:47.92,0:10:50.78,Main-207+,,0,0,0,,Sono Spandam del CP5.
Dialogue: 0,0:10:50.78,0:10:53.34,Main-207+,,0,0,0,,Che coincidenza che lei sia qui, \Nè di grande aiuto.
Dialogue: 0,0:10:53.66,0:10:56.94,Main-207+,,0,0,0,,Vorrei che affidasse a noi la loro custodia.
Dialogue: 0,0:10:56.94,0:10:58.90,Main-207+,,0,0,0,,Vorrei interrogarli.
Dialogue: 0,0:10:58.90,0:10:59.85,Main-207+,,0,0,0,,Mnh.
Dialogue: 0,0:11:01.28,0:11:05.10,Thoughts-207+,,0,0,0,,Prova pure a trovare una scusa. \NTra la mia parola e la tua c'è un abisso!{nel senso che Spandam è "più credibile" di Tom (data la posizione che ricoprono)}
Dialogue: 0,0:11:05.51,0:11:09.61,Thoughts-207+,,0,0,0,,I progetti dell'antica arma \NPluton cadranno nelle mie mani!
Comment: 0,0:11:09.61,0:11:10.48,Main-207+,,0,0,0,,
Dialogue: 0,0:11:10.48,0:11:12.03,Main-207+,,0,0,0,,Che disastro...
Dialogue: 0,0:11:16.07,0:11:19.83,Main-207+,,0,0,0,,{\q2}Per prima cosa, per la questione del treno marino \Nnon si può dire altro che sia un vero successo.{cps e ew}
Dialogue: 0,0:11:19.83,0:11:24.52,Main-207+,,0,0,0,,D'ora in avanti sicuramente contribuirà \Nallo sviluppo di Water Seven.
Dialogue: 0,0:11:24.52,0:11:29.71,Main-207+,,0,0,0,,Nonostante con oggi avresti potuto essere assolto del crimine
Dialogue: 0,0:11:29.71,0:11:34.72,Main-207+,,0,0,0,,di aver costruito la nave pirata di Gold Roger
Dialogue: 0,0:11:34.72,0:11:36.21,Main-207+,,0,0,0,,perché hai commesso un altro reato?{cps. also queste tre sono riscrivibili}
Dialogue: 0,0:11:36.21,0:11:37.18,Main-207+,,0,0,0,,Non scherziamo!
Dialogue: 0,0:11:37.18,0:11:40.39,Main-207+,,0,0,0,,I colpevoli dell'attacco alla \Nnave giudiziaria non siamo noi!
Dialogue: 0,0:11:40.39,0:11:43.35,Main-207+,,0,0,0,,È colpa di quel bastardo laggiù detto Spandam!{circa}
Dialogue: 0,0:11:47.06,0:11:49.86,Main-207+,,0,0,0,,Ah eh?!
Dialogue: 0,0:11:50.57,0:11:51.48,Main-207+,,0,0,0,,Assurdo!
Dialogue: 0,0:11:51.87,0:11:54.86,Main-207+,,0,0,0,,Ma che razza di assurdità \Ndice quel apprendista di Tom!
Dialogue: 0,0:11:56.09,0:12:00.70,Main-207+,,0,0,0,,Cosa otterrebbe l'ente governativo CP5 \Naffondando la nave giudiziaria?
Dialogue: 0,0:12:01.19,0:12:04.04,Main-207+,,0,0,0,,Che sciocchezze che dice!\N È assolutamente impossibile.
Dialogue: 0,0:12:06.30,0:12:07.96,Main-207+,,0,0,0,,Il tuo nome è Cutty Flam, giusto?
Dialogue: 0,0:12:08.69,0:12:14.30,Main-207+,,0,0,0,,Tanto per iniziare, vi abbiamo colti in fragrante \Nfinché eravate a bordo di quelle navi.{le navi dell'attacco}
Dialogue: 0,0:12:14.54,0:12:20.30,Main-207+,,0,0,0,,E inoltre quelle navi d'assalto sono state \Ncostruite dalla vostra azienda, no?
Dialogue: 0,0:12:24.65,0:12:26.93,Main-207+,,0,0,0,,Delle navi che facciano una cosa del genere...
Dialogue: 0,0:12:31.16,0:12:33.07,Main-207+,,0,0,0,,Ormai quelle non...
Dialogue: 0,0:12:34.48,0:12:36.44,Main-207+,,0,0,0,,sono più mie navi!
Dialogue: 0,0:12:46.08,0:12:48.29,Main-207+,,0,0,0,,Tom ha spezzato le manette!{direbbe strappato} 
Dialogue: 0,0:12:48.71,0:12:49.75,Main-207+,,0,0,0,,In posizione!
Dialogue: 0,0:12:53.25,0:12:57.01,Main-207+,,0,0,0,,Il signor Tom... \Nha colpito Franky per la prima volta.
Dialogue: 0,0:12:57.97,0:12:58.97,Main-207+,,0,0,0,,Ma che fai?!
Dialogue: 0,0:13:02.20,0:13:04.92,Main-207+,,0,0,0,,"Non sono più mie navi"?!
Dialogue: 0,0:13:05.51,0:13:07.66,Main-207+,,0,0,0,,Quella è l'unica cosa che non devi mai dire!
Dialogue: 0,0:13:08.54,0:13:12.21,Main-207+,,0,0,0,,Che problema c'è a dirlo?! Mi sto pentendo!{ovviamente di averle costruite, non di aver detto che non sono sue}
Dialogue: 0,0:13:12.92,0:13:16.15,Main-207+,,0,0,0,,{\q2}Senza quelle navi, nessuno sarebbe stato ferito.
Dialogue: 0,0:13:18.20,0:13:21.82,Main-207+,,0,0,0,,{EL 01 @07:44}Costruire... una qualunque nave...
Dialogue: 0,0:13:24.81,0:13:27.11,Main-207+,,0,0,0,,non è né un bene né un male!{ew}
Dialogue: 0,0:13:28.02,0:13:31.83,Main-207+,,0,0,0,,Non m'importa che tipo \Ndi navi costruirai in futuro.
Dialogue: 0,0:13:32.23,0:13:32.88,Main-207+,,0,0,0,,Ma...
Dialogue: 0,0:13:33.66,0:13:38.09,Main-207+,,0,0,0,,Anche se le navi che creerai feriranno \Nqualcuno o distruggeranno il mondo
Dialogue: 0,0:13:38.09,0:13:41.80,Main-207+,,0,0,0,,{\q2}tu, come creatore, non puoi far altro che amarle!{non sarebbe così diretto, dice tipo "il creatore non può far altro che amarle", ma non mi scorreva il discorso}
Dialogue: 0,0:13:42.49,0:13:45.79,Main-207+,,0,0,0,,Il loro creatore non può rigettarle!{circa, molto circa}
Dialogue: 0,0:13:45.79,0:13:47.51,Main-207+,,0,0,0,,Non incolpare le navi!
Dialogue: 0,0:13:47.51,0:13:52.10,Main-207+,,0,0,0,,Un uomo deve essere fiero con \Nun "don" delle navi che crea!{ew}
Dialogue: 0,0:14:11.62,0:14:14.75,Main-207+,,0,0,0,,Iceburg... Franky...
Dialogue: 0,0:14:15.25,0:14:18.42,Main-207+,,0,0,0,,{\q2}{Z - Used as flashback in W7 12 @18:32}Non immischiatevi in ciò che sta per succedere!
Dialogue: 0,0:14:18.77,0:14:19.92,Main-207+,,0,0,0,,In alcun modo!
Dialogue: 0,0:14:22.00,0:14:27.04,Thoughts-207+,,0,0,0,,Ad incastrarmi è stato il Governo Mondiale. \NA giudicarmi sarà il Governo Mondiale.
Dialogue: 0,0:14:27.04,0:14:29.62,Thoughts-207+,,0,0,0,,Non c'è modo di chiarire questi sospetti.{ew}
Dialogue: 0,0:14:30.60,0:14:32.18,Thoughts-207+,,0,0,0,,È la fine.
Dialogue: 0,0:14:33.05,0:14:37.69,Thoughts-207+,,0,0,0,,Dev'essere dura vedere le proprie navi \Nsenza macchia usate in questo modo.
Dialogue: 0,0:14:38.30,0:14:41.07,Thoughts-207+,,0,0,0,,Sicuramente vuoi colpirlo, vero, Franky?
Dialogue: 0,0:14:51.54,0:14:52.58,Main-207+,,0,0,0,,Signor Tom!
Dialogue: 0,0:14:52.58,0:14:54.57,Main-207+,,0,0,0,,Tom ha perso il controllo!
Comment: 0,0:14:55.16,0:14:55.58,Main-207+,,0,0,0,,
Dialogue: 0,0:14:55.58,0:14:56.54,Main-207+,,0,0,0,,Che disastro!
Dialogue: 0,0:14:57.02,0:14:59.67,Main-207+,,0,0,0,,Fermati! Se continuerai così...!
Dialogue: 0,0:15:01.00,0:15:03.84,Main-207+,,0,0,0,,Tu...
Dialogue: 0,0:15:04.09,0:15:06.39,Main-207+,,0,0,0,,puoi capire il suo dolore?!
Dialogue: 0,0:15:06.39,0:15:07.64,Main-207+,,0,0,0,,S-Sparate!
Dialogue: 0,0:15:12.52,0:15:13.89,Main-207+,,0,0,0,,Hanno sparato!
Dialogue: 0,0:15:20.58,0:15:22.28,Main-207+,,0,0,0,,Signor Tom!
Dialogue: 0,0:15:23.99,0:15:26.07,Thoughts-207+,,0,0,0,,Proiettili anestetici?
Dialogue: 0,0:15:30.91,0:15:34.66,Main-207+,,0,0,0,,Brutto uomo-pesce dalla forza \Nsovrumana, ben ti sta!{ew... spandam complimenti per la fantasia}
Dialogue: 0,0:15:35.37,0:15:37.58,Main-207+,,0,0,0,,Signor Tom! Perché l'hai fatto?
Dialogue: 0,0:15:37.58,0:15:41.13,Main-207+,,0,0,0,,Ehi, voialtri! Che state facendo?! \NMuovetevi a catturarlo!
Dialogue: 0,0:15:41.71,0:15:45.88,Main-207+,,0,0,0,,Trasportate tutti i violenti\N Tom's Workers ad Enies Lobby!
Dialogue: 0,0:15:46.36,0:15:48.87,Main-207+,,0,0,0,,Ma quindi Tom è sempre stato \Nun tipo così violento?{lievemente adattato}
Dialogue: 0,0:15:48.87,0:15:50.35,Main-207+,,0,0,0,,Ma che diavolo sta pensando?
Dialogue: 0,0:15:51.22,0:15:54.68,Main-207+,,0,0,0,,Alla fine è davvero un uomo che \Nha venduto l'anima ad un pirata!
Dialogue: 0,0:15:55.64,0:15:58.73,Main-207+,,0,0,0,,Ha costruito delle corazzate e \Nstava aspettando l'occasione giusta!{cps}
Dialogue: 0,0:15:59.38,0:16:01.69,Main-207+,,0,0,0,,Bastardi, come osate rivolgervi \Ncosì al signor Tom?!
Dialogue: 0,0:16:01.69,0:16:02.78,Main-207+,,0,0,0,,Smettila!
Dialogue: 0,0:16:02.78,0:16:03.88,Main-207+,,0,0,0,,Eh?
Dialogue: 0,0:16:03.88,0:16:05.74,Main-207+,,0,0,0,,Va bene così.
Dialogue: 0,0:16:05.11,0:16:05.74,Secondary-207+,,0,0,0,,Ma...!
Dialogue: 0,0:16:06.59,0:16:07.61,Main-207+,,0,0,0,,Giudice.
Dialogue: 0,0:16:07.61,0:16:08.61,Main-207+,,0,0,0,,Eh?
Dialogue: 0,0:16:09.24,0:16:13.04,Main-207+,,0,0,0,,Ammetto il crimine dell'attacco\N alla nave giudiziaria.
Dialogue: 0,0:16:13.04,0:16:14.08,Main-207+,,0,0,0,,Eh?!
Dialogue: 0,0:16:14.08,0:16:16.58,Main-207+,,0,0,0,,Asp–! Signor Tom, non lo fare!
Dialogue: 0,0:16:16.58,0:16:18.62,Main-207+,,0,0,0,,Ma ho un favore da chiederle.
Dialogue: 0,0:16:18.62,0:16:22.01,Main-207+,,0,0,0,,{\q2}Ma sta' zitto, idiota di un uomo-pesce! \NChi mai ascolterebbe le richieste di un criminale!{in jp la seconda non è completa, ma è abbastanza per capire la versione completa. ma così siamo a cps rossi}
Dialogue: 0,0:16:22.01,0:16:23.67,Main-207+,,0,0,0,,Chiudi la bocca, CP5!
Dialogue: 0,0:16:23.67,0:16:24.17,Main-207+,,0,0,0,,Ah–
Dialogue: 0,0:16:25.26,0:16:27.01,Main-207+,,0,0,0,,Dunque quale sarebbe il favore?
Dialogue: 0,0:16:27.01,0:16:32.30,Main-207+,,0,0,0,,Se un crimine può sparire grazie \Nalla costruzione del treno marino,
Dialogue: 0,0:16:32.97,0:16:35.02,Main-207+,,0,0,0,,allora vorrei fosse cancellato quello di oggi.{cps}
Dialogue: 0,0:16:35.28,0:16:36.14,Main-207+,,0,0,0,,Eh?
Dialogue: 0,0:16:36.54,0:16:41.27,Main-207+,,0,0,0,,Anche se esaudissi questa tua richiesta, \Ntornerai solo al punto di partenza.
Dialogue: 0,0:16:41.27,0:16:46.44,Main-207+,,0,0,0,,Ti rimarrà ancora il crimine con pena capitale \Ndi aver costruito la nave del Re dei Pirati.
Dialogue: 0,0:16:46.86,0:16:49.11,Main-207+,,0,0,0,,Sì. Preferisco sia così.
Dialogue: 0,0:16:49.71,0:16:52.82,Main-207+,,0,0,0,,{Used as flashback in Enies Lobby 11 @14:44}Il fatto di aver dato una mano a Roger
Dialogue: 0,0:16:53.22,0:16:56.50,Main-207+,,0,0,0,,mi rende orgoglioso con un "don"!{ew}
Dialogue: 0,0:16:58.41,0:17:00.28,Main-207+,,0,0,0,,Che arroganza.
Dialogue: 0,0:17:00.28,0:17:03.17,Main-207+,,0,0,0,,Essere orgoglioso di aver dato \Nuna mano al Re dei Pirati...
Dialogue: 0,0:17:03.65,0:17:04.61,Main-207+,,0,0,0,,Traditore!
Dialogue: 0,0:17:04.61,0:17:06.84,Main-207+,,0,0,0,,– Uomo-pesce feroce!\N– Maledetto uomo-pesce!
Dialogue: 0,0:17:07.27,0:17:09.17,Main-207+,,0,0,0,,Signor Tom! Ma perché?!
Dialogue: 0,0:17:09.76,0:17:11.26,Main-207+,,0,0,0,,Va bene così.
Dialogue: 0,0:17:11.80,0:17:14.93,Main-207+,,0,0,0,,Ascolta bene. Non incolparti.
Dialogue: 0,0:17:15.50,0:17:20.39,Main-207+,,0,0,0,,{\q2}Non credevo che il governo fosse così determinato\N nel voler mettere le mani sui progetti.
Dialogue: 0,0:17:20.39,0:17:23.99,Main-207+,,0,0,0,,Riguardo alla questione con Roger, \Nero già in una posizione sfavorevole.
Dialogue: 0,0:17:23.99,0:17:25.90,Main-207+,,0,0,0,,Anche se fosse, perché di tua iniziativa...!
Dialogue: 0,0:17:25.90,0:17:27.40,Main-207+,,0,0,0,,Va tutto bene.
Dialogue: 0,0:17:27.83,0:17:33.70,Main-207+,,0,0,0,,{\q2}Guarda. Anche se l'accusa torna ad essere quella di \Nquattordici anni fa, ormai niente è più come allora.
Dialogue: 0,0:17:33.70,0:17:36.77,Main-207+,,0,0,0,,Questa città ora è piena di energia.
Dialogue: 0,0:17:38.25,0:17:40.12,Main-207+,,0,0,0,,D'ora in poi...
Dialogue: 0,0:17:40.63,0:17:43.63,Main-207+,,0,0,0,,indipendentemente da ciò che mi succederà...
Dialogue: 0,0:17:43.89,0:17:46.71,Main-207+,,0,0,0,,diventerò forza per la città.
Dialogue: 0,0:17:47.26,0:17:49.26,Main-207+,,0,0,0,,Il mio sogno...
Dialogue: 0,0:17:50.22,0:17:54.05,Main-207+,,0,0,0,,finalmente si è messo in moto...
Dialogue: 0,0:17:55.84,0:17:57.15,Main-207+,,0,0,0,,Signor Tom!
Dialogue: 0,0:17:59.27,0:18:00.27,Main-207+,,0,0,0,,Signor Tom!
Dialogue: 0,0:18:05.59,0:18:08.32,Thoughts-207+,,0,0,0,,Iceburg. Franky.
Dialogue: 0,0:18:08.81,0:18:11.11,Thoughts-207+,,0,0,0,,Vi affido i progetti.
Dialogue: 0,0:18:11.88,0:18:14.36,Thoughts-207+,,0,0,0,,Signora Kokoro. Yokozuna.
Dialogue: 0,0:18:15.13,0:18:17.53,Thoughts-207+,,0,0,0,,Grazie di tutto...{molto circa}
Dialogue: 0,0:18:22.10,0:18:23.87,Main-207+,,0,0,0,,Finalmente l'anestetico ha fatto effetto?!
Dialogue: 0,0:18:23.87,0:18:26.64,Main-207+,,0,0,0,,Catturate i tre responsabili \Ndell'attacco alla nave giudiziaria!{cps}
Dialogue: 0,0:18:26.64,0:18:27.75,Main-207+,,0,0,0,,– Sì!\N– Sì!
Dialogue: 0,0:18:29.05,0:18:29.96,Main-207+,,0,0,0,,Aspetta.
Dialogue: 0,0:18:30.33,0:18:31.05,Main-207+,,0,0,0,,Ah?
Dialogue: 0,0:18:31.38,0:18:33.65,Main-207+,,0,0,0,,{Used as flashback in Enies Lobby 22 @06:16}Il capo d'accusa è stato modificato.
Dialogue: 0,0:18:33.65,0:18:38.15,Main-207+,,0,0,0,,Per il reato di aver costruito la \Nnave del Re dei Pirati Gold Roger
Dialogue: 0,0:18:38.15,0:18:42.27,Main-207+,,0,0,0,,il mastro carpentiere Tom \Nsarà trasferito ad Enies Lobby.
Dialogue: 0,0:18:42.65,0:18:43.72,Main-207+,,0,0,0,,È tutto.
Dialogue: 0,0:18:46.98,0:18:50.07,Main-207+,,0,0,0,,'Sto vecchio... Chissà da quale\N emozione si è fatto influenzare...
Dialogue: 0,0:18:50.07,0:18:52.44,Main-207+,,0,0,0,,Oh beh, non mi servono i apprendisti.
Dialogue: 0,0:18:52.68,0:18:54.78,Main-207+,,0,0,0,,Liberate i due apprendisti!
Dialogue: 0,0:19:01.05,0:19:03.58,Main-207+,,0,0,0,,Il signor Tom non può più salvarsi.
Dialogue: 0,0:19:04.47,0:19:07.50,Main-207+,,0,0,0,,Con il Governo Mondiale come \Navversario, non c'è nulla da fare.
Dialogue: 0,0:19:08.06,0:19:12.85,Main-207+,,0,0,0,,Resistete. Il signor Tom vi ha salvati.
Dialogue: 0,0:19:12.85,0:19:17.14,Main-207+,,0,0,0,,{\q2}Se ve li inimicaste, non vi basterebbero mille vite.
Dialogue: 0,0:19:17.52,0:19:20.81,Main-207+,,0,0,0,,Enies Lobby è l'isola della giustizia \Ndi proprietà del governo.
Dialogue: 0,0:19:21.43,0:19:27.35,Main-207+,,0,0,0,,Nessun criminale trasportato \Nlà è mai più tornato indietro!
Dialogue: 0,0:19:28.32,0:19:30.69,Main-207+,,0,0,0,,Il treno marino è pronto!
Dialogue: 0,0:19:30.69,0:19:31.90,Main-207+,,0,0,0,,Il trasferimento è possibile!{ew e cps}
Dialogue: 0,0:19:31.90,0:19:32.44,Main-207+,,0,0,0,,Bene!
Dialogue: 0,0:19:33.28,0:19:34.36,Main-207+,,0,0,0,,Signora Kokoro...
Dialogue: 0,0:19:35.70,0:19:38.66,Main-207+,,0,0,0,,Ehi, voialtri! Portatelo via subito!
Dialogue: 0,0:19:38.66,0:19:39.87,Main-207+,,0,0,0,,Per me...
Dialogue: 0,0:19:40.70,0:19:43.66,Main-207+,,0,0,0,,Portate via questo pesante uomo-pesce matto!
Dialogue: 0,0:19:43.66,0:19:46.58,Main-207+,,0,0,0,,è impossibile!
Comment: 0,0:19:46.16,0:19:46.58,Main-207+,,0,0,0,,
Comment: 0,0:19:46.58,0:19:47.33,Main-207+,,0,0,0,,Ah!
Dialogue: 0,0:19:48.88,0:19:49.92,Main-207+,,0,0,0,,Ehi!
Dialogue: 0,0:19:56.47,0:19:58.05,Main-207+,,0,0,0,,Fermo!
Dialogue: 0,0:20:04.60,0:20:06.68,Main-207+,,0,0,0,,Il volto del signor Spandam si è piegato!
Dialogue: 0,0:20:06.68,0:20:09.49,Main-207+,,0,0,0,,{Z - Needs to match 14:52}Questa volta è stato l'apprendista \Ndi Tom a perdere il controllo!{cps}
Dialogue: 0,0:20:10.31,0:20:11.90,Main-207+,,0,0,0,,Non farlo!
Comment: 0,0:20:10.99,0:20:11.90,Secondary-207+,,0,0,0,,
Dialogue: 0,0:20:11.90,0:20:16.24,Main-207+,,0,0,0,,Catturatelo! E gli altri trasportino via Tom!
Dialogue: 0,0:20:16.24,0:20:20.02,Main-207+,,0,0,0,,Fatevi sotto! Non vi lascerò portarlo via!
Dialogue: 0,0:20:20.02,0:20:21.40,Main-207+,,0,0,0,,Potete sparare!
Dialogue: 0,0:20:22.75,0:20:24.62,Main-207+,,0,0,0,,Ridatemi il signor Tom!
Dialogue: 0,0:20:28.10,0:20:29.41,Main-207+,,0,0,0,,Va tutto bene?!
Dialogue: 0,0:20:31.42,0:20:33.21,Main-207+,,0,0,0,,Veloce, scappa!
Dialogue: 0,0:20:33.21,0:20:34.21,Main-207+,,0,0,0,,Sparate!
Dialogue: 0,0:20:45.27,0:20:47.73,Main-207+,,0,0,0,,Brutto maledetto! È scappato!
Dialogue: 0,0:20:48.12,0:20:51.19,Main-207+,,0,0,0,,{\q2}Non perdonerò mai quel moccioso di Cutty Flam!
Dialogue: 0,0:20:51.61,0:20:53.57,Main-207+,,0,0,0,,È un criminale a tutti gli effetti!
Dialogue: 0,0:20:54.19,0:20:57.82,Main-207+,,0,0,0,,Una volta conclusa questa questione, \Nfarò impiccare quell'idiota!
Dialogue: 0,0:20:58.29,0:21:00.07,Main-207+,,0,0,0,,Signor Spandam!
Dialogue: 0,0:20:59.42,0:21:00.07,Secondary-207+,,0,0,0,,Cosa?!
Dialogue: 0,0:21:00.40,0:21:02.70,Main-207+,,0,0,0,,È-È Cutty Flam!
Dialogue: 0,0:21:02.70,0:21:04.19,Main-207+,,0,0,0,,Cosa?!
Dialogue: 0,0:21:04.19,0:21:05.74,Main-207+,,0,0,0,,Ci ha seguiti fino a qui!
Dialogue: 0,0:21:06.09,0:21:09.20,Main-207+,,0,0,0,,È sui binari e ha una qualche arma!
Dialogue: 0,0:21:13.68,0:21:15.63,Main-207+,,0,0,0,,Sta' dove sei, Yokozuna.
Comment: 0,0:21:15.63,0:21:16.42,Main-207+,,0,0,0,,
Dialogue: 0,0:21:17.57,0:21:19.35,Main-207+,,0,0,0,,Ma è stupido?!
Dialogue: 0,0:21:19.35,0:21:20.59,Main-207+,,0,0,0,,Che facciamo?
Dialogue: 0,0:21:21.43,0:21:22.59,Main-207+,,0,0,0,,Ma sei stupido pure tu?!
Dialogue: 0,0:21:22.90,0:21:26.22,Main-207+,,0,0,0,,Continuiamo ad andare avanti!\N Esattamente come vuole lui!
Dialogue: 0,0:21:26.22,0:21:27.89,Main-207+,,0,0,0,,Non c'è nulla di cui preoccuparsi!
Dialogue: 0,0:21:27.89,0:21:29.14,Main-207+,,0,0,0,,S-Sì...
Dialogue: 0,0:21:31.77,0:21:34.15,Main-207+,,0,0,0,,Fermati, Puffing Tom!
Dialogue: 0,0:21:36.61,0:21:40.36,Main-207+,,0,0,0,,Bastardo... \NDove pensi di portare il tuo creatore?!
Comment: 0,0:21:50.79,0:21:52.46,Main-207+,,0,0,0,,
Dialogue: 0,0:21:55.22,0:21:57.01,Main-207+,,0,0,0,,Non ti lascerò passare!
Dialogue: 0,0:22:02.03,0:22:04.05,Main-207+,,0,0,0,,Ridatemi il signor Tom!
Dialogue: 0,0:22:06.22,0:22:09.98,Main-207+,,0,0,0,,{\t(2910,3760,\c&HFFFFFF&\3c&HFFFFFF&\4c&HFFFFFF&)}Fermati, treno marino!
Dialogue: 0,0:22:13.60,0:22:18.02,Flashbacks-207+,,0,0,0,,{W7 12 @12:41 (solo reference) e 12:55 (vero flashback)}Capisco! I tuoi genitori ti \Nhanno abbandonato? Che capolavoro!
Dialogue: 0,0:22:18.58,0:22:20.03,Flashbacks-207+,,0,0,0,,Ehi! Stai ridendo troppo!
Dialogue: 0,0:22:20.33,0:22:22.78,Flashbacks-207+,,0,0,0,,Bene! Vieni da noi con un "don"!
Dialogue: 0,0:22:23.21,0:22:24.70,Thoughts-207+,,0,0,0,,Signor Tom...
Dialogue: 0,0:22:25.32,0:22:28.66,Thoughts-207+,,0,0,0,,Non voglio più costruire delle navi!
Dialogue: 0,0:22:29.48,0:22:34.71,Thoughts-207+,,0,0,0,,Non posso amare delle navi che hanno \Nferito delle persone a cui tengo.
Dialogue: 0,0:22:35.16,0:22:36.29,Thoughts-207+,,0,0,0,,Però, signor Tom...
Dialogue: 0,0:22:37.67,0:22:41.46,Thoughts-207+,,0,0,0,,Il mio obiettivo... alla fine sei tu!
Dialogue: 0,0:22:50.66,0:22:53.79,Thoughts-207+,,0,0,0,,Voglio che tu torni e che mi insegni ancora!{non so a verbi qua, non mi viene}
Dialogue: 0,0:23:03.31,0:23:04.95,Thoughts-207+,,0,0,0,,Anch'io un giorno...
Dialogue: 0,0:23:05.55,0:23:07.70,Thoughts-207+,,0,0,0,,voglio costruire la nave dei miei sogni!
Dialogue: 0,0:23:11.60,0:23:17.37,Thoughts-207+,,0,0,0,,{\q2}Una che possa attraversare orgogliosamente con un \N"don" le onde sconosciute ai confini del mondo!
Dialogue: 0,0:23:18.01,0:23:19.94,Thoughts-207+,,0,0,0,,La nave dei sogni!
Comment: 0,0:00:00.00,0:00:00.00,Main-207+,,0,0,0,,{=11}===============================DIALOGUE============================
