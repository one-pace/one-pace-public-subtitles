Comment: 0,0:00:00.00,0:00:00.00,Main-207+,,0,0,0,,{=12}===============================DIALOGUE============================
Dialogue: 0,0:02:06.81,0:02:10.03,Main-207+,,0,0,0,,ギャー！食われるー！
Dialogue: 0,0:02:10.03,0:02:10.84,Main-207+,,0,0,0,,食らえ！
Dialogue: 0,0:02:26.68,0:02:30.58,Main-207+,,0,0,0,,どけ！どけ！アイスバーグ～！
Dialogue: 0,0:02:34.25,0:02:37.24,Main-207+,,0,0,0,, ンマー！\N何やってんだフランキー！
Dialogue: 0,0:02:42.97,0:02:44.18,Main-207+,,0,0,0,,この！
Dialogue: 0,0:02:43.59,0:02:44.18,Secondary-207+,,0,0,0,,あっ
Dialogue: 0,0:02:44.18,0:02:45.43,Main-207+,,0,0,0,,ンマー！
Dialogue: 0,0:02:45.43,0:02:47.94,Main-207+,,0,0,0,,お前は仕事も手伝わねえで何やってんだ
Dialogue: 0,0:02:47.94,0:02:50.14,Main-207+,,0,0,0,,こんな危なっかしいもんばっかり造ってよ！
Dialogue: 0,0:02:50.14,0:02:53.44,Main-207+,,0,0,0,,うるせえな！お前には関係ないだろバカバーグ！
Dialogue: 0,0:02:53.44,0:02:57.65,Main-207+,,0,0,0,,これは俺の大事な戦艦\Nバトルフランキー号なんだ
Dialogue: 0,0:02:57.65,0:03:00.37,Main-207+,,0,0,0,,何だか知らんが\N誰かがケガする前に全部捨てろ！
Dialogue: 0,0:03:00.97,0:03:04.28,Main-207+,,0,0,0,,何置いても勝手だろ！\Nここは廃船島なんだ！
Dialogue: 0,0:03:04.28,0:03:08.33,Main-207+,,0,0,0,,見てろ　俺は次こそ\N海王類に勝てる船艦を造ってやる！
Dialogue: 0,0:03:08.33,0:03:10.83,Main-207+,,0,0,0,,ンマー　勝てるか\Nお前なんか食われちまえ！
Dialogue: 0,0:03:10.83,0:03:12.71,Main-207+,,0,0,0,,勝てるさ
Dialogue: 0,0:03:11.58,0:03:12.71,Secondary-207+,,0,0,0,,ンマー！勝てねえ
Dialogue: 0,0:03:12.71,0:03:14.82,Main-207+,,0,0,0,,勝てる！
Dialogue: 0,0:03:13.33,0:03:14.82,Secondary-207+,,0,0,0,,ンマー！勝てねえ！
Dialogue: 0,0:03:17.67,0:03:23.73,Main-207+,,0,0,0,,{\fad(150,150)\bord2.9\shad2\fnFOT-Greco Std B Strp\fscx92\fscy92\b1}男なら～　ドンとやれ！
Dialogue: 0,0:03:40.84,0:03:43.27,Main-207+,,0,0,0,,進水式終了だ
Dialogue: 0,0:03:43.27,0:03:46.74,Main-207+,,0,0,0,,頑丈ないい船がドンとできた
Dialogue: 0,0:03:46.74,0:03:48.96,Main-207+,,0,0,0,,なあ　ヨコヅナ
Comment: 0,0:03:48.17,0:03:48.96,Main-207+,,0,0,0,,ゲロッ　ゲロッ
Dialogue: 0,0:03:49.55,0:03:52.02,Main-207+,,0,0,0,,仕上げは明日にするか
Dialogue: 0,0:03:52.02,0:03:54.51,Main-207+,,0,0,0,,さあ　帰るぞ
Comment: 0,0:03:53.65,0:03:54.50,Main-207+,,0,0,0,,ゲロッ　ゲロッ
Dialogue: 0,0:03:55.05,0:03:57.43,Main-207+,,0,0,0,,ああ腹減った
Comment: 0,0:03:56.64,0:03:57.43,Main-207+,,0,0,0,,ゲロゲロッ
Dialogue: 0,0:03:57.43,0:03:59.31,Main-207+,,0,0,0,,メシは何だろうな？
Comment: 0,0:03:58.96,0:04:00.48,Main-207+,,0,0,0,,ゲロゲロ
Dialogue: 0,0:04:00.48,0:04:01.29,Main-207+,,0,0,0,,ちょっと
Dialogue: 0,0:04:01.29,0:04:03.80,Main-207+,,0,0,0,,–　待ってよ　トムさーん！\N–　待ってよ　トムさーん！
Dialogue: 0,0:04:11.38,0:04:15.06,Main-207+,,0,0,0,,バトルフランキーは今 何号だ？フランキー
Dialogue: 0,0:04:15.06,0:04:16.11,Main-207+,,0,0,0,,ん…　８号
Dialogue: 0,0:04:16.11,0:04:17.69,Main-207+,,0,0,0,,惜しかったんだ～
Dialogue: 0,0:04:17.69,0:04:18.75,Main-207+,,0,0,0,,ウソつけ！
Dialogue: 0,0:04:18.75,0:04:21.63,Main-207+,,0,0,0,,まったく\Nトムさんが許すから調子に乗るんだよ
Dialogue: 0,0:04:21.63,0:04:23.49,Main-207+,,0,0,0,,こいつは武器ばっかり作ってよ
Dialogue: 0,0:04:23.49,0:04:25.32,Main-207+,,0,0,0,,うっせえよ！バカバーグ！
Dialogue: 0,0:04:25.32,0:04:29.11,Main-207+,,0,0,0,,くっ…　何だと？このバカンキーが！
Dialogue: 0,0:04:31.58,0:04:33.42,Secondary-207+,,0,0,0,,{\an8}キッ…　なんだと！
Dialogue: 0,0:04:33.42,0:04:35.80,Secondary-207+,,0,0,0,,{\an8}バカ…
Dialogue: 0,0:04:32.86,0:04:35.80,Main-207+,,0,0,0,,はいはい\N２人ともケンカはやめな
Dialogue: 0,0:04:35.80,0:04:38.34,Main-207+,,0,0,0,,–　だってココロさんこいつが！\N–　だってココロさんこいつが！
Dialogue: 0,0:04:39.04,0:04:41.02,Main-207+,,0,0,0,,まったく…
Dialogue: 0,0:04:41.02,0:04:43.07,Main-207+,,0,0,0,,トムさんも笑いすぎだよ
Dialogue: 0,0:04:43.07,0:04:45.80,Main-207+,,0,0,0,,何がツボに入ったんだい？ああ
Dialogue: 0,0:04:45.80,0:04:48.00,Main-207+,,0,0,0,,そうそう　そういえば
Dialogue: 0,0:04:48.00,0:04:51.88,Main-207+,,0,0,0,,また木材を積んだ交易船が\N海賊にやられたって
Dialogue: 0,0:04:51.88,0:04:55.76,Main-207+,,0,0,0,,海賊王が死刑になった後\Nめっきり海賊が増えちまって
Dialogue: 0,0:04:55.76,0:04:59.40,Main-207+,,0,0,0,,ダメだねもうこの町は…\N海賊時代にのまれちまってる
Dialogue: 0,0:04:59.96,0:05:02.27,Main-207+,,0,0,0,,気持ちで負けてんだね
Dialogue: 0,0:05:03.02,0:05:09.12,Main-207+,,0,0,0,,アクア･ラグナの浸水で\N木材も鉄もよその島からしか手に入らなくなったところへ
Dialogue: 0,0:05:09.12,0:05:12.91,Main-207+,,0,0,0,,凶暴な海や海賊たちが交易を阻む
Dialogue: 0,0:05:12.91,0:05:16.41,Main-207+,,0,0,0,,仕事の不足した造船所同士で客を取り合う
Dialogue: 0,0:05:16.41,0:05:19.38,Main-207+,,0,0,0,,ケンカが始まる　職は失う
Dialogue: 0,0:05:20.07,0:05:25.69,Main-207+,,0,0,0,,ほっときゃ　このウォーターセブンは\N浸水を待つだけのほうけた島になっちまうよ
Dialogue: 0,0:05:26.46,0:05:32.38,Main-207+,,0,0,0,,昔は造船業で一時代を築いた\Nこのウォーターセブンがねえ
Dialogue: 0,0:05:32.38,0:05:36.56,Main-207+,,0,0,0,,そうだよな\Nトムさんもすげえ海賊船造ったんだもんな
Dialogue: 0,0:05:36.56,0:05:38.94,Main-207+,,0,0,0,,なあ！海賊船の設計図教えてくれよ！
Dialogue: 0,0:05:42.02,0:05:44.49,Main-207+,,0,0,0,,何で笑うんだよ？
Dialogue: 0,0:05:44.49,0:05:49.07,Main-207+,,0,0,0,,フランキー\Nこの世に海賊船の設計図なんてのはねえのよ
Dialogue: 0,0:05:49.07,0:05:53.37,Main-207+,,0,0,0,,乗り込んだ船乗りがドクロを掲げりゃ海賊船
Dialogue: 0,0:05:53.37,0:05:55.79,Main-207+,,0,0,0,,カモメを掲げりゃあ海軍船だ
Dialogue: 0,0:05:56.46,0:05:59.33,Main-207+,,0,0,0,,何を造りたがろうと構わねえが
Dialogue: 0,0:05:59.33,0:06:04.09,Main-207+,,0,0,0,,造った船に男はドンと胸を張れ！
Dialogue: 0,0:06:08.75,0:06:10.85,Main-207+,,0,0,0,,トムさん　寝ねえのか？
Dialogue: 0,0:06:11.49,0:06:12.88,Main-207+,,0,0,0,,何描いてんだ？
Dialogue: 0,0:06:12.88,0:06:16.27,Main-207+,,0,0,0,,ああ　これはこの島の希望だ
Dialogue: 0,0:06:17.14,0:06:18.42,Main-207+,,0,0,0,,希望？
Dialogue: 0,0:06:18.42,0:06:22.70,Main-207+,,0,0,0,,これで　ウォーターセブンが\N再生できるといいんだが…
Dialogue: 0,0:06:23.20,0:06:24.94,Main-207+,,0,0,0,,さあ　もう寝な
Dialogue: 0,0:06:25.41,0:06:26.95,Main-207+,,0,0,0,,うん
Dialogue: 0,0:06:26.95,0:06:27.95,Main-207+,,0,0,0,,ん？
Comment: 0,0:06:41.55,0:06:42.42,Main-207+,,0,0,0,,あっ！
Dialogue: 0,0:06:46.85,0:06:49.05,Main-207+,,0,0,0,,政府の司法船が来たぞ！
Dialogue: 0,0:06:49.05,0:06:51.14,Main-207+,,0,0,0,,何だ？司法船って
Dialogue: 0,0:06:51.14,0:06:52.89,Main-207+,,0,0,0,,移動する裁判所だ
Dialogue: 0,0:06:52.89,0:06:54.47,Main-207+,,0,0,0,,誰を裁きに来たんだ？
Dialogue: 0,0:06:59.56,0:07:00.55,Main-207+,,0,0,0,,ちょっと待てよ
Dialogue: 0,0:07:00.55,0:07:02.93,Main-207+,,0,0,0,,トムさんが何をしたんだよ！\N何だよ　どけよ！
Dialogue: 0,0:07:02.93,0:07:04.52,Main-207+,,0,0,0,,お前らトムさんを返せ！
Dialogue: 0,0:07:04.52,0:07:08.16,Main-207+,,0,0,0,,大丈夫だ　心配するな
Dialogue: 0,0:07:11.20,0:07:15.12,Main-207+,,0,0,0,,トムさん！トムさーん！
Dialogue: 0,0:07:21.87,0:07:26.47,Main-207+,,0,0,0,,先日処刑された海賊王\Nゴールド･ロジャーの海賊船
Dialogue: 0,0:07:26.47,0:07:29.47,Main-207+,,0,0,0,,オーロ･ジャクソン号を製造した事実を
Dialogue: 0,0:07:29.47,0:07:32.45,Main-207+,,0,0,0,,世界的凶悪犯への加担と見なし
Comment: 0,0:07:29.14,0:07:30.54,Secondary-207+,,0,0,0,,
Dialogue: 0,0:07:32.45,0:07:38.60,Main-207+,,0,0,0,,造船技師トムをエニエス･ロビーへ連行\Nおよび死刑に処す！
Dialogue: 0,0:07:38.60,0:07:40.02,Main-207+,,0,0,0,,えっ！？
Dialogue: 0,0:07:40.02,0:07:44.98,Main-207+,,0,0,0,,大変だー！トムが…\Nトムが死刑になるぞー！
Dialogue: 0,0:07:45.64,0:07:48.53,Main-207+,,0,0,0,,海賊王の船を造った罪だってよ
Dialogue: 0,0:07:48.53,0:07:49.65,Main-207+,,0,0,0,,ついに来たか…
Dialogue: 0,0:07:49.65,0:07:52.91,Main-207+,,0,0,0,,世界中迷惑してんだ\Nしかたねえよ
Dialogue: 0,0:07:54.41,0:07:59.09,Main-207+,,0,0,0,,本来船大工が\N誰に船を売ろうとも罪ではないが
Dialogue: 0,0:07:59.09,0:08:01.37,Main-207+,,0,0,0,,海賊王に限っては特例だ
Dialogue: 0,0:08:01.37,0:08:07.85,Main-207+,,0,0,0,,ヤツの海賊行為に少しでも肩入れしたと\N見なされる者は全てが危険人物
Dialogue: 0,0:08:07.85,0:08:09.56,Main-207+,,0,0,0,,よって死刑
Dialogue: 0,0:08:09.56,0:08:11.22,Main-207+,,0,0,0,,罪人を連行せよ
Dialogue: 0,0:08:11.22,0:08:11.84,Main-207+,,0,0,0,,–　はっ\N–　はっ
Dialogue: 0,0:08:11.84,0:08:13.22,Main-207+,,0,0,0,,さあ行くぞ
Dialogue: 0,0:08:13.22,0:08:14.55,Main-207+,,0,0,0,,早く歩け
Dialogue: 0,0:08:15.12,0:08:16.10,Main-207+,,0,0,0,,どうした？
Dialogue: 0,0:08:16.10,0:08:17.61,Main-207+,,0,0,0,,早く行かないか
Dialogue: 0,0:08:17.61,0:08:19.01,Main-207+,,0,0,0,,おい！何をしている？
Dialogue: 0,0:08:19.01,0:08:20.77,Main-207+,,0,0,0,,わしは今…
Dialogue: 0,0:08:20.46,0:08:20.77,Secondary-207+,,0,0,0,,あっ
Dialogue: 0,0:08:21.18,0:08:26.69,Main-207+,,0,0,0,,海上の線路をドンと走る蒸気機関\Nパドルシップを構想している
Dialogue: 0,0:08:27.65,0:08:29.15,Main-207+,,0,0,0,,おい！貴様！何を言いだす
Dialogue: 0,0:08:29.15,0:08:30.57,Main-207+,,0,0,0,,この…
Dialogue: 0,0:08:30.57,0:08:36.67,Main-207+,,0,0,0,,今や　廃れたこの島の\Nその原因がままならねえ交易だとして
Dialogue: 0,0:08:36.67,0:08:37.60,Main-207+,,0,0,0,,今や
Dialogue: 0,0:08:38.10,0:08:44.46,Main-207+,,0,0,0,,すさんだ人々の心が\N沈む島を不安に思う気持ちだとして
Dialogue: 0,0:08:44.46,0:08:46.55,Main-207+,,0,0,0,,海列車の開通は
Dialogue: 0,0:08:46.55,0:08:51.01,Main-207+,,0,0,0,,いずれ必ずこのウォーターセブンの救いになる
Dialogue: 0,0:08:53.38,0:08:55.82,Main-207+,,0,0,0,,し…　失礼\Nすぐに連行しますので
Dialogue: 0,0:08:55.82,0:08:57.31,Main-207+,,0,0,0,,いや　少し待て
Dialogue: 0,0:08:57.31,0:08:57.93,Main-207+,,0,0,0,,–　え？\N–　え？
Dialogue: 0,0:08:57.93,0:09:00.97,Main-207+,,0,0,0,,海列車…　と言ったな？
Dialogue: 0,0:09:00.97,0:09:06.77,Main-207+,,0,0,0,,島から島へ\N煙を上げて海の線路を走る船
Dialogue: 0,0:09:06.77,0:09:11.53,Main-207+,,0,0,0,,客も物資も船も運び\N天候に左右されることなく
Dialogue: 0,0:09:11.53,0:09:15.17,Main-207+,,0,0,0,,誰でも自由に海を渡れるようになる
Dialogue: 0,0:09:15.17,0:09:16.70,Main-207+,,0,0,0,,何を夢みてえなことを
Dialogue: 0,0:09:16.70,0:09:20.82,Main-207+,,0,0,0,,線路なんてそんなもの\Nアクア･ラグナが来りゃ壊れて終わりだ
Dialogue: 0,0:09:20.82,0:09:24.48,Main-207+,,0,0,0,,そうだそうだ！\Nそれに海には海王類もいるんだぞ！
Dialogue: 0,0:09:24.48,0:09:27.55,Main-207+,,0,0,0,,海の線路は固定する必要はない
Dialogue: 0,0:09:28.23,0:09:33.09,Main-207+,,0,0,0,,水面の少し下をゆらゆら揺れて\N波には決して逆らわず
Dialogue: 0,0:09:33.09,0:09:38.26,Main-207+,,0,0,0,,海列車はロープを手繰るように\Nその線路を道しるべとするだけだ
Dialogue: 0,0:09:38.26,0:09:40.62,Main-207+,,0,0,0,,さらに線路とパドルの間に
Dialogue: 0,0:09:40.62,0:09:45.98,Main-207+,,0,0,0,,魚たちの嫌がる不協和音を出す\N仕組みを考えている
Dialogue: 0,0:09:45.98,0:09:50.23,Main-207+,,0,0,0,,そうすれば\N海王類も線路に近づかなくなる
Dialogue: 0,0:09:50.23,0:09:51.90,Main-207+,,0,0,0,,できるのか？そんなこと
Dialogue: 0,0:09:52.54,0:09:56.86,Main-207+,,0,0,0,,セント･ポプ　ラプッチ　サン･ファルド\Nこの島を結べば
Dialogue: 0,0:09:56.86,0:10:00.70,Main-207+,,0,0,0,,それぞれの交易で産業は発展できる
Dialogue: 0,0:10:00.70,0:10:01.74,Main-207+,,0,0,0,,すてき
Dialogue: 0,0:10:01.74,0:10:07.25,Main-207+,,0,0,0,,じきに設計図が完成するが\Nそこらの船大工に造れるほど単純じゃねえ
Dialogue: 0,0:10:07.25,0:10:10.17,Main-207+,,0,0,0,,そこにエニエス･ロビーをつなぐことは？
Dialogue: 0,0:10:10.17,0:10:12.09,Main-207+,,0,0,0,,もちろん可能だ
Dialogue: 0,0:10:14.11,0:10:18.21,Main-207+,,0,0,0,,この技術が完成し\Nやがて海を越えれば
Dialogue: 0,0:10:18.21,0:10:21.68,Main-207+,,0,0,0,,世界中の島々の交渉がドンと変わる
Dialogue: 0,0:10:21.68,0:10:25.85,Main-207+,,0,0,0,,海列車はウォーターセブンの希望だ！
Dialogue: 0,0:10:26.35,0:10:27.81,Main-207+,,0,0,0,,何年かかる？
Dialogue: 0,0:10:27.81,0:10:29.27,Main-207+,,0,0,0,,10年
Dialogue: 0,0:10:29.27,0:10:30.98,Main-207+,,0,0,0,,では造ってみせよ
Dialogue: 0,0:10:30.98,0:10:33.06,Main-207+,,0,0,0,,造船技師トムに
Dialogue: 0,0:10:33.06,0:10:38.50,Main-207+,,0,0,0,,海列車の開発期間として\N10年の執行猶予を言い渡す
Dialogue: 0,0:10:39.74,0:10:41.56,Main-207+,,0,0,0,,すげえぞ！
Dialogue: 0,0:10:41.56,0:10:43.45,Main-207+,,0,0,0,,頑張れ　トム！
Dialogue: 0,0:10:43.45,0:10:46.66,Main-207+,,0,0,0,,ウォーターセブンを救ってくれ！
Dialogue: 0,0:10:49.37,0:10:51.54,Main-207+,,0,0,0,,ドンと生きてた！
Dialogue: 0,0:10:51.54,0:10:54.00,Main-207+,,0,0,0,,笑いごっちゃないよトムさん
Dialogue: 0,0:10:54.00,0:10:57.22,Main-207+,,0,0,0,,来る時が来たと思って\N背筋が凍ったよあたしゃ
Dialogue: 0,0:10:57.76,0:11:02.18,Main-207+,,0,0,0,,まあしかし　これでうまくいけば\Nロジャーの件は忘れてもらえそうだね
Dialogue: 0,0:11:02.18,0:11:05.56,Main-207+,,0,0,0,,ンマー！だけど トムさん\Nやっぱすげえよな
Dialogue: 0,0:11:05.56,0:11:09.27,Main-207+,,0,0,0,,あんなこと考えてたなんて！\Nみんな圧倒されてたもんな
Dialogue: 0,0:11:09.27,0:11:10.90,Main-207+,,0,0,0,,やっぱ海列…
Dialogue: 0,0:11:11.35,0:11:12.39,Main-207+,,0,0,0,,ごちそうさん！
Dialogue: 0,0:11:12.39,0:11:14.62,Main-207+,,0,0,0,,来いヨコヅナ\Nクロール教えてやる
Comment: 0,0:11:14.27,0:11:15.44,Main-207+,,0,0,0,,ゲロッ
Dialogue: 0,0:11:15.44,0:11:18.99,Main-207+,,0,0,0,,おいフランキー！何だよ！\Nお前さっきから膨れてよ
Dialogue: 0,0:11:18.99,0:11:22.24,Main-207+,,0,0,0,,うるっせえな！\N俺は怒ってんだ何もかもに！
Dialogue: 0,0:11:22.24,0:11:26.48,Main-207+,,0,0,0,,ゴールド･ロジャーの船は\Nグランドラインを１周した世界で１隻の船だぞ
Dialogue: 0,0:11:26.48,0:11:29.91,Main-207+,,0,0,0,,そんなすげえ船を造ったトムさんが\N何で死刑にされなきゃいけねえんだ！
Dialogue: 0,0:11:29.91,0:11:32.83,Main-207+,,0,0,0,,周りのヤツらも\Nそれが当たり前みたいに言いやがって！
Dialogue: 0,0:11:32.83,0:11:34.92,Main-207+,,0,0,0,,イカダ１隻も作れねえバカたちが！
Dialogue: 0,0:11:34.92,0:11:36.56,Main-207+,,0,0,0,,俺は知ってんだ！
Dialogue: 0,0:11:36.56,0:11:41.26,Main-207+,,0,0,0,,こんな橋の下に会社があるのもロジャーの船のことで\N町のヤツらから追い出されたからだろ！
Dialogue: 0,0:11:41.26,0:11:45.22,Main-207+,,0,0,0,,世界一の船大工が\N何でこんな目に遭わなきゃならねえんだよ！
Dialogue: 0,0:11:47.14,0:11:49.54,Main-207+,,0,0,0,,何がおかしいんだこの角ダヌキ！
Dialogue: 0,0:11:49.54,0:11:52.02,Main-207+,,0,0,0,,誰に当たってんだバカンキー！\N許さねえぞ！
Dialogue: 0,0:11:52.02,0:11:53.94,Thoughts-207+,,0,0,0,,本人がこうなのも許せねえんだ
Dialogue: 0,0:11:58.61,0:12:00.82,Main-207+,,0,0,0,,違う違う！そうじゃない！
Dialogue: 0,0:12:00.82,0:12:03.78,Main-207+,,0,0,0,,思いっきり水をかいて\N後ろに押し出すんだ
Comment: 0,0:12:04.45,0:12:06.25,Main-207+,,0,0,0,,ゲロッ　ゲロッ
Dialogue: 0,0:12:06.81,0:12:09.70,Main-207+,,0,0,0,,ダメだ！ダメだ！\Nもっとこうガバーッとかくんだよ！
Dialogue: 0,0:12:09.70,0:12:11.80,Main-207+,,0,0,0,,ったく何なんだよ
Comment: 0,0:12:10.21,0:12:11.80,Secondary-207+,,0,0,0,,{\an8}
Dialogue: 0,0:12:11.80,0:12:13.79,Main-207+,,0,0,0,,あんなアホ追い出しちまえばいいんだ
Dialogue: 0,0:12:13.79,0:12:17.92,Main-207+,,0,0,0,,まあ　そう言うな\N一緒に船を造る仲間なんだ
Dialogue: 0,0:12:17.92,0:12:22.30,Main-207+,,0,0,0,,造船技術も既に\N島の職人たちと比べても大差ねえし
Dialogue: 0,0:12:22.30,0:12:24.55,Main-207+,,0,0,0,,造るものは危なっかしいがな
Dialogue: 0,0:12:24.55,0:12:28.47,Main-207+,,0,0,0,,あいつはいつでもまっすぐなだけよ
Dialogue: 0,0:12:33.89,0:12:37.52,Main-207+,,0,0,0,,２年前にドンと廃船島に現れたガキが
Dialogue: 0,0:12:37.52,0:12:40.90,Main-207+,,0,0,0,,ガラクタを使って\N大砲を造っていたのには驚いた
Dialogue: 0,0:12:41.24,0:12:45.36,Flashbacks-207+,,0,0,0,,{Refer to W7 13 @22:13}おっさん　俺拾ってくれ！\N親から見捨てられたんだ！
Dialogue: 0,0:12:45.70,0:12:50.97,Main-207+,,0,0,0,,聞けば“手に負えねえガキだ”と\N親に船から放り出されたんだという
Dialogue: 0,0:12:50.97,0:12:54.08,Main-207+,,0,0,0,,どこぞのろくでもねえ海賊のようだが
Dialogue: 0,0:12:55.20,0:12:57.08,Main-207+,,0,0,0,,{Refer to W7 13 @22:13}傑作！
Dialogue: 0,0:12:56.19,0:12:57.08,Secondary-207+,,0,0,0,,トムさん
Dialogue: 0,0:12:57.08,0:12:59.05,Main-207+,,0,0,0,,たくましいじゃないの
Dialogue: 0,0:12:59.61,0:13:02.55,Main-207+,,0,0,0,,それでもあいつは曲がってねえんだ
Dialogue: 0,0:13:02.55,0:13:07.22,Main-207+,,0,0,0,,おめえら２人はいつか必ず\N世界に通用する造船技師になるんだ
Dialogue: 0,0:13:07.22,0:13:09.04,Main-207+,,0,0,0,,仲よくやんな
Dialogue: 0,0:13:09.04,0:13:12.77,Main-207+,,0,0,0,,フランキーには無理だね\N細胞からイカれてんだあいつは
Dialogue: 0,0:13:13.94,0:13:18.04,Main-207+,,0,0,0,,さあ　設計図ができしだい\N海列車を造り出すぞ
Dialogue: 0,0:13:18.04,0:13:21.70,Main-207+,,0,0,0,,おう…\Nだけどあいつきっと手伝わねえよ
Dialogue: 0,0:13:23.07,0:13:25.45,Main-207+,,0,0,0,,好きにしたらいいとも
Dialogue: 0,0:15:01.69,0:15:02.84,Main-207+,,0,0,0,,自殺？
Dialogue: 0,0:15:02.84,0:15:06.55,Main-207+,,0,0,0,,４番の造船会社の社長だと
Dialogue: 0,0:15:06.55,0:15:07.89,Main-207+,,0,0,0,,あの事故のせいだ
Dialogue: 0,0:15:08.54,0:15:12.42,Main-207+,,0,0,0,,物資がねえから\N自らの船で木材を買いに出て
Dialogue: 0,0:15:12.42,0:15:14.64,Main-207+,,0,0,0,,海で50人死なせたって
Dialogue: 0,0:15:15.19,0:15:17.61,Main-207+,,0,0,0,,造船所も閉鎖だそうだ
Dialogue: 0,0:15:18.43,0:15:20.82,Main-207+,,0,0,0,,弱えな　人間なんて
Dialogue: 0,0:15:21.46,0:15:24.31,Main-207+,,0,0,0,,もうダメなのか　この島は…
Dialogue: 0,0:15:24.31,0:15:25.86,Main-207+,,0,0,0,,おーい！
Dialogue: 0,0:15:25.86,0:15:29.15,Main-207+,,0,0,0,,お前ら聞いたか？廃船島の話
Dialogue: 0,0:15:30.55,0:15:32.45,Main-207+,,0,0,0,,お…　おい！それ本当かよ？
Dialogue: 0,0:15:32.99,0:15:36.37,Main-207+,,0,0,0,,トムズワーカーズが\N海列車を完成させただと！？
Dialogue: 0,0:15:36.37,0:15:39.91,Main-207+,,0,0,0,,うわっ！本当に走んのか？こんな船が！
Dialogue: 0,0:15:39.91,0:15:42.75,Main-207+,,0,0,0,,危ねえよ\N犯罪者の造った船なんて
Dialogue: 0,0:15:42.75,0:15:44.15,Main-207+,,0,0,0,,私乗る
Dialogue: 0,0:15:44.15,0:15:45.29,Main-207+,,0,0,0,,あ…　じゃあ俺も
Dialogue: 0,0:15:45.29,0:15:46.96,Main-207+,,0,0,0,,トム！説明はなしか？
Dialogue: 0,0:15:46.96,0:15:49.21,Main-207+,,0,0,0,,出航するよ　乗っとくれ
Dialogue: 0,0:15:56.26,0:15:57.55,Main-207+,,0,0,0,,動いた！
Dialogue: 0,0:15:57.55,0:16:00.13,Main-207+,,0,0,0,,パドルが線路をつかんでる！
Dialogue: 0,0:16:01.06,0:16:02.33,Main-207+,,0,0,0,,動いた！
Dialogue: 0,0:16:02.33,0:16:04.44,Main-207+,,0,0,0,,すごい　走ってる！
Dialogue: 0,0:16:15.21,0:16:18.42,Narrator-207+,,0,0,0,,今より12年前の話
Dialogue: 0,0:16:18.42,0:16:25.04,Narrator-207+,,0,0,0,,この時初めて閉ざされ　廃れゆく町から\N悩まされる人々を乗せて…
Dialogue: 0,0:16:30.01,0:16:34.59,Narrator-207+,,0,0,0,,海列車パッフィングトムは海を渡った
Dialogue: 0,0:16:42.27,0:16:44.13,Main-207+,,0,0,0,,なるほど
Dialogue: 0,0:16:44.98,0:16:52.49,Main-207+,,0,0,0,,この薄汚い倉庫は\Nかつての造船会社トムズワーカーズの本社か
Dialogue: 0,0:16:53.78,0:16:54.99,Main-207+,,0,0,0,,造船会社？
Dialogue: 0,0:16:56.04,0:16:59.34,Main-207+,,0,0,0,,トム　アイスバーグ　カティ･フラム
Dialogue: 0,0:17:00.10,0:17:04.46,Main-207+,,0,0,0,,３人で造船にいそしんだ\N思い出の場所というわけだな
Dialogue: 0,0:17:05.17,0:17:10.67,Main-207+,,0,0,0,,それを秘密基地と呼ぶとは\Nずいぶんかわいげのあることをするもんだな
Dialogue: 0,0:17:10.67,0:17:12.55,Main-207+,,0,0,0,,黙れ！
Dialogue: 0,0:17:12.55,0:17:14.63,Main-207+,,0,0,0,,さっさとここから出ろ！
Dialogue: 0,0:17:14.63,0:17:19.80,Main-207+,,0,0,0,,もらうべきものをもらってからだ\N船大工カティ･フラム
Dialogue: 0,0:17:19.80,0:17:21.90,Main-207+,,0,0,0,,設計図はここにはねえよ！
Dialogue: 0,0:17:22.77,0:17:26.26,Main-207+,,0,0,0,,まっ　当然といえば当然の答え
Dialogue: 0,0:17:27.52,0:17:28.19,Main-207+,,0,0,0,,おい！
Dialogue: 0,0:17:28.19,0:17:29.23,Main-207+,,0,0,0,,カリファ！
Dialogue: 0,0:17:33.37,0:17:34.91,Main-207+,,0,0,0,,痛え…
Dialogue: 0,0:17:37.62,0:17:40.54,Main-207+,,0,0,0,,どど…　どうしよう俺
Dialogue: 0,0:17:43.75,0:17:45.63,Main-207+,,0,0,0,,てめえ…
Dialogue: 0,0:17:46.32,0:17:49.84,Main-207+,,0,0,0,,別に\N今すぐ答える必要もないさ
Dialogue: 0,0:17:49.84,0:17:52.55,Main-207+,,0,0,0,,我々には切り札がある
Dialogue: 0,0:17:52.55,0:17:55.25,Main-207+,,0,0,0,,８年も昔の話だが
Dialogue: 0,0:17:55.25,0:17:58.14,Main-207+,,0,0,0,,君は犯罪を犯してるらしいな
Dialogue: 0,0:17:58.76,0:18:00.43,Main-207+,,0,0,0,,トムと同じように
Dialogue: 0,0:18:00.43,0:18:03.43,Main-207+,,0,0,0,,ふざけるな！\Nトムさんは犯罪者じゃねえ！
Dialogue: 0,0:18:03.43,0:18:05.89,Main-207+,,0,0,0,,てめえなんかが分かったふうな口利くな！
Dialogue: 0,0:18:05.89,0:18:07.06,Main-207+,,0,0,0,,ガキが！
Dialogue: 0,0:18:16.06,0:18:18.07,Main-207+,,0,0,0,,トムさん…
Dialogue: 0,0:18:20.69,0:18:21.60,Main-207+,,0,0,0,,来ないで！
Dialogue: 0,0:18:22.45,0:18:23.99,Main-207+,,0,0,0,,騒ぐな
Dialogue: 0,0:18:23.99,0:18:29.77,Main-207+,,0,0,0,,犯罪者ならば\N自分がどういう道をたどるか分かるはずだ
Dialogue: 0,0:18:30.66,0:18:31.54,Flashbacks-207+,,0,0,0,,フランキー
Dialogue: 0,0:18:32.05,0:18:34.76,Flashbacks-207+,,0,0,0,,{Z - Flashback to W7 13 @14:15}これから起こることに口を出すな
Dialogue: 0,0:18:34.76,0:18:36.18,Flashbacks-207+,,0,0,0,,絶対に！
Dialogue: 0,0:18:36.74,0:18:38.93,Main-207+,,0,0,0,,てめえらがどれほど
Dialogue: 0,0:18:40.27,0:18:41.51,Main-207+,,0,0,0,,トムさんを
Dialogue: 0,0:18:43.05,0:18:47.40,Main-207+,,0,0,0,,このウォーターセブンを知ってるってんだよ！
Dialogue: 0,0:18:57.55,0:19:00.57,Main-207+,,0,0,0,,３日後に司法船が来るんですって？
Dialogue: 0,0:19:00.57,0:19:03.08,Main-207+,,0,0,0,,いよいよトムの裁判か
Dialogue: 0,0:19:03.08,0:19:04.87,Main-207+,,0,0,0,,どうなるのかしら？
Dialogue: 0,0:19:04.87,0:19:06.58,Main-207+,,0,0,0,,大丈夫だろう
Dialogue: 0,0:19:06.58,0:19:07.83,Main-207+,,0,0,0,,そうね
Dialogue: 0,0:19:08.25,0:19:10.60,Main-207+,,0,0,0,,ちゃんと約束を果たしたんですもんね
Dialogue: 0,0:19:10.60,0:19:11.68,Main-207+,,0,0,0,,ああ
Dialogue: 0,0:19:15.17,0:19:17.79,Main-207+,,0,0,0,,届いた木材をドックへ運び込め
Dialogue: 0,0:19:17.79,0:19:20.55,Main-207+,,0,0,0,,セント･ポプラでの交渉はうまくいったか？
Dialogue: 0,0:19:20.55,0:19:22.05,Main-207+,,0,0,0,,まだダメだ
Dialogue: 0,0:19:22.05,0:19:25.44,Main-207+,,0,0,0,,あいつら資材のねえ俺たちの足元を見やがる
Dialogue: 0,0:19:25.44,0:19:27.31,Main-207+,,0,0,0,,サン･ファルドの鉄もそうだ
Dialogue: 0,0:19:27.31,0:19:30.27,Main-207+,,0,0,0,,あんなに高くちゃ結局造船所は赤字だぜ
Dialogue: 0,0:19:30.27,0:19:33.66,Main-207+,,0,0,0,,でも次こそ何とかしてやろうじゃねえか！
Dialogue: 0,0:19:33.66,0:19:35.77,Main-207+,,0,0,0,,–　おおー！そうだそうだ！\N–　おおー！そうだそうだ！
Dialogue: 0,0:19:41.12,0:19:44.41,Main-207+,,0,0,0,,海を渡れることにみんな喜んでるけど
Dialogue: 0,0:19:44.41,0:19:47.37,Main-207+,,0,0,0,,他の島との交易は難航らしい
Dialogue: 0,0:19:48.18,0:19:50.21,Main-207+,,0,0,0,,これでも町は変わらねえのかな
Dialogue: 0,0:19:52.79,0:19:55.37,Main-207+,,0,0,0,,だが人間に活気がある
Dialogue: 0,0:19:55.37,0:19:58.55,Main-207+,,0,0,0,,結果はすぐについてこねえよアイスバーグ
Dialogue: 0,0:19:58.55,0:20:03.14,Main-207+,,0,0,0,,やれるだけのことをやったら\N男はドンと胸を張ってりゃいいんだ
Dialogue: 0,0:20:03.91,0:20:04.69,Main-207+,,0,0,0,,ああ
Dialogue: 0,0:20:14.49,0:20:16.20,Main-207+,,0,0,0,,どうもこんにちは
Dialogue: 0,0:20:16.20,0:20:19.81,Main-207+,,0,0,0,,あなたですか？\N造船技師のミスター･トムとは
Dialogue: 0,0:20:19.81,0:20:22.11,Main-207+,,0,0,0,,いやあ　捜しました
Dialogue: 0,0:20:22.11,0:20:23.32,Main-207+,,0,0,0,,ん？
Dialogue: 0,0:20:23.32,0:20:26.20,Main-207+,,0,0,0,,すみませんが 少々お話…
Dialogue: 0,0:20:25.55,0:20:26.20,Secondary-207+,,0,0,0,,あの…
Dialogue: 0,0:20:26.20,0:20:28.14,Main-207+,,0,0,0,,口を挟むな　下がってろ！
Dialogue: 0,0:20:28.14,0:20:28.75,Main-207+,,0,0,0,,–　はっ\N–　はっ
Dialogue: 0,0:20:28.75,0:20:31.21,Main-207+,,0,0,0,,少々お話をさせていただき…
Dialogue: 0,0:20:35.75,0:20:38.43,Main-207+,,0,0,0,,わっ　私は…
Dialogue: 0,0:20:38.43,0:20:41.66,Main-207+,,0,0,0,,サイファーポールナンバー５の
Dialogue: 0,0:20:41.66,0:20:43.18,Main-207+,,0,0,0,,スパンダ…
Dialogue: 0,0:20:43.18,0:20:44.01,Main-207+,,0,0,0,,–　スパンダムさん！\Nスパンダムさん！
Dialogue: 0,0:20:47.51,0:20:49.72,Main-207+,,0,0,0,,おう！悪い
Dialogue: 0,0:20:49.72,0:20:53.19,Main-207+,,0,0,0,,誰だか知らねえが\N祝砲が当たっちまった
Dialogue: 0,0:20:53.19,0:20:54.07,Main-207+,,0,0,0,,そして
Dialogue: 0,0:20:55.11,0:21:00.00,Main-207+,,0,0,0,,スーパー！\Nバトルフランキー35号　帰還！
Dialogue: 0,0:21:00.00,0:21:01.40,Main-207+,,0,0,0,,海王類をしとめたぜ！
Dialogue: 0,0:21:01.82,0:21:05.87,Main-207+,,0,0,0,,見よ！このでかさ\N全長100メートルはあろうかって怪物だ！
Dialogue: 0,0:21:07.99,0:21:10.70,Main-207+,,0,0,0,,あのバカは…\Nまた性懲りもなく
Dialogue: 0,0:21:12.57,0:21:16.80,Main-207+,,0,0,0,,だーっ！\Nてめえ！やめろ！このアホバーグ！
Dialogue: 0,0:21:17.46,0:21:19.01,Main-207+,,0,0,0,,何度言わせるんだ！
Dialogue: 0,0:21:19.01,0:21:22.09,Main-207+,,0,0,0,,次から次へといまだに\Nこんな戦艦造り続けやがって
Dialogue: 0,0:21:22.63,0:21:24.09,Main-207+,,0,0,0,,いいかげんにしろよ！
Dialogue: 0,0:21:24.09,0:21:28.24,Main-207+,,0,0,0,,お前にできねえなら\N今日という今日は俺が全部処分してやる！
Dialogue: 0,0:21:28.24,0:21:29.01,Main-207+,,0,0,0,,ふざけるな！
Dialogue: 0,0:21:29.01,0:21:30.98,Main-207+,,0,0,0,,俺の大事な戦艦だぞ
Dialogue: 0,0:21:30.98,0:21:33.55,Main-207+,,0,0,0,,そんな勝手なことさせるか！
Dialogue: 0,0:21:33.55,0:21:35.48,Main-207+,,0,0,0,,ンマーいいか？フランキー
Dialogue: 0,0:21:35.48,0:21:38.08,Main-207+,,0,0,0,,お前海王類をしとめたんだろ？
Dialogue: 0,0:21:38.08,0:21:40.11,Main-207+,,0,0,0,,これはそれほどの凶器だってことだ
Dialogue: 0,0:21:40.11,0:21:44.19,Main-207+,,0,0,0,,{Gaijin - W7 13 @08:26}そんなもんを何十隻も放置できる\Nお前の神経が分からねえ！
Dialogue: 0,0:21:44.19,0:21:47.12,Main-207+,,0,0,0,,別に人を攻撃するわけじゃねえだろうが！
Dialogue: 0,0:21:47.66,0:21:49.73,Main-207+,,0,0,0,,お前の意志どうこうじゃねえ
Dialogue: 0,0:21:49.73,0:21:52.99,Main-207+,,0,0,0,,{arch: Matching Flashback in W7-13 @08:31}凶器を存在させた責任を\N問いかけてんだ　バカンキー！
Dialogue: 0,0:21:53.88,0:21:55.54,Main-207+,,0,0,0,,ちょっ　ちょ…
Dialogue: 0,0:21:57.62,0:22:00.46,Main-207+,,0,0,0,,トムさん！何とか言ってくれよ！
Dialogue: 0,0:22:00.46,0:22:03.05,Main-207+,,0,0,0,,我が社の面汚しだバカンキーは！
Dialogue: 0,0:22:03.05,0:22:04.92,Main-207+,,0,0,0,,またバカンキーって
Dialogue: 0,0:22:06.98,0:22:08.89,Main-207+,,0,0,0,,ちょっと！お待ちくださいよ！
Dialogue: 0,0:22:09.43,0:22:13.97,Main-207+,,0,0,0,,まずはちゃんと謝ってほしい\Nそして私の話を聞いてほしい！
Dialogue: 0,0:22:13.97,0:22:16.45,Main-207+,,0,0,0,,政府の人間だな？
Dialogue: 0,0:22:16.45,0:22:18.06,Main-207+,,0,0,0,,裁判の件か？
Dialogue: 0,0:22:18.06,0:22:20.90,Main-207+,,0,0,0,,え？何です？それは
Dialogue: 0,0:22:20.90,0:22:24.03,Main-207+,,0,0,0,,いえ　そちらのほうは\N存じていませんが
Dialogue: 0,0:22:24.03,0:22:25.74,Main-207+,,0,0,0,,ん？
Dialogue: 0,0:22:28.36,0:22:29.87,Main-207+,,0,0,0,,トムさんはどうした？
Dialogue: 0,0:22:29.87,0:22:32.69,Main-207+,,0,0,0,,２人きりで話すんだと
Dialogue: 0,0:22:32.69,0:22:35.80,Main-207+,,0,0,0,,レンガ倉庫にいるよ　政府のヤツと
Dialogue: 0,0:22:35.80,0:22:38.20,Main-207+,,0,0,0,,スパン…　何だっけ？
Dialogue: 0,0:22:38.20,0:22:40.08,Main-207+,,0,0,0,,スパンダ何とかだ
Dialogue: 0,0:22:40.08,0:22:43.48,Main-207+,,0,0,0,,ありゃあ司法船とは別の役人だね
Dialogue: 0,0:22:43.48,0:22:46.05,Main-207+,,0,0,0,,まとまりのねえヤツらだよ
Dialogue: 0,0:22:49.07,0:22:52.12,Main-207+,,0,0,0,,知らん！\Nそんなものの設計図は持ってねえ
Dialogue: 0,0:22:53.56,0:22:54.90,Main-207+,,0,0,0,,ウソをつけ！
Dialogue: 0,0:22:54.90,0:22:57.71,Main-207+,,0,0,0,,人が下手に出てりゃシラを切り倒しやがって
Dialogue: 0,0:22:57.71,0:23:00.90,Main-207+,,0,0,0,,ウォーターセブンをさかのぼり\Nもう調べはついてるんだ！
Dialogue: 0,0:23:00.90,0:23:04.77,Main-207+,,0,0,0,,身の回りを取り調べれば\Nあっという間に現物が出てくる
Dialogue: 0,0:23:06.88,0:23:09.78,Main-207+,,0,0,0,,わしを調べる権限がお前らにあるのか？
Dialogue: 0,0:23:10.55,0:23:12.69,Main-207+,,0,0,0,,あるともトム
Dialogue: 0,0:23:12.69,0:23:18.25,Main-207+,,0,0,0,,お前がゴールド･ロジャーの船を造った\N大罪人だってのも　何と調査済みだ
Dialogue: 0,0:23:18.25,0:23:22.56,Main-207+,,0,0,0,,罪人である以上\Nお前の身柄はこちらの自由になるわけだ
Dialogue: 0,0:23:22.56,0:23:25.60,Main-207+,,0,0,0,,そんなことは　とうに政府に漏れてる
Dialogue: 0,0:23:25.60,0:23:26.46,Main-207+,,0,0,0,,何！？
Dialogue: 0,0:23:26.46,0:23:28.47,Main-207+,,0,0,0,,そんなバカな
Dialogue: 0,0:23:28.47,0:23:32.93,Main-207+,,0,0,0,,じゃあ　なぜ貴様は捕まらず\Nここで船大工をやってるんだ！
Dialogue: 0,0:23:32.93,0:23:36.95,Main-207+,,0,0,0,,諜報部員なら自分で調べろ\Nじゃあな
Dialogue: 0,0:23:38.74,0:23:40.89,Main-207+,,0,0,0,,おい待て！話はまだだ！
Dialogue: 0,0:23:40.89,0:23:42.94,Main-207+,,0,0,0,,俺を誰だと思ってるんだ！
Dialogue: 0,0:23:45.91,0:23:47.86,Main-207+,,0,0,0,,何だ　そのことかい
Dialogue: 0,0:23:47.86,0:23:52.16,Main-207+,,0,0,0,,トムなら司法船との約束を果たしたからな
Dialogue: 0,0:23:52.16,0:23:56.01,Main-207+,,0,0,0,,３日後の裁判で罪は帳消しになるだろう
Dialogue: 0,0:23:56.01,0:23:58.41,Main-207+,,0,0,0,,偉大な男だよ　トムは
Dialogue: 0,0:23:58.41,0:24:00.34,Main-207+,,0,0,0,,冗談じゃねえ
Dialogue: 0,0:24:00.92,0:24:04.07,Main-207+,,0,0,0,,ロジャーに関わる大罪が帳消しだと？
Dialogue: 0,0:24:04.69,0:24:08.76,Flashbacks-207+,,0,0,0,,やはりそんなものが存在したか
Dialogue: 0,0:24:08.76,0:24:09.81,Flashbacks-207+,,0,0,0,,はい
Dialogue: 0,0:24:09.81,0:24:12.91,Flashbacks-207+,,0,0,0,,当然この設計図を嗅ぎ回る海賊もいます
Dialogue: 0,0:24:12.91,0:24:16.78,Flashbacks-207+,,0,0,0,,万が一\N政府以外の誰かの手にそれが渡った場合
Dialogue: 0,0:24:16.78,0:24:20.06,Flashbacks-207+,,0,0,0,,もはや\N政府に太刀打ちするすべはありません
Dialogue: 0,0:24:20.06,0:24:24.18,Flashbacks-207+,,0,0,0,,世に言う大海賊時代幕開けから10年以上経過し
Dialogue: 0,0:24:24.18,0:24:28.02,Flashbacks-207+,,0,0,0,,海賊どもはみるみる力をつけ\N数も増加するばかり
Dialogue: 0,0:24:28.02,0:24:32.89,Flashbacks-207+,,0,0,0,,古代兵器の復活阻止など\Nのんびりとしたことを言ってる場合ではありません
Dialogue: 0,0:24:32.89,0:24:36.37,Flashbacks-207+,,0,0,0,,正義を掲げる我々こそこれくらいの牙を持たねば！
Dialogue: 0,0:24:36.37,0:24:41.54,Flashbacks-207+,,0,0,0,,古代兵器は我々が所持し\Nこの大海賊時代を撃ち払うのです！
Dialogue: 0,0:24:43.33,0:24:47.54,Flashbacks-207+,,0,0,0,,時代は動いている\N一理なくもないが…
Dialogue: 0,0:24:47.54,0:24:52.92,Flashbacks-207+,,0,0,0,,ならばその設計図とやらをまず手に入れてみせろ\N話はその先だ
Dialogue: 0,0:24:52.92,0:24:56.51,Flashbacks-207+,,0,0,0,,この件お前に一任しようスパンダム
Dialogue: 0,0:24:56.51,0:24:59.15,Flashbacks-207+,,0,0,0,,はっ！お任せください
Dialogue: 0,0:25:00.06,0:25:04.19,Main-207+,,0,0,0,,さんざん苦労を積み重ね\N調べ上げて得たこのチャンスを
Dialogue: 0,0:25:04.19,0:25:06.36,Main-207+,,0,0,0,,みすみす棒に振ってたまるか！
Dialogue: 0,0:25:10.74,0:25:11.67,Main-207+,,0,0,0,,行くぞ！
Dialogue: 0,0:25:15.03,0:25:19.91,Main-207+,,0,0,0,,クソッ　ヤツが犯罪者でなくちゃ\N困るんだよ　俺が！
Dialogue: 0,0:25:20.99,0:25:21.94,Main-207+,,0,0,0,,–　スパンダムさん！\N–　スパンダムさん！
Dialogue: 0,0:25:28.33,0:25:30.13,Main-207+,,0,0,0,,何が帳消し…
Dialogue: 0,0:25:30.13,0:25:31.97,Main-207+,,0,0,0,,見てやがれ　生意気な
Dialogue: 0,0:25:32.88,0:25:36.08,Main-207+,,0,0,0,,おい！\Nあと５人諜報部員を呼びつけろ
Dialogue: 0,0:25:36.08,0:25:36.68,Main-207+,,0,0,0,,–　はっ！\N–　はっ！
Dialogue: 0,0:25:42.25,0:25:44.48,Main-207+,,0,0,0,,–　スパンダムさん！\N–　スパンダムさん！
Dialogue: 0,0:25:47.07,0:25:48.78,Main-207+,,0,0,0,,アイスバーグ　フランキー
Dialogue: 0,0:25:48.78,0:25:49.45,Main-207+,,0,0,0,,ん？
Dialogue: 0,0:25:49.45,0:25:51.65,Main-207+,,0,0,0,,２人ともこっちへ来い
Dialogue: 0,0:25:51.65,0:25:54.61,Main-207+,,0,0,0,,大切なものをお前たちに預けたい
Dialogue: 0,0:25:58.17,0:26:01.59,Main-207+,,0,0,0,,な…　何のためにこんなものが…
Dialogue: 0,0:26:01.59,0:26:05.33,Main-207+,,0,0,0,,こ…　こんなもん人間に造れんのか？
Dialogue: 0,0:26:05.33,0:26:09.29,Main-207+,,0,0,0,,造船史上最悪の　化け物だ
Dialogue: 0,0:26:09.29,0:26:13.53,Main-207+,,0,0,0,,政府がこの設計図の存在に気づいて\N動きだしている
Dialogue: 0,0:26:13.53,0:26:15.80,Main-207+,,0,0,0,,わしが持っていてはもう危ねえ
Dialogue: 0,0:26:15.80,0:26:20.22,Main-207+,,0,0,0,,怖えけど…\N分かった　受け取るよ
Dialogue: 0,0:26:20.22,0:26:25.10,Main-207+,,0,0,0,,すんげえ！アイスバーグ\Nおい！これ造ってみようぜ！
Dialogue: 0,0:26:25.10,0:26:26.28,Main-207+,,0,0,0,,バカ野郎！
Dialogue: 0,0:26:26.28,0:26:28.39,Main-207+,,0,0,0,,いってえ…
Dialogue: 0,0:26:28.39,0:26:30.34,Main-207+,,0,0,0,,少しは考えて物言え！
Dialogue: 0,0:26:30.34,0:26:32.06,Main-207+,,0,0,0,,これは俺が管理する
Dialogue: 0,0:26:32.06,0:26:34.48,Main-207+,,0,0,0,,こんなもん\Nこの世に存在さしちまったら…
Dialogue: 0,0:26:35.38,0:26:36.22,Main-207+,,0,0,0,,ん？
Dialogue: 0,0:26:39.16,0:26:41.83,Main-207+,,0,0,0,,ああ　世界は滅ぶ
Dialogue: 0,0:26:46.37,0:26:50.26,Main-207+,,0,0,0,,しかしもう\Nどうしようとおめえらの自由さ
Dialogue: 0,0:26:50.26,0:26:51.96,Main-207+,,0,0,0,,ヤバくなったら捨てたっていい
Dialogue: 0,0:26:51.96,0:26:53.46,Main-207+,,0,0,0,,トムさん
Dialogue: 0,0:26:53.46,0:26:55.26,Main-207+,,0,0,0,,ついでに１つ
Dialogue: 0,0:26:56.06,0:26:58.65,Main-207+,,0,0,0,,わしの不安要素も伝えておく
