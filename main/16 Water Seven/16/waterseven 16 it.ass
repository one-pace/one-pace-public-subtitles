Comment: 0,0:00:00.00,0:00:00.00,Main-207+,,0,0,0,,{=8}===============================DIALOGUE============================
Dialogue: 0,0:02:07.02,0:02:09.48,Main-207+,,0,0,0,,È scesa fino ai sobborghi!{circa}
Dialogue: 0,0:02:13.53,0:02:15.07,Main-207+,,0,0,0,,– Aspetta!\N– Non andare nei sobborghi!
Dialogue: 0,0:02:15.07,0:02:16.74,Main-207+,,0,0,0,,Non seguitela!
Dialogue: 0,0:02:17.33,0:02:18.58,Main-207+,,0,0,0,,Signor Paulie!
Dialogue: 0,0:02:18.58,0:02:21.08,Main-207+,,0,0,0,,Andare in tanti non servirà a niente!
Dialogue: 0,0:02:21.08,0:02:22.16,Main-207+,,0,0,0,,Però...!
Dialogue: 0,0:02:22.16,0:02:24.58,Main-207+,,0,0,0,,L'avversario è il mare!
Dialogue: 0,0:02:24.58,0:02:26.54,Main-207+,,0,0,0,,Finirete solo per rimetterci tutti le penne.{molto circa, è il sentimento. di suo è tipo "non farete altro che diventare compagni di viaggio" dove compagno di viaggio è inteso come trascinare qualcuno con sé}
Dialogue: 0,0:02:26.54,0:02:28.84,Main-207+,,0,0,0,,Qualunque cosa accada, agirò solo io.
Dialogue: 0,0:02:28.84,0:02:31.01,Main-207+,,0,0,0,,Ne ha di coraggio per correre laggiù.
Dialogue: 0,0:02:31.01,0:02:32.59,Main-207+,,0,0,0,,Che razza di donna!
Dialogue: 0,0:02:32.59,0:02:34.26,Main-207+,,0,0,0,,Idioti! Non state lì ad ammirarla!{ew... ma non mi viene meglio di così... con ammirarla è nel senso che sono un po' impressionati da lei circa}
Dialogue: 0,0:02:34.72,0:02:37.05,Main-207+,,0,0,0,,Ehi! Torna subito qui!
Dialogue: 0,0:02:37.05,0:02:39.18,Main-207+,,0,0,0,,Verrai inghiottita dal mare!
Dialogue: 0,0:02:39.18,0:02:40.97,Thoughts-207+,,0,0,0,,È un anemone di mare!{ew la voce pls... also io le chiamo così, wikipedia mi dice che si chiamano anche attinie -angy}
Dialogue: 0,0:02:45.02,0:02:47.27,Thoughts-207+,,0,0,0,,Un anemone di mare...
Dialogue: 0,0:02:47.27,0:02:50.02,Thoughts-207+,,0,0,0,,Un anemone di mare nel camino...
Dialogue: 0,0:02:50.02,0:02:51.78,Thoughts-207+,,0,0,0,,Ma perché c'è un anemone di mare?{sarebbe "ma perché un anemone di mare?"}
Dialogue: 0,0:02:52.53,0:02:54.53,Thoughts-207+,,0,0,0,,Un anemone di mare...{e fu così che tutto il team imparò che "isoginchaku" vuol dire anemone di mare XD}
Dialogue: 0,0:03:11.59,0:03:14.34,Main-207+,,0,0,0,,Ehi, aspetta, renna! Non anche tu!
Dialogue: 0,0:03:14.34,0:03:15.88,Main-207+,,0,0,0,,Zoro!{vi prego, sta voce T_T}
Dialogue: 0,0:03:17.97,0:03:20.97,Main-207+,,0,0,0,,Sorella pirata, sei fantastica!
Dialogue: 0,0:03:21.56,0:03:23.73,Main-207+,,0,0,0,,Che incosciente...{di suo è tipo "che gesto idiota", ma l'idea è quella e secondo me ci sta}
Dialogue: 0,0:03:23.73,0:03:26.02,Main-207+,,0,0,0,,Non farà a tempo!
Dialogue: 0,0:03:26.02,0:03:27.19,Main-207+,,0,0,0,,Guarda al largo!
Dialogue: 0,0:03:28.06,0:03:31.23,Main-207+,,0,0,0,,L'onda è già arrivata là!
Dialogue: 0,0:03:33.15,0:03:35.65,Main-207+,,0,0,0,,Oh no! Moriranno!
Dialogue: 0,0:03:35.65,0:03:37.16,Main-207+,,0,0,0,,Non possono salvarsi!
Dialogue: 0,0:03:40.20,0:03:42.66,Main-207+,,0,0,0,,Zoro! Zoro!
Dialogue: 0,0:03:42.66,0:03:44.12,Main-207+,,0,0,0,,Mi senti?!
Dialogue: 0,0:03:44.12,0:03:45.58,Main-207+,,0,0,0,,Sono io!
Dialogue: 0,0:03:46.00,0:03:47.08,Main-207+,,0,0,0,,Chopper?!
Dialogue: 0,0:03:51.96,0:03:53.21,Main-207+,,0,0,0,,Così non va!
Dialogue: 0,0:03:53.21,0:03:55.05,Main-207+,,0,0,0,,Non posso andare avanti!
Dialogue: 0,0:04:02.68,0:04:04.81,Main-207+,,0,0,0,,Luffy!
Dialogue: 0,0:04:11.11,0:04:14.28,Main-207+,,0,0,0,,Tu! Che stai facendo lassù?!{sarebbe là}
Dialogue: 0,0:04:16.74,0:04:20.91,Main-207+,,0,0,0,,Mn... Mnami! Sei bietro di me?!{parla male in jp, fate voi}
Dialogue: 0,0:04:22.16,0:04:24.95,Main-207+,,0,0,0,,No, ecco, senti!
Dialogue: 0,0:04:24.95,0:04:32.00,Main-207+,,0,0,0,,Quel tizio col piccione mi ha sbazzato via! \NE così sono finito a fagiolo qui!{anche qua poche cose le dice male -angy}
Dialogue: 0,0:04:43.39,0:04:47.02,Main-207+,,0,0,0,,Smettila di scherzare in un momento \Nimportante come questo!
Dialogue: 0,0:04:47.02,0:04:51.10,Main-207+,,0,0,0,,Finché tu eri lì a perdere tempo, \NRobin è stata portata via!
Comment: 0,0:04:55.78,0:04:58.15,Main-207+,,0,0,0,,
Comment: 0,0:04:58.69,0:05:00.82,Main-207+,,0,0,0,,
Dialogue: 0,0:04:55.78,0:05:00.82,Main-207+,,0,0,0,,Robin ha intenzione di morire... \Nper il nostro bene!{in jp "intenzione di morire" è la seconda parte}
Dialogue: 0,0:05:11.00,0:05:17.21,Main-207+,,0,0,0,,Sacrificando solo se stessa, \Nci ha protetti tutti dall'attacco del governo!
Dialogue: 0,0:05:18.01,0:05:21.22,Flashbacks-207+,,0,0,0,,{ALA 21 @ 12:54}Non ho né destinazione \Nné posto in cui tornare.
Dialogue: 0,0:05:21.59,0:05:23.47,Flashbacks-207+,,0,0,0,,{W7 10 - 26:42 (una parte)}Ti sbagli. Abbiamo finito.
Dialogue: 0,0:05:23.47,0:05:25.35,Flashbacks-207+,,0,0,0,,Non ci vedremo mai più.{seconda parte del flashback sopra, W7 10 @ 26:42}
Dialogue: 0,0:05:26.93,0:05:30.81,Main-207+,,0,0,0,,Anche se sapeva che sarebbe stata \Nuccisa se l'avessero portata via!
Dialogue: 0,0:05:34.06,0:05:35.65,Main-207+,,0,0,0,,Allora...
Dialogue: 0,0:05:35.65,0:05:37.73,Main-207+,,0,0,0,,Robin stava...
Dialogue: 0,0:05:38.61,0:05:40.74,Main-207+,,0,0,0,,davvero mentendo?
Dialogue: 0,0:05:43.53,0:05:44.45,Main-207+,,0,0,0,,Sì!
Dialogue: 0,0:05:46.28,0:05:48.08,Main-207+,,0,0,0,,Che sollievo...{per fortuna}
Dialogue: 0,0:05:52.46,0:05:53.92,Main-207+,,0,0,0,,Non preoccuparti!
Dialogue: 0,0:05:55.38,0:05:57.71,Main-207+,,0,0,0,,Non lascerò Robin morire!
Dialogue: 0,0:05:58.09,0:05:59.59,Main-207+,,0,0,0,,Guardate quell'onda!
Dialogue: 0,0:05:59.59,0:06:02.68,Main-207+,,0,0,0,,Ma cos'è?! È veramente \Nmolto più grande del solito!
Dialogue: 0,0:06:03.05,0:06:05.47,Main-207+,,0,0,0,,Ehi! Siamo seriamente nei guai!
Dialogue: 0,0:06:05.47,0:06:08.72,Main-207+,,0,0,0,,Donna pirata! Arrenditi e scappa!
Dialogue: 0,0:06:08.72,0:06:10.02,Main-207+,,0,0,0,,Renna!
Dialogue: 0,0:06:14.27,0:06:15.31,Main-207+,,0,0,0,,Mi stai strappando!{ewwwwwwwwwwwwww}
Dialogue: 0,0:06:15.31,0:06:16.81,Main-207+,,0,0,0,,Non riesco a farti uscire!
Dialogue: 0,0:06:16.81,0:06:18.98,Main-207+,,0,0,0,,Ma come sei entrato qui, Zoro?!
Dialogue: 0,0:06:18.98,0:06:20.32,Main-207+,,0,0,0,,Non tirarmi!
Dialogue: 0,0:06:29.12,0:06:32.54,Main-207+,,0,0,0,,Che faccio?! \NQuell'onda enorme è già vicinissima!{direbbe "è già arrivata fin là"... also, non ce la faccio sta voce}
Dialogue: 0,0:06:33.33,0:06:35.21,Main-207+,,0,0,0,,Anche se me lo chiedi...{riferito al "che faccio"}
Dialogue: 0,0:06:36.29,0:06:38.21,Main-207+,,0,0,0,,Ma tu... ehi, aspetta un attimo!
Dialogue: 0,0:06:38.21,0:06:41.09,Main-207+,,0,0,0,,Non è che hai Kitetsu con te?
Dialogue: 0,0:06:41.09,0:06:42.97,Main-207+,,0,0,0,,Eh? La spada?
Dialogue: 0,0:06:42.97,0:06:44.34,Main-207+,,0,0,0,,Sì, ce l'ho.
Dialogue: 0,0:06:44.34,0:06:45.59,Main-207+,,0,0,0,,Come l'hai capito?
Dialogue: 0,0:06:45.59,0:06:49.43,Main-207+,,0,0,0,,{\fs70\an8}Nota: "Yoto" significa "spada maledetta".
Dialogue: 0,0:06:45.59,0:06:49.43,Main-207+,,0,0,0,,Lo posso capire... solo per quella.\NPerché è una Yoto.
Dialogue: 0,0:06:49.97,0:06:51.72,Main-207+,,0,0,0,,Me l'hai portata, Chopper?{meh}
Dialogue: 0,0:06:51.72,0:06:52.52,Main-207+,,0,0,0,,Grazie!
Dialogue: 0,0:06:52.52,0:06:55.06,Main-207+,,0,0,0,,Mettimela in mano! Sbrigati!
Dialogue: 0,0:06:55.85,0:06:56.85,Main-207+,,0,0,0,,Veloci, scappate!
Dialogue: 0,0:06:56.85,0:07:00.11,Main-207+,,0,0,0,,Salite su un posto alto! \NUn posto ancora più alto!
Dialogue: 0,0:07:00.94,0:07:02.78,Main-207+,,0,0,0,,Ormai è inutile! Non faranno a tempo!
Dialogue: 0,0:07:02.78,0:07:05.74,Main-207+,,0,0,0,,Verranno inghiottiti!
Dialogue: 0,0:07:10.66,0:07:13.70,Main-207+,,0,0,0,,È l'Aqua Laguna!
Dialogue: 0,0:07:26.30,0:07:27.84,Main-207+,,0,0,0,,Ma cos'è...
Dialogue: 0,0:07:34.93,0:07:36.27,Main-207+,,0,0,0,,Ormai è inutile!
Dialogue: 0,0:08:01.50,0:08:05.05,Main-207+,,0,0,0,,Ma che succede?! L'edificio si è rotto!
Dialogue: 0,0:08:15.81,0:08:17.10,Main-207+,,0,0,0,,Zoro!
Dialogue: 0,0:08:17.10,0:08:19.31,Main-207+,,0,0,0,,Allontanati, Chopper!
Dialogue: 0,0:08:19.31,0:08:20.81,Main-207+,,0,0,0,,{\fad(150,150)}Ittouryuu...
Dialogue: 0,0:08:20.81,0:08:23.98,Main-207+,,0,0,0,,{\fad(150,150)\an8\fs70\q2}Nota: Gioco di parole che si riferisce a "trentasei fenici kleśa"\No a "trentasei colpi di cannone".
Dialogue: 0,0:08:20.81,0:08:23.98,Main-207+,,0,0,0,,{\fad(150,150)}Sanjuroku Pondo Ho!{c'ho tagliato le u per i dittonghi e le u lunghe...}
Dialogue: 0,0:08:31.78,0:08:33.91,Main-207+,,0,0,0,,Ma chi diavolo sono quei tizi?!{cosa sonio}
Dialogue: 0,0:08:35.12,0:08:37.33,Main-207+,,0,0,0,,Andiamo, Nami!
Dialogue: 0,0:08:41.38,0:08:43.00,Main-207+,,0,0,0,,Ma che roba è?!
Dialogue: 0,0:08:43.00,0:08:45.34,Main-207+,,0,0,0,,{\fad(150,150)}Rumble! Jumping Point!
Dialogue: 0,0:08:46.76,0:08:47.67,Main-207+,,0,0,0,,Aggrappati, Zoro!
Comment: 0,0:08:57.35,0:08:58.64,Main-207+,,0,0,0,,
Dialogue: 0,0:08:57.35,0:08:58.64,Main-207+,,0,0,0,,I sobborghi...!
Dialogue: 0,0:09:02.48,0:09:03.19,Main-207+,,0,0,0,,Maledizione!
Dialogue: 0,0:09:15.37,0:09:16.33,Main-207+,,0,0,0,,Ehi!
Dialogue: 0,0:09:16.33,0:09:17.29,Main-207+,,0,0,0,,Guardate là!
Dialogue: 0,0:09:17.29,0:09:18.91,Main-207+,,0,0,0,,Sono loro!
Dialogue: 0,0:09:34.18,0:09:37.22,Main-207+,,0,0,0,,Incredibile! Evviva!
Dialogue: 0,0:09:38.39,0:09:40.31,Main-207+,,0,0,0,,Ora che sono sul grande ponte, sono al sicuro.{cps}
Dialogue: 0,0:09:40.31,0:09:42.77,Main-207+,,0,0,0,,L'onda non dovrebbe riuscire a raggiungerli.
Dialogue: 0,0:09:42.77,0:09:44.36,Main-207+,,0,0,0,,Siete straordinari!
Dialogue: 0,0:09:44.36,0:09:45.82,Main-207+,,0,0,0,,Ben fatto!
Dialogue: 0,0:10:03.58,0:10:05.04,Main-207+,,0,0,0,,È arrivata fino a là!
Dialogue: 0,0:10:05.04,0:10:06.75,Main-207+,,0,0,0,,E i Cappello di Paglia?!
Dialogue: 0,0:10:06.75,0:10:08.63,Main-207+,,0,0,0,,Sono stati inghiottiti dall'Aqua Laguna?!
Dialogue: 0,0:10:14.80,0:10:16.35,Main-207+,,0,0,0,,No, guardate!
Dialogue: 0,0:10:20.14,0:10:21.68,Main-207+,,0,0,0,,Signor Paulie!
Dialogue: 0,0:10:28.27,0:10:29.32,Main-207+,,0,0,0,,Maledizione!
Dialogue: 0,0:10:50.25,0:10:51.84,Main-207+,,0,0,0,,Non ancora! Correte!
Dialogue: 0,0:10:51.84,0:10:54.05,Main-207+,,0,0,0,,Correte fino all'isola dei cantieri!
Dialogue: 0,0:10:56.09,0:10:57.60,Main-207+,,0,0,0,,Veloci!
Dialogue: 0,0:10:57.60,0:10:59.39,Main-207+,,0,0,0,,Il grande ponte crollerà!
Dialogue: 0,0:11:30.88,0:11:32.76,Main-207+,,0,0,0,,Che razza di onda...
Dialogue: 0,0:11:33.67,0:11:37.01,Main-207+,,0,0,0,,Non posso crederci... \NMa siamo nell'isola dei cantieri!{della serie, non può credere che l'acqua sia arrivata fin lì}
Dialogue: 0,0:11:37.51,0:11:39.60,Main-207+,,0,0,0,,Anche stare qui sembra pericoloso...
Dialogue: 0,0:11:39.93,0:11:42.47,Main-207+,,0,0,0,,Guardate! La marea si sta ritirando di nuovo!
Dialogue: 0,0:11:43.10,0:11:45.98,Main-207+,,0,0,0,,È ovvio! Continuerà così.
Dialogue: 0,0:11:45.98,0:11:48.35,Main-207+,,0,0,0,,Una seconda... e poi una terza onda!
Dialogue: 0,0:11:48.35,0:11:50.31,Main-207+,,0,0,0,,Proprio come questa...!
Dialogue: 0,0:11:50.31,0:11:53.23,Main-207+,,0,0,0,,Dovremmo evacuare anche noi più in alto!
Dialogue: 0,0:12:00.45,0:12:02.91,Main-207+,,0,0,0,,Siete proprio degli incoscienti...
Dialogue: 0,0:12:02.91,0:12:06.25,Main-207+,,0,0,0,,Grazie... \NCi hai proprio salvati, tizio delle corde.
Dialogue: 0,0:12:06.75,0:12:08.08,Main-207+,,0,0,0,,Che spavento...
Dialogue: 0,0:12:08.08,0:12:09.67,Main-207+,,0,0,0,,{\i1}Quella{\i0} sarebbe l'Aqua Laguna?
Dialogue: 0,0:12:10.04,0:12:11.92,Main-207+,,0,0,0,,Sto ancora tremando...
Dialogue: 0,0:12:13.42,0:12:18.13,Main-207+,,0,0,0,,Se ogni anno fosse così enorme, \Nquest'isola sarebbe scomparsa da tempo.
Dialogue: 0,0:12:18.51,0:12:20.14,Main-207+,,0,0,0,,Quest'anno è diverso.
Dialogue: 0,0:12:20.14,0:12:22.89,Main-207+,,0,0,0,,Siete proprio dei pazzi, eh?{molto circa}
Dialogue: 0,0:12:22.89,0:12:25.31,Main-207+,,0,0,0,,Vi siete salvati per un pelo.
Dialogue: 0,0:12:26.23,0:12:27.94,Main-207+,,0,0,0,,Oh, è la vecchia mostro!
Dialogue: 0,0:12:27.94,0:12:29.81,Main-207+,,0,0,0,,Quindi eri su quest'isola?!
Dialogue: 0,0:12:29.81,0:12:31.19,Main-207+,,0,0,0,,Mi pare ovvio!
Dialogue: 0,0:12:31.19,0:12:35.61,Main-207+,,0,0,0,,Se fossi là in mezzo al mare, \Navrei finito con il morire annegata!
Dialogue: 0,0:12:36.94,0:12:38.61,Main-207+,,0,0,0,,Fratellone pirata!
Dialogue: 0,0:12:38.61,0:12:41.45,Main-207+,,0,0,0,,Sei stato fantastico! Con quel boom!
Dialogue: 0,0:12:42.95,0:12:43.95,Main-207+,,0,0,0,,Beh, sì!
Dialogue: 0,0:12:46.66,0:12:48.33,Main-207+,,0,0,0,,Ma vuoi farmi morire soffocato?!
Dialogue: 0,0:12:49.54,0:12:53.84,Main-207+,,0,0,0,,'Sto bastardo! \NÈ svenuto restando aggrappato a me!
Dialogue: 0,0:12:55.55,0:12:56.34,Main-207+,,0,0,0,,Eh?
Dialogue: 0,0:12:56.34,0:12:59.93,Main-207+,,0,0,0,,Ah, giusto, Zoro! Come mai sei stato \Ntravolto dall'onda anche tu?
Dialogue: 0,0:12:59.93,0:13:01.39,Main-207+,,0,0,0,,Eri nella città di sotto?
Dialogue: 0,0:13:01.39,0:13:04.14,Main-207+,,0,0,0,,Eh? N-No, ecco...
Dialogue: 0,0:13:04.14,0:13:05.89,Main-207+,,0,0,0,,Era conficcato in un camino!
Dialogue: 0,0:13:09.77,0:13:12.35,Main-207+,,0,0,0,,"Conficcato in un camino"?
Dialogue: 0,0:13:14.40,0:13:16.40,Main-207+,,0,0,0,,Sei proprio uno scemo, Zoro~!
Dialogue: 0,0:13:16.40,0:13:18.65,Main-207+,,0,0,0,,Ma come si fa a finire così...!
Dialogue: 0,0:13:18.65,0:13:21.16,Main-207+,,0,0,0,,Ma ti pare il caso di ridere?!
Dialogue: 0,0:13:21.16,0:13:22.61,Main-207+,,0,0,0,,Siete entrambi degli scemi!
Dialogue: 0,0:13:23.53,0:13:25.37,Main-207+,,0,0,0,,Allora, dobbiamo riunirci a Sanji...
Dialogue: 0,0:13:25.37,0:13:26.24,Main-207+,,0,0,0,,Ma dov'è Sanji?
Dialogue: 0,0:13:28.16,0:13:29.33,Main-207+,,0,0,0,,Giusto...
Dialogue: 0,0:13:29.33,0:13:32.29,Main-207+,,0,0,0,,Ci sono un sacco di cose che devo dirti. \NAscolta anche tu, Zoro.
Dialogue: 0,0:13:40.01,0:13:42.59,Main-207+,,0,0,0,,È giunta la migliore occasione in assoluto!
Dialogue: 0,0:13:43.59,0:13:46.35,Main-207+,,0,0,0,,Cinque viceammiragli del QG della Marina...
Dialogue: 0,0:13:46.35,0:13:50.89,Main-207+,,0,0,0,,e dieci navi da guerra per \Nla chiamata d'emergenza, il Buster Call.{ew}
Dialogue: 0,0:13:50.89,0:13:57.65,Main-207+,,0,0,0,,Quell'Aokiji ha concesso il diritto \Ndi attivarlo a noi del CP9.
Dialogue: 0,0:13:58.98,0:14:01.95,Main-207+,,0,0,0,,Non lo pensi anche tu, Funkfreed?{fate come vi pare per il nome, non ha translitterazioni ufficili}
Dialogue: 0,0:14:04.53,0:14:07.70,Main-207+,,0,0,0,,La donna che il Governo Mondiale \Nha inseguito per vent'anni...
Dialogue: 0,0:14:07.70,0:14:12.75,Main-207+,,0,0,0,,Nico Robin è caduta così \Nfacilmente nelle nostre mani.{lui dice sempre CP9 comunque}
Dialogue: 0,0:14:12.75,0:14:16.38,Main-207+,,0,0,0,,E, allo stesso tempo, anche \Nl'apprendista di Tom che ha i progetti di Pluton,
Dialogue: 0,0:14:16.38,0:14:19.42,Main-207+,,0,0,0,,l'odioso Cutty Flam, è in trasferimento.{ew}
Dialogue: 0,0:14:20.01,0:14:26.39,Main-207+,,0,0,0,,Gli unici due che, in questo vasto mondo, \Nsono in grado di riportare in vita l'antica arma...
Dialogue: 0,0:14:26.80,0:14:31.52,Main-207+,,0,0,0,,sono sul treno marino e proprio ora \Nsi stanno dirigendo verso di me.
Dialogue: 0,0:14:32.35,0:14:36.56,Main-207+,,0,0,0,,Un potere militare in grado di distruggere \Nil mondo... sta venendo da me.
Dialogue: 0,0:14:45.28,0:14:47.70,Main-207+,,0,0,0,,Non c'è niente a cui pensare!{perché "non c'è nulla su cui riflettere" mi sembra troppo elevato per luffy}
Dialogue: 0,0:14:48.41,0:14:50.41,Main-207+,,0,0,0,,Prendiamo subito una nave e inseguiamoli!{cps}
Dialogue: 0,0:14:51.50,0:14:53.33,Main-207+,,0,0,0,,Non c'è altra scelta.
Dialogue: 0,0:14:59.42,0:15:01.88,Main-207+,,0,0,0,,Ehi! Tizio delle corde!
Dialogue: 0,0:15:02.46,0:15:03.67,Main-207+,,0,0,0,,Dacci una nave!
Dialogue: 0,0:15:03.67,0:15:07.39,Main-207+,,0,0,0,,Anzi, piuttosto di una nave... \NNon partono altri treni marini?{altrimenti la risposta di Paulie ha poco senso}
Dialogue: 0,0:15:07.76,0:15:12.02,Main-207+,,0,0,0,,C'è solo un unico treno marino \Nin questo mondo, il Puffing Tom.
Dialogue: 0,0:15:12.02,0:15:14.94,Main-207+,,0,0,0,,Quella è una miracolosa nave \Ncompletata solo grazie
Dialogue: 0,0:15:14.94,0:15:18.65,Main-207+,,0,0,0,,{\q2}al miglior team di carpentieri che sia mai esistito.{in jp sono al contrario}
Dialogue: 0,0:15:20.44,0:15:22.32,Main-207+,,0,0,0,,Allora prestaci una nave!
Dialogue: 0,0:15:22.32,0:15:24.82,Main-207+,,0,0,0,,La più forte e veloce di questa città!
Dialogue: 0,0:15:24.82,0:15:27.07,Main-207+,,0,0,0,,Fatela finita!
Dialogue: 0,0:15:27.82,0:15:31.12,Main-207+,,0,0,0,,Proprio ora... cosa avete visto in mare?!
Dialogue: 0,0:15:31.12,0:15:34.41,Main-207+,,0,0,0,,Per poco non siete stati \Ntrascinati via dalle onde!
Dialogue: 0,0:15:34.41,0:15:37.88,Main-207+,,0,0,0,,Infatti! Non potete partire per mare adesso!
Dialogue: 0,0:15:37.88,0:15:38.75,Main-207+,,0,0,0,,Ma siete scemi?!
Dialogue: 0,0:15:38.75,0:15:43.42,Main-207+,,0,0,0,,Nessuna nave ha mai attraversato con \Nsuccesso l'Aqua Laguna annuale.{nel senso, quella normale che c'è ogni anno}
Dialogue: 0,0:15:43.42,0:15:45.63,Main-207+,,0,0,0,,Avete visto la distruzione dei sobborghi, no?
Dialogue: 0,0:15:46.05,0:15:49.34,Main-207+,,0,0,0,,La città che non aveva mai ceduto \Nall'Aqua Laguna prima d'ora...
Dialogue: 0,0:15:49.89,0:15:51.51,Main-207+,,0,0,0,,Che fine misera...
Dialogue: 0,0:15:52.14,0:15:55.77,Main-207+,,0,0,0,,Per di più, quest'anno è su un altro livello.
Dialogue: 0,0:15:55.77,0:15:59.94,Main-207+,,0,0,0,,Se vi dessi una nave ora, \Nanche se fosse il miglior galeone...
Dialogue: 0,0:15:59.94,0:16:02.48,Main-207+,,0,0,0,,verrebbe ridotto in mille pezzi \Ncon un solo colpo, no?
Dialogue: 0,0:16:03.07,0:16:06.65,Main-207+,,0,0,0,,Sapendo che andreste a morire, \Nnon posso permettermi di darvi una nave.
Dialogue: 0,0:16:07.24,0:16:08.66,Main-207+,,0,0,0,,Aspettate fino a mattina.
Dialogue: 0,0:16:10.24,0:16:12.49,Main-207+,,0,0,0,,Quando la tempesta sarà passata, \Nvi presterò una nave.{cps}
Dialogue: 0,0:16:13.20,0:16:16.12,Main-207+,,0,0,0,,Ehi! \NAndate anche voi al centro di evacuazione!
Dialogue: 0,0:16:16.12,0:16:18.00,Main-207+,,0,0,0,,Abbiamo terminato la ricerca.
Dialogue: 0,0:16:18.58,0:16:19.67,Main-207+,,0,0,0,,Se...
Dialogue: 0,0:16:21.42,0:16:26.47,Main-207+,,0,0,0,,Se aspettassimo fino a mattina, \Nil nostro desiderio si avvererebbe?
Dialogue: 0,0:16:28.97,0:16:32.05,Main-207+,,0,0,0,,Conosco Enies Lobby.
Dialogue: 0,0:16:32.55,0:16:35.56,Main-207+,,0,0,0,,Dopo aver sentito che è un'isola \Ndel governo, me ne sono ricordata.
Dialogue: 0,0:16:35.56,0:16:36.56,Main-207+,,0,0,0,,Laggiù...
Dialogue: 0,0:16:36.89,0:16:40.06,Main-207+,,0,0,0,,Laggiù... non ci sono forse \Nle "Porte della Giustizia"?{ho visto che viene chiamato "cancello". non è sbagliato, ma visually sono porte, no? e "mon" può essere cancello, porte, portone, ingresso. also, userò "G" per glossario, quindi qui è G - Luoghi -angy}
Dialogue: 0,0:16:41.15,0:16:42.81,Main-207+,,0,0,0,,Cosa sarebbero?
Dialogue: 0,0:16:43.15,0:16:47.15,Main-207+,,0,0,0,,Sull'isola giudiziaria di proprietà \Ndel governo, Enies Lobby...
Dialogue: 0,0:16:47.74,0:16:50.16,Main-207+,,0,0,0,,c'è un tribunale di facciata.{nel senso che è così solo di nome}
Dialogue: 0,0:16:50.78,0:16:55.04,Main-207+,,0,0,0,,Essere trasportati ad Enies Lobby è \Nconsiderata una prova di colpevolezza
Dialogue: 0,0:16:55.04,0:16:59.41,Main-207+,,0,0,0,,{\q2}e i prigionieri attraversano quel tribunale deserto
Dialogue: 0,0:16:59.41,0:17:03.50,Main-207+,,0,0,0,,{\q2}fino a trovarsi davanti a delle enormi e fredde porte.
Dialogue: 0,0:17:05.88,0:17:08.92,Main-207+,,0,0,0,,Quelle porte sono dette "Porte della Giustizia".{eh, usa termini diversi per "porta"}
Dialogue: 0,0:17:09.47,0:17:11.39,Main-207+,,0,0,0,,Se una persona colpevole le attraversa,
Dialogue: 0,0:17:11.39,0:17:15.39,Main-207+,,0,0,0,,non vedrà mai più la luce del sole. \NSono le porte della disperazione.{ha più senso in due frasi anche se è una frase sola in jp}
Dialogue: 0,0:17:16.01,0:17:20.35,Main-207+,,0,0,0,,Questo perché... al di là di quelle porte, \Nvi è un ponte e il mare oltre ad esso
Dialogue: 0,0:17:20.35,0:17:22.81,Main-207+,,0,0,0,,porta solamente a due posti.
Dialogue: 0,0:17:24.19,0:17:28.86,Main-207+,,0,0,0,,Uno... è l'apice della forza militare globale,
Dialogue: 0,0:17:28.86,0:17:30.11,Main-207+,,0,0,0,,il QG della Marina.
Dialogue: 0,0:17:31.57,0:17:35.16,Main-207+,,0,0,0,,E l'altro... è pieno di sale di tortura e patiboli,
Dialogue: 0,0:17:35.16,0:17:39.37,Main-207+,,0,0,0,,{\q2}è il luogo in cui vengono rinchiusi i più pericolosi \Nprigionieri che hanno seminato il caos nel mondo,{ew}
Dialogue: 0,0:17:39.37,0:17:42.79,Main-207+,,0,0,0,,è la grande prigione sottomarina, Impel Down.{G - Luoghi}
Dialogue: 0,0:17:43.83,0:17:45.29,Main-207+,,0,0,0,,In pratica...
Dialogue: 0,0:17:45.29,0:17:49.42,Main-207+,,0,0,0,,Enies Lobby non concede \Nalcuna pietà ai criminali
Dialogue: 0,0:17:49.42,0:17:52.93,Main-207+,,0,0,0,,ed è semplicemente un organo \Ngiudiziario per spedirli laggiù!
Dialogue: 0,0:17:52.93,0:17:54.34,Main-207+,,0,0,0,,Non è forse così?!
Dialogue: 0,0:17:55.64,0:17:57.76,Main-207+,,0,0,0,,Per una ricercata come Robin
Dialogue: 0,0:17:57.76,0:18:00.48,Main-207+,,0,0,0,,sarà l'inferno ovunque verrà portata dopo.
Dialogue: 0,0:18:00.85,0:18:05.36,Main-207+,,0,0,0,,{\q2}Anche finché siamo qui a parlare, Robin si sta \Navvicinando sempre di più alle Porte della Giustizia.{cps e modificato per mettere qualcosa che almeno si dica in italiano... "finché siamo qui a parlare" sarebbe tipo "finché siamo qui a far questo"}
Dialogue: 0,0:18:05.73,0:18:08.32,Main-207+,,0,0,0,,Non possiamo certo aspettare fino a mattina!
Dialogue: 0,0:18:11.19,0:18:14.16,Main-207+,,0,0,0,,Dato che ne sai così tanto, ti dirò una cosa.
Dialogue: 0,0:18:14.91,0:18:18.29,Main-207+,,0,0,0,,{\q2}Anche se il mare fosse calmo e vi dessi una nave,
Dialogue: 0,0:18:18.74,0:18:21.16,Main-207+,,0,0,0,,non è un luogo in cui dovreste andare.
Dialogue: 0,0:18:21.16,0:18:25.08,Main-207+,,0,0,0,,Non dimenticate che siete pirati anche voi.
Dialogue: 0,0:18:25.58,0:18:30.71,Main-207+,,0,0,0,,{\q2}Proprio come hai detto, Enies Lobby è \Nl'ingresso che porta al centro del Governo Mondiale.
Dialogue: 0,0:18:30.71,0:18:34.01,Main-207+,,0,0,0,,Naturalmente è predisposta \Ncon un'adeguata difesa bellica.{ew}
Dialogue: 0,0:18:34.59,0:18:40.18,Main-207+,,0,0,0,,{\q2}È impensabile che dei pirati possano andare a riprendersi\N un compagno che è stato trasportato laggiù.{con pirati non intende i cappello di paglia, ma in generale}
Dialogue: 0,0:18:40.18,0:18:42.52,Main-207+,,0,0,0,,Questo perché è ovvio come andrebbe a finire.
Dialogue: 0,0:18:43.06,0:18:48.48,Main-207+,,0,0,0,,Avete forse intenzione di sfidare \Nil centro del Governo Mondiale?!{ew}
Dialogue: 0,0:18:51.90,0:18:54.78,Main-207+,,0,0,0,,I-Infatti! Lasciate perdere!
Dialogue: 0,0:18:54.78,0:18:56.95,Main-207+,,0,0,0,,Con l'Aqua Laguna, non possiamo \Ndarvi una nave fino a mattina!{cps}
Dialogue: 0,0:18:56.95,0:18:58.91,Main-207+,,0,0,0,,Inseguendola, finirete per farvi uccidere!
Dialogue: 0,0:18:58.91,0:19:01.95,Main-207+,,0,0,0,,Ci sono zero possibilità che sopravviviate!
Dialogue: 0,0:19:01.95,0:19:02.87,Main-207+,,0,0,0,,Luffy...
Dialogue: 0,0:19:04.83,0:19:06.38,Main-207+,,0,0,0,,Allora, la nave...
Dialogue: 0,0:19:06.38,0:19:08.17,Main-207+,,0,0,0,,la ruberemo!
Dialogue: 0,0:19:09.59,0:19:12.30,Main-207+,,0,0,0,,Noi andremo per mare adesso!
Dialogue: 0,0:19:16.09,0:19:17.89,Main-207+,,0,0,0,,Una compagna ci aspetta!
Dialogue: 0,0:19:17.89,0:19:21.14,Main-207+,,0,0,0,,Non mettetevi in mezzo!{non intralciateci}
Dialogue: 0,0:19:24.69,0:19:27.52,Main-207+,,0,0,0,,A-Anche le onde si sono arrabbiate!
Dialogue: 0,0:19:30.65,0:19:32.40,Main-207+,,0,0,0,,– Cos–?!\N– Vuole forse combattere, quel bastardo?
Dialogue: 0,0:19:32.40,0:19:33.86,Main-207+,,0,0,0,,Ah, che spavento!
Dialogue: 0,0:19:35.36,0:19:38.20,Main-207+,,0,0,0,,D'accordo! Sarò il tuo avversario!
Dialogue: 0,0:19:45.50,0:19:47.87,Main-207+,,0,0,0,,Aspettate, voialtri!
Dialogue: 0,0:19:50.63,0:19:51.92,Main-207+,,0,0,0,,Signora Kokoro!
Dialogue: 0,0:19:51.92,0:19:54.72,Main-207+,,0,0,0,,Siete voi nel torno, Cappello di Paglia.{è in voi si, non sono matta}
Dialogue: 0,0:19:55.80,0:19:58.47,Main-207+,,0,0,0,,Paulie ha ragione, stupidi idioti.
Dialogue: 0,0:19:58.47,0:20:00.89,Main-207+,,0,0,0,,'Sta zitta! Vecchia, tu non–
Dialogue: 0,0:20:00.89,0:20:03.60,Main-207+,,0,0,0,,Non c'entro, giusto?
Dialogue: 0,0:20:03.60,0:20:05.10,Main-207+,,0,0,0,,Beh, ascoltami.
Dialogue: 0,0:20:05.10,0:20:08.40,Main-207+,,0,0,0,,Che cavolo... Pare proprio che vogliate \Nmorire se vi lasciassimo fare.
Dialogue: 0,0:20:08.77,0:20:10.02,Main-207+,,0,0,0,,Sentite bene.
Dialogue: 0,0:20:10.02,0:20:14.78,Main-207+,,0,0,0,,Se ci fosse una nave in grado \Ndi superare quell'Aqua Laguna,
Dialogue: 0,0:20:14.78,0:20:18.45,Main-207+,,0,0,0,,sarebbe solo il treno marino \Ncostruito da quell'uomo leggendario.
Dialogue: 0,0:20:18.78,0:20:21.66,Main-207+,,0,0,0,,Però quello non è qui adesso, quindi...
Dialogue: 0,0:20:21.66,0:20:23.74,Main-207+,,0,0,0,,stiamo cercando di andarci con una nave!
Dialogue: 0,0:20:25.75,0:20:28.50,Main-207+,,0,0,0,,Se siete pronti a morire...
Dialogue: 0,0:20:29.00,0:20:30.13,Main-207+,,0,0,0,,seguitemi.
Dialogue: 0,0:20:30.50,0:20:32.09,Main-207+,,0,0,0,,Ve lo darò...
Dialogue: 0,0:20:32.09,0:20:33.92,Main-207+,,0,0,0,,un treno marino!
Dialogue: 0,0:20:59.61,0:21:01.57,Main-207+,,0,0,0,,Brutti idioti! Che state facendo?!
Dialogue: 0,0:21:01.57,0:21:04.45,Main-207+,,0,0,0,,{\q2}Qui tutti tranne i criminali indossano l'uniforme!
Dialogue: 0,0:21:09.50,0:21:11.08,Main-207+,,0,0,0,,A-Alla carica!
Dialogue: 0,0:21:11.50,0:21:14.04,Main-207+,,0,0,0,,Sapevo sarebbe finita così...{è l'idea, per matchare anche l'espressione}
Dialogue: 0,0:21:24.22,0:21:27.22,Main-207+,,0,0,0,,Pensavo sarebbe stato un buon piano...
Dialogue: 0,0:21:27.22,0:21:29.31,Main-207+,,0,0,0,,l'operazione "fregatene e tira dritto".{circa}
Dialogue: 0,0:21:32.44,0:21:34.40,Main-207+,,0,0,0,,Eh?! S-Sanji?!
Dialogue: 0,0:21:34.40,0:21:35.61,Main-207+,,0,0,0,,– Fermo dove sei!\N– Fermo dove sei!
Dialogue: 0,0:21:39.49,0:21:41.53,Main-207+,,0,0,0,,– Non ti lasceremo andare oltre!\N– Non ti lasceremo andare oltre!
Dialogue: 0,0:21:42.45,0:21:43.87,Main-207+,,0,0,0,,Gemelli?{parla quello che ne ha 3 comunque -.-}
Dialogue: 0,0:21:50.21,0:21:51.67,Main-207+,,0,0,0,,{\fad(150,150)}Collier...
Dialogue: 0,0:21:53.63,0:21:55.34,Main-207+,,0,0,0,,{\fad(150,150)}Frit!
Dialogue: 0,0:22:02.93,0:22:06.85,Main-207+,,0,0,0,,S-Sanji! Perché sei sul treno marino?!
Dialogue: 0,0:22:07.39,0:22:09.60,Main-207+,,0,0,0,,È quello che vorrei chiederti io.
Dialogue: 0,0:22:15.86,0:22:17.27,Main-207+,,0,0,0,,Tu... mnh...
Dialogue: 0,0:22:17.27,0:22:19.61,Main-207+,,0,0,0,,Tu di cui non conosco il nome.
Dialogue: 0,0:22:19.61,0:22:22.57,Main-207+,,0,0,0,,Ma che farsa, maledetto...
Comment: 0,0:22:24.74,0:22:26.07,Main-207+,,0,0,0,,Ooh!{la coerenza degli inglesi sul lasciare o meno ste cose -.-}
Dialogue: 0,0:22:25.95,0:22:28.20,Main-207+,,0,0,0,,Ma quindi c'erano dei lumacofoni!
Dialogue: 0,0:22:28.20,0:22:29.83,Main-207+,,0,0,0,,Ah, che fortuna!
Dialogue: 0,0:22:29.83,0:22:32.16,Main-207+,,0,0,0,,Ma come? Qui ce ne sono un sacco!
Dialogue: 0,0:22:32.16,0:22:33.96,Main-207+,,0,0,0,,Forse fa anche da sala comunicazioni?
Dialogue: 0,0:22:35.21,0:22:40.42,Main-207+,,0,0,0,,{\q2}Quei funzionari del vagone di prima avevano con sé\N cose inutili come maschere e costumi...
Dialogue: 0,0:22:40.88,0:22:43.59,Main-207+,,0,0,0,,Con questi posso finalmente \Ncontattare la cara Nami!
Dialogue: 0,0:22:43.59,0:22:47.10,Main-207+,,0,0,0,,Quindi voi... siete compagni pirati?
Dialogue: 0,0:22:47.10,0:22:48.56,Main-207+,,0,0,0,,– Ex!\N– Ex!
Dialogue: 0,0:22:48.56,0:22:50.06,Main-207+,,0,0,0,,E tu chi saresti?!
Dialogue: 0,0:22:50.06,0:22:55.44,Main-207+,,0,0,0,,Sono il volto nascosto di Water Seven, \Nil demolitore Franky.
Dialogue: 0,0:22:56.98,0:22:59.98,Main-207+,,0,0,0,,{\i1}Tu{\i0} sei Franky?! Bastardo di merda!
Dialogue: 0,0:22:59.98,0:23:02.94,Main-207+,,0,0,0,,Come hai osato ridurre in quello \Nstato il nostro naso lungo?!
Dialogue: 0,0:23:02.94,0:23:05.57,Main-207+,,0,0,0,,In quante fette vuoi che ti sfiletti, eh?!
Dialogue: 0,0:23:05.57,0:23:07.20,Main-207+,,0,0,0,,Ah, no, no, no...
Dialogue: 0,0:23:07.20,0:23:10.58,Main-207+,,0,0,0,,Ah– S-S-Sanji, aspetta! \NSono successe un sacco di cose da allora!
Dialogue: 0,0:23:10.58,0:23:13.75,Main-207+,,0,0,0,,Bastardo! Te ne pentirai quando \Nqueste corte verranno slegate!{circa}
Dialogue: 0,0:23:13.75,0:23:16.00,Main-207+,,0,0,0,,Ancora a dire queste cose...
Dialogue: 0,0:23:16.50,0:23:20.46,Main-207+,,0,0,0,,Ah! Questo qui ha aiutato la Merry una volta!
Dialogue: 0,0:23:21.71,0:23:23.21,Main-207+,,0,0,0,,Giusto...
Dialogue: 0,0:23:24.09,0:23:26.38,Main-207+,,0,0,0,,La Merry...
Dialogue: 0,0:23:27.76,0:23:31.39,Main-207+,,0,0,0,,Ehi, ehi! Aspetta! \NTi pare il momento di deprimerti?!
Dialogue: 0,0:23:31.39,0:23:35.60,Main-207+,,0,0,0,,In ogni caso, fratello! Ti prego, slega le corde!
Dialogue: 0,0:23:35.60,0:23:39.40,Main-207+,,0,0,0,,Ma chi ti slegherebbe mai?! \NRimani così per sempre, polpo!
Dialogue: 0,0:23:39.40,0:23:43.49,Main-207+,,0,0,0,,Bastardo! Guarda quante arie ti dai \Nsolo perché sono stato gentile!{non so, non capisco...}
Dialogue: 0,0:23:43.49,0:23:46.11,Main-207+,,0,0,0,,Fatela finita, voi due maledetti!
Dialogue: 0,0:23:46.11,0:23:49.95,Main-207+,,0,0,0,,Se perdiamo tempo, ci beccheranno, no?!
Dialogue: 0,0:23:49.95,0:23:51.45,Main-207+,,0,0,0,,Ma 'sta zitto tu!
Dialogue: 0,0:23:51.45,0:23:52.58,Main-207+,,0,0,0,,Cosa?!
Dialogue: 0,0:23:52.58,0:23:54.08,Main-207+,,0,0,0,,State zitti entrambi, brutti–!
Dialogue: 0,0:23:54.08,0:23:55.91,Main-207+,,0,0,0,,Dai, slega queste corde in fretta!
Dialogue: 0,0:24:01.80,0:24:03.00,Main-207+,,0,0,0,,Capitano T Bone?
Dialogue: 0,0:24:08.43,0:24:11.64,Main-207+,,0,0,0,,{\q2}Questo magazzino è abbandonato da oltre otto anni.
Dialogue: 0,0:24:12.22,0:24:16.23,Main-207+,,0,0,0,,{\an8}E il treno marino non è più stato\N toccato da oltre dodici anni.
Dialogue: 0,0:24:16.23,0:24:17.48,Main-207+,,0,0,0,,Andiamo, Chopper!
Dialogue: 0,0:24:17.48,0:24:18.56,Main-207+,,0,0,0,,Sì!
Dialogue: 0,0:24:18.56,0:24:20.69,Main-207+,,0,0,0,,Potrebbe non muoversi più.
Dialogue: 0,0:24:21.82,0:24:23.73,Main-207+,,0,0,0,,Ehi! Quello sarebbe un problema!
Dialogue: 0,0:24:27.99,0:24:30.37,Main-207+,,0,0,0,,Ehi, dai, aspettate.
Dialogue: 0,0:24:30.37,0:24:35.08,Main-207+,,0,0,0,,Anche andando così di fretta, \Nsenza le chiavi non potete passare.
Dialogue: 0,0:24:36.25,0:24:38.67,Main-207+,,0,0,0,,Ma come? È aperto?
Dialogue: 0,0:24:43.92,0:24:45.17,Main-207+,,0,0,0,,Eccolo!
Dialogue: 0,0:24:45.80,0:24:48.17,Main-207+,,0,0,0,,Che figo~!
Dialogue: 0,0:24:48.17,0:24:50.51,Main-207+,,0,0,0,,Fantastico!
Dialogue: 0,0:24:51.64,0:24:55.60,Main-207+,,0,0,0,,Lasciate che ve lo dica, non è normale.
Dialogue: 0,0:24:55.60,0:24:58.31,Main-207+,,0,0,0,,Il suo nome è Rocketman.
Dialogue: 0,0:24:58.31,0:25:01.81,Main-207+,,0,0,0,,È un aggeggio su cui \Nnon dovrebbero salire passeggeri.
Dialogue: 0,0:25:01.81,0:25:03.19,Main-207+,,0,0,0,,Rocketman!
Dialogue: 0,0:25:03.19,0:25:04.77,Main-207+,,0,0,0,,Sembra veloce!
Dialogue: 0,0:25:04.77,0:25:06.11,Main-207+,,0,0,0,,Che figo!
Dialogue: 0,0:25:06.78,0:25:09.15,Main-207+,,0,0,0,,Ma cos'è quel viso?
Dialogue: 0,0:25:09.15,0:25:12.37,Main-207+,,0,0,0,,{\q2}La testa di squalo è stata aggiunta come tocco di stile!{potrebbe anche voler dire "per scherzo"}
Comment: 0,0:25:13.24,0:25:13.91,Main-207+,,0,0,0,,Eh?
Dialogue: 0,0:25:15.08,0:25:16.66,Main-207+,,0,0,0,,Il vecchio Ice!
Dialogue: 0,0:25:17.95,0:25:19.37,Main-207+,,0,0,0,,Cappello di Paglia.
Dialogue: 0,0:25:19.37,0:25:20.83,Main-207+,,0,0,0,,Sono felice tu sia sano e salvo.{non direbbe che è felice... forse "meno male che tu stia bene" è più vicino}
Dialogue: 0,0:25:21.33,0:25:23.92,Main-207+,,0,0,0,,È proprio come ha detto la ragazza pirata.
Dialogue: 0,0:25:23.92,0:25:25.46,Main-207+,,0,0,0,,Vi ha portati qui la signora Kokoro?
Dialogue: 0,0:25:25.46,0:25:28.67,Main-207+,,0,0,0,,Sei ancora vivo, eh, Iceburg?
Dialogue: 0,0:25:28.67,0:25:30.80,Main-207+,,0,0,0,,Cosa ci fai qui?
Dialogue: 0,0:25:31.22,0:25:34.89,Main-207+,,0,0,0,,Se sono qui è perché \Nho avuto il tuo stesso pensiero.
Comment: 0,0:25:34.89,0:25:35.64,Main-207+,,0,0,0,,Eh?
Dialogue: 0,0:25:36.35,0:25:38.27,Main-207+,,0,0,0,,Non posso proprio abbandonare degli idioti.
Dialogue: 0,0:25:43.69,0:25:44.52,Main-207+,,0,0,0,,Usatelo.
Dialogue: 0,0:25:45.15,0:25:46.94,Main-207+,,0,0,0,,La manutenzione è completata.
Dialogue: 0,0:25:46.94,0:25:49.94,Main-207+,,0,0,0,,Ci ho caricato sia acqua che carbone. \NAl momento sta accumulando vapore.{cps}
Dialogue: 0,0:25:50.95,0:25:53.57,Main-207+,,0,0,0,,Vecchio, stavi facendo i preparativi?!
Comment: 0,0:25:53.57,0:25:54.82,Main-207+,,0,0,0,,
Dialogue: 0,0:25:55.91,0:25:58.37,Main-207+,,0,0,0,,Rallegratevi dopo esserne usciti vivi.
Dialogue: 0,0:25:58.37,0:26:03.50,Main-207+,,0,0,0,,{\q2}Dopotutto la velocità di questo Rocketman non può \Nessere contenuta per quanto si provi a regolarla.
Dialogue: 0,0:26:03.50,0:26:06.59,Main-207+,,0,0,0,,È il prototipo fallito prima del \Ncompletamento del Puffing Tom.
Dialogue: 0,0:26:07.05,0:26:09.21,Main-207+,,0,0,0,,Non posso garantire la vostra sopravvivenza.{cps}
Dialogue: 0,0:26:10.42,0:26:13.38,Main-207+,,0,0,0,,Sì! Grazie, vecchio Ice!
Dialogue: 0,0:26:15.80,0:26:17.97,Main-207+,,0,0,0,,Bene! Andiamo!
Dialogue: 0,0:26:18.52,0:26:20.06,Main-207+,,0,0,0,,Voi, salite!
Dialogue: 0,0:26:20.89,0:26:23.39,Main-207+,,0,0,0,,Vecchia! \NUna volta che arriva Nami, parti subito!
Dialogue: 0,0:26:23.39,0:26:24.90,Main-207+,,0,0,0,,Ooops!
Dialogue: 0,0:26:27.02,0:26:29.23,Main-207+,,0,0,0,,Luffy! Va tutto bene?
Dialogue: 0,0:26:29.23,0:26:32.03,Main-207+,,0,0,0,,È da prima che ti tremano le gambe!
Dialogue: 0,0:26:32.03,0:26:33.66,Main-207+,,0,0,0,,Sicuramente ha perso troppo sangue.
Dialogue: 0,0:26:34.91,0:26:39.12,Main-207+,,0,0,0,,Non riesco a tirar fuori bene la forza... \NSe ci fosse della carne...
Dialogue: 0,0:26:39.58,0:26:40.95,Main-207+,,0,0,0,,Veloci, per di qua!
Dialogue: 0,0:26:43.58,0:26:44.58,Main-207+,,0,0,0,,Aspetta!
Dialogue: 0,0:26:44.58,0:26:47.96,Main-207+,,0,0,0,,Ma non serve andare così lontano, \Nperché non mangi qui?
Dialogue: 0,0:26:47.96,0:26:50.13,Main-207+,,0,0,0,,Esatto! Stai morendo di fame, no?!
Dialogue: 0,0:26:50.13,0:26:51.76,Main-207+,,0,0,0,,Come se mangiassi così tanto!
Dialogue: 0,0:26:51.76,0:26:52.84,Main-207+,,0,0,0,,– Eh?!\N– Eh?!
Dialogue: 0,0:26:53.34,0:26:54.68,Main-207+,,0,0,0,,Scusate! Sono in ritardo!
Dialogue: 0,0:26:54.68,0:26:55.51,Main-207+,,0,0,0,,Nami.
Dialogue: 0,0:26:55.51,0:26:57.89,Main-207+,,0,0,0,,Ehi! Ma che stavi facendo?!
Dialogue: 0,0:26:57.89,0:26:59.68,Main-207+,,0,0,0,,Veloce, sali, brutta idiota!
Dialogue: 0,0:27:00.01,0:27:01.93,Main-207+,,0,0,0,,Wow, fantastico.
Dialogue: 0,0:27:01.93,0:27:03.39,Main-207+,,0,0,0,,Questo è il treno marino?
Dialogue: 0,0:27:04.52,0:27:07.31,Main-207+,,0,0,0,,Non avrei mai pensato che \Nci fosse un'altra nave qui.
Dialogue: 0,0:27:07.31,0:27:08.57,Main-207+,,0,0,0,,Che sorpresa!
Dialogue: 0,0:27:08.90,0:27:10.53,Main-207+,,0,0,0,,Ma dove sei stata, Nami?!
Dialogue: 0,0:27:10.53,0:27:12.36,Main-207+,,0,0,0,,{\i1}Chi{\i0} ha detto che non c'è tempo?!
Dialogue: 0,0:27:13.11,0:27:14.45,Main-207+,,0,0,0,,Cos'è quel bagaglio?!
Dialogue: 0,0:27:14.45,0:27:15.66,Main-207+,,0,0,0,,Carne e cose da bere.
Dialogue: 0,0:27:15.66,0:27:17.87,Main-207+,,0,0,0,,Scusami per le lamentele.
Dialogue: 0,0:27:19.16,0:27:20.91,Main-207+,,0,0,0,,Oh issa.
Dialogue: 0,0:27:20.91,0:27:26.71,Main-207+,,0,0,0,,{\q2}Se riuscissi a lanciarti dal canale al mare e riuscissi \Nad agganciarti ai binari, per il momento sarebbe fatta, ma...
Dialogue: 0,0:27:26.71,0:27:28.04,Main-207+,,0,0,0,,Va tutto bene.
Dialogue: 0,0:27:28.04,0:27:31.17,Main-207+,,0,0,0,,Nel pilotare, sono io qui la veterana.
Dialogue: 0,0:27:31.17,0:27:33.92,Main-207+,,0,0,0,,Tu rimani qui a riposarti con calma.
Dialogue: 0,0:27:34.38,0:27:35.38,Main-207+,,0,0,0,,Che vergogna.
Dialogue: 0,0:27:35.38,0:27:38.47,Main-207+,,0,0,0,,Chimney starà giocando da quella parte, quindi{sarebbe chimney e gli altri (ma gli altri è il coniglio)}
Dialogue: 0,0:27:38.47,0:27:40.18,Main-207+,,0,0,0,,la lascio nelle tue mani.
Dialogue: 0,0:27:43.10,0:27:46.48,Main-207+,,0,0,0,,Cappello di Paglia!
Dialogue: 0,0:27:48.15,0:27:49.65,Main-207+,,0,0,0,,Ma loro sono...
Dialogue: 0,0:27:50.52,0:27:52.03,Main-207+,,0,0,0,,La Famiglia Franky!
Dialogue: 0,0:27:55.95,0:27:57.70,Main-207+,,0,0,0,,Ma perché proprio adesso?!{"in un momento così occupato" sarebbe lett}
Dialogue: 0,0:27:58.78,0:28:00.03,Main-207+,,0,0,0,,Vi prego!
Dialogue: 0,0:28:00.03,0:28:02.58,Main-207+,,0,0,0,,Portateci con voi!
Dialogue: 0,0:28:02.58,0:28:07.00,Main-207+,,0,0,0,,Abbiamo sentito dai tizi della Galley-La \Nche state andando ad Enies Lobby!
Dialogue: 0,0:28:07.83,0:28:11.09,Main-207+,,0,0,0,,{\q2}Il fratello Franky è stato portato via dal governo
Dialogue: 0,0:28:11.09,0:28:12.38,Main-207+,,0,0,0,,e vorremmo seguirlo, ma...
Dialogue: 0,0:28:13.17,0:28:16.38,Main-207+,,0,0,0,,{\q2}noi da soli non possiamo superare l'Aqua Laguna!
Dialogue: 0,0:28:16.38,0:28:18.97,Main-207+,,0,0,0,,L'avversario è il Governo Mondiale.
Dialogue: 0,0:28:19.34,0:28:21.51,Main-207+,,0,0,0,,Come se ci importasse!
Dialogue: 0,0:28:21.51,0:28:23.35,Main-207+,,0,0,0,,Ci riprenderemo il fratello!
Dialogue: 0,0:28:23.35,0:28:27.06,Main-207+,,0,0,0,,Non esiteremmo a dare la \Nnostra vita per il fratello!
Dialogue: 0,0:28:27.06,0:28:28.44,Main-207+,,0,0,0,,Vi preghiamo!
Dialogue: 0,0:28:28.44,0:28:30.52,Main-207+,,0,0,0,,Aiutateci!
Dialogue: 0,0:28:30.52,0:28:32.40,Main-207+,,0,0,0,,Cappello di Paglia!
Dialogue: 0,0:28:32.94,0:28:35.86,Main-207+,,0,0,0,,Vi prego! Il fratello è il più importante per noi!{un po' adattata}
Dialogue: 0,0:28:36.24,0:28:38.11,Main-207+,,0,0,0,,Non scherziamo.
Dialogue: 0,0:28:38.11,0:28:41.45,Main-207+,,0,0,0,,Ma vi rendete almeno conto \Ndi cosa avete fatto finora?!
Dialogue: 0,0:28:47.83,0:28:49.46,Main-207+,,0,0,0,,Lo sappiamo!
Dialogue: 0,0:28:50.83,0:28:53.09,Main-207+,,0,0,0,,Nonostante sia umiliante, vi supplichiamo.{non sapevo come altro metterla questa}
Dialogue: 0,0:28:54.00,0:28:56.76,Main-207+,,0,0,0,,Vogliamo salvare il fratello!
Dialogue: 0,0:29:11.02,0:29:11.98,Main-207+,,0,0,0,,Salite.
Dialogue: 0,0:29:12.44,0:29:13.44,Main-207+,,0,0,0,,Veloci!
Dialogue: 0,0:29:17.99,0:29:19.95,Main-207+,,0,0,0,,Cappello di Paglia...
Dialogue: 0,0:29:20.49,0:29:22.37,Main-207+,,0,0,0,,Ehi, Luffy!
Dialogue: 0,0:29:23.45,0:29:24.95,Main-207+,,0,0,0,,Beh, va bene così, dai!{il dai è più per il tono}
Dialogue: 0,0:29:25.49,0:29:26.91,Main-207+,,0,0,0,,Scusate!
Dialogue: 0,0:29:27.91,0:29:30.12,Main-207+,,0,0,0,,Vi dobbiamo un favore!
Dialogue: 0,0:29:30.46,0:29:31.62,Main-207+,,0,0,0,,Fate in fretta!
Dialogue: 0,0:29:32.96,0:29:34.75,Main-207+,,0,0,0,,Però non serve sia in quel vagone!
Dialogue: 0,0:29:36.59,0:29:40.97,Main-207+,,0,0,0,,Noi vi seguiremo e ci tufferemo \Nin mare con i king bull!
Dialogue: 0,0:29:40.97,0:29:43.55,Main-207+,,0,0,0,,Ci basterà aggrapparci al retro dei vagoni!
Dialogue: 0,0:29:44.22,0:29:45.72,Main-207+,,0,0,0,,King bull?
Dialogue: 0,0:29:45.72,0:29:47.27,Main-207+,,0,0,0,,Contiamo su di voi!
Dialogue: 0,0:29:47.27,0:29:48.89,Main-207+,,0,0,0,,Allora, a più tardi!
Dialogue: 0,0:29:49.77,0:29:51.27,Main-207+,,0,0,0,,Andiamo!
Dialogue: 0,0:29:51.27,0:29:53.73,Main-207+,,0,0,0,,– Sì!\N– Sì!
Dialogue: 0,0:30:00.11,0:30:04.45,Main-207+,,0,0,0,,Evviva! Possiamo andare a salvare il fratello!
Comment: 0,0:30:04.45,0:30:06.45,Secondary-207+,,0,0,0,,{\an8}– Sì!\N– Sì!
Dialogue: 0,0:30:04.45,0:30:06.45,Main-207+,,0,0,0,,Veloci!
Dialogue: 0,0:30:14.54,0:30:15.21,Main-207+,,0,0,0,,Com'è?
Dialogue: 0,0:30:17.92,0:30:18.50,Main-207+,,0,0,0,,Bene!
Dialogue: 0,0:30:19.13,0:30:20.51,Main-207+,,0,0,0,,Allora, andiamo?
Dialogue: 0,0:30:58.17,0:31:00.88,Main-207+,,0,0,0,,Forza, pirati!
Dialogue: 0,0:31:00.88,0:31:03.38,Main-207+,,0,0,0,,Non fatevi sbalzare fuori!
Dialogue: 0,0:31:15.35,0:31:18.86,Main-207+,,0,0,0,,{\q2}Partenza da Water Seven, arrivo ad Enies Lobby.
Dialogue: 0,0:31:18.86,0:31:22.90,Main-207+,,0,0,0,,Treno marino, Rocketman!
Dialogue: 0,0:31:26.03,0:31:29.37,Main-207+,,0,0,0,,Bene! Si parte!
Dialogue: 0,0:31:32.25,0:31:33.29,Main-207+,,0,0,0,,Andiamo!
Dialogue: 0,0:31:34.12,0:31:38.38,Main-207+,,0,0,0,,A riprenderci tutto!{sarebbe rubare (per riprendere) tutto -angy}
Comment: 0,0:00:00.00,0:00:00.00,Main-207+,,0,0,0,,{=9}===============================DIALOGUE============================
