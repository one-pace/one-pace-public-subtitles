Comment: 0,0:00:00.00,0:00:00.00,Main-207+,,0,0,0,,{=8}===============================DIALOGUE============================
Dialogue: 0,0:02:07.02,0:02:09.48,Main-207+,,0,0,0,,裏町へ飛び降りた！
Dialogue: 0,0:02:13.53,0:02:15.07,Main-207+,,0,0,0,,–　待て！\N–　裏町へ行くな！
Dialogue: 0,0:02:15.07,0:02:16.74,Main-207+,,0,0,0,,追うなお前ら
Dialogue: 0,0:02:17.33,0:02:18.58,Main-207+,,0,0,0,,パウリーさん
Dialogue: 0,0:02:18.58,0:02:21.08,Main-207+,,0,0,0,,大勢行きゃあ助かるってもんじゃねえ
Dialogue: 0,0:02:21.08,0:02:22.16,Main-207+,,0,0,0,,しかし…
Dialogue: 0,0:02:22.16,0:02:24.58,Main-207+,,0,0,0,,相手は海だぞ
Dialogue: 0,0:02:24.58,0:02:26.54,Main-207+,,0,0,0,,道連れになるだけだ
Dialogue: 0,0:02:26.54,0:02:28.84,Main-207+,,0,0,0,,何かあったら俺だけが動く
Dialogue: 0,0:02:28.84,0:02:31.01,Main-207+,,0,0,0,,よくあんなとこ走れるな
Dialogue: 0,0:02:31.01,0:02:32.59,Main-207+,,0,0,0,,なんて女だよ
Dialogue: 0,0:02:32.59,0:02:34.26,Main-207+,,0,0,0,,バカ！感心してどうする！
Dialogue: 0,0:02:34.72,0:02:37.05,Main-207+,,0,0,0,,おーい！今すぐ戻れ！
Dialogue: 0,0:02:37.05,0:02:39.18,Main-207+,,0,0,0,,海に飲み込まれるぞ！
Dialogue: 0,0:02:39.18,0:02:40.97,Thoughts-207+,,0,0,0,,イソギンチャクだ
Dialogue: 0,0:02:45.02,0:02:47.27,Thoughts-207+,,0,0,0,,イソギンチャク
Dialogue: 0,0:02:47.27,0:02:50.02,Thoughts-207+,,0,0,0,,煙突からイソギンチャク
Dialogue: 0,0:02:50.02,0:02:51.78,Thoughts-207+,,0,0,0,,何でイソギンチャク？
Dialogue: 0,0:02:52.53,0:02:54.53,Thoughts-207+,,0,0,0,,イソギンチャク…
Dialogue: 0,0:03:11.59,0:03:14.34,Main-207+,,0,0,0,,こら待てトナカイ！お前まで！
Dialogue: 0,0:03:14.34,0:03:15.88,Main-207+,,0,0,0,,ゾロ！
Dialogue: 0,0:03:17.97,0:03:20.97,Main-207+,,0,0,0,,海賊姉ちゃんすごーい！
Dialogue: 0,0:03:21.56,0:03:23.73,Main-207+,,0,0,0,,バカなマネを…
Dialogue: 0,0:03:23.73,0:03:26.02,Main-207+,,0,0,0,,手遅れになるよ
Dialogue: 0,0:03:26.02,0:03:27.19,Main-207+,,0,0,0,,沖を見なよ
Dialogue: 0,0:03:28.06,0:03:31.23,Main-207+,,0,0,0,,もう波がそこまで来てるんらよ！
Dialogue: 0,0:03:33.15,0:03:35.65,Main-207+,,0,0,0,,ヤベえ！あいつら死んじまう！
Dialogue: 0,0:03:35.65,0:03:37.16,Main-207+,,0,0,0,,もう助からねえぞ
Dialogue: 0,0:03:40.20,0:03:42.66,Main-207+,,0,0,0,,ゾロ！ゾロ！
Dialogue: 0,0:03:42.66,0:03:44.12,Main-207+,,0,0,0,,聞こえるか？
Dialogue: 0,0:03:44.12,0:03:45.58,Main-207+,,0,0,0,,俺だぞ！
Dialogue: 0,0:03:46.00,0:03:47.08,Main-207+,,0,0,0,,チョッパー？
Dialogue: 0,0:03:51.96,0:03:53.21,Main-207+,,0,0,0,,ダメだわ
Dialogue: 0,0:03:53.21,0:03:55.05,Main-207+,,0,0,0,,これ以上進めない
Dialogue: 0,0:04:02.68,0:04:04.81,Main-207+,,0,0,0,,ルフィ！
Dialogue: 0,0:04:11.11,0:04:14.28,Main-207+,,0,0,0,,あんた！そこで何やってんのよ！
Dialogue: 0,0:04:16.74,0:04:20.91,Main-207+,,0,0,0,,ニュ…　ニャミ！\Nうひろにいんのか？
Dialogue: 0,0:04:22.16,0:04:24.95,Main-207+,,0,0,0,,いやおい　聞いてくれよ！
Dialogue: 0,0:04:24.95,0:04:32.00,Main-207+,,0,0,0,,しかしあのハトのヤツに飛ばはれてよ！\Nほのまま飛んれこれがうめえことにここに
Dialogue: 0,0:04:43.39,0:04:47.02,Main-207+,,0,0,0,,ふざけてんじゃないわよ！\Nこんな大事な時に
Dialogue: 0,0:04:47.02,0:04:51.10,Main-207+,,0,0,0,,あんたがグズグズしてる間に\Nロビンが連れてかれちゃったじゃない！
Comment: 0,0:04:55.78,0:04:58.15,Main-207+,,0,0,0,,ロビンはあたしたちのために
Comment: 0,0:04:58.69,0:05:00.82,Main-207+,,0,0,0,,死ぬつもりなのよ！
Dialogue: 0,0:04:55.78,0:05:00.82,Main-207+,,0,0,0,,ロビンはあたしたちのために\N死ぬつもりなのよ！
Dialogue: 0,0:05:11.00,0:05:17.21,Main-207+,,0,0,0,,自分一人犠牲になってロビンは\Nあたしたちを政府の攻撃から守ってくれたの！
Dialogue: 0,0:05:18.01,0:05:21.22,Flashbacks-207+,,0,0,0,,{~Flashback W7 15}私には行く当ても帰る場所もないの
Dialogue: 0,0:05:21.59,0:05:23.47,Flashbacks-207+,,0,0,0,,{W7 10 - 26:42}いいえ　終わりよ
Dialogue: 0,0:05:23.47,0:05:25.35,Flashbacks-207+,,0,0,0,,もう二度と会うことはないわ
Dialogue: 0,0:05:26.93,0:05:30.81,Main-207+,,0,0,0,,連行されれば\N殺されることも分かってるのに！
Dialogue: 0,0:05:34.06,0:05:35.65,Main-207+,,0,0,0,,じゃあ
Dialogue: 0,0:05:35.65,0:05:37.73,Main-207+,,0,0,0,,やっぱりロビンは
Dialogue: 0,0:05:38.61,0:05:40.74,Main-207+,,0,0,0,,ウソついてたのか
Dialogue: 0,0:05:43.53,0:05:44.45,Main-207+,,0,0,0,,うん！
Dialogue: 0,0:05:46.28,0:05:48.08,Main-207+,,0,0,0,,よかった
Dialogue: 0,0:05:52.46,0:05:53.92,Main-207+,,0,0,0,,安心しろ！
Dialogue: 0,0:05:55.38,0:05:57.71,Main-207+,,0,0,0,,ロビンは死なせねえ！
Dialogue: 0,0:05:58.09,0:05:59.59,Main-207+,,0,0,0,,見ろ！あの波を！
Dialogue: 0,0:05:59.59,0:06:02.68,Main-207+,,0,0,0,,何だありゃ\Nやっぱりいつもの数倍でけえ！
Dialogue: 0,0:06:03.05,0:06:05.47,Main-207+,,0,0,0,,おい！本気でヤベえぞ
Dialogue: 0,0:06:05.47,0:06:08.72,Main-207+,,0,0,0,,海賊女！もう諦めて逃げろ！
Dialogue: 0,0:06:08.72,0:06:10.02,Main-207+,,0,0,0,,トナカイ！
Dialogue: 0,0:06:14.27,0:06:15.31,Main-207+,,0,0,0,,ちぎれる！
Dialogue: 0,0:06:15.31,0:06:16.81,Main-207+,,0,0,0,,抜けねえよ
Dialogue: 0,0:06:16.81,0:06:18.98,Main-207+,,0,0,0,,どうやって入ったんだゾロ
Dialogue: 0,0:06:18.98,0:06:20.32,Main-207+,,0,0,0,,引っ張るな！
Dialogue: 0,0:06:29.12,0:06:32.54,Main-207+,,0,0,0,,どうしよう\Nもう大波がそこまで来てるんだよ！
Dialogue: 0,0:06:33.33,0:06:35.21,Main-207+,,0,0,0,,どうしようったって…
Dialogue: 0,0:06:36.29,0:06:38.21,Main-207+,,0,0,0,,お前　ちょっと待て
Dialogue: 0,0:06:38.21,0:06:41.09,Main-207+,,0,0,0,,もしかして鬼徹持ってんじゃねえか？
Dialogue: 0,0:06:41.09,0:06:42.97,Main-207+,,0,0,0,,えっ　刀？
Dialogue: 0,0:06:42.97,0:06:44.34,Main-207+,,0,0,0,,ああ持ってるよ
Dialogue: 0,0:06:44.34,0:06:45.59,Main-207+,,0,0,0,,何で分かったんだ？
Dialogue: 0,0:06:45.59,0:06:49.43,Main-207+,,0,0,0,,分かるんだ　そいつだけは\N妖刀だからな
Dialogue: 0,0:06:49.97,0:06:51.72,Main-207+,,0,0,0,,チョッパー　持っててくれたのか
Dialogue: 0,0:06:51.72,0:06:52.52,Main-207+,,0,0,0,,ありがとう
Dialogue: 0,0:06:52.52,0:06:55.06,Main-207+,,0,0,0,,それを手に持たせろ　急げ！
Dialogue: 0,0:06:55.85,0:06:56.85,Main-207+,,0,0,0,,早く逃げろ！
Dialogue: 0,0:06:56.85,0:07:00.11,Main-207+,,0,0,0,,高い場所へ登れ\Nもっと高い場所へ！
Dialogue: 0,0:07:00.94,0:07:02.78,Main-207+,,0,0,0,,もうダメだ！間に合わねえ！
Dialogue: 0,0:07:02.78,0:07:05.74,Main-207+,,0,0,0,,のまれちまうぞー！
Dialogue: 0,0:07:10.66,0:07:13.70,Main-207+,,0,0,0,,アクア･ラグナだー！
Dialogue: 0,0:07:26.30,0:07:27.84,Main-207+,,0,0,0,,何？これ…
Dialogue: 0,0:07:34.93,0:07:36.27,Main-207+,,0,0,0,,もうダメだ！
Dialogue: 0,0:08:01.50,0:08:05.05,Main-207+,,0,0,0,,何だ？建物壊しやがった！
Dialogue: 0,0:08:15.81,0:08:17.10,Main-207+,,0,0,0,,ゾロ！
Dialogue: 0,0:08:17.10,0:08:19.31,Main-207+,,0,0,0,,離れてろチョッパー
Dialogue: 0,0:08:19.31,0:08:20.81,Main-207+,,0,0,0,,{\fad(150,150)}一刀流
Dialogue: 0,0:08:20.81,0:08:23.98,Main-207+,,0,0,0,,{\fad(150,150)}三十六煩悩鳳！
Dialogue: 0,0:08:31.78,0:08:33.91,Main-207+,,0,0,0,,何だあいつら！
Dialogue: 0,0:08:35.12,0:08:37.33,Main-207+,,0,0,0,,行くぞ！ナミ！
Dialogue: 0,0:08:41.38,0:08:43.00,Main-207+,,0,0,0,,何だこりゃ
Dialogue: 0,0:08:43.00,0:08:45.34,Main-207+,,0,0,0,,{\fad(150,150)}ランブル！ジャンピングポイント！
Dialogue: 0,0:08:46.76,0:08:47.67,Main-207+,,0,0,0,,つかまってゾロ
Dialogue: 0,0:08:57.35,0:08:58.64,Main-207+,,0,0,0,,裏町が！
Dialogue: 0,0:09:02.48,0:09:03.19,Main-207+,,0,0,0,,クソ！
Dialogue: 0,0:09:15.37,0:09:16.33,Main-207+,,0,0,0,,おい！
Dialogue: 0,0:09:16.33,0:09:17.29,Main-207+,,0,0,0,,あれを見ろ
Dialogue: 0,0:09:17.29,0:09:18.91,Main-207+,,0,0,0,,あいつらだ！
Dialogue: 0,0:09:34.18,0:09:37.22,Main-207+,,0,0,0,,すごーい！やった～！
Dialogue: 0,0:09:38.39,0:09:40.31,Main-207+,,0,0,0,,大橋まで来れば安全だ
Dialogue: 0,0:09:40.31,0:09:42.77,Main-207+,,0,0,0,,さすがにあそこまで波は届かねえ
Dialogue: 0,0:09:42.77,0:09:44.36,Main-207+,,0,0,0,,すげえぞお前ら！
Dialogue: 0,0:09:44.36,0:09:45.82,Main-207+,,0,0,0,,やるなお前ら！
Dialogue: 0,0:10:03.58,0:10:05.04,Main-207+,,0,0,0,,ここまで来やがった！
Dialogue: 0,0:10:05.04,0:10:06.75,Main-207+,,0,0,0,,麦わらたちは？
Dialogue: 0,0:10:06.75,0:10:08.63,Main-207+,,0,0,0,,アクア･ラグナにのまれちまったのか？
Dialogue: 0,0:10:14.80,0:10:16.35,Main-207+,,0,0,0,,いや！あれ見ろ！
Dialogue: 0,0:10:20.14,0:10:21.68,Main-207+,,0,0,0,,パウリーさん！
Dialogue: 0,0:10:28.27,0:10:29.32,Main-207+,,0,0,0,,クソッ…
Dialogue: 0,0:10:50.25,0:10:51.84,Main-207+,,0,0,0,,まだだ　走れ！
Dialogue: 0,0:10:51.84,0:10:54.05,Main-207+,,0,0,0,,造船島へ走れ！
Dialogue: 0,0:10:56.09,0:10:57.60,Main-207+,,0,0,0,,急げ！
Dialogue: 0,0:10:57.60,0:10:59.39,Main-207+,,0,0,0,,大橋が崩れるぞ！
Dialogue: 0,0:11:30.88,0:11:32.76,Main-207+,,0,0,0,,なんて波だ
Dialogue: 0,0:11:33.67,0:11:37.01,Main-207+,,0,0,0,,考えられねえ\Nここは造船島だぞ
Dialogue: 0,0:11:37.51,0:11:39.60,Main-207+,,0,0,0,,ここにいてもヤバそうだ
Dialogue: 0,0:11:39.93,0:11:42.47,Main-207+,,0,0,0,,見ろ　潮がまた引いてく
Dialogue: 0,0:11:43.10,0:11:45.98,Main-207+,,0,0,0,,当然だ　まだまだ続くぞ
Dialogue: 0,0:11:45.98,0:11:48.35,Main-207+,,0,0,0,,第２波　第３波と
Dialogue: 0,0:11:48.35,0:11:50.31,Main-207+,,0,0,0,,今みてえなのが
Dialogue: 0,0:11:50.31,0:11:53.23,Main-207+,,0,0,0,,俺たちももっと高い所へ避難しよう
Dialogue: 0,0:12:00.45,0:12:02.91,Main-207+,,0,0,0,,まったくムチャしやがって
Dialogue: 0,0:12:02.91,0:12:06.25,Main-207+,,0,0,0,,ありがとう\N助かったよ　ロープのヤツ
Dialogue: 0,0:12:06.75,0:12:08.08,Main-207+,,0,0,0,,びっくりした
Dialogue: 0,0:12:08.08,0:12:09.67,Main-207+,,0,0,0,,あれがアクア･ラグナ？
Dialogue: 0,0:12:10.04,0:12:11.92,Main-207+,,0,0,0,,まだ震えが止まらない
Dialogue: 0,0:12:13.42,0:12:18.13,Main-207+,,0,0,0,,あんなでかいのが毎年来てたら\Nこの島はとっくになくなってるよ
Dialogue: 0,0:12:18.51,0:12:20.14,Main-207+,,0,0,0,,今年のは特別だ
Dialogue: 0,0:12:20.14,0:12:22.89,Main-207+,,0,0,0,,ホントにあきれたねおめえら
Dialogue: 0,0:12:22.89,0:12:25.31,Main-207+,,0,0,0,,よく助かったもんら
Dialogue: 0,0:12:26.23,0:12:27.94,Main-207+,,0,0,0,,怪獣のばあさん
Dialogue: 0,0:12:27.94,0:12:29.81,Main-207+,,0,0,0,,この島にいたのか
Dialogue: 0,0:12:29.81,0:12:31.19,Main-207+,,0,0,0,,当たりめえら
Dialogue: 0,0:12:31.19,0:12:35.61,Main-207+,,0,0,0,,あんな海の真ん中にいたら\N溺れて死んじまうわね
Dialogue: 0,0:12:36.94,0:12:38.61,Main-207+,,0,0,0,,海賊兄ちゃん
Dialogue: 0,0:12:38.61,0:12:41.45,Main-207+,,0,0,0,,すごかったよ！ババーンって
Dialogue: 0,0:12:42.95,0:12:43.95,Main-207+,,0,0,0,,まあな
Dialogue: 0,0:12:46.66,0:12:48.33,Main-207+,,0,0,0,,窒息させる気かい！
Dialogue: 0,0:12:49.54,0:12:53.84,Main-207+,,0,0,0,,この野郎　しがみついたまま\N気絶してやがる
Dialogue: 0,0:12:55.55,0:12:56.34,Main-207+,,0,0,0,,あれ？
Dialogue: 0,0:12:56.34,0:12:59.93,Main-207+,,0,0,0,,そういやゾロ\N何でお前まで波に追われてたんだ？
Dialogue: 0,0:12:59.93,0:13:01.39,Main-207+,,0,0,0,,下の町にいたのか？
Dialogue: 0,0:13:01.39,0:13:04.14,Main-207+,,0,0,0,,えっ？い…　いや　別に…
Dialogue: 0,0:13:04.14,0:13:05.89,Main-207+,,0,0,0,,煙突に刺さってた
Dialogue: 0,0:13:09.77,0:13:12.35,Main-207+,,0,0,0,,煙突に刺さってた？
Dialogue: 0,0:13:14.40,0:13:16.40,Main-207+,,0,0,0,,ゾロはまぬけだな～
Dialogue: 0,0:13:16.40,0:13:18.65,Main-207+,,0,0,0,,どうやったらそんなことに…
Dialogue: 0,0:13:18.65,0:13:21.16,Main-207+,,0,0,0,,人を笑える立場かあんたが！
Dialogue: 0,0:13:21.16,0:13:22.61,Main-207+,,0,0,0,,どっちも大まぬけよ！
Dialogue: 0,0:13:23.53,0:13:25.37,Main-207+,,0,0,0,,じゃあサンジとウ…
Dialogue: 0,0:13:25.37,0:13:26.24,Main-207+,,0,0,0,,サンジは？
Dialogue: 0,0:13:28.16,0:13:29.33,Main-207+,,0,0,0,,そうね
Dialogue: 0,0:13:29.33,0:13:32.29,Main-207+,,0,0,0,,話すことはいろいろあるわ\Nゾロも聞いて
Dialogue: 0,0:13:40.01,0:13:42.59,Main-207+,,0,0,0,,最大のチャンスが巡ってきた
Dialogue: 0,0:13:43.59,0:13:46.35,Main-207+,,0,0,0,,海軍本部の中将５人
Dialogue: 0,0:13:46.35,0:13:50.89,Main-207+,,0,0,0,,そして軍艦10隻を\N緊急招集できるバスターコール
Dialogue: 0,0:13:50.89,0:13:57.65,Main-207+,,0,0,0,,この発動の権利をかの青雉が\N我らＣＰ９に与えてくれたおかげだ
Dialogue: 0,0:13:58.98,0:14:01.95,Main-207+,,0,0,0,,そう思うだろ？ファンクフリード
Dialogue: 0,0:14:04.53,0:14:07.70,Main-207+,,0,0,0,,世界政府が20年も追い続けた女
Dialogue: 0,0:14:07.70,0:14:12.75,Main-207+,,0,0,0,,ニコ･ロビンが\Nこうも簡単に我々ＣＰ９の手に落ち
Dialogue: 0,0:14:12.75,0:14:16.38,Main-207+,,0,0,0,,同時にプルトンの設計図を持つ\Nトムの弟子
Dialogue: 0,0:14:16.38,0:14:19.42,Main-207+,,0,0,0,,にっくきカティ･フラムも一緒に連行中
Dialogue: 0,0:14:20.01,0:14:26.39,Main-207+,,0,0,0,,世界広しといえど\N古代兵器復活の鍵を握るたった２人の人間が
Dialogue: 0,0:14:26.80,0:14:31.52,Main-207+,,0,0,0,,海列車に乗って今\N俺のもとへ向かっているのだ
Dialogue: 0,0:14:32.35,0:14:36.56,Main-207+,,0,0,0,,世界を滅ぼせるほどの軍事力が\N俺のもとに
Dialogue: 0,0:14:45.28,0:14:47.70,Main-207+,,0,0,0,,考えることは何もねえじゃねえか
Dialogue: 0,0:14:48.41,0:14:50.41,Main-207+,,0,0,0,,すぐに船出して追いかけよう！
Dialogue: 0,0:14:51.50,0:14:53.33,Main-207+,,0,0,0,,それ以外ねえな
Dialogue: 0,0:14:59.42,0:15:01.88,Main-207+,,0,0,0,,おい！ロープのヤツ
Dialogue: 0,0:15:02.46,0:15:03.67,Main-207+,,0,0,0,,船出してくれよ
Dialogue: 0,0:15:03.67,0:15:07.39,Main-207+,,0,0,0,,いや　船より\N海列車はもう出ねえのか？
Dialogue: 0,0:15:07.76,0:15:12.02,Main-207+,,0,0,0,,海列車ってのはこの世に\Nパッフィングトム１台きりだ
Dialogue: 0,0:15:12.02,0:15:14.94,Main-207+,,0,0,0,,かつていた伝説の船大工のチームが
Dialogue: 0,0:15:14.94,0:15:18.65,Main-207+,,0,0,0,,力を合わせてこそ完成した\N奇跡の船なんだ　あれは
Dialogue: 0,0:15:20.44,0:15:22.32,Main-207+,,0,0,0,,じゃあ船貸してくれ
Dialogue: 0,0:15:22.32,0:15:24.82,Main-207+,,0,0,0,,この町で一番強くて速え船
Dialogue: 0,0:15:24.82,0:15:27.07,Main-207+,,0,0,0,,いいかげんにしろてめえら！
Dialogue: 0,0:15:27.82,0:15:31.12,Main-207+,,0,0,0,,たった今　海で何を見た？
Dialogue: 0,0:15:31.12,0:15:34.41,Main-207+,,0,0,0,,もう少しで波にさらわれちまうとこだったんだぞ！
Dialogue: 0,0:15:34.41,0:15:37.88,Main-207+,,0,0,0,,そうだぞ\N今海に出られるわけねえだろ
Dialogue: 0,0:15:37.88,0:15:38.75,Main-207+,,0,0,0,,バカか！
Dialogue: 0,0:15:38.75,0:15:43.42,Main-207+,,0,0,0,,例年のアクア･ラグナでさえ\Nそれを越えた船はいねえんだ
Dialogue: 0,0:15:43.42,0:15:45.63,Main-207+,,0,0,0,,崩壊する裏町を見たろ
Dialogue: 0,0:15:46.05,0:15:49.34,Main-207+,,0,0,0,,今までのアクア･ラグナじゃびくともしなかった町が…
Dialogue: 0,0:15:49.89,0:15:51.51,Main-207+,,0,0,0,,哀れなもんだ
Dialogue: 0,0:15:52.14,0:15:55.77,Main-207+,,0,0,0,,しかも　今年のでかさは桁違いだ
Dialogue: 0,0:15:55.77,0:15:59.94,Main-207+,,0,0,0,,今船を出せば\N最大のガレオン船で挑んだとしても
Dialogue: 0,0:15:59.94,0:16:02.48,Main-207+,,0,0,0,,一発で粉々にされちまうだろう
Dialogue: 0,0:16:03.07,0:16:06.65,Main-207+,,0,0,0,,死ぬと分かってて\N船を出させるわけにはいかねえ
Dialogue: 0,0:16:07.24,0:16:08.66,Main-207+,,0,0,0,,朝まで待て
Dialogue: 0,0:16:10.24,0:16:12.49,Main-207+,,0,0,0,,嵐が過ぎたら船くらい貸してやる
Dialogue: 0,0:16:13.20,0:16:16.12,Main-207+,,0,0,0,,おい　おめえらも\N避難所にでも行ってろ
Dialogue: 0,0:16:16.12,0:16:18.00,Main-207+,,0,0,0,,もう人捜しは終わったんだ
Dialogue: 0,0:16:18.58,0:16:19.67,Main-207+,,0,0,0,,もし…
Dialogue: 0,0:16:21.42,0:16:26.47,Main-207+,,0,0,0,,もし　朝まで待ったとして\Nあたしたちの願いは果たされるの？
Dialogue: 0,0:16:28.97,0:16:32.05,Main-207+,,0,0,0,,エニエス･ロビーって\Nあたし知ってるわ
Dialogue: 0,0:16:32.55,0:16:35.56,Main-207+,,0,0,0,,政府の島だと聞いて思い出したの
Dialogue: 0,0:16:35.56,0:16:36.56,Main-207+,,0,0,0,,そこは…
Dialogue: 0,0:16:36.89,0:16:40.06,Main-207+,,0,0,0,,そこは“正義の門”がある場所じゃないの？
Dialogue: 0,0:16:41.15,0:16:42.81,Main-207+,,0,0,0,,何だ？そりゃ
Dialogue: 0,0:16:43.15,0:16:47.15,Main-207+,,0,0,0,,政府所有の司法の島\Nエニエス･ロビー
Dialogue: 0,0:16:47.74,0:16:50.16,Main-207+,,0,0,0,,そこにあるのは名ばかりの裁判所
Dialogue: 0,0:16:50.78,0:16:55.04,Main-207+,,0,0,0,,エニエス･ロビーへ連行されること\Nそのものが罪人の証しとされ
Dialogue: 0,0:16:55.04,0:16:59.41,Main-207+,,0,0,0,,罪人は\Nその誰もいない裁判所を素通りして
Dialogue: 0,0:16:59.41,0:17:03.50,Main-207+,,0,0,0,,やがて冷たく巨大な鋼鉄の扉にたどり着く
Dialogue: 0,0:17:05.88,0:17:08.92,Main-207+,,0,0,0,,その扉は　“正義の門”と呼ばれ
Dialogue: 0,0:17:09.47,0:17:11.39,Main-207+,,0,0,0,,罪がある者がくぐれば
Dialogue: 0,0:17:11.39,0:17:15.39,Main-207+,,0,0,0,,もう二度と日の光を\N見ることのできない絶望の扉
Dialogue: 0,0:17:16.01,0:17:20.35,Main-207+,,0,0,0,,なぜなら\Nその先にある港から海へ出て
Dialogue: 0,0:17:20.35,0:17:22.81,Main-207+,,0,0,0,,到達できる場所は２つしかないから
Dialogue: 0,0:17:24.19,0:17:28.86,Main-207+,,0,0,0,,１つは\N世界中の正義の戦力の最高峰
Dialogue: 0,0:17:28.86,0:17:30.11,Main-207+,,0,0,0,,“海軍本部”
Dialogue: 0,0:17:31.57,0:17:35.16,Main-207+,,0,0,0,,もう１つは\N拷問室と死刑台が立ち並び
Dialogue: 0,0:17:35.16,0:17:39.37,Main-207+,,0,0,0,,世界中で暴れ回っていた凶悪な\N囚人たちが幽閉される
Dialogue: 0,0:17:39.37,0:17:42.79,Main-207+,,0,0,0,,深海の大監獄　“インペルダウン”
Dialogue: 0,0:17:43.83,0:17:45.29,Main-207+,,0,0,0,,つまり
Dialogue: 0,0:17:45.29,0:17:49.42,Main-207+,,0,0,0,,エニエス･ロビーは罪人に\N何の慈悲も与えず
Dialogue: 0,0:17:49.42,0:17:52.93,Main-207+,,0,0,0,,ただそこへ送り込むだけの裁判機関
Dialogue: 0,0:17:52.93,0:17:54.34,Main-207+,,0,0,0,,そうでしょ？
Dialogue: 0,0:17:55.64,0:17:57.76,Main-207+,,0,0,0,,賞金首のロビンにとっては
Dialogue: 0,0:17:57.76,0:18:00.48,Main-207+,,0,0,0,,どこへ運ばれようとその先は地獄よ
Dialogue: 0,0:18:00.85,0:18:05.36,Main-207+,,0,0,0,,こうしてる今も　ロビンは刻々と\N正義の門に近づいてってるのに
Dialogue: 0,0:18:05.73,0:18:08.32,Main-207+,,0,0,0,,朝までなんて待てるわけないじゃない！
Dialogue: 0,0:18:11.19,0:18:14.16,Main-207+,,0,0,0,,そこまで分かってんなら１つ教えとくが
Dialogue: 0,0:18:14.91,0:18:18.29,Main-207+,,0,0,0,,たとえ海が穏やかで船を出せたとしても
Dialogue: 0,0:18:18.74,0:18:21.16,Main-207+,,0,0,0,,そこへは行くべきじゃねえ
Dialogue: 0,0:18:21.16,0:18:25.08,Main-207+,,0,0,0,,お前ら自身\N海賊だってことを忘れるな
Dialogue: 0,0:18:25.58,0:18:30.71,Main-207+,,0,0,0,,お前の言うとおりエニエス･ロビーは\N世界政府中枢につながる玄関だ
Dialogue: 0,0:18:30.71,0:18:34.01,Main-207+,,0,0,0,,当然それに相当する戦線が敷いてある
Dialogue: 0,0:18:34.59,0:18:40.18,Main-207+,,0,0,0,,どんな海賊も　あの島へ連行された仲間を\N取り返そうなんて考えねえ
Dialogue: 0,0:18:40.18,0:18:42.52,Main-207+,,0,0,0,,どうなるか分かりきっているからな
Dialogue: 0,0:18:43.06,0:18:48.48,Main-207+,,0,0,0,,お前ら世界政府の中枢に\Nケンカでも売る気か！
Dialogue: 0,0:18:51.90,0:18:54.78,Main-207+,,0,0,0,,そ…　そうだぞ　お前ら\Nもうやめとけ
Dialogue: 0,0:18:54.78,0:18:56.95,Main-207+,,0,0,0,,アクア･ラグナで朝まで船は出せねえ
Dialogue: 0,0:18:56.95,0:18:58.91,Main-207+,,0,0,0,,追いかけても殺されちまう
Dialogue: 0,0:18:58.91,0:19:01.95,Main-207+,,0,0,0,,お前らこそ助かる可能性ゼロだぞ
Dialogue: 0,0:19:01.95,0:19:02.87,Main-207+,,0,0,0,,ルフィ
Dialogue: 0,0:19:04.83,0:19:06.38,Main-207+,,0,0,0,,じゃあ船は
Dialogue: 0,0:19:06.38,0:19:08.17,Main-207+,,0,0,0,,奪っていく！
Dialogue: 0,0:19:09.59,0:19:12.30,Main-207+,,0,0,0,,俺たちは今海へ出る！
Dialogue: 0,0:19:16.09,0:19:17.89,Main-207+,,0,0,0,,仲間が待ってんだ
Dialogue: 0,0:19:17.89,0:19:21.14,Main-207+,,0,0,0,,邪魔すんなー！
Dialogue: 0,0:19:24.69,0:19:27.52,Main-207+,,0,0,0,,な…　波まで怒った
Dialogue: 0,0:19:30.65,0:19:32.40,Main-207+,,0,0,0,,–　なっ…\N–　やる気か？あんにゃろう
Dialogue: 0,0:19:32.40,0:19:33.86,Main-207+,,0,0,0,,ああびっくりした
Dialogue: 0,0:19:35.36,0:19:38.20,Main-207+,,0,0,0,,いいぜ　相手になってやる
Dialogue: 0,0:19:45.50,0:19:47.87,Main-207+,,0,0,0,,待ちな　おめえら
Dialogue: 0,0:19:50.63,0:19:51.92,Main-207+,,0,0,0,,ココロさん
Dialogue: 0,0:19:51.92,0:19:54.72,Main-207+,,0,0,0,,悪いのはおめえら　麦わら
Dialogue: 0,0:19:55.80,0:19:58.47,Main-207+,,0,0,0,,パウリーの言うとおりら\Nバカたれ
Dialogue: 0,0:19:58.47,0:20:00.89,Main-207+,,0,0,0,,うっせえな！ばあさんには関係…
Dialogue: 0,0:20:00.89,0:20:03.60,Main-207+,,0,0,0,,関係ねえ…　なあ
Dialogue: 0,0:20:03.60,0:20:05.10,Main-207+,,0,0,0,,まあ聞きな
Dialogue: 0,0:20:05.10,0:20:08.40,Main-207+,,0,0,0,,まったく　おめえら\Nほっときゃあ死ぬ気らね
Dialogue: 0,0:20:08.77,0:20:10.02,Main-207+,,0,0,0,,いいかい？
Dialogue: 0,0:20:10.02,0:20:14.78,Main-207+,,0,0,0,,あのアクア･ラグナを\N乗り越える船が存在するとしたら
Dialogue: 0,0:20:14.78,0:20:18.45,Main-207+,,0,0,0,,伝説の男が作った海列車だけら
Dialogue: 0,0:20:18.78,0:20:21.66,Main-207+,,0,0,0,,だけどそれは今ここにねえから
Dialogue: 0,0:20:21.66,0:20:23.74,Main-207+,,0,0,0,,俺たちは船で行こうとしてんだ
Dialogue: 0,0:20:25.75,0:20:28.50,Main-207+,,0,0,0,,死ぬ覚悟があるんなら
Dialogue: 0,0:20:29.00,0:20:30.13,Main-207+,,0,0,0,,ついてきな
Dialogue: 0,0:20:30.50,0:20:32.09,Main-207+,,0,0,0,,出してやるよ
Dialogue: 0,0:20:32.09,0:20:33.92,Main-207+,,0,0,0,,海列車
Dialogue: 0,0:20:59.61,0:21:01.57,Main-207+,,0,0,0,,バカ野郎！何してやがる！
Dialogue: 0,0:21:01.57,0:21:04.45,Main-207+,,0,0,0,,ここにいるヤツは\N罪人以外みんな制服だ！
Dialogue: 0,0:21:09.50,0:21:11.08,Main-207+,,0,0,0,,か…　かかれ！
Dialogue: 0,0:21:11.50,0:21:14.04,Main-207+,,0,0,0,,やっぱりそうなっちまうのか
Dialogue: 0,0:21:24.22,0:21:27.22,Main-207+,,0,0,0,,いい作戦だと思ったんだがな
Dialogue: 0,0:21:27.22,0:21:29.31,Main-207+,,0,0,0,,バックレ素通り大作戦
Dialogue: 0,0:21:32.44,0:21:34.40,Main-207+,,0,0,0,,ええっ？サ…　サンジ！？
Dialogue: 0,0:21:34.40,0:21:35.61,Main-207+,,0,0,0,,–　待ちな\N–　待ちな
Dialogue: 0,0:21:39.49,0:21:41.53,Main-207+,,0,0,0,,–　ここから先へは行かせねえ\N–　ここから先へは行かせねえ
Dialogue: 0,0:21:42.45,0:21:43.87,Main-207+,,0,0,0,,双子か？
Dialogue: 0,0:21:50.21,0:21:51.67,Main-207+,,0,0,0,,{\fad(150,150)}コリエ…
Dialogue: 0,0:21:53.63,0:21:55.34,Main-207+,,0,0,0,,{\fad(150,150)}フリット！
Dialogue: 0,0:22:02.93,0:22:06.85,Main-207+,,0,0,0,,サンジ\Nお前が何で海列車にいるんだ？
Dialogue: 0,0:22:07.39,0:22:09.60,Main-207+,,0,0,0,,そりゃこっちが聞きてえよ
Dialogue: 0,0:22:15.86,0:22:17.27,Main-207+,,0,0,0,,そこの…　あ～
Dialogue: 0,0:22:17.27,0:22:19.61,Main-207+,,0,0,0,,名前など存じませんがそこの君
Dialogue: 0,0:22:19.61,0:22:22.57,Main-207+,,0,0,0,,わざとらしいなてめえこの…
Comment: 0,0:22:24.74,0:22:26.07,Main-207+,,0,0,0,,おおっ
Dialogue: 0,0:22:25.95,0:22:28.20,Main-207+,,0,0,0,,あった　あった　電伝虫
Dialogue: 0,0:22:28.20,0:22:29.83,Main-207+,,0,0,0,,おおよかった
Dialogue: 0,0:22:29.83,0:22:32.16,Main-207+,,0,0,0,,何だ\Nここには何匹もあるじゃねえか
Dialogue: 0,0:22:32.16,0:22:33.96,Main-207+,,0,0,0,,通信室も兼ねてんのかな？
Dialogue: 0,0:22:35.21,0:22:40.42,Main-207+,,0,0,0,,さっきの車両の役人たちときたら\N仮面やら仮装やらくっだらねえもんばっか持ってやがって
Dialogue: 0,0:22:40.88,0:22:43.59,Main-207+,,0,0,0,,これでやっとナミさんと連絡が取れる
Dialogue: 0,0:22:43.59,0:22:47.10,Main-207+,,0,0,0,,おめえら　つまり海賊仲間か
Dialogue: 0,0:22:47.10,0:22:48.56,Main-207+,,0,0,0,,–　元な\N–　元な
Dialogue: 0,0:22:48.56,0:22:50.06,Main-207+,,0,0,0,,誰だ？てめえは
Dialogue: 0,0:22:50.06,0:22:55.44,Main-207+,,0,0,0,,俺はウォーターセブンの裏の顔\N解体屋フランキーだ
Dialogue: 0,0:22:56.98,0:22:59.98,Main-207+,,0,0,0,,てめえがフランキーか！クソ野郎
Dialogue: 0,0:22:59.98,0:23:02.94,Main-207+,,0,0,0,,よくもあん時はうちの長っ鼻をえらい目に！
Dialogue: 0,0:23:02.94,0:23:05.57,Main-207+,,0,0,0,,何枚におろされてえんだ　こら！
Dialogue: 0,0:23:05.57,0:23:07.20,Main-207+,,0,0,0,,ああっ　いや\Nあいや　あいや…
Dialogue: 0,0:23:07.20,0:23:10.58,Main-207+,,0,0,0,,あっサ…　サンジ　ちょっと待て\Nあれからいろいろあったんだ
Dialogue: 0,0:23:10.58,0:23:13.75,Main-207+,,0,0,0,,てんめえ\Nこの縄解けたら覚えてろ！
Dialogue: 0,0:23:13.75,0:23:16.00,Main-207+,,0,0,0,,またおめえはそういうことを…
Dialogue: 0,0:23:16.50,0:23:20.46,Main-207+,,0,0,0,,ああ　こいつは\N一時メリー号を助けてくれたんだ
Dialogue: 0,0:23:21.71,0:23:23.21,Main-207+,,0,0,0,,そうだ…
Dialogue: 0,0:23:24.09,0:23:26.38,Main-207+,,0,0,0,,メリー号は…
Dialogue: 0,0:23:27.76,0:23:31.39,Main-207+,,0,0,0,,おいおい　待てよ\N今しんみりしてる場合か
Dialogue: 0,0:23:31.39,0:23:35.60,Main-207+,,0,0,0,,ううっ　とにかく兄ちゃん\N頼む　縄をほどいてくれよ
Dialogue: 0,0:23:35.60,0:23:39.40,Main-207+,,0,0,0,,誰がてめえの縄解くか！\N一生捕まってろタコ！
Dialogue: 0,0:23:39.40,0:23:43.49,Main-207+,,0,0,0,,てんめえ！人が下手に出てりゃ\Nいい気になりやがって！
Dialogue: 0,0:23:43.49,0:23:46.11,Main-207+,,0,0,0,,やめろってんだ　てめえらはおい！
Dialogue: 0,0:23:46.11,0:23:49.95,Main-207+,,0,0,0,,グズグズしてたら\N見つかっちまうだろうがああ！
Dialogue: 0,0:23:49.95,0:23:51.45,Main-207+,,0,0,0,,うるせえんだてめえは！
Dialogue: 0,0:23:51.45,0:23:52.58,Main-207+,,0,0,0,,何！？
Dialogue: 0,0:23:52.58,0:23:54.08,Main-207+,,0,0,0,,２人とも黙れこのっ
Dialogue: 0,0:23:54.08,0:23:55.91,Main-207+,,0,0,0,,いいから早く縄ほどけ！
Dialogue: 0,0:24:01.80,0:24:03.00,Main-207+,,0,0,0,,Ｔボーン大佐
Dialogue: 0,0:24:08.43,0:24:11.64,Main-207+,,0,0,0,,この倉庫は８年以上放置されてる
Dialogue: 0,0:24:12.22,0:24:16.23,Main-207+,,0,0,0,,海列車に至っちゃ12年以上手付かずら
Dialogue: 0,0:24:16.23,0:24:17.48,Main-207+,,0,0,0,,行くぞチョッパー
Dialogue: 0,0:24:17.48,0:24:18.56,Main-207+,,0,0,0,,うん
Dialogue: 0,0:24:18.56,0:24:20.69,Main-207+,,0,0,0,,もう動かねえかもしんねえがな
Dialogue: 0,0:24:21.82,0:24:23.73,Main-207+,,0,0,0,,おい！それじゃ困るぞ
Dialogue: 0,0:24:27.99,0:24:30.37,Main-207+,,0,0,0,,おいおい　待ちな
Dialogue: 0,0:24:30.37,0:24:35.08,Main-207+,,0,0,0,,そんなに急いだって鍵がなきゃ通れねえよ
Dialogue: 0,0:24:36.25,0:24:38.67,Main-207+,,0,0,0,,何ら？開いてるれえ
Dialogue: 0,0:24:43.92,0:24:45.17,Main-207+,,0,0,0,,あった！
Dialogue: 0,0:24:45.80,0:24:48.17,Main-207+,,0,0,0,,かっこいいぞ～！
Dialogue: 0,0:24:48.17,0:24:50.51,Main-207+,,0,0,0,,すげえ！
Dialogue: 0,0:24:51.64,0:24:55.60,Main-207+,,0,0,0,,言っとくけど\Nまともなもんじゃねえよ
Dialogue: 0,0:24:55.60,0:24:58.31,Main-207+,,0,0,0,,こいつの名は“ロケットマン”
Dialogue: 0,0:24:58.31,0:25:01.81,Main-207+,,0,0,0,,とても客なんぞ乗せられねえ代物さ
Dialogue: 0,0:25:01.81,0:25:03.19,Main-207+,,0,0,0,,ロケットマン！
Dialogue: 0,0:25:03.19,0:25:04.77,Main-207+,,0,0,0,,速そう！
Dialogue: 0,0:25:04.77,0:25:06.11,Main-207+,,0,0,0,,すごーい！
Dialogue: 0,0:25:06.78,0:25:09.15,Main-207+,,0,0,0,,何だ？あの面は
Dialogue: 0,0:25:09.15,0:25:12.37,Main-207+,,0,0,0,,サメのヘッドはしゃれで付けてあんらがね
Comment: 0,0:25:13.24,0:25:13.91,Main-207+,,0,0,0,,あれ？
Dialogue: 0,0:25:15.08,0:25:16.66,Main-207+,,0,0,0,,アイスのおっさん
Dialogue: 0,0:25:17.95,0:25:19.37,Main-207+,,0,0,0,,麦わら
Dialogue: 0,0:25:19.37,0:25:20.83,Main-207+,,0,0,0,,よく無事だったな
Dialogue: 0,0:25:21.33,0:25:23.92,Main-207+,,0,0,0,,海賊娘の言ったとおりだ
Dialogue: 0,0:25:23.92,0:25:25.46,Main-207+,,0,0,0,,ココロさんが連れてきたのか
Dialogue: 0,0:25:25.46,0:25:28.67,Main-207+,,0,0,0,,命はあったようだね　アイスバーグ
Dialogue: 0,0:25:28.67,0:25:30.80,Main-207+,,0,0,0,,おめえここで何してんらい？
Dialogue: 0,0:25:31.22,0:25:34.89,Main-207+,,0,0,0,,ここにいるってことは\Nあんたと同じことを考えてたのさ
Comment: 0,0:25:34.89,0:25:35.64,Main-207+,,0,0,0,,うん？
Dialogue: 0,0:25:36.35,0:25:38.27,Main-207+,,0,0,0,,バカはほっとけねえもんだ
Dialogue: 0,0:25:43.69,0:25:44.52,Main-207+,,0,0,0,,使え
Dialogue: 0,0:25:45.15,0:25:46.94,Main-207+,,0,0,0,,整備は済んだ
Dialogue: 0,0:25:46.94,0:25:49.94,Main-207+,,0,0,0,,水も石炭も積んで\N今蒸気をためてる
Dialogue: 0,0:25:50.95,0:25:53.57,Main-207+,,0,0,0,,おっさん準備しててくれたのか
Comment: 0,0:25:53.57,0:25:54.82,Main-207+,,0,0,0,,うおっ…　おっとっと
Dialogue: 0,0:25:55.91,0:25:58.37,Main-207+,,0,0,0,,喜ぶのは生きてられてからにしろ
Dialogue: 0,0:25:58.37,0:26:03.50,Main-207+,,0,0,0,,何しろこのロケットマンは\Nどう調整しても蒸気機関がスピードを抑えられねえ
Dialogue: 0,0:26:03.50,0:26:06.59,Main-207+,,0,0,0,,パッフィングトム完成以前の失敗作だ
Dialogue: 0,0:26:07.05,0:26:09.21,Main-207+,,0,0,0,,命の保証はできねえぞ
Dialogue: 0,0:26:10.42,0:26:13.38,Main-207+,,0,0,0,,ああ\Nありがとうアイスのおっさん
Dialogue: 0,0:26:15.80,0:26:17.97,Main-207+,,0,0,0,,よーし！行くぞ！
Dialogue: 0,0:26:18.52,0:26:20.06,Main-207+,,0,0,0,,おめえら乗れ！
Dialogue: 0,0:26:20.89,0:26:23.39,Main-207+,,0,0,0,,ばあさん\Nナミが来たらすぐ出してくれ
Dialogue: 0,0:26:23.39,0:26:24.90,Main-207+,,0,0,0,,わっとっとっと…
Dialogue: 0,0:26:27.02,0:26:29.23,Main-207+,,0,0,0,,ルフィ！大丈夫か？
Dialogue: 0,0:26:29.23,0:26:32.03,Main-207+,,0,0,0,,さっきから足元がフラフラしてるぞ
Dialogue: 0,0:26:32.03,0:26:33.66,Main-207+,,0,0,0,,血を流しすぎたんだろ
Dialogue: 0,0:26:34.91,0:26:39.12,Main-207+,,0,0,0,,ちょっとうまく力が出ねえ\N肉でもあれば…
Dialogue: 0,0:26:39.58,0:26:40.95,Main-207+,,0,0,0,,急いでこっち
Dialogue: 0,0:26:43.58,0:26:44.58,Main-207+,,0,0,0,,待って！
Dialogue: 0,0:26:44.58,0:26:47.96,Main-207+,,0,0,0,,何もそんなとこ行かず\Nこの辺で食べたらいいじゃないか
Dialogue: 0,0:26:47.96,0:26:50.13,Main-207+,,0,0,0,,そうだよ！腹ペコなんだろ？
Dialogue: 0,0:26:50.13,0:26:51.76,Main-207+,,0,0,0,,あたしがそんなに食べるか！
Dialogue: 0,0:26:51.76,0:26:52.84,Main-207+,,0,0,0,,–　ええっ？\N–　ええっ？
Dialogue: 0,0:26:53.34,0:26:54.68,Main-207+,,0,0,0,,ごめん！遅くなった！
Dialogue: 0,0:26:54.68,0:26:55.51,Main-207+,,0,0,0,,ナミ
Dialogue: 0,0:26:55.51,0:26:57.89,Main-207+,,0,0,0,,おい！何やってんだお前！
Dialogue: 0,0:26:57.89,0:26:59.68,Main-207+,,0,0,0,,早く乗れ！バカ野郎！
Dialogue: 0,0:27:00.01,0:27:01.93,Main-207+,,0,0,0,,うわっ　すごい
Dialogue: 0,0:27:01.93,0:27:03.39,Main-207+,,0,0,0,,これが海列車？
Dialogue: 0,0:27:04.52,0:27:07.31,Main-207+,,0,0,0,,いやあ\Nこんな所にもう１隻あったとは
Dialogue: 0,0:27:07.31,0:27:08.57,Main-207+,,0,0,0,,驚いた
Dialogue: 0,0:27:08.90,0:27:10.53,Main-207+,,0,0,0,,どこ行ってたんだナミ
Dialogue: 0,0:27:10.53,0:27:12.36,Main-207+,,0,0,0,,時間がねえっつったの誰だよ
Dialogue: 0,0:27:13.11,0:27:14.45,Main-207+,,0,0,0,,その荷物何だ！
Dialogue: 0,0:27:14.45,0:27:15.66,Main-207+,,0,0,0,,お肉と飲み物
Dialogue: 0,0:27:15.66,0:27:17.87,Main-207+,,0,0,0,,文句言ってごめんなさい
Dialogue: 0,0:27:19.16,0:27:20.91,Main-207+,,0,0,0,,よいしょっと
Dialogue: 0,0:27:20.91,0:27:26.71,Main-207+,,0,0,0,,水路から海へ飛び出して\N線路さえつかめばいったんは成功だが…
Dialogue: 0,0:27:26.71,0:27:28.04,Main-207+,,0,0,0,,大丈夫ら
Dialogue: 0,0:27:28.04,0:27:31.17,Main-207+,,0,0,0,,操縦ならあたしのほうがベテランらよ
Dialogue: 0,0:27:31.17,0:27:33.92,Main-207+,,0,0,0,,おめえはここれゆっくり体休めてな
Dialogue: 0,0:27:34.38,0:27:35.38,Main-207+,,0,0,0,,面目ねえ
Dialogue: 0,0:27:35.38,0:27:38.47,Main-207+,,0,0,0,,チムニーたちがその辺で遊んでるはずらから
Dialogue: 0,0:27:38.47,0:27:40.18,Main-207+,,0,0,0,,世話頼んどくよ
Dialogue: 0,0:27:43.10,0:27:46.48,Main-207+,,0,0,0,,麦わらー！
Dialogue: 0,0:27:48.15,0:27:49.65,Main-207+,,0,0,0,,あいつら…
Dialogue: 0,0:27:50.52,0:27:52.03,Main-207+,,0,0,0,,フランキー一家！
Dialogue: 0,0:27:55.95,0:27:57.70,Main-207+,,0,0,0,,この忙しい時に
Dialogue: 0,0:27:58.78,0:28:00.03,Main-207+,,0,0,0,,頼む
Dialogue: 0,0:28:00.03,0:28:02.58,Main-207+,,0,0,0,,俺たちも連れてってくれ！
Dialogue: 0,0:28:02.58,0:28:07.00,Main-207+,,0,0,0,,おめえらがエニエス･ロビーへ行くって\Nガレーラのヤツらに聞いた
Dialogue: 0,0:28:07.83,0:28:11.09,Main-207+,,0,0,0,,フランキーのアニキが\N政府に連行されちまって…
Dialogue: 0,0:28:11.09,0:28:12.38,Main-207+,,0,0,0,,追いかけてえけど
Dialogue: 0,0:28:13.17,0:28:16.38,Main-207+,,0,0,0,,俺たちだけじゃアクア･ラグナを越えられねえ！
Dialogue: 0,0:28:16.38,0:28:18.97,Main-207+,,0,0,0,,相手は世界政府らよ
Dialogue: 0,0:28:19.34,0:28:21.51,Main-207+,,0,0,0,,誰だろうと構うもんか！
Dialogue: 0,0:28:21.51,0:28:23.35,Main-207+,,0,0,0,,アニキを取り返すんだ
Dialogue: 0,0:28:23.35,0:28:27.06,Main-207+,,0,0,0,,あたしらアニキのためなら命も惜しくないわいな！
Dialogue: 0,0:28:27.06,0:28:28.44,Main-207+,,0,0,0,,お願いだよ
Dialogue: 0,0:28:28.44,0:28:30.52,Main-207+,,0,0,0,,力を貸しとくれ
Dialogue: 0,0:28:30.52,0:28:32.40,Main-207+,,0,0,0,,麦わら！
Dialogue: 0,0:28:32.94,0:28:35.86,Main-207+,,0,0,0,,頼む　アニキの一大事なんだ
Dialogue: 0,0:28:36.24,0:28:38.11,Main-207+,,0,0,0,,冗談じゃないわ
Dialogue: 0,0:28:38.11,0:28:41.45,Main-207+,,0,0,0,,あんたたちが今まで\N何をしてきたか分かってんの？
Dialogue: 0,0:28:47.83,0:28:49.46,Main-207+,,0,0,0,,分かってる
Dialogue: 0,0:28:50.83,0:28:53.09,Main-207+,,0,0,0,,恥を忍んで頼んでる
Dialogue: 0,0:28:54.00,0:28:56.76,Main-207+,,0,0,0,,アニキを助けてえんだ！
Dialogue: 0,0:29:11.02,0:29:11.98,Main-207+,,0,0,0,,乗れ
Dialogue: 0,0:29:12.44,0:29:13.44,Main-207+,,0,0,0,,急げ！
Dialogue: 0,0:29:17.99,0:29:19.95,Main-207+,,0,0,0,,麦わら…
Dialogue: 0,0:29:20.49,0:29:22.37,Main-207+,,0,0,0,,ちょっとルフィ！
Dialogue: 0,0:29:23.45,0:29:24.95,Main-207+,,0,0,0,,まあ　いいよ
Dialogue: 0,0:29:25.49,0:29:26.91,Main-207+,,0,0,0,,すまねえ！
Dialogue: 0,0:29:27.91,0:29:30.12,Main-207+,,0,0,0,,恩に着る
Dialogue: 0,0:29:30.46,0:29:31.62,Main-207+,,0,0,0,,早くしろ
Dialogue: 0,0:29:32.96,0:29:34.75,Main-207+,,0,0,0,,でもその車両じゃなくていいんだ
Dialogue: 0,0:29:36.59,0:29:40.97,Main-207+,,0,0,0,,俺たちはおめえらに合わせて\Nキングブルで海に飛び出すからよ
Dialogue: 0,0:29:40.97,0:29:43.55,Main-207+,,0,0,0,,車両の後ろにつかまらせてくれればいいんだ
Dialogue: 0,0:29:44.22,0:29:45.72,Main-207+,,0,0,0,,キングブル？
Dialogue: 0,0:29:45.72,0:29:47.27,Main-207+,,0,0,0,,よろしく頼む
Dialogue: 0,0:29:47.27,0:29:48.89,Main-207+,,0,0,0,,じゃあ後で！
Dialogue: 0,0:29:49.77,0:29:51.27,Main-207+,,0,0,0,,行くぞ！
Dialogue: 0,0:29:51.27,0:29:53.73,Main-207+,,0,0,0,,–　おおー！\N–　おおー！
Dialogue: 0,0:30:00.11,0:30:04.45,Main-207+,,0,0,0,,やった～！\Nアニキを救出に行けるぞ！
Comment: 0,0:30:04.45,0:30:06.45,Secondary-207+,,0,0,0,,{\an8}–　おお～っ！\N–　おお～っ！
Dialogue: 0,0:30:04.45,0:30:06.45,Main-207+,,0,0,0,,急げ！
Dialogue: 0,0:30:14.54,0:30:15.21,Main-207+,,0,0,0,,どう？
Dialogue: 0,0:30:17.92,0:30:18.50,Main-207+,,0,0,0,,よし
Dialogue: 0,0:30:19.13,0:30:20.51,Main-207+,,0,0,0,,ほいじゃ行こうか
Dialogue: 0,0:30:58.17,0:31:00.88,Main-207+,,0,0,0,,さあ海賊ども
Dialogue: 0,0:31:00.88,0:31:03.38,Main-207+,,0,0,0,,振り落とされんじゃらいよ！
Dialogue: 0,0:31:15.35,0:31:18.86,Main-207+,,0,0,0,,ウォーターセブン発エニエス･ロビー行き
Dialogue: 0,0:31:18.86,0:31:22.90,Main-207+,,0,0,0,,海列車　ロケットマン！
Dialogue: 0,0:31:26.03,0:31:29.37,Main-207+,,0,0,0,,よーし！出航！
Dialogue: 0,0:31:32.25,0:31:33.29,Main-207+,,0,0,0,,行くぞ！
Dialogue: 0,0:31:34.12,0:31:38.38,Main-207+,,0,0,0,,全部奪い返しにー！
Comment: 0,0:00:00.00,0:00:00.00,Main-207+,,0,0,0,,{=9}===============================DIALOGUE============================
