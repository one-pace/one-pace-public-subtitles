Comment: 0,0:00:00.00,0:00:00.00,Main-207-,,0,0,0,,{=131}===============================DIALOGUE============================
Dialogue: 0,0:01:54.04,0:01:57.72,Main-207-,,0,0,0,,{\q2}Bene, bene, se non vi sbrigherete, la barca \Nproseguirà nella Foresta dello Smarrimento!{cps}
Dialogue: 0,0:01:57.72,0:01:58.64,Main-207-,,0,0,0,,Ehi!
Dialogue: 0,0:01:58.64,0:02:02.10,Main-207-,,0,0,0,,Se non seguiamo la barca, \Nla perderemo di vista!
Dialogue: 0,0:02:03.52,0:02:06.69,Main-207-,,0,0,0,,Se la perdessimo in questa foresta, \Nritrovarla sarebbe un'impresa!
Dialogue: 0,0:02:06.69,0:02:07.94,Main-207-,,0,0,0,,Aspetta, Usopp!
Dialogue: 0,0:02:07.94,0:02:10.07,Main-207-,,0,0,0,,{\q2}Vale lo stesso anche se ci dividessimo!
Dialogue: 0,0:02:10.07,0:02:11.57,Main-207-,,0,0,0,,Luffy! E tu?
Dialogue: 0,0:02:11.57,0:02:13.49,Main-207-,,0,0,0,,Voi fermate la barca!
Dialogue: 0,0:02:13.82,0:02:16.07,Main-207-,,0,0,0,,Metterò fuori gioco quel tizio a palla!{non lo dice "io" weirdly enough}
Dialogue: 0,0:02:17.08,0:02:18.24,Main-207-,,0,0,0,,Provaci pure~!
Dialogue: 0,0:02:18.24,0:02:21.20,Main-207-,,0,0,0,,Sono guidato dalla \Nbeatitudine e dall'orgoglio!
Dialogue: 0,0:02:22.41,0:02:26.25,Thoughts-207-,,0,0,0,,{\q2\an8\fs70}Nota: I daruma sono bambole \Nrotondeggianti senza gambe e braccia.
Dialogue: 0,0:02:22.41,0:02:26.25,Thoughts-207-,,0,0,0,,Comunque sia, serve qualcuno che \Nsi occupi di quel daruma...
Dialogue: 0,0:02:26.67,0:02:28.17,Main-207-,,0,0,0,,Non esagerare!{della serie, non so mettervela meglio... tipo non strafare? non so }
Dialogue: 0,0:02:28.17,0:02:30.00,Main-207-,,0,0,0,,Usa un potere strano!
Dialogue: 0,0:02:30.00,0:02:32.22,Main-207-,,0,0,0,,{\q2}Una volta fermata la barca, tornerò indietro!
Dialogue: 0,0:02:31.34,0:02:32.22,Secondary-207-,,0,0,0,,Ok!
Dialogue: 0,0:02:34.26,0:02:36.76,Main-207-,,0,0,0,,Non muoverti da lì, palla!
Dialogue: 0,0:02:38.68,0:02:40.26,Main-207-,,0,0,0,,Dopo aver afferrato il ramo...
Dialogue: 0,0:02:43.73,0:02:46.40,Main-207-,,0,0,0,,{\fad(150,150)}Gum Gum...
Dialogue: 0,0:02:46.40,0:02:47.94,Main-207-,,0,0,0,,lo stesso attacco di prima?
Dialogue: 0,0:02:47.94,0:02:49.86,Main-207-,,0,0,0,,{\fad(150,150)}Pistol!
Dialogue: 0,0:02:50.65,0:02:51.48,Main-207-,,0,0,0,,Swish!{hirari è una sorta di onomatopea, indica un movimento leggiadro}
Dialogue: 0,0:03:07.96,0:03:09.21,Main-207-,,0,0,0,,Senza fretta...
Dialogue: 0,0:03:09.21,0:03:11.50,Main-207-,,0,0,0,,puoi prendertela comoda.
Dialogue: 0,0:03:28.48,0:03:31.69,Main-207-,,0,0,0,,{\q2}Bene, dove saranno andati gli altri due?
Dialogue: 0,0:03:32.11,0:03:35.15,Main-207-,,0,0,0,,{\q2}Non me ne lascerò scappare nemmeno uno.
Dialogue: 0,0:03:38.03,0:03:39.28,Main-207-,,0,0,0,,Eccolo, eccolo!
Dialogue: 0,0:03:41.45,0:03:43.83,Main-207-,,0,0,0,,Ehi! La vedi, Usopp?!
Dialogue: 0,0:03:52.34,0:03:53.21,Main-207-,,0,0,0,,Eccola!
Dialogue: 0,0:03:53.21,0:03:54.63,Main-207-,,0,0,0,,Dammi delle istruzioni!{ordini mi pare brutto}
Dialogue: 0,0:03:54.63,0:03:55.80,Main-207-,,0,0,0,,Davanti a te!
Dialogue: 0,0:03:55.80,0:03:58.63,Main-207-,,0,0,0,,Scala l'albero successivo al prossimo!
Dialogue: 0,0:03:58.63,0:04:00.72,Main-207-,,0,0,0,,Puoi saltare sulla nave dal ramo!
Dialogue: 0,0:04:00.72,0:04:01.89,Main-207-,,0,0,0,,Ho capito!
Dialogue: 0,0:04:17.61,0:04:19.32,Main-207-,,0,0,0,,Woah! È lui!
Dialogue: 0,0:04:19.32,0:04:21.03,Main-207-,,0,0,0,,Che intenzioni ha?!
Dialogue: 0,0:04:21.78,0:04:23.28,Main-207-,,0,0,0,,Vai!
Dialogue: 0,0:04:24.20,0:04:25.20,Main-207-,,0,0,0,,Attento, Sanji!
Dialogue: 0,0:04:25.20,0:04:27.08,Main-207-,,0,0,0,,Una palla sta venendo per di là!
Dialogue: 0,0:04:27.08,0:04:29.50,Main-207-,,0,0,0,,Cosa?! Ma che sta facendo Luffy?!
Dialogue: 0,0:04:39.51,0:04:42.05,Main-207-,,0,0,0,,{\fad(150,150)}Biliardo a Sorpresa!{ew G - abilità [Satori]}
Dialogue: 0,0:04:45.35,0:04:46.64,Main-207-,,0,0,0,,Usopp!
Dialogue: 0,0:04:47.81,0:04:50.56,Thoughts-207-,,0,0,0,,Il bersaglio ero {\i1}io{\i0}!
Dialogue: 0,0:04:53.73,0:04:55.53,Thoughts-207-,,0,0,0,,{\t(439,0,1,\c&HFFFFFF&\3c&HFFFFFF&\4c&HFFFFFF&)}Un esplosione...
Dialogue: 0,0:04:56.82,0:04:58.36,Thoughts-207-,,0,0,0,,No, ma come "pon"?!
Dialogue: 0,0:05:00.24,0:05:01.49,Main-207-,,0,0,0,,Quella sbagliata, eh?
Dialogue: 0,0:05:07.37,0:05:08.66,Main-207-,,0,0,0,,Cretino!
Dialogue: 0,0:05:10.96,0:05:13.50,Main-207-,,0,0,0,,Brutto bastardo!
Dialogue: 0,0:05:14.75,0:05:16.67,Main-207-,,0,0,0,,{\fad(150,150)}Gum Gum...
Dialogue: 0,0:05:16.67,0:05:19.26,Main-207-,,0,0,0,,{\fad(150,150)}Gatling!
Dialogue: 0,0:05:26.26,0:05:27.43,Main-207-,,0,0,0,,Smettila, Luffy!
Dialogue: 0,0:05:27.43,0:05:29.89,Main-207-,,0,0,0,,Non sparare a caso le palle lì intorno!
Dialogue: 0,0:05:33.77,0:05:36.36,Main-207-,,0,0,0,,Cosa?! Cosa?! Cosa?!
Dialogue: 0,0:05:36.36,0:05:37.86,Main-207-,,0,0,0,,Oh no!
Dialogue: 0,0:05:37.86,0:05:40.19,Main-207-,,0,0,0,,È troppo tardi!
Dialogue: 0,0:05:40.19,0:05:41.53,Main-207-,,0,0,0,,Sta' attento!
Dialogue: 0,0:05:41.53,0:05:43.53,Main-207-,,0,0,0,,Arrivano da tutte le parti!{direzioni}
Dialogue: 0,0:05:45.53,0:05:47.79,Main-207-,,0,0,0,,Siete proprio divertenti voialtri!{interessanti}
Dialogue: 0,0:05:56.21,0:05:56.96,Main-207-,,0,0,0,,Delle lance!
Dialogue: 0,0:05:56.96,0:05:57.71,Main-207-,,0,0,0,,Un granchio!
Dialogue: 0,0:06:02.26,0:06:03.63,Main-207-,,0,0,0,,Quattro nello stesso momento?!
Dialogue: 0,0:06:13.64,0:06:14.52,Main-207-,,0,0,0,,Ma cosa?!
Dialogue: 0,0:06:14.52,0:06:16.48,Main-207-,,0,0,0,,Altre sbagliate?
Dialogue: 0,0:06:23.24,0:06:24.70,Main-207-,,0,0,0,,Scotta!
Dialogue: 0,0:06:24.70,0:06:26.82,Main-207-,,0,0,0,,Scotta, scotta, scotta, scotta, scotta!
Dialogue: 0,0:06:27.37,0:06:28.78,Main-207-,,0,0,0,,Acqua!
Dialogue: 0,0:06:28.78,0:06:29.79,Main-207-,,0,0,0,,Acqua, acqua, acqua!
Dialogue: 0,0:06:29.79,0:06:31.20,Main-207-,,0,0,0,,Scotta! Scotta, scotta!
Dialogue: 0,0:06:31.20,0:06:33.58,Main-207-,,0,0,0,,Scotta, scotta, scotta, scotta, scotta!
Dialogue: 0,0:06:33.58,0:06:36.08,Main-207-,,0,0,0,,Il fiume!
Dialogue: 0,0:06:39.09,0:06:42.34,Main-207-,,0,0,0,,Ahia!
Dialogue: 0,0:06:50.47,0:06:51.93,Main-207-,,0,0,0,,Ne sono uscito!
Dialogue: 0,0:06:53.14,0:06:54.02,Main-207-,,0,0,0,,Luffy!
Dialogue: 0,0:06:54.02,0:06:55.52,Main-207-,,0,0,0,,Non cadere nel fiume di sotto!
Dialogue: 0,0:06:55.52,0:06:57.15,Main-207-,,0,0,0,,Potrebbe non avere un fondo!
Dialogue: 0,0:06:57.15,0:06:58.02,Main-207-,,0,0,0,,Eh?!
Dialogue: 0,0:07:08.99,0:07:10.12,Main-207-,,0,0,0,,Che rischio!
Dialogue: 0,0:07:24.34,0:07:26.18,Main-207-,,0,0,0,,Ma sei un cretino o cosa?!
Dialogue: 0,0:07:26.18,0:07:27.55,Main-207-,,0,0,0,,{\fad(150,150)}Usopp Hammer!
Dialogue: 0,0:07:27.55,0:07:28.64,Main-207-,,0,0,0,,{\fad(150,150)}Usopp Hammer!
Dialogue: 0,0:07:28.64,0:07:29.89,Main-207-,,0,0,0,,{\fad(150,150)}Usopp Hammer!
Dialogue: 0,0:07:29.89,0:07:30.68,Main-207-,,0,0,0,,{\fad(150,150)}Elastico~!
Dialogue: 0,0:07:30.68,0:07:32.14,Main-207-,,0,0,0,,{\fad(150,150)}Usopp Hammer!
Dialogue: 0,0:07:38.56,0:07:40.56,Main-207-,,0,0,0,,Yahoo!
Dialogue: 0,0:07:42.94,0:07:44.49,Main-207-,,0,0,0,,Yahoo!
Dialogue: 0,0:07:46.03,0:07:48.41,Main-207-,,0,0,0,,Ah giusto! C'era anche quel modo!
Dialogue: 0,0:07:48.41,0:07:50.70,Main-207-,,0,0,0,,È il momento di testarlo!
Dialogue: 0,0:07:55.12,0:07:57.42,Main-207-,,0,0,0,,Non puoi fare proprio niente, Usopp?
Dialogue: 0,0:08:01.29,0:08:02.55,Main-207-,,0,0,0,,Certo che posso.
Dialogue: 0,0:08:02.55,0:08:06.38,Main-207-,,0,0,0,,La gente mi chiama \N"il più grande inventore tra i pirati".
Dialogue: 0,0:08:06.76,0:08:09.34,Main-207-,,0,0,0,,Vi mostrerò la mia nuova arma!{ore-sama}
Dialogue: 0,0:08:10.47,0:08:12.14,Main-207-,,0,0,0,,{\fad(150,150)}Usopp...
Dialogue: 0,0:08:12.14,0:08:14.85,Main-207-,,0,0,0,,{\fad(150,150)}Ah aah~!
Dialogue: 0,0:08:15.27,0:08:16.35,Main-207-,,0,0,0,,Ma che sarebbe?
Dialogue: 0,0:08:16.35,0:08:18.10,Main-207-,,0,0,0,,Beh, sta a guardare!
Dialogue: 0,0:08:20.19,0:08:21.31,Main-207-,,0,0,0,,Eccola!
Dialogue: 0,0:08:21.31,0:08:23.44,Main-207-,,0,0,0,,Proprio nel fiume qui davanti!
Dialogue: 0,0:08:24.15,0:08:25.69,Main-207-,,0,0,0,,Posso farcela!
Dialogue: 0,0:08:26.11,0:08:27.07,Main-207-,,0,0,0,,{\fad(150,150)}Set up!{che up è fuori timing for whatever reason}
Dialogue: 0,0:08:38.41,0:08:40.21,Main-207-,,0,0,0,,Che vuole fare?
Dialogue: 0,0:08:44.55,0:08:45.42,Main-207-,,0,0,0,,Bene!
Dialogue: 0,0:08:45.42,0:08:48.01,Main-207-,,0,0,0,,Con questo arriverò diretto \Nalla Karasumaru!
Dialogue: 0,0:08:48.42,0:08:51.64,Main-207-,,0,0,0,,Se proseguisse oltre dentro alla \Nforesta, sarà impossibile raggiungerla.{cps}
Dialogue: 0,0:08:51.64,0:08:53.97,Main-207-,,0,0,0,,Non posso lasciarmela sfuggire!
Dialogue: 0,0:08:54.86,0:08:55.47,Main-207-,,0,0,0,,Eeh...
Dialogue: 0,0:08:55.47,0:08:56.85,Main-207-,,0,0,0,,Ma quindi ci sai fare!
Dialogue: 0,0:08:56.85,0:08:58.56,Main-207-,,0,0,0,,Attento alle palle!{che suona malissimo, intende ovviamente quelle della sfida}
Dialogue: 0,0:08:58.56,0:09:00.60,Main-207-,,0,0,0,,Non farò una cavolata del genere!{nel senso che non si farò colpire...}
Dialogue: 0,0:09:00.60,0:09:03.98,Main-207-,,0,0,0,,Chiamami "il re della giungla"!
Dialogue: 0,0:09:03.98,0:09:05.15,Main-207-,,0,0,0,,Vado!
Dialogue: 0,0:09:05.15,0:09:06.61,Main-207-,,0,0,0,,{\fad(150,150)}Usopp...
Dialogue: 0,0:09:07.15,0:09:12.11,Main-207-,,0,0,0,,{\fad(150,150)}Ah aah aah~!
Dialogue: 0,0:09:21.33,0:09:23.75,Main-207-,,0,0,0,,Che succede?! Sbrigati a salirci sopra!{alla barca ovviamente, non lo dice}
Dialogue: 0,0:09:24.13,0:09:25.00,Main-207-,,0,0,0,,No...
Dialogue: 0,0:09:25.42,0:09:27.13,Main-207-,,0,0,0,,Ecco vedi...
Dialogue: 0,0:09:27.13,0:09:29.59,Main-207-,,0,0,0,,Me n'ero dimenticato, ma...
Dialogue: 0,0:09:29.59,0:09:35.60,Main-207-,,0,0,0,,La corda è fissata alla cintura, \Nquindi non posso scendere da qui!
Dialogue: 0,0:09:41.64,0:09:43.48,Main-207-,,0,0,0,,Maledizione, maledizione, maledizione!{ne direbbe  molti di più, ma cps}
Dialogue: 0,0:09:43.48,0:09:46.27,Main-207-,,0,0,0,,Ah... lo prendo... ah... \Nlo prendo... aah...
Dialogue: 0,0:09:57.79,0:09:58.91,Main-207-,,0,0,0,,Yahoo!
Dialogue: 0,0:09:58.91,0:10:00.16,Main-207-,,0,0,0,,Yo, Usopp!
Dialogue: 0,0:10:00.16,0:10:01.91,Main-207-,,0,0,0,,Sembri divertirti anche tu, eh?!
Comment: 0,0:10:01.91,0:10:04.75,Main-207-,,0,0,0,,Ah aah aah~!
Dialogue: 0,0:10:05.50,0:10:08.25,Main-207-,,0,0,0,,Voialtri... devo parlarvi un attimo...
Dialogue: 0,0:10:19.14,0:10:20.72,Main-207-,,0,0,0,,Avete capito?
Dialogue: 0,0:10:20.72,0:10:24.90,Main-207-,,0,0,0,,Dimenticherò ciò che è appena \Nsuccesso, perciò statemi a sentire.
Dialogue: 0,0:10:24.90,0:10:26.90,Main-207-,,0,0,0,,Sì, scusa...
Dialogue: 0,0:10:26.90,0:10:28.82,Main-207-,,0,0,0,,Mi dispiace...
Dialogue: 0,0:10:28.82,0:10:32.82,Main-207-,,0,0,0,,{\q2}Per il momento, non pensate alla barca.
Dialogue: 0,0:10:33.45,0:10:36.53,Main-207-,,0,0,0,,Attaccheremo quel tizio tutti e tre.
Dialogue: 0,0:10:37.53,0:10:39.79,Main-207-,,0,0,0,,Che sia un sacerdote o meno,
Dialogue: 0,0:10:39.79,0:10:43.33,Main-207-,,0,0,0,,{\q2}attaccandolo tutti insieme, sicuramente \Ntroveremo un'apertura per batterlo.
Dialogue: 0,0:10:43.33,0:10:45.50,Main-207-,,0,0,0,,Battermi?
Dialogue: 0,0:10:53.09,0:10:54.80,Main-207-,,0,0,0,,Dov'è andato quel maledetto?
Dialogue: 0,0:11:09.11,0:11:10.19,Main-207-,,0,0,0,,{\fad(150,150)}Impact!
Dialogue: 0,0:11:13.99,0:11:14.90,Main-207-,,0,0,0,,{\pos(388,1052)}Sanji!
Dialogue: 0,0:11:13.99,0:11:14.90,Main-207-,,0,0,0,,{\pos(1118,1052)}Sanji!
Dialogue: 0,0:11:24.79,0:11:26.92,Main-207-,,0,0,0,,La vita è sofferenza...
Dialogue: 0,0:11:27.75,0:11:28.83,Main-207-,,0,0,0,,Bene.
Dialogue: 0,0:11:28.83,0:11:30.38,Main-207-,,0,0,0,,Ancora due~!
Dialogue: 0,0:11:33.38,0:11:34.88,Main-207-,,0,0,0,,B-Bene...
Dialogue: 0,0:11:34.88,0:11:37.01,Main-207-,,0,0,0,,{\t(1983,0,1,\c&HFFFFFF&\3c&HFFFFFF&\4c&HFFFFFF&)}Per fortuna che c'è questo...
Dialogue: 0,0:11:37.47,0:11:38.34,Flashbacks-207-,,0,0,0,,Statemi a sentire.
Dialogue: 0,0:11:38.34,0:11:40.97,Flashbacks-207-,,0,0,0,,Questo whistle lo tengo io.
Dialogue: 0,0:11:40.97,0:11:42.93,Flashbacks-207-,,0,0,0,,Qualcuno ha da obiettare?
Dialogue: 0,0:11:42.93,0:11:44.14,Flashbacks-207-,,0,0,0,,– Sì!\N– Sì!
Dialogue: 0,0:11:44.14,0:11:45.39,Flashbacks-207-,,0,0,0,,Sì! Sì!
Dialogue: 0,0:11:45.39,0:11:47.56,Flashbacks-207-,,0,0,0,,Ma che state dicendo?!
Dialogue: 0,0:11:47.56,0:11:50.15,Flashbacks-207-,,0,0,0,,{\q2}Sono la ragazza più fragile in assoluto!
Dialogue: 0,0:11:50.15,0:11:52.65,Flashbacks-207-,,0,0,0,,Questo fischietto lo devo tenere io!
Dialogue: 0,0:11:52.65,0:11:53.86,Flashbacks-207-,,0,0,0,,Voglio fischiarci!
Dialogue: 0,0:11:53.86,0:11:58.61,Flashbacks-207-,,0,0,0,,Luffy! Tu vuoi solo farlo \Nfischiare, no?! Togliti di torno!
Dialogue: 0,0:11:58.61,0:12:01.66,Flashbacks-207-,,0,0,0,,{\q2}Ma io voglio chiamare il vecchio adesso!
Dialogue: 0,0:12:01.66,0:12:03.12,Flashbacks-207-,,0,0,0,,Lasciamelo tenere!
Dialogue: 0,0:12:03.12,0:12:04.87,Flashbacks-207-,,0,0,0,,Sono io il più debole!{doubtful tbh}
Dialogue: 0,0:12:04.87,0:12:08.00,Flashbacks-207-,,0,0,0,,Non dire idiozie! \NSono io il più debole di tutti!
Dialogue: 0,0:12:08.00,0:12:09.88,Flashbacks-207-,,0,0,0,,Ma che dite?! Non prendetemi in giro!
Dialogue: 0,0:12:09.88,0:12:12.13,Flashbacks-207-,,0,0,0,,È ovvio che sia io la più debole, no?!
Dialogue: 0,0:12:12.13,0:12:14.38,Flashbacks-207-,,0,0,0,,Ti sbagli! Il più debole sono io!
Dialogue: 0,0:12:14.38,0:12:18.26,Flashbacks-207-,,0,0,0,,Voi due! Non sottovalutate \Nla mia totale incapacità!
Dialogue: 0,0:12:18.26,0:12:19.97,Flashbacks-207-,,0,0,0,,Voglio fischiarci! \NIo voglio fischiarci!
Dialogue: 0,0:12:19.97,0:12:22.35,Flashbacks-207-,,0,0,0,,Che litigio strano che fate.
Dialogue: 0,0:12:19.97,0:12:22.35,FlashbacksSecondary-207-,,0,0,0,,Voglio fischiarci!
Dialogue: 0,0:12:25.98,0:12:27.81,Flashbacks-207-,,0,0,0,,Allora facciamo così.
Dialogue: 0,0:12:27.81,0:12:29.23,Flashbacks-207-,,0,0,0,,Al centro della nave.
Dialogue: 0,0:12:29.23,0:12:31.36,Flashbacks-207-,,0,0,0,,Lo lascerò appeso all'albero principale,
Dialogue: 0,0:12:31.36,0:12:35.19,Flashbacks-207-,,0,0,0,,perciò lo userà chi è \Nsi troverà in difficoltà.
Dialogue: 0,0:12:35.53,0:12:36.82,Flashbacks-207-,,0,0,0,,Così siamo pari.
Dialogue: 0,0:12:36.82,0:12:37.57,Flashbacks-207-,,0,0,0,,Bene.
Dialogue: 0,0:12:37.57,0:12:38.61,Flashbacks-207-,,0,0,0,,Ho capito.
Dialogue: 0,0:12:39.32,0:12:40.66,Flashbacks-207-,,0,0,0,,Ah, e poi...
Dialogue: 0,0:12:41.12,0:12:44.08,Flashbacks-207-,,0,0,0,,Voi non avete alcun diritto di usarlo.
Dialogue: 0,0:12:44.08,0:12:46.66,Flashbacks-207-,,0,0,0,,Tsk... Ma voglio chiamare il vecchio...
Dialogue: 0,0:12:46.66,0:12:49.79,Flashbacks-207-,,0,0,0,,Se lo usaste, vi spedirò a calci \Nfino ai confini del mondo!
Dialogue: 0,0:12:49.79,0:12:51.63,Flashbacks-207-,,0,0,0,,– Ho capito, starò attento.\N– Ho capito, starò attento.
Dialogue: 0,0:12:54.00,0:12:58.09,Main-207-,,0,0,0,,Con questo, se qualcosa succedesse, \Nil cavaliere del cielo verrà a salvarmi.
Dialogue: 0,0:12:58.09,0:13:01.68,Main-207-,,0,0,0,,{\q2}Però... usare il whistle sarà l'ultima spiaggia...
Dialogue: 0,0:13:02.22,0:13:03.55,Main-207-,,0,0,0,,Bene!
Dialogue: 0,0:13:03.55,0:13:06.85,Main-207-,,0,0,0,,Darò del mio meglio \Ncome guardia della nave!
Dialogue: 0,0:13:18.24,0:13:19.57,Main-207-,,0,0,0,,E quello...?
Dialogue: 0,0:13:32.29,0:13:33.54,Main-207-,,0,0,0,,Ma come?
Dialogue: 0,0:13:33.54,0:13:36.46,Main-207-,,0,0,0,,Sei tu l'unico sacrificio che\N posso uccidere?
Dialogue: 0,0:13:55.94,0:13:59.86,Main-207-,,0,0,0,,Quest'anno il raccolto \Ndelle zucche è ottimo.
Dialogue: 0,0:14:00.36,0:14:01.49,Main-207-,,0,0,0,,Sì...
Dialogue: 0,0:14:02.11,0:14:05.32,Main-207-,,0,0,0,,Come potrei mai ringraziarla?
Dialogue: 0,0:14:05.74,0:14:07.08,Main-207-,,0,0,0,,Mi scusi...
Dialogue: 0,0:14:07.08,0:14:10.12,Main-207-,,0,0,0,,per averle causato problemi.
Dialogue: 0,0:14:10.12,0:14:15.33,Main-207-,,0,0,0,,Se tua figlia ha aiutato quei \NCappello di Paglia a fuggire...
Dialogue: 0,0:14:15.33,0:14:18.17,Main-207-,,0,0,0,,{\q2}anche tu sarai considerato un complice.
Dialogue: 0,0:14:18.17,0:14:19.80,Main-207-,,0,0,0,,Sei in pericolo.
Dialogue: 0,0:14:20.71,0:14:22.84,Main-207-,,0,0,0,,Questo è un servizio.
Dialogue: 0,0:14:23.43,0:14:27.60,Main-207-,,0,0,0,,Il mantra di Enel non \Npotrà raggiungerci qui.
Dialogue: 0,0:14:31.73,0:14:33.89,Main-207-,,0,0,0,,Come vanno le cose all'Isola Angel?
Dialogue: 0,0:14:33.89,0:14:35.10,Main-207-,,0,0,0,,Come?
Dialogue: 0,0:14:35.60,0:14:37.02,Main-207-,,0,0,0,,Il raccolto.
Dialogue: 0,0:14:37.02,0:14:38.98,Main-207-,,0,0,0,,Com'è andato quest'anno?
Dialogue: 0,0:14:38.98,0:14:41.57,Main-207-,,0,0,0,,Oh, pare prosegua bene.
Dialogue: 0,0:14:41.57,0:14:43.07,Main-207-,,0,0,0,,Capisco.
Dialogue: 0,0:14:43.57,0:14:44.70,Main-207-,,0,0,0,,Ne sono lieto.
Dialogue: 0,0:14:45.45,0:14:49.58,Main-207-,,0,0,0,,Quello è succo di zucca del mio orto.{che poi, ho di recente scoperto che per i jp le bibite sono "succo" T_T}
Dialogue: 0,0:14:49.58,0:14:51.04,Main-207-,,0,0,0,,È delizioso.
Dialogue: 0,0:14:51.04,0:14:52.04,Main-207-,,0,0,0,,Certo.
Dialogue: 0,0:14:52.04,0:14:54.29,Main-207-,,0,0,0,,Mi scusi, lo prendo volentieri.
Dialogue: 0,0:14:55.17,0:14:56.42,Main-207-,,0,0,0,,Signora Conis.{non mi ricordo cosa avevo fatto, conis-san}
Dialogue: 0,0:14:56.42,0:14:58.25,Main-207-,,0,0,0,,Prendine anche tu, signora Conis.
Dialogue: 0,0:15:05.51,0:15:06.93,Main-207-,,0,0,0,,Figliola.
Dialogue: 0,0:15:06.93,0:15:11.81,Main-207-,,0,0,0,,Sai che nel Mare Blu ci sono \Ndelle persone dette "pirati"?
Dialogue: 0,0:15:12.47,0:15:13.39,Main-207-,,0,0,0,,No...
Dialogue: 0,0:15:13.85,0:15:17.06,Main-207-,,0,0,0,,{\q2}Sono dei criminali che viaggiano per mare.
Dialogue: 0,0:15:17.90,0:15:25.03,Main-207-,,0,0,0,,{\q2}Ce ne sono di vario tipo, ma tutte le loro navi\Nespongono una bandiera nera con un teschio.
Dialogue: 0,0:15:28.24,0:15:32.54,Main-207-,,0,0,0,,Probabilmente anche quei\N Cappello di Paglia lo sono.
Dialogue: 0,0:15:33.12,0:15:34.37,Main-207-,,0,0,0,,C-Cosa?!
Dialogue: 0,0:15:34.37,0:15:37.46,Main-207-,,0,0,0,,Sta dicendo che erano \Ncriminali sin dal principio?!
Dialogue: 0,0:15:38.54,0:15:39.79,Main-207-,,0,0,0,,Beh...
Dialogue: 0,0:15:39.79,0:15:43.38,Main-207-,,0,0,0,,probabilmente sono "fuori dalla \Nnorma" nel Mare Blu.{è inteso come "fuorilegge" immagino...}
Dialogue: 0,0:15:43.38,0:15:47.47,Main-207-,,0,0,0,,In qualunque mondo, ci sono persone \Nche esulano dalle norme.
Dialogue: 0,0:15:47.47,0:15:50.47,Main-207-,,0,0,0,,Dove differiscono da voi?
Dialogue: 0,0:15:52.56,0:15:54.39,Main-207-,,0,0,0,,Chi può affermare che...
Dialogue: 0,0:15:54.39,0:15:58.94,Main-207-,,0,0,0,,il mondo sia giusto e che chi \Nva controcorrente ha torto?
Dialogue: 0,0:15:58.94,0:16:00.86,Main-207-,,0,0,0,,Può capitare.{????????????????}
Dialogue: 0,0:16:01.77,0:16:03.32,Main-207-,,0,0,0,,Portando un esempio estremo...
Dialogue: 0,0:16:03.65,0:16:09.66,Main-207-,,0,0,0,,{\q2}uno che sarebbe detto eroe in tempi di guerra, \Nnell'era sbagliata non è altro che un assassino.
Dialogue: 0,0:16:10.62,0:16:13.99,Main-207-,,0,0,0,,Anch'io posseggo un amico tra i pirati.
Dialogue: 0,0:16:15.04,0:16:20.63,Main-207-,,0,0,0,,Venne qui oltre vent'anni fa, quando \Noccupavo ancora il trono di Dio.
Dialogue: 0,0:16:20.63,0:16:21.46,Main-207-,,0,0,0,,Era davvero...
Dialogue: 0,0:16:21.96,0:16:25.51,Main-207-,,0,0,0,,un tipo splendido e piacevole.{豪快 vi invito a cercarlo, il numero di traduzioni diverse che ha sto termine...}
Dialogue: 0,0:16:25.51,0:16:27.93,Main-207-,,0,0,0,,Mi dispiacque quando se ne andò.{circa}
Dialogue: 0,0:16:28.72,0:16:34.56,Main-207-,,0,0,0,,{\q2}Anche se ad un primo sguardo può non sembrare,\N Skypiea è un Paese in cui le battaglie non terminano mai.{non ci sta sullo schermo}
Dialogue: 0,0:16:35.72,0:16:37.98,Main-207-,,0,0,0,,Tra noi del cielo...
Dialogue: 0,0:16:38.56,0:16:44.15,Main-207-,,0,0,0,,{\q2}e gli Shandia detti guerriglieri. \NUn Paese di lunghi combattimenti interminabili.{G - varie}
Dialogue: 0,0:16:44.15,0:16:49.36,Main-207-,,0,0,0,,Gli Shandia continuano \Ntuttora a sfidare Enel.
Dialogue: 0,0:16:49.74,0:16:54.99,Main-207-,,0,0,0,,Quando lei era Dio, il suo tentativo di \Nconvivenza con gli Shandia
Dialogue: 0,0:16:54.99,0:17:00.83,Main-207-,,0,0,0,,{\q2}fu una speranza di pace che avrebbe posto \Nfine alla guerra durata centinaia di anni...
Dialogue: 0,0:17:01.21,0:17:02.38,Main-207-,,0,0,0,,Sì...{o solo "mnh"}
Dialogue: 0,0:17:02.38,0:17:08.67,Main-207-,,0,0,0,,Ad un passo dal traguardo, \NEnel rubò il mio trono di Dio.
Dialogue: 0,0:17:08.67,0:17:10.09,Main-207-,,0,0,0,,Sono spiacente.
Dialogue: 0,0:17:10.09,0:17:12.84,Main-207-,,0,0,0,,Fu così che tutto andò in fumo.
Dialogue: 0,0:17:12.84,0:17:15.97,Main-207-,,0,0,0,,C-Cosa dice?! \NNon c'è bisogno di scusarsi!
Dialogue: 0,0:17:19.14,0:17:24.65,Main-207-,,0,0,0,,A Skypiea circola da tempo \Nimmemore questa leggenda.{tempo immemore è un po' una mia interpretazione. dai tempi antichi cmq}
Dialogue: 0,0:17:25.07,0:17:27.90,Main-207-,,0,0,0,,{\c&H080905&\3c&H080905&\4c&H080905&\t(16,2018,1,\c&HFFFFFF&\3c&H000000&\4c&H000000&)}Molto tempo fa...
Dialogue: 0,0:17:27.90,0:17:31.15,Main-207-,,0,0,0,,nel giorno in cui il territorio sacro\N Upper Yard nacque...
Dialogue: 0,0:17:31.15,0:17:35.78,Main-207-,,0,0,0,,una splendida voce canora \Ndell'isola avvolse il Paese.
Dialogue: 0,0:17:36.29,0:17:41.87,Main-207-,,0,0,0,,{\q2}Fu allora che inizio la lotta tra \Ngli Shandia e gli abitanti del cielo.
Dialogue: 0,0:17:42.50,0:17:45.38,Main-207-,,0,0,0,,Proprio come se quello \Nfosse stato il segnale...
Dialogue: 0,0:17:45.79,0:17:54.05,Main-207-,,0,0,0,,{\q2}{PJ/Z - Skypiea 22 - 23:42}Per questo, quando sentiremo quella voce canora \Ndell'isola, questo combattimento terminerà.
Dialogue: 0,0:17:54.05,0:17:56.89,Main-207-,,0,0,0,,La voce canora dell'isola?
Dialogue: 0,0:17:56.89,0:17:58.02,Main-207-,,0,0,0,,Esatto.
Dialogue: 0,0:17:59.31,0:18:02.39,Main-207-,,0,0,0,,Il territorio sacro canterà di nuovo.
Dialogue: 0,0:18:04.31,0:18:06.02,Main-207-,,0,0,0,,Un giorno, di sicuro.
Dialogue: 0,0:18:18.08,0:18:19.41,Main-207-,,0,0,0,,Cos'è successo?
Dialogue: 0,0:18:19.41,0:18:21.79,Main-207-,,0,0,0,,Voialtri, vi affido la casa.
Dialogue: 0,0:18:21.79,0:18:24.37,Main-207-,,0,0,0,,È del lavoro! Vai, Pierre!
Dialogue: 0,0:18:57.66,0:19:01.37,Main-207-,,0,0,0,,Padre! Ma che buon succo di zucca!
Dialogue: 0,0:19:01.87,0:19:02.75,Main-207-,,0,0,0,,Sì...
Dialogue: 0,0:19:02.75,0:19:04.62,Main-207-,,0,0,0,,Hai proprio ragione...
Dialogue: 0,0:19:04.62,0:19:06.83,Main-207-,,0,0,0,,Ne sono lieto.
Dialogue: 0,0:19:19.85,0:19:21.35,Main-207-,,0,0,0,,Smettila!
Dialogue: 0,0:19:21.35,0:19:23.35,Main-207-,,0,0,0,,Smettila ti prego!
Dialogue: 0,0:19:23.35,0:19:25.23,Main-207-,,0,0,0,,Lascia stare la nave!
Dialogue: 0,0:19:25.23,0:19:27.23,Main-207-,,0,0,0,,Lascia stare almeno la nave!
Dialogue: 0,0:19:32.15,0:19:33.28,Main-207-,,0,0,0,,Maledizione!
Dialogue: 0,0:20:02.18,0:20:03.68,Main-207-,,0,0,0,,Maledizione...
Dialogue: 0,0:20:05.06,0:20:06.77,Main-207-,,0,0,0,,Maledizione!
Dialogue: 0,0:20:06.77,0:20:08.77,Main-207-,,0,0,0,,Smettila!
Dialogue: 0,0:20:08.77,0:20:11.06,Main-207-,,0,0,0,,S-Sono di guardia alla nave!
Dialogue: 0,0:20:11.44,0:20:13.65,Main-207-,,0,0,0,,Hanno detto che contano su di me!
Dialogue: 0,0:20:18.28,0:20:19.11,Main-207-,,0,0,0,,Bene...
Dialogue: 0,0:20:19.57,0:20:21.78,Main-207-,,0,0,0,,Che facciamo, Fuza?
Dialogue: 0,0:20:25.08,0:20:27.91,Main-207-,,0,0,0,,Dice di non attaccare i compagni.
Dialogue: 0,0:20:27.91,0:20:30.67,Main-207-,,0,0,0,,Dice di non ferire la nave.
Dialogue: 0,0:20:30.67,0:20:33.21,Main-207-,,0,0,0,,Dice di non voler morire.
Dialogue: 0,0:20:34.05,0:20:35.59,Main-207-,,0,0,0,,Che seccatura, eh?
Dialogue: 0,0:20:35.92,0:20:38.80,Main-207-,,0,0,0,,Ah, che bastardo egoista.
Dialogue: 0,0:20:38.80,0:20:40.97,Main-207-,,0,0,0,,È davvero irritante.
Dialogue: 0,0:20:51.15,0:20:52.77,Main-207-,,0,0,0,,Gan Fall...
Dialogue: 0,0:20:54.52,0:20:58.03,Main-207-,,0,0,0,,Se vuoi vivere così tanto, \Nperché sei debole?!
Dialogue: 0,0:20:59.24,0:21:00.11,Main-207-,,0,0,0,,Smettila!
Dialogue: 0,0:21:00.95,0:21:03.20,Main-207-,,0,0,0,,Quella è la lancia che brucia!
Dialogue: 0,0:21:09.21,0:21:10.37,Main-207-,,0,0,0,,Ah– Smettila! Ah!
Dialogue: 0,0:21:10.96,0:21:11.79,Main-207-,,0,0,0,,Maledizione!
Dialogue: 0,0:21:14.25,0:21:15.71,Main-207-,,0,0,0,,Brutto bastardo!
Dialogue: 0,0:21:17.17,0:21:18.01,Main-207-,,0,0,0,,Cos–?!
Dialogue: 0,0:21:19.17,0:21:21.13,Main-207-,,0,0,0,,Vuoi dire di...
Dialogue: 0,0:21:22.09,0:21:24.81,Main-207-,,0,0,0,,voler vivere senza alcun sacrificio?
Dialogue: 0,0:21:25.18,0:21:26.81,Thoughts-207-,,0,0,0,,Ma che cos'ha 'sto tizio?!
Dialogue: 0,0:21:26.81,0:21:31.27,Thoughts-207-,,0,0,0,,È da prima che pare che \Npreveda i miei movimenti...
Dialogue: 0,0:21:33.23,0:21:37.78,Main-207-,,0,0,0,,Se qualcuno sopravvive significa \Nche qualcun altro deve morire.
Dialogue: 0,0:21:38.78,0:21:41.40,Main-207-,,0,0,0,,In questo mondo funziona così!
Dialogue: 0,0:21:44.28,0:21:48.12,Main-207-,,0,0,0,,{\q2}Tu... sai che questo è l'altare sacrificale?
Dialogue: 0,0:21:48.12,0:21:50.04,Main-207-,,0,0,0,,S-Sì!
Dialogue: 0,0:21:50.04,0:21:51.79,Main-207-,,0,0,0,,Avevano detto qualcosa del genere.
Dialogue: 0,0:21:51.79,0:21:52.92,Main-207-,,0,0,0,,Esatto.
Dialogue: 0,0:21:52.92,0:21:58.30,Main-207-,,0,0,0,,{\q2}Il resto dei vostri compagni sta \Ndisperatamente cercando di raggiungervi qui.
Dialogue: 0,0:22:00.42,0:22:05.55,Main-207-,,0,0,0,,{\an8}Su quest'isola ci sono quattro aree\N su cui regniamo noi sacerdoti.{spostata sopra altrimenti il typesetting copre la frase}
Dialogue: 0,0:22:06.56,0:22:10.23,Main-207-,,0,0,0,,{\an8}Fin tanto che gli obiettivi si \Ntrovano in una di quelle aree...
Dialogue: 0,0:22:10.23,0:22:12.94,Main-207-,,0,0,0,,{\an8}gli altri sacerdoti non \Npossono intervenire per regola.{...non sapevo come metterla}
Dialogue: 0,0:22:13.77,0:22:19.15,Main-207-,,0,0,0,,Ma... questo altare sacrificale \Nnon è parte di alcuna area...
Dialogue: 0,0:22:19.57,0:22:22.32,Main-207-,,0,0,0,,e dunque è una free area.
Dialogue: 0,0:22:22.32,0:22:25.99,Main-207-,,0,0,0,,Significa che non importa \Nse qualcuno ci mette le mani.
Dialogue: 0,0:22:26.45,0:22:33.12,Main-207-,,0,0,0,,{\q2}Ma comunque... questo è vero quando coloro che \Nstavano affrontando la prova in una delle aree sono morti.{non ci sta sullo schermo}
Dialogue: 0,0:22:33.12,0:22:34.04,Main-207-,,0,0,0,,Eh?!
Dialogue: 0,0:22:34.04,0:22:36.46,Main-207-,,0,0,0,,Allora Luffy e gli altri...!
Dialogue: 0,0:22:36.79,0:22:38.42,Main-207-,,0,0,0,,Non agitarti.
Dialogue: 0,0:22:38.42,0:22:42.88,Main-207-,,0,0,0,,{\q2}Anche se sono venuto qui, non significa \Nche i tuoi compagni siano morti.
Dialogue: 0,0:22:43.47,0:22:44.93,Main-207-,,0,0,0,,Sfortunatamente...
Dialogue: 0,0:22:45.55,0:22:49.31,Main-207-,,0,0,0,,c'è un altro motivo per cui sono qui.
Dialogue: 0,0:22:49.31,0:22:50.39,Main-207-,,0,0,0,,Eh?
Dialogue: 0,0:22:50.39,0:22:51.47,Main-207-,,0,0,0,,Un altro?
Dialogue: 0,0:22:52.14,0:22:55.85,Main-207-,,0,0,0,,Allora, ecco... Se Luffy e \Ngli altri venissero a salvarci,
Dialogue: 0,0:22:55.85,0:22:57.86,Main-207-,,0,0,0,,potremmo fuggire anche noi?!
Dialogue: 0,0:22:57.86,0:23:00.32,Main-207-,,0,0,0,,Sì, è proprio così.
Dialogue: 0,0:23:00.82,0:23:04.91,Main-207-,,0,0,0,,Ammesso che riusciate a \Nfuggire da questa free area.
Dialogue: 0,0:23:04.91,0:23:05.74,Main-207-,,0,0,0,,Eh?
Dialogue: 0,0:23:06.41,0:23:08.87,Main-207-,,0,0,0,,Però, beh, aspetta un attimo.
Dialogue: 0,0:23:08.87,0:23:12.12,Main-207-,,0,0,0,,L'altro motivo che dicevo \Nper cui sono venuto qui...
Dialogue: 0,0:23:12.12,0:23:14.83,Main-207-,,0,0,0,,è perché quelle sono le normali \Nregole del giudizio divino
Dialogue: 0,0:23:14.83,0:23:18.50,Main-207-,,0,0,0,,e perché in casi eccezionali \Ncambiano leggermente.
Dialogue: 0,0:23:18.50,0:23:19.46,Main-207-,,0,0,0,,Casi eccezionali?
Dialogue: 0,0:23:19.46,0:23:20.84,Main-207-,,0,0,0,,Esatto.
Dialogue: 0,0:23:20.84,0:23:22.09,Main-207-,,0,0,0,,Per esempio...
Dialogue: 0,0:23:22.46,0:23:28.51,Main-207-,,0,0,0,,{\q2}nel caso in cui tre dei sacrifici passino alla foresta \Ntramite le liane e fuggano di loro iniziativa.
Dialogue: 0,0:23:28.51,0:23:30.85,Main-207-,,0,0,0,,Eh... C'è un caso del genere...
Dialogue: 0,0:23:32.47,0:23:34.23,Flashbacks-207-,,0,0,0,,{Skypiea 05 @11:39}C'è Dio, no?
Dialogue: 0,0:23:34.23,0:23:35.69,Flashbacks-207-,,0,0,0,,{Skypiea 05 @11:39}Vado a trovarlo.
Dialogue: 0,0:23:45.57,0:23:48.28,Thoughts-207-,,0,0,0,,Il colpevole è {\i1}lui{\i0}!
Dialogue: 0,0:23:49.45,0:23:53.75,Main-207-,,0,0,0,,{\alpha&HFF&\c&HE8FAFC&\3c&HE8FAFC&\4c&HE8FAFC&\t(21,270,1,\c&HFFFFFF&\3c&H000000&\4c&H000000&)\t(20,61,\4a&H78&\3a&H00&\1a&H00&)}I peccati di chi è scappato va \Nespiato con la morte di qualcuno.
Dialogue: 0,0:23:55.12,0:23:58.17,Main-207-,,0,0,0,,{\q2}È il sacrificio, la verità di questo mondo.{ewwwwwwwwwww}
Dialogue: 0,0:23:59.17,0:24:02.80,Main-207-,,0,0,0,,Se tornassero qui, \Nsarebbe ancora meglio.
Dialogue: 0,0:24:02.80,0:24:05.26,Main-207-,,0,0,0,,Potrebbero vedere con i propri \Nocchi la morte
Dialogue: 0,0:24:05.26,0:24:08.26,Main-207-,,0,0,0,,di un compagno e così capire\N profondamente la propria colpa!{ho spostato di un compagno da quella sopra perché non ci stava in cps altrimenti}
Dialogue: 0,0:24:11.01,0:24:15.64,Main-207-,,0,0,0,,Dai la tua vita... a God!
Dialogue: 0,0:24:17.60,0:24:19.31,Main-207-,,0,0,0,,Non voglio!
Dialogue: 0,0:24:28.15,0:24:29.20,Main-207-,,0,0,0,,Muori!
Dialogue: 0,0:24:42.38,0:24:45.05,Main-207-,,0,0,0,,Ti ho fatto aspettare un po'!
Dialogue: 0,0:24:45.42,0:24:47.88,Main-207-,,0,0,0,,Cavaliere del cielo!
Dialogue: 0,0:24:50.97,0:24:53.68,Main-207-,,0,0,0,,Che raro ospite è arrivato!
Dialogue: 0,0:25:01.31,0:25:03.23,Main-207-,,0,0,0,,Gan Fall!
Dialogue: 0,0:25:07.57,0:25:10.78,Main-207-,,0,0,0,,Cavaliere del cielo!
Dialogue: 0,0:25:10.78,0:25:13.70,Main-207-,,0,0,0,,Un avversario di tutto rispetto, \Nnon c'è dubbio.
Dialogue: 0,0:25:13.70,0:25:16.49,Main-207-,,0,0,0,,Diamoci un po' dentro, Pierre!
Dialogue: 0,0:25:18.87,0:25:21.92,Main-207-,,0,0,0,,Che vuole quel decrepito \Ndella generazione passata?!
Dialogue: 0,0:25:22.38,0:25:24.92,Main-207-,,0,0,0,,Divertiamoci un po', Fuza!
Dialogue: 0,0:25:26.59,0:25:28.17,Main-207-,,0,0,0,,Ruggisci quanto vuoi!
Dialogue: 0,0:25:28.17,0:25:31.13,Main-207-,,0,0,0,,In quest'isola non servono due dei!
Dialogue: 0,0:25:39.60,0:25:41.69,Main-207-,,0,0,0,,Vai!
Dialogue: 0,0:26:24.52,0:26:30.11,Main-207-,,0,0,0,,Cavaliere del cielo!
Dialogue: 0,0:26:40.62,0:26:43.25,Main-207-,,0,0,0,,{\q2}Serve ancora un piccolo sforzo, Pierre.
Dialogue: 0,0:26:43.25,0:26:44.62,Main-207-,,0,0,0,,Vai!
Dialogue: 0,0:26:50.51,0:26:51.84,Main-207-,,0,0,0,,Bastardo!
Dialogue: 0,0:26:54.13,0:26:57.47,Main-207-,,0,0,0,,{\q2}Sicuramente sei venuto qui sapendolo,
Dialogue: 0,0:26:57.47,0:27:00.93,Main-207-,,0,0,0,,ma sei già un criminale!
Dialogue: 0,0:27:00.93,0:27:06.44,Main-207-,,0,0,0,,Ah... irritanti schiocchi, \Nassaggiate la via della mia ira!{ew ma onestamente idk}
Dialogue: 0,0:27:09.27,0:27:10.94,Main-207-,,0,0,0,,{\fad(150,150)}Prova della corda!
Dialogue: 0,0:27:30.71,0:27:33.09,Main-207-,,0,0,0,,Respiri ancora?
Dialogue: 0,0:27:33.09,0:27:35.93,Main-207-,,0,0,0,,Impressionante~! Impressionante~!
Dialogue: 0,0:27:35.93,0:27:40.56,Main-207-,,0,0,0,,Allora, come premio, \Nti concederò il colpo di grazia!
Dialogue: 0,0:27:48.98,0:27:51.11,Main-207-,,0,0,0,,{\fad(150,150)}Ghirlanda di Gemme a Sorpresa.{G - abilità}
Dialogue: 0,0:28:15.63,0:28:16.59,Main-207-,,0,0,0,,Aisa!{G - personaggi}
Dialogue: 0,0:28:19.51,0:28:20.68,Main-207-,,0,0,0,,Dove sei stata?
Dialogue: 0,0:28:21.55,0:28:22.68,Main-207-,,0,0,0,,Kamakiri!{G - personaggi}
Dialogue: 0,0:28:22.68,0:28:24.93,Main-207-,,0,0,0,,Ancora ad Upper Yard?
Dialogue: 0,0:28:24.93,0:28:27.56,Main-207-,,0,0,0,,Dentro alla borsa hai il Vearth, vero?
Dialogue: 0,0:28:29.02,0:28:30.94,Main-207-,,0,0,0,,Datti una regolata.
Dialogue: 0,0:28:32.27,0:28:34.19,Main-207-,,0,0,0,,Rischi di morire.
Dialogue: 0,0:28:38.32,0:28:40.20,Main-207-,,0,0,0,,Sono affari miei!
Dialogue: 0,0:28:40.78,0:28:43.33,Main-207-,,0,0,0,,{\q2}Tanto non riuscirete mai a battere Enel!
Dialogue: 0,0:28:48.00,0:28:49.37,Main-207-,,0,0,0,,Maledetta mocciosa!
Dialogue: 0,0:28:50.50,0:28:51.83,Main-207-,,0,0,0,,Una chance?
Dialogue: 0,0:28:51.83,0:28:53.38,Main-207-,,0,0,0,,Esatto.
Dialogue: 0,0:28:53.38,0:28:57.47,Main-207-,,0,0,0,,Per qualche motivo, \NGan Fall è andato ad Upper Yard.
Dialogue: 0,0:28:57.47,0:29:02.47,Main-207-,,0,0,0,,{\q2}Quel vecchio crede di poter riportare la pace \Nall'intera Isola del Cielo senza conflitti.
Dialogue: 0,0:29:03.26,0:29:05.31,Main-207-,,0,0,0,,È un grave errore!
Dialogue: 0,0:29:08.02,0:29:10.10,Main-207-,,0,0,0,,Vincere o perdere...
Dialogue: 0,0:29:10.10,0:29:13.27,Main-207-,,0,0,0,,Non c'è altra conclusione \Nper il termine di una battaglia!
Dialogue: 0,0:29:15.28,0:29:17.65,Main-207-,,0,0,0,,Così disse il Grande Guerriero Kalgara:{G - personaggi}
Dialogue: 0,0:29:17.65,0:29:19.74,Main-207-,,0,0,0,,"rianimate la fiamma di Shandia".{accendete}
Dialogue: 0,0:29:20.24,0:29:22.74,Main-207-,,0,0,0,,È ciò che otterremo.
Dialogue: 0,0:29:22.74,0:29:26.54,Main-207-,,0,0,0,,Il precedente Dio Gan Fall\N o l'attuale God Enel...
Dialogue: 0,0:29:26.54,0:29:28.71,Main-207-,,0,0,0,,Non importa chi sia l'avversario.
Dialogue: 0,0:29:28.71,0:29:31.04,Main-207-,,0,0,0,,Comunque cambi la forma,
Dialogue: 0,0:29:31.04,0:29:37.21,Main-207-,,0,0,0,,chiunque regni fregiandosi del nome di \NDio, per noi non fa alcuna differenza!
Dialogue: 0,0:29:37.21,0:29:40.80,Main-207-,,0,0,0,,{\q2}Sono tutti quanti soggetti da eliminare!
Dialogue: 0,0:29:40.80,0:29:41.97,Main-207-,,0,0,0,,Wyper.{G - personaggi}
Dialogue: 0,0:29:43.05,0:29:46.43,Main-207-,,0,0,0,,C'è stata una ribelle \Ncontro Enel all'Isola Angel.
Dialogue: 0,0:29:46.43,0:29:48.06,Main-207-,,0,0,0,,Pare sia una giovane ragazza.
Dialogue: 0,0:29:49.02,0:29:52.81,Main-207-,,0,0,0,,{\q2}È la prima volta nei sei anni di regno di Enel.
Dialogue: 0,0:29:52.81,0:29:54.56,Main-207-,,0,0,0,,E quindi?
Dialogue: 0,0:29:54.56,0:29:58.19,Main-207-,,0,0,0,,Dato che Gan Fall ha salvato \Nquella ragazza dal giudizio...
Dialogue: 0,0:29:58.19,0:30:02.57,Main-207-,,0,0,0,,Enel ha ottenuto un motivo per poter \Ngiudicare anche il precedente Dio.
Dialogue: 0,0:30:03.45,0:30:05.53,Main-207-,,0,0,0,,{\q2}Non semplicemente come cavaliere del cielo
Dialogue: 0,0:30:05.53,0:30:11.58,Main-207-,,0,0,0,,{\q2}ma come precedente Dio. \NGan Fall non ha mai ferito nessuno di noi
Dialogue: 0,0:30:12.04,0:30:15.34,Main-207-,,0,0,0,,e non ha mai nemmeno provato \Na affrontare Enel direttamente.
Dialogue: 0,0:30:15.71,0:30:20.13,Main-207-,,0,0,0,,Quell'uomo ha finalmente \Nmesso piede ad Upper Yard!
Dialogue: 0,0:30:20.63,0:30:26.22,Main-207-,,0,0,0,,{\q2}Così facendo, se si trafiggesse a vicenda \Ncon uno dei sacerdoti, sarebbe ottimo.
Dialogue: 0,0:30:26.22,0:30:31.93,Main-207-,,0,0,0,,O forse intendi dire che Gan Fall non è \Npiù un avversario ostile per noi?!
Dialogue: 0,0:30:31.93,0:30:34.44,Main-207-,,0,0,0,,Quando si ha un nemico comune,
Dialogue: 0,0:30:34.44,0:30:36.94,Main-207-,,0,0,0,,si tende a considerare chi \Nsta accanto un alleato!
Dialogue: 0,0:30:39.86,0:30:43.74,Main-207-,,0,0,0,,Se hai dei dubbi, \Nnon partecipare alla battaglia, Raki.
Dialogue: 0,0:30:44.57,0:30:46.24,Main-207-,,0,0,0,,Saresti solo d'intralcio!
Dialogue: 0,0:30:50.66,0:30:51.79,Main-207-,,0,0,0,,Aisa!
Dialogue: 0,0:30:53.71,0:30:57.04,Main-207-,,0,0,0,,Che vuoi?! Non sono\N stata ad Upper Yard...!
Dialogue: 0,0:30:57.79,0:31:00.46,Main-207-,,0,0,0,,Non entrare ancora nella tenda.
Dialogue: 0,0:31:02.05,0:31:07.89,Main-207-,,0,0,0,,{\q2}Wyper... No... L'uomo che ha ereditato il sangue \Ndel Grande Guerriero Kalgara è irritato.
Dialogue: 0,0:31:09.51,0:31:11.85,Main-207-,,0,0,0,,Già... Fa proprio paura...
Dialogue: 0,0:31:14.77,0:31:16.40,Main-207-,,0,0,0,,Fa più paura di Dio.
Dialogue: 0,0:31:20.15,0:31:21.65,Main-207-,,0,0,0,,Salvare?
Dialogue: 0,0:31:21.65,0:31:22.94,Main-207-,,0,0,0,,Loro?
Dialogue: 0,0:31:24.20,0:31:25.78,Main-207-,,0,0,0,,Noi?
Dialogue: 0,0:31:25.78,0:31:28.45,Main-207-,,0,0,0,,Sì. Esatto.
Dialogue: 0,0:31:28.95,0:31:32.87,Main-207-,,0,0,0,,Impegniamoci per dar \Nloro una via di fuga.
Dialogue: 0,0:31:46.68,0:31:48.97,Main-207-,,0,0,0,,Non capisco cosa stiano facendo...
Dialogue: 0,0:31:48.97,0:31:50.05,Main-207-,,0,0,0,,Fantastico...
Dialogue: 0,0:31:52.35,0:31:56.52,Main-207-,,0,0,0,,{\q2}Non credo più di poter negoziare con voi!
Dialogue: 0,0:31:57.77,0:32:00.11,Main-207-,,0,0,0,,Poco incisivo come sempre!
Dialogue: 0,0:32:01.94,0:32:04.82,Thoughts-207-,,0,0,0,,Ma cos'è questo combattimento?
Dialogue: 0,0:32:12.33,0:32:14.45,Main-207-,,0,0,0,,Il giudizio divino...
Dialogue: 0,0:32:15.96,0:32:18.79,Main-207-,,0,0,0,,Quella ragazza... \Nha fatto una cosa stupida...
Dialogue: 0,0:32:20.25,0:32:22.09,Main-207-,,0,0,0,,God Enel...
Dialogue: 0,0:32:22.67,0:32:25.38,Main-207-,,0,0,0,,non bisogna farlo arrabbiare.
Dialogue: 0,0:32:44.94,0:32:46.65,Flashbacks-207-,,0,0,0,,{Skypiea 04 @28:10}La prego, ritorni!
Dialogue: 0,0:32:47.07,0:32:48.65,Flashbacks-207-,,0,0,0,,{\t(1021,0,1,\c&HFFFFFF&\3c&HFFFFFF&\4c&HFFFFFF&)}{Skypiea 04 @ 28:15}Dio...
Dialogue: 0,0:32:56.45,0:32:58.08,Main-207-,,0,0,0,,Ci sei cascato, eh?
Dialogue: 0,0:33:03.59,0:33:06.13,Main-207-,,0,0,0,,Che succede, Gan Fall?!
Dialogue: 0,0:33:06.13,0:33:08.42,Main-207-,,0,0,0,,Che hai fatto?!
Dialogue: 0,0:33:09.09,0:33:11.64,Thoughts-207-,,0,0,0,,Perché? \NPerché non riesco a muovermi?
Dialogue: 0,0:33:11.64,0:33:13.55,Main-207-,,0,0,0,,Per chi sta per per morire...
Dialogue: 0,0:33:14.64,0:33:16.60,Main-207-,,0,0,0,,non servono delle risposte.
Dialogue: 0,0:33:29.57,0:33:32.74,Main-207-,,0,0,0,,L'estremamente misteriosa\N prova della corda...
Dialogue: 0,0:33:34.24,0:33:35.83,Main-207-,,0,0,0,,Puoi venire...
Dialogue: 0,0:33:35.83,0:33:39.25,Main-207-,,0,0,0,,ad Upper Yard, ma non pensare \Nche le prove di noi sacerdoti...
Dialogue: 0,0:33:40.21,0:33:44.21,Main-207-,,0,0,0,,siano così facili da superare.
Dialogue: 0,0:33:48.84,0:33:50.34,Main-207-,,0,0,0,,God Enel...
Dialogue: 0,0:33:51.72,0:33:54.85,Main-207-,,0,0,0,,è nobile e inarrivabile.
Dialogue: 0,0:34:00.06,0:34:01.44,Flashbacks-207-,,0,0,0,,{Flashback, this episode @17:59}Esatto.
Dialogue: 0,0:34:01.44,0:34:04.56,Flashbacks-207-,,0,0,0,,Il territorio sacro canterà di nuovo.
Dialogue: 0,0:34:04.56,0:34:05.90,Flashbacks-207-,,0,0,0,,Un giorno, di sicuro.
Dialogue: 0,0:34:06.98,0:34:08.48,Main-207-,,0,0,0,,Cavaliere...
Dialogue: 0,0:34:09.86,0:34:13.07,Main-207-,,0,0,0,,Cavaliere del cielo!
Comment: 0,0:00:00.00,0:00:00.00,Main-207-,,0,0,0,,{=132}===============================DIALOGUE============================
Comment: 0,0:00:00.00,0:00:00.00,Main-207-,,0,0,0,,{=135}============================SIGNS AND TITLE=========================
