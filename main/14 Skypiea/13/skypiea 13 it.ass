Comment: 0,0:00:00.00,0:00:00.00,Main-207-,,0,0,0,,{=10}===============================DIALOGUE============================
Dialogue: 0,0:02:03.35,0:02:05.23,Main-207-,,0,0,0,,Manca ancora poco...
Dialogue: 0,0:02:05.23,0:02:10.36,Main-207-,,0,0,0,,Se trovassi l'oro per primo, \Ntutti si stupiranno...
Dialogue: 0,0:02:16.24,0:02:18.70,Main-207-,,0,0,0,,Anche qui ci sono delle rovine, eh?
Comment: 0,0:02:21.54,0:02:22.54,Main-207-,,0,0,0,,
Dialogue: 0,0:02:24.79,0:02:25.75,Main-207-,,0,0,0,,A-Ahi!
Dialogue: 0,0:02:26.42,0:02:27.96,Main-207-,,0,0,0,,Ma che posto è questo?!
Dialogue: 0,0:02:27.96,0:02:30.00,Main-207-,,0,0,0,,Il terreno è un po' deformato...{distorto, piegato, inclinato}
Dialogue: 0,0:02:30.00,0:02:31.88,Main-207-,,0,0,0,,Partiamo per di là.{continuo a sostenere che suona meglio in noi, come se stesse parlando a sé stesso così}
Dialogue: 0,0:02:38.05,0:02:40.31,Main-207-,,0,0,0,,Oro! Oro!
Dialogue: 0,0:02:42.64,0:02:43.89,Main-207-,,0,0,0,,Aspetta.
Dialogue: 0,0:02:43.89,0:02:45.60,Main-207-,,0,0,0,,Aspetta, Holy.
Dialogue: 0,0:02:45.60,0:02:47.36,Main-207-,,0,0,0,,Holy, aspetta.
Dialogue: 0,0:02:57.07,0:02:59.70,Thoughts-207-,,0,0,0,,Io... mi ero montato un po' la testa!
Dialogue: 0,0:02:59.70,0:03:01.74,Thoughts-207-,,0,0,0,,Avrei fatto meglio a tornare indietro!
Dialogue: 0,0:03:01.74,0:03:03.96,Thoughts-207-,,0,0,0,,Morirò!
Dialogue: 0,0:03:06.54,0:03:10.88,Main-207-,,0,0,0,,Con te, oggi siamo a tre persone\N che passano per di qua.
Dialogue: 0,0:03:11.25,0:03:12.21,Main-207-,,0,0,0,,Eh?
Dialogue: 0,0:03:12.21,0:03:13.17,Main-207-,,0,0,0,,Chi sei?!
Dialogue: 0,0:03:13.72,0:03:16.84,Main-207-,,0,0,0,,Certo che quel testa di ragno \Nè proprio uno sbadato!{lett lo chiama testa di ragno...}
Dialogue: 0,0:03:17.64,0:03:20.10,Main-207-,,0,0,0,,Tu... hai eliminato Gedatsu, vero?
Dialogue: 0,0:03:21.43,0:03:23.77,Thoughts-207-,,0,0,0,,Parla del tizio di prima...
Dialogue: 0,0:03:25.06,0:03:27.27,Main-207-,,0,0,0,,Ah, non importa, non importa.
Dialogue: 0,0:03:27.27,0:03:30.19,Main-207-,,0,0,0,,È meglio per il mondo che \Nquell'idiota sia sparito.
Dialogue: 0,0:03:30.19,0:03:31.52,Main-207-,,0,0,0,,Non lo pensi anche tu?
Dialogue: 0,0:03:43.16,0:03:44.95,Main-207-,,0,0,0,,Cosa?! Sono caduto su–{direbbe "qualcosa", ma solo quello. ovvio dalla scena che intende che è caduto su qualcosa}
Dialogue: 0,0:03:52.00,0:03:53.63,Main-207-,,0,0,0,,Non avere paura!
Dialogue: 0,0:03:53.63,0:03:55.97,Main-207-,,0,0,0,,Quel cane è Holy, \Nè il mio amato cane.
Dialogue: 0,0:03:55.97,0:03:57.59,Main-207-,,0,0,0,,Non ti morderà.
Dialogue: 0,0:03:57.97,0:04:01.39,Main-207-,,0,0,0,,M-Ma! Questo qui è a terra \Ned è ridotto male...
Dialogue: 0,0:04:01.39,0:04:06.10,Main-207-,,0,0,0,,Holy è ben addestrato, perciò \Nnon morde la gente senza motivo.
Dialogue: 0,0:04:07.44,0:04:10.56,Main-207-,,0,0,0,,Quell'uomo... l'ho fatto a fette io.
Dialogue: 0,0:04:11.69,0:04:14.11,Main-207-,,0,0,0,,Fa ancora più paura così! \NMa chi sei?!
Dialogue: 0,0:04:14.82,0:04:15.90,Main-207-,,0,0,0,,Chi sei?
Dialogue: 0,0:04:15.90,0:04:17.15,Main-207-,,0,0,0,,Il mio nome è Ohm.
Dialogue: 0,0:04:17.15,0:04:19.07,Secondary-207-,,0,0,0,,{\an8}C-Che paura...
Dialogue: 0,0:04:17.78,0:04:19.07,Main-207-,,0,0,0,,Fa' silenzio!
Dialogue: 0,0:04:19.07,0:04:20.32,Secondary-207-,,0,0,0,,{\an8}È troppo spaventoso!
Dialogue: 0,0:04:20.32,0:04:23.70,Main-207-,,0,0,0,,Al momento... sono addolorato \Nper la fragilità umana.
Dialogue: 0,0:04:21.07,0:04:22.49,Secondary-207-,,0,0,0,,{\an8}Non ce la posso fare...{molto circa}
Dialogue: 0,0:04:23.70,0:04:24.58,Main-207-,,0,0,0,,Eh?
Dialogue: 0,0:04:25.70,0:04:29.04,Main-207-,,0,0,0,,{\q2}Pur sapendo che la vita umana è effimera,
Dialogue: 0,0:04:29.04,0:04:31.79,Main-207-,,0,0,0,,perché le persone continuano\N a combattere e a perire?
Dialogue: 0,0:04:32.67,0:04:34.00,Main-207-,,0,0,0,,Cosa, cosa?
Dialogue: 0,0:04:34.73,0:04:36.84,Main-207-,,0,0,0,,Nati per diventare felici,
Dialogue: 0,0:04:36.84,0:04:38.43,Main-207-,,0,0,0,,desiderano la felicità,
Dialogue: 0,0:04:38.88,0:04:40.47,Main-207-,,0,0,0,,ma muoiono combattendo!
Dialogue: 0,0:04:41.18,0:04:44.97,Main-207-,,0,0,0,,Allora sarebbe meglio non \Nfar nulla sin dall'inizio.
Dialogue: 0,0:04:44.97,0:04:47.35,Main-207-,,0,0,0,,Non si può sfuggire alla natura umana.
Dialogue: 0,0:04:47.35,0:04:48.68,Main-207-,,0,0,0,,Che tristezza.
Dialogue: 0,0:04:49.73,0:04:52.77,Main-207-,,0,0,0,,Ma c'è una strada per salvarli!{gli umani sottointeso}
Dialogue: 0,0:04:54.36,0:04:55.98,Main-207-,,0,0,0,,Basta che muoiano tutti!
Dialogue: 0,0:04:56.73,0:04:59.03,Main-207-,,0,0,0,,{\q2}Ma perché dice cose così spaventose?!
Dialogue: 0,0:04:59.03,0:05:00.61,Main-207-,,0,0,0,,Non riesco a crederci!
Dialogue: 0,0:05:01.24,0:05:03.78,Main-207-,,0,0,0,,Cosa sei venuto a fare qui?
Dialogue: 0,0:05:03.78,0:05:06.04,Main-207-,,0,0,0,,Ah–! Sono venuto solo a cercare l'or–
Dialogue: 0,0:05:06.04,0:05:08.41,Main-207-,,0,0,0,,Il desiderio genera conflitti!
Dialogue: 0,0:05:08.41,0:05:09.12,Main-207-,,0,0,0,,Eh?
Dialogue: 0,0:05:09.50,0:05:11.12,Main-207-,,0,0,0,,Ti salverò.
Dialogue: 0,0:05:11.12,0:05:14.09,Main-207-,,0,0,0,,Salverai me?
Dialogue: 0,0:05:18.84,0:05:22.09,Main-207-,,0,0,0,,Morendo non potrai più \Nfare o desiderare nulla!
Dialogue: 0,0:05:23.76,0:05:26.68,Thoughts-207-,,0,0,0,,Non vuole salvarmi per niente!
Dialogue: 0,0:05:36.73,0:05:37.82,Main-207-,,0,0,0,,Kamakiri!
Dialogue: 0,0:05:38.94,0:05:40.32,Main-207-,,0,0,0,,Kamakiri!
Dialogue: 0,0:05:42.45,0:05:43.57,Main-207-,,0,0,0,,Vai...
Dialogue: 0,0:05:44.41,0:05:46.12,Main-207-,,0,0,0,,Vai, Raki.
Dialogue: 0,0:05:46.78,0:05:48.37,Main-207-,,0,0,0,,Ma... Kamakiri...
Dialogue: 0,0:05:50.58,0:05:55.46,Main-207-,,0,0,0,,Nel tempio di Dio... \Nin cui sta andando Wyper...
Dialogue: 0,0:05:55.46,0:05:58.25,Main-207-,,0,0,0,,Enel non c'è!
Dialogue: 0,0:05:58.25,0:06:00.51,Main-207-,,0,0,0,,Puoi... ancora fermarlo.
Dialogue: 0,0:06:01.38,0:06:03.26,Main-207-,,0,0,0,,Ferma... Wyper!
Dialogue: 0,0:06:03.89,0:06:06.85,Main-207-,,0,0,0,,Ho capito! Ho capito, \Nquindi smetti di parlare!
Dialogue: 0,0:06:10.98,0:06:14.35,Main-207-,,0,0,0,,{\t(2852,0,1,\c&H181614&\3c&H181614&\4c&H181614&)}Nessuno... può vincere...
Dialogue: 0,0:06:14.48,0:06:17.82,Flashbacks-207-,,0,0,0,,{\c&H181614&\3c&H181614&\4c&H181614&\t(0,1270,1,\c&HFFFFFF&\3c&H525252&\4c&H000000&)}{Skypiea 12 - 06:52}Io sono il fulmine.
Dialogue: 0,0:06:24.74,0:06:27.12,Main-207-,,0,0,0,,Lui... è invincibile!
Comment: 0,0:06:30.04,0:06:31.91,Main-207-,,0,0,0,,
Comment: 0,0:06:31.91,0:06:36.50,Main-207-,,0,0,0,,
Dialogue: 0,0:06:30.04,0:06:36.50,Main-207-,,0,0,0,,{\q2}Lui è ciò che gli uomini hanno temuto \Ndal principio, il fulmine... È Dio in persona.{io l'appunto ve lo faccio. di suo "kaminari" sarebbe tuono, ma tuono a casa mia è il suono dei fulmini e non mi avrebbe senso. fulmine in jp è "inazuma", ma per me ha molto più senso così -angy}
Dialogue: 0,0:06:39.50,0:06:41.17,Main-207-,,0,0,0,,Fermerò Wyper.
Dialogue: 0,0:06:41.17,0:06:42.63,Main-207-,,0,0,0,,Aspettami qui.
Dialogue: 0,0:06:42.63,0:06:46.22,Main-207-,,0,0,0,,La borsa di Aisa... \Nla lascio nelle tue mani.
Dialogue: 0,0:06:57.86,0:07:00.52,Flashbacks-207-,,0,0,0,,Nessuno... può vincere.{vedi poco sopra}
Dialogue: 0,0:07:00.52,0:07:03.52,Flashbacks-207-,,0,0,0,,Lui... è invincibile!{vedi poco sopra}
Dialogue: 0,0:07:03.52,0:07:07.91,Thoughts-207-,,0,0,0,,Uno forte come Kamakiri... \Nè demoralizzato.
Dialogue: 0,0:07:09.74,0:07:11.19,Thoughts-207-,,0,0,0,,Il Frutto Tuono Tuono...{io ve la spiego la logica, se poi vi piace di più "rombo" fate voi. L'idea è, in genere "kaminari" lo metto fulmine, ma vuol dire tuono come dicevo sopra. Goro goro è l'onomatopea per il rombo dei tuoni. Quindi dato che kaminari sarebbe tuono e goro goro è il suono, per me il frutto ci sta tuono tuono invece che rombo rombo. anche perché a me rombo rombo fa venire in mente la figura geometrica, non il rumore dei fulmini -angy}
Dialogue: 0,0:07:11.19,0:07:16.00,Thoughts-207-,,0,0,0,,{\q2}La tipologia Logia, la più potente tra i Frutti del \NDiavolo... pensare che Enel abbia quei poteri...{che poi, lei come le sa queste info? nessuno ha ancora detto il nome del frutto di Enel fin qua, né che è un Logia}
Comment: 0,0:07:11.19,0:07:13.58,Thoughts-207-,,0,0,0,,
Comment: 0,0:07:13.58,0:07:16.00,Thoughts-207-,,0,0,0,,
Dialogue: 0,0:07:16.00,0:07:17.54,Thoughts-207-,,0,0,0,,Devo sbrigarmi a fermarlo!{riferito a wyper senza dirlo}
Dialogue: 0,0:07:23.34,0:07:27.72,Main-207-,,0,0,0,,Mi sembra di aver già visto \Nquesto posto, o forse no...
Dialogue: 0,0:07:27.72,0:07:28.89,Main-207-,,0,0,0,,Forse sì...
Dialogue: 0,0:07:30.10,0:07:32.10,Main-207-,,0,0,0,,Forse no...
Dialogue: 0,0:07:32.10,0:07:33.10,Main-207-,,0,0,0,,Direi di sì.
Dialogue: 0,0:07:34.10,0:07:35.89,Main-207-,,0,0,0,,Un posto che ci assomiglia?
Dialogue: 0,0:07:40.86,0:07:42.57,Main-207-,,0,0,0,,Bastardo, hai appena riso, vero?!
Dialogue: 0,0:07:45.53,0:07:49.87,Main-207-,,0,0,0,,Che vuoi? È colpa tua per avermi \Nseguito per rubarmi il cibo, no?
Dialogue: 0,0:07:49.87,0:07:53.29,Main-207-,,0,0,0,,Stando con me, capitano \Nqueste cose. Non seguirmi!
Dialogue: 0,0:08:01.25,0:08:02.04,Main-207-,,0,0,0,,Idiota! Ehi!
Dialogue: 0,0:08:02.04,0:08:03.17,Main-207-,,0,0,0,,Ehi, ehi!
Dialogue: 0,0:08:04.55,0:08:07.17,Main-207-,,0,0,0,,Aspetta! Non c'è più cibo dentro!
Dialogue: 0,0:08:07.17,0:08:08.68,Main-207-,,0,0,0,,Brutto morto di fame!
Dialogue: 0,0:08:08.68,0:08:12.39,Main-207-,,0,0,0,,{\fad(0,1650)}Ma fin dove vuoi volare?!
Dialogue: 0,0:08:13.31,0:08:16.27,Main-207-,,0,0,0,,{\q2}Sono finito in un posto proprio assurdo!
Dialogue: 0,0:08:19.60,0:08:21.40,Main-207-,,0,0,0,,{\fad(0,650)}Un vicolo cieco!
Dialogue: 0,0:08:25.28,0:08:28.57,Main-207-,,0,0,0,,Ma dai, non può essere così dopo \Nche ho camminato così tanto!{lo so del doppio così, ma è luffy dai}
Dialogue: 0,0:08:29.45,0:08:30.32,Main-207-,,0,0,0,,Che sia...
Dialogue: 0,0:08:30.91,0:08:32.83,Main-207-,,0,0,0,,una porta con qualche meccanismo?
Dialogue: 0,0:08:34.12,0:08:35.87,Main-207-,,0,0,0,,Ah, capito!
Dialogue: 0,0:08:35.87,0:08:39.67,Main-207-,,0,0,0,,Se la sfondo, \Npotrei riuscire a proseguire!
Dialogue: 0,0:08:39.67,0:08:44.80,Main-207-,,0,0,0,,{\fad(150,150)}Gum Gum Bazooka!
Dialogue: 0,0:08:48.92,0:08:49.93,Main-207-,,0,0,0,,Eh?
Dialogue: 0,0:08:49.93,0:08:51.72,Main-207-,,0,0,0,,Non si è mossa di un centimetro!
Dialogue: 0,0:08:59.35,0:09:01.85,Main-207-,,0,0,0,,{\t(1482,0,1,\c&H181614&\3c&H181614&\4c&H181614&)}C-C-Che succede?!
Dialogue: 0,0:09:19.75,0:09:21.79,Main-207-,,0,0,0,,Non mi ha seguito! Che sollievo!
Dialogue: 0,0:09:25.13,0:09:27.63,Main-207-,,0,0,0,,Che sia anche lui un sacerdote?
Dialogue: 0,0:09:27.63,0:09:30.05,Main-207-,,0,0,0,,Qui ci sono un sacco di nascondigli.
Dialogue: 0,0:09:30.05,0:09:33.89,Main-207-,,0,0,0,,Per ora, devo scappare da qui e \Nriunirmi con Luffy e gli altri.
Dialogue: 0,0:09:36.72,0:09:38.77,Main-207-,,0,0,0,,Sembra che sia uno spadaccino...
Dialogue: 0,0:09:38.77,0:09:41.89,Main-207-,,0,0,0,,quindi, se continuo a schivare \Nnascondendomi, riuscirò a fuggire.{cps}
Dialogue: 0,0:09:44.98,0:09:46.82,Main-207-,,0,0,0,,È scappato piuttosto lontano.
Dialogue: 0,0:09:47.53,0:09:50.57,Main-207-,,0,0,0,,È da sciocchi sfuggire al \Nbraccio della salvezza.{direbbe mano, ma mi pare più comune braccio in italiano}
Dialogue: 0,0:09:50.57,0:09:54.32,Main-207-,,0,0,0,,Anche questo è attaccamento \Nalla vita... una passione mondana.
Dialogue: 0,0:09:55.83,0:09:56.83,Main-207-,,0,0,0,,Però!
Dialogue: 0,0:10:14.80,0:10:18.35,Main-207-,,0,0,0,,{\fad(0,441)}Senza via di scampo... \Nè la via della tristezza.
Dialogue: 0,0:10:19.64,0:10:24.23,Main-207-,,0,0,0,,Qui la sopravvivenza è del zero\N percento! La prova del ferro!
Dialogue: 0,0:10:25.10,0:10:25.77,Main-207-,,0,0,0,,Aisa?
Dialogue: 0,0:10:25.77,0:10:28.52,Main-207-,,0,0,0,,Non posso stare qui ferma! \NVado da Raki!
Dialogue: 0,0:10:28.52,0:10:30.03,Main-207-,,0,0,0,,Aspetta!
Dialogue: 0,0:10:30.57,0:10:32.32,Main-207-,,0,0,0,,Ehi! Non puoi!
Dialogue: 0,0:10:33.11,0:10:34.24,Main-207-,,0,0,0,,Che cavolo!
Dialogue: 0,0:10:37.66,0:10:39.16,Main-207-,,0,0,0,,Ho detto aspetta!
Dialogue: 0,0:10:39.16,0:10:43.29,Main-207-,,0,0,0,,Che vuoi?! Lasciami! \NHo detto lasciami! Lasciami!
Dialogue: 0,0:10:43.79,0:10:45.75,Main-207-,,0,0,0,,Non c'entra niente con te, no?!
Dialogue: 0,0:10:45.75,0:10:50.63,Main-207-,,0,0,0,,{\q2}Hai ragione, ma non posso lasciare \Nche una bambina come te venga uccisa!
Dialogue: 0,0:10:50.63,0:10:51.88,Main-207-,,0,0,0,,Io sono una guerriera!
Dialogue: 0,0:10:52.26,0:10:55.55,Main-207-,,0,0,0,,Sì, sì, ho capito, guerriera bambina!
Dialogue: 0,0:10:56.34,0:10:58.72,Main-207-,,0,0,0,,Anche se mi fulmini con lo sguardo, \Nnon mi fai paura.{ho voluto specificare con lo sguardo... fate voi poi, così è cps}
Dialogue: 0,0:10:58.72,0:11:01.18,Main-207-,,0,0,0,,Ehm... Va tutto bene?
Dialogue: 0,0:11:01.18,0:11:02.39,Main-207-,,0,0,0,,Stiamo bene, stiamo bene!
Dialogue: 0,0:11:02.39,0:11:05.06,Main-207-,,0,0,0,,Dai! Agitarsi è inutile, sali!
Dialogue: 0,0:11:05.69,0:11:10.44,Main-207-,,0,0,0,,Non voglio! Lasciami! \NDevo salvare tutti! Lasciami!
Dialogue: 0,0:11:10.44,0:11:12.86,Main-207-,,0,0,0,,Se non la fai finita, ti colpirò sai?!
Dialogue: 0,0:11:14.07,0:11:15.11,Main-207-,,0,0,0,,Anche piangere è inutile!{cps}
Dialogue: 0,0:11:15.78,0:11:19.12,Main-207-,,0,0,0,,Persino due della nostra \Nciurma sono già stati sconfitti!{crew}
Dialogue: 0,0:11:19.12,0:11:21.20,Main-207-,,0,0,0,,Non posso lasciarti fare!
Dialogue: 0,0:11:21.54,0:11:23.37,Main-207-,,0,0,0,,Su, veloce, sali.
Dialogue: 0,0:11:40.30,0:11:41.51,Main-207-,,0,0,0,,Non ci credo!
Dialogue: 0,0:11:47.39,0:11:50.52,Main-207-,,0,0,0,,Aah~ Che sorpresa.
Dialogue: 0,0:11:50.52,0:11:52.23,Main-207-,,0,0,0,,Ma che ha 'sta caverna?!
Dialogue: 0,0:11:52.90,0:11:56.74,Main-207-,,0,0,0,,Appena dopo il terremoto, è giunta \Nsubito un'onda di mare nuvola!{ew}
Dialogue: 0,0:11:58.07,0:11:59.87,Main-207-,,0,0,0,,Stavo per annegare!
Dialogue: 0,0:11:59.87,0:12:00.87,Main-207-,,0,0,0,,Brutta bastarda!
Dialogue: 0,0:12:00.87,0:12:02.70,Main-207-,,0,0,0,,Apri un buco!
Dialogue: 0,0:12:07.37,0:12:09.25,Main-207-,,0,0,0,,Ma quanto è grande?!
Dialogue: 0,0:12:09.25,0:12:10.67,Main-207-,,0,0,0,,Brutta–!
Dialogue: 0,0:12:10.67,0:12:12.67,Main-207-,,0,0,0,,Dov'è l'uscita?!
Dialogue: 0,0:12:12.67,0:12:17.38,Main-207-,,0,0,0,,{\fad(150,150)}Gum Gum Gatling!
Dialogue: 0,0:12:27.94,0:12:29.14,Main-207-,,0,0,0,,Signorina Nami!
Dialogue: 0,0:12:29.14,0:12:31.15,Main-207-,,0,0,0,,Per di là c'è la foresta!
Dialogue: 0,0:12:33.02,0:12:34.86,Main-207-,,0,0,0,,Signorina Nami!
Dialogue: 0,0:12:36.74,0:12:37.95,Main-207-,,0,0,0,,Che facciamo?
Dialogue: 0,0:12:37.95,0:12:39.57,Main-207-,,0,0,0,,È entrata nella foresta.
Dialogue: 0,0:12:45.87,0:12:46.87,Main-207-,,0,0,0,,Maledizione!
Dialogue: 0,0:12:48.75,0:12:49.79,Main-207-,,0,0,0,,Resistente!{tenace}
Dialogue: 0,0:13:04.72,0:13:05.56,Main-207-,,0,0,0,,Cosa?
Dialogue: 0,0:13:08.64,0:13:09.48,Main-207-,,0,0,0,,Chi c'è?!
Dialogue: 0,0:13:09.48,0:13:11.23,Main-207-,,0,0,0,,Qualcosa... \Nsta arrivando qualcosa!
Dialogue: 0,0:13:17.23,0:13:18.82,Main-207-,,0,0,0,,Vai via, via!
Dialogue: 0,0:13:20.82,0:13:22.24,Main-207-,,0,0,0,,È il padrone del cielo!{G - varie (non so se lo vuoi maiuscolo @Cora)}
Dialogue: 0,0:13:22.61,0:13:24.45,Main-207-,,0,0,0,,Ma quella era Aisa?
Dialogue: 0,0:13:44.72,0:13:46.85,Main-207-,,0,0,0,,Sono entrata...
Dialogue: 0,0:13:46.85,0:13:48.31,Main-207-,,0,0,0,,nella foresta!
Dialogue: 0,0:13:52.56,0:13:55.31,Main-207-,,0,0,0,,Ehi! Ehi, mettimi giù!{fammi scendere}
Dialogue: 0,0:13:55.31,0:13:57.44,Main-207-,,0,0,0,,Ma mi stai ascoltando, bastardo?!
Dialogue: 0,0:13:59.44,0:14:02.91,Main-207-,,0,0,0,,Stupido uccellaccio, \Nvuoi che ti taglio a fette?{uccellaccio è per il tono, ste cose non esistono in jp}
Dialogue: 0,0:14:09.62,0:14:10.25,Main-207-,,0,0,0,,Cosa?
Dialogue: 0,0:14:15.92,0:14:17.75,Main-207-,,0,0,0,,Il serpente gigante!
Dialogue: 0,0:14:17.75,0:14:21.13,Main-207-,,0,0,0,,Ehi! Vola più in alto! Ci mangerà!
Dialogue: 0,0:14:23.51,0:14:25.47,Main-207-,,0,0,0,,Muoviti, ehi!
Dialogue: 0,0:14:27.97,0:14:31.39,Main-207-,,0,0,0,,Ci sta ancora seguendo! Non sembra \Nstranamente agitato quel serpente?!
Dialogue: 0,0:14:50.33,0:14:52.33,Main-207-,,0,0,0,,Bastardo!
Dialogue: 0,0:15:08.64,0:15:12.98,Main-207-,,0,0,0,,{\fad(0,652)}Sulla cima di questo Giant Jack... \Nc'è il tempio di Dio!
Dialogue: 0,0:15:13.60,0:15:16.23,Main-207-,,0,0,0,,Lì c'è Enel!
Dialogue: 0,0:15:16.23,0:15:22.07,Main-207-,,0,0,0,,Regolerò i conti... di questa \Nmaledetta storia di quattrocento anni!
Dialogue: 0,0:15:23.32,0:15:24.24,Main-207-,,0,0,0,,Arriva.
Dialogue: 0,0:15:38.33,0:15:43.46,Main-207-,,0,0,0,,Wyper! Scalando ancora la liana, \Narriverai al tempio di Dio.
Dialogue: 0,0:15:43.84,0:15:46.22,Main-207-,,0,0,0,,Chi ti ha autorizzato a passare?
Dialogue: 0,0:15:47.89,0:15:49.22,Main-207-,,0,0,0,,Ohm!
Dialogue: 0,0:15:51.56,0:15:55.39,Main-207-,,0,0,0,,{\q2}Puntare al tempio di Dio ormai è futile.{inutile, ma visto che è Gan Fall why not?}
Dialogue: 0,0:15:56.27,0:15:57.64,Main-207-,,0,0,0,,Gan Fall!
Dialogue: 0,0:16:00.48,0:16:02.94,Main-207-,,0,0,0,,Perché sei qui tu?!
Dialogue: 0,0:16:03.36,0:16:06.20,Main-207-,,0,0,0,,{\q2}Provi ancora nostalgia per il trono di Dio?!
Dialogue: 0,0:16:06.20,0:16:10.41,Main-207-,,0,0,0,,Non ho nostalgia, ma non ho finito \Ndi assumermi le mie responsabilità.
Dialogue: 0,0:16:11.16,0:16:16.33,Main-207-,,0,0,0,,Sono appena andato a dare \Nun'occhiata al tempio di Dio qui sopra.
Dialogue: 0,0:16:20.29,0:16:23.30,Main-207-,,0,0,0,,Una tragedia... È del tutto distrutto.
Dialogue: 0,0:16:30.93,0:16:34.60,Main-207-,,0,0,0,,Ovviamente... Enel non era presente.
Dialogue: 0,0:16:35.39,0:16:40.35,Main-207-,,0,0,0,,Pare che ormai sia diventato \Nun fardello inutile per lui.
Dialogue: 0,0:16:42.55,0:16:48.45,Flashbacks-207-,,0,0,0,,{Skypiea 11 - 06:59 (without the "but")}{\q2}Sembra che il grande progetto durato sei \Nanni stia per giungere alla sua conclusione.
Dialogue: 0,0:16:48.45,0:16:52.18,Flashbacks-207-,,0,0,0,,{Skypiea 11 - 07:11 (without the "so")}Sono venuto qui per dirti addio.
Dialogue: 0,0:16:56.79,0:17:00.62,Main-207-,,0,0,0,,Cos'è che desiderate, Ohm?!
Dialogue: 0,0:17:01.21,0:17:05.21,Main-207-,,0,0,0,,Hai detto... che Enel non \Nè nel tempio di Dio?!
Dialogue: 0,0:17:22.23,0:17:24.77,Main-207-,,0,0,0,,Un compagno di Cappello di Paglia?
Dialogue: 0,0:17:24.79,0:17:26.78,Main-207-,,0,0,0,,Ah... Questa l'ho sentita.{nel senso che la caduta gli ha fatto "male" (effetto) -angy}
Dialogue: 0,0:17:26.78,0:17:28.53,Main-207-,,0,0,0,,Non perdonerò mai quell'uccello.
Dialogue: 0,0:17:28.53,0:17:29.65,Main-207-,,0,0,0,,Sei tu, eh?
Dialogue: 0,0:17:33.37,0:17:34.45,Main-207-,,0,0,0,,Questo posto è...?
Dialogue: 0,0:17:39.66,0:17:41.83,Main-207-,,0,0,0,,Rovine?
Dialogue: 0,0:17:45.25,0:17:47.92,Main-207-,,0,0,0,,Qualcuno qui pare avere\N un'aria crudele.{feroce?}
Dialogue: 0,0:17:48.51,0:17:50.63,Main-207-,,0,0,0,,Ehi! Dammi l'oro!
Dialogue: 0,0:17:50.63,0:17:52.63,Main-207-,,0,0,0,,Ah aah, che tristezza.{again yare yare non è una vera parola, è tipo un sospiro a parole}
Dialogue: 0,0:17:52.63,0:17:56.64,Main-207-,,0,0,0,,Nessuno può sfuggire \Nalla mia prova del ferro.{meh}
Dialogue: 0,0:17:56.64,0:18:00.39,Main-207-,,0,0,0,,Se mi intralcerete, vi eliminerò tutti!
Dialogue: 0,0:18:00.39,0:18:05.15,Main-207-,,0,0,0,,Potresti dirmi dove si trovano \NEnel e la guardia divina?
Dialogue: 0,0:18:08.78,0:18:11.95,Main-207-,,0,0,0,,Ma che ha 'sta caverna?!
Dialogue: 0,0:18:22.83,0:18:27.21,Main-207-,,0,0,0,,Beh, signori miei, sicuramente \Navrete molto da dire, ma...
Dialogue: 0,0:18:27.21,0:18:29.21,Main-207-,,0,0,0,,se volete aver voce in capitolo,
Dialogue: 0,0:18:29.21,0:18:32.17,Main-207-,,0,0,0,,prima dovete sopravvivere!{sopravvivere qui in realtà}
Dialogue: 0,0:18:39.81,0:18:41.10,Main-207-,,0,0,0,,Andiamo, Holy.
Dialogue: 0,0:18:41.10,0:18:42.85,Main-207-,,0,0,0,,Scatenati quanto vuoi.
Dialogue: 0,0:18:44.52,0:18:46.90,Main-207-,,0,0,0,,L'obiettivo è quello, Pierre.
Dialogue: 0,0:18:46.90,0:18:50.28,Main-207-,,0,0,0,,Se non fermiamo il sacerdote di Enel, \Nnon potremo far nulla!
Dialogue: 0,0:18:54.95,0:19:00.41,Main-207-,,0,0,0,,Comunque, quel serpente gigante \Nalla fine è venuto fin qui.
Dialogue: 0,0:19:05.17,0:19:06.79,Main-207-,,0,0,0,,Maledizione!
Dialogue: 0,0:19:08.00,0:19:11.30,Main-207-,,0,0,0,,Non si rompe, eppure continua ad\N andare su e giù, a destra e a sinistra!{cps}
Dialogue: 0,0:19:13.34,0:19:15.55,Main-207-,,0,0,0,,È strana! Questa caverna!
Dialogue: 0,0:19:19.14,0:19:21.35,Main-207-,,0,0,0,,Voi tutti...
Dialogue: 0,0:19:22.77,0:19:24.27,Main-207-,,0,0,0,,sparite insieme!{ewwwwwwwwwwwwwwwwwwwwwwwwwwwwwwwwwwwwwwwwwwww}
Dialogue: 0,0:19:37.78,0:19:39.99,Main-207-,,0,0,0,,Hai un'arma piuttosto problematica.{ew}
Dialogue: 0,0:19:39.99,0:19:42.54,Main-207-,,0,0,0,,Un abitante del Mare Blu \Nche non sa nulla–!
Dialogue: 0,0:19:43.16,0:19:48.29,Main-207-,,0,0,0,,Non c'è niente qui da dare... a voi \Nche siete appena arrivati in cielo!{orrenda}
Dialogue: 0,0:19:48.29,0:19:52.63,Main-207-,,0,0,0,,Non ho proprio voglia di star a\N sentire gli affari degli altri.
Dialogue: 0,0:19:54.34,0:19:57.93,Main-207-,,0,0,0,,La situazione del cielo non ci riguarda!
Dialogue: 0,0:19:58.59,0:19:59.64,Main-207-,,0,0,0,,Infatti!
Dialogue: 0,0:20:03.35,0:20:06.56,Main-207-,,0,0,0,,L'intenzione è sempre stata ucciderti!\N Nessun problema!
Dialogue: 0,0:20:06.56,0:20:07.52,Main-207-,,0,0,0,,Crepa!
Dialogue: 0,0:20:14.65,0:20:17.11,Thoughts-207-,,0,0,0,,'Sto tizio... è più forte \Ndi quanto pensassi...{forte è una mia supposizione, non arriva a dirlo}
Dialogue: 0,0:20:29.29,0:20:30.63,Main-207-,,0,0,0,,Crepa!
Dialogue: 0,0:20:48.89,0:20:50.65,Main-207-,,0,0,0,,Giusto, lui...
Dialogue: 0,0:20:50.65,0:20:53.11,Main-207-,,0,0,0,,ha veleno nelle zanne!
Dialogue: 0,0:20:59.28,0:21:00.53,Main-207-,,0,0,0,,Anche di qua delle zanne?!
Dialogue: 0,0:21:05.45,0:21:07.75,Main-207-,,0,0,0,,Cosa?! \NMa come si muove 'sto cane?!
Dialogue: 0,0:21:09.08,0:21:11.58,Main-207-,,0,0,0,,Il suo nome è Holy.
Dialogue: 0,0:21:11.58,0:21:14.34,Main-207-,,0,0,0,,Lascia che te lo dica. \NIo sono un allevatore del cielo.{o celeste fate voi}
Dialogue: 0,0:21:14.34,0:21:16.51,Main-207-,,0,0,0,,In pratica, sono uno Sky Breeder.
Dialogue: 0,0:21:17.09,0:21:20.34,Main-207-,,0,0,0,,Non mi limito all'addestramento \Nstandard degli animali.
Dialogue: 0,0:21:20.34,0:21:25.35,Main-207-,,0,0,0,,{\q2}Oltre a camminare su due piedi perfettamente, \Ngli ho anche insegnato la boxe!
Dialogue: 0,0:21:26.10,0:21:27.60,Main-207-,,0,0,0,,Assaporala bene!
Dialogue: 0,0:21:29.68,0:21:31.31,Main-207-,,0,0,0,,Ma ci sono dei limiti, no?{si riferisce ovviamente che sta roba è un'assurdità}
Dialogue: 0,0:21:39.49,0:21:40.78,Main-207-,,0,0,0,,Gan Fall...
Dialogue: 0,0:21:41.40,0:21:44.74,Main-207-,,0,0,0,,Uno che si è fatto battere da Shura \Nnon ha ancora imparato la lezione?!
Dialogue: 0,0:21:45.58,0:21:48.83,Main-207-,,0,0,0,,Non ti è ormai quasi impossibile \Nmaneggiare la tua lancia?!
Dialogue: 0,0:21:48.83,0:21:50.08,Main-207-,,0,0,0,,Vecchio decrepito!
Dialogue: 0,0:21:50.66,0:21:52.58,Main-207-,,0,0,0,,Eppure non posso ritirarmi!
Dialogue: 0,0:21:52.58,0:21:56.29,Main-207-,,0,0,0,,Questo perché non so cosa \Nintendiate combinare ora!
Dialogue: 0,0:21:59.09,0:22:00.92,Main-207-,,0,0,0,,Non montarti la testa!
Dialogue: 0,0:22:01.55,0:22:05.85,Main-207-,,0,0,0,,Anche se lo venissi a sapere, \Nla nobile volontà di God
Dialogue: 0,0:22:06.35,0:22:08.47,Main-207-,,0,0,0,,non è per te comprensibile!
Dialogue: 0,0:22:15.90,0:22:17.69,Main-207-,,0,0,0,,Seguiteli, seguiteli!
Dialogue: 0,0:22:17.69,0:22:19.78,Main-207-,,0,0,0,,Inseguite gli Shandia!
Dialogue: 0,0:22:23.91,0:22:26.03,Main-207-,,0,0,0,,Cosa, cosa?! Che c'è?!
Dialogue: 0,0:22:26.03,0:22:27.28,Main-207-,,0,0,0,,Cos'è "bee"?!
Dialogue: 0,0:22:27.28,0:22:28.16,Main-207-,,0,0,0,,Delle capre?!
Dialogue: 0,0:22:28.16,0:22:31.20,Main-207-,,0,0,0,,Sono i soldati sacri! \NSe ci prendono, ci uccideranno!
Dialogue: 0,0:22:31.20,0:22:33.25,Main-207-,,0,0,0,,Cosa sono i soldati sacri?
Dialogue: 0,0:22:33.25,0:22:34.83,Main-207-,,0,0,0,,I tirapiedi di Enel!
Dialogue: 0,0:22:34.83,0:22:36.42,Main-207-,,0,0,0,,Veloce, scappa!
Dialogue: 0,0:22:36.42,0:22:38.92,Main-207-,,0,0,0,,A-Aspetta! Ma...
Dialogue: 0,0:22:38.92,0:22:41.51,Main-207-,,0,0,0,,Ma dov'è che stiamo andando?!
Dialogue: 0,0:22:54.77,0:22:58.69,Main-207-,,0,0,0,,Maledizione! Quel serpente... \Nsi è messo in mezzo!{è stato d'intralcio}
Dialogue: 0,0:23:10.04,0:23:11.83,Main-207-,,0,0,0,,Ehi, Chopper?!
Dialogue: 0,0:23:12.29,0:23:14.50,Main-207-,,0,0,0,,Ehi! Perché sei...?!
Dialogue: 0,0:23:16.33,0:23:17.58,Main-207-,,0,0,0,,Giusto.
Dialogue: 0,0:23:17.58,0:23:19.84,Main-207-,,0,0,0,,Un compagno del Mare Blu...
Dialogue: 0,0:23:21.59,0:23:24.05,Main-207-,,0,0,0,,Ehi... Stai attento lì.
Dialogue: 0,0:23:31.77,0:23:32.89,Main-207-,,0,0,0,,Cosa?!
Dialogue: 0,0:23:34.43,0:23:36.27,Main-207-,,0,0,0,,Filo spinato?
Dialogue: 0,0:23:37.90,0:23:40.11,Main-207-,,0,0,0,,È quella... la prova?
Dialogue: 0,0:23:40.69,0:23:41.69,Main-207-,,0,0,0,,Chopper.
Dialogue: 0,0:23:41.69,0:23:43.28,Main-207-,,0,0,0,,Ehi, Chopper!
Dialogue: 0,0:23:43.28,0:23:44.78,Main-207-,,0,0,0,,Rispondimi!
Dialogue: 0,0:23:44.78,0:23:47.61,Main-207-,,0,0,0,,Perché... sei venuto qui da solo?!
Dialogue: 0,0:23:47.61,0:23:49.07,Main-207-,,0,0,0,,Ehi!
Dialogue: 0,0:23:49.07,0:23:50.87,Main-207-,,0,0,0,,Sfortunatamente...
Dialogue: 0,0:23:54.54,0:23:56.79,Main-207-,,0,0,0,,quello è nuvola ferrea.{nuvola ferro? G - oggetti}
Dialogue: 0,0:23:57.75,0:24:01.29,Main-207-,,0,0,0,,Ha il peso di una nuvola, \Nma durezza del ferro.
Dialogue: 0,0:24:01.29,0:24:04.38,Main-207-,,0,0,0,,Può essere emessa dai Milky Dial.
Dialogue: 0,0:24:04.38,0:24:07.05,Main-207-,,0,0,0,,{\q2}Sono connessi ad un punto del terreno...
Dialogue: 0,0:24:07.05,0:24:08.80,Main-207-,,0,0,0,,e, se calpestati, si attivano.
Comment: 0,0:24:10.18,0:24:13.06,Main-207-,,0,0,0,,
Comment: 0,0:24:13.06,0:24:15.77,Main-207-,,0,0,0,,
Dialogue: 0,0:24:10.18,0:24:15.77,Main-207-,,0,0,0,,{\q2}Non è possibile sapere dove e quando un interruttore \Nsi attiverà. E non è detto che verrete attaccati.{ewwwwww e non ci sta a schermo}
Dialogue: 0,0:24:15.77,0:24:19.90,Main-207-,,0,0,0,,Quell'animale... \Nper metà l'ho sistemato io.
Dialogue: 0,0:24:20.48,0:24:23.57,Main-207-,,0,0,0,,Per il resto è stato preda \Ndella prova per conto suo.
Dialogue: 0,0:24:30.37,0:24:32.74,Main-207-,,0,0,0,,Ti è venuta voglia di vendicarti?
Dialogue: 0,0:24:33.28,0:24:34.41,Main-207-,,0,0,0,,No.
Dialogue: 0,0:24:35.29,0:24:39.17,Main-207-,,0,0,0,,Non mi piace molto \Nquel motivo per combattere.
Dialogue: 0,0:24:40.25,0:24:41.63,Main-207-,,0,0,0,,Oh.
Dialogue: 0,0:24:42.25,0:24:43.50,Main-207-,,0,0,0,,Notevole.
Dialogue: 0,0:24:43.50,0:24:44.38,Main-207-,,0,0,0,,Però...
Dialogue: 0,0:24:47.76,0:24:50.51,Main-207-,,0,0,0,,Mi sono... caricato un po'.
Comment: 0,0:25:03.02,0:25:04.15,Main-207-,,0,0,0,,
Comment: 0,0:25:04.15,0:25:06.65,Main-207-,,0,0,0,,
Dialogue: 0,0:25:03.02,0:25:06.65,Main-207-,,0,0,0,,Chiedo scusa. Qui va bene, \Ngiusto, signorina Conis?
Dialogue: 0,0:25:06.65,0:25:09.15,Main-207-,,0,0,0,,È la costa in cui devono incontrarsi.
Dialogue: 0,0:25:09.15,0:25:10.66,Main-207-,,0,0,0,,Sì, padre.
Dialogue: 0,0:25:10.66,0:25:12.87,Main-207-,,0,0,0,,Così ha detto la signorina Nami.
Dialogue: 0,0:25:13.37,0:25:15.49,Main-207-,,0,0,0,,Comunque è un gran problema...
Dialogue: 0,0:25:15.49,0:25:18.33,Main-207-,,0,0,0,,Siamo finiti noi a far da\N guardia alla nave...
Dialogue: 0,0:25:19.08,0:25:23.29,Main-207-,,0,0,0,,Finché non tornano, \Ndobbiamo difenderla a tutti i costi!
Dialogue: 0,0:25:23.29,0:25:25.67,Main-207-,,0,0,0,,Suoniamo il clacson come minaccia?
Dialogue: 0,0:25:25.67,0:25:27.59,Main-207-,,0,0,0,,Certo, padre!
Dialogue: 0,0:25:27.59,0:25:29.30,Main-207-,,0,0,0,,Dopotutto è rassicurante!
Dialogue: 0,0:25:33.72,0:25:35.72,Main-207-,,0,0,0,,Così va bene.
Dialogue: 0,0:25:40.48,0:25:43.61,Main-207-,,0,0,0,,Suu, tu puoi tenere d'occhio di là?
Dialogue: 0,0:25:49.82,0:25:53.07,Main-207-,,0,0,0,,Bene! Darò del mio meglio \Nper prendermi cura di voi!
Dialogue: 0,0:25:53.07,0:25:54.82,Main-207-,,0,0,0,,Voi due, tenete duro!
Dialogue: 0,0:26:01.87,0:26:04.54,Thoughts-207-,,0,0,0,,Spero che siate sani e salvi...
Dialogue: 0,0:26:04.54,0:26:07.67,Thoughts-207-,,0,0,0,,Chiedo scusa per quest'Isola del Cielo.
Dialogue: 0,0:26:13.64,0:26:15.30,Main-207-,,0,0,0,,Al tempio di Dio!
Dialogue: 0,0:26:16.76,0:26:19.97,Main-207-,,0,0,0,,La testa di Enel... oggi!{molto circa}
Dialogue: 0,0:26:22.19,0:26:24.90,Main-207-,,0,0,0,,Non lasciateli andare al tempio di Dio!
Dialogue: 0,0:26:25.31,0:26:29.15,Main-207-,,0,0,0,,Scalate il Giant Jack!
Dialogue: 0,0:26:34.99,0:26:38.54,Thoughts-207-,,0,0,0,,Wyper! Non usare più il Reject!
Dialogue: 0,0:26:39.62,0:26:41.37,Main-207-,,0,0,0,,Soldati sacri, tornate indietro!
Dialogue: 0,0:26:41.37,0:26:43.25,Main-207-,,0,0,0,,{\i1}{\i0}Fermate gli Shandia!
Dialogue: 0,0:26:53.13,0:26:55.34,Thoughts-207-,,0,0,0,,Non sfidare Enel, Wyper!
Dialogue: 0,0:27:01.31,0:27:02.60,Thoughts-207-,,0,0,0,,{\t(1144,0,1,\c&HE8EAEA&\3c&HE8EAEA&\4c&HE8EAEA&)}Non...
Dialogue: 0,0:27:03.14,0:27:06.02,Thoughts-207-,,0,0,0,,Non puoi... sconfiggere Enel!
Dialogue: 0,0:27:26.92,0:27:28.00,Main-207-,,0,0,0,,Esatto.
Comment: 0,0:27:28.79,0:27:30.75,Main-207-,,0,0,0,,
Comment: 0,0:27:30.75,0:27:34.97,Main-207-,,0,0,0,,
Dialogue: 0,0:27:28.79,0:27:34.97,Main-207-,,0,0,0,,Salite tutti... sulle rovine al piano\N superiore. E poi eliminatevi a vicenda.
Dialogue: 0,0:27:38.22,0:27:40.89,Main-207-,,0,0,0,,Sopravviveremo in cinque.
Dialogue: 0,0:27:44.14,0:27:48.90,Main-207-,,0,0,0,,Le profezie di Dio sono assolute.
Dialogue: 0,0:27:58.49,0:28:00.45,Main-207-,,0,0,0,,Smettila, Wyper!
Dialogue: 0,0:28:00.45,0:28:01.91,Main-207-,,0,0,0,,Io...
Dialogue: 0,0:28:01.91,0:28:04.04,Main-207-,,0,0,0,,Ma quale "io"?!
Dialogue: 0,0:28:04.04,0:28:06.25,Main-207-,,0,0,0,,Vuoi dire che non sei mio nemico?!
Dialogue: 0,0:28:06.71,0:28:11.29,Main-207-,,0,0,0,,Per noi, tu ed Enel siete \Ndella stessa pasta, Gan Fall!{orrendo, ma non mi viene un altro modo di dirlo}
Dialogue: 0,0:28:11.29,0:28:14.17,Main-207-,,0,0,0,,Non vuoi nemmeno ascoltarmi?!
Dialogue: 0,0:28:21.39,0:28:22.43,Main-207-,,0,0,0,,Bastardo!
Dialogue: 0,0:28:33.44,0:28:37.45,Main-207-,,0,0,0,,{\q2}Il Burn Bazooka non ha avuto effetto... \Nma che razza di squame ha?!{non è proprio così, specie la prima... sono un po' più collegate. è che non mi viene. io volevo "per essere [????] dal burn bazooka, che razza di squame devi avere?" ma non mi viene niente da mettere nel [????] -angy}
Dialogue: 0,0:28:42.33,0:28:47.96,Main-207-,,0,0,0,,Basta! Ora basta con 'sta caverna!
Dialogue: 0,0:29:08.10,0:29:10.35,Main-207-,,0,0,0,,Quello... cos'era?
Dialogue: 0,0:29:11.60,0:29:14.44,Main-207-,,0,0,0,,È per questo che non sopporto \Ngli abitanti del Mare Blu.
Dialogue: 0,0:29:15.36,0:29:18.99,Main-207-,,0,0,0,,Anche questa spada... \Nè di nuvola ferrea.
Dialogue: 0,0:29:18.99,0:29:20.86,Main-207-,,0,0,0,,In pratica, la lama...
Dialogue: 0,0:29:21.45,0:29:27.45,Main-207-,,0,0,0,,grazie alle nuvole ferree generate\N dal Dial nascosto nell'elsa
Dialogue: 0,0:29:27.45,0:29:29.79,Main-207-,,0,0,0,,può seguire i nemici ovunque!
Dialogue: 0,0:29:33.96,0:29:38.01,Main-207-,,0,0,0,,Hai capito? Spadaccino del Mare Blu.
Dialogue: 0,0:29:38.01,0:29:40.09,Main-207-,,0,0,0,,È come una frusta.
Comment: 0,0:29:40.09,0:29:41.38,Main-207-,,0,0,0,,
Comment: 0,0:29:41.38,0:29:44.72,Main-207-,,0,0,0,,
Dialogue: 0,0:29:40.09,0:29:44.72,Main-207-,,0,0,0,,Ho capito... che il Mare Bianco Bianco \Nè pieno di guerrieri da circo!{circa}
Dialogue: 0,0:29:51.23,0:29:52.23,Main-207-,,0,0,0,,Holy.
Dialogue: 0,0:29:53.27,0:29:54.77,Main-207-,,0,0,0,,Che ne dici di combattere separati?{cps. volendo "combattiamo separati" senza domanda anche se ci sarebbe}
Dialogue: 0,0:29:58.65,0:30:03.49,Main-207-,,0,0,0,,Queste rovine al livello superiore... \Nsi sono fatte piuttosto vivaci.
Dialogue: 0,0:30:17.00,0:30:20.80,Main-207-,,0,0,0,,{\q2}Guarda un po'... Chi avrebbe pensato che \Nci sarebbe stato anche il padrone del cielo?
Dialogue: 0,0:30:20.80,0:30:23.30,Main-207-,,0,0,0,,Le daremo una mano, Grande Ohm!
Dialogue: 0,0:30:27.76,0:30:28.97,Main-207-,,0,0,0,,Voialtri...
Dialogue: 0,0:30:30.48,0:30:32.10,Main-207-,,0,0,0,,A quanto pare, i rimanenti...
Dialogue: 0,0:30:32.10,0:30:34.85,Main-207-,,0,0,0,,Già! Pare siamo solo noi!
Dialogue: 0,0:30:34.85,0:30:38.94,Main-207-,,0,0,0,,Ti faremo raggiungere Enel, Wyper!
Dialogue: 0,0:30:45.03,0:30:48.58,Main-207-,,0,0,0,,Ah, giusto! \NScaviamo un buco e usciamo fuori!{idem con patate al discorso che facevo con chopper}
Dialogue: 0,0:30:56.04,0:30:57.63,Main-207-,,0,0,0,,Quel serpente gigante...
Dialogue: 0,0:31:02.22,0:31:04.09,Main-207-,,0,0,0,,– Sta ridendo!\N– Sta ridendo!
Dialogue: 0,0:31:09.76,0:31:11.31,Main-207-,,0,0,0,,Aspetta!
Dialogue: 0,0:31:13.06,0:31:16.02,Main-207-,,0,0,0,,Che insistenti!
Dialogue: 0,0:31:16.02,0:31:18.02,Main-207-,,0,0,0,,N-Nami?!
Dialogue: 0,0:31:18.02,0:31:18.90,Main-207-,,0,0,0,,{\pos(580,1053)}Aisa!
Dialogue: 0,0:31:18.90,0:31:20.23,Main-207-,,0,0,0,,{\pos(280,1053)}Figliola!
Dialogue: 0,0:31:20.23,0:31:21.98,Main-207-,,0,0,0,,Fatele fuori!
Dialogue: 0,0:31:38.92,0:31:41.17,Main-207-,,0,0,0,,Aisa! Che ci fai lì?!
Dialogue: 0,0:31:41.17,0:31:43.71,Main-207-,,0,0,0,,Nami! Ma perché sei qui?!
Dialogue: 0,0:31:45.09,0:31:47.01,Main-207-,,0,0,0,,Zoro! E gli altri?!
Dialogue: 0,0:31:47.01,0:31:48.18,Main-207-,,0,0,0,,Wyper!
Dialogue: 0,0:31:48.18,0:31:50.89,Main-207-,,0,0,0,,Cosa state tramando, \Nabitanti del Mare Blu?!
Dialogue: 0,0:31:51.35,0:31:53.77,Main-207-,,0,0,0,,Aisa! Allontanati da lei!
Dialogue: 0,0:32:00.90,0:32:02.28,Main-207-,,0,0,0,,Siamo salve...
Dialogue: 0,0:32:02.28,0:32:05.49,Main-207-,,0,0,0,,Demone! Wyper, sei un demone!
Dialogue: 0,0:32:05.86,0:32:08.49,Main-207-,,0,0,0,,Perché siete venute qui?
Dialogue: 0,0:32:08.49,0:32:10.45,Main-207-,,0,0,0,,"Perché"?!
Dialogue: 0,0:32:10.45,0:32:13.24,Main-207-,,0,0,0,,Perché un enorme...
Dialogue: 0,0:32:13.91,0:32:14.87,Main-207-,,0,0,0,,serpente...
Dialogue: 0,0:32:21.38,0:32:23.00,Main-207-,,0,0,0,,Quell'imbecille!
Dialogue: 0,0:32:23.84,0:32:24.96,Main-207-,,0,0,0,,Aisa!
Dialogue: 0,0:32:38.27,0:32:39.85,Main-207-,,0,0,0,,Wyper!
Dialogue: 0,0:32:43.82,0:32:47.32,Main-207-,,0,0,0,,Nemmeno in grado di badare \Na se stessi questi idioti...
Dialogue: 0,0:32:49.07,0:32:51.41,Main-207-,,0,0,0,,Lasciate perdere gli altri!
Dialogue: 0,0:32:52.41,0:32:53.91,Main-207-,,0,0,0,,Tanto nessuno...
Dialogue: 0,0:32:53.91,0:32:56.54,Main-207-,,0,0,0,,si salverà alla fine!{alla fine l'ho aggiunto io}
Comment: 0,0:00:00.00,0:00:00.00,Main-207-,,0,0,0,,{=11}===============================DIALOGUE============================
