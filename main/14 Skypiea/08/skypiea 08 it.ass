Dialogue: 0,0:22:49.18,0:22:51.02,Family Main,,0,0,0,,{=42}♪ Non siamo conoscenti, ♪
Dialogue: 0,0:22:51.02,0:22:53.18,Family Main,,0,0,0,,{=42}♪ tantomeno amici, ♪
Dialogue: 0,0:22:55.56,0:22:57.56,Family Secondary,,0,0,0,,{=42}♪ finché i mari salperem'! ♪
Dialogue: 0,0:22:53.18,0:22:56.48,Family Main,,0,0,0,,{=42}♪ quel che siamo è FAMILY ♪
Dialogue: 0,0:22:56.48,0:22:58.69,Family Main,,0,0,0,,{=42}♪ Non siam imparentati, ♪
Dialogue: 0,0:22:58.69,0:23:01.19,Family Main,,0,0,0,,{=42}♪ fratelli pure no, ♪
Dialogue: 0,0:23:01.57,0:23:05.91,Family Main,,0,0,0,,{=42}♪ qual che siamo è FAMILY ♪
Dialogue: 0,0:23:11.29,0:23:14.66,Family Main,,0,0,0,,{=42}♪ Esaminando ♪
Dialogue: 0,0:23:14.66,0:23:19.21,Family Main,,0,0,0,,{=42}♪ pur una carta nautica enorme, ♪
Dialogue: 0,0:23:19.21,0:23:21.92,Family Main,,0,0,0,,{=42}♪ dei tipi come questi qua, ♪
Dialogue: 0,0:23:21.92,0:23:24.67,Family Main,,0,0,0,,{=42}♪ scovar non riuscirai ♪
Dialogue: 0,0:23:24.67,0:23:29.47,Family Main,,0,0,0,,{=42}♪ Combinaguai di prima classe ♪
Dialogue: 0,0:23:29.47,0:23:33.10,Family Main,,0,0,0,,{=42}♪ imbaracati sul MOTHER SHIP ♪
Dialogue: 0,0:23:33.10,0:23:37.02,Family Main,,0,0,0,,{=42}♪ Il precedente buonsenso, ♪
Dialogue: 0,0:23:37.02,0:23:41.15,Family Main,,0,0,0,,{=42}♪ buttalo e vien con noi! ♪
Dialogue: 0,0:23:42.94,0:23:46.53,Family Main,,0,0,0,,{=42}♪ Everyday survival, ♪
Dialogue: 0,0:23:46.53,0:23:50.28,Family Main,,0,0,0,,{=42}♪ grandi vincite! ♪
Dialogue: 0,0:23:50.28,0:23:54.12,Family Main,,0,0,0,,{=42}♪ Il numero uno dei tesori, ♪
Dialogue: 0,0:23:54.12,0:24:00.29,Family Main,,0,0,0,,{=42}♪ acchiappiamo con MOTHER SHIP ♪
Dialogue: 0,0:24:01.42,0:24:05.22,Family Main,,0,0,0,,{=42}♪ I migliori sono quelli ♪
Dialogue: 0,0:24:05.22,0:24:11.47,Family Main,,0,0,0,,{=42}♪ con cui tu sempre riderai! ♪
Dialogue: 0,0:24:12.43,0:24:14.56,Family Main,,0,0,0,,{=42}♪ Non siamo conoscenti, ♪
Dialogue: 0,0:24:14.56,0:24:16.64,Family Main,,0,0,0,,{=42}♪ tantomeno amici, ♪
Dialogue: 0,0:24:18.90,0:24:21.86,Family Secondary,,0,0,0,,{=42}♪ finché su avventure andrem!! ♪
Dialogue: 0,0:24:16.64,0:24:20.06,Family Main,,0,0,0,,{=42}♪ Quel che siamo è FAMILY! ♪
Dialogue: 0,0:24:20.06,0:24:22.02,Family Main,,0,0,0,,{=42}♪ Non siam imparentati, ♪
Dialogue: 0,0:24:22.02,0:24:25.03,Family Main,,0,0,0,,{=42}♪ fratelli pure no, ♪
Dialogue: 0,0:24:25.03,0:24:29.32,Family Main,,0,0,0,,{=42}♪ quel che siamo è FAMILY! ♪
