Comment: 0,0:00:00.00,0:00:00.00,Main-207-,,0,0,0,,{=24}===============================DIALOGUE============================
Dialogue: 0,0:02:06.86,0:02:08.32,Main-207-,,0,0,0,,Bu bir çiçek!
Dialogue: 0,0:02:07.57,0:02:08.32,Secondary-207-,,0,0,0,,Çiçek mi?
Dialogue: 0,0:02:13.28,0:02:15.28,Main-207-,,0,0,0,,Hayır, boş ver. İnsanmış.
Dialogue: 0,0:02:15.28,0:02:16.57,Main-207-,,0,0,0,,Ne bu?
Dialogue: 0,0:02:16.57,0:02:20.12,Main-207-,,0,0,0,,Bu yaşlı adam,\Ndev kalamara tek attı...
Dialogue: 0,0:02:20.12,0:02:21.87,Main-207-,,0,0,0,,Sadece balık mı tutuyordu...
Dialogue: 0,0:02:21.87,0:02:24.96,Main-207-,,0,0,0,,yoksa bizi kurtarmak için mi yaptı?
Dialogue: 0,0:02:52.24,0:02:54.70,Main-207-,,0,0,0,,Bir şey desene lan, hıyar!
Dialogue: 0,0:02:57.66,0:03:00.20,Main-207-,,0,0,0,,S-Savaşmak istiyorsan\Nsavaşırız, şerefsiz!
Dialogue: 0,0:03:00.20,0:03:01.91,Main-207-,,0,0,0,,Toplarımız var!
Dialogue: 0,0:03:13.01,0:03:15.88,Main-207-,,0,0,0,,Savaşmasanız daha iyi olur, biri ölebilir.
Dialogue: 0,0:03:19.22,0:03:20.51,Main-207-,,0,0,0,,Öyle mi?
Dialogue: 0,0:03:20.51,0:03:21.76,Main-207-,,0,0,0,,Kim ölecek?
Dialogue: 0,0:03:21.76,0:03:22.97,Main-207-,,0,0,0,,Ben.
Dialogue: 0,0:03:22.97,0:03:24.23,Main-207-,,0,0,0,,Sen mi?!
Dialogue: 0,0:03:24.23,0:03:25.02,Main-207-,,0,0,0,,Ulan...
Dialogue: 0,0:03:25.02,0:03:26.06,Main-207-,,0,0,0,,Hey, sakinleş.
Dialogue: 0,0:03:26.06,0:03:28.48,Main-207-,,0,0,0,,Bizimle dalga geçiyor...
Dialogue: 0,0:03:29.77,0:03:31.77,Main-207-,,0,0,0,,Hey, ihtiyar!
Dialogue: 0,0:03:31.77,0:03:34.65,Main-207-,,0,0,0,,Bize kim olduğunu ve\Nnerede olduğumuzu söyle.
Dialogue: 0,0:03:44.00,0:03:45.66,Main-207-,,0,0,0,,Birine soru sorarken,
Dialogue: 0,0:03:46.33,0:03:50.50,Main-207-,,0,0,0,,nezaketen önce kendini\Ntanıtman gerekmez mi?
Dialogue: 0,0:03:50.50,0:03:53.80,Main-207-,,0,0,0,,Ha? Evet, doğru dedin.
Dialogue: 0,0:03:53.80,0:03:54.96,Main-207-,,0,0,0,,Kusura bakma.
Dialogue: 0,0:03:54.96,0:03:57.68,Main-207-,,0,0,0,,– Benim adım Crocus.\N– Ben Roro... noa...
Dialogue: 0,0:03:57.68,0:04:00.89,Main-207-,,0,0,0,,İkiz Burun'un\Ndeniz feneri bekçisiyim.
Dialogue: 0,0:04:00.89,0:04:02.72,Main-207-,,0,0,0,,71 yaşındayım ve\Nikizler burcuyum.
Dialogue: 0,0:04:02.72,0:04:05.39,Main-207-,,0,0,0,,Kan grubum AB.
Dialogue: 0,0:04:03.10,0:04:05.39,Main-207-,,0,0,0,,{\an8}Bırakın biçeyim şunu!
Dialogue: 0,0:04:03.93,0:04:05.39,Secondary-207-,,0,0,0,,{\an8}Hey, sakinleş.
Dialogue: 0,0:04:05.39,0:04:07.56,Main-207-,,0,0,0,,Nerede olduğumuzu mu sordunuz?
Dialogue: 0,0:04:08.10,0:04:15.65,Main-207-,,0,0,0,,Benim özel mekanıma dalıp\Nbir de soru mu soruyorsunuz?
Dialogue: 0,0:04:16.44,0:04:19.99,Main-207-,,0,0,0,,Bir farenin midesinde\Ngibi mi duruyoruz?
Dialogue: 0,0:04:19.99,0:04:22.83,Main-207-,,0,0,0,,O hâlde balina\Ntarafından yutulduğumuz gerçek.
Dialogue: 0,0:04:23.53,0:04:26.20,Main-207-,,0,0,0,,Ama burası cidden\Nbalinanın midesi mi?
Dialogue: 0,0:04:26.20,0:04:29.12,Main-207-,,0,0,0,,Dur bi' saniye! Ne olacak şimdi bize?!
Dialogue: 0,0:04:29.12,0:04:31.54,Main-207-,,0,0,0,,Sindirilmek istemiyorum!
Dialogue: 0,0:04:39.51,0:04:41.39,Main-207-,,0,0,0,,– Kes şunu artık!\N– Kes şunu artık!
Dialogue: 0,0:04:41.39,0:04:44.10,Main-207-,,0,0,0,,Şu tekrarlanan şakaları\Nhiç mi duymadınız çocuklar?
Dialogue: 0,0:04:44.10,0:04:44.97,Main-207-,,0,0,0,,– Şaka mıydı bu?\N– Şaka mıydı bu?
Dialogue: 0,0:04:44.97,0:04:46.97,Main-207-,,0,0,0,,Çıkış o tarafta.
Dialogue: 0,0:04:46.97,0:04:48.48,Main-207-,,0,0,0,,– Çıkabilir miyiz yani?!\N– Çıkabilir miyiz yani?!
Dialogue: 0,0:04:49.35,0:04:52.90,Main-207-,,0,0,0,,Bir saniye! Niye balinanın\Nmidesinde bir çıkış var?!
Dialogue: 0,0:04:52.90,0:04:55.19,Main-207-,,0,0,0,,Ve niye kapısı gökyüzünde?!
Dialogue: 0,0:04:55.19,0:04:57.90,Main-207-,,0,0,0,,Dur... Dikkatli baksana...
Dialogue: 0,0:04:57.90,0:05:02.16,Main-207-,,0,0,0,,Gökyüzü... Martılar...
Dialogue: 0,0:05:02.82,0:05:04.08,Main-207-,,0,0,0,,Bunlar resim!
Dialogue: 0,0:05:04.08,0:05:06.45,Main-207-,,0,0,0,,Hepsi balinanın midesine çizilmiş resimler!
Dialogue: 0,0:05:06.45,0:05:07.66,Main-207-,,0,0,0,,Ha?!
Dialogue: 0,0:05:07.66,0:05:09.29,Main-207-,,0,0,0,,Bir doktorun mizah anlayışı.
Dialogue: 0,0:05:09.29,0:05:11.67,Main-207-,,0,0,0,,Seni şerefsiz!\NBuradaki amacın ne?!
Dialogue: 0,0:05:11.67,0:05:13.38,Main-207-,,0,0,0,,Bu kadarı yeter. Görmezden gelin!
Dialogue: 0,0:05:13.38,0:05:14.46,Main-207-,,0,0,0,,Katılıyorum.
Dialogue: 0,0:05:14.46,0:05:17.00,Main-207-,,0,0,0,,Nami! Çıkışı bulduk, hadi gidelim.
Dialogue: 0,0:05:17.00,0:05:18.42,Main-207-,,0,0,0,,Aynen.
Dialogue: 0,0:05:23.05,0:05:24.51,Main-207-,,0,0,0,,Ne oluyor?!
Dialogue: 0,0:05:25.89,0:05:27.22,Main-207-,,0,0,0,,Başladı...
Dialogue: 0,0:05:28.35,0:05:29.23,Main-207-,,0,0,0,,Bakın!
Dialogue: 0,0:05:30.02,0:05:31.35,Main-207-,,0,0,0,,O bir ada değil!
Dialogue: 0,0:05:31.35,0:05:33.65,Main-207-,,0,0,0,,Gemiymiş.\NVe demirden yapılmış!
Dialogue: 0,0:05:33.65,0:05:37.15,Main-207-,,0,0,0,,Doğru ya!\NBu deniz mide asidinden oluşuyor!
Dialogue: 0,0:05:37.15,0:05:40.82,Main-207-,,0,0,0,,O zaman burada uzun süre\Nkalırsak tahtadan gemimiz eriyecek.
Dialogue: 0,0:05:40.82,0:05:43.03,Main-207-,,0,0,0,,Hey! Ne başladı?!
Dialogue: 0,0:05:43.03,0:05:45.03,Main-207-,,0,0,0,,Söylesene!
Dialogue: 0,0:05:45.70,0:05:47.20,Main-207-,,0,0,0,,Bu balina...
Dialogue: 0,0:05:48.70,0:05:53.17,Main-207-,,0,0,0,,Laboon, kafasını\NRed Line'a vurmaya başladı.
Dialogue: 0,0:06:02.59,0:06:03.51,Main-207-,,0,0,0,,– Ne?!\N– Ne?!
Dialogue: 0,0:06:03.51,0:06:07.51,Main-207-,,0,0,0,,Şimdi düşününce,\Nbalinanın alnında feci yaralar vardı.
Dialogue: 0,0:06:07.51,0:06:09.64,Main-207-,,0,0,0,,Bir de gökyüzüne doğru bağırıyordu...
Dialogue: 0,0:06:09.64,0:06:11.23,Main-207-,,0,0,0,,Bu ne demek?
Dialogue: 0,0:06:12.10,0:06:13.69,Main-207-,,0,0,0,,Acı çekiyor!
Dialogue: 0,0:06:20.74,0:06:24.11,Main-207-,,0,0,0,,Anladım!\NDemek moruk bunu amaçlıyor!
Dialogue: 0,0:06:24.11,0:06:25.03,Main-207-,,0,0,0,,Muhtemelen...
Dialogue: 0,0:06:25.03,0:06:28.08,Main-207-,,0,0,0,,Balinayı vücudunun içinden\Nöldürmeye çalışıyor!
Dialogue: 0,0:06:28.08,0:06:28.91,Main-207-,,0,0,0,,Şimdi...
Dialogue: 0,0:06:28.91,0:06:31.16,Main-207-,,0,0,0,,Ne fena bir öldürme yöntemi!
Dialogue: 0,0:06:31.16,0:06:33.54,Main-207-,,0,0,0,,Pekâlâ, gizem çözüldü.\NHemen çıkalım şuradan.
Dialogue: 0,0:06:33.54,0:06:35.37,Main-207-,,0,0,0,,Burada oyalanırsak sindirileceğiz.
Dialogue: 0,0:06:36.54,0:06:39.38,Main-207-,,0,0,0,,Bu balina avı, bizi ilgilendirmiyor.
Dialogue: 0,0:06:39.38,0:06:41.59,Main-207-,,0,0,0,,Balinayı kurtarmak da bize düşmez.
Dialogue: 0,0:06:41.59,0:06:42.88,Main-207-,,0,0,0,,Hadi gidelim.
Dialogue: 0,0:06:57.06,0:07:00.52,Main-207-,,0,0,0,,Kahretsin!\NDalgalar bu kadar şiddetliyken...
Dialogue: 0,0:07:00.52,0:07:02.65,Main-207-,,0,0,0,,kapılara ulaşabilir miyiz, bilmiyorum...?
Dialogue: 0,0:07:02.65,0:07:04.95,Main-207-,,0,0,0,,Kürek çekmemiz şart! Kürekleri alın!
Dialogue: 0,0:07:04.95,0:07:07.91,Main-207-,,0,0,0,,Hadi, çabucak gidelim!\NLuffy için endişeleniyorum.
Dialogue: 0,0:07:07.91,0:07:09.28,Main-207-,,0,0,0,,O dışarıda!
Dialogue: 0,0:07:09.28,0:07:11.24,Main-207-,,0,0,0,,Ağzından fırladığını gördüm!
Dialogue: 0,0:07:14.00,0:07:16.00,Main-207-,,0,0,0,,Yaşlı adam denize atladı!
Dialogue: 0,0:07:16.00,0:07:16.79,Main-207-,,0,0,0,,Ha?
Dialogue: 0,0:07:17.29,0:07:19.79,Main-207-,,0,0,0,,Ne yapmaya çalışıyor?\NSindirilecek.
Dialogue: 0,0:07:30.18,0:07:32.56,Main-207-,,0,0,0,,Ne?! N'oluyor?! Ha? Neden?!
Dialogue: 0,0:07:32.56,0:07:33.81,Main-207-,,0,0,0,,Başım... Başım...
Dialogue: 0,0:07:33.81,0:07:36.19,Main-207-,,0,0,0,,Başım dönüyor!
Dialogue: 0,0:07:44.19,0:07:45.44,Main-207-,,0,0,0,,Şimdi ne var?
Dialogue: 0,0:07:45.44,0:07:48.24,Main-207-,,0,0,0,,Deniz mi? Nehir mi? Kanal mı?
Dialogue: 0,0:07:58.29,0:08:02.17,Main-207-,,0,0,0,,Çok iyi. Bu kadar derine inmeyi başardık.
Dialogue: 0,0:08:02.88,0:08:04.63,Main-207-,,0,0,8,,Dinleyin, Bayan Wednesday.
Dialogue: 0,0:08:04.63,0:08:06.88,Main-207-,,0,0,0,,Bu kapıların arkasında mide var...
Dialogue: 0,0:08:06.88,0:08:09.51,Main-207-,,0,0,0,,ve o yaşlı bunak muhtemelen orada.
Dialogue: 0,0:08:09.51,0:08:12.14,Main-207-,,0,0,0,,Onu yok etmeliyiz.
Dialogue: 0,0:08:12.76,0:08:15.02,Main-207-,,0,0,10,,Hedefimiz balina.
Dialogue: 0,0:08:15.39,0:08:17.02,Main-207-,,0,0,0,,Aynen öyle, Bay 9.
Dialogue: 0,0:08:17.02,0:08:21.48,Main-207-,,0,0,0,,Bu balina, bizim kasabımızın biriciği.
Dialogue: 0,0:08:24.23,0:08:26.32,Main-207-,,0,0,0,,Hey! Moruk sudan çıktı!
Dialogue: 0,0:08:26.32,0:08:27.32,Main-207-,,0,0,0,,Boş verin.
Dialogue: 0,0:08:27.32,0:08:30.82,Main-207-,,0,0,0,,Asıl önemli olan,\Nbu kapıları nasıl açacağız?
Dialogue: 0,0:08:31.28,0:08:33.83,Main-207-,,0,0,0,,Tamam mı, Bayan Wednesday?
Dialogue: 0,0:08:33.83,0:08:36.33,Main-207-,,0,0,0,,Kapıları "Üç, iki, bir, bebek!"\Ndeyip açacağız.
Dialogue: 0,0:08:36.33,0:08:37.46,Main-207-,,0,0,0,,Tetikte ol.
Dialogue: 0,0:08:37.46,0:08:40.42,Main-207-,,0,0,0,,Anlaşıldı, Bay 9. Hazır ve nazırım.
Dialogue: 0,0:08:42.92,0:08:48.09,Main-207-,,0,0,0,,{\an8}Duramıyorum!!!
Dialogue: 0,0:08:44.05,0:08:45.71,Main-207-,,0,0,0,,Bu ses de ne, Bay 9?
Dialogue: 0,0:08:45.71,0:08:48.09,Main-207-,,0,0,0,,Bilmiyorum, Bayan Wednesday.
Dialogue: 0,0:08:58.31,0:08:59.44,Main-207-,,0,0,0,,Yine mi...?
Dialogue: 0,0:09:01.98,0:09:03.77,Main-207-,,0,0,0,,Bu hiç iyi değil, Bayan Wednesday!
Dialogue: 0,0:09:03.77,0:09:06.32,Main-207-,,0,0,0,,Altımızda mide asidinden bir deniz var!
Dialogue: 0,0:09:07.90,0:09:08.74,Main-207-,,0,0,0,,Luffy?
Dialogue: 0,0:09:08.74,0:09:11.32,Main-207-,,0,0,0,,Hey! Yani herkes iyi mi?
Dialogue: 0,0:09:12.36,0:09:14.74,Main-207-,,0,0,0,,Her neyse... yardım edin!
Dialogue: 0,0:09:19.29,0:09:23.00,Main-207-,,0,0,0,,Luffy ile birlikte\Niki tuhaf tip daha ortaya çıktı.
Dialogue: 0,0:09:23.00,0:09:25.17,Main-207-,,0,0,0,,Hey! Yaşlı adam kayboldu!
Dialogue: 0,0:09:25.17,0:09:28.21,Main-207-,,0,0,0,,Boş ver onu! Hadi Luffy'i kurtaralım!
Dialogue: 0,0:09:42.90,0:09:44.94,Main-207-,,0,0,0,,Dur, Laboon.
Dialogue: 0,0:09:45.52,0:09:48.53,Main-207-,,0,0,0,,Artık kendine zarar verme.
Dialogue: 0,0:09:48.53,0:09:50.99,Main-207-,,0,0,0,,Çok az sakinleştirici iğne kaldı.
Dialogue: 0,0:09:50.99,0:09:53.45,Main-207-,,0,0,0,,Daha fazla yapmam lazım...
Dialogue: 0,0:09:55.95,0:09:59.54,Main-207-,,0,0,0,,O duvar, dünyadaki okyanusları ayırır.
Dialogue: 0,0:09:59.54,0:10:04.54,Main-207-,,0,0,0,,Ölene kadar toslasan bile\Nkıramazsın, Laboon.
Dialogue: 0,0:10:09.46,0:10:10.84,Main-207-,,0,0,0,,Sakinleşti.
Dialogue: 0,0:10:10.84,0:10:12.59,Main-207-,,0,0,0,,Balina sessizleşti.
Dialogue: 0,0:10:12.59,0:10:14.47,Main-207-,,0,0,0,,Görünüşe bakılırsa öyle.
Dialogue: 0,0:10:14.97,0:10:16.10,Main-207-,,0,0,0,,Şimdi...
Dialogue: 0,0:10:17.01,0:10:20.56,Main-207-,,0,0,0,,Sizi de kurtardık ama siz kimsiniz?
Dialogue: 0,0:10:21.39,0:10:24.35,Main-207-,,0,0,0,,Bay 9, bunlar korsan.
Dialogue: 0,0:10:24.35,0:10:26.52,Main-207-,,0,0,0,,B-Biliyorum, Bayan Wednesday.
Dialogue: 0,0:10:27.23,0:10:32.03,Main-207-,,0,0,0,,A-Ama onlarla konuşursak\Nbizi anlarlar... belki...
Dialogue: 0,0:10:32.03,0:10:34.49,Main-207-,,0,0,0,,Siz eşkıyalar hâlâ burada mısınız?!
Dialogue: 0,0:10:35.20,0:10:37.41,Main-207-,,0,0,0,,Kaç kez daha söyleyeceğim?!
Dialogue: 0,0:10:37.99,0:10:42.58,Main-207-,,0,0,0,,Ben hayatta olduğum müddetçe\NLaboon'un kılına bile dokunamazsınız!
Dialogue: 0,0:10:45.17,0:10:46.38,Main-207-,,0,0,0,,Geri geldi.
Dialogue: 0,0:10:46.38,0:10:48.04,Main-207-,,0,0,0,,Kim bu ihtiyar?
Dialogue: 0,0:10:50.00,0:10:52.92,Main-207-,,0,0,0,,İstediğini söyle, öylece gidemeyiz.
Dialogue: 0,0:10:52.92,0:10:55.63,Main-207-,,0,0,0,,Bu balinayı indirmek bizim görevimiz.
Dialogue: 0,0:10:55.63,0:10:58.51,Main-207-,,0,0,0,,Bu sefer balina avımıza\Nengel olamayacaksın!
Dialogue: 0,0:10:58.51,0:11:01.56,Main-207-,,0,0,0,,Midesinde bir delik açacağız!
Dialogue: 0,0:11:01.56,0:11:03.31,Main-207-,,0,0,0,,Hadi, bebek!
Dialogue: 0,0:11:02.35,0:11:03.31,Secondary-207-,,0,0,0,,Anlaşıldı!
Dialogue: 0,0:11:09.02,0:11:11.15,Main-207-,,0,0,0,,Şerefsizler!
Dialogue: 0,0:11:15.49,0:11:17.66,Main-207-,,0,0,0,,İhtiyar, mermilere kafa attı...!
Dialogue: 0,0:11:17.66,0:11:20.16,Main-207-,,0,0,0,,Acaba... balinayı mı istiyor?!
Dialogue: 0,0:11:23.58,0:11:25.12,Main-207-,,0,0,0,,Bu anlamsız direnişi kes!
Dialogue: 0,0:11:25.12,0:11:27.29,Main-207-,,0,0,0,,Balinayı istediğin kadar koru!
Dialogue: 0,0:11:27.83,0:11:31.05,Main-207-,,0,0,0,,Onu kasabamız için yemeğe çevireceğiz!
Dialogue: 0,0:11:37.18,0:11:38.43,Main-207-,,0,0,0,,Ne oluyor?
Dialogue: 0,0:11:46.39,0:11:47.90,Main-207-,,0,0,0,,Sadece...
Dialogue: 0,0:11:47.90,0:11:49.15,Main-207-,,0,0,0,,içimden geldi.
Dialogue: 0,0:11:54.07,0:11:57.82,Main-207-,,0,0,0,,Beni kurtardığınız için\Nteşekkür ederim... ama neden?
Dialogue: 0,0:11:57.82,0:11:59.41,Main-207-,,0,0,0,,Niyetim o değildi.
Dialogue: 0,0:11:59.41,0:12:01.70,Main-207-,,0,0,0,,Sadece onları sevmedim.
Dialogue: 0,0:12:02.74,0:12:05.66,Secondary-207-,,0,0,0,,{\an8}Hey, Luffy! Napıyorsun?
Dialogue: 0,0:12:06.96,0:12:08.58,Secondary-207-,,0,0,0,,{\an8}Kes şunu!
Dialogue: 0,0:12:08.58,0:12:12.00,Secondary-207-,,0,0,0,,{\an8}Hey! Hey, Luffy! Dursana!
Dialogue: 0,0:12:12.00,0:12:14.26,Secondary-207-,,0,0,0,,{\an8}Ne yapmaya çalışıyorsun?
Dialogue: 0,0:12:14.26,0:12:16.01,Secondary-207-,,0,0,0,,{\an8}O başkasına ait.
Dialogue: 0,0:12:02.74,0:12:05.66,Main-207-,,0,0,0,,Söylesene, kim bunlar?
Dialogue: 0,0:12:05.66,0:12:08.58,Main-207-,,0,0,0,,Balinanın içinde ne yapıyorsun?
Dialogue: 0,0:12:08.58,0:12:12.00,Main-207-,,0,0,0,,Onlar yakındaki bir kasabadan eşkıyalar.
Dialogue: 0,0:12:12.00,0:12:14.80,Main-207-,,0,0,0,,Balina eti peşindeler.
Dialogue: 0,0:12:14.80,0:12:17.13,Main-207-,,0,0,0,,Eğer Laboon'u yakalarlarsa,
Dialogue: 0,0:12:17.13,0:12:20.76,Main-207-,,0,0,0,,kasaba halkını 2-3 ay doyururlar.
Dialogue: 0,0:12:21.14,0:12:22.05,Main-207-,,0,0,0,,Laboon mu?
Dialogue: 0,0:12:22.05,0:12:24.14,Main-207-,,0,0,0,,Bu balinanın adı.
Dialogue: 0,0:12:24.14,0:12:29.48,Main-207-,,0,0,0,,O bir ada balinası,\Nsadece Batı Mavi'de yaşayan bir tür.
Dialogue: 0,0:12:29.48,0:12:32.23,Main-207-,,0,0,0,,Onlar dünyanın en büyük balinaları.
Dialogue: 0,0:12:32.23,0:12:35.36,Main-207-,,0,0,0,,Et için avlanılmasına müsaade etmeyeceğim.
Dialogue: 0,0:12:35.78,0:12:39.11,Main-207-,,0,0,0,,Red Line'a toslamasının bir sebebi var...
Dialogue: 0,0:12:39.11,0:12:44.33,Main-207-,,0,0,0,,Ve Reverse Mountain'a bağırmasının da...
Dialogue: 0,0:12:44.33,0:12:45.08,Main-207-,,0,0,0,,Sebebi mi?
Dialogue: 0,0:12:45.08,0:12:46.29,Main-207-,,0,0,0,,Evet.
Dialogue: 0,0:12:46.66,0:12:52.21,Main-207-,,0,0,0,,{\fad(0,1352)}O, insan kalbine sahip bir balina.
Dialogue: 0,0:12:52.63,0:12:57.63,Main-207-,,0,0,0,,Sadakatle bir grup korsanın\Ngelmesini bekliyor.
Dialogue: 0,0:13:01.30,0:13:03.51,Main-207-,,0,0,0,,50 yıl oldu...
Dialogue: 0,0:13:03.97,0:13:08.48,Main-207-,,0,0,0,,Anlatayım... Laboon'un hikayesini...
Dialogue: 0,0:13:21.99,0:13:26.66,Main-207-,,0,0,0,,Günlerden bir gün, bekçi olarak\Ngörevime devam ederken,
Dialogue: 0,0:13:26.66,0:13:31.04,Main-207-,,0,0,0,,bazı iyi yürekli korsanlar, \NReverse Mountain'dan indiler...
Dialogue: 0,0:13:31.04,0:13:33.71,Main-207-,,0,0,0,,ve Grand Line'a girdiler.
Dialogue: 0,0:13:33.71,0:13:38.34,Main-207-,,0,0,0,,Arkalarından da onları takip eden\Nminik bir balina geldi...
Dialogue: 0,0:13:38.34,0:13:40.92,Main-207-,,0,0,0,,O Laboon'du.
Dialogue: 0,0:13:41.76,0:13:45.97,Main-207-,,0,0,0,,Daha önce de söylediğim gibi,\Nada balinası en büyük balina türüdür,
Dialogue: 0,0:13:45.97,0:13:47.64,Main-207-,,0,0,0,,ve sadece Batı Mavi'de yaşar.
Dialogue: 0,0:13:48.64,0:13:52.64,Main-207-,,0,0,0,,Korsanlar, Laboon ile seyahat ediyorlardı...
Dialogue: 0,0:13:52.64,0:13:59.36,Main-207-,,0,0,0,,ama Grand Line, çok tehlikeli olduğu\Niçin onu Batı Mavi'de bıraktılar.
Dialogue: 0,0:13:59.36,0:14:01.78,Main-207-,,0,0,0,,Ama Laboon,\Ngizliden takibe devam etti.
Dialogue: 0,0:14:02.78,0:14:07.83,Main-207-,,0,0,0,,{\t(4654,0,1,\3c&HFFFFFF&\4c&HFFFFFF&)\t(4988,5029,\alpha&HFF&)}Ada balinaları genelde\Ngrup olarak hareket ederler...
Dialogue: 0,0:14:08.37,0:14:13.29,Main-207-,,0,0,0,,{\t(4528,0,1,\c&HFEFEFE&\3c&HFEFEFE&\4c&HFEFEFE&)\t(4862,4903,\alpha&HFF&)}ama galiba Laboon,\No korsan tayfasını ailesi olarak gördü.
Dialogue: 0,0:14:13.29,0:14:18.63,Main-207-,,0,0,0,,{\c&HFCFEFE&\3c&HFCFEFE&\4c&HFCFEFE&\t(0,317,1,\c&HFFFFFF&\3c&H000000&\4c&H000000&)}Gemileri arızalandığı için\Nburada birkaç ay boyunca kaldılar.
Dialogue: 0,0:14:18.63,0:14:22.38,Main-207-,,0,0,0,,O dönemde yakın arkadaş olduk.
Dialogue: 0,0:14:24.01,0:14:26.97,Main-207-,,0,0,0,,Bu yüzden, ayrılacakları gün...
Dialogue: 0,0:14:27.60,0:14:29.60,Flashbacks-207-,,0,0,0,,Sana güveniyorum ve bir ricam var.
Dialogue: 0,0:14:29.60,0:14:32.23,Flashbacks-207-,,0,0,0,,Ona 2-3 yıl göz kulak olur musun?
Dialogue: 0,0:14:32.77,0:14:36.31,Flashbacks-207-,,0,0,0,,Dünyayı dolaşıp mutlaka geri geleceğiz.
Dialogue: 0,0:14:37.44,0:14:40.11,Flashbacks-207-,,0,0,0,,Dinle, Laboon.\NSana diyeceklerim var.
Dialogue: 0,0:14:40.11,0:14:43.70,Flashbacks-207-,,0,0,0,,Grand Line'a gireceğiz ve\Ndünyanın etrafını tavaf edeceğiz.
Dialogue: 0,0:14:43.70,0:14:46.12,Flashbacks-207-,,0,0,0,,Ama bizi burada beklemen gerekiyor.
Dialogue: 0,0:14:46.45,0:14:48.37,Flashbacks-207-,,0,0,0,,Tehlikeli bir yere gidiyoruz.
Dialogue: 0,0:14:48.37,0:14:50.70,Flashbacks-207-,,0,0,0,,Sana uygun değil.
Dialogue: 0,0:14:51.33,0:14:54.16,Flashbacks-207-,,0,0,0,,Endişelenme. Üç yıl göz açıp\Nkapayıncaya kadar geçer.
Dialogue: 0,0:14:54.16,0:14:55.42,Flashbacks-207-,,0,0,0,,Bizi unutma...
Dialogue: 0,0:14:55.92,0:14:58.67,Flashbacks-207-,,0,0,0,,Bir arada olmasak bile\Nher zaman arkadaş olacağız.
Dialogue: 0,0:15:03.13,0:15:04.63,Flashbacks-207-,,0,0,0,,Hadi, biz kaçtık!
Dialogue: 0,0:15:08.39,0:15:10.47,Flashbacks-207-,,0,0,0,,Millet! Yola koyulalım!
Dialogue: 0,0:15:10.47,0:15:12.02,Flashbacks-207-,,0,0,0,,Çapayı çekin!
Dialogue: 0,0:15:12.02,0:15:13.48,Flashbacks-207-,,0,0,0,,– Tamam!\N– Tamam!
Dialogue: 0,0:15:17.69,0:15:18.94,Flashbacks-207-,,0,0,0,,Laboon!
Dialogue: 0,0:15:20.15,0:15:22.23,Flashbacks-207-,,0,0,0,,Laboon! Bekle bizi!
Dialogue: 0,0:15:22.23,0:15:24.70,Flashbacks-207-,,0,0,0,,Mutlaka geri döneceğiz!
Dialogue: 0,0:15:24.70,0:15:26.32,Flashbacks-207-,,0,0,0,,Sözüm söz!
Dialogue: 0,0:15:38.88,0:15:41.80,Main-207-,,0,0,0,,Bu, 50 uzun yıl önceydi...
Dialogue: 0,0:15:41.80,0:15:43.05,Main-207-,,0,0,0,,50 yıl mı?
Dialogue: 0,0:15:43.05,0:15:46.43,Main-207-,,0,0,0,,Laboon onları 50 yıldır bekliyor mu?
Dialogue: 0,0:15:46.43,0:15:50.47,Main-207-,,0,0,0,,Bu yüzden mi bağırıp duvara tosluyor?
Dialogue: 0,0:15:50.47,0:15:51.26,Main-207-,,0,0,0,,Evet.
Dialogue: 0,0:16:00.69,0:16:02.44,Main-207-,,0,0,0,,Ne muhteşem bir kanal.
Dialogue: 0,0:16:02.44,0:16:05.49,Main-207-,,0,0,0,,Bu kadar büyük bir delikle\Nhayatta kalmasına şaşırdım.
Dialogue: 0,0:16:05.49,0:16:07.11,Main-207-,,0,0,0,,Bu da mı mizah anlayışındı?
Dialogue: 0,0:16:07.11,0:16:08.95,Main-207-,,0,0,0,,"Doktor"un mizah anlayışı.
Dialogue: 0,0:16:08.95,0:16:09.82,Main-207-,,0,0,0,,Doktor mu?
Dialogue: 0,0:16:09.82,0:16:12.08,Main-207-,,0,0,0,,Öyle görünmeyebilirim\Nama ben doktorum.
Dialogue: 0,0:16:12.08,0:16:15.33,Main-207-,,0,0,0,,Yıllar önce Burun'da\Nbir klinik işletiyordum.
Dialogue: 0,0:16:15.33,0:16:17.96,Main-207-,,0,0,0,,Birkaç yıl gemi doktorluğu da yaptım.
Dialogue: 0,0:16:17.96,0:16:19.17,Main-207-,,0,0,0,,Harbi mi?
Dialogue: 0,0:16:19.67,0:16:21.75,Main-207-,,0,0,0,,O hâlde gemimizin doktoru ol!
Dialogue: 0,0:16:21.75,0:16:23.55,Main-207-,,0,0,0,,Saçmalama.
Dialogue: 0,0:16:23.55,0:16:27.72,Main-207-,,0,0,0,,Artık sizin gibi pervasızca\Nşeyler yapacak yaşta değilim.
Dialogue: 0,0:16:27.72,0:16:31.01,Main-207-,,0,0,0,,Doktor ha?\NDemek ondan balinanın içi bu halde...
Dialogue: 0,0:16:31.01,0:16:32.72,Main-207-,,0,0,0,,Yani onca şey tedavi amaçlı mı?
Dialogue: 0,0:16:33.18,0:16:34.72,Main-207-,,0,0,0,,Doğru.
Dialogue: 0,0:16:34.72,0:16:40.40,Main-207-,,0,0,0,,Balina bu kadar büyük olunca\Ndışarıdan tedavisi imkânsız oluyor.
Dialogue: 0,0:16:41.15,0:16:42.52,Main-207-,,0,0,0,,Kapıları açacağım.
Dialogue: 0,0:16:53.45,0:16:55.20,Main-207-,,0,0,0,,Sonunda!!
Dialogue: 0,0:16:55.20,0:16:57.62,Main-207-,,0,0,0,,Gerçek gökyüzü!
Dialogue: 0,0:17:06.42,0:17:08.30,Main-207-,,0,0,0,,Bayan Wednesday, ne olu...
Dialogue: 0,0:17:10.55,0:17:12.72,Main-207-,,0,0,0,,50 yıl, ha....?
Dialogue: 0,0:17:12.72,0:17:15.18,Main-207-,,0,0,0,,Korsanlar onu harbiden çok bekletmişler...
Dialogue: 0,0:17:15.18,0:17:16.43,Main-207-,,0,0,0,,Aptal!
Dialogue: 0,0:17:16.43,0:17:18.52,Main-207-,,0,0,0,,Burası Grand Line.
Dialogue: 0,0:17:18.85,0:17:20.27,Main-207-,,0,0,0,,Çoktan ölmüşlerdir.
Dialogue: 0,0:17:20.27,0:17:23.61,Main-207-,,0,0,0,,Ne kadar beklerse beklesin,\Ngelmeyecekler.
Dialogue: 0,0:17:23.61,0:17:26.32,Main-207-,,0,0,0,,Niye bu kadar umutsuz konuştun ki?!
Dialogue: 0,0:17:26.69,0:17:28.61,Main-207-,,0,0,0,,Öldüklerinden emin değiliz!
Dialogue: 0,0:17:28.61,0:17:30.45,Main-207-,,0,0,0,,Belki de geri gelecekler!
Dialogue: 0,0:17:30.45,0:17:32.36,Main-207-,,0,0,0,,Çok dokunaklı bir hikaye!
Dialogue: 0,0:17:32.36,0:17:35.58,Main-207-,,0,0,0,,Arkadaşlarının verdiği sözü\Ntutacaklarına inanan bir balina...
Dialogue: 0,0:17:35.58,0:17:37.70,Main-207-,,0,0,0,,Değil mi, ihtiyar?!
Dialogue: 0,0:17:37.70,0:17:39.04,Main-207-,,0,0,0,,Evet...
Dialogue: 0,0:17:39.04,0:17:42.29,Main-207-,,0,0,0,,Ama gerçekler acıdır.
Dialogue: 0,0:17:42.29,0:17:46.92,Main-207-,,0,0,0,,Güvenilir bir kaynaktan teyit ettim.
Dialogue: 0,0:17:46.92,0:17:50.01,Main-207-,,0,0,0,,Grand Line'dan kaçmışlar...
Dialogue: 0,0:17:50.01,0:17:51.55,Main-207-,,0,0,0,,Olamaz...
Dialogue: 0,0:17:51.55,0:17:54.47,Main-207-,,0,0,0,,{\fad(0,984)}Onu bırakıp gitmiş olamazlar değil mi?!
Dialogue: 0,0:17:55.72,0:17:57.81,Main-207-,,0,0,0,,Grand Line'dan kaçmışlar...
Dialogue: 0,0:17:57.81,0:18:00.18,Main-207-,,0,0,0,,Yani Calm Belt'i aşıp hayatta kaldılar mı?
Dialogue: 0,0:18:00.18,0:18:02.64,Main-207-,,0,0,0,,Hayatta olsalar bile,
Dialogue: 0,0:18:02.64,0:18:05.11,Main-207-,,0,0,0,,geri döneceklerinden şüpheliyim.
Dialogue: 0,0:18:05.11,0:18:08.32,Main-207-,,0,0,0,,Mevsimler. Hava durumu.\NAkıntı. Rüzgârın yönü.
Dialogue: 0,0:18:08.32,0:18:10.57,Main-207-,,0,0,0,,Hepsi o kadar tahmin edilemez ki...
Dialogue: 0,0:18:10.57,0:18:13.95,Main-207-,,0,0,0,,Grand Line'da sağduyu işe yaramaz.
Dialogue: 0,0:18:13.95,0:18:18.79,Main-207-,,0,0,0,,Grand Line'ın dehşeti,\Niradesi zayıf olanlara hiç acımaz.
Dialogue: 0,0:18:18.79,0:18:22.41,Main-207-,,0,0,0,,İradeleri zayıf olduğu için\Nverdikleri sözden dönerek...
Dialogue: 0,0:18:22.41,0:18:26.29,Main-207-,,0,0,0,,kendi kıçlarını kurtarmak için kaçtılar.
Dialogue: 0,0:18:28.09,0:18:30.84,Main-207-,,0,0,0,,Balinayı terk mi ettiler?!
Dialogue: 0,0:18:30.84,0:18:33.47,Main-207-,,0,0,0,,50 yıldır onları beklemişken mi?!
Dialogue: 0,0:18:33.47,0:18:34.68,Main-207-,,0,0,0,,Çok gaddarca!
Dialogue: 0,0:18:35.22,0:18:38.47,Main-207-,,0,0,0,,Gelmeyeceklerini biliyorsan,\Nbunu niye ona söylemedin?
Dialogue: 0,0:18:38.81,0:18:41.60,Main-207-,,0,0,0,,Bu balina, insanların dediklerini anlıyor, değil mi?
Dialogue: 0,0:18:41.93,0:18:43.27,Main-207-,,0,0,0,,Ona söyledim.
Dialogue: 0,0:18:43.27,0:18:45.73,Main-207-,,0,0,0,,Tüm hikâyeyi anlattım.
Dialogue: 0,0:18:46.31,0:18:48.52,Flashbacks-207-,,0,0,0,,Laboon! Dinle beni!
Dialogue: 0,0:18:48.52,0:18:51.57,Flashbacks-207-,,0,0,0,,Duydum ki Grand Line'ı terketmişler.
Dialogue: 0,0:18:52.11,0:18:54.45,Flashbacks-207-,,0,0,0,,Sizler yakın arkadaştınız...
Dialogue: 0,0:18:54.78,0:18:58.45,Flashbacks-207-,,0,0,0,,ve sana verdikleri söz emin ol gerçekti.
Dialogue: 0,0:19:04.54,0:19:06.33,Flashbacks-207-,,0,0,0,,Ama korkarım ki...
Dialogue: 0,0:19:06.92,0:19:08.84,Flashbacks-207-,,0,0,0,,asla geri dönmeyecekler...
Dialogue: 0,0:19:29.11,0:19:31.78,Flashbacks-207-,,0,0,0,,Aç kulaklarını da dinle, Laboon!
Dialogue: 0,0:19:31.78,0:19:33.49,Flashbacks-207-,,0,0,0,,Gelmeyecek–
Dialogue: 0,0:19:42.58,0:19:45.25,Flashbacks-207-,,0,0,0,,Kabullenemiyorsun, biliyorum.
Dialogue: 0,0:19:46.00,0:19:49.38,Flashbacks-207-,,0,0,0,,Ama artık kabullenmek zorundasın...
Dialogue: 0,0:19:50.04,0:19:50.75,Flashbacks-207-,,0,0,0,,Laboon!
Dialogue: 0,0:19:55.30,0:19:56.84,Flashbacks-207-,,0,0,0,,Laboon!
Dialogue: 0,0:20:07.10,0:20:12.94,Main-207-,,0,0,0,,O günden sonra\NReverse Mountain'a bağırmaya ve...
Dialogue: 0,0:20:12.94,0:20:16.57,Main-207-,,0,0,0,,Red Line'a toslamaya başladı.
Dialogue: 0,0:20:16.57,0:20:18.49,Main-207-,,0,0,0,,Sanki duvarın ötesinden...
Dialogue: 0,0:20:18.49,0:20:23.24,Main-207-,,0,0,0,,geleceklermiş gibi diretircesine...
Dialogue: 0,0:20:23.83,0:20:25.12,Main-207-,,0,0,0,,Ne balinaymış be...
Dialogue: 0,0:20:25.12,0:20:27.29,Main-207-,,0,0,0,,Beklemenin bir anlamı olmasa bile...
Dialogue: 0,0:20:27.29,0:20:31.25,Main-207-,,0,0,0,,{\q2}Bana inanmayı reddediyor çünkü haklıysam\Nbeklemesinin bir anlamı kalmıyor.
Dialogue: 0,0:20:31.92,0:20:35.92,Main-207-,,0,0,0,,Her şeyden çok bundan korkuyor.
Dialogue: 0,0:20:35.92,0:20:38.22,Main-207-,,0,0,0,,Laboon, Batı Mavi'den.
Dialogue: 0,0:20:38.63,0:20:40.59,Main-207-,,0,0,0,,Oraya geri dönmesinin imkânı yok.
Dialogue: 0,0:20:40.59,0:20:46.73,Main-207-,,0,0,0,,{\q2}O korsanlar, onun için sadece birer dost değil,\Naynı zamanda evine dönme umuduydu.
Dialogue: 0,0:20:46.73,0:20:50.73,Main-207-,,0,0,0,,Bu zavallı balinanın durumu bir kenara,
Dialogue: 0,0:20:50.73,0:20:53.52,Main-207-,,0,0,0,,sen de yüzüstü bırakılmış\Nhissediyorsun, değil mi?
Dialogue: 0,0:20:55.86,0:20:58.45,Main-207-,,0,0,0,,Onun için yeterince uğraşmadın mı?
Dialogue: 0,0:20:58.45,0:21:01.11,Main-207-,,0,0,0,,Alnındaki yaralara baksanıza!
Dialogue: 0,0:21:01.11,0:21:06.54,Main-207-,,0,0,0,,Kafasını vurmaya devam ederse\Nöleceği aşikâr.
Dialogue: 0,0:21:06.54,0:21:09.87,Main-207-,,0,0,0,,Tuhaf bir ilişki ama\N50 yıldır onun yanındayım.
Dialogue: 0,0:21:09.87,0:21:11.92,Main-207-,,0,0,0,,Durup ölmesine göz yumamam.
Dialogue: 0,0:21:14.75,0:21:16.38,Main-207-,,0,0,0,,N'apıyor yine bu salak?
Dialogue: 0,0:21:16.38,0:21:18.13,Main-207-,,0,0,0,,İki saniye boş bırakmaya gelmiyor...
Dialogue: 0,0:21:18.13,0:21:20.09,Main-207-,,0,0,0,,Kendini dağcı mı sanıyor?
Dialogue: 0,0:21:21.89,0:21:24.51,Main-207-,,0,0,0,,{\fad(150,150)}Lastik-Lastik...
Dialogue: 0,0:21:24.51,0:21:26.60,Main-207-,,0,0,0,,{\fad(150,150)}Çiçek Demeti!
Dialogue: 0,0:21:26.93,0:21:28.73,Main-207-,,0,0,0,,Gemi direği değil mi o?
Dialogue: 0,0:21:28.73,0:21:30.73,Main-207-,,0,0,0,,Evet. Bizim geminin.
Dialogue: 0,0:21:30.73,0:21:32.02,Main-207-,,0,0,0,,Ana direk...
Dialogue: 0,0:21:32.35,0:21:34.65,Main-207-,,0,0,0,,Hey! Gemiyi parçalama!
Dialogue: 0,0:21:41.45,0:21:43.91,Main-207-,,0,0,0,,– Ne yapıyorsun be?!\N– Ne yapıyorsun be?!
Dialogue: 0,0:21:54.71,0:21:55.79,Main-207-,,0,0,0,,Lan...?! Hey, çocuk!
Dialogue: 0,0:21:56.17,0:21:59.21,Main-207-,,0,0,0,,Endişelenme! Ezilerek ölmez!
Dialogue: 0,0:22:04.01,0:22:04.85,Main-207-,,0,0,0,,Ahmak!
Dialogue: 0,0:22:11.60,0:22:13.02,Main-207-,,0,0,0,,Ne düşünüyor ki?
Dialogue: 0,0:22:17.07,0:22:20.24,Main-207-,,0,0,0,,Luffy! Ne yaptığını sanıyorsun?!
Dialogue: 0,0:22:25.07,0:22:26.20,Main-207-,,0,0,0,,Berabere!
Dialogue: 0,0:22:31.00,0:22:32.29,Main-207-,,0,0,0,,Baya güçlüyüm, ha?
Dialogue: 0,0:22:34.37,0:22:36.79,Main-207-,,0,0,0,,Dövüşümüz bitmedi!
Dialogue: 0,0:22:36.79,0:22:38.80,Main-207-,,0,0,0,,Sonra hesaplaşırız!
Dialogue: 0,0:22:38.80,0:22:42.38,Main-207-,,0,0,0,,Arkadaşların ölmüş olabilir ama ben,\Nher zaman senin rakibinim!
Dialogue: 0,0:22:42.38,0:22:46.60,Main-207-,,0,0,0,,Bir gün, kesinlikle bunu çözüp\Nkim daha güçlüymüş görmeliyiz.
Dialogue: 0,0:22:46.60,0:22:50.39,Main-207-,,0,0,0,,Grand Line'ı dolaşıp,\Nseni görmeye geri geleceğiz.
Dialogue: 0,0:22:51.73,0:22:53.69,Main-207-,,0,0,0,,Geri döndüğümde, tekrar dövüşelim!
Dialogue: 0,0:23:09.28,0:23:10.45,Main-207-,,0,0,0,,Harika.
Dialogue: 0,0:23:10.45,0:23:14.33,Main-207-,,0,0,0,,Bu sembol,\Ntekrar dövüşeceğimizin sözü!
Dialogue: 0,0:23:14.33,0:23:20.34,Main-207-,,0,0,0,,Biz geri dönene dek, kafanı \Ntoslama da silinmesin. Anlaştık mı?!
Dialogue: 0,0:23:23.76,0:23:25.51,Main-207-,,0,0,0,,Pekâlâ!
Dialogue: 0,0:23:27.39,0:23:28.51,Main-207-,,0,0,0,,Nereye gittiler, onlar?
Dialogue: 0,0:23:28.51,0:23:29.97,Main-207-,,0,0,0,,"Onlar" mı?
Dialogue: 0,0:23:29.97,0:23:31.85,Main-207-,,0,0,0,,Ah, o garip tipleri mi diyorsun?
Dialogue: 0,0:23:31.85,0:23:33.35,Main-207-,,0,0,0,,Herhâlde kaçtılar?
Dialogue: 0,0:23:33.35,0:23:36.65,Main-207-,,0,0,0,,Ne iş çevirdiklerini hiç öğrenemedik de...?
Dialogue: 0,0:23:39.56,0:23:42.86,Main-207-,,0,0,0,,Bayan Wednesday, ne yapacağız?
Dialogue: 0,0:23:45.15,0:23:48.91,Main-207-,,0,0,0,,En azından geri dönüp\Npatrona rapor vermek zorundayız.
Dialogue: 0,0:23:48.91,0:23:51.66,Main-207-,,0,0,0,,Bu görevi çoktan tamamlamalıydık.
Dialogue: 0,0:23:51.66,0:23:55.62,Main-207-,,0,0,0,,Haklısın. Hain olarak damgalanırsak\Nbizim için çok kötü olur.
Dialogue: 0,0:23:56.00,0:23:56.75,Main-207-,,0,0,0,,Evet.
Dialogue: 0,0:23:56.75,0:24:00.09,Main-207-,,0,0,0,,Silahlarımızı kaybettiğimiz için\Nüsse dönüp baştan başlamalıyız.
Dialogue: 0,0:24:00.09,0:24:04.21,Main-207-,,0,0,0,,Öyle gerekiyorsa.\NO zaman başlayalım... Ha?
Dialogue: 0,0:24:04.21,0:24:06.55,Main-207-,,0,0,0,,Ha...? Nerede..? Ne?!
Dialogue: 0,0:24:06.88,0:24:07.88,Main-207-,,0,0,0,,Sorun ne?
Dialogue: 0,0:24:09.43,0:24:10.14,Main-207-,,0,0,0,,Gitmiş...
Dialogue: 0,0:24:10.14,0:24:10.76,Main-207-,,0,0,0,,Ne?
Dialogue: 0,0:24:13.52,0:24:14.43,Main-207-,,0,0,0,,Bu ne?
Dialogue: 0,0:24:15.18,0:24:17.23,Main-207-,,0,0,0,,Seyir pusulasını mı düşürdün?!
Dialogue: 0,0:24:17.23,0:24:18.94,Main-207-,,0,0,0,,Çok özür dilerim, Bayan Wednesday!
Dialogue: 0,0:24:18.94,0:24:21.23,Main-207-,,0,0,0,,O olmadan kasabamıza dönemeyiz ki.
Dialogue: 0,0:24:23.23,0:24:24.36,Main-207-,,0,0,0,,Görünüşe–
Dialogue: 0,0:24:25.86,0:24:28.24,Main-207-,,0,0,0,,Y-Yoksa o...?!
Dialogue: 0,0:24:28.24,0:24:28.95,Main-207-,,0,0,0,,Ha?
Dialogue: 0,0:24:30.53,0:24:31.78,Main-207-,,0,0,0,,Onlar...
Dialogue: 0,0:24:32.74,0:24:34.70,Main-207-,,0,0,0,,O-Olamaz...
Dialogue: 0,0:24:35.62,0:24:36.91,Main-207-,,0,0,10,,...Uğursuzlar!
Dialogue: 0,0:24:36.91,0:24:38.21,Main-207-,,0,0,10,,Lanet! Geç kaldık!
Dialogue: 0,0:24:38.21,0:24:39.29,Main-207-,,0,0,10,,Bay 13!
Dialogue: 0,0:24:39.29,0:24:41.13,Main-207-,,0,0,10,,Bayan Friday!
Dialogue: 0,0:24:41.46,0:24:43.80,Main-207-,,0,0,0,,Lütfen, durun! Açıklayabiliriz!
Dialogue: 0,0:24:43.80,0:24:46.51,Main-207-,,0,0,0,,Derhal patrona rapor vereceğiz!
Dialogue: 0,0:25:00.65,0:25:04.98,Main-207-,,0,0,0,,Oh be! Artık Grand Line\Nyolculuğumuzu planlayabilirim.
Dialogue: 0,0:25:09.78,0:25:13.66,Main-207-,,0,0,0,,Pekâlâ! Sonunda mavi yüzgeçli\Nfil orkinosunu pişireceğim!
Dialogue: 0,0:25:13.66,0:25:15.16,Main-207-,,0,0,0,,Kahretsin...!
Dialogue: 0,0:25:16.12,0:25:20.12,Main-207-,,0,0,0,,Luffy'nin, gemimizi parçalarken\Naklı neredeydi?! Aman be...
Dialogue: 0,0:25:20.12,0:25:21.42,Main-207-,,0,0,0,,Hey, Zoro!
Dialogue: 0,0:25:21.42,0:25:24.21,Main-207-,,0,0,0,,Bir el atsana!\NBen gemi marangozu değilim!
Dialogue: 0,0:25:30.13,0:25:31.72,Main-207-,,0,0,0,,Bu çığlık da ne?
Dialogue: 0,0:25:31.72,0:25:33.60,Main-207-,,0,0,0,,Sorun nedir, Nami-{\i1}san{\i}?!
Dialogue: 0,0:25:33.60,0:25:35.76,Main-207-,,0,0,0,,Eğer acıktıysan, yemeğin hazır!
Dialogue: 0,0:25:35.76,0:25:36.56,Main-207-,,0,0,0,,Hazır mı?
Dialogue: 0,0:25:36.89,0:25:39.02,Main-207-,,0,0,0,,P-Pusulamız bozulmuş!
Dialogue: 0,0:25:39.64,0:25:41.23,Main-207-,,0,0,0,,Hiçbir yeri göstermiyor!
Dialogue: 0,0:25:41.23,0:25:42.90,Main-207-,,0,0,0,,Evet, haklısın.
Dialogue: 0,0:25:42.90,0:25:45.02,Main-207-,,0,0,0,,Dönüp duruyor.
Dialogue: 0,0:25:45.02,0:25:46.69,Main-207-,,0,0,0,,Vay! Eğlenceli!
Dialogue: 0,0:25:47.57,0:25:51.49,Main-207-,,0,0,0,,Görünüşe göre buraya\Nhazırlıksız gelmişsiniz.
Dialogue: 0,0:25:51.49,0:25:54.57,Main-207-,,0,0,0,,Tanrı aşkına!\NCanınızı sokakta mı buldunuz?
Dialogue: 0,0:25:55.03,0:25:55.66,Main-207-,,0,0,0,,Ne?
Dialogue: 0,0:25:55.66,0:25:56.37,Main-207-,,0,0,0,,Yemek?
Dialogue: 0,0:25:56.37,0:25:58.20,Main-207-,,0,0,0,,Sen ot yiyebilirsin.
Dialogue: 0,0:25:58.20,0:25:59.66,Main-207-,,0,0,0,,Size söylemiştim
Dialogue: 0,0:25:59.66,0:26:03.08,Main-207-,,0,0,0,,Sağduyu bu denizde işe yaramaz.
Dialogue: 0,0:26:03.08,0:26:06.38,Main-207-,,0,0,0,,Pusulanız bozuk değil.
Dialogue: 0,0:26:07.17,0:26:09.38,Main-207-,,0,0,0,,O zaman manyetik alanlar mı?
Dialogue: 0,0:26:09.38,0:26:10.47,Main-207-,,0,0,0,,Evet.
Dialogue: 0,0:26:10.47,0:26:15.85,Main-207-,,0,0,0,,Grand Line'daki adalar, yüksek\Nmiktarda manyetik mineral içerir.
Dialogue: 0,0:26:15.85,0:26:18.60,Main-207-,,0,0,0,,Grand Line boyunca\Nanormalliklere sebep olurlar.
Dialogue: 0,0:26:18.60,0:26:22.02,Main-207-,,0,0,0,,Dahası, akıntı ve rüzgârlar da\Nsabit değildir.
Dialogue: 0,0:26:22.02,0:26:25.86,Main-207-,,0,0,0,,Rotacıysan, bunun ne kadar\Nkorkunç olduğunu bilirsin.
Dialogue: 0,0:26:25.86,0:26:30.07,Main-207-,,0,0,0,,Evet, yönümüzü bilemezsek\Nhapı yuttuk demektir.
Dialogue: 0,0:26:30.07,0:26:31.03,Main-207-,,0,0,0,,Leziz!
Dialogue: 0,0:26:31.03,0:26:33.15,Main-207-,,0,0,0,,B-Bilmiyordum! Şey...
Dialogue: 0,0:26:33.15,0:26:35.78,Main-207-,,0,0,0,,Hey! Bu çok fena! Ne yapacağız?!
Dialogue: 0,0:26:35.78,0:26:38.24,Main-207-,,0,0,0,,Hiç de fena değil. Nefis!
Dialogue: 0,0:26:38.24,0:26:41.20,Main-207-,,0,0,0,,Bir saniye sessiz durabilir misiniz?!
Dialogue: 0,0:26:41.20,0:26:44.37,Main-207-,,0,0,0,,Mavi yüzgeçli fil orkinosunun\Nburnu da pek lezzetliymiş!
Dialogue: 0,0:26:44.83,0:26:49.84,Main-207-,,0,0,0,,Grand Line'da dolaşabilmeniz için\Nbir seyir pusulası şart.
Dialogue: 0,0:26:49.84,0:26:52.09,Main-207-,,0,0,0,,Seyir pusulası mı? O ne ki?
Dialogue: 0,0:26:52.09,0:26:56.09,Main-207-,,0,0,0,,Manyetizmayı ölçen özel bir pusula çeşidi.
Dialogue: 0,0:26:56.09,0:26:57.64,Main-207-,,0,0,0,,Garip görünüşlü mü?
Dialogue: 0,0:26:57.64,0:27:00.22,Main-207-,,0,0,0,,Evet, tuhaf bir şekli var.
Dialogue: 0,0:27:00.22,0:27:01.64,Main-207-,,0,0,0,,Bunun gibi mi?
Dialogue: 0,0:27:01.64,0:27:02.77,Main-207-,,0,0,0,,Evet, o.
Dialogue: 0,0:27:03.23,0:27:08.15,Main-207-,,0,0,0,,Seyir pusulası olmadan\NGrand Line'da yolunuzu bulamazsınız.
Dialogue: 0,0:27:08.90,0:27:10.40,Main-207-,,0,0,0,,Anladım...
Dialogue: 0,0:27:10.40,0:27:12.15,Main-207-,,0,0,0,,Ama bir saniye...
Dialogue: 0,0:27:12.65,0:27:14.07,Main-207-,,0,0,0,,Luffy?
Dialogue: 0,0:27:14.45,0:27:17.07,Main-207-,,0,0,0,,Sende ne işi var onun?
Dialogue: 0,0:27:18.78,0:27:22.87,Main-207-,,0,0,0,,O iki tuhaf tip, gemiye düşürmüş.
Dialogue: 0,0:27:22.87,0:27:24.04,Main-207-,,0,0,0,,Öyle mi?
Dialogue: 0,0:27:24.04,0:27:25.42,Main-207-,,0,0,0,,Niye bana vurdun?
Dialogue: 0,0:27:25.42,0:27:26.37,Main-207-,,0,0,0,,İçimden geldi.
Dialogue: 0,0:27:26.37,0:27:27.33,Main-207-,,0,0,0,,Makul.
Dialogue: 0,0:27:28.59,0:27:29.92,Main-207-,,0,0,0,,Demek seyir pusulası bu.
Dialogue: 0,0:27:29.92,0:27:31.46,Main-207-,,0,0,0,,Hiç işaret yok.
Dialogue: 0,0:27:31.46,0:27:39.05,Main-207-,,0,0,0,,Grand Line'daki adaların manyetik\Nalanları belli bir kuralı takip eder:
Dialogue: 0,0:27:39.05,0:27:44.23,Main-207-,,0,0,0,,İki adanın birbirine uyguladığı\Nmanyetik kuvveti hesaplayarak,
Dialogue: 0,0:27:44.23,0:27:46.73,Main-207-,,0,0,0,,bir sonraki adaya olan\Nyolu bulabilirsiniz.
Dialogue: 0,0:27:47.23,0:27:50.40,Main-207-,,0,0,0,,Tabii, adanın denizdeki yerini\Nbilemeyeceğinizden,
Dialogue: 0,0:27:50.40,0:27:54.24,Main-207-,,0,0,0,,güvenebileceğiniz tek şey\Nseyir pusulasının manyetik kaydıdır.
Dialogue: 0,0:27:54.69,0:28:01.37,Main-207-,,0,0,0,,{\q2}Başlamak için, Reverse Mountain'ın\Nyedi manyetik alanından birini seçmelisiniz.
Dialogue: 0,0:28:01.37,0:28:04.29,Main-207-,,0,0,0,,Ama hangi adadan başladığınız farketmeksizin,
Dialogue: 0,0:28:04.29,0:28:08.17,Main-207-,,0,0,0,,manyetik çekimler sonunda sizi\Ntek bir rotaya itecektir.
Dialogue: 0,0:28:08.17,0:28:11.71,Main-207-,,0,0,0,,Ve yolculuğun sonundaki adanın adı da...
Dialogue: 0,0:28:12.21,0:28:13.55,Main-207-,,0,0,0,,Laugh Tale'dir.
Dialogue: 0,0:28:13.55,0:28:16.34,Main-207-,,0,0,0,,Grand Line'daki son ada.
Dialogue: 0,0:28:16.34,0:28:20.55,Main-207-,,0,0,0,,Bu adanın varlığını onaylayan\Ntek kişi Korsanlar Kralı'ydı.
Dialogue: 0,0:28:20.55,0:28:22.68,Main-207-,,0,0,0,,Efsanevi bir ada.
Dialogue: 0,0:28:22.68,0:28:24.06,Main-207-,,0,0,0,,Laugh Tale...
Dialogue: 0,0:28:24.06,0:28:26.89,Main-207-,,0,0,0,,One Piece de orada değil mi?!
Dialogue: 0,0:28:26.89,0:28:29.94,Main-207-,,0,0,0,,Kim bilir? En muhtemel teori o,
Dialogue: 0,0:28:29.94,0:28:32.65,Main-207-,,0,0,0,,ama kanıtlayan olmadı.
Dialogue: 0,0:28:32.65,0:28:34.28,Main-207-,,0,0,0,,Oraya...
Dialogue: 0,0:28:34.28,0:28:35.82,Main-207-,,0,0,0,,vardığımızda anlarız.
Dialogue: 0,0:28:38.70,0:28:41.41,Main-207-,,0,0,0,,Tamam, ben hazırım!\NHazırlanalım mı artık?
Dialogue: 0,0:28:41.41,0:28:43.24,Main-207-,,0,0,0,,Hepsini tek başına mı yedin?!
Dialogue: 0,0:28:43.24,0:28:44.91,Main-207-,,0,0,0,,Oha! Kemikleri bile yemiş.
Dialogue: 0,0:28:44.91,0:28:48.21,Main-207-,,0,0,0,,Seyir pusulası, demek? \NBuna gözümüz gibi bakmamız lazım.
Dialogue: 0,0:28:48.21,0:28:50.42,Main-207-,,0,0,0,,Yolculuğumuz için çok mühim.
Dialogue: 0,0:28:50.42,0:28:52.17,Main-207-,,0,0,0,,Seni kahrolası lastik adam!
Dialogue: 0,0:28:52.17,0:28:54.80,Main-207-,,0,0,0,,Nami-{\i1}san{\i0}'a müthiş bir yemek yapmıştım,
Dialogue: 0,0:28:55.59,0:28:58.72,Main-207-,,0,0,0,,ama o, tek bir ısırık bile yiyemedi!
Dialogue: 0,0:29:13.61,0:29:14.57,Main-207-,,0,0,0,,N'apıyorsun?
Dialogue: 0,0:29:14.57,0:29:16.99,Main-207-,,0,0,0,,Nasılmış, kodumun lastiği seni?
Dialogue: 0,0:29:15.90,0:29:16.99,Secondary-207-,,0,0,0,,Sanji-{\i1}kun{\i0}...
Dialogue: 0,0:29:16.99,0:29:18.44,Main-207-,,0,0,0,,Evet, Nami-{\i1}san{\i}!
Dialogue: 0,0:29:19.28,0:29:22.41,Main-207-,,0,0,0,,Defolup gidin de az serinleyin!!
Dialogue: 0,0:29:26.79,0:29:28.79,Main-207-,,0,0,0,,Hey, dur bir saniye...
Dialogue: 0,0:29:29.25,0:29:32.54,Main-207-,,0,0,0,,Bu çok önemli bir şey değil miydi?!
Dialogue: 0,0:29:32.54,0:29:35.04,Main-207-,,0,0,0,,Biricik seyir pusulamız...
Dialogue: 0,0:29:35.04,0:29:37.38,Main-207-,,0,0,0,,Panik yapmayın.\NBenimkini veririm size.
Dialogue: 0,0:29:37.80,0:29:40.30,Main-207-,,0,0,0,,Laboon için bir teşekkür olarak görün.
Dialogue: 0,0:29:47.81,0:29:49.81,Main-207-,,0,0,0,,Ahh... Öleceğim sandım. Ha?
Dialogue: 0,0:29:52.44,0:29:55.57,Main-207-,,0,0,0,,Buyrun, yardım edeyim, hanımefendi.
Dialogue: 0,0:29:55.57,0:29:56.61,Main-207-,,0,0,0,,Oh, teşekkür ederim.
Dialogue: 0,0:29:56.61,0:29:57.82,Main-207-,,0,0,0,,Ne güzel bir gün, değil mi?
Dialogue: 0,0:29:57.82,0:29:58.61,Main-207-,,0,0,0,,Hey!
Dialogue: 0,0:29:59.24,0:30:00.53,Main-207-,,0,0,0,,Sizden bir ricamız var.
Dialogue: 0,0:30:04.16,0:30:05.45,Main-207-,,0,0,0,,Whisky Peak mi?
Dialogue: 0,0:30:05.78,0:30:06.99,Main-207-,,0,0,0,,Ne tuhaf bir isim.
Dialogue: 0,0:30:06.99,0:30:08.08,Main-207-,,0,0,0,,O ne ki?
Dialogue: 0,0:30:08.08,0:30:10.83,Main-207-,,0,0,0,,Bizim yaşadığımız yer... beyefendi.
Dialogue: 0,0:30:10.83,0:30:12.96,Main-207-,,0,0,0,,Sizin geminize ne oldu?
Dialogue: 0,0:30:12.96,0:30:15.42,Main-207-,,0,0,0,,Berbat hâlde.
Dialogue: 0,0:30:16.04,0:30:20.13,Main-207-,,0,0,0,,Balinayı öldürmeye kalkıp şimdi bunu\Nistemek biraz abartı değil mi, Bay 9?
Dialogue: 0,0:30:20.55,0:30:22.47,Main-207-,,0,0,0,,Neyin nesiniz siz bakayım?
Dialogue: 0,0:30:22.47,0:30:24.18,Main-207-,,0,0,0,,Ben bir kralım.
Dialogue: 0,0:30:25.26,0:30:26.22,Main-207-,,0,0,0,,Yalancı.
Dialogue: 0,0:30:27.47,0:30:29.22,Main-207-,,0,0,0,,Söyleyemeyiz!
Dialogue: 0,0:30:29.22,0:30:31.48,Main-207-,,0,0,0,,Ama evimize geri dönmek istiyoruz.
Dialogue: 0,0:30:31.48,0:30:34.81,Main-207-,,0,0,0,,Ketumluk etmek istemeyiz ama...
Dialogue: 0,0:30:34.81,0:30:37.23,Main-207-,,0,0,0,,şirketimizin mottosu\N"gizlilik" en nihayetinde...
Dialogue: 0,0:30:37.23,0:30:39.65,Main-207-,,0,0,0,,Size hakkımızda hiçbir şey söyleyemeyiz.
Dialogue: 0,0:30:39.98,0:30:43.36,Main-207-,,0,0,0,,İyi niyetinize güvenerek size yalvarıyoruz.
Dialogue: 0,0:30:43.36,0:30:45.74,Main-207-,,0,0,0,,İyiliğinizin karşılığını mutlaka vereceğiz.
Dialogue: 0,0:30:45.74,0:30:47.58,Main-207-,,0,0,0,,İnanmayın.
Dialogue: 0,0:30:47.58,0:30:50.66,Main-207-,,0,0,0,,Ne derlerse desinler,\Nbunlar güvenilmez insanlar.
Dialogue: 0,0:30:51.08,0:30:56.17,Main-207-,,0,0,0,,Bu arada seyir pusulamız kırıldı.\NHâlâ gelmek istiyor musunuz?
Dialogue: 0,0:30:56.50,0:30:59.71,Main-207-,,0,0,0,,Ne?! Kırdınız mı?!\NO benimdi, biliyorsunuz!
Dialogue: 0,0:30:59.71,0:31:03.76,Main-207-,,0,0,0,,Biz mütevazıyken siz kibirli mi\Ndavranıyorsunuz?! Bizden farkınız yok!
Dialogue: 0,0:31:04.13,0:31:05.55,Main-207-,,0,0,0,,Ah, söylemeyi unuttum,
Dialogue: 0,0:31:05.55,0:31:08.72,Main-207-,,0,0,0,,bay Crocus sayesinde\Nbir yedeğimiz var.
Dialogue: 0,0:31:09.56,0:31:11.72,Main-207-,,0,0,0,,Siz, yüce gönüllü insanlara yalvarıyoruz.
Dialogue: 0,0:31:12.10,0:31:14.69,Thoughts-207-,,0,0,0,,Kahretsin! Cadaloz bizimle oynuyor!
Dialogue: 0,0:31:15.02,0:31:16.52,Main-207-,,0,0,0,,Olur, gelebilirsiniz.
Dialogue: 0,0:31:17.94,0:31:19.40,Main-207-,,0,0,0,,Whisky Peak mi ne?
Dialogue: 0,0:31:19.40,0:31:20.57,Main-207-,,0,0,0,,Gidelim bakalım.
Dialogue: 0,0:31:20.57,0:31:21.32,Main-207-,,0,0,0,,– Ne?\N– Ha?
Dialogue: 0,0:31:21.32,0:31:25.53,Main-207-,,0,0,0,,Hey, bu güvenilmez tiplerle\Nyola çıkmamız doğru mu?
Dialogue: 0,0:31:25.91,0:31:26.95,Main-207-,,0,0,0,,Sorun ne?
Dialogue: 0,0:31:26.95,0:31:28.99,Main-207-,,0,0,0,,Öyle ufak detayları dert etmeyin.
Dialogue: 0,0:31:28.99,0:31:33.96,Main-207-,,0,0,0,,Burada rotanızı belirledikten sonra, değiştiremezsiniz.
Dialogue: 0,0:31:33.96,0:31:36.79,Main-207-,,0,0,0,,Beğenmezsek bir tur daha döneriz.
Dialogue: 0,0:31:37.33,0:31:38.71,Main-207-,,0,0,0,,Öyle mi...?
Dialogue: 0,0:31:39.25,0:31:41.09,Main-207-,,0,0,0,,Artık yola çıkalım mı?
Dialogue: 0,0:31:42.46,0:31:45.55,Main-207-,,0,0,0,,Balinaya sözümü verdim.\NHadi yola çıkalım.
Dialogue: 0,0:31:45.93,0:31:48.30,Main-207-,,0,0,0,,Sen de kimsin?
Dialogue: 0,0:31:48.30,0:31:49.26,Main-207-,,0,0,0,,Ben mi?
Dialogue: 0,0:31:49.26,0:31:50.14,Main-207-,,0,0,0,,Ben...
Dialogue: 0,0:31:50.56,0:31:52.72,Main-207-,,0,0,0,,Korsanlar Kralı olacak adamım.
Dialogue: 0,0:31:57.19,0:31:58.77,Thoughts-207-,,0,0,0,,Ne aptal bir korsan...
Dialogue: 0,0:32:01.65,0:32:03.19,Main-207-,,0,0,0,,Hâllolmuş olmalı.
Dialogue: 0,0:32:03.19,0:32:05.24,Main-207-,,0,0,0,,Pusula şimdiye ayarlanmış olmalı.
Dialogue: 0,0:32:05.86,0:32:08.32,Main-207-,,0,0,0,,Harita ile aynı yönü mü işaret ediyor?
Dialogue: 0,0:32:08.32,0:32:09.07,Main-207-,,0,0,0,,Evet.
Dialogue: 0,0:32:09.78,0:32:11.74,Main-207-,,0,0,0,,Whisky Peak'i işaret ediyor.
Dialogue: 0,0:32:12.24,0:32:14.08,Main-207-,,0,0,0,,Görüşürüz, çiçekli ihtiyar!
Dialogue: 0,0:32:14.08,0:32:15.66,Main-207-,,0,0,0,,Seyir pusulası için sağ ol!
Dialogue: 0,0:32:15.66,0:32:17.58,Main-207-,,0,0,0,,Evet. İyi yolculuklar!
Dialogue: 0,0:32:17.58,0:32:20.21,Main-207-,,0,0,0,,Seninle de görüşürüz, balina!\NŞimdilik gidiyorum!
Dialogue: 0,0:32:25.17,0:32:27.13,Main-207-,,0,0,0,,Whisky Peak'e...
Dialogue: 0,0:32:27.13,0:32:29.51,Main-207-,,0,0,0,,tam yol ileri!!
Dialogue: 0,0:32:29.51,0:32:31.51,Main-207-,,0,0,0,,– Evet!\N– Evet!
Dialogue: 0,0:32:49.16,0:32:54.04,Main-207-,,0,0,0,,Merak ediyorum, acaba onlar\Nnicedir beklediğimiz korsanlar mı...?
Dialogue: 0,0:32:54.04,0:32:58.00,Main-207-,,0,0,0,,Bu çocuğun çok acayip bir aurası var...
Dialogue: 0,0:33:01.04,0:33:02.25,Main-207-,,0,0,0,,değil mi,
Dialogue: 0,0:33:02.25,0:33:03.96,Main-207-,,0,0,0,,Roger?
Comment: 0,0:00:00.00,0:00:00.00,Main-207-,,0,0,0,,{=25}===============================DIALOGUE============================
