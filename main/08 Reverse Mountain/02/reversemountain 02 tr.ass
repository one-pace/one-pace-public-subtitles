Comment: 0,0:00:00.00,0:00:00.00,Main-207-,,0,0,0,,{=22}===============================DIALOGUE============================
Dialogue: 0,0:02:06.86,0:02:08.32,Main-207-,,0,0,0,,Bu bir çiçek!
Dialogue: 0,0:02:07.57,0:02:08.32,Secondary-207-,,0,0,0,,Çiçek mi?
Dialogue: 0,0:02:13.28,0:02:15.28,Main-207-,,0,0,0,,Hayır, boş ver. İnsanmış.
Dialogue: 0,0:02:15.28,0:02:16.57,Main-207-,,0,0,0,,Ne bu?
Dialogue: 0,0:02:16.57,0:02:20.12,Main-207-,,0,0,0,,Bu yaşlı adam,\Ndev kalamara tek attı...
Dialogue: 0,0:02:20.12,0:02:21.87,Main-207-,,0,0,0,,Sadece balık mı tutuyordu...
Dialogue: 0,0:02:21.87,0:02:24.96,Main-207-,,0,0,0,,yoksa bizi kurtarmak için mi yaptı?
Dialogue: 0,0:02:52.24,0:02:54.70,Main-207-,,0,0,0,,Bir şey desene lan, hıyar!
Dialogue: 0,0:02:57.66,0:03:00.20,Main-207-,,0,0,0,,S-Savaşmak istiyorsan\Nsavaşırız, şerefsiz!
Dialogue: 0,0:03:00.20,0:03:01.91,Main-207-,,0,0,0,,Toplarımız var!
Dialogue: 0,0:03:02.41,0:03:05.29,Main-207-,,0,0,0,,Savaşmasanız daha iyi olur, biri ölebilir.
Dialogue: 0,0:03:08.63,0:03:09.92,Main-207-,,0,0,0,,Öyle mi?
Dialogue: 0,0:03:09.92,0:03:11.17,Main-207-,,0,0,0,,Kim ölecek?
Dialogue: 0,0:03:11.17,0:03:12.38,Main-207-,,0,0,0,,Ben.
Dialogue: 0,0:03:12.38,0:03:13.63,Main-207-,,0,0,0,,Sen mi?!
Dialogue: 0,0:03:13.63,0:03:14.42,Main-207-,,0,0,0,,Ulan...
Dialogue: 0,0:03:14.42,0:03:15.47,Main-207-,,0,0,0,,Hey, sakinleş.
Dialogue: 0,0:03:15.47,0:03:17.89,Main-207-,,0,0,0,,Bizimle dalga geçiyor...
Dialogue: 0,0:03:19.18,0:03:21.18,Main-207-,,0,0,0,,Hey, ihtiyar!
Dialogue: 0,0:03:21.18,0:03:24.23,Main-207-,,0,0,0,,Bize kim olduğunu ve\Nnerede olduğumuzu söyle.
Dialogue: 0,0:03:24.81,0:03:26.48,Main-207-,,0,0,0,,Birine soru sorarken,
Dialogue: 0,0:03:27.15,0:03:31.32,Main-207-,,0,0,0,,nezaketen önce kendini\Ntanıtman gerekmez mi?
Dialogue: 0,0:03:31.32,0:03:34.61,Main-207-,,0,0,0,,Ha? Evet, doğru dedin.
Dialogue: 0,0:03:34.61,0:03:35.78,Main-207-,,0,0,0,,Kusura bakma.
Dialogue: 0,0:03:35.78,0:03:38.49,Main-207-,,0,0,0,,– Benim adım Crocus.\N– Ben Roro... noa...
Dialogue: 0,0:03:38.49,0:03:41.70,Main-207-,,0,0,0,,İkiz Burun'un\Ndeniz feneri bekçisiyim.
Dialogue: 0,0:03:41.70,0:03:43.54,Main-207-,,0,0,0,,71 yaşındayım ve\Nikizler burcuyum.
Dialogue: 0,0:03:43.54,0:03:46.21,Main-207-,,0,0,0,,Kan grubum AB.
Dialogue: 0,0:03:43.91,0:03:46.21,Main-207-,,0,0,0,,{\an8}Bırakın biçeyim şunu!
Dialogue: 0,0:03:44.75,0:03:46.21,Secondary-207-,,0,0,0,,{\an8}Hey, sakinleş.
Dialogue: 0,0:03:46.21,0:03:48.37,Main-207-,,0,0,0,,Nerede olduğumuzu mu sordunuz?
Dialogue: 0,0:03:48.92,0:03:56.47,Main-207-,,0,0,0,,Benim özel mekanıma dalıp\Nbir de soru mu soruyorsunuz?
Dialogue: 0,0:03:57.26,0:04:00.80,Main-207-,,0,0,0,,Bir farenin midesinde\Ngibi mi duruyoruz?
Dialogue: 0,0:04:00.80,0:04:03.64,Main-207-,,0,0,0,,O hâlde balina\Ntarafından yutulduğumuz gerçek.
Dialogue: 0,0:04:04.35,0:04:07.02,Main-207-,,0,0,0,,Ama burası cidden\Nbalinanın midesi mi?
Dialogue: 0,0:04:07.02,0:04:09.94,Main-207-,,0,0,0,,Dur bi' saniye! Ne olacak şimdi bize?!
Dialogue: 0,0:04:09.94,0:04:12.82,Main-207-,,0,0,0,,Sindirilmek istemiyorum!
Dialogue: 0,0:04:12.82,0:04:14.73,Main-207-,,0,0,0,,Çıkış o tarafta.
Dialogue: 0,0:04:14.73,0:04:16.24,Main-207-,,0,0,0,,– Çıkabilir miyiz yani?!\N– Çıkabilir miyiz yani?!
Dialogue: 0,0:04:17.11,0:04:20.66,Main-207-,,0,0,0,,Bir saniye! Niye balinanın\Nmidesinde bir çıkış var?!
Dialogue: 0,0:04:20.66,0:04:22.95,Main-207-,,0,0,0,,Ve niye kapısı gökyüzünde?!
Dialogue: 0,0:04:22.95,0:04:25.66,Main-207-,,0,0,0,,Dur... Dikkatli baksana...
Dialogue: 0,0:04:25.66,0:04:29.92,Main-207-,,0,0,0,,Gökyüzü... Martılar...
Dialogue: 0,0:04:30.58,0:04:31.83,Main-207-,,0,0,0,,Bunlar resim!
Dialogue: 0,0:04:31.83,0:04:34.21,Main-207-,,0,0,0,,Hepsi balinanın midesine çizilmiş resimler!
Dialogue: 0,0:04:34.21,0:04:35.42,Main-207-,,0,0,0,,Ha?!
Dialogue: 0,0:04:35.42,0:04:37.05,Main-207-,,0,0,0,,Bir doktorun mizah anlayışı.
Dialogue: 0,0:04:37.05,0:04:39.43,Main-207-,,0,0,0,,Seni şerefsiz!\NBuradaki amacın ne?!
Dialogue: 0,0:04:39.43,0:04:41.14,Main-207-,,0,0,0,,Bu kadarı yeter. Görmezden gelin!
Dialogue: 0,0:04:41.14,0:04:42.22,Main-207-,,0,0,0,,Katılıyorum.
Dialogue: 0,0:04:42.22,0:04:44.76,Main-207-,,0,0,0,,Nami! Çıkışı bulduk, hadi gidelim.
Dialogue: 0,0:04:44.76,0:04:46.18,Main-207-,,0,0,0,,Aynen.
Dialogue: 0,0:04:50.81,0:04:52.27,Main-207-,,0,0,0,,Ne oluyor?!
Dialogue: 0,0:04:53.65,0:04:54.98,Main-207-,,0,0,0,,Başladı...
Dialogue: 0,0:04:56.11,0:04:56.98,Main-207-,,0,0,0,,Bakın!
Dialogue: 0,0:04:57.78,0:04:59.11,Main-207-,,0,0,0,,O bir ada değil!
Dialogue: 0,0:04:59.11,0:05:01.41,Main-207-,,0,0,0,,Gemiymiş.\NVe demirden yapılmış!
Dialogue: 0,0:05:01.41,0:05:04.91,Main-207-,,0,0,0,,Doğru ya!\NBu deniz mide asidinden oluşuyor!
Dialogue: 0,0:05:04.91,0:05:08.58,Main-207-,,0,0,0,,O zaman burada uzun süre\Nkalırsak tahtadan gemimiz eriyecek.
Dialogue: 0,0:05:08.58,0:05:10.79,Main-207-,,0,0,0,,Hey! Ne başladı?!
Dialogue: 0,0:05:10.79,0:05:12.79,Main-207-,,0,0,0,,Söylesene!
Dialogue: 0,0:05:13.46,0:05:14.96,Main-207-,,0,0,0,,Bu balina...
Dialogue: 0,0:05:16.46,0:05:20.93,Main-207-,,0,0,0,,Laboon, kafasını\NRed Line'a vurmaya başladı.
Dialogue: 0,0:05:30.35,0:05:31.27,Main-207-,,0,0,0,,– Ne?!\N– Ne?!
Dialogue: 0,0:05:31.27,0:05:35.27,Main-207-,,0,0,0,,Şimdi düşününce,\Nbalinanın alnında feci yaralar vardı.
Dialogue: 0,0:05:35.27,0:05:37.40,Main-207-,,0,0,0,,Bir de gökyüzüne doğru bağırıyordu...
Dialogue: 0,0:05:37.40,0:05:38.99,Main-207-,,0,0,0,,Bu ne demek?
Dialogue: 0,0:05:39.86,0:05:41.45,Main-207-,,0,0,0,,Acı çekiyor!
Dialogue: 0,0:05:48.49,0:05:51.87,Main-207-,,0,0,0,,Anladım!\NDemek moruk bunu amaçlıyor!
Dialogue: 0,0:05:51.87,0:05:52.79,Main-207-,,0,0,0,,Muhtemelen...
Dialogue: 0,0:05:52.79,0:05:55.84,Main-207-,,0,0,0,,Balinayı vücudunun içinden\Nöldürmeye çalışıyor!
Dialogue: 0,0:05:55.84,0:05:56.67,Main-207-,,0,0,0,,Şimdi...
Dialogue: 0,0:05:56.67,0:05:58.92,Main-207-,,0,0,0,,Ne fena bir öldürme yöntemi!
Dialogue: 0,0:05:58.92,0:06:01.30,Main-207-,,0,0,0,,Pekâlâ, gizem çözüldü.\NHemen çıkalım şuradan.
Dialogue: 0,0:06:01.30,0:06:03.13,Main-207-,,0,0,0,,Burada oyalanırsak sindirileceğiz.
Dialogue: 0,0:06:04.30,0:06:07.14,Main-207-,,0,0,0,,Bu balina avı, bizi ilgilendirmiyor.
Dialogue: 0,0:06:07.14,0:06:09.35,Main-207-,,0,0,0,,Balinayı kurtarmak da bize düşmez.
Dialogue: 0,0:06:09.35,0:06:10.64,Main-207-,,0,0,0,,Hadi gidelim.
Dialogue: 0,0:06:24.82,0:06:28.28,Main-207-,,0,0,0,,Kahretsin!\NDalgalar bu kadar şiddetliyken...
Dialogue: 0,0:06:28.28,0:06:30.41,Main-207-,,0,0,0,,kapılara ulaşabilir miyiz, bilmiyorum...?
Dialogue: 0,0:06:30.41,0:06:32.71,Main-207-,,0,0,0,,Kürek çekmemiz şart! Kürekleri alın!
Dialogue: 0,0:06:32.71,0:06:35.67,Main-207-,,0,0,0,,Hadi, çabucak gidelim!\NLuffy için endişeleniyorum.
Dialogue: 0,0:06:35.67,0:06:37.04,Main-207-,,0,0,0,,O dışarıda!
Dialogue: 0,0:06:37.04,0:06:39.00,Main-207-,,0,0,0,,Ağzından fırladığını gördüm!
Dialogue: 0,0:06:41.76,0:06:43.76,Main-207-,,0,0,0,,Yaşlı adam denize atladı!
Dialogue: 0,0:06:43.76,0:06:44.55,Main-207-,,0,0,0,,Ha?
Dialogue: 0,0:06:45.05,0:06:47.55,Main-207-,,0,0,0,,Ne yapmaya çalışıyor?\NSindirilecek.
Dialogue: 0,0:06:57.94,0:07:00.32,Main-207-,,0,0,0,,Ne?! N'oluyor?! Ha? Neden?!
Dialogue: 0,0:07:00.32,0:07:01.57,Main-207-,,0,0,0,,Başım... Başım...
Dialogue: 0,0:07:01.57,0:07:03.95,Main-207-,,0,0,0,,Başım dönüyor!
Dialogue: 0,0:07:11.95,0:07:13.20,Main-207-,,0,0,0,,Şimdi ne var?
Dialogue: 0,0:07:13.20,0:07:16.00,Main-207-,,0,0,0,,Deniz mi? Nehir mi? Kanal mı?
Dialogue: 0,0:07:26.05,0:07:29.93,Main-207-,,0,0,0,,Çok iyi. Bu kadar derine inmeyi başardık.
Dialogue: 0,0:07:30.64,0:07:32.39,Main-207-,,0,0,8,,Dinleyin, Bayan Wednesday.
Dialogue: 0,0:07:32.39,0:07:34.64,Main-207-,,0,0,0,,Bu kapıların arkasında mide var...
Dialogue: 0,0:07:34.64,0:07:37.27,Main-207-,,0,0,0,,ve o yaşlı bunak muhtemelen orada.
Dialogue: 0,0:07:37.27,0:07:39.90,Main-207-,,0,0,0,,Onu yok etmeliyiz.
Dialogue: 0,0:07:40.52,0:07:42.78,Main-207-,,0,0,10,,Hedefimiz balina.
Dialogue: 0,0:07:43.15,0:07:44.78,Main-207-,,0,0,0,,Aynen öyle, Bay 9.
Dialogue: 0,0:07:44.78,0:07:49.24,Main-207-,,0,0,0,,Bu balina, bizim kasabımızın biriciği.
Dialogue: 0,0:07:51.99,0:07:54.08,Main-207-,,0,0,0,,Hey! Moruk sudan çıktı!
Dialogue: 0,0:07:54.08,0:07:55.08,Main-207-,,0,0,0,,Boş verin.
Dialogue: 0,0:07:55.08,0:07:58.58,Main-207-,,0,0,0,,Asıl önemli olan,\Nbu kapıları nasıl açacağız?
Dialogue: 0,0:07:59.04,0:08:01.59,Main-207-,,0,0,0,,Tamam mı, Bayan Wednesday?
Dialogue: 0,0:08:01.59,0:08:04.09,Main-207-,,0,0,0,,Kapıları "Üç, iki, bir, bebek!"\Ndeyip açacağız.
Dialogue: 0,0:08:04.09,0:08:05.21,Main-207-,,0,0,0,,Tetikte ol.
Dialogue: 0,0:08:05.21,0:08:08.18,Main-207-,,0,0,0,,Anlaşıldı, Bay 9. Hazır ve nazırım.
Dialogue: 0,0:08:10.68,0:08:15.85,Main-207-,,0,0,0,,{\an8}Duramıyorum!!!
Dialogue: 0,0:08:11.80,0:08:13.47,Main-207-,,0,0,0,,Bu ses de ne, Bay 9?
Dialogue: 0,0:08:13.47,0:08:15.85,Main-207-,,0,0,0,,Bilmiyorum, Bayan Wednesday.
Dialogue: 0,0:08:26.07,0:08:27.19,Main-207-,,0,0,0,,Yine mi...?
Dialogue: 0,0:08:29.74,0:08:31.53,Main-207-,,0,0,0,,Bu hiç iyi değil, Bayan Wednesday!
Dialogue: 0,0:08:31.53,0:08:34.08,Main-207-,,0,0,0,,Altımızda mide asidinden bir deniz var!
Dialogue: 0,0:08:35.66,0:08:36.50,Main-207-,,0,0,0,,Luffy?
Dialogue: 0,0:08:36.50,0:08:39.08,Main-207-,,0,0,0,,Hey! Yani herkes iyi mi?
Dialogue: 0,0:08:40.12,0:08:42.50,Main-207-,,0,0,0,,Her neyse... yardım edin!
Dialogue: 0,0:08:47.05,0:08:50.76,Main-207-,,0,0,0,,Luffy ile birlikte\Niki tuhaf tip daha ortaya çıktı.
Dialogue: 0,0:08:50.76,0:08:52.93,Main-207-,,0,0,0,,Hey! Yaşlı adam kayboldu!
Dialogue: 0,0:08:52.93,0:08:55.97,Main-207-,,0,0,0,,Boş ver onu! Hadi Luffy'i kurtaralım!
Dialogue: 0,0:09:10.65,0:09:12.70,Main-207-,,0,0,0,,Dur, Laboon.
Dialogue: 0,0:09:13.28,0:09:16.29,Main-207-,,0,0,0,,Artık kendine zarar verme.
Dialogue: 0,0:09:16.29,0:09:18.75,Main-207-,,0,0,0,,Çok az sakinleştirici iğne kaldı.
Dialogue: 0,0:09:18.75,0:09:21.21,Main-207-,,0,0,0,,Daha fazla yapmam lazım...
Dialogue: 0,0:09:23.71,0:09:27.30,Main-207-,,0,0,0,,O duvar, dünyadaki okyanusları ayırır.
Dialogue: 0,0:09:27.30,0:09:32.30,Main-207-,,0,0,0,,Ölene kadar toslasan bile\Nkıramazsın, Laboon.
Dialogue: 0,0:09:37.22,0:09:38.60,Main-207-,,0,0,0,,Sakinleşti.
Dialogue: 0,0:09:38.60,0:09:40.35,Main-207-,,0,0,0,,Balina sessizleşti.
Dialogue: 0,0:09:40.35,0:09:42.23,Main-207-,,0,0,0,,Görünüşe bakılırsa öyle.
Dialogue: 0,0:09:42.73,0:09:43.85,Main-207-,,0,0,0,,Şimdi...
Dialogue: 0,0:09:44.77,0:09:48.32,Main-207-,,0,0,0,,Sizi de kurtardık ama siz kimsiniz?
Dialogue: 0,0:09:49.15,0:09:52.11,Main-207-,,0,0,0,,Bay 9, bunlar korsan.
Dialogue: 0,0:09:52.11,0:09:54.28,Main-207-,,0,0,0,,B-Biliyorum, Bayan Wednesday.
Dialogue: 0,0:09:54.99,0:09:59.79,Main-207-,,0,0,0,,A-Ama onlarla konuşursak\Nbizi anlarlar... belki...
Dialogue: 0,0:09:59.79,0:10:02.25,Main-207-,,0,0,0,,Siz eşkıyalar hâlâ burada mısınız?!
Dialogue: 0,0:10:02.96,0:10:05.17,Main-207-,,0,0,0,,Kaç kez daha söyleyeceğim?!
Dialogue: 0,0:10:05.75,0:10:10.34,Main-207-,,0,0,0,,Ben hayatta olduğum müddetçe\NLaboon'un kılına bile dokunamazsınız!
Dialogue: 0,0:10:12.93,0:10:14.14,Main-207-,,0,0,0,,Geri geldi.
Dialogue: 0,0:10:14.14,0:10:15.80,Main-207-,,0,0,0,,Kim bu ihtiyar?
Dialogue: 0,0:10:17.76,0:10:20.68,Main-207-,,0,0,0,,İstediğini söyle, öylece gidemeyiz.
Dialogue: 0,0:10:20.68,0:10:23.39,Main-207-,,0,0,0,,Bu balinayı indirmek bizim görevimiz.
Dialogue: 0,0:10:23.39,0:10:26.27,Main-207-,,0,0,0,,Bu sefer balina avımıza\Nengel olamayacaksın!
Dialogue: 0,0:10:26.27,0:10:29.32,Main-207-,,0,0,0,,Midesinde bir delik açacağız!
Dialogue: 0,0:10:29.32,0:10:31.07,Main-207-,,0,0,0,,Hadi, bebek!
Dialogue: 0,0:10:30.11,0:10:31.07,Secondary-207-,,0,0,0,,Anlaşıldı!
Dialogue: 0,0:10:36.78,0:10:38.91,Main-207-,,0,0,0,,Şerefsizler!
Dialogue: 0,0:10:43.25,0:10:45.42,Main-207-,,0,0,0,,İhtiyar, mermilere kafa attı...!
Dialogue: 0,0:10:45.42,0:10:47.92,Main-207-,,0,0,0,,Acaba... balinayı mı istiyor?!
Dialogue: 0,0:10:51.34,0:10:52.88,Main-207-,,0,0,0,,Bu anlamsız direnişi kes!
Dialogue: 0,0:10:52.88,0:10:55.05,Main-207-,,0,0,0,,Balinayı istediğin kadar koru!
Dialogue: 0,0:10:55.59,0:10:58.80,Main-207-,,0,0,0,,Onu kasabamız için yemeğe çevireceğiz!
Dialogue: 0,0:11:04.94,0:11:06.19,Main-207-,,0,0,0,,Ne oluyor?
Dialogue: 0,0:11:14.15,0:11:15.65,Main-207-,,0,0,0,,Sadece...
Dialogue: 0,0:11:15.65,0:11:16.91,Main-207-,,0,0,0,,içimden geldi.
Dialogue: 0,0:11:21.83,0:11:25.58,Main-207-,,0,0,0,,Beni kurtardığınız için\Nteşekkür ederim... ama neden?
Dialogue: 0,0:11:25.58,0:11:27.17,Main-207-,,0,0,0,,Niyetim o değildi.
Dialogue: 0,0:11:27.17,0:11:29.46,Main-207-,,0,0,0,,Sadece onları sevmedim.
Dialogue: 0,0:11:30.50,0:11:33.42,Secondary-207-,,0,0,0,,{\an8}Hey, Luffy! Napıyorsun?
Dialogue: 0,0:11:34.72,0:11:36.34,Secondary-207-,,0,0,0,,{\an8}Kes şunu!
Dialogue: 0,0:11:36.34,0:11:39.76,Secondary-207-,,0,0,0,,{\an8}Hey! Hey, Luffy! Dursana!
Dialogue: 0,0:11:39.76,0:11:42.01,Secondary-207-,,0,0,0,,{\an8}Ne yapmaya çalışıyorsun?
Dialogue: 0,0:11:42.01,0:11:43.77,Secondary-207-,,0,0,0,,{\an8}O başkasına ait.
Dialogue: 0,0:11:30.50,0:11:33.42,Main-207-,,0,0,0,,Söylesene, kim bunlar?
Dialogue: 0,0:11:33.42,0:11:36.34,Main-207-,,0,0,0,,Balinanın içinde ne yapıyorsun?
Dialogue: 0,0:11:36.34,0:11:39.76,Main-207-,,0,0,0,,Onlar yakındaki bir kasabadan eşkıyalar.
Dialogue: 0,0:11:39.76,0:11:42.56,Main-207-,,0,0,0,,Balina eti peşindeler.
Dialogue: 0,0:11:42.56,0:11:44.89,Main-207-,,0,0,0,,Eğer Laboon'u yakalarlarsa,
Dialogue: 0,0:11:44.89,0:11:48.52,Main-207-,,0,0,0,,kasaba halkını 2-3 ay doyururlar.
Dialogue: 0,0:11:48.90,0:11:49.81,Main-207-,,0,0,0,,Laboon mu?
Dialogue: 0,0:11:49.81,0:11:51.90,Main-207-,,0,0,0,,Bu balinanın adı.
Dialogue: 0,0:11:51.90,0:11:57.24,Main-207-,,0,0,0,,O bir ada balinası,\Nsadece Batı Mavi'de yaşayan bir tür.
Dialogue: 0,0:11:57.24,0:11:59.99,Main-207-,,0,0,0,,Onlar dünyanın en büyük balinaları.
Dialogue: 0,0:11:59.99,0:12:03.12,Main-207-,,0,0,0,,Et için avlanılmasına müsaade etmeyeceğim.
Dialogue: 0,0:12:03.54,0:12:06.87,Main-207-,,0,0,0,,Red Line'a toslamasının bir sebebi var...
Dialogue: 0,0:12:06.87,0:12:12.09,Main-207-,,0,0,0,,Ve Reverse Mountain'a bağırmasının da...
Dialogue: 0,0:12:12.09,0:12:12.84,Main-207-,,0,0,0,,Sebebi mi?
Dialogue: 0,0:12:12.84,0:12:14.05,Main-207-,,0,0,0,,Evet.
Dialogue: 0,0:12:14.42,0:12:19.97,Main-207-,,0,0,0,,{\fad(0,1352)}O, insan kalbine sahip bir balina.
Dialogue: 0,0:12:20.39,0:12:25.39,Main-207-,,0,0,0,,Sadakatle bir grup korsanın\Ngelmesini bekliyor.
Dialogue: 0,0:12:29.06,0:12:31.27,Main-207-,,0,0,0,,50 yıl oldu...
Dialogue: 0,0:12:31.73,0:12:36.24,Main-207-,,0,0,0,,Anlatayım... Laboon'un hikayesini...
Dialogue: 0,0:12:49.75,0:12:54.42,Main-207-,,0,0,0,,Günlerden bir gün, bekçi olarak\Ngörevime devam ederken,
Dialogue: 0,0:12:54.42,0:12:58.80,Main-207-,,0,0,0,,bazı iyi yürekli korsanlar, \NReverse Mountain'dan indiler...
Dialogue: 0,0:12:58.80,0:13:01.47,Main-207-,,0,0,0,,ve Grand Line'a girdiler.
Dialogue: 0,0:13:01.47,0:13:06.10,Main-207-,,0,0,0,,Arkalarından da onları takip eden\Nminik bir balina geldi...
Dialogue: 0,0:13:06.10,0:13:08.68,Main-207-,,0,0,0,,O Laboon'du.
Dialogue: 0,0:13:09.52,0:13:13.73,Main-207-,,0,0,0,,Daha önce de söylediğim gibi,\Nada balinası en büyük balina türüdür,
Dialogue: 0,0:13:13.73,0:13:15.40,Main-207-,,0,0,0,,ve sadece Batı Mavi'de yaşar.
Dialogue: 0,0:13:16.40,0:13:20.40,Main-207-,,0,0,0,,Korsanlar, Laboon ile seyahat ediyorlardı...
Dialogue: 0,0:13:20.40,0:13:27.12,Main-207-,,0,0,0,,ama Grand Line, çok tehlikeli olduğu\Niçin onu Batı Mavi'de bıraktılar.
Dialogue: 0,0:13:27.12,0:13:29.54,Main-207-,,0,0,0,,Ama Laboon,\Ngizliden takibe devam etti.
Dialogue: 0,0:13:30.54,0:13:35.59,Main-207-,,0,0,0,,{\t(4654,0,1,\3c&HFFFFFF&\4c&HFFFFFF&)\t(4988,5029,\alpha&HFF&)}Ada balinaları genelde\Ngrup olarak hareket ederler...
Dialogue: 0,0:13:36.13,0:13:41.05,Main-207-,,0,0,0,,{\t(4528,0,1,\c&HFEFEFE&\3c&HFEFEFE&\4c&HFEFEFE&)\t(4862,4903,\alpha&HFF&)}ama galiba Laboon,\No korsan tayfasını ailesi olarak gördü.
Dialogue: 0,0:13:41.05,0:13:46.39,Main-207-,,0,0,0,,{\c&HFCFEFE&\3c&HFCFEFE&\4c&HFCFEFE&\t(0,317,1,\c&HFFFFFF&\3c&H000000&\4c&H000000&)}Gemileri arızalandığı için\Nburada birkaç ay boyunca kaldılar.
Dialogue: 0,0:13:46.39,0:13:50.14,Main-207-,,0,0,0,,O dönemde yakın arkadaş olduk.
Dialogue: 0,0:13:51.77,0:13:54.73,Main-207-,,0,0,0,,Bu yüzden, ayrılacakları gün...
Dialogue: 0,0:13:55.36,0:13:57.36,Flashbacks-207-,,0,0,0,,Sana güveniyorum ve bir ricam var.
Dialogue: 0,0:13:57.36,0:13:59.99,Flashbacks-207-,,0,0,0,,Ona 2-3 yıl göz kulak olur musun?
Dialogue: 0,0:14:00.53,0:14:04.07,Flashbacks-207-,,0,0,0,,Dünyayı dolaşıp mutlaka geri geleceğiz.
Dialogue: 0,0:14:05.20,0:14:07.87,Flashbacks-207-,,0,0,0,,Dinle, Laboon.\NSana diyeceklerim var.
Dialogue: 0,0:14:07.87,0:14:11.46,Flashbacks-207-,,0,0,0,,Grand Line'a gireceğiz ve\Ndünyanın etrafını tavaf edeceğiz.
Dialogue: 0,0:14:11.46,0:14:13.87,Flashbacks-207-,,0,0,0,,Ama bizi burada beklemen gerekiyor.
Dialogue: 0,0:14:14.21,0:14:16.13,Flashbacks-207-,,0,0,0,,Tehlikeli bir yere gidiyoruz.
Dialogue: 0,0:14:16.13,0:14:18.46,Flashbacks-207-,,0,0,0,,Sana uygun değil.
Dialogue: 0,0:14:19.09,0:14:21.92,Flashbacks-207-,,0,0,0,,Endişelenme. Üç yıl göz açıp\Nkapayıncaya kadar geçer.
Dialogue: 0,0:14:21.92,0:14:23.18,Flashbacks-207-,,0,0,0,,Bizi unutma...
Dialogue: 0,0:14:23.68,0:14:26.43,Flashbacks-207-,,0,0,0,,Bir arada olmasak bile\Nher zaman arkadaş olacağız.
Dialogue: 0,0:14:30.89,0:14:32.39,Flashbacks-207-,,0,0,0,,Hadi, biz kaçtık!
Dialogue: 0,0:14:36.15,0:14:38.23,Flashbacks-207-,,0,0,0,,Millet! Yola koyulalım!
Dialogue: 0,0:14:38.23,0:14:39.78,Flashbacks-207-,,0,0,0,,Çapayı çekin!
Dialogue: 0,0:14:39.78,0:14:41.24,Flashbacks-207-,,0,0,0,,– Tamam!\N– Tamam!
Dialogue: 0,0:14:45.45,0:14:46.70,Flashbacks-207-,,0,0,0,,Laboon!
Dialogue: 0,0:14:47.91,0:14:49.99,Flashbacks-207-,,0,0,0,,Laboon! Bekle bizi!
Dialogue: 0,0:14:49.99,0:14:52.45,Flashbacks-207-,,0,0,0,,Mutlaka geri döneceğiz!
Dialogue: 0,0:14:52.45,0:14:54.08,Flashbacks-207-,,0,0,0,,Sözüm söz!
Dialogue: 0,0:15:06.64,0:15:09.56,Main-207-,,0,0,0,,Bu, 50 uzun yıl önceydi...
Dialogue: 0,0:15:09.56,0:15:10.81,Main-207-,,0,0,0,,50 yıl mı?
Dialogue: 0,0:15:10.81,0:15:14.18,Main-207-,,0,0,0,,Laboon onları 50 yıldır bekliyor mu?
Dialogue: 0,0:15:14.18,0:15:18.23,Main-207-,,0,0,0,,Bu yüzden mi bağırıp duvara tosluyor?
Dialogue: 0,0:15:18.23,0:15:19.02,Main-207-,,0,0,0,,Evet.
Dialogue: 0,0:15:28.45,0:15:30.20,Main-207-,,0,0,0,,Ne muhteşem bir kanal.
Dialogue: 0,0:15:30.20,0:15:33.25,Main-207-,,0,0,0,,Bu kadar büyük bir delikle\Nhayatta kalmasına şaşırdım.
Dialogue: 0,0:15:33.25,0:15:34.87,Main-207-,,0,0,0,,Bu da mı mizah anlayışındı?
Dialogue: 0,0:15:34.87,0:15:36.71,Main-207-,,0,0,0,,"Doktor"un mizah anlayışı.
Dialogue: 0,0:15:36.71,0:15:37.58,Main-207-,,0,0,0,,Doktor mu?
Dialogue: 0,0:15:37.58,0:15:39.84,Main-207-,,0,0,0,,Öyle görünmeyebilirim\Nama ben doktorum.
Dialogue: 0,0:15:39.84,0:15:43.09,Main-207-,,0,0,0,,Yıllar önce Burun'da\Nbir klinik işletiyordum.
Dialogue: 0,0:15:43.09,0:15:45.72,Main-207-,,0,0,0,,Birkaç yıl gemi doktorluğu da yaptım.
Dialogue: 0,0:15:45.72,0:15:46.93,Main-207-,,0,0,0,,Harbi mi?
Dialogue: 0,0:15:47.43,0:15:49.51,Main-207-,,0,0,0,,O hâlde gemimizin doktoru ol!
Dialogue: 0,0:15:49.51,0:15:51.31,Main-207-,,0,0,0,,Saçmalama.
Dialogue: 0,0:15:51.31,0:15:55.48,Main-207-,,0,0,0,,Artık sizin gibi pervasızca\Nşeyler yapacak yaşta değilim.
Dialogue: 0,0:15:55.48,0:15:58.77,Main-207-,,0,0,0,,Doktor ha?\NDemek ondan balinanın içi bu halde...
Dialogue: 0,0:15:58.77,0:16:00.48,Main-207-,,0,0,0,,Yani onca şey tedavi amaçlı mı?
Dialogue: 0,0:16:00.94,0:16:02.48,Main-207-,,0,0,0,,Doğru.
Dialogue: 0,0:16:02.48,0:16:08.16,Main-207-,,0,0,0,,Balina bu kadar büyük olunca\Ndışarıdan tedavisi imkânsız oluyor.
Dialogue: 0,0:16:08.91,0:16:10.28,Main-207-,,0,0,0,,Kapıları açacağım.
Dialogue: 0,0:16:21.21,0:16:22.96,Main-207-,,0,0,0,,Sonunda!!
Dialogue: 0,0:16:22.96,0:16:25.38,Main-207-,,0,0,0,,Gerçek gökyüzü!
Dialogue: 0,0:16:34.18,0:16:36.06,Main-207-,,0,0,0,,Bayan Wednesday, ne olu...
Dialogue: 0,0:16:38.31,0:16:40.48,Main-207-,,0,0,0,,50 yıl, ha....?
Dialogue: 0,0:16:40.48,0:16:42.94,Main-207-,,0,0,0,,Korsanlar onu harbiden çok bekletmişler...
Dialogue: 0,0:16:42.94,0:16:44.19,Main-207-,,0,0,0,,Aptal!
Dialogue: 0,0:16:44.19,0:16:46.28,Main-207-,,0,0,0,,Burası Grand Line.
Dialogue: 0,0:16:46.61,0:16:48.03,Main-207-,,0,0,0,,Çoktan ölmüşlerdir.
Dialogue: 0,0:16:48.03,0:16:51.37,Main-207-,,0,0,0,,Ne kadar beklerse beklesin,\Ngelmeyecekler.
Dialogue: 0,0:16:51.37,0:16:54.08,Main-207-,,0,0,0,,Niye bu kadar umutsuz konuştun ki?!
Dialogue: 0,0:16:54.45,0:16:56.37,Main-207-,,0,0,0,,Öldüklerinden emin değiliz!
Dialogue: 0,0:16:56.37,0:16:58.21,Main-207-,,0,0,0,,Belki de geri gelecekler!
Dialogue: 0,0:16:58.21,0:17:00.12,Main-207-,,0,0,0,,Çok dokunaklı bir hikaye!
Dialogue: 0,0:17:00.12,0:17:03.34,Main-207-,,0,0,0,,Arkadaşlarının verdiği sözü\Ntutacaklarına inanan bir balina...
Dialogue: 0,0:17:03.34,0:17:05.46,Main-207-,,0,0,0,,Değil mi, ihtiyar?!
Dialogue: 0,0:17:05.46,0:17:06.80,Main-207-,,0,0,0,,Evet...
Dialogue: 0,0:17:06.80,0:17:10.05,Main-207-,,0,0,0,,Ama gerçekler acıdır.
Dialogue: 0,0:17:10.05,0:17:14.68,Main-207-,,0,0,0,,Güvenilir bir kaynaktan teyit ettim.
Dialogue: 0,0:17:14.68,0:17:17.77,Main-207-,,0,0,0,,Grand Line'dan kaçmışlar...
Dialogue: 0,0:17:17.77,0:17:19.31,Main-207-,,0,0,0,,Olamaz...
Dialogue: 0,0:17:19.31,0:17:22.23,Main-207-,,0,0,0,,{\fad(0,984)}Onu bırakıp gitmiş olamazlar değil mi?!
Dialogue: 0,0:17:23.48,0:17:25.57,Main-207-,,0,0,0,,Grand Line'dan kaçmışlar...
Dialogue: 0,0:17:25.57,0:17:27.94,Main-207-,,0,0,0,,Yani Calm Belt'i aşıp hayatta kaldılar mı?
Dialogue: 0,0:17:27.94,0:17:30.40,Main-207-,,0,0,0,,Hayatta olsalar bile,
Dialogue: 0,0:17:30.40,0:17:32.86,Main-207-,,0,0,0,,geri döneceklerinden şüpheliyim.
Dialogue: 0,0:17:32.86,0:17:36.08,Main-207-,,0,0,0,,Mevsimler. Hava durumu.\NAkıntı. Rüzgârın yönü.
Dialogue: 0,0:17:36.08,0:17:38.33,Main-207-,,0,0,0,,Hepsi o kadar tahmin edilemez ki...
Dialogue: 0,0:17:38.33,0:17:41.71,Main-207-,,0,0,0,,Grand Line'da sağduyu işe yaramaz.
Dialogue: 0,0:17:41.71,0:17:46.55,Main-207-,,0,0,0,,Grand Line'ın dehşeti,\Niradesi zayıf olanlara hiç acımaz.
Dialogue: 0,0:17:46.55,0:17:50.17,Main-207-,,0,0,0,,İradeleri zayıf olduğu için\Nverdikleri sözden dönerek...
Dialogue: 0,0:17:50.17,0:17:54.05,Main-207-,,0,0,0,,kendi kıçlarını kurtarmak için kaçtılar.
Dialogue: 0,0:17:55.85,0:17:58.60,Main-207-,,0,0,0,,Balinayı terk mi ettiler?!
Dialogue: 0,0:17:58.60,0:18:01.23,Main-207-,,0,0,0,,50 yıldır onları beklemişken mi?!
Dialogue: 0,0:18:01.23,0:18:02.44,Main-207-,,0,0,0,,Çok gaddarca!
Dialogue: 0,0:18:02.98,0:18:06.23,Main-207-,,0,0,0,,Gelmeyeceklerini biliyorsan,\Nbunu niye ona söylemedin?
Dialogue: 0,0:18:06.57,0:18:09.36,Main-207-,,0,0,0,,Bu balina, insanların dediklerini anlıyor, değil mi?
Dialogue: 0,0:18:09.69,0:18:11.03,Main-207-,,0,0,0,,Ona söyledim.
Dialogue: 0,0:18:11.03,0:18:13.49,Main-207-,,0,0,0,,Tüm hikâyeyi anlattım.
Dialogue: 0,0:18:14.07,0:18:16.28,Flashbacks-207-,,0,0,0,,Laboon! Dinle beni!
Dialogue: 0,0:18:16.28,0:18:19.33,Flashbacks-207-,,0,0,0,,Duydum ki Grand Line'ı terketmişler.
Dialogue: 0,0:18:19.87,0:18:22.21,Flashbacks-207-,,0,0,0,,Sizler yakın arkadaştınız...
Dialogue: 0,0:18:22.54,0:18:26.21,Flashbacks-207-,,0,0,0,,ve sana verdikleri söz emin ol gerçekti.
Dialogue: 0,0:18:32.30,0:18:34.09,Flashbacks-207-,,0,0,0,,Ama korkarım ki...
Dialogue: 0,0:18:34.68,0:18:36.60,Flashbacks-207-,,0,0,0,,asla geri dönmeyecekler...
Dialogue: 0,0:18:56.87,0:18:59.53,Flashbacks-207-,,0,0,0,,Aç kulaklarını da dinle, Laboon!
Dialogue: 0,0:18:59.53,0:19:01.24,Flashbacks-207-,,0,0,0,,Gelmeyecek–
Dialogue: 0,0:19:10.34,0:19:13.01,Flashbacks-207-,,0,0,0,,Kabullenemiyorsun, biliyorum.
Dialogue: 0,0:19:13.76,0:19:17.14,Flashbacks-207-,,0,0,0,,Ama artık kabullenmek zorundasın...
Dialogue: 0,0:19:17.80,0:19:18.51,Flashbacks-207-,,0,0,0,,Laboon!
Dialogue: 0,0:19:23.06,0:19:24.60,Flashbacks-207-,,0,0,0,,Laboon!
Dialogue: 0,0:19:34.86,0:19:40.70,Main-207-,,0,0,0,,O günden sonra\NReverse Mountain'a bağırmaya ve...
Dialogue: 0,0:19:40.70,0:19:44.33,Main-207-,,0,0,0,,Red Line'a toslamaya başladı.
Dialogue: 0,0:19:44.33,0:19:46.25,Main-207-,,0,0,0,,Sanki duvarın ötesinden...
Dialogue: 0,0:19:46.25,0:19:51.00,Main-207-,,0,0,0,,geleceklermiş gibi diretircesine...
Dialogue: 0,0:19:51.59,0:19:52.88,Main-207-,,0,0,0,,Ne balinaymış be...
Dialogue: 0,0:19:52.88,0:19:55.05,Main-207-,,0,0,0,,Beklemenin bir anlamı olmasa bile...
Dialogue: 0,0:19:55.05,0:19:59.01,Main-207-,,0,0,0,,{\q2}Bana inanmayı reddediyor çünkü haklıysam\Nbeklemesinin bir anlamı kalmıyor.
Dialogue: 0,0:19:59.68,0:20:03.68,Main-207-,,0,0,0,,Her şeyden çok bundan korkuyor.
Dialogue: 0,0:20:03.68,0:20:05.98,Main-207-,,0,0,0,,Laboon, Batı Mavi'den.
Dialogue: 0,0:20:06.39,0:20:08.35,Main-207-,,0,0,0,,Oraya geri dönmesinin imkânı yok.
Dialogue: 0,0:20:08.35,0:20:14.48,Main-207-,,0,0,0,,{\q2}O korsanlar, onun için sadece birer dost değil,\Naynı zamanda evine dönme umuduydu.
Dialogue: 0,0:20:14.48,0:20:18.49,Main-207-,,0,0,0,,Bu zavallı balinanın durumu bir kenara,
Dialogue: 0,0:20:18.49,0:20:21.28,Main-207-,,0,0,0,,sen de yüzüstü bırakılmış\Nhissediyorsun, değil mi?
Dialogue: 0,0:20:23.62,0:20:26.20,Main-207-,,0,0,0,,Onun için yeterince uğraşmadın mı?
Dialogue: 0,0:20:26.20,0:20:28.87,Main-207-,,0,0,0,,Alnındaki yaralara baksanıza!
Dialogue: 0,0:20:28.87,0:20:34.30,Main-207-,,0,0,0,,Kafasını vurmaya devam ederse\Nöleceği aşikâr.
Dialogue: 0,0:20:34.30,0:20:37.63,Main-207-,,0,0,0,,Tuhaf bir ilişki ama\N50 yıldır onun yanındayım.
Dialogue: 0,0:20:37.63,0:20:39.68,Main-207-,,0,0,0,,Durup ölmesine göz yumamam.
Dialogue: 0,0:20:42.51,0:20:44.14,Main-207-,,0,0,0,,N'apıyor yine bu salak?
Dialogue: 0,0:20:44.14,0:20:45.89,Main-207-,,0,0,0,,İki saniye boş bırakmaya gelmiyor...
Dialogue: 0,0:20:45.89,0:20:47.85,Main-207-,,0,0,0,,Kendini dağcı mı sanıyor?
Dialogue: 0,0:20:49.64,0:20:52.27,Main-207-,,0,0,0,,{\fad(150,150)}Lastik-Lastik...
Dialogue: 0,0:20:52.27,0:20:54.36,Main-207-,,0,0,0,,{\fad(150,150)}Çiçek Demeti!
Dialogue: 0,0:20:54.69,0:20:56.49,Main-207-,,0,0,0,,Gemi direği değil mi o?
Dialogue: 0,0:20:56.49,0:20:58.49,Main-207-,,0,0,0,,Evet. Bizim geminin.
Dialogue: 0,0:20:58.49,0:20:59.78,Main-207-,,0,0,0,,Ana direk...
Dialogue: 0,0:21:00.11,0:21:02.41,Main-207-,,0,0,0,,Hey! Gemiyi parçalama!
Dialogue: 0,0:21:09.21,0:21:11.67,Main-207-,,0,0,0,,– Ne yapıyorsun be?!\N– Ne yapıyorsun be?!
Dialogue: 0,0:21:22.47,0:21:23.55,Main-207-,,0,0,0,,Lan...?! Hey, çocuk!
Dialogue: 0,0:21:23.93,0:21:26.97,Main-207-,,0,0,0,,Endişelenme! Ezilerek ölmez!
Dialogue: 0,0:21:31.77,0:21:32.60,Main-207-,,0,0,0,,Ahmak!
Dialogue: 0,0:21:39.36,0:21:40.78,Main-207-,,0,0,0,,Ne düşünüyor ki?
Dialogue: 0,0:21:44.83,0:21:47.99,Main-207-,,0,0,0,,Luffy! Ne yaptığını sanıyorsun?!
Dialogue: 0,0:21:52.83,0:21:53.96,Main-207-,,0,0,0,,Berabere!
Dialogue: 0,0:21:58.76,0:22:00.05,Main-207-,,0,0,0,,Baya güçlüyüm, ha?
Dialogue: 0,0:22:02.13,0:22:04.55,Main-207-,,0,0,0,,Dövüşümüz bitmedi!
Dialogue: 0,0:22:04.55,0:22:06.56,Main-207-,,0,0,0,,Sonra hesaplaşırız!
Dialogue: 0,0:22:06.56,0:22:10.14,Main-207-,,0,0,0,,Arkadaşların ölmüş olabilir ama ben,\Nher zaman senin rakibinim!
Dialogue: 0,0:22:10.14,0:22:14.35,Main-207-,,0,0,0,,Bir gün, kesinlikle bunu çözüp\Nkim daha güçlüymüş görmeliyiz.
Dialogue: 0,0:22:14.35,0:22:18.15,Main-207-,,0,0,0,,Grand Line'ı dolaşıp,\Nseni görmeye geri geleceğiz.
Dialogue: 0,0:22:19.48,0:22:21.44,Main-207-,,0,0,0,,Geri döndüğümde, tekrar dövüşelim!
Dialogue: 0,0:22:37.04,0:22:38.21,Main-207-,,0,0,0,,Harika.
Dialogue: 0,0:22:38.21,0:22:42.09,Main-207-,,0,0,0,,Bu sembol,\Ntekrar dövüşeceğimizin sözü!
Dialogue: 0,0:22:42.09,0:22:48.10,Main-207-,,0,0,0,,Biz geri dönene dek, kafanı \Ntoslama da silinmesin. Anlaştık mı?!
Dialogue: 0,0:22:51.52,0:22:53.27,Main-207-,,0,0,0,,Pekâlâ!
Dialogue: 0,0:22:55.15,0:22:56.27,Main-207-,,0,0,0,,Nereye gittiler, onlar?
Dialogue: 0,0:22:56.27,0:22:57.73,Main-207-,,0,0,0,,"Onlar" mı?
Dialogue: 0,0:22:57.73,0:22:59.61,Main-207-,,0,0,0,,Ah, o garip tipleri mi diyorsun?
Dialogue: 0,0:22:59.61,0:23:01.11,Main-207-,,0,0,0,,Herhâlde kaçtılar?
Dialogue: 0,0:23:01.11,0:23:04.40,Main-207-,,0,0,0,,Ne iş çevirdiklerini hiç öğrenemedik de...?
Dialogue: 0,0:23:07.32,0:23:10.62,Main-207-,,0,0,0,,Bayan Wednesday, ne yapacağız?
Dialogue: 0,0:23:12.91,0:23:16.67,Main-207-,,0,0,0,,En azından geri dönüp\Npatrona rapor vermek zorundayız.
Dialogue: 0,0:23:16.67,0:23:19.42,Main-207-,,0,0,0,,Bu görevi çoktan tamamlamalıydık.
Dialogue: 0,0:23:19.42,0:23:23.38,Main-207-,,0,0,0,,Haklısın. Hain olarak damgalanırsak\Nbizim için çok kötü olur.
Dialogue: 0,0:23:23.76,0:23:24.51,Main-207-,,0,0,0,,Evet.
Dialogue: 0,0:23:24.51,0:23:27.84,Main-207-,,0,0,0,,Silahlarımızı kaybettiğimiz için\Nüsse dönüp baştan başlamalıyız.
Dialogue: 0,0:23:27.84,0:23:31.97,Main-207-,,0,0,0,,Öyle gerekiyorsa.\NO zaman başlayalım... Ha?
Dialogue: 0,0:23:31.97,0:23:34.31,Main-207-,,0,0,0,,Ha...? Nerede..? Ne?!
Dialogue: 0,0:23:34.64,0:23:35.64,Main-207-,,0,0,0,,Sorun ne?
Dialogue: 0,0:23:37.19,0:23:37.90,Main-207-,,0,0,0,,Gitmiş...
Dialogue: 0,0:23:37.90,0:23:38.52,Main-207-,,0,0,0,,Ne?
Dialogue: 0,0:23:41.27,0:23:42.19,Main-207-,,0,0,0,,Bu ne?
Dialogue: 0,0:23:42.94,0:23:44.99,Main-207-,,0,0,0,,Seyir pusulasını mı düşürdün?!
Dialogue: 0,0:23:44.99,0:23:46.70,Main-207-,,0,0,0,,Çok özür dilerim, Bayan Wednesday!
Dialogue: 0,0:23:46.70,0:23:48.99,Main-207-,,0,0,0,,O olmadan kasabamıza dönemeyiz ki.
Dialogue: 0,0:23:50.99,0:23:52.12,Main-207-,,0,0,0,,Görünüşe–
Dialogue: 0,0:23:53.62,0:23:56.00,Main-207-,,0,0,0,,Y-Yoksa o...?!
Dialogue: 0,0:23:56.00,0:23:56.71,Main-207-,,0,0,0,,Ha?
Dialogue: 0,0:23:58.29,0:23:59.54,Main-207-,,0,0,0,,Onlar...
Dialogue: 0,0:24:00.50,0:24:02.46,Main-207-,,0,0,0,,O-Olamaz...
Dialogue: 0,0:24:03.38,0:24:04.67,Main-207-,,0,0,10,,...Uğursuzlar!
Dialogue: 0,0:24:04.67,0:24:05.97,Main-207-,,0,0,10,,Lanet! Geç kaldık!
Dialogue: 0,0:24:05.97,0:24:07.05,Main-207-,,0,0,10,,Bay 13!
Dialogue: 0,0:24:07.05,0:24:08.89,Main-207-,,0,0,10,,Bayan Friday!
Dialogue: 0,0:24:09.22,0:24:11.55,Main-207-,,0,0,0,,Lütfen, durun! Açıklayabiliriz!
Dialogue: 0,0:24:11.55,0:24:14.27,Main-207-,,0,0,0,,Derhal patrona rapor vereceğiz!
Dialogue: 0,0:24:28.41,0:24:32.74,Main-207-,,0,0,0,,Oh be! Artık Grand Line\Nyolculuğumuzu planlayabilirim.
Dialogue: 0,0:24:37.54,0:24:41.42,Main-207-,,0,0,0,,Pekâlâ! Sonunda mavi yüzgeçli\Nfil orkinosunu pişireceğim!
Dialogue: 0,0:24:41.42,0:24:42.92,Main-207-,,0,0,0,,Kahretsin...!
Dialogue: 0,0:24:43.88,0:24:47.88,Main-207-,,0,0,0,,Luffy'nin, gemimizi parçalarken\Naklı neredeydi?! Aman be...
Dialogue: 0,0:24:47.88,0:24:49.18,Main-207-,,0,0,0,,Hey, Zoro!
Dialogue: 0,0:24:49.18,0:24:51.97,Main-207-,,0,0,0,,Bir el atsana!\NBen gemi marangozu değilim!
Dialogue: 0,0:24:57.89,0:24:59.48,Main-207-,,0,0,0,,Bu çığlık da ne?
Dialogue: 0,0:24:59.48,0:25:01.35,Main-207-,,0,0,0,,Sorun nedir, Nami-{\i1}san{\i}?!
Dialogue: 0,0:25:01.35,0:25:03.52,Main-207-,,0,0,0,,Eğer acıktıysan, yemeğin hazır!
Dialogue: 0,0:25:03.52,0:25:04.32,Main-207-,,0,0,0,,Hazır mı?
Dialogue: 0,0:25:04.65,0:25:06.78,Main-207-,,0,0,0,,P-Pusulamız bozulmuş!
Dialogue: 0,0:25:07.40,0:25:08.99,Main-207-,,0,0,0,,Hiçbir yeri göstermiyor!
Dialogue: 0,0:25:08.99,0:25:10.66,Main-207-,,0,0,0,,Evet, haklısın.
Dialogue: 0,0:25:10.66,0:25:12.78,Main-207-,,0,0,0,,Dönüp duruyor.
Dialogue: 0,0:25:12.78,0:25:14.45,Main-207-,,0,0,0,,Vay! Eğlenceli!
Dialogue: 0,0:25:15.33,0:25:19.25,Main-207-,,0,0,0,,Görünüşe göre buraya\Nhazırlıksız gelmişsiniz.
Dialogue: 0,0:25:19.25,0:25:22.33,Main-207-,,0,0,0,,Tanrı aşkına!\NCanınızı sokakta mı buldunuz?
Dialogue: 0,0:25:22.79,0:25:23.42,Main-207-,,0,0,0,,Ne?
Dialogue: 0,0:25:23.42,0:25:24.13,Main-207-,,0,0,0,,Yemek?
Dialogue: 0,0:25:24.13,0:25:25.96,Main-207-,,0,0,0,,Sen ot yiyebilirsin.
Dialogue: 0,0:25:25.96,0:25:27.42,Main-207-,,0,0,0,,Size söylemiştim
Dialogue: 0,0:25:27.42,0:25:30.84,Main-207-,,0,0,0,,Sağduyu bu denizde işe yaramaz.
Dialogue: 0,0:25:30.84,0:25:34.14,Main-207-,,0,0,0,,Pusulanız bozuk değil.
Dialogue: 0,0:25:34.93,0:25:37.14,Main-207-,,0,0,0,,O zaman manyetik alanlar mı?
Dialogue: 0,0:25:37.14,0:25:38.22,Main-207-,,0,0,0,,Evet.
Dialogue: 0,0:25:38.22,0:25:43.61,Main-207-,,0,0,0,,Grand Line'daki adalar, yüksek\Nmiktarda manyetik mineral içerir.
Dialogue: 0,0:25:43.61,0:25:46.36,Main-207-,,0,0,0,,Grand Line boyunca\Nanormalliklere sebep olurlar.
Dialogue: 0,0:25:46.36,0:25:49.78,Main-207-,,0,0,0,,Dahası, akıntı ve rüzgârlar da\Nsabit değildir.
Dialogue: 0,0:25:49.78,0:25:53.62,Main-207-,,0,0,0,,Rotacıysan, bunun ne kadar\Nkorkunç olduğunu bilirsin.
Dialogue: 0,0:25:53.62,0:25:57.83,Main-207-,,0,0,0,,Evet, yönümüzü bilemezsek\Nhapı yuttuk demektir.
Dialogue: 0,0:25:57.83,0:25:58.79,Main-207-,,0,0,0,,Leziz!
Dialogue: 0,0:25:58.79,0:26:00.91,Main-207-,,0,0,0,,B-Bilmiyordum! Şey...
Dialogue: 0,0:26:00.91,0:26:03.54,Main-207-,,0,0,0,,Hey! Bu çok fena! Ne yapacağız?!
Dialogue: 0,0:26:03.54,0:26:06.00,Main-207-,,0,0,0,,Hiç de fena değil. Nefis!
Dialogue: 0,0:26:06.00,0:26:08.96,Main-207-,,0,0,0,,Bir saniye sessiz durabilir misiniz?!
Dialogue: 0,0:26:08.96,0:26:12.13,Main-207-,,0,0,0,,Mavi yüzgeçli fil orkinosunun\Nburnu da pek lezzetliymiş!
Dialogue: 0,0:26:12.59,0:26:17.60,Main-207-,,0,0,0,,Grand Line'da dolaşabilmeniz için\Nbir seyir pusulası şart.
Dialogue: 0,0:26:17.60,0:26:19.85,Main-207-,,0,0,0,,Seyir pusulası mı? O ne ki?
Dialogue: 0,0:26:19.85,0:26:23.85,Main-207-,,0,0,0,,Manyetizmayı ölçen özel bir pusula çeşidi.
Dialogue: 0,0:26:23.85,0:26:25.40,Main-207-,,0,0,0,,Garip görünüşlü mü?
Dialogue: 0,0:26:25.40,0:26:27.98,Main-207-,,0,0,0,,Evet, tuhaf bir şekli var.
Dialogue: 0,0:26:27.98,0:26:29.40,Main-207-,,0,0,0,,Bunun gibi mi?
Dialogue: 0,0:26:29.40,0:26:30.53,Main-207-,,0,0,0,,Evet, o.
Dialogue: 0,0:26:30.99,0:26:35.91,Main-207-,,0,0,0,,Seyir pusulası olmadan\NGrand Line'da yolunuzu bulamazsınız.
Dialogue: 0,0:26:36.66,0:26:38.16,Main-207-,,0,0,0,,Anladım...
Dialogue: 0,0:26:38.16,0:26:39.91,Main-207-,,0,0,0,,Ama bir saniye...
Dialogue: 0,0:26:40.41,0:26:41.83,Main-207-,,0,0,0,,Luffy?
Dialogue: 0,0:26:42.21,0:26:44.83,Main-207-,,0,0,0,,Sende ne işi var onun?
Dialogue: 0,0:26:46.54,0:26:50.63,Main-207-,,0,0,0,,O iki tuhaf tip, gemiye düşürmüş.
Dialogue: 0,0:26:50.63,0:26:51.80,Main-207-,,0,0,0,,Öyle mi?
Dialogue: 0,0:26:51.80,0:26:53.17,Main-207-,,0,0,0,,Niye bana vurdun?
Dialogue: 0,0:26:53.17,0:26:54.13,Main-207-,,0,0,0,,İçimden geldi.
Dialogue: 0,0:26:54.13,0:26:55.09,Main-207-,,0,0,0,,Makul.
Dialogue: 0,0:26:56.34,0:26:57.68,Main-207-,,0,0,0,,Demek seyir pusulası bu.
Dialogue: 0,0:26:57.68,0:26:59.22,Main-207-,,0,0,0,,Hiç işaret yok.
Dialogue: 0,0:26:59.22,0:27:06.81,Main-207-,,0,0,0,,Grand Line'daki adaların manyetik\Nalanları belli bir kuralı takip eder:
Dialogue: 0,0:27:06.81,0:27:11.99,Main-207-,,0,0,0,,İki adanın birbirine uyguladığı\Nmanyetik kuvveti hesaplayarak,
Dialogue: 0,0:27:11.99,0:27:14.49,Main-207-,,0,0,0,,bir sonraki adaya olan\Nyolu bulabilirsiniz.
Dialogue: 0,0:27:14.99,0:27:18.16,Main-207-,,0,0,0,,Tabii, adanın denizdeki yerini\Nbilemeyeceğinizden,
Dialogue: 0,0:27:18.16,0:27:22.00,Main-207-,,0,0,0,,güvenebileceğiniz tek şey\Nseyir pusulasının manyetik kaydıdır.
Dialogue: 0,0:27:22.45,0:27:29.13,Main-207-,,0,0,0,,{\q2}Başlamak için, Reverse Mountain'ın\Nyedi manyetik alanından birini seçmelisiniz.
Dialogue: 0,0:27:29.13,0:27:32.05,Main-207-,,0,0,0,,Ama hangi adadan başladığınız farketmeksizin,
Dialogue: 0,0:27:32.05,0:27:35.93,Main-207-,,0,0,0,,manyetik çekimler sonunda sizi\Ntek bir rotaya itecektir.
Dialogue: 0,0:27:35.93,0:27:39.47,Main-207-,,0,0,0,,Ve yolculuğun sonundaki adanın adı da...
Dialogue: 0,0:27:39.97,0:27:41.31,Main-207-,,0,0,0,,Laugh Tale'dir.
Dialogue: 0,0:27:41.31,0:27:44.10,Main-207-,,0,0,0,,Grand Line'daki son ada.
Dialogue: 0,0:27:44.10,0:27:48.31,Main-207-,,0,0,0,,Bu adanın varlığını onaylayan\Ntek kişi Korsanlar Kralı'ydı.
Dialogue: 0,0:27:48.31,0:27:50.44,Main-207-,,0,0,0,,Efsanevi bir ada.
Dialogue: 0,0:27:50.44,0:27:51.82,Main-207-,,0,0,0,,Laugh Tale...
Dialogue: 0,0:27:51.82,0:27:54.65,Main-207-,,0,0,0,,One Piece de orada değil mi?!
Dialogue: 0,0:27:54.65,0:27:57.70,Main-207-,,0,0,0,,Kim bilir? En muhtemel teori o,
Dialogue: 0,0:27:57.70,0:28:00.41,Main-207-,,0,0,0,,ama kanıtlayan olmadı.
Dialogue: 0,0:28:00.41,0:28:02.04,Main-207-,,0,0,0,,Oraya...
Dialogue: 0,0:28:02.04,0:28:03.58,Main-207-,,0,0,0,,vardığımızda anlarız.
Dialogue: 0,0:28:06.46,0:28:09.17,Main-207-,,0,0,0,,Tamam, ben hazırım!\NHazırlanalım mı artık?
Dialogue: 0,0:28:09.17,0:28:11.00,Main-207-,,0,0,0,,Hepsini tek başına mı yedin?!
Dialogue: 0,0:28:11.00,0:28:12.67,Main-207-,,0,0,0,,Oha! Kemikleri bile yemiş.
Dialogue: 0,0:28:12.67,0:28:15.97,Main-207-,,0,0,0,,Seyir pusulası, demek? \NBuna gözümüz gibi bakmamız lazım.
Dialogue: 0,0:28:15.97,0:28:18.18,Main-207-,,0,0,0,,Yolculuğumuz için çok mühim.
Dialogue: 0,0:28:18.18,0:28:19.93,Main-207-,,0,0,0,,Seni kahrolası lastik adam!
Dialogue: 0,0:28:19.93,0:28:22.56,Main-207-,,0,0,0,,Nami-{\i1}san{\i0}'a müthiş bir yemek yapmıştım,
Dialogue: 0,0:28:23.35,0:28:26.48,Main-207-,,0,0,0,,ama o, tek bir ısırık bile yiyemedi!
Dialogue: 0,0:28:41.37,0:28:42.33,Main-207-,,0,0,0,,N'apıyorsun?
Dialogue: 0,0:28:42.33,0:28:44.74,Main-207-,,0,0,0,,Nasılmış, kodumun lastiği seni?
Dialogue: 0,0:28:43.66,0:28:44.74,Secondary-207-,,0,0,0,,Sanji-{\i1}kun{\i0}...
Dialogue: 0,0:28:44.74,0:28:46.20,Main-207-,,0,0,0,,Evet, Nami-{\i1}san{\i}!
Dialogue: 0,0:28:47.04,0:28:50.17,Main-207-,,0,0,0,,Defolup gidin de az serinleyin!!
Dialogue: 0,0:28:54.55,0:28:56.55,Main-207-,,0,0,0,,Hey, dur bir saniye...
Dialogue: 0,0:28:57.01,0:29:00.30,Main-207-,,0,0,0,,Bu çok önemli bir şey değil miydi?!
Dialogue: 0,0:29:00.30,0:29:02.80,Main-207-,,0,0,0,,Biricik seyir pusulamız...
Dialogue: 0,0:29:02.80,0:29:05.14,Main-207-,,0,0,0,,Panik yapmayın.\NBenimkini veririm size.
Dialogue: 0,0:29:05.56,0:29:08.06,Main-207-,,0,0,0,,Laboon için bir teşekkür olarak görün.
Dialogue: 0,0:29:15.57,0:29:17.57,Main-207-,,0,0,0,,Ahh... Öleceğim sandım. Ha?
Dialogue: 0,0:29:20.20,0:29:23.32,Main-207-,,0,0,0,,Buyrun, yardım edeyim, hanımefendi.
Dialogue: 0,0:29:23.32,0:29:24.37,Main-207-,,0,0,0,,Oh, teşekkür ederim.
Dialogue: 0,0:29:24.37,0:29:25.58,Main-207-,,0,0,0,,Ne güzel bir gün, değil mi?
Dialogue: 0,0:29:25.58,0:29:26.37,Main-207-,,0,0,0,,Hey!
Dialogue: 0,0:29:27.00,0:29:28.29,Main-207-,,0,0,0,,Sizden bir ricamız var.
Dialogue: 0,0:29:31.92,0:29:33.21,Main-207-,,0,0,0,,Whisky Peak mi?
Dialogue: 0,0:29:33.54,0:29:34.75,Main-207-,,0,0,0,,Ne tuhaf bir isim.
Dialogue: 0,0:29:34.75,0:29:35.84,Main-207-,,0,0,0,,O ne ki?
Dialogue: 0,0:29:35.84,0:29:38.59,Main-207-,,0,0,0,,Bizim yaşadığımız yer... beyefendi.
Dialogue: 0,0:29:38.59,0:29:40.72,Main-207-,,0,0,0,,Sizin geminize ne oldu?
Dialogue: 0,0:29:40.72,0:29:43.18,Main-207-,,0,0,0,,Berbat hâlde.
Dialogue: 0,0:29:43.80,0:29:47.89,Main-207-,,0,0,0,,Balinayı öldürmeye kalkıp şimdi bunu\Nistemek biraz abartı değil mi, Bay 9?
Dialogue: 0,0:29:48.31,0:29:50.23,Main-207-,,0,0,0,,Neyin nesiniz siz bakayım?
Dialogue: 0,0:29:50.23,0:29:51.94,Main-207-,,0,0,0,,Ben bir kralım.
Dialogue: 0,0:29:53.02,0:29:53.98,Main-207-,,0,0,0,,Yalancı.
Dialogue: 0,0:29:55.23,0:29:56.98,Main-207-,,0,0,0,,Söyleyemeyiz!
Dialogue: 0,0:29:56.98,0:29:59.24,Main-207-,,0,0,0,,Ama evimize geri dönmek istiyoruz.
Dialogue: 0,0:29:59.24,0:30:02.57,Main-207-,,0,0,0,,Ketumluk etmek istemeyiz ama...
Dialogue: 0,0:30:02.57,0:30:04.99,Main-207-,,0,0,0,,şirketimizin mottosu\N"gizlilik" en nihayetinde...
Dialogue: 0,0:30:04.99,0:30:07.41,Main-207-,,0,0,0,,Size hakkımızda hiçbir şey söyleyemeyiz.
Dialogue: 0,0:30:07.74,0:30:11.12,Main-207-,,0,0,0,,İyi niyetinize güvenerek size yalvarıyoruz.
Dialogue: 0,0:30:11.12,0:30:13.50,Main-207-,,0,0,0,,İyiliğinizin karşılığını mutlaka vereceğiz.
Dialogue: 0,0:30:13.50,0:30:15.34,Main-207-,,0,0,0,,İnanmayın.
Dialogue: 0,0:30:15.34,0:30:18.42,Main-207-,,0,0,0,,Ne derlerse desinler,\Nbunlar güvenilmez insanlar.
Dialogue: 0,0:30:18.84,0:30:23.93,Main-207-,,0,0,0,,Bu arada seyir pusulamız kırıldı.\NHâlâ gelmek istiyor musunuz?
Dialogue: 0,0:30:24.26,0:30:27.47,Main-207-,,0,0,0,,Ne?! Kırdınız mı?!\NO benimdi, biliyorsunuz!
Dialogue: 0,0:30:27.47,0:30:31.52,Main-207-,,0,0,0,,Biz mütevazıyken siz kibirli mi\Ndavranıyorsunuz?! Bizden farkınız yok!
Dialogue: 0,0:30:31.89,0:30:33.31,Main-207-,,0,0,0,,Ah, söylemeyi unuttum,
Dialogue: 0,0:30:33.31,0:30:36.48,Main-207-,,0,0,0,,bay Crocus sayesinde\Nbir yedeğimiz var.
Dialogue: 0,0:30:37.32,0:30:39.48,Main-207-,,0,0,0,,Siz, yüce gönüllü insanlara yalvarıyoruz.
Dialogue: 0,0:30:39.86,0:30:42.45,Thoughts-207-,,0,0,0,,Kahretsin! Cadaloz bizimle oynuyor!
Dialogue: 0,0:30:42.78,0:30:44.28,Main-207-,,0,0,0,,Olur, gelebilirsiniz.
Dialogue: 0,0:30:45.70,0:30:47.16,Main-207-,,0,0,0,,Whisky Peak mi ne?
Dialogue: 0,0:30:47.16,0:30:48.33,Main-207-,,0,0,0,,Gidelim bakalım.
Dialogue: 0,0:30:48.33,0:30:49.08,Main-207-,,0,0,0,,– Ne?\N– Ha?
Dialogue: 0,0:30:49.08,0:30:53.29,Main-207-,,0,0,0,,Hey, bu güvenilmez tiplerle\Nyola çıkmamız doğru mu?
Dialogue: 0,0:30:53.66,0:30:54.71,Main-207-,,0,0,0,,Sorun ne?
Dialogue: 0,0:30:54.71,0:30:56.75,Main-207-,,0,0,0,,Öyle ufak detayları dert etmeyin.
Dialogue: 0,0:30:56.75,0:31:01.71,Main-207-,,0,0,0,,Burada rotanızı belirledikten sonra, değiştiremezsiniz.
Dialogue: 0,0:31:01.71,0:31:04.55,Main-207-,,0,0,0,,Beğenmezsek bir tur daha döneriz.
Dialogue: 0,0:31:05.09,0:31:06.47,Main-207-,,0,0,0,,Öyle mi...?
Dialogue: 0,0:31:07.01,0:31:08.85,Main-207-,,0,0,0,,Artık yola çıkalım mı?
Dialogue: 0,0:31:10.22,0:31:13.31,Main-207-,,0,0,0,,Balinaya sözümü verdim.\NHadi yola çıkalım.
Dialogue: 0,0:31:13.68,0:31:16.06,Main-207-,,0,0,0,,Sen de kimsin?
Dialogue: 0,0:31:16.06,0:31:17.02,Main-207-,,0,0,0,,Ben mi?
Dialogue: 0,0:31:17.02,0:31:17.90,Main-207-,,0,0,0,,Ben...
Dialogue: 0,0:31:18.31,0:31:20.48,Main-207-,,0,0,0,,Korsanlar Kralı olacak adamım.
Dialogue: 0,0:31:24.95,0:31:26.53,Thoughts-207-,,0,0,0,,Ne aptal bir korsan...
Dialogue: 0,0:31:29.41,0:31:30.95,Main-207-,,0,0,0,,Hâllolmuş olmalı.
Dialogue: 0,0:31:30.95,0:31:33.00,Main-207-,,0,0,0,,Pusula şimdiye ayarlanmış olmalı.
Dialogue: 0,0:31:33.62,0:31:36.08,Main-207-,,0,0,0,,Harita ile aynı yönü mü işaret ediyor?
Dialogue: 0,0:31:36.08,0:31:36.83,Main-207-,,0,0,0,,Evet.
Dialogue: 0,0:31:37.54,0:31:39.50,Main-207-,,0,0,0,,Whisky Peak'i işaret ediyor.
Dialogue: 0,0:31:40.00,0:31:41.84,Main-207-,,0,0,0,,Görüşürüz, çiçekli ihtiyar!
Dialogue: 0,0:31:41.84,0:31:43.42,Main-207-,,0,0,0,,Seyir pusulası için sağ ol!
Dialogue: 0,0:31:43.42,0:31:45.34,Main-207-,,0,0,0,,Evet. İyi yolculuklar!
Dialogue: 0,0:31:45.34,0:31:47.97,Main-207-,,0,0,0,,Seninle de görüşürüz, balina!\NŞimdilik gidiyorum!
Dialogue: 0,0:31:52.93,0:31:54.89,Main-207-,,0,0,0,,Whisky Peak'e...
Dialogue: 0,0:31:54.89,0:31:57.27,Main-207-,,0,0,0,,tam yol ileri!!
Dialogue: 0,0:31:57.27,0:31:59.27,Main-207-,,0,0,0,,– Evet!\N– Evet!
Dialogue: 0,0:32:16.91,0:32:21.79,Main-207-,,0,0,0,,Merak ediyorum, acaba onlar\Nnicedir beklediğimiz korsanlar mı...?
Dialogue: 0,0:32:21.79,0:32:25.76,Main-207-,,0,0,0,,Bu çocuğun çok acayip bir aurası var...
Dialogue: 0,0:32:28.80,0:32:30.01,Main-207-,,0,0,0,,değil mi,
Dialogue: 0,0:32:30.01,0:32:31.72,Main-207-,,0,0,0,,Roger?
Comment: 0,0:00:00.00,0:00:00.00,Main-207-,,0,0,0,,{=23}===============================DIALOGUE============================
