Dialogue: 0,0:02:08.48,0:02:10.07,Main-207-,,0,0,0,,Che succede, Zoro?{Cora}
Dialogue: 0,0:02:10.07,0:02:12.57,Main-207-,,0,0,0,,È da un po' che hai quella faccia seria.{ -angy}
Dialogue: 0,0:02:12.57,0:02:15.11,Main-207-,,0,0,0,,{\q2}Ecco... \NSpero sia solo la mia immaginazione, ma...{-angy}
Dialogue: 0,0:02:15.11,0:02:16.07,Main-207-,,0,0,0,,Cosa?{angy}
Dialogue: 0,0:02:16.07,0:02:20.70,Main-207-,,0,0,0,,{\q2}Ho come l'impressione che...\N questa nave non si muova da un po'.{Tony}
Dialogue: 0,0:02:24.96,0:02:25.54,Main-207-,,0,0,0,,Eh?{angy}
Dialogue: 0,0:02:26.63,0:02:30.92,Main-207-,,0,0,0,,{\q2}Ora che mi ci fai pensare...\Nla vela non sta prendendo vento per niente.{Cora}
Dialogue: 0,0:02:34.34,0:02:35.47,Main-207-,,0,0,0,,Oh no!{-angy}
Dialogue: 0,0:02:35.47,0:02:37.55,Main-207-,,0,0,0,,Siamo finiti nella Calm Belt!{-angy}
Dialogue: 0,0:02:37.89,0:02:38.89,Main-207-,,0,0,0,,{\i1}Charm{\i0} Belt?{Cora}
Dialogue: 0,0:02:38.89,0:02:39.72,Main-207-,,0,0,0,,Che roba è?{Tony}
Dialogue: 0,0:02:39.72,0:02:42.23,Main-207-,,0,0,0,,Calm{\i0} Belt! \NQui le navi sono in bonaccia!{Cora}
Dialogue: 0,0:02:42.23,0:02:43.31,Main-207-,,0,0,0,,{La forza di Nami?! - angy}"Nami è una minaccia"?!{Cora}
Dialogue: 0,0:02:43.31,0:02:44.52,Main-207-,,0,0,0,,Cretino!{Cora}
Dialogue: 0,0:02:51.40,0:02:52.61,Main-207-,,0,0,0,,{\q2}Cos'è? \NUn terremoto?{ -angy}
Dialogue: 0,0:02:52.61,0:02:54.40,Main-207-,,0,0,0,,{\q2}Un terremoto? \NIn mare?{Cora}
Dialogue: 0,0:02:54.40,0:02:56.82,Main-207-,,0,0,0,,Piantatela di dire stupidaggini!{-angy}
Dialogue: 0,0:02:56.82,0:02:58.74,Main-207-,,0,0,0,,Sbrigatevi ad ammainare le vele e remate!{Cora}
Dialogue: 0,0:02:58.74,0:03:00.33,Main-207-,,0,0,0,,Torniamo sulla rotta di prima!{angy}
Dialogue: 0,0:03:00.33,0:03:01.70,Main-207-,,0,0,0,,Agli ordini, cara Nami!{Cora}
Dialogue: 0,0:03:02.04,0:03:03.79,Main-207-,,0,0,0,,Perché sei così agitata?{angy}
Dialogue: 0,0:03:03.79,0:03:05.54,Main-207-,,0,0,0,,Perché remare?\NQuesta è una barca a vela.{Cora}
Dialogue: 0,0:03:05.54,0:03:06.75,Main-207-,,0,0,0,,Infatti!{-angy}
Dialogue: 1,0:03:06.75,0:03:09.59,Main-207-,,0,0,0,,La Marina ci sta cercando là, \Nperché dovremmo tornarci?!{aggiunta}
Dialogue: 0,0:03:09.59,0:03:12.71,Main-207-,,0,0,0,,{\q2}Basta! \NFate come vi dico! Siamo nei guai!{angy}
Dialogue: 0,0:03:12.71,0:03:14.55,Main-207-,,0,0,0,,Ma il mare è tranquillo.{angy}
Dialogue: 0,0:03:14.55,0:03:15.17,Main-207-,,0,0,0,,Già.{Cora}
Dialogue: 0,0:03:15.17,0:03:17.93,Main-207-,,0,0,0,,{\q2}Aaah, uffa! \NAllora vi spiego!{ -angy}
Dialogue: 0,0:03:17.93,0:03:23.35,Main-207-,,0,0,0,,Dato che siamo scappati in fretta, \Nsiamo andati più a sud del previsto!{-angy}
Dialogue: 0,0:03:23.35,0:03:25.23,Main-207-,,0,0,0,,{\q2}Quindi, siamo entrati nella Grand Line?{angy}
Dialogue: 0,0:03:25.23,0:03:27.02,Main-207-,,0,0,0,,Wow!{angy}
Dialogue: 0,0:03:27.02,0:03:29.86,Main-207-,,0,0,0,,Se fosse così facile entrarci, \Nci andrebbero tutti!{Cora}
Dialogue: 0,0:03:31.44,0:03:32.44,Main-207-,,0,0,0,,Ascoltate bene!{Cora}
Dialogue: 0,0:03:32.44,0:03:37.41,Main-207-,,0,0,0,,{\q2}La Grand Line, verso cui siamo diretti, \Nè circondata da due fasce marittime.{Cora}
Dialogue: 0,0:03:37.41,0:03:42.24,Main-207-,,0,0,0,,{\q2}Capite?\NQueste due fasce sono dette Calm Belt!{Cora}
Dialogue: 0,0:03:43.33,0:03:47.58,Main-207-,,0,0,0,,Non si sa perché, ma in queste \Nzone non c'è né vento né correnti.{-angy}
Dialogue: 0,0:03:47.58,0:03:49.63,Main-207-,,0,0,0,,Sono aree di totale bonaccia!{Cora}
Dialogue: 0,0:03:49.63,0:03:52.38,Main-207-,,0,0,0,,Per le barche a vela che \Nnecessitano del vento{Cora}
Dialogue: 0,0:03:52.38,0:03:54.13,Main-207-,,0,0,0,,sono molto pericolose, se non fatali!{Cora}{CPS rosa! -angy}
Dialogue: 0,0:03:54.13,0:03:55.63,Main-207-,,0,0,0,,Luffy, adesso hai capito?{Cora}
Dialogue: 0,0:03:55.63,0:03:57.72,Main-207-,,0,0,0,,Sì! Siamo nei guai.{angy}
Dialogue: 0,0:03:57.72,0:04:00.18,Main-207-,,0,0,0,,Ah bene, hai capito più \Ndi quanto mi aspettassi.{aggiunta}
Dialogue: 0,0:04:00.18,0:04:03.14,Main-207-,,0,0,0,,{\q2}Ecco perché il vecchio \Ndiceva che era pericoloso...{aggiunta}
Dialogue: 0,0:04:03.14,0:04:05.85,Main-207-,,0,0,0,,{\q2}Quindi è per questo che non c'è vento.{angy}
Dialogue: 0,0:04:05.85,0:04:08.19,Main-207-,,0,0,0,,{\q2}Se la nave è ferma,\Nnon possiamo fare molto.{Cora}
Dialogue: 0,0:04:08.19,0:04:09.94,Main-207-,,0,0,0,,Basta aspettare che torni il vento!{Cora}
Dialogue: 0,0:04:09.94,0:04:14.07,Main-207-,,0,0,0,,{\q2}Ho detto che, una volta entrati qui, non \Nimporta quanto si aspetti, non ci sarà mai vento!{-angy}
Dialogue: 0,0:04:14.07,0:04:15.23,Main-207-,,0,0,0,,E non è tutto!{angy}
Dialogue: 0,0:04:15.23,0:04:18.61,Main-207-,,0,0,0,,C'è un'altra ragione per cui queste \Nzone sono considerate pericolose!{angy}
Dialogue: 0,0:04:18.61,0:04:20.03,Main-207-,,0,0,0,,Qui ci–{-angy}
Dialogue: 0,0:04:22.03,0:04:23.66,Main-207-,,0,0,0,,Cosa? Che succede?{angy}
Dialogue: 0,0:04:28.87,0:04:31.17,Main-207-,,0,0,0,,Sono enormi!
Dialogue: 0,0:04:36.92,0:04:39.59,Main-207-,,0,0,0,,{\q2}La Calm Belt è la tana dei Re del Mare.{-Cora}
Dialogue: 0,0:04:39.59,0:04:41.55,Main-207-,,0,0,0,,Oltretutto, di quelli giganti!{angy}
Dialogue: 0,0:04:41.93,0:04:46.02,Main-207-,,0,0,0,,È anche per colpa loro che non \Nsi passa mai per la Calm Belt...{Tony}
Dialogue: 0,0:04:47.02,0:04:48.94,Main-207-,,0,0,0,,E ora cosa dovremmo fare?{Cora}
Dialogue: 0,0:04:49.35,0:04:51.48,Main-207-,,0,0,0,,Prima o poi torneranno sott'acqua.{Cora}
Dialogue: 0,0:04:51.48,0:04:54.86,Main-207-,,0,0,0,,Dopodiché... \Nremeremo il più forte possibile.{Cora}
Dialogue: 0,0:04:54.86,0:04:56.61,Main-207-,,0,0,0,,Sul serio?!{angy}
Dialogue: 0,0:04:56.61,0:04:57.49,Main-207-,,0,0,0,,{\fscx80\fscy80\bord3.041\shad3.041}Idiota!
Dialogue: 0,0:04:59.24,0:05:01.07,Main-207-,,0,0,0,,Scusa...{angy}
Dialogue: 0,0:05:05.49,0:05:07.16,Main-207-,,0,0,0,,Aspetta un attimo...!{angy}
Dialogue: 0,0:05:07.16,0:05:08.62,Main-207-,,0,0,0,,Se fa così...{angy}
Dialogue: 0,0:05:08.62,0:05:11.12,Main-207-,,0,0,0,,{Sta per starnutire! - angy}vuol dire che sta per starnutire!{Cora}
Dialogue: 0,0:05:11.75,0:05:14.00,Main-207-,,0,0,0,,– Cosa?!\N– Cosa?!{angy}
Dialogue: 0,0:05:14.00,0:05:16.75,Main-207-,,0,0,0,,Fighissimo! \NSembra di volare!{Cora}
Dialogue: 0,0:05:18.67,0:05:25.14,Main-207-,,0,0,0,,Stiamo volando veramente!{angy}
Dialogue: 0,0:05:27.56,0:05:30.35,Main-207-,,0,0,0,,Pare che siamo riusciti a \Ntornare sulla rotta precedente...{-angy}
Dialogue: 0,0:05:30.35,0:05:33.90,Main-207-,,0,0,0,,Dovremmo riuscire a \Nvedere la Red Line ormai...{angy}
Dialogue: 0,0:05:37.90,0:05:40.95,Main-207-,,0,0,0,,Finalmente la Grand Line, eh?!{ -angy}
Dialogue: 0,0:05:41.78,0:05:46.03,Main-207-,,0,0,0,,{\q2}Ehi, Sanji! \NFinalmente! Finalmente! Finalmente!{angy}
Dialogue: 0,0:05:46.03,0:05:47.62,Main-207-,,0,0,0,,Mi fai male!{angy}
Dialogue: 0,0:05:47.62,0:05:48.70,Main-207-,,0,0,0,,Scusa...{angy}
Dialogue: 0,0:05:49.16,0:05:50.41,Secondary-207-,,0,0,0,,{\an8}Zoro!
Dialogue: 0,0:05:50.41,0:05:51.66,Secondary-207-,,0,0,0,,{\an8}Finalmente! Finalmente!{angy}
Dialogue: 0,0:05:50.41,0:05:51.66,Thoughts-207-,,0,0,0,,Comunque...{ -angy}
Dialogue: 0,0:05:51.66,0:05:55.29,Secondary-207-,,0,0,0,,{\an8}Finalmente! Finalmente! Finalmente!
Dialogue: 0,0:05:51.66,0:05:55.29,Thoughts-207-,,0,0,0,,{\q2}sarà davvero come \Ndisegnato in questa mappa?{-angy}
Dialogue: 0,0:05:55.29,0:05:57.42,Secondary-207-,,0,0,0,,{\an8}Non spingermi!
Dialogue: 0,0:06:03.05,0:06:04.14,Main-207-,,0,0,0,,Guardate qui!{-angy}
Dialogue: 0,0:06:05.39,0:06:09.06,Main-207-,,0,0,0,,{[/q2]Ne avevo già sentito parlare e\Nanche la mappa lo rappresenta così. - angy}{Avevo già sentito delle voci...\Ne anche la mappa sembra confermare. - Tony}Ne avevo già sentito parlare...\Ne anche la mappa la rappresenta così.{Non userei "confermare" per dare ancora un velo di mistero alla cosa -Cora}{ed è più corretto rispetto a quello che viene detto -angy}
Dialogue: 0,0:06:09.06,0:06:13.10,Main-207-,,0,0,0,,{\q2}Se è tutto vero, l'entrata della \NGrand Line... è una montagna!{Tony}
Dialogue: 0,0:06:13.10,0:06:14.65,Main-207-,,0,0,0,,Una montagna?{angy}
Dialogue: 0,0:06:14.65,0:06:16.02,Main-207-,,0,0,0,,{Dobbiamo andarci addosso? - ...probabilmente si può scrivere meglio. è tipo scontarsi -angy}{[/q2]Che si fa ora, ci andiamo contro? - Tony}{ma il che si fa ora proprio non viene detto e allunghiamo troppo la frase, si hanno cps rossicci -angy}Dobbiamo andarci contro?{Cora}
Dialogue: 0,0:06:16.02,0:06:17.15,Main-207-,,0,0,0,,Ma che storia è questa?{Tony}
Dialogue: 0,0:06:17.15,0:06:22.15,Main-207-,,0,0,0,,{\q2}Anch'io non ci credevo, ma... \Nnella mappa sono disegnati dei canali.{--angy}
Dialogue: 0,0:06:22.15,0:06:24.32,Main-207-,,0,0,0,,Forse significa che dobbiamo scalarli.{-angy}
Dialogue: 0,0:06:25.41,0:06:27.20,Main-207-,,0,0,0,,Bello!{Cora}
Dialogue: 0,0:06:27.20,0:06:28.66,Main-207-,,0,0,0,,Ma che dici?!{Cora}
Dialogue: 0,0:06:28.66,0:06:33.04,Main-207-,,0,0,0,,{\q2}Anche se ci fossero questi canali,\Nuna nave non può mica scalare una montagna!{ Cora}
Dialogue: 0,0:06:33.04,0:06:34.67,Main-207-,,0,0,0,,Però, è disegnata così!{Cora}
Dialogue: 0,0:06:34.67,0:06:38.13,Main-207-,,0,0,0,,{\q2}Giusto!\NLa mia cara Nami non potrebbe mai sbagliarsi!{Cora}
Dialogue: 0,0:06:38.75,0:06:41.38,Main-207-,,0,0,0,,{\q2}Quella è la mappa che hai rubato a Buggy, no?{ -angy}
Dialogue: 0,0:06:41.38,0:06:42.80,Main-207-,,0,0,0,,Ci possiamo fidare?{ -angy}
Dialogue: 0,0:06:42.80,0:06:44.09,Main-207-,,0,0,0,,E-Ehi!{angy}
Dialogue: 0,0:06:44.09,0:06:46.14,Main-207-,,0,0,0,,Aiutatemi con il timone!{angy}
Dialogue: 0,0:06:46.14,0:06:48.51,Main-207-,,0,0,0,,Sanji, aiuta Usopp!{angy}
Dialogue: 0,0:06:48.51,0:06:50.85,Main-207-,,0,0,0,,{\q2}Fa così tanto casino che non riesco a pensare!{angy}
Dialogue: 0,0:06:50.85,0:06:52.39,Main-207-,,0,0,0,,Agli ordini, signora Nami!{Cora}
Dialogue: 0,0:06:52.39,0:06:53.48,Main-207-,,0,0,0,,Allora...!{Cora}
Dialogue: 0,0:06:46.72,0:06:49.51,Secondary-207-,,0,0,0,,Qualcuno...!{angy}
Dialogue: 0,0:06:49.51,0:06:52.39,Secondary-207-,,0,0,0,,Qualcuno...! Qualcuno mi aiuti!{-angy}
Dialogue: 0,0:06:53.94,0:06:57.40,Main-207-,,0,0,0,,N-Non ti sembra che la corrente \Nsia un po' troppo forte?!{Cora}
Dialogue: 0,0:06:57.40,0:06:58.15,Main-207-,,0,0,0,,Eh?
Dialogue: 0,0:06:58.15,0:06:59.77,Main-207-,,0,0,0,,Usopp, cos'hai appena detto?{ -angy}
Dialogue: 0,0:06:59.77,0:07:02.53,Main-207-,,0,0,0,,"Non ti sembra che la corrente \Nsia un po' troppo forte?!"{Cora}
Dialogue: 0,0:07:02.53,0:07:04.32,Main-207-,,0,0,0,,Corrente...{angy}
Dialogue: 0,0:07:04.32,0:07:05.15,Main-207-,,0,0,0,,Ho capito!{letterale -angy}
Dialogue: 0,0:07:05.15,0:07:06.28,Main-207-,,0,0,0,,Cosa?{ -angy}
Dialogue: 0,0:07:06.28,0:07:08.12,Main-207-,,0,0,0,,{\q2}Dobbiamo davvero scalare la montagna!{Tony}
Dialogue: 0,0:07:08.12,0:07:10.66,Main-207-,,0,0,0,,Insisti ancora con quella storia?{Cora}
Dialogue: 0,0:07:10.66,0:07:11.37,Main-207-,,0,0,0,,Guardate qui!{ -angy}
Dialogue: 0,0:07:11.37,0:07:12.50,Main-207-,,0,0,0,,Vedete?{angy}
Dialogue: 0,0:07:12.50,0:07:15.71,Main-207-,,0,0,0,,{\q2}La luce guida del faro puntava decisamente qui.{Meglio esplicitarlo perché non era chiaro neanche a me, in contesto nautico può stare senza virgolette -Cora}{ma non si parla assolutamente di faro da nessuna parte, non è chiaro nemmeno in jp -angy}
Dialogue: 0,0:07:15.71,0:07:18.04,Main-207-,,0,0,0,,Alla Reverse Mountain, sulla Red Line.{Cora}
Dialogue: 0,0:07:18.04,0:07:20.50,Main-207-,,0,0,0,,Ehi! \NDecidetevi, che devo fare?!{Tony}
Dialogue: 0,0:07:21.05,0:07:23.17,Main-207-,,0,0,0,,Qui ci sono dei canali, no?{ -angy}
Dialogue: 0,0:07:23.17,0:07:28.64,Main-207-,,0,0,0,,Se tutte le correnti dei quattro mari \Nfluiscono verso questa montagna...{angy}
Dialogue: 0,0:07:29.97,0:07:34.23,Main-207-,,0,0,0,,{\q2}Allora, le quattro correnti risalgono lungo \Nquesti canali per poi scontrarsi in cima{ -angy}
Dialogue: 0,0:07:34.23,0:07:36.31,Main-207-,,0,0,0,,e fluire verso la Grand Line!{angy}
Dialogue: 0,0:07:36.85,0:07:39.02,Main-207-,,0,0,0,,{\q2}La Reverse Mountain è un'isola invernale,{angy}
Dialogue: 0,0:07:39.02,0:07:44.36,Main-207-,,0,0,0,,{\q2}quindi ogni corrente che si scontra con la \NRed Line passa dalla superficie alla profondità.{-angy}
Dialogue: 0,0:07:44.36,0:07:46.99,Main-207-,,0,0,0,,Se per errore non riuscissimo \Na entrare nel canale...{ -angy}
Dialogue: 0,0:07:47.61,0:07:50.45,Main-207-,,0,0,0,,{\t(2316,0,1,\c&HFDFEFD&\3c&HFDFEFD&\4c&HFDFEFD&)}la Going Merry si scontrerà\Ncompletamente sulla Red Line...{Cora}
Dialogue: 0,0:07:52.70,0:07:54.87,Main-207-,,0,0,0,,{\t(1230,0,1,\c&HFEFEFC&\3c&HFEFEFC&\4c&HFEFEFC&)}e verrà distrutta!{angy}
Dialogue: 0,0:07:55.58,0:07:58.25,Main-207-,,0,0,0,,{\q2}Diventerà un relitto in fondo al mare. \NÈ chiaro?{-angy}
Dialogue: 0,0:07:58.25,0:07:59.67,Main-207-,,0,0,0,,Oh, capisco.{angy}
Dialogue: 0,0:07:59.67,0:08:02.71,Main-207-,,0,0,0,,Quindi, è una montagna strana, eh?
Dialogue: 0,0:08:04.09,0:08:07.01,Main-207-,,0,0,0,,{\q2}Beh... pensavo che non l'avrebbe capito...{Cora}
Dialogue: 0,0:08:07.63,0:08:10.64,Main-207-,,0,0,0,,{\q2}Comunque, questa nave \Nsta già seguendo la corrente,{Cora}
Dialogue: 0,0:08:10.64,0:08:12.39,Main-207-,,0,0,0,,{\q2}quindi se manovriamo per bene il timone{Cora}
Dialogue: 0,0:08:12.39,0:08:15.60,Main-207-,,0,0,0,,dovremmo riuscire a scalare la \NReverse Mountain fino alla cima!{angy}
Dialogue: 0,0:08:15.93,0:08:18.06,Main-207-,,0,0,0,,Nami, sei fantastica!{-angy}
Dialogue: 0,0:08:18.06,0:08:20.98,Main-207-,,0,0,0,,Navi che scalano le montagne...\Nmai sentito.{Cora}
Dialogue: 0,0:08:20.98,0:08:22.69,Main-207-,,0,0,0,,Io un po' sì.{angy}
Dialogue: 0,0:08:23.07,0:08:24.48,Main-207-,,0,0,0,,Dici della montagna strana?{Cora}
Dialogue: 0,0:08:24.82,0:08:25.69,Main-207-,,0,0,0,,No...{angy}
Dialogue: 0,0:08:25.69,0:08:30.70,Main-207-,,0,0,0,,{\q2}Ho sentito dire che circa la metà di chi va\N verso la Grand Line, muore prima di arrivarci.{Cora}
Dialogue: 0,0:08:31.78,0:08:34.74,Main-207-,,0,0,0,,Sapevo che non sarebbe stato facile.{angy}
Dialogue: 0,0:08:35.12,0:08:36.62,Main-207-,,0,0,0,,{\q2}Sanji! \NOccupati delle vele!{-angy}
Dialogue: 0,0:08:36.62,0:08:38.37,Main-207-,,0,0,0,,Ricevuto, signora Nami!{Cora}
Dialogue: 0,0:08:38.37,0:08:39.50,Main-207-,,0,0,0,,Luffy, aiutami anche tu!{Tony}
Dialogue: 0,0:08:39.50,0:08:41.46,Main-207-,,0,0,0,,Eeh?{-angy}
Dialogue: 0,0:08:51.97,0:08:53.22,Main-207-,,0,0,0,,Ehi!{angy}
Dialogue: 0,0:08:53.22,0:08:55.35,Main-207-,,0,0,0,,Si vede la montagna strana!{angy}
Dialogue: 0,0:08:55.35,0:08:56.97,Main-207-,,0,0,0,,– C-Cosa?\N– Eh?{angy}
Dialogue: 0,0:08:57.39,0:09:00.02,Main-207-,,0,0,0,,È-È g-gigantesca!{angy}
Dialogue: 0,0:09:02.40,0:09:04.98,Main-207-,,0,0,0,,Quindi... quella è la Red Line?!{angy}
Dialogue: 0,0:09:05.48,0:09:11.49,Main-207-,,0,0,0,,{\q2}P-P-P-P-Per via delle nuvole, \Nnon si vede nemmeno la cima!{angy}
Dialogue: 0,0:09:31.93,0:09:33.72,Main-207-,,0,0,0,,Ci sta risucchiando!{-angy}
Dialogue: 0,0:09:34.35,0:09:35.97,Main-207-,,0,0,0,,Tenete forte il timone!{angy}
Dialogue: 0,0:09:35.97,0:09:37.47,Main-207-,,0,0,0,,– Lascia fare a noi!\N– Lascia fare a noi!{angy}
Dialogue: 0,0:09:44.77,0:09:47.36,Main-207-,,0,0,0,,N-Nami! \NDov'è l'entrata?!{angy}
Dialogue: 0,0:09:47.36,0:09:50.32,Main-207-,,0,0,0,,Se continuiamo di qua,\Nci schianteremo sulla roccia!{Cora}
Dialogue: 0,0:09:52.66,0:09:54.57,Main-207-,,0,0,0,,Quella fessura nella roccia...{Cora}
Dialogue: 0,0:09:57.45,0:10:00.29,Main-207-,,0,0,0,,{\q2}Nami! \NChe facciamo?!{angy}
Dialogue: 0,0:10:00.29,0:10:01.71,Main-207-,,0,0,0,,Proseguite dritti!{angy}
Dialogue: 0,0:10:01.71,0:10:02.87,Main-207-,,0,0,0,,Sul serio?!{angy}
Dialogue: 0,0:10:02.87,0:10:04.08,Main-207-,,0,0,0,,Fatelo e basta!{angy}
Dialogue: 0,0:10:05.08,0:10:07.04,Main-207-,,0,0,0,,{\q2}Nami! \NQuella è l'entrata del canale?{angy}
Dialogue: 0,0:10:07.04,0:10:08.50,Main-207-,,0,0,0,,È molto probabile!{Cora}
Dialogue: 0,0:10:09.17,0:10:10.97,Main-207-,,0,0,0,,Non posso crederci...{angy}
Dialogue: 0,0:10:11.63,0:10:15.14,Main-207-,,0,0,0,,{\q2}Il mare sta {\i1}davvero{\i0} scalando la montagna!{angy}
Dialogue: 0,0:10:20.22,0:10:23.48,Main-207-,,0,0,0,,Dobbiamo attraversare quella paratoia!{-angy}
Dialogue: 0,0:10:23.81,0:10:26.36,Main-207-,,0,0,0,,Altrimenti, la nave andrà in pezzi!{ -angy}
Dialogue: 0,0:10:30.15,0:10:33.36,Main-207-,,0,0,0,,S-Siamo fuori strada!\N Più a destra! Destra! Destra!{angy}
Dialogue: 0,0:10:33.36,0:10:35.66,Main-207-,,0,0,0,,Destra?! Dest-\N A dritta, a dritta!{angy}
Dialogue: 0,0:10:38.45,0:10:40.95,Main-207-,,0,0,0,,Forza...!{-angy}
Dialogue: 0,0:10:47.88,0:10:49.42,Main-207-,,0,0,0,,– Il timone!\N– Il timone!{angy}
Dialogue: 0,0:10:49.42,0:10:52.13,Main-207-,,0,0,0,,{\fad(150,150)}Gum Gum Palloncino!{angy}
Dialogue: 0,0:11:00.76,0:11:02.31,Main-207-,,0,0,0,,Luffy!
Dialogue: 0,0:11:02.31,0:11:03.18,Main-207-,,0,0,0,,Aggrappati!{angy}
Dialogue: 0,0:11:16.07,0:11:18.74,Main-207-,,0,0,0,,– Siamo dentro!\N– Siamo dentro!{Cora}
Dialogue: 0,0:11:24.87,0:11:28.21,Main-207-,,0,0,0,,E ora...\N dritti verso la cima!{angy}
Dialogue: 0,0:11:32.46,0:11:35.22,Main-207-,,0,0,0,,C-Che roba!{angy}
Dialogue: 0,0:11:42.47,0:11:43.56,Main-207-,,0,0,0,,Vero?!{angy}
Dialogue: 0,0:11:45.64,0:11:48.44,Main-207-,,0,0,0,,Siamo dentro le nuvole!{angy}
Dialogue: 0,0:11:59.37,0:12:01.70,Main-207-,,0,0,0,,Che figata!{angy}
Dialogue: 0,0:12:03.12,0:12:05.20,Main-207-,,0,0,0,,Siamo arrivati sopra le nuvole!{angy}
Dialogue: 0,0:12:15.55,0:12:18.63,Main-207-,,0,0,0,,Guardate! \NÈ la cima! La cima!{angy}
Dialogue: 0,0:12:31.40,0:12:33.65,Main-207-,,0,0,0,,Yahoo!
Dialogue: 0,0:12:54.75,0:12:55.80,Main-207-,,0,0,0,,Lo vedo!{angy}
Dialogue: 0,0:12:56.21,0:12:58.63,Main-207-,,0,0,0,,Il mare più grande del mondo!{ -Cora}
Dialogue: 0,0:12:58.63,0:12:59.93,Main-207-,,0,0,0,,La Grand Line!{angy}
Dialogue: 0,0:13:02.64,0:13:06.97,Main-207-,,0,0,0,,{\q2}Da qualche parte più avanti... c'è il One Piece!{ -angy}
Dialogue: 0,0:13:07.56,0:13:10.10,Main-207-,,0,0,0,,Andiamo!{angy}
Dialogue: 0,0:13:24.62,0:13:26.49,Main-207-,,0,0,0,,Avete sentito anche voi quel rumore?{Cora}
Dialogue: 0,0:13:26.49,0:13:28.41,Main-207-,,0,0,0,,Sarà stato solo il vento, no?{angy}
Dialogue: 0,0:13:28.41,0:13:31.58,Main-207-,,0,0,0,,È pieno di strane conformazioni \Nrocciose, sarà per quello!{Cora}
Dialogue: 0,0:13:36.25,0:13:37.21,Main-207-,,0,0,0,,Cos'è quella?{angy}
Dialogue: 0,0:13:37.80,0:13:40.30,Main-207-,,0,0,0,,{\q2}Nami! \NVedo una montagna davanti a noi!{angy}
Dialogue: 0,0:13:40.30,0:13:42.63,Main-207-,,0,0,0,,{\q2}Una montagna?! \NNon può essere!{angy}
Dialogue: 0,0:13:42.63,0:13:44.68,Main-207-,,0,0,0,,Ma c'è per davvero!{angy}
Dialogue: 0,0:13:44.68,0:13:46.97,Main-207-,,0,0,0,,{\q2}Chi se ne frega!\N Andiamo!{angy}
Dialogue: 0,0:13:47.64,0:13:51.64,Main-207-,,0,0,0,,{\q2}Dopo aver passato i Promontori Gemelli, \Ndovrebbe esserci solo mare!{-angy}
Dialogue: 0,0:13:57.48,0:13:58.86,Main-207-,,0,0,0,,Oh no!{angy}
Dialogue: 0,0:14:01.03,0:14:02.49,Main-207-,,0,0,0,,Non è una montagna!{angy}
Dialogue: 0,0:14:02.49,0:14:03.74,Main-207-,,0,0,0,,È un muro nero!{angy}
Dialogue: 0,0:14:03.74,0:14:04.91,Main-207-,,0,0,0,,Ti sbagli! È...{angy}
Dialogue: 0,0:14:04.91,0:14:06.03,Main-207-,,0,0,0,,Che razza di roba è?!{Cora}
Dialogue: 0,0:14:06.03,0:14:07.28,Main-207-,,0,0,0,,U-U-U-Una...{angy}
Dialogue: 0,0:14:07.28,0:14:09.41,Main-207-,,0,0,0,,balena!{angy}
Dialogue: 0,0:14:11.91,0:14:13.42,Main-207-,,0,0,0,,C-C-C-Che facciamo?!{angy}
Dialogue: 0,0:14:13.42,0:14:14.38,Main-207-,,0,0,0,,Ci combattiamo?{-angy}
Dialogue: 0,0:14:14.38,0:14:16.54,Main-207-,,0,0,0,,{\q2}Deficiente!\NNon puoi combattere con quella!{Cora}
Dialogue: 0,0:14:16.54,0:14:19.51,Main-207-,,0,0,0,,{\q2}M-M-M-Ma ci sta bloccando la strada!{angy}
Dialogue: 0,0:14:19.51,0:14:21.22,Main-207-,,0,0,0,,Che facciamo?!{angy}
Dialogue: 0,0:14:21.22,0:14:22.67,Main-207-,,0,0,0,,Fermi un secondo!{Cora}
Dialogue: 0,0:14:23.22,0:14:27.18,Main-207-,,0,0,0,,{\q2}Se anche da così vicino sembra solo un muro, \Ndove sono i suoi occhi?!{angy}
Dialogue: 0,0:14:27.68,0:14:31.31,Main-207-,,0,0,0,,{\q2}Giusto! \NNon è detto che ci abbia ancora notati!{angy}
Dialogue: 0,0:14:31.31,0:14:33.85,Main-207-,,0,0,0,,{\q2}Ma, se andiamo avanti così, ci scontreremo!{angy}
Dialogue: 0,0:14:33.85,0:14:35.90,Main-207-,,0,0,0,,{\q2}Ehi! \NA sinistra potremmo passarci!{angy}
Dialogue: 0,0:14:35.90,0:14:38.36,Main-207-,,0,0,0,,{\q2}A babordo! \NTutta a babordo!{angy}
Dialogue: 0,0:14:38.94,0:14:40.44,Main-207-,,0,0,0,,Ma il timone è rotto!{angy}
Dialogue: 0,0:14:40.44,0:14:42.90,Main-207-,,0,0,0,,{\q2}Fa' qualcosa! \NTi aiuto io!{ angy}
Dialogue: 0,0:14:42.90,0:14:44.28,Main-207-,,0,0,0,,Ah, giusto!{angy}
Dialogue: 0,0:14:44.28,0:14:46.57,Main-207-,,0,0,0,,Mi è venuta una bella idea~!{angy}
Dialogue: 0,0:14:46.57,0:14:47.24,Main-207-,,0,0,0,,Luffy...?
Dialogue: 0,0:14:47.24,0:14:49.12,Main-207-,,0,0,0,,Ah-\N Cosa vuoi fare?!{angy}
Dialogue: 0,0:14:54.46,0:14:56.29,Main-207-,,0,0,0,,Non gira!{angy}
Dialogue: 0,0:14:56.29,0:14:58.88,Main-207-,,0,0,0,,{\q2}Non si mette bene! \NNon gira!{Cora}
Dialogue: 0,0:14:58.88,0:15:00.17,Main-207-,,0,0,0,,Bastarda!{-angy}
Dialogue: 0,0:15:00.17,0:15:02.30,Main-207-,,0,0,0,,Non ci arrenderemo!{angy}
Dialogue: 0,0:15:10.97,0:15:12.89,Main-207-,,0,0,0,,È finita...?{angy}
Dialogue: 0,0:15:19.90,0:15:22.11,Thoughts-207-,,0,0,0,,{\pos(1174.999,1053)}Il cannone?!
Dialogue: 0,0:15:20.15,0:15:22.11,Thoughts-207-,,0,0,0,,{\an8\pos(840,27)}Il cannone?!
Dialogue: 0,0:15:20.40,0:15:22.11,Thoughts-207-,,0,0,0,,{\pos(480,1053)}Il cannone?!
Dialogue: 0,0:15:20.65,0:15:22.11,Thoughts-207-,,0,0,0,,{\an8\pos(270,27)}Il cannone?!
Dialogue: 0,0:15:22.11,0:15:24.07,Main-207-,,0,0,0,,Ottimo~! \NCi siamo fermati?{Cora}
Dialogue: 0,0:15:32.08,0:15:33.16,Main-207-,,0,0,0,,Lo detesto...{Da rivedere presumo, mi è venuto in mente solo questo -Cora}{funziona- angy}
Dialogue: 0,0:15:33.58,0:15:34.58,Main-207-,,0,0,0,,Forse sono morta...{angy}
Dialogue: 0,0:15:37.42,0:15:39.33,Main-207-,,0,0,0,,Il mio posto speciale!{-angy}
Dialogue: 0,0:15:56.39,0:15:56.98,Main-207-,,0,0,0,,Sca–{angy}
Dialogue: 0,0:15:56.98,0:15:58.90,Main-207-,,0,0,0,,Scappiamo finché siamo in tempo!{angy}
Dialogue: 0,0:15:58.90,0:16:00.90,Main-207-,,0,0,0,,Che–\N Cosa cavolo sta succedendo?!{-angy}
Dialogue: 0,0:16:00.90,0:16:03.40,Main-207-,,0,0,0,,Non si è accorta del colpo \Nper via della sua grandezza?!{Cora}
Dialogue: 0,0:16:03.40,0:16:04.74,Main-207-,,0,0,0,,O è solo lenta a capire?!{-Cora}
Dialogue: 0,0:16:04.74,0:16:06.70,Main-207-,,0,0,0,,Chi se ne frega! \NAndiamocene finché possiamo!{angy}
Dialogue: 0,0:16:12.53,0:16:13.58,Main-207-,,0,0,0,,Che male le orecchie!{-angy}
Dialogue: 0,0:16:13.58,0:16:15.20,Main-207-,,0,0,0,,{\q2}Remate! \NContinuate a remare!{angy}
Dialogue: 0,0:16:15.20,0:16:17.12,Main-207-,,0,0,0,,Dobbiamo allontanarci da quella cosa!{angy}
Dialogue: 0,0:16:23.34,0:16:24.46,Main-207-,,0,0,0,,Luffy...?
Dialogue: 0,0:16:24.46,0:16:25.84,Main-207-,,0,0,0,,Tu!{angy}
Dialogue: 0,0:16:25.84,0:16:30.43,Main-207-,,0,0,0,,Come hai osato distruggere \Nil mio posto speciale?!{ -Cora}
Dialogue: 0,0:16:31.72,0:16:34.72,Main-207-,,0,0,0,,– Deficiente!\N– Deficiente!{angy}
Dialogue: 0,0:16:41.65,0:16:44.48,Main-207-,,0,0,0,,{\q2}Allora, com'era?! \NBastarda, fatti sotto!{angy}
Dialogue: 0,0:16:44.48,0:16:46.07,Main-207-,,0,0,0,,– Luffy, sta' zitto!\N– Luffy, sta' zitto!{-angy}
Dialogue: 0,0:16:50.07,0:16:51.45,Main-207-,,0,0,0,,C-Cosa?{angy}
Dialogue: 0,0:17:07.38,0:17:08.34,Main-207-,,0,0,0,,Luffy!
Dialogue: 0,0:17:08.34,0:17:09.22,Main-207-,,0,0,0,,Luffy!
Dialogue: 0,0:17:15.43,0:17:18.39,Main-207-,,0,0,0,,Non morirò!{angy}
Dialogue: 0,0:17:43.50,0:17:44.84,Main-207-,,0,0,0,,Che faccio?{angy}
Dialogue: 0,0:17:44.84,0:17:46.38,Main-207-,,0,0,0,,Sono stati tutti mangiati...{Cora}
Dialogue: 0,0:17:47.42,0:17:50.38,Main-207-,,0,0,0,,Ehi! Tu! Sputali! \NRidammeli!{-angy}
Dialogue: 0,0:17:50.38,0:17:52.30,Main-207-,,0,0,0,,{\q2}Sputali! \NTi ho detto di ridarmeli!{angy}
Dialogue: 0,0:17:52.30,0:17:53.22,Main-207-,,0,0,0,,Tu–
Dialogue: 0,0:17:55.47,0:17:57.22,Main-207-,,0,0,0,,Bastarda!{angy}
Dialogue: 0,0:17:57.64,0:17:59.73,Main-207-,,0,0,0,,Ti immergi in acqua?!\N Fermati!{angy}
Dialogue: 0,0:17:59.73,0:18:02.19,Main-207-,,0,0,0,,Ehi! Ti ho detto di smetterla! Ehi!{angy}
Dialogue: 0,0:18:02.98,0:18:05.15,Main-207-,,0,0,0,,{\q2}Ti prego, aspetta!\NRidammi i miei compagni!{angy}
Dialogue: 0,0:18:05.61,0:18:06.40,Main-207-,,0,0,0,,Ehi!{angy}
Dialogue: 0,0:18:06.40,0:18:08.11,Main-207-,,0,0,0,,Ti ho detto di smetterla!{angy}
Dialogue: 0,0:18:08.48,0:18:10.78,Main-207-,,0,0,0,,D'ora in poi, saremo insieme \Nnelle nostre avventure!{Cora}
Dialogue: 0,0:18:10.78,0:18:12.11,Main-207-,,0,0,0,,Sono importanti per me!{Cora}
Dialogue: 0,0:18:12.61,0:18:15.24,Main-207-,,0,0,0,,Ridammeli!{angy}
Dialogue: 0,0:18:36.76,0:18:38.85,Main-207-,,0,0,0,,Cosa... ne pensate?{angy}
Dialogue: 0,0:18:38.85,0:18:40.77,Main-207-,,0,0,0,,Cosa ne pensiamo...?{angy}
Dialogue: 0,0:18:40.77,0:18:42.48,Main-207-,,0,0,0,,Come dovremmo pensarla...?{angy}
Dialogue: 0,0:18:42.48,0:18:44.23,Main-207-,,0,0,0,,N-N-N-Non...{-angy}
Dialogue: 0,0:18:44.23,0:18:48.40,Main-207-,,0,0,0,,Ero certo che fossimo stati \Ninghiottiti da quella balena...{angy}
Dialogue: 0,0:18:50.15,0:18:51.82,Main-207-,,0,0,0,,È un sogno?{angy}
Dialogue: 0,0:18:51.82,0:18:54.40,Main-207-,,0,0,0,,Sì... probabilmente è un sogno.{angy}
Dialogue: 0,0:19:00.08,0:19:02.62,Main-207-,,0,0,0,,Allora, quell'isola e quella \Ncasa cosa sarebbero?{angy}
Dialogue: 0,0:19:02.62,0:19:04.00,Main-207-,,0,0,0,,Illusioni.{Cora}
Dialogue: 0,0:19:08.59,0:19:10.75,Main-207-,,0,0,0,,Allora, quello...?{angy}
Dialogue: 0,0:19:11.42,0:19:14.76,Main-207-,,0,0,0,,– È un grande re calamaro!\N – È un grande re calamaro!{-angy}
Dialogue: 0,0:19:35.99,0:19:37.99,Main-207-,,0,0,0,,Sembra ci sia qualcuno qui.{angy}
Dialogue: 0,0:19:37.99,0:19:39.57,Main-207-,,0,0,0,,Speriamo sia una persona...{-angy}
Dialogue: 0,0:19:40.58,0:19:42.58,Main-207-,,0,0,0,,{\q2}Non ne posso più. \NVoglio tornare a casa...{angy}
Dialogue: 0,0:19:42.58,0:19:46.37,Main-207-,,0,0,0,,E Luffy è scomparso... \NCosa ne sarà di noi?{Cora}
Dialogue: 0,0:19:46.37,0:19:48.04,Main-207-,,0,0,0,,Ora che lo dici, dov'è Luffy?!{angy}
Dialogue: 0,0:19:50.09,0:19:51.92,Main-207-,,0,0,0,,Che roba è questa?!{angy}
Dialogue: 0,0:19:51.92,0:19:55.84,Main-207-,,0,0,0,,Perché ci sono una porta e un \Npassaggio dentro a una balena?{angy}
Dialogue: 0,0:19:58.72,0:19:59.80,Main-207-,,0,0,0,,Una nave...{angy}
Dialogue: 0,0:19:59.80,0:20:03.97,Main-207-,,0,0,0,,{\q2}D-D-Dovremo sparagli?\NFacciamo esplodere quell'isola con un {\i1}boom{\i0}?!{Cora}
