Comment: 0,0:00:00.00,0:00:00.00,Main-207-,,0,0,0,,{=8}===============================DIALOGUE============================
Dialogue: 0,0:02:08.48,0:02:10.07,Main-207-,,0,0,0,,Sorun ne, Zoro?
Dialogue: 0,0:02:10.07,0:02:12.57,Main-207-,,0,0,0,,Yüzün bir an ciddi\Nbir ifadeye büründü.
Dialogue: 0,0:02:12.57,0:02:15.11,Main-207-,,0,0,0,,Umarım sadece hayal gücümdür.
Dialogue: 0,0:02:15.11,0:02:16.07,Main-207-,,0,0,0,,O ne?
Dialogue: 0,0:02:16.07,0:02:20.70,Main-207-,,0,0,0,,Sanırım bu gemi,\Nbir süredir hareket etmiyor.
Dialogue: 0,0:02:24.96,0:02:25.54,Main-207-,,0,0,0,,Ne?
Dialogue: 0,0:02:26.63,0:02:30.92,Main-207-,,0,0,0,,Düşününce,\Nyelken hiç rüzgâr almıyor...
Dialogue: 0,0:02:34.34,0:02:35.47,Main-207-,,0,0,0,,Olamaz...!
Dialogue: 0,0:02:35.47,0:02:37.55,Main-207-,,0,0,0,,Calm Belt'e girdik!
Dialogue: 0,0:02:37.89,0:02:38.89,Main-207-,,0,0,0,,Charm Belt mi?
Dialogue: 0,0:02:38.89,0:02:39.72,Main-207-,,0,0,0,,O ne lan?
Dialogue: 0,0:02:39.72,0:02:42.23,Main-207-,,0,0,0,,Calm Belt! Hiçbir şeyin\Nkıpırdamadığı bir deniz!
Dialogue: 0,0:02:42.23,0:02:43.31,Main-207-,,0,0,0,,Bu senin gücün mü?
Dialogue: 0,0:02:43.31,0:02:44.52,Main-207-,,0,0,0,,{\an8}Seni salak!
Dialogue: 0,0:02:51.40,0:02:52.61,Main-207-,,0,0,0,,Deprem miydi o?
Dialogue: 0,0:02:52.61,0:02:54.40,Main-207-,,0,0,0,,Deprem mi? Ama denizdeyiz.
Dialogue: 0,0:02:54.40,0:02:56.82,Main-207-,,0,0,0,,Hadi millet, odaklanın!
Dialogue: 0,0:02:56.82,0:02:58.74,Main-207-,,0,0,0,,Yelkenleri toplayıp küreklere asılın!
Dialogue: 0,0:02:58.74,0:03:00.33,Main-207-,,0,0,0,,Eski rotamıza dönelim!
Dialogue: 0,0:03:00.33,0:03:01.70,Main-207-,,0,0,0,,Emredersin, Nami-{\i1}san{\i0}!
Dialogue: 0,0:03:02.04,0:03:03.79,Main-207-,,0,0,0,,Niye evhamlanıyorsun ki?
Dialogue: 0,0:03:03.79,0:03:05.54,Main-207-,,0,0,0,,Kürek çekmek mi? Bu bir yelkenli.
Dialogue: 0,0:03:05.54,0:03:06.75,Main-207-,,0,0,0,,Adam haklı.
Dialogue: 1,0:03:06.75,0:03:09.59,Main-207-,,0,0,0,,Denizcilerden yeni kaçtık,\Nniye geri dönelim ki?
Dialogue: 0,0:03:09.59,0:03:12.71,Main-207-,,0,0,0,,Hemen dediğimi yapın!\NBaşımız büyük dertte!
Dialogue: 0,0:03:12.71,0:03:14.55,Main-207-,,0,0,0,,Ama deniz sakin görünüyor.
Dialogue: 0,0:03:14.55,0:03:15.17,Main-207-,,0,0,0,,Öyle.
Dialogue: 0,0:03:15.17,0:03:17.93,Main-207-,,0,0,0,,Off, tamam! Anlatayım size!
Dialogue: 0,0:03:17.93,0:03:23.35,Main-207-,,0,0,0,,Dinleyin. Aceleyle kaçarken,\Nplanladığımızdan daha güneye geldik!
Dialogue: 0,0:03:23.35,0:03:25.23,Main-207-,,0,0,0,,O halde Grand Line'a mı girdik?
Dialogue: 0,0:03:25.23,0:03:27.02,Main-207-,,0,0,0,,Yaşasın!
Dialogue: 0,0:03:27.02,0:03:29.86,Main-207-,,0,0,0,,O kadar kolay olsaydı,\NGrand Line'a herkes girerdi!
Dialogue: 0,0:03:31.44,0:03:32.44,Main-207-,,0,0,0,,Bakın.
Dialogue: 0,0:03:32.44,0:03:37.41,Main-207-,,0,0,0,,Grand Line, iki başka deniz\Narasında sıkışmıştır!
Dialogue: 0,0:03:37.41,0:03:42.24,Main-207-,,0,0,0,,Anladınız mı?\NBu denizlere Calm Belt denir.
Dialogue: 0,0:03:43.33,0:03:47.58,Main-207-,,0,0,0,,Sebebi bilinmez, bu bölgelerde\Nne rüzgâr eser, ne de akıntı vardır.
Dialogue: 0,0:03:47.58,0:03:49.63,Main-207-,,0,0,0,,Bu denizler tamamen durgundur.
Dialogue: 0,0:03:49.63,0:03:52.38,Main-207-,,0,0,0,,Yelkenliler için, bu bölgelerde yolculuk yapmak...
Dialogue: 0,0:03:52.38,0:03:54.13,Main-207-,,0,0,0,,çok tehlikelidir!
Dialogue: 0,0:03:54.13,0:03:55.63,Main-207-,,0,0,0,,Luffy, anladın mı?
Dialogue: 0,0:03:55.63,0:03:57.72,Main-207-,,0,0,0,,Evet. Kısaca, başımız belada.
Dialogue: 0,0:03:57.72,0:04:00.18,Main-207-,,0,0,0,,Aynen öyle. Anlamana sevindim.
Dialogue: 0,0:04:00.18,0:04:03.14,Main-207-,,0,0,0,,Yani o moruk tehlikeli dediğinde,\Nkastettiği bu muydu?
Dialogue: 0,0:04:03.14,0:04:05.85,Main-207-,,0,0,0,,Bu, rüzgârın olmayışını açıklıyor.
Dialogue: 0,0:04:05.85,0:04:08.19,Main-207-,,0,0,0,,Gemi kıpırdamazsa hiçbir şey yapamayız.
Dialogue: 0,0:04:08.19,0:04:09.94,Main-207-,,0,0,0,,Sadece rüzgârı beklesek–
Dialogue: 0,0:04:09.94,0:04:14.07,Main-207-,,0,0,0,,Bunu az önce açıkladım!\Nİstediğin kadar bekle, rüzgâr esmez!
Dialogue: 0,0:04:14.07,0:04:15.23,Main-207-,,0,0,0,,Ve dahası da var!
Dialogue: 0,0:04:15.23,0:04:18.61,Main-207-,,0,0,0,,Bu bölgenin tehlikeli olmasının\Nbaşka bir sebebi daha var!
Dialogue: 0,0:04:18.61,0:04:20.03,Main-207-,,0,0,0,,Bu yer–
Dialogue: 0,0:04:22.03,0:04:23.66,Main-207-,,0,0,0,,Ne oluyor?
Dialogue: 0,0:04:28.87,0:04:31.17,Main-207-,,0,0,0,,Kocamanlar!
Dialogue: 0,0:04:36.92,0:04:39.59,Main-207-,,0,0,0,,Calm Belt, deniz krallarının yuvasıdır.
Dialogue: 0,0:04:39.59,0:04:41.55,Main-207-,,0,0,0,,Özellikle devasa olanların.
Dialogue: 0,0:04:41.93,0:04:46.02,Main-207-,,0,0,0,,{\q2}İnsanların Calm Belt'ten geçememelerinin\Nbir başka sebebi de onlar.
Dialogue: 0,0:04:47.02,0:04:48.94,Main-207-,,0,0,0,,Şimdi ne yapacağız?
Dialogue: 0,0:04:49.35,0:04:51.48,Main-207-,,0,0,0,,Önünde sonunda denize geri döneceklerdir.
Dialogue: 0,0:04:51.48,0:04:54.86,Main-207-,,0,0,0,,Sonra tüm gücümüzle kürek çekeceğiz.
Dialogue: 0,0:04:54.86,0:04:56.61,Main-207-,,0,0,0,,Ciddi misin sen?!
Dialogue: 0,0:04:56.61,0:04:57.49,Main-207-,,0,0,0,,{\fscx80\fscy80\bord3.04\shad3.04}Seni salak!
Dialogue: 0,0:04:59.24,0:05:01.07,Main-207-,,0,0,0,,Özür...
Dialogue: 0,0:05:05.49,0:05:07.16,Main-207-,,0,0,0,,Bekle bir saniye...!
Dialogue: 0,0:05:07.16,0:05:08.62,Main-207-,,0,0,0,,Yoksa o...
Dialogue: 0,0:05:08.62,0:05:11.12,Main-207-,,0,0,0,,Hapşıracak!
Dialogue: 0,0:05:11.75,0:05:14.00,Main-207-,,0,0,0,,– Ne?!\N– Ne?!
Dialogue: 0,0:05:14.00,0:05:16.75,Main-207-,,0,0,0,,Süper! Sanki uçuyoruz!
Dialogue: 0,0:05:18.67,0:05:25.14,Main-207-,,0,0,0,,Gerçekten {\i1}uçuyoruz{\i}!!
Dialogue: 0,0:05:27.56,0:05:30.35,Main-207-,,0,0,0,,Görünüşe göre asıl rotamıza döndük...
Dialogue: 0,0:05:30.35,0:05:33.90,Main-207-,,0,0,0,,Red Line'ı her an görebiliriz...
Dialogue: 0,0:05:37.90,0:05:40.95,Main-207-,,0,0,0,,Sonunda Grand Line'a ulaşıyoruz!
Dialogue: 0,0:05:41.78,0:05:46.03,Main-207-,,0,0,0,,Hey, Sanji! Oraya varıyoruz.\NSonunda varıyoruz!
Dialogue: 0,0:05:46.03,0:05:47.62,Main-207-,,0,0,0,,Acıtıyor!
Dialogue: 0,0:05:47.62,0:05:48.70,Main-207-,,0,0,0,,Afedersin...
Dialogue: 0,0:05:49.16,0:05:50.41,Secondary-207-,,0,0,0,,{\an8}Zoro!
Dialogue: 0,0:05:50.41,0:05:51.66,Secondary-207-,,0,0,0,,{\an8}Oraya varıyoruz!
Dialogue: 0,0:05:50.41,0:05:51.66,Thoughts-207-,,0,0,0,,Ama...
Dialogue: 0,0:05:51.66,0:05:55.29,Secondary-207-,,0,0,0,,{\an8}Sonunda varıyoruz!
Dialogue: 0,0:05:51.66,0:05:55.29,Thoughts-207-,,0,0,0,,Bu harita doğru çizilmiş mi?
Dialogue: 0,0:05:55.29,0:05:57.42,Secondary-207-,,0,0,0,,{\an8}Kes şunu!!!
Dialogue: 0,0:06:03.05,0:06:04.14,Main-207-,,0,0,0,,Şuna bakın!
Dialogue: 0,0:06:05.39,0:06:09.06,Main-207-,,0,0,0,,Bazı şeyler duymuştum,\Nüstelik, bu haritaya da çizilmiş!
Dialogue: 0,0:06:09.06,0:06:13.10,Main-207-,,0,0,0,,Eğer gerçekten doğruysa,\NGrand Line'ın girişi bir dağ!
Dialogue: 0,0:06:13.10,0:06:14.65,Main-207-,,0,0,0,,Dağ mı?
Dialogue: 0,0:06:14.65,0:06:16.02,Main-207-,,0,0,0,,Dağa mı çarpacağız?
Dialogue: 0,0:06:16.02,0:06:17.15,Main-207-,,0,0,0,,Cidden mi?
Dialogue: 0,0:06:17.15,0:06:22.15,Main-207-,,0,0,0,,Ben de inanmamıştım ama\Nharitada dağa çıkan kanallar var.
Dialogue: 0,0:06:22.15,0:06:24.32,Main-207-,,0,0,0,,Yani yukarı çıkmamız gerekebilir!
Dialogue: 0,0:06:25.41,0:06:27.20,Main-207-,,0,0,0,,Çok iyi be!
Dialogue: 0,0:06:27.20,0:06:28.66,Main-207-,,0,0,0,,Ne diyorsun sen?!
Dialogue: 0,0:06:28.66,0:06:33.04,Main-207-,,0,0,0,,Kanal olsun olmasın,\Nbir gemi dağa çıkamaz!
Dialogue: 0,0:06:33.04,0:06:34.67,Main-207-,,0,0,0,,Ama harita öyle söylüyor!
Dialogue: 0,0:06:34.67,0:06:38.13,Main-207-,,0,0,0,,Evet! Nami-{\i1}san{\i} asla yanılmaz!
Dialogue: 0,0:06:38.75,0:06:41.38,Main-207-,,0,0,0,,Bu haritayı Buggy'den çalmıştın, değil mi?
Dialogue: 0,0:06:41.38,0:06:42.80,Main-207-,,0,0,0,,Güvenilir mi ki?
Dialogue: 0,0:06:42.80,0:06:44.09,Main-207-,,0,0,0,,H-Hey!
Dialogue: 0,0:06:44.09,0:06:46.14,Main-207-,,0,0,0,,Biri dümene yardım etsin!
Dialogue: 0,0:06:46.14,0:06:48.51,Main-207-,,0,0,0,,Sanji-{\i1}kun{\i}! Usopp'a yardım et!
Dialogue: 0,0:06:48.51,0:06:50.85,Main-207-,,0,0,0,,Bu bağırış çağırışta düşünemiyorum!
Dialogue: 0,0:06:50.85,0:06:52.39,Main-207-,,0,0,0,,Hemen, Nami-{\i1}san{\i}!
Dialogue: 0,0:06:52.39,0:06:53.48,Main-207-,,0,0,0,,Tamam!
Dialogue: 0,0:06:46.72,0:06:49.51,Secondary-207-,,0,0,0,,Kımıldamıyor bile!
Dialogue: 0,0:06:49.51,0:06:52.39,Secondary-207-,,0,0,0,,Kımıldamıyor! Biri yardım etsin!
Dialogue: 0,0:06:53.94,0:06:57.40,Main-207-,,0,0,0,,B-Bu akıntı çok güçlü değil mi?!
Dialogue: 0,0:06:57.40,0:06:58.15,Main-207-,,0,0,0,,Ne?!
Dialogue: 0,0:06:58.15,0:06:59.77,Main-207-,,0,0,0,,Usopp! Ne dedin sen?
Dialogue: 0,0:06:59.77,0:07:02.53,Main-207-,,0,0,0,,"B-Bu akıntı çok güçlü değil mi?!"
Dialogue: 0,0:07:02.53,0:07:04.32,Main-207-,,0,0,0,,Akıntı...
Dialogue: 0,0:07:04.32,0:07:05.15,Main-207-,,0,0,0,,İşte bu!
Dialogue: 0,0:07:05.15,0:07:06.28,Main-207-,,0,0,0,,Ne oldu?
Dialogue: 0,0:07:06.28,0:07:08.12,Main-207-,,0,0,0,,Gerçekten dağa doğru gidiyorlar!
Dialogue: 0,0:07:08.12,0:07:10.66,Main-207-,,0,0,0,,Hâlâ mı aynı muhabbet?!
Dialogue: 0,0:07:10.66,0:07:11.37,Main-207-,,0,0,0,,Bakın!
Dialogue: 0,0:07:11.37,0:07:12.50,Main-207-,,0,0,0,,Gördünüz mü?
Dialogue: 0,0:07:12.50,0:07:15.71,Main-207-,,0,0,0,,Işık buraya işaret ediyor olmalı...
Dialogue: 0,0:07:15.71,0:07:18.04,Main-207-,,0,0,0,,Red Line'daki Reverse Mountain!
Dialogue: 0,0:07:18.04,0:07:20.50,Main-207-,,0,0,0,,Hey! Bi el atsanıza buraya!
Dialogue: 0,0:07:21.05,0:07:23.17,Main-207-,,0,0,0,,Bu kanalları görüyor musunuz?
Dialogue: 0,0:07:23.17,0:07:28.64,Main-207-,,0,0,0,,Eğer dört denizin güçlü akıntıları\Nbu dağa doğru akıyorsa...
Dialogue: 0,0:07:29.97,0:07:34.23,Main-207-,,0,0,0,,dört akıntı da bu kanallardan yukarıya\Ndoğru çıkıp zirvede birleşir...
Dialogue: 0,0:07:34.23,0:07:36.31,Main-207-,,0,0,0,,ve Grand Line'a dökülür!
Dialogue: 0,0:07:36.85,0:07:39.02,Main-207-,,0,0,0,,Reverse Mountain bir kış adası,...
Dialogue: 0,0:07:39.02,0:07:44.36,Main-207-,,0,0,0,,yani Red Line'a çarpan tüm akıntılar\Nyüzeyden dimdik derine doğru iner.
Dialogue: 0,0:07:44.36,0:07:46.99,Main-207-,,0,0,0,,Eğer kanalın girişini kaçırıp\Nişi bok edersek...
Dialogue: 0,0:07:47.61,0:07:50.45,Main-207-,,0,0,0,,{\t(2316,0,1,\c&HFDFEFD&\3c&HFDFEFD&\4c&HFDFEFD&)}Going Merry, \NRed Line'a bodoslama çarpar...
Dialogue: 0,0:07:52.70,0:07:54.87,Main-207-,,0,0,0,,{\t(1230,0,1,\c&HFEFEFC&\3c&HFEFEFC&\4c&HFEFEFC&)}ve paramparça olur!
Dialogue: 0,0:07:55.58,0:07:58.25,Main-207-,,0,0,0,,Ve biz de denizin dibini boylarız.\NAnladınız mı?
Dialogue: 0,0:07:58.25,0:07:59.67,Main-207-,,0,0,0,,Ah! Baya ilginçmiş!
Dialogue: 0,0:07:59.67,0:08:02.71,Main-207-,,0,0,0,,Yani basitçe, gizemli bir dağ!
Dialogue: 0,0:08:04.09,0:08:07.01,Main-207-,,0,0,0,,Hiç anlamamışsın...
Dialogue: 0,0:08:07.63,0:08:10.64,Main-207-,,0,0,0,,Neyse, bu gemi şu anda\No akıntıların birinde.
Dialogue: 0,0:08:10.64,0:08:12.39,Main-207-,,0,0,0,,Eğer kontrolümüzü yitirmezsek,...
Dialogue: 0,0:08:12.39,0:08:15.60,Main-207-,,0,0,0,,Reverse Mountain'a\Ntek parça olarak çıkarız.
Dialogue: 0,0:08:15.93,0:08:18.06,Main-207-,,0,0,0,,Nami-{\i1}san{\i}! Harikasın!
Dialogue: 0,0:08:18.06,0:08:20.98,Main-207-,,0,0,0,,Daha önce hiç dağa çıkan\Nbi' gemi duymamıştım.
Dialogue: 0,0:08:20.98,0:08:22.69,Main-207-,,0,0,0,,Ben bir şeyler duymuştum!
Dialogue: 0,0:08:23.07,0:08:24.48,Main-207-,,0,0,0,,Bu dağ hakkında mı?
Dialogue: 0,0:08:24.82,0:08:25.69,Main-207-,,0,0,0,,Hayır.
Dialogue: 0,0:08:25.69,0:08:30.70,Main-207-,,0,0,0,,Grand Line'a gidenlerin yarısı\Ndaha giremeden ölüyormuş...
Dialogue: 0,0:08:31.78,0:08:34.74,Main-207-,,0,0,0,,Girmenin kolay olmayacağını biliyordum.
Dialogue: 0,0:08:35.12,0:08:36.62,Main-207-,,0,0,0,,Sanji-{\i1}kun{\i0}! Yelkenlere sende!
Dialogue: 0,0:08:36.62,0:08:38.37,Main-207-,,0,0,0,,Emredersin, Nami-{\i1}san{\i0}!
Dialogue: 0,0:08:38.37,0:08:39.50,Main-207-,,0,0,0,,Luffy! Bir el at!
Dialogue: 0,0:08:39.50,0:08:41.46,Main-207-,,0,0,0,,Ne?!
Dialogue: 0,0:08:51.97,0:08:53.22,Main-207-,,0,0,0,,Hey!
Dialogue: 0,0:08:53.22,0:08:55.35,Main-207-,,0,0,0,,Gizemli dağ göründü!
Dialogue: 0,0:08:55.35,0:08:56.97,Main-207-,,0,0,0,,– N-Ne?!\N– Ne dedin?!
Dialogue: 0,0:08:57.39,0:09:00.02,Main-207-,,0,0,0,,K-Kocaman!!
Dialogue: 0,0:09:02.40,0:09:04.98,Main-207-,,0,0,0,,Demek bu Red Line, ha?!
Dialogue: 0,0:09:05.48,0:09:11.49,Main-207-,,0,0,0,,T-T-Tepesi bulutların ötesinde!
Dialogue: 0,0:09:31.93,0:09:33.72,Main-207-,,0,0,0,,Bizi içine çekiyor!
Dialogue: 0,0:09:34.35,0:09:35.97,Main-207-,,0,0,0,,Dümeni sağlam tutun!
Dialogue: 0,0:09:35.97,0:09:37.47,Main-207-,,0,0,0,,– Hallediyoruz!\N– Hallediyoruz!
Dialogue: 0,0:09:44.77,0:09:47.36,Main-207-,,0,0,0,,N-Nami! G-Giriş nerede?!
Dialogue: 0,0:09:47.36,0:09:50.32,Main-207-,,0,0,0,,Bu şekilde devam edersek çarpacağız!
Dialogue: 0,0:09:52.66,0:09:54.57,Main-207-,,0,0,0,,Kayalıktaki yarık...
Dialogue: 0,0:09:57.45,0:10:00.29,Main-207-,,0,0,0,,Nami! Ne yapalım?!
Dialogue: 0,0:10:00.29,0:10:01.71,Main-207-,,0,0,0,,Dümdüz devam edin!
Dialogue: 0,0:10:01.71,0:10:02.87,Main-207-,,0,0,0,,Emin misin?!
Dialogue: 0,0:10:02.87,0:10:04.08,Main-207-,,0,0,0,,Evet!
Dialogue: 0,0:10:05.08,0:10:07.04,Main-207-,,0,0,0,,Nami! Şu kanal girişi mi?
Dialogue: 0,0:10:07.04,0:10:08.50,Main-207-,,0,0,0,,Büyük ihtimal!
Dialogue: 0,0:10:09.17,0:10:10.97,Main-207-,,0,0,0,,Gözlerime inanamıyorum!
Dialogue: 0,0:10:11.63,0:10:15.14,Main-207-,,0,0,0,,Kahrolası deniz\Ncidden dağa doğru akıyor!
Dialogue: 0,0:10:20.22,0:10:23.48,Main-207-,,0,0,0,,Bu geçitlerden sorunsuzca\Ngeçmemiz gerekiyor!
Dialogue: 0,0:10:23.81,0:10:26.36,Main-207-,,0,0,0,,Aksi takdirde gemi paramparça olur!
Dialogue: 0,0:10:30.15,0:10:33.36,Main-207-,,0,0,0,,R-Rotadan sapıyoruz!\NSağa doğru! Sağa! Sağa!
Dialogue: 0,0:10:33.36,0:10:35.66,Main-207-,,0,0,0,,Sağa mı?! Sancak alabanda!
Dialogue: 0,0:10:38.45,0:10:40.95,Main-207-,,0,0,0,,H-Hadi, yüklen!
Dialogue: 0,0:10:47.88,0:10:49.42,Main-207-,,0,0,0,,– Dümen kolu!\N– Dümen kolu!
Dialogue: 0,0:10:49.42,0:10:52.13,Main-207-,,0,0,0,,{\fad(150,150)}Lastik-Lastik Balon!
Dialogue: 0,0:11:00.76,0:11:02.31,Main-207-,,0,0,0,,Luffy!
Dialogue: 0,0:11:02.31,0:11:03.18,Main-207-,,0,0,0,,Bana tutun!
Dialogue: 0,0:11:16.07,0:11:18.74,Main-207-,,0,0,0,,– Başardık!\N– Başardık!
Dialogue: 0,0:11:24.87,0:11:28.21,Main-207-,,0,0,0,,Şimdi alabildiğine zirveye doğru!
Dialogue: 0,0:11:32.46,0:11:35.22,Main-207-,,0,0,0,,M-Müthiş!
Dialogue: 0,0:11:42.47,0:11:43.56,Main-207-,,0,0,0,,Harika, değil mi?
Dialogue: 0,0:11:45.64,0:11:48.44,Main-207-,,0,0,0,,Bulutların içindeyiz!
Dialogue: 0,0:11:59.37,0:12:01.70,Main-207-,,0,0,0,,Müthiş!!!
Dialogue: 0,0:12:03.12,0:12:05.20,Main-207-,,0,0,0,,Bulutların üstüne çıktık!
Dialogue: 0,0:12:15.55,0:12:18.63,Main-207-,,0,0,0,,Bakın! Zirve! Zirve orada!
Dialogue: 0,0:12:31.40,0:12:33.65,Main-207-,,0,0,0,,Yaşasın!
Dialogue: 0,0:12:54.75,0:12:55.80,Main-207-,,0,0,0,,Görüyorum!
Dialogue: 0,0:12:56.21,0:12:58.63,Main-207-,,0,0,0,,İşte dünyanın en büyük denizi!
Dialogue: 0,0:12:58.63,0:12:59.93,Main-207-,,0,0,0,,Grand Line!
Dialogue: 0,0:13:02.64,0:13:06.97,Main-207-,,0,0,0,,One Piece orada bir yerde!
Dialogue: 0,0:13:07.56,0:13:10.10,Main-207-,,0,0,0,,Gidelim!
Dialogue: 0,0:13:24.62,0:13:26.49,Main-207-,,0,0,0,,Siz de duydunuz mu?
Dialogue: 0,0:13:26.49,0:13:28.41,Main-207-,,0,0,0,,Rüzgârı mı diyorsun?
Dialogue: 0,0:13:28.41,0:13:31.58,Main-207-,,0,0,0,,Herhâlde çevredeki\Ntuhaf oluşumlardan kaynaklı.
Dialogue: 0,0:13:36.25,0:13:37.21,Main-207-,,0,0,0,,O ne?
Dialogue: 0,0:13:37.80,0:13:40.30,Main-207-,,0,0,0,,Nami-{\i1}san{\i}!\Nİleride bir dağ görüyorum!
Dialogue: 0,0:13:40.30,0:13:42.63,Main-207-,,0,0,0,,Dağ mı?! Bu imkânsız!
Dialogue: 0,0:13:42.63,0:13:44.68,Main-207-,,0,0,0,,Ama görüyorum!
Dialogue: 0,0:13:44.68,0:13:46.97,Main-207-,,0,0,0,,Kimin umrunda?! Gidelim!!
Dialogue: 0,0:13:47.64,0:13:51.64,Main-207-,,0,0,0,,İkiz Burun'u geçer geçmez\Naçık denize ulaşmalıyız!
Dialogue: 0,0:13:57.48,0:13:58.86,Main-207-,,0,0,0,,Hassiktir!!
Dialogue: 0,0:14:01.03,0:14:02.49,Main-207-,,0,0,0,,Dağ değilmiş!
Dialogue: 0,0:14:02.49,0:14:03.74,Main-207-,,0,0,0,,Siyah bir duvar bu!
Dialogue: 0,0:14:03.74,0:14:04.91,Main-207-,,0,0,0,,Hayır, değil! Bu...
Dialogue: 0,0:14:04.91,0:14:06.03,Main-207-,,0,0,0,,O zaman ne?!
Dialogue: 0,0:14:06.03,0:14:07.28,Main-207-,,0,0,0,,B-B-Bu...
Dialogue: 0,0:14:07.28,0:14:09.41,Main-207-,,0,0,0,,Balina!
Dialogue: 0,0:14:11.91,0:14:13.42,Main-207-,,0,0,0,,N-N-Ne halt e-edeceğiz şimdi?!
Dialogue: 0,0:14:13.42,0:14:14.38,Main-207-,,0,0,0,,Dövelim mi?
Dialogue: 0,0:14:14.38,0:14:16.54,Main-207-,,0,0,0,,Aptal! Bu şeyi nasıl döveceğiz?!
Dialogue: 0,0:14:16.54,0:14:19.51,Main-207-,,0,0,0,,A-A-A-Ama yolumuzu kapatıyor!
Dialogue: 0,0:14:19.51,0:14:21.22,Main-207-,,0,0,0,,Ne yapacağız?!
Dialogue: 0,0:14:21.22,0:14:22.67,Main-207-,,0,0,0,,Durun bir saniye!
Dialogue: 0,0:14:23.22,0:14:27.18,Main-207-,,0,0,0,,Yakından bir duvara benziyorsa\No zaman gözleri nerede?!
Dialogue: 0,0:14:27.68,0:14:31.31,Main-207-,,0,0,0,,Doğru! Bizi görmemiş olabilir!
Dialogue: 0,0:14:31.31,0:14:33.85,Main-207-,,0,0,0,,Ama bir şey yapmazsak çarpacağız!
Dialogue: 0,0:14:33.85,0:14:35.90,Main-207-,,0,0,0,,Hey! Sol tarafından geçebiliriz!
Dialogue: 0,0:14:35.90,0:14:38.36,Main-207-,,0,0,0,,İskele! İskele alabanda!
Dialogue: 0,0:14:38.94,0:14:40.44,Main-207-,,0,0,0,,Ama dümen kolu kırık!
Dialogue: 0,0:14:40.44,0:14:42.90,Main-207-,,0,0,0,,Bir şey yapın!\NBen de yardım edeceğim!
Dialogue: 0,0:14:42.90,0:14:44.28,Main-207-,,0,0,0,,Ah, evet!
Dialogue: 0,0:14:44.28,0:14:46.57,Main-207-,,0,0,0,,Bir fikrim var!
Dialogue: 0,0:14:46.57,0:14:47.24,Main-207-,,0,0,0,,Luffy...?
Dialogue: 0,0:14:47.24,0:14:49.12,Main-207-,,0,0,0,,Hey, napıyorsun?!
Dialogue: 0,0:14:54.46,0:14:56.29,Main-207-,,0,0,0,,Olmuyor!
Dialogue: 0,0:14:56.29,0:14:58.88,Main-207-,,0,0,0,,Gemi dönmüyor!
Dialogue: 0,0:14:58.88,0:15:00.17,Main-207-,,0,0,0,,Kahretsin!
Dialogue: 0,0:15:00.17,0:15:02.30,Main-207-,,0,0,0,,Pes etmeyin!
Dialogue: 0,0:15:10.97,0:15:12.89,Main-207-,,0,0,0,,Her şey bitti mi...?!
Dialogue: 0,0:15:19.90,0:15:22.11,Thoughts-207-,,0,0,0,,{\pos(1175,1053)}Top mu?!
Dialogue: 0,0:15:20.15,0:15:22.11,Thoughts-207-,,0,0,0,,{\an8\pos(840,27)}Top mu?!
Dialogue: 0,0:15:20.40,0:15:22.11,Thoughts-207-,,0,0,0,,{\pos(480,1053)}Top mu?!
Dialogue: 0,0:15:20.65,0:15:22.11,Thoughts-207-,,0,0,0,,{\an8\pos(270,27)}Top mu?!
Dialogue: 0,0:15:22.11,0:15:24.07,Main-207-,,0,0,0,,Pekâlâ! Durdu mu ki?
Dialogue: 0,0:15:32.08,0:15:33.16,Main-207-,,0,0,0,,Ayvayı yedik...
Dialogue: 0,0:15:33.58,0:15:34.58,Main-207-,,0,0,0,,Bittik...
Dialogue: 0,0:15:37.42,0:15:39.33,Main-207-,,0,0,0,,Özel koltuğum!
Dialogue: 0,0:15:56.39,0:15:56.98,Main-207-,,0,0,0,,Çok...
Dialogue: 0,0:15:56.98,0:15:58.90,Main-207-,,0,0,0,,Çok geç olmadan tüyelim!
Dialogue: 0,0:15:58.90,0:16:00.90,Main-207-,,0,0,0,,Ne oluyor, lan?!
Dialogue: 0,0:16:00.90,0:16:03.40,Main-207-,,0,0,0,,Çok büyük diye mi hissetmedi?!
Dialogue: 0,0:16:03.40,0:16:04.74,Main-207-,,0,0,0,,Yoksa çok mu yavaş?!
Dialogue: 0,0:16:04.74,0:16:06.70,Main-207-,,0,0,0,,Kim bilir?! Neyse, hadi sıvışalım!
Dialogue: 0,0:16:12.53,0:16:13.58,Main-207-,,0,0,0,,Kulaklarım!
Dialogue: 0,0:16:13.58,0:16:15.20,Main-207-,,0,0,0,,Kürek çekin! Asılın küreklere!
Dialogue: 0,0:16:15.20,0:16:17.12,Main-207-,,0,0,0,,Ondan uzaklaşmamız lazım!
Dialogue: 0,0:16:23.34,0:16:24.46,Main-207-,,0,0,0,,Luffy...?
Dialogue: 0,0:16:24.46,0:16:25.84,Main-207-,,0,0,0,,Sen!
Dialogue: 0,0:16:25.84,0:16:30.43,Main-207-,,0,0,0,,Özel koltuğuma ne yaptın lan?!
Dialogue: 0,0:16:31.72,0:16:34.72,Main-207-,,0,0,0,,– Seni salak!\N– Seni salak!
Dialogue: 0,0:16:41.65,0:16:44.48,Main-207-,,0,0,0,,Nasılmış?! Yiyosa gel, şerefsiz!
Dialogue: 0,0:16:44.48,0:16:46.07,Main-207-,,0,0,0,,– Kes artık, aptal!\N– Kes artık, aptal!
Dialogue: 0,0:16:50.07,0:16:51.45,Main-207-,,0,0,0,,N-Ne?
Dialogue: 0,0:17:07.38,0:17:08.34,Main-207-,,0,0,0,,Luffy!
Dialogue: 0,0:17:08.34,0:17:09.22,Main-207-,,0,0,0,,Luffy!
Dialogue: 0,0:17:15.43,0:17:18.39,Main-207-,,0,0,0,,Ölmeyeceğim!
Dialogue: 0,0:17:43.50,0:17:44.84,Main-207-,,0,0,0,,Şimdi ne yapacağım?
Dialogue: 0,0:17:44.84,0:17:46.38,Main-207-,,0,0,0,,Herkesi yedi...
Dialogue: 0,0:17:47.42,0:17:50.38,Main-207-,,0,0,0,,Hey, sen! Geri tükür!\NOnları geri ver!
Dialogue: 0,0:17:50.38,0:17:52.30,Main-207-,,0,0,0,,Tükür onları artık! Beni dinle!
Dialogue: 0,0:17:52.30,0:17:53.22,Main-207-,,0,0,0,,Ulan–
Dialogue: 0,0:17:55.47,0:17:57.22,Main-207-,,0,0,0,,Seni... pislik!
Dialogue: 0,0:17:57.64,0:17:59.73,Main-207-,,0,0,0,,Dalıyor musun?! Dursana!
Dialogue: 0,0:17:59.73,0:18:02.19,Main-207-,,0,0,0,,Hey! Dur dedim! Hey!
Dialogue: 0,0:18:02.98,0:18:05.15,Main-207-,,0,0,0,,Lütfen, dur! Arkadaşlarımı geri ver!
Dialogue: 0,0:18:05.61,0:18:06.40,Main-207-,,0,0,0,,Hey!
Dialogue: 0,0:18:06.40,0:18:08.11,Main-207-,,0,0,0,,Dur artık!
Dialogue: 0,0:18:08.48,0:18:10.78,Main-207-,,0,0,0,,Onlarla maceralara atılacaktık!
Dialogue: 0,0:18:10.78,0:18:12.11,Main-207-,,0,0,0,,Onları kaybedemem!
Dialogue: 0,0:18:12.61,0:18:15.24,Main-207-,,0,0,0,,Geri ver onları!
Dialogue: 0,0:18:36.76,0:18:38.85,Main-207-,,0,0,0,,Ne düşünüyorsun...?
Dialogue: 0,0:18:38.85,0:18:40.77,Main-207-,,0,0,0,,Ne mi düşünüyorum...?
Dialogue: 0,0:18:40.77,0:18:42.48,Main-207-,,0,0,0,,Ne düşünmeliyim?
Dialogue: 0,0:18:42.48,0:18:44.23,Main-207-,,0,0,0,,N-N-N-N-Ne...?
Dialogue: 0,0:18:44.23,0:18:48.40,Main-207-,,0,0,0,,Balina tarafından yutulduğumuza emindim...
Dialogue: 0,0:18:50.15,0:18:51.82,Main-207-,,0,0,0,,Rüya mı bu?
Dialogue: 0,0:18:51.82,0:18:54.40,Main-207-,,0,0,0,,Evet, muhtemelen.
Dialogue: 0,0:19:00.08,0:19:02.62,Main-207-,,0,0,0,,Peki, bu ada ve ev,\Nburada ne arıyor?
Dialogue: 0,0:19:02.62,0:19:04.00,Main-207-,,0,0,0,,Halüsinasyon.
Dialogue: 0,0:19:08.59,0:19:10.75,Main-207-,,0,0,0,,O zaman, bu...?
Dialogue: 0,0:19:11.42,0:19:14.76,Main-207-,,0,0,0,,– Dev bir kalamar!\N– Dev bir kalamar!
Dialogue: 0,0:19:35.99,0:19:37.99,Main-207-,,0,0,0,,Görünüşe göre burada biri var.
Dialogue: 0,0:19:37.99,0:19:39.57,Main-207-,,0,0,0,,Umarım bi' insandır...
Dialogue: 0,0:19:40.58,0:19:42.58,Main-207-,,0,0,0,,Yetti artık bana.\NEve gitmek istiyorum.
Dialogue: 0,0:19:42.58,0:19:46.37,Main-207-,,0,0,0,,Luffy de gitti. Bize ne olacak?
Dialogue: 0,0:19:46.37,0:19:48.04,Main-207-,,0,0,0,,Doğru ya, Luffy nerede?!
Dialogue: 0,0:19:50.09,0:19:51.92,Main-207-,,0,0,0,,Bu ne lan?
Dialogue: 0,0:19:51.92,0:19:55.84,Main-207-,,0,0,0,,Niye balinanın içinde\Nkapı ve koridor var?
Dialogue: 0,0:19:58.72,0:19:59.80,Main-207-,,0,0,0,,Bir gemi...
Dialogue: 0,0:19:59.80,0:20:03.97,Main-207-,,0,0,0,,T-T-Topu ateşlesek mi adaya doğru?!
Dialogue: 0,0:20:03.97,0:20:05.81,Main-207-,,0,0,0,,Hayır, durun bir saniye...
Dialogue: 0,0:20:07.27,0:20:09.27,Main-207-,,0,0,0,,Biri dışarı çıkıyor...
Comment: 0,0:00:00.00,0:00:00.00,Main-207-,,0,0,0,,{=9}===============================DIALOGUE============================
