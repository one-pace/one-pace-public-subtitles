Comment: 0,0:00:00.00,0:00:00.00,Main-207+,,0,0,0,,{=2}===============================DIALOGUE============================
Dialogue: 0,0:01:32.91,0:01:37.29,Main-207+,,0,0,0,,Yine mi aynı terane velet?
Dialogue: 0,0:01:37.29,0:01:39.66,Main-207+,,0,0,0,,Sen kim korsanlar kralı olmak kim?
Dialogue: 0,0:01:46.17,0:01:49.05,Thoughts-207+,,0,0,0,,Saldırısı bana zarar mı verdi?
Dialogue: 0,0:01:50.05,0:01:54.47,Main-207+,,0,0,0,,Wano'daki ihtiyarın öğrettiği haki mi bu?
Dialogue: 0,0:01:54.47,0:01:56.72,Main-207+,,0,0,0,,O haki neydi öyle?
Dialogue: 0,0:01:56.72,0:01:58.93,Main-207+,,0,0,0,,Yumruklar Kaido'ya işliyor muydu?
Dialogue: 0,0:02:00.77,0:02:03.10,Main-207+,,0,0,0,,Kazanma şansımız var demek.
Dialogue: 0,0:02:03.10,0:02:08.36,Main-207+,,0,0,0,,Her şey sırayla. Önce Hasır Şapka'ya\Nbir şey demem lazım.
Dialogue: 0,0:02:08.78,0:02:10.99,Main-207+,,0,0,0,,Bana bak, velet.
Dialogue: 0,0:02:12.07,0:02:19.62,Main-207+,,0,0,0,,Korsanlar Kralı ne anlama geliyor\Nbiliyor musun sen?
Dialogue: 0,0:02:25.00,0:02:30.46,Thoughts-207+,,0,0,0,,Kuri'de ifadesini aldıktan sonra buna n'oldu?
Dialogue: 0,0:02:33.34,0:02:35.59,Thoughts-207+,,0,0,0,,Benimle dövüşebilecek...
Dialogue: 0,0:02:36.72,0:02:40.14,Thoughts-207+,,0,0,0,,sadece bir avuç insan var.
Dialogue: 0,0:02:46.69,0:02:53.36,Thoughts-207+,,0,0,0,,Onlar kadar iyi olduğunu mu ima ediyorsun?
Dialogue: 0,0:02:54.32,0:02:57.49,Main-207+,,0,0,0,,Hasır Şapka!
Dialogue: 0,0:03:09.59,0:03:12.05,Main-207+,,0,0,0,,{\fad(150,150)}Gök Gürültüsü Bagua!
Dialogue: 0,0:03:20.89,0:03:21.89,Main-207+,,0,0,0,,Hadi be!
Dialogue: 0,0:03:21.89,0:03:24.81,Main-207+,,0,0,0,,Geleceği gördüğüm hâlde çok hızlıydı.
Dialogue: 0,0:03:24.81,0:03:26.19,Main-207+,,0,0,0,,Helal olsun!
Dialogue: 0,0:03:26.19,0:03:29.31,Main-207+,,0,0,0,,Bu seferkini yemedin.
Dialogue: 0,0:03:29.31,0:03:31.69,Main-207+,,0,0,0,,Kalıbından utan, Kaido!
Dialogue: 0,0:03:31.69,0:03:34.19,Main-207+,,0,0,0,,Çöplerden yakarak kurtulursun.
Dialogue: 0,0:03:35.32,0:03:37.07,Main-207+,,0,0,0,,Prometheus!
Dialogue: 0,0:03:37.07,0:03:38.41,Main-207+,,0,0,0,,Emret, Mama!
Dialogue: 0,0:03:39.28,0:03:42.12,Main-207+,,0,0,0,,Yakıp kül et!
Dialogue: 0,0:03:44.08,0:03:46.21,Main-207+,,0,0,0,,{\fad(150,150)}Kutsal Ateş!
Dialogue: 0,0:03:47.58,0:03:50.42,Main-207+,,0,0,0,,{\fad(150,150)}Tilki Ateşi Stili: Alev Yaran!
Dialogue: 0,0:03:56.01,0:03:58.05,Main-207+,,0,0,0,,Prometheus!
Dialogue: 0,0:03:59.72,0:04:01.22,Main-207+,,0,0,0,,Kin'emon'un tekniğiydi!
Dialogue: 0,0:04:01.22,0:04:03.47,Main-207+,,0,0,0,,Süpersin Zoro!
Dialogue: 0,0:04:05.73,0:04:06.98,Main-207+,,0,0,0,,Çaldım.
Dialogue: 0,0:04:06.98,0:04:09.40,Main-207+,,0,0,0,,Ay, ay, ay, ay!
Dialogue: 0,0:04:09.40,0:04:10.86,Main-207+,,0,0,0,,Canım yandı.
Dialogue: 0,0:04:12.32,0:04:14.40,Main-207+,,0,0,0,,Gevşeyeyim deme sakın Luffy!
Dialogue: 0,0:04:15.32,0:04:17.61,Main-207+,,0,0,0,,Karşımızda iki Yonko var!
Dialogue: 0,0:04:22.78,0:04:23.91,Main-207+,,0,0,0,,{\fad(150,150)}Değişim!
Dialogue: 0,0:04:34.75,0:04:36.71,Main-207+,,0,0,0,,Hey, Hasır Şapka-{\i1}ya{\i0}.
Dialogue: 0,0:04:36.71,0:04:37.76,Main-207+,,0,0,0,,Trao!
Dialogue: 0,0:04:37.76,0:04:39.63,Main-207+,,0,0,0,,Kurtardın beni! Sağ ol!
Dialogue: 0,0:04:40.30,0:04:41.64,Main-207+,,0,0,0,,Dinle!
Dialogue: 0,0:04:42.26,0:04:44.39,Main-207+,,0,0,0,,Sana bir şey söylemem lazım!
Dialogue: 0,0:04:44.39,0:04:45.06,Main-207+,,0,0,0,,Heh?
Dialogue: 0,0:04:45.06,0:04:47.02,Main-207+,,0,0,0,,Ben...
Dialogue: 0,0:04:47.02,0:04:50.60,Main-207+,,0,0,0,,zaten onları aşağı yollayacaktım!
Dialogue: 0,0:04:51.56,0:04:52.52,Main-207+,,0,0,0,,Heh?!
Dialogue: 0,0:04:52.52,0:04:55.15,Main-207+,,0,0,0,,{\fad(0,481)}Ama sen öyle deyince...
Dialogue: 0,0:04:55.15,0:04:55.94,Flashbacks-207+,,0,0,0,,Trao!
Dialogue: 0,0:04:55.94,0:04:58.36,Flashbacks-207+,,0,0,0,,Hepsini aşağı yolla!{Wano 55 - 10:16 (EX - 20:13)}
Dialogue: 0,0:05:00.66,0:05:02.32,Main-207+,,0,0,0,,...sanki senin emrini...
Dialogue: 0,0:05:02.32,0:05:05.08,Main-207+,,0,0,0,,yerine getiriyormuş gibi göründüm!
Dialogue: 0,0:05:05.08,0:05:06.37,Main-207+,,0,0,0,,Heh?!
Dialogue: 0,0:05:06.37,0:05:08.33,Main-207+,,0,0,0,,Ne fark eder be?
Dialogue: 0,0:05:09.79,0:05:11.42,Main-207+,,0,0,0,,Trafalgar...
Dialogue: 0,0:05:12.04,0:05:15.63,Main-207+,,0,0,0,,Hasır Şapka sonunda sana\Ntasmayı takmış dedim.
Dialogue: 0,0:05:15.63,0:05:17.59,Main-207+,,0,0,0,,Y-Yürü git lan!
Dialogue: 0,0:05:17.59,0:05:22.01,Main-207+,,0,0,0,,Bir ezik diğer eziğin\Nadamı olmuş beni bağlamaz.
Dialogue: 0,0:05:22.01,0:05:23.26,Main-207+,,0,0,0,,– Heh?!\N– Heh?!
Dialogue: 0,0:05:23.26,0:05:25.64,Main-207+,,0,0,0,,Sensin ezik!
Dialogue: 0,0:05:25.64,0:05:27.64,Main-207+,,0,0,0,,Sen kime ezik diyo'n lan?
Dialogue: 0,0:05:27.64,0:05:30.18,Main-207+,,0,0,0,,Kesin laklağı!
Dialogue: 0,0:05:30.18,0:05:31.39,Main-207+,,0,0,0,,– Heh?!\N– Heh?!
Dialogue: 0,0:05:32.81,0:05:35.06,Main-207+,,0,0,0,,Yakıp kül et şunları Prometheus!
Dialogue: 0,0:05:35.06,0:05:36.65,Main-207+,,0,0,0,,Emredersin Mama!
Dialogue: 0,0:05:36.65,0:05:38.94,Main-207+,,0,0,0,,{\fad(150,150)}Kutsal Ateş Topları!
Dialogue: 0,0:05:43.16,0:05:45.03,Main-207+,,0,0,0,,Tamam, buldum!
Dialogue: 0,0:05:45.03,0:05:46.08,Main-207+,,0,0,0,,– Heh?!\N– Heh?!
Dialogue: 0,0:05:46.08,0:05:50.12,Main-207+,,0,0,0,,Şu saldırıdan ilk kaçan eziktir!
Dialogue: 0,0:05:50.12,0:05:51.87,Main-207+,,0,0,0,,Ne alaka gerizekâlı?
Dialogue: 0,0:05:51.87,0:05:55.59,Main-207+,,0,0,0,,Böyle boktan oyunları icat ederken\Nçok düşünüyor musun?
Dialogue: 0,0:05:55.59,0:05:59.71,Main-207+,,0,0,0,,Al işte, bu yüzden adınız tarihe geçmeyecek!
Dialogue: 0,0:05:59.71,0:06:00.97,Main-207+,,0,0,0,,Öyle olsun,
Dialogue: 0,0:06:00.97,0:06:03.09,Main-207+,,0,0,0,,ikiniz de eziksiniz o zaman!
Dialogue: 0,0:06:03.09,0:06:04.34,Main-207+,,0,0,0,,– Heh?!\N– Heh?!
Dialogue: 0,0:06:04.34,0:06:06.51,Main-207+,,0,0,0,,Kaçanı siksinler!
Dialogue: 0,0:06:06.51,0:06:08.01,Main-207+,,0,0,0,,İyi, bana uyar.
Dialogue: 0,0:06:08.01,0:06:10.68,Main-207+,,0,0,0,,Çabuk kaçın ödlekler.
Dialogue: 0,0:06:10.68,0:06:12.81,Main-207+,,0,0,0,,Savuşturun hadi pısırıklar.
Dialogue: 0,0:06:15.35,0:06:16.77,Main-207+,,0,0,0,,Dikkat, geliyor!
Dialogue: 0,0:06:28.20,0:06:30.24,Main-207+,,0,0,0,,N'apıyorsunuz ulan siz?
Dialogue: 0,0:06:33.16,0:06:37.79,Main-207+,,0,0,0,,Kim Korsanlar Kralı olacağım diyordu?
Dialogue: 0,0:06:37.79,0:06:39.71,Main-207+,,0,0,0,,Peki...
Dialogue: 0,0:06:39.71,0:06:42.97,Main-207+,,0,0,0,,sizi nasıl öldürsem?
Dialogue: 0,0:06:43.67,0:06:45.72,Main-207+,,0,0,0,,Linlin, sen geri dur.
Dialogue: 0,0:06:45.72,0:06:48.05,Main-207+,,0,0,0,,Ne kadar güçlüler görmek istiyorum.
Dialogue: 0,0:06:48.80,0:06:50.06,Main-207+,,0,0,0,,Heh?
Dialogue: 0,0:06:50.06,0:06:52.35,Main-207+,,0,0,0,,Ne lüzumu var bunun?
Dialogue: 0,0:06:53.94,0:06:56.94,Main-207+,,0,0,0,,Beni engelleme, Katil Kamazo.
Dialogue: 0,0:06:59.32,0:07:02.99,Main-207+,,0,0,0,,Öyle gülen pek insan yok da.
Dialogue: 0,0:07:05.78,0:07:10.62,Main-207+,,0,0,0,,O zaman Cezalandırıcılarım\Nyanımda olsaydı boku yemiştin...
Dialogue: 0,0:07:10.62,0:07:12.41,Main-207+,,0,0,0,,Zorojuro.
Dialogue: 0,0:07:12.41,0:07:13.79,Main-207+,,0,0,0,,Sonuç değişmezdi.
Dialogue: 0,0:07:40.82,0:07:42.86,Main-207+,,0,0,0,,{\fad(150,150)}Kafakesen Pençeler!
Dialogue: 0,0:07:43.40,0:07:44.94,Main-207+,,0,0,0,,{\fad(150,150)}Üç Kılıç Stili:
Dialogue: 0,0:07:46.65,0:07:49.24,Main-207+,,0,0,0,,{\fad(150,150)}Arafın İblis Doğrayıcısı!
Dialogue: 0,0:08:07.38,0:08:08.47,Main-207+,,0,0,0,,Yeterli değil.
Dialogue: 0,0:08:16.35,0:08:17.98,Main-207+,,0,0,0,,Ününü hak ediyorsun.
Dialogue: 0,0:08:18.48,0:08:22.94,Main-207+,,0,0,0,,Enma'nın gücünü biraz daha salmam lazım.
Dialogue: 0,0:08:23.27,0:08:24.48,Main-207+,,0,0,0,,Kaido!
Comment: 0,0:08:24.48,0:08:25.57,Main-207+,,0,0,0,,Hım?
Dialogue: 0,0:08:26.49,0:08:29.11,Main-207+,,0,0,0,,İşini tek bir seferde bitireceğiz!
Dialogue: 0,0:08:29.11,0:08:31.66,Main-207+,,0,0,0,,{\fad(150,150)}Dördüncü Vites!
Dialogue: 0,0:08:54.18,0:08:55.85,Main-207+,,0,0,0,,{\fad(150,150)}Sıçrayan Adam!
Dialogue: 0,0:09:57.58,0:09:58.74,Main-207+,,0,0,0,,Aynen öyle!
Dialogue: 0,0:10:00.62,0:10:02.58,Main-207+,,0,0,0,,{\fad(150,150)}Punk Rotten!
Dialogue: 0,0:10:14.93,0:10:16.30,Main-207+,,0,0,0,,{\fad(150,150)}Oda!
Dialogue: 0,0:10:18.43,0:10:19.35,Main-207+,,0,0,0,,{\fad(150,150)}Takt!
Dialogue: 0,0:11:06.02,0:11:10.48,Main-207+,,0,0,0,,Canavardan farkı yok bunların.
Dialogue: 0,0:11:10.48,0:11:11.57,Main-207+,,0,0,0,,Hadi!
Dialogue: 0,0:11:11.57,0:11:14.70,Main-207+,,0,0,0,,Sizde korsanlar kralı olacak\Nkapasite var mı...
Dialogue: 0,0:11:15.82,0:11:17.28,Main-207+,,0,0,0,,saldırın da göreyim!
Dialogue: 0,0:11:23.45,0:11:26.58,Main-207+,,0,0,0,,{\fad(150,150)}Lastik-Lastik...
Dialogue: 0,0:11:33.51,0:11:35.51,Main-207+,,0,0,0,,{\fad(150,150)}Kong Silahı!
Dialogue: 0,0:11:47.94,0:11:49.94,Main-207+,,0,0,0,,Of...
Dialogue: 0,0:11:49.94,0:11:51.23,Main-207+,,0,0,0,,Bu acıttı!
Dialogue: 0,0:11:54.65,0:11:57.32,Main-207+,,0,0,0,,Derin ne kadar kalın farkındayım!
Dialogue: 0,0:11:57.32,0:12:01.20,Main-207+,,0,0,0,,Ama pestilini çıkarırsam ölür gidersin bence!
Dialogue: 0,0:12:06.83,0:12:08.46,Main-207+,,0,0,0,,Arzu ettiğin gibi...
Dialogue: 0,0:12:08.46,0:12:11.29,Main-207+,,0,0,0,,ne kadar güçlüyüm göstereyim!
Dialogue: 0,0:12:11.29,0:12:13.34,Main-207+,,0,0,0,,{\fad(150,150)}Punk Mengenesi!
Dialogue: 0,0:12:32.40,0:12:36.69,Main-207+,,0,0,0,,Fena değil ama yetmez.
Dialogue: 0,0:12:42.70,0:12:45.45,Main-207+,,0,0,0,,Ben ekleme yapayım.
Dialogue: 0,0:12:45.45,0:12:46.66,Main-207+,,0,0,0,,O da ne?
Dialogue: 0,0:12:46.66,0:12:47.71,Main-207+,,0,0,0,,{\fad(150,150)}Takt!
Dialogue: 0,0:12:49.71,0:12:50.46,Main-207+,,0,0,0,,Siktir!
Dialogue: 0,0:13:02.39,0:13:03.89,Main-207+,,0,0,0,,Lan piç!
Dialogue: 0,0:13:03.89,0:13:06.06,Main-207+,,0,0,0,,Beni de onunla beraber mi öldürecektin?
Dialogue: 0,0:13:11.56,0:13:13.94,Main-207+,,0,0,0,,Of, çok acıyor.
Dialogue: 0,0:13:13.94,0:13:16.28,Main-207+,,0,0,0,,Ölüyorum sanki.
Dialogue: 0,0:13:17.48,0:13:19.95,Main-207+,,0,0,0,,O zamandan beri...
Dialogue: 0,0:13:29.50,0:13:31.71,Main-207+,,0,0,0,,böyle bir acı hissetmemiştim!
Dialogue: 0,0:13:37.59,0:13:39.21,Main-207+,,0,0,0,,Leziz!
Dialogue: 0,0:13:39.21,0:13:41.80,Main-207+,,0,0,0,,Tam doldum.
Dialogue: 0,0:13:48.97,0:13:52.64,Main-207+,,0,0,0,,Sizde iş var, bok çuvalları.
Dialogue: 0,0:13:52.64,0:13:57.32,Main-207+,,0,0,0,,Korsanlar Kralı olmayı hedefleyen\Ndangalaklardan daha azını beklemezdim.
Dialogue: 0,0:14:01.36,0:14:02.53,Main-207+,,0,0,0,,Ama...
Dialogue: 0,0:14:03.11,0:14:06.08,Main-207+,,0,0,0,,artık beni durduramazsınız!
Dialogue: 0,0:14:19.05,0:14:21.26,Main-207+,,0,0,0,,Çok yazık.
Dialogue: 0,0:14:21.26,0:14:25.26,Main-207+,,0,0,0,,Yakında öleceksiniz.
Dialogue: 0,0:14:35.77,0:14:40.44,Main-207+,,0,0,0,,Siz mevta olduğunuzda\Nneyiniz varsa benim olacak.
Dialogue: 0,0:14:40.44,0:14:45.70,Main-207+,,0,0,0,,Adadaki tayfanız da buna dahil.
Dialogue: 0,0:14:47.07,0:14:49.79,Main-207+,,0,0,0,,Çok beklersin!
Dialogue: 0,0:14:52.83,0:14:54.71,Main-207+,,0,0,0,,Sadece tayfalarınızı da değil,
Dialogue: 0,0:14:54.71,0:14:56.54,Main-207+,,0,0,0,,hazinelerinizi de alacağız.
Dialogue: 0,0:14:56.54,0:14:58.79,Main-207+,,0,0,0,,Ponegliflerinizi de.
Dialogue: 0,0:14:58.79,0:15:01.80,Main-207+,,0,0,0,,Sizde de var onlardan değil mi?
Dialogue: 0,0:15:01.80,0:15:03.38,Main-207+,,0,0,0,,Sabırsızlanıyorum.
Dialogue: 0,0:15:05.30,0:15:08.80,Main-207+,,0,0,0,,Asıl ben sizin\Ntayfa ve hazinelerinizi alacağım!
Dialogue: 0,0:15:12.18,0:15:16.23,Main-207+,,0,0,0,,Bu savaşın galibi\NKorsanlar Kralı olma yolunda...
Dialogue: 0,0:15:16.23,0:15:18.40,Main-207+,,0,0,0,,büyük bir adım atmış olacak.
Dialogue: 0,0:15:19.98,0:15:22.11,Main-207+,,0,0,0,,Korsanlar Kralı...
Dialogue: 0,0:15:22.61,0:15:25.15,Main-207+,,0,0,0,,ben olacağım!
Dialogue: 0,0:15:50.51,0:15:52.01,Main-207+,,0,0,0,,{\fad(150,150)}Yıkım Rüzgârı!
Dialogue: 0,0:16:13.33,0:16:14.16,Main-207+,,0,0,0,,Kid!
Dialogue: 0,0:16:16.46,0:16:18.37,Main-207+,,0,0,0,,Olan hurdalara oldu!
Dialogue: 0,0:16:22.71,0:16:24.88,Main-207+,,0,0,0,,Kaido!
Dialogue: 0,0:16:30.22,0:16:33.85,Main-207+,,0,0,0,,Ahmak Korsanlar Kralı adayları,
Dialogue: 0,0:16:33.85,0:16:36.81,Main-207+,,0,0,0,,eğlendirin beni!
Dialogue: 0,0:16:42.65,0:16:46.65,Main-207+,,0,0,0,,Wano'ya ben hükmedeceğim!
Dialogue: 0,0:16:51.37,0:16:54.70,Flashbacks-207+,,0,0,0,,Wano'ya...{Wano 55 Extended - 19:37}
Dialogue: 0,0:16:56.08,0:16:58.54,Flashbacks-207+,,0,0,0,,sahip çıkar mısın?
Dialogue: 0,0:17:16.72,0:17:20.52,Main-207+,,0,0,0,,{\fad(150,150)}Lastik-Lastik...
Dialogue: 0,0:17:20.52,0:17:22.02,Main-207+,,0,0,0,,{\fad(150,150)}Kong...
Dialogue: 0,0:17:22.90,0:17:25.65,Main-207+,,0,0,0,,{\fad(150,150)}Tüfeği!
Dialogue: 0,0:17:37.58,0:17:41.79,Main-207+,,0,0,0,,Öyle uykuya dalmak yok, Yonko bey!
Dialogue: 0,0:17:54.39,0:17:57.85,Main-207+,,0,0,0,,{\fad(150,150)}Gibson Çakışı!
Dialogue: 0,0:18:10.44,0:18:11.74,Main-207+,,0,0,0,,{\fad(150,150)}Oda!
Dialogue: 0,0:18:13.07,0:18:14.41,Main-207+,,0,0,0,,{\fad(150,150)}Değişim!
Dialogue: 0,0:18:20.70,0:18:23.58,Main-207+,,0,0,0,,Bir ejderhanın içini hiç incelememiştim...
Dialogue: 0,0:18:29.84,0:18:32.55,Main-207+,,0,0,0,,ama kalbin burada olsa gerek!
Dialogue: 0,0:18:34.18,0:18:35.76,Main-207+,,0,0,0,,{\fad(150,150)}Gama Bıçağı!
Dialogue: 0,0:18:43.27,0:18:46.06,Main-207+,,0,0,0,,Seni içten yok edeceğim!
Dialogue: 0,0:18:50.11,0:18:51.82,Main-207+,,0,0,0,,Amma can sıktınız!
Dialogue: 0,0:19:03.16,0:19:06.67,Main-207+,,0,0,0,,Vücudum ne denli dayanıklı öğrendiniz demek.
Dialogue: 0,0:19:06.67,0:19:10.84,Main-207+,,0,0,0,,Cahil cesaretiyle saldıran andavallardan\Ndeğilsiniz belli ki.
Dialogue: 0,0:19:12.71,0:19:15.38,Main-207+,,0,0,0,,Sert derisi sıktı artık!
Dialogue: 0,0:19:16.76,0:19:19.76,Main-207+,,0,0,0,,Gövdesini kesip biçsem yetmez mi?!
Dialogue: 0,0:19:26.77,0:19:28.48,Main-207+,,0,0,0,,{\fad(150,150)}Sonik...
Dialogue: 0,0:19:30.19,0:19:31.86,Main-207+,,0,0,0,,{\fad(150,150)}Tırpan!
Dialogue: 0,0:19:43.54,0:19:45.21,Main-207+,,0,0,0,,Biraz acıtmıştır herhâlde...
Dialogue: 0,0:19:47.67,0:19:49.13,Main-207+,,0,0,0,,Kaido!
Dialogue: 0,0:19:49.13,0:19:50.50,Main-207+,,0,0,0,,{\fad(150,150)}İndra!
Dialogue: 0,0:19:54.63,0:19:56.13,Main-207+,,0,0,0,,Killer!
Dialogue: 0,0:20:01.26,0:20:04.47,Main-207+,,0,0,0,,Bu göğün altında olduğunuz sürece...
Dialogue: 0,0:20:04.47,0:20:07.60,Main-207+,,0,0,0,,kaçacak yeriniz yok.
Dialogue: 0,0:20:08.52,0:20:14.44,Main-207+,,0,0,0,,Beklemediğim kadar eğleniyorum!
Dialogue: 0,0:20:14.74,0:20:17.78,Main-207+,,0,0,0,,{\fad(150,150)}Gergedan Obüsü!
Dialogue: 0,0:20:23.66,0:20:26.58,Main-207+,,0,0,0,,İyi saldırı!
Dialogue: 0,0:20:33.50,0:20:34.71,Main-207+,,0,0,0,,Trao...
Dialogue: 0,0:20:35.13,0:20:36.97,Main-207+,,0,0,0,,beni yukarı yolla!
Dialogue: 0,0:20:38.68,0:20:41.68,Main-207+,,0,0,0,,Emir veren verene...
Dialogue: 0,0:20:43.89,0:20:47.48,Main-207+,,0,0,0,,Ben sizin uşağınız değilim!
Dialogue: 0,0:20:48.14,0:20:49.98,Main-207+,,0,0,0,,{\fad(150,150)}Tilki Ateşi Stili...
Dialogue: 0,0:20:55.23,0:20:58.70,Main-207+,,0,0,0,,{\fad(150,150)}Patlayan Nefes!
Dialogue: 0,0:21:04.74,0:21:06.75,Main-207+,,0,0,0,,{\fad(150,150)}...Alev Yaran!
Dialogue: 0,0:21:12.67,0:21:13.88,Main-207+,,0,0,0,,Zoro!
Dialogue: 0,0:21:15.71,0:21:17.34,Main-207+,,0,0,0,,Bir kere daha!
Dialogue: 0,0:21:18.63,0:21:20.05,Main-207+,,0,0,0,,Trao!
Dialogue: 0,0:21:20.05,0:21:21.13,Main-207+,,0,0,0,,Heh?!
Dialogue: 0,0:21:21.13,0:21:25.14,Main-207+,,0,0,0,,Emir kulunuz yok karşınızda!
Dialogue: 0,0:21:33.31,0:21:34.52,Main-207+,,0,0,0,,O ne?
Dialogue: 0,0:21:36.02,0:21:37.73,Main-207+,,0,0,0,,Savuşturman gerek Kaido!
Dialogue: 0,0:21:38.11,0:21:41.36,Main-207+,,0,0,0,,Sıradan bir kılıç değil o!
Dialogue: 0,0:21:41.36,0:21:43.37,Main-207+,,0,0,0,,{\fad(150,150)}Tek Kılıç Stili:
Dialogue: 0,0:21:52.67,0:21:55.42,Main-207+,,0,0,0,,{\fad(150,150)}Uçan Ejder Alevi!
Dialogue: 0,0:22:06.81,0:22:09.52,Main-207+,,0,0,0,,Niye bunun kılıcından...
Dialogue: 0,0:22:09.52,0:22:12.69,Main-207+,,0,0,0,,Oden'in hissiyatını alıyorum?
Dialogue: 0,0:22:12.69,0:22:14.31,Main-207+,,0,0,0,,Ah lan!
Dialogue: 0,0:22:14.31,0:22:15.48,Main-207+,,0,0,0,,Iskaladım!
Dialogue: 0,0:22:15.48,0:22:18.36,Main-207+,,0,0,0,,Bizi çok hafife alıyorsunuz.
Dialogue: 0,0:22:18.36,0:22:20.28,Main-207+,,0,0,0,,{\fad(150,150)}İndra!
Dialogue: 0,0:22:26.74,0:22:28.29,Main-207+,,0,0,0,,Zoro!
Dialogue: 0,0:22:31.87,0:22:34.50,Main-207+,,0,0,0,,Kaçacak yeriniz yok.
Dialogue: 0,0:22:35.75,0:22:40.63,Main-207+,,0,0,0,,{\fad(150,150)}Yıldırım Tanrısı Tenjin!
Dialogue: 0,0:22:48.14,0:22:49.26,Main-207+,,0,0,0,,Ha siktir!
Dialogue: 0,0:22:49.26,0:22:51.06,Main-207+,,0,0,0,,Doğal afet mi?
Dialogue: 0,0:23:27.01,0:23:28.39,Main-207+,,0,0,0,,Hasır Şapka!
Dialogue: 0,0:23:28.39,0:23:31.89,Main-207+,,0,0,0,,Yıldırım sana neden işlemiyor lan?
Dialogue: 0,0:23:38.31,0:23:41.57,Main-207+,,0,0,0,,Lastiğim de ondan!
Dialogue: 0,0:23:45.07,0:23:47.78,Main-207+,,0,0,0,,Ne hakla Zoro ve diğerlerine zarar verirsin?
Dialogue: 0,0:23:50.49,0:23:52.37,Main-207+,,0,0,0,,{\fad(150,150)}Patlayan Nefes!
Dialogue: 0,0:24:23.53,0:24:26.90,Main-207+,,0,0,0,,Ateş de mi işe yaramıyor? Niye?
Dialogue: 0,0:24:30.20,0:24:32.33,Main-207+,,0,0,0,,Cesaretimden!
Dialogue: 0,0:24:34.29,0:24:36.87,Main-207+,,0,0,0,,{\fad(150,150)}Lastik-Lastik...
Dialogue: 0,0:24:41.38,0:24:43.13,Main-207+,,0,0,0,,{\fad(150,150)}Kong...
Dialogue: 0,0:24:47.09,0:24:51.01,Main-207+,,0,0,0,,{\fad(150,150)}Mitralyözü!
Comment: 0,0:00:00.00,0:00:00.00,Main-207+,,0,0,0,,{=3}===============================DIALOGUE============================
