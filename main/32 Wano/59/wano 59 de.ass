Comment: 0,0:00:00.00,0:00:00.00,Main-207+,,0,0,0,,{=116}===============================DIALOGUE============================
Dialogue: 0,0:01:32.28,0:01:33.66,Main-207+,,0,0,0,,Hä?! Ich fass es ja nicht!
Dialogue: 0,0:01:34.20,0:01:36.20,Main-207+,,0,0,0,,Die Orochi-Geheimagenten
Dialogue: 0,0:01:36.49,0:01:40.83,Main-207+,,0,0,0,,und Anführer der Mimawari-Samurai wurden\Nfast allesamt aus dem Verkehr gezogen.
Dialogue: 0,0:01:41.25,0:01:42.04,Main-207+,,0,0,0,,Daikoku!
Dialogue: 0,0:01:42.58,0:01:43.88,Main-207+,,0,0,0,,Meister Kazekage!
Dialogue: 0,0:01:43.88,0:01:45.79,Main-207+,,0,0,0,,Kommandant Hotei!
Dialogue: 0,0:01:49.34,0:01:52.38,Main-207+,,0,0,0,,Das ist also die Kraft des\Nlegendären Unterweltbosses.
Dialogue: 0,0:01:52.38,0:01:56.68,Main-207+,,0,0,0,,Er hat dem Eisoger standgehalten\Nund dazu noch seine Kraft benutzt.
Dialogue: 0,0:01:57.10,0:01:59.89,Main-207+,,0,0,0,,Nun verstehe ich ein wenig,\Nwieso er in Wano Kuni...
Dialogue: 0,0:02:01.23,0:02:03.19,Main-207+,,0,0,0,,so sehr gefürchtet war.
Dialogue: 0,0:02:11.11,0:02:12.95,Main-207+,,0,0,0,,Boss!
Dialogue: 0,0:02:15.16,0:02:17.41,Main-207+,,0,0,0,,Boss Hyogoro!
Dialogue: 0,0:02:19.99,0:02:22.83,Main-207+,,0,0,0,,Worauf wartest du, Yatappe?!
Dialogue: 0,0:02:26.08,0:02:28.34,Main-207+,,0,0,0,,Schlag mir den Kopf ab!
Dialogue: 0,0:02:28.88,0:02:31.63,Main-207+,,0,0,0,,Wenn ich mich in einen Oger verwandle...
Dialogue: 0,0:02:37.14,0:02:38.51,Main-207+,,0,0,0,,Das ist mir klar!
Dialogue: 0,0:02:38.51,0:02:40.31,Main-207+,,0,0,0,,Geben Sie mir noch einen Moment!
Dialogue: 0,0:02:40.31,0:02:42.14,Main-207+,,0,0,0,,Ich werde es tun!
Dialogue: 0,0:02:42.14,0:02:44.39,Main-207+,,0,0,0,,Ich werde es ganz sicher tun!
Dialogue: 0,0:02:46.65,0:02:48.27,Main-207+,,0,0,0,,Ich kann ihn gut verstehen.
Dialogue: 0,0:02:48.98,0:02:50.73,Main-207+,,0,0,0,,Schließlich war er immer...
Dialogue: 0,0:02:50.73,0:02:52.74,Main-207+,,0,0,0,,wie ein Vater für uns.
Dialogue: 0,0:02:58.20,0:03:00.95,Main-207+,,0,0,0,,Tsunagoro, zögere nicht und töte mich!
Dialogue: 0,0:03:01.99,0:03:04.58,Main-207+,,0,0,0,,Boss Hyogoro...
Dialogue: 0,0:03:04.58,0:03:06.46,Main-207+,,0,0,0,,Gleich werde ich wieder bei Ihnen sein.
Dialogue: 0,0:03:11.71,0:03:13.21,Main-207+,,0,0,0,,Omasa!
Dialogue: 0,0:03:13.21,0:03:14.72,Main-207+,,0,0,0,,Verdammter Mist!
Dialogue: 0,0:03:14.72,0:03:18.05,Main-207+,,0,0,0,,Schaffst du es noch rechtzeitig?! Tanuki!
Dialogue: 0,0:03:18.05,0:03:19.89,Main-207+,,0,0,0,,Ich stoße an meine Grenzen!
Dialogue: 0,0:03:19.89,0:03:21.64,Main-207+,,0,0,0,,Für mich gibt es keine Rettung!
Dialogue: 0,0:03:24.27,0:03:25.64,Main-207+,,0,0,0,,Jetzt tu es schon!
Dialogue: 0,0:03:26.14,0:03:27.90,Main-207+,,0,0,0,,Ich will euch nicht...
Dialogue: 0,0:03:28.52,0:03:30.27,Main-207+,,0,0,0,,Boss Omasa!
Dialogue: 0,0:03:32.36,0:03:36.11,Main-207+,,0,0,0,,Ich will euch nicht wehtun müssen!
Dialogue: 0,0:03:36.11,0:03:37.91,Main-207+,,0,0,0,,Tanuki!
Dialogue: 0,0:03:37.91,0:03:39.78,Main-207+,,0,0,0,,Ist das Heilmittel noch nicht fertig?!
Dialogue: 0,0:03:40.20,0:03:42.70,Main-207+,,0,0,0,,Dieser ganze Floor...
Dialogue: 0,0:03:43.37,0:03:44.62,Main-207+,,0,0,0,,und unsere Kameraden...
Dialogue: 0,0:03:45.25,0:03:47.96,Main-207+,,0,0,0,,werden wieder von der Eisogern zerfressen.
Dialogue: 0,0:03:52.13,0:03:53.67,Main-207+,,0,0,0,,All-Star Queen!
Dialogue: 0,0:03:54.01,0:03:56.67,Main-207+,,0,0,0,,All-Star Queen!
Dialogue: 0,0:03:57.09,0:04:02.43,Main-207+,,0,0,0,,Warum müssen wir als deine\NUntergebenen an diesem Virus krepieren?!
Dialogue: 0,0:04:08.10,0:04:11.36,Main-207+,,0,0,0,,Schnauze, ihr Schmeißfliegen!
Dialogue: 0,0:04:11.36,0:04:16.28,Main-207+,,0,0,0,,Ihr habt für mich längst\Nkeine Verwendung mehr!
Dialogue: 0,0:04:17.03,0:04:18.70,Main-207+,,0,0,0,,Hört gut zu!
Dialogue: 0,0:04:18.70,0:04:22.12,Main-207+,,0,0,0,,Da ihr ausgedient habt, seid ihr\Nnichts mehr als Abschaum!
Dialogue: 0,0:04:28.46,0:04:32.13,Main-207+,,0,0,0,,Der Eisoger ist mein Virus-Meisterwerk!
Dialogue: 0,0:04:32.13,0:04:36.17,Main-207+,,0,0,0,,Eigentlich hab ich ihn\Nsogar für euch erschaffen.
Dialogue: 0,0:04:36.59,0:04:38.76,Main-207+,,0,0,0,,Hey, Pleasures!
Dialogue: 0,0:04:38.76,0:04:43.89,Main-207+,,0,0,0,,Ihr habt bereits die Fähigkeit verloren,\Neuer Leben aufs Spiel zu setzen!
Dialogue: 0,0:04:43.89,0:04:47.06,Main-207+,,0,0,0,,Ihr seid nur noch\NKanonenfutter, das lachen kann!
Dialogue: 0,0:04:47.06,0:04:48.60,Main-207+,,0,0,0,,W-Wie fies!
Dialogue: 0,0:04:50.31,0:04:52.69,Main-207+,,0,0,0,,Hey, Waiters!
Dialogue: 0,0:04:52.69,0:04:56.86,Main-207+,,0,0,0,,{Ihr könnt warten, bis ihr schwarz werdet,\Naber ihr bekommt keine SMILE-Früchte! - CR}{Egal wie lange ihr wartet,\Nihr könnt keine SMILE-Früchte mehr kriegen! - Nikki}Egal wie lange ihr wartet,\Nihr kriegt keine SMILE-Früchte!{Nikki}
Dialogue: 0,0:04:56.86,0:05:00.28,Main-207+,,0,0,0,,Ihr habt die Chance verloren,\NKraft zu erlangen!
Dialogue: 0,0:05:00.28,0:05:03.24,Main-207+,,0,0,0,,Ihr seid die ewigen Waiters.
Dialogue: 0,0:05:03.24,0:05:06.37,Main-207+,,0,0,0,,Ihr seid buchstäblich zum Warten verdammt.
Dialogue: 0,0:05:06.37,0:05:12.12,Main-207+,,0,0,0,,{\q2}Ihr Taugenichtse könnt euch unserer erstklassigen\N100-Bestien-Piratenbande nur als nützlich erweisen,
Dialogue: 0,0:05:12.12,0:05:14.96,Main-207+,,0,0,0,,wenn ihr wenigstens zu Ogern werdet
Dialogue: 0,0:05:14.96,0:05:18.46,Main-207+,,0,0,0,,und kurz vor eurem Tod etwas Sinnvolles tut!
Dialogue: 0,0:05:19.22,0:05:22.26,Main-207+,,0,0,0,,Soll das heißen, dass du von uns\Nverlangst, dass wir sterben sollen?
Dialogue: 0,0:05:22.26,0:05:24.51,Main-207+,,0,0,0,,Ja, du hast es erfasst.
Dialogue: 0,0:05:26.39,0:05:29.52,Main-207+,,0,0,0,,Wir haben Fußsoldaten wie Sand am Meer.
Dialogue: 0,0:05:30.43,0:05:32.56,Main-207+,,0,0,0,,Wie fies! Wie kannst du so was sagen?!
Dialogue: 0,0:05:32.56,0:05:33.73,Main-207+,,0,0,0,,Das glaub ich nicht.
Dialogue: 0,0:05:33.73,0:05:35.82,Main-207+,,0,0,0,,Ihr hattet eure Chance.
Dialogue: 0,0:05:35.82,0:05:39.36,Main-207+,,0,0,0,,Die Antikörper hätten einige\Nvon euch retten können.
Dialogue: 0,0:05:44.66,0:05:47.58,Main-207+,,0,0,0,,So ein Mist! Ich werde sicher nicht sterben!
Dialogue: 0,0:05:47.58,0:05:51.58,Main-207+,,0,0,0,,Tötet jeden unserer Soldaten, der sich in\Neinen Eisoger verwandelt! Zeigt keine Gnade!
Dialogue: 0,0:05:54.33,0:05:56.00,Main-207+,,0,0,0,,Strengt euch mal an!
Dialogue: 0,0:05:56.00,0:05:58.84,Main-207+,,0,0,0,,Kämpft bis auf die Knochen, um zu überleben.
Dialogue: 0,0:05:59.34,0:06:02.59,Main-207+,,0,0,0,,Das Herrschaftsverhältnis unserer\NFeinde macht mich krank.
Dialogue: 0,0:06:02.59,0:06:04.22,Main-207+,,0,0,0,,Ja, kannst du laut sagen.
Dialogue: 0,0:06:04.55,0:06:06.47,Main-207+,,0,0,0,,Hey, ihr elenden Samurai!
Dialogue: 0,0:06:06.47,0:06:11.60,Main-207+,,0,0,0,,Ihr unterliegt vielleicht dem Gedanken,\Ndass ihr da drüben etwas beschützt,
Dialogue: 0,0:06:11.60,0:06:14.02,Main-207+,,0,0,0,,aber vergesst nicht,
Dialogue: 0,0:06:14.65,0:06:16.98,Main-207+,,0,0,0,,dass der Tanuki letztlich auch ein Pirat ist!
Dialogue: 0,0:06:18.11,0:06:19.61,Main-207+,,0,0,0,,Queen...
Dialogue: 0,0:06:19.61,0:06:23.57,Main-207+,,0,0,0,,Wer kann schon in kurzer Zeit\Nso viele Antikörper herstellen?
Dialogue: 0,0:06:25.70,0:06:26.91,Main-207+,,0,0,0,,Das ist unmöglich!
Dialogue: 0,0:06:26.91,0:06:32.46,Main-207+,,0,0,0,,Sicher hat er sich die Antikörper selbst\Nverabreicht und aus dem Staub gemacht.
Dialogue: 0,0:06:33.83,0:06:36.42,Main-207+,,0,0,0,,Wirf ihn nicht mit euch in einen Topf!
Dialogue: 0,0:06:37.59,0:06:39.42,Main-207+,,0,0,0,,Wie kannst du dir da so sicher sein?!
Dialogue: 0,0:06:39.42,0:06:42.09,Main-207+,,0,0,0,,Piraten sind immerhin Verräter.
Dialogue: 0,0:06:46.09,0:06:48.51,Main-207+,,0,0,0,,Boss Hyogoro!
Dialogue: 0,0:06:48.51,0:06:51.47,Main-207+,,0,0,0,,Irgendwann werde ich Ihnen {ver}folgen!
Dialogue: 0,0:06:53.85,0:06:56.40,Main-207+,,0,0,0,,Lass dir dabei aber bitte genug Zeit.
Dialogue: 0,0:07:02.19,0:07:04.53,Main-207+,,0,0,0,,– Boss!\N– Boss!
Dialogue: 0,0:07:09.41,0:07:11.12,Thoughts-207+,,0,0,0,,Lebt wohl!
Dialogue: 0,0:07:19.79,0:07:22.38,Main-207+,,0,0,0,,Stopp!
Dialogue: 0,0:07:33.02,0:07:35.81,Main-207+,,0,0,0,,Halt mich nicht auf, Tanuki!
Dialogue: 0,0:07:35.81,0:07:38.15,Main-207+,,0,0,0,,Ich habe keine andere Wahl.
Dialogue: 0,0:07:38.56,0:07:39.81,Main-207+,,0,0,0,,Warte bitte!
Dialogue: 0,0:07:39.81,0:07:41.48,Main-207+,,0,0,0,,Ich werde ihn sofort retten.
Dialogue: 0,0:07:42.94,0:07:45.11,Main-207+,,0,0,0,,Boss! Schluck es runter!
Dialogue: 0,0:07:50.03,0:07:52.49,Main-207+,,0,0,0,,Ein Glück! Ich bin nicht zu spät.
Dialogue: 0,0:07:54.04,0:07:56.25,Main-207+,,0,0,0,,B-Boss...
Dialogue: 0,0:08:00.25,0:08:02.75,Main-207+,,0,0,0,,Super! Es funktioniert!
Dialogue: 0,0:08:02.75,0:08:04.59,Main-207+,,0,0,0,,Sein Körper wird wieder warm!
Dialogue: 0,0:08:21.15,0:08:24.57,Main-207+,,0,0,0,,Boss Hyogoro, sind Sie in Ordnung?!
Dialogue: 0,0:08:25.36,0:08:26.82,Main-207+,,0,0,0,,Ja...
Dialogue: 0,0:08:31.49,0:08:32.62,Main-207+,,0,0,0,,Es hat geklappt!
Dialogue: 0,0:08:32.62,0:08:34.95,Main-207+,,0,0,0,,Ich hab fest an dich geglaubt, Tanuki!
Dialogue: 0,0:08:36.75,0:08:39.37,Main-207+,,0,0,0,,Miyagi! Tristan! Beeilt euch!
Dialogue: 0,0:08:41.13,0:08:43.29,Main-207+,,0,0,0,,Jawohl, Dr. Chopper!
Dialogue: 0,0:08:44.42,0:08:45.84,Main-207+,,0,0,0,,Das ist doch...
Dialogue: 0,0:08:50.34,0:08:53.01,Main-207+,,0,0,0,,Vorbereitungen abgeschlossen, Dr. Chopper!
Dialogue: 0,0:08:53.01,0:08:55.47,Main-207+,,0,0,0,,Okay, dann mal los!
Dialogue: 0,0:08:59.35,0:09:01.98,Main-207+,,0,0,0,,Dr. Chopper! Gib den Befehl!
Dialogue: 0,0:09:01.98,0:09:03.27,Main-207+,,0,0,0,,– Eine Kanone?!\N– Eine Kanone?!
Dialogue: 0,0:09:04.15,0:09:06.69,Main-207+,,0,0,0,,{\fad(150,150)}Chopperphage...
Dialogue: 0,0:09:06.69,0:09:08.99,Main-207+,,0,0,0,,{\fad(150,192)}Nebulizer!
Dialogue: 0,0:09:10.74,0:09:12.78,Main-207+,,0,0,0,,Feuer frei!
Dialogue: 0,0:09:31.55,0:09:35.10,Main-207+,,0,0,0,,Leute! Atmet den Nebel ein!
Dialogue: 0,0:09:36.76,0:09:41.06,Main-207+,,0,0,0,,Was fällt dir eigentlich ein, Tanuki?!
Dialogue: 0,0:09:43.02,0:09:48.65,Main-207+,,0,0,0,,Was zum Geier hast du mit\Nmeinem Meisterwerk gemacht?!
Dialogue: 0,0:09:51.40,0:09:57.49,Main-207+,,0,0,0,,{\q2}Es wäre unmöglich gewesen, Tausenden von Soldaten auf\Ndiesem Floor das Heilmittel individuell zu verabreichen!
Dialogue: 0,0:09:57.91,0:10:02.00,Main-207+,,0,0,0,,Deshalb hab ich die Antikörper als Basis\Ngenommen und mein eigenes Virus erstellt!
Dialogue: 0,0:10:02.41,0:10:03.79,Main-207+,,0,0,0,,Wie bitte?!
Dialogue: 0,0:10:04.13,0:10:07.17,Main-207+,,0,0,0,,Ein schlechter Virus kann durch\Neinen guten Virus besiegt werden!
Dialogue: 0,0:10:07.80,0:10:13.26,Main-207+,,0,0,0,,Auf diese Weise kann jeder das Heilmittel\Ndurch Einatmen des Nebels zu sich nehmen!
Dialogue: 0,0:10:15.18,0:10:18.76,Main-207+,,0,0,0,,Du bist nur ein Arzt auf einer\NNussschale von einem Piratenschiff.
Dialogue: 0,0:10:18.76,0:10:21.56,Main-207+,,0,0,0,,Wo hast du dir solche Techniken angeeignet?
Dialogue: 0,0:10:21.56,0:10:24.85,Main-207+,,0,0,0,,Wir wurden über die ganze Welt verstreut\Nund haben uns selbst ausgebildet.
Dialogue: 0,0:10:24.85,0:10:29.40,Main-207+,,0,0,0,,Sogar meine Untergebenen\Nsind die Eisoger losgeworden.
Dialogue: 0,0:10:29.40,0:10:31.65,Main-207+,,0,0,0,,Das hättest du dir sparen können.
Dialogue: 0,0:10:32.95,0:10:36.74,Main-207+,,0,0,0,,Ein Virus darf nicht einfach\Nim Kampf eingesetzt werden!
Dialogue: 0,0:10:36.74,0:10:39.54,Main-207+,,0,0,0,,Irgendwann geht so was\Nimmer nach hinten los!
Dialogue: 0,0:10:44.00,0:10:48.09,Main-207+,,0,0,0,,Ich muss mich sicher nicht von einem\NTanuki über Ethik belehren lassen.
Dialogue: 0,0:10:48.09,0:10:50.75,Main-207+,,0,0,0,,Für wen zum Teufel hältst du mich?!
Dialogue: 0,0:11:01.22,0:11:02.93,Main-207+,,0,0,0,,Pleasures?!
Dialogue: 0,0:11:04.48,0:11:05.48,Main-207+,,0,0,0,,Warum habt ihr das getan?!
Dialogue: 0,0:11:08.06,0:11:10.11,Main-207+,,0,0,0,,Was soll der Scheiß?!
Dialogue: 0,0:11:10.11,0:11:12.69,Main-207+,,0,0,0,,Verschwindet von dort, ihr Schmeißfliegen!
Dialogue: 0,0:11:12.69,0:11:14.49,Main-207+,,0,0,0,,Halt die Schnauze, Queen!
Dialogue: 0,0:11:15.45,0:11:18.87,Main-207+,,0,0,0,,Du wolltest unsere Waffenbrüder töten,
Dialogue: 0,0:11:18.87,0:11:21.70,Main-207+,,0,0,0,,aber dieser Tanuki hat\Nihnen das Leben gerettet.
Dialogue: 0,0:11:22.70,0:11:26.79,Main-207+,,0,0,0,,Anstatt durch einen verrückten\NVorgesetzten zu sterben,
Dialogue: 0,0:11:26.79,0:11:29.96,Main-207+,,0,0,0,,beißen wir lieber an der Seite\Nunseres Lebensretters ins Gras!
Dialogue: 0,0:11:29.96,0:11:32.46,Main-207+,,0,0,0,,Nicht wahr, Jungs?!
Dialogue: 0,0:11:35.59,0:11:37.43,Main-207+,,0,0,0,,Danke, Tanuki!
Dialogue: 0,0:11:37.43,0:11:38.93,Main-207+,,0,0,0,,{\pos(1452,1053)}Tanuki!
Dialogue: 0,0:11:39.30,0:11:40.72,Main-207+,,0,0,0,,{\pos(470,1053)}Tanuki!
Dialogue: 0,0:11:40.72,0:11:42.68,Main-207+,,0,0,0,,{\pos(1452,1053)}Tanuki!
Dialogue: 0,0:11:42.68,0:11:45.73,Main-207+,,0,0,0,,{\pos(470,1053)}Ich stehe in\Ndeiner Schuld, Tanuki!
Dialogue: 0,0:11:46.10,0:11:48.19,Main-207+,,0,0,0,,{\pos(1452,1053)}Tanuki, hab vielen Dank!
Dialogue: 0,0:11:48.19,0:11:51.52,Main-207+,,0,0,0,,{\pos(470,1053)}Für einen Tanuki hast\Ndu es echt drauf.
Dialogue: 0,0:11:51.86,0:12:01.45,Main-207+,,0,0,0,,– Tanuki! Tanuki! Tanuki! Tanuki!\N– Tanuki! Tanuki! Tanuki! Tanuki!
Dialogue: 0,0:11:51.86,0:12:01.45,Main-207+,,0,0,0,,{\an8}– Tanuki! Tanuki! Tanuki! Tanuki!\N– Tanuki! Tanuki! Tanuki! Tanuki!
Dialogue: 0,0:12:01.45,0:12:03.79,Main-207+,,0,0,0,,Fahr zur Hölle, Queen!
Dialogue: 0,0:12:08.00,0:12:10.58,Main-207+,,0,0,0,,Ihr miesen Arschlöcher!
Dialogue: 0,0:12:13.46,0:12:16.13,Main-207+,,0,0,0,,Was zum Henker ist das?
Dialogue: 0,0:12:16.55,0:12:18.51,Main-207+,,0,0,0,,Reife Leistung, Tanuki!
Dialogue: 0,0:12:20.01,0:12:21.30,Main-207+,,0,0,0,,Mach es!
Dialogue: 0,0:12:21.68,0:12:23.56,Main-207+,,0,0,0,,Danke, Marco!
Dialogue: 0,0:12:23.56,0:12:25.98,Main-207+,,0,0,0,,Da wäre noch eine Sache,\Ndie ich sagen möchte!
Dialogue: 0,0:12:25.98,0:12:29.02,Main-207+,,0,0,0,,Tanuki!
Dialogue: 0,0:12:29.77,0:12:30.98,Main-207+,,0,0,0,,{\fad(150,313)}Rumble!
Dialogue: 0,0:12:31.52,0:12:33.86,Main-207+,,0,0,0,,{\fad(150,150)}Monster Point!
Dialogue: 0,0:12:34.65,0:12:37.28,Main-207+,,0,0,0,,{Go! - OG}– Zum Angriff!\N– Zum Angriff!
Dialogue: 0,0:12:36.03,0:12:37.28,Secondary-207+,,0,0,0,,{[/an8]You got this! - Polly}{\an8}Mach ihn platt!{Nikki}
Dialogue: 0,0:12:38.07,0:12:39.03,Main-207+,,0,0,0,,Was?!
Dialogue: 0,0:12:40.74,0:12:44.08,Main-207+,,0,0,0,,Ich bin kein Tanuki!
Comment: 0,0:12:40.74,0:12:50.08,Main-207+,,0,0,0,,{=73}Ich bin kein Tanuki!{TS by FiberAhmed}
