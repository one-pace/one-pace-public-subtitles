Comment: 0,0:00:00.00,0:00:00.00,Main-207+,,0,0,0,,{=106}===============================DIALOGUE============================
Dialogue: 0,0:01:32.28,0:01:33.66,Main-207+,,0,0,0,,Olacak iş değil!
Dialogue: 0,0:01:34.20,0:01:36.20,Main-207+,,0,0,0,,Oniwabanshu...
Dialogue: 0,0:01:36.49,0:01:38.66,Main-207+,,0,0,0,,ve Mimawari-gumi komutanlarının çoğu...
Dialogue: 0,0:01:38.66,0:01:40.83,Main-207+,,0,0,0,,yerde yatıyor!
Dialogue: 0,0:01:41.25,0:01:42.04,Main-207+,,0,0,0,,Daikoku-{\i1}san{\i0}!
Dialogue: 0,0:01:42.58,0:01:43.88,Main-207+,,0,0,0,,Kazekage-{\i1}sama{\i0}!
Dialogue: 0,0:01:43.88,0:01:45.79,Main-207+,,0,0,0,,Komutan Hotei!
Dialogue: 0,0:01:49.34,0:01:52.38,Main-207+,,0,0,0,,Efsanevi yakuza liderinin gücü mü bu?
Dialogue: 0,0:01:52.38,0:01:56.68,Main-207+,,0,0,0,,Buz şeytanına dönüşmeye karşı koyup\Nbunu lehine kullandı!
Dialogue: 0,0:01:57.10,0:01:59.89,Main-207+,,0,0,0,,Neden dünyanın Wano'dan bu kadar korktuğunu...
Dialogue: 0,0:02:01.23,0:02:03.19,Main-207+,,0,0,0,,şimdi daha iyi anladım.
Dialogue: 0,0:02:11.11,0:02:12.95,Main-207+,,0,0,0,,Patron!
Dialogue: 0,0:02:15.16,0:02:17.41,Main-207+,,0,0,0,,Patron Hyogoro!
Dialogue: 0,0:02:19.99,0:02:22.83,Main-207+,,0,0,0,,Neyi bekliyorsun, Yatappe?
Dialogue: 0,0:02:26.08,0:02:28.34,Main-207+,,0,0,0,,Zihnini boşalt!
Dialogue: 0,0:02:28.88,0:02:31.63,Main-207+,,0,0,0,,Buz şeytanına dönüşürsem...
Dialogue: 0,0:02:37.14,0:02:38.51,Main-207+,,0,0,0,,Biliyorum!
Dialogue: 0,0:02:38.51,0:02:40.31,Main-207+,,0,0,0,,Bana az süre tanıyın!
Dialogue: 0,0:02:40.31,0:02:42.14,Main-207+,,0,0,0,,Yapacağım,
Dialogue: 0,0:02:42.14,0:02:44.39,Main-207+,,0,0,0,,birazdan yapacağım!
Dialogue: 0,0:02:46.65,0:02:48.27,Main-207+,,0,0,0,,Zorlanmakta haklı.
Dialogue: 0,0:02:48.98,0:02:50.73,Main-207+,,0,0,0,,Siz bizim...
Dialogue: 0,0:02:50.73,0:02:52.74,Main-207+,,0,0,0,,babamız sayılırsınız.
Dialogue: 0,0:02:58.20,0:03:00.95,Main-207+,,0,0,0,,Tsunagoro, tereddüte düşmeden kes beni!
Dialogue: 0,0:03:01.99,0:03:04.58,Main-207+,,0,0,0,,Patron Hyogoro...
Dialogue: 0,0:03:04.58,0:03:06.46,Main-207+,,0,0,0,,ben de peşinizden geliyorum!
Dialogue: 0,0:03:11.71,0:03:13.21,Main-207+,,0,0,0,,Omasa!
Dialogue: 0,0:03:13.21,0:03:14.72,Main-207+,,0,0,0,,Kahretsin!
Dialogue: 0,0:03:14.72,0:03:18.05,Main-207+,,0,0,0,,Nerede kaldınız, Tanuki-{\i1}san{\i0}?!
Dialogue: 0,0:03:18.05,0:03:19.89,Main-207+,,0,0,0,,Benim de artık takatım kalmadı!
Dialogue: 0,0:03:19.89,0:03:21.64,Main-207+,,0,0,0,,Yolun sonuna geldim.
Dialogue: 0,0:03:24.27,0:03:25.64,Main-207+,,0,0,0,,Çabuk yap!
Dialogue: 0,0:03:26.14,0:03:27.90,Main-207+,,0,0,0,,Sizi...
Dialogue: 0,0:03:28.52,0:03:30.27,Main-207+,,0,0,0,,Sefir Omasa!
Dialogue: 0,0:03:32.36,0:03:36.11,Main-207+,,0,0,0,,Sizi incitmek istemiyorum!
Dialogue: 0,0:03:36.11,0:03:37.91,Main-207+,,0,0,0,,Tanuki-{\i1}san{\i0}!
Dialogue: 0,0:03:37.91,0:03:39.78,Main-207+,,0,0,0,,Daha ilacı bitiremediniz mi?
Dialogue: 0,0:03:40.20,0:03:42.70,Main-207+,,0,0,0,,Yine bu kat...
Dialogue: 0,0:03:43.37,0:03:44.62,Main-207+,,0,0,0,,ve dostlarımız...
Dialogue: 0,0:03:45.25,0:03:47.96,Main-207+,,0,0,0,,buz şeytanının esiri olacak!
Dialogue: 0,0:03:52.13,0:03:53.67,Main-207+,,0,0,0,,Queen-{\i1}sama{\i0}!
Dialogue: 0,0:03:54.01,0:03:56.67,Main-207+,,0,0,0,,Queen-{\i1}sama{\i0}!
Dialogue: 0,0:03:57.09,0:04:02.43,Main-207+,,0,0,0,,Sizin için çalışıyoruz be...\NNiye biz de virüsünüzden ölmek zorundayız?
Dialogue: 0,0:04:08.10,0:04:11.36,Main-207+,,0,0,0,,Kesin sesinizi ezikler!
Dialogue: 0,0:04:11.36,0:04:16.28,Main-207+,,0,0,0,,Artık sizden bir cacık olmaz.
Dialogue: 0,0:04:17.03,0:04:18.70,Main-207+,,0,0,0,,Dinleyin!
Dialogue: 0,0:04:18.70,0:04:22.12,Main-207+,,0,0,0,,Hiçbir işe yaramazsanız çöpsünüz demektir.
Dialogue: 0,0:04:28.46,0:04:32.13,Main-207+,,0,0,0,,Buz şeytanı virüsü benim şaheserim!
Dialogue: 0,0:04:32.13,0:04:36.17,Main-207+,,0,0,0,,Bir nevi sizin için yapıldı.
Dialogue: 0,0:04:36.59,0:04:38.76,Main-207+,,0,0,0,,Hey, Hazcılar!
Dialogue: 0,0:04:38.76,0:04:43.89,Main-207+,,0,0,0,,Siz çoktan yetenek bahsini kaybettiniz.
Dialogue: 0,0:04:43.89,0:04:47.06,Main-207+,,0,0,0,,Gülmekten başka bir şey yapmayan\Noksijen israflarısınız.
Dialogue: 0,0:04:47.06,0:04:48.60,Main-207+,,0,0,0,,A-Ağır oluyor!
Dialogue: 0,0:04:50.31,0:04:52.69,Main-207+,,0,0,0,,Hey, Fırsatçılar!
Dialogue: 0,0:04:52.69,0:04:56.86,Main-207+,,0,0,0,,Sonsuza dek bekleseniz de\Nyeni Gülücükler gelmeyecek!
Dialogue: 0,0:04:56.86,0:05:00.28,Main-207+,,0,0,0,,Yani, yetenek kazanma şansınızı kaybettiniz!
Dialogue: 0,0:05:00.28,0:05:03.24,Main-207+,,0,0,0,,Ebediyen Fırsatçılar.
Dialogue: 0,0:05:03.24,0:05:06.37,Main-207+,,0,0,0,,Adı üstünde tek işiniz beklemek.
Dialogue: 0,0:05:06.37,0:05:12.12,Main-207+,,0,0,0,,Siz avellerin Canavar Korsanları'na\Nkatkı sağlayabilmesinin tek yolu...
Dialogue: 0,0:05:12.12,0:05:14.96,Main-207+,,0,0,0,,buz şeytanına dönüşerek...
Dialogue: 0,0:05:14.96,0:05:18.46,Main-207+,,0,0,0,,giderayak bir işe yaraması!
Dialogue: 0,0:05:19.22,0:05:22.26,Main-207+,,0,0,0,,Sanki bize öl diyorsunuz.
Dialogue: 0,0:05:22.26,0:05:24.51,Main-207+,,0,0,0,,Evet, diyorum.
Dialogue: 0,0:05:26.39,0:05:29.52,Main-207+,,0,0,0,,Denizde kum, bizde adam.
Dialogue: 0,0:05:30.43,0:05:32.56,Main-207+,,0,0,0,,Ayıp ama, böyle söylenir mi?
Dialogue: 0,0:05:32.56,0:05:33.73,Main-207+,,0,0,0,,Olamaz...
Dialogue: 0,0:05:33.73,0:05:35.82,Main-207+,,0,0,0,,Size bir şans verdim!
Dialogue: 0,0:05:35.82,0:05:39.36,Main-207+,,0,0,0,,Antikor birkaçınız kurtarabilir!
Dialogue: 0,0:05:44.66,0:05:47.58,Main-207+,,0,0,0,,Sikeyim! Ölecek değilim!
Dialogue: 0,0:05:47.58,0:05:51.58,Main-207+,,0,0,0,,Dönüşen siper arkadaşlarınız olsun,\Nsamuraylar olsun, alayını kesin!
Dialogue: 0,0:05:54.33,0:05:56.00,Main-207+,,0,0,0,,Kim tutar sizi?
Dialogue: 0,0:05:56.00,0:05:58.84,Main-207+,,0,0,0,,Hayatta kalmak için götünüzü yırtın!
Dialogue: 0,0:05:59.34,0:06:02.59,Main-207+,,0,0,0,,Karşı tarafın ast üst ilişkisi şahane.
Dialogue: 0,0:06:02.59,0:06:04.22,Main-207+,,0,0,0,,Evet, hem de nasıl.
Dialogue: 0,0:06:04.55,0:06:06.47,Main-207+,,0,0,0,,Siz oradaki samuraylar,
Dialogue: 0,0:06:06.47,0:06:11.60,Main-207+,,0,0,0,,korumalık yapmak iyi hoş da...
Dialogue: 0,0:06:11.60,0:06:14.02,Main-207+,,0,0,0,,o tanuki...
Dialogue: 0,0:06:14.65,0:06:16.98,Main-207+,,0,0,0,,bir korsan.
Dialogue: 0,0:06:18.11,0:06:19.61,Main-207+,,0,0,0,,Queen...
Dialogue: 0,0:06:19.61,0:06:23.57,Main-207+,,0,0,0,,Kısacık sürede tonla antikor mu üretecek?
Dialogue: 0,0:06:25.70,0:06:26.91,Main-207+,,0,0,0,,İmkânı yok!
Dialogue: 0,0:06:26.91,0:06:32.46,Main-207+,,0,0,0,,Antikoru kendine enjekte edip\Ntüymemişse bir şey bilmiyorum!
Dialogue: 0,0:06:33.83,0:06:36.42,Main-207+,,0,0,0,,Size benzemez o!
Dialogue: 0,0:06:37.59,0:06:39.42,Main-207+,,0,0,0,,Öyle mi?
Dialogue: 0,0:06:39.42,0:06:42.09,Main-207+,,0,0,0,,Korsanların işi arkadan vurmaktır.
Dialogue: 0,0:06:46.09,0:06:48.51,Main-207+,,0,0,0,,Patron Hyogoro!
Dialogue: 0,0:06:48.51,0:06:51.47,Main-207+,,0,0,0,,Ben de yakında size katılacağım!
Dialogue: 0,0:06:53.85,0:06:56.40,Main-207+,,0,0,0,,Vaden dolunca katılırsın.
Dialogue: 0,0:07:02.19,0:07:04.53,Main-207+,,0,0,0,,– Patron!\N– Patron!
Dialogue: 0,0:07:09.41,0:07:11.12,Thoughts-207+,,0,0,0,,Elveda...
Dialogue: 0,0:07:19.79,0:07:22.38,Main-207+,,0,0,0,,Bekle!
Dialogue: 0,0:07:33.02,0:07:35.81,Main-207+,,0,0,0,,Durdurmayın beni, Tanuki-{\i1}san{\i0}!
Dialogue: 0,0:07:35.81,0:07:38.15,Main-207+,,0,0,0,,Bunu yapmak lazım.
Dialogue: 0,0:07:38.56,0:07:39.81,Main-207+,,0,0,0,,Bekle biraz,
Dialogue: 0,0:07:39.81,0:07:41.48,Main-207+,,0,0,0,,şimdi onu kurtaracağım.
Dialogue: 0,0:07:42.94,0:07:45.11,Main-207+,,0,0,0,,Patron, yut onu.
Dialogue: 0,0:07:50.03,0:07:52.49,Main-207+,,0,0,0,,Şükür yetiştim.
Dialogue: 0,0:07:54.04,0:07:56.25,Main-207+,,0,0,0,,P-Patron...
Dialogue: 0,0:08:00.25,0:08:02.75,Main-207+,,0,0,0,,Harika, işe yaradı!
Dialogue: 0,0:08:02.75,0:08:04.59,Main-207+,,0,0,0,,Vücudun yanması normal.
Dialogue: 0,0:08:21.15,0:08:22.98,Main-207+,,0,0,0,,Patron Hyogoro!
Dialogue: 0,0:08:22.98,0:08:24.57,Main-207+,,0,0,0,,İyi misiniz?!
Dialogue: 0,0:08:25.36,0:08:26.82,Main-207+,,0,0,0,,Evet...
Dialogue: 0,0:08:31.49,0:08:32.62,Main-207+,,0,0,0,,İşe yaradı!
Dialogue: 0,0:08:32.62,0:08:34.95,Main-207+,,0,0,0,,Tanuki-{\i1}san{\i0}, size güvenim tamdı!
Dialogue: 0,0:08:36.75,0:08:39.37,Main-207+,,0,0,0,,Miyagi, Tristan, acele edin!
Dialogue: 0,0:08:41.13,0:08:43.29,Main-207+,,0,0,0,,Peki, Dr. Chopper!
Dialogue: 0,0:08:44.42,0:08:45.84,Main-207+,,0,0,0,,Bu...
Dialogue: 0,0:08:50.34,0:08:53.01,Main-207+,,0,0,0,,Her şey hazır, Dr. Chopper!
Dialogue: 0,0:08:53.01,0:08:55.47,Main-207+,,0,0,0,,Pekâlâ, hadi yapalım!
Dialogue: 0,0:08:59.35,0:09:01.98,Main-207+,,0,0,0,,Dr. Chopper, emrinizi bekliyoruz!
Dialogue: 0,0:09:01.98,0:09:03.27,Main-207+,,0,0,0,,– Top mu?!\N– Top mu?!
Dialogue: 0,0:09:04.15,0:09:06.69,Main-207+,,0,0,0,,{\fad(150,150)}Chopper'ın Faj...
Dialogue: 0,0:09:06.69,0:09:08.99,Main-207+,,0,0,0,,{\fad(150,192)}Nebulizatörü!
Dialogue: 0,0:09:10.74,0:09:12.78,Main-207+,,0,0,0,,Ateş!
Dialogue: 0,0:09:31.55,0:09:35.10,Main-207+,,0,0,0,,Herkes sisi içine çeksin!
Dialogue: 0,0:09:36.76,0:09:41.06,Main-207+,,0,0,0,,Ne yaptığını sanıyorsun, tanuki?!
Dialogue: 0,0:09:43.02,0:09:48.65,Main-207+,,0,0,0,,Şaheserime ne yaptın öyle?
Dialogue: 0,0:09:51.40,0:09:57.49,Main-207+,,0,0,0,,Kattaki sürüyle savaşçıya\Nilacı teker teker vermenin olanağı yok!
Dialogue: 0,0:09:57.91,0:10:02.00,Main-207+,,0,0,0,,Ben de antikordan kendi virüsümü yarattım!
Dialogue: 0,0:10:02.41,0:10:03.79,Main-207+,,0,0,0,,Ne dedin?
Dialogue: 0,0:10:04.13,0:10:07.17,Main-207+,,0,0,0,,İyi bir virüs, kötü bir virüsü yenebilir!
Dialogue: 0,0:10:07.80,0:10:13.26,Main-207+,,0,0,0,,Bu yolla herkes sisi soluyarak ilacı alabilir!
Dialogue: 0,0:10:15.18,0:10:18.76,Main-207+,,0,0,0,,Senin gibi ufacık bir korsan tayfasının doktoru...
Dialogue: 0,0:10:18.76,0:10:21.56,Main-207+,,0,0,0,,böyle becerileri nereden edindi?
Dialogue: 0,0:10:21.56,0:10:24.85,Main-207+,,0,0,0,,Biz dünyanın dört bir yanına dağılıp\Nkendimizi eğittik!
Dialogue: 0,0:10:24.85,0:10:29.40,Main-207+,,0,0,0,,Benim adamlarımı bile virüsten kurtardın!
Dialogue: 0,0:10:29.40,0:10:31.65,Main-207+,,0,0,0,,Üstüne vazife mi?
Dialogue: 0,0:10:32.95,0:10:36.74,Main-207+,,0,0,0,,Virüsler savaşta kullanılmaz!
Dialogue: 0,0:10:36.74,0:10:39.54,Main-207+,,0,0,0,,İşler kontrolden çıkar!
Dialogue: 0,0:10:44.00,0:10:48.09,Main-207+,,0,0,0,,Bir tanukiden etik dersi alacak değilim!
Dialogue: 0,0:10:48.09,0:10:50.75,Main-207+,,0,0,0,,Karşında kim var sanıyorsun?
Comment: 0,0:10:59.22,0:11:00.06,Main-207+,,0,0,0,,Ne?!
Dialogue: 0,0:11:01.22,0:11:02.93,Main-207+,,0,0,0,,Hazcılar?!
Dialogue: 0,0:11:04.48,0:11:05.48,Main-207+,,0,0,0,,Neden?
Dialogue: 0,0:11:08.06,0:11:10.11,Main-207+,,0,0,0,,N'apıyorsunuz lan siz?
Dialogue: 0,0:11:10.11,0:11:12.69,Main-207+,,0,0,0,,Çekilin önümden ezik sürüsü!
Dialogue: 0,0:11:12.69,0:11:14.49,Main-207+,,0,0,0,,Kapa çeneni, Queen!
Dialogue: 0,0:11:15.45,0:11:18.87,Main-207+,,0,0,0,,Tanuki-{\i1}san{\i0} kurtarmasaydı...
Dialogue: 0,0:11:18.87,0:11:21.70,Main-207+,,0,0,0,,kardeşlerimiz ölüyordu!
Dialogue: 0,0:11:22.70,0:11:26.79,Main-207+,,0,0,0,,Bir manyağın emrinde ölmektense...
Dialogue: 0,0:11:26.79,0:11:29.96,Main-207+,,0,0,0,,bizi kurtaranın yanında ölürüz!
Dialogue: 0,0:11:29.96,0:11:32.46,Main-207+,,0,0,0,,Değil mi, beyler?
Dialogue: 0,0:11:35.59,0:11:37.43,Main-207+,,0,0,0,,Sağ ol, tanuki!
Dialogue: 0,0:11:37.43,0:11:38.93,Main-207+,,0,0,0,,{\pos(1452,1053)}Tanuki!
Dialogue: 0,0:11:39.30,0:11:40.72,Main-207+,,0,0,0,,{\pos(470,1053)}Tanuki!
Dialogue: 0,0:11:40.72,0:11:42.68,Main-207+,,0,0,0,,{\pos(1452,1053)}Tanuki!
Dialogue: 0,0:11:42.68,0:11:45.73,Main-207+,,0,0,0,,{\pos(470,1053)}Size bir can borcumuz var,\NTanuki-{\i1}san{\i0}!
Dialogue: 0,0:11:46.10,0:11:48.19,Main-207+,,0,0,0,,{\pos(1452,1053)}Tanuki-{\i1}san{\i0}, teşekkür ederim!
Dialogue: 0,0:11:48.19,0:11:51.52,Main-207+,,0,0,0,,{\pos(470,1053)}Etkileyici birisin, tanuki.
Dialogue: 0,0:11:51.86,0:12:01.45,Main-207+,,0,0,0,,– Tanuki! Tanuki! Tanuki! Tanuki!\N– Tanuki! Tanuki! Tanuki! Tanuki!
Dialogue: 0,0:11:51.86,0:12:01.45,Main-207+,,0,0,0,,{\an8}– Tanuki! Tanuki! Tanuki! Tanuki!\N– Tanuki! Tanuki! Tanuki! Tanuki!
Dialogue: 0,0:12:01.45,0:12:03.79,Main-207+,,0,0,0,,Geber, Queen!
Dialogue: 0,0:12:08.00,0:12:10.58,Main-207+,,0,0,0,,Mallar!
Dialogue: 0,0:12:13.46,0:12:16.13,Main-207+,,0,0,0,,Bu ne ulan?
Dialogue: 0,0:12:16.55,0:12:18.51,Main-207+,,0,0,0,,Aferin sana, tanuki.
Dialogue: 0,0:12:20.01,0:12:21.30,Main-207+,,0,0,0,,Sana saldım.
Dialogue: 0,0:12:21.68,0:12:23.56,Main-207+,,0,0,0,,Sağ ol, Marco.
Dialogue: 0,0:12:23.56,0:12:25.98,Main-207+,,0,0,0,,Demek istediğim bir şey daha var.
Dialogue: 0,0:12:25.98,0:12:29.02,Main-207+,,0,0,0,,Tanuki!
Dialogue: 0,0:12:29.77,0:12:30.98,Main-207+,,0,0,0,,{\fad(150,313)}Gümbürtü!
Dialogue: 0,0:12:31.52,0:12:33.86,Main-207+,,0,0,0,,{\fad(150,150)}Canavar Noktası!
Dialogue: 0,0:12:34.65,0:12:37.28,Main-207+,,0,0,0,,– Hakla onu!\N– Hakla onu!
Dialogue: 0,0:12:36.03,0:12:37.28,Secondary-207+,,0,0,0,,{\an8}Yaparsın!
Dialogue: 0,0:12:38.07,0:12:39.03,Main-207+,,0,0,0,,Ne?!
Dialogue: 0,0:12:40.74,0:12:44.08,Main-207+,,0,0,0,,Ben tanuki değilim!
Comment: 0,0:12:40.74,0:12:50.08,Main-207+,,0,0,0,,{=73}I'm not a tanuki!{TS by FiberAhmed}
