Dialogue: 0,0:12:53.38,0:12:56.96,Main-207+,,0,0,0,,Kalenin her katında\Ngeniş bir tavan arası var.
Dialogue: 0,0:12:56.96,0:12:58.59,Main-207+,,0,0,0,,Kimse bizi orada göremez!
Dialogue: 0,0:12:58.59,0:12:59.80,Main-207+,,0,0,0,,Tamam!
Dialogue: 0,0:12:59.80,0:13:03.18,Main-207+,,0,0,0,,Momonosuke-{\i1}sama{\i0}, biraz daha sabredin!
Dialogue: 0,0:13:03.60,0:13:06.31,Main-207+,,0,0,0,,Momonosuke-{\i1}kun{\i0}, rahat mısın orada?
Dialogue: 0,0:13:07.39,0:13:09.77,Main-207+,,0,0,0,,Hiç değilim...
Dialogue: 0,0:13:14.23,0:13:15.98,Main-207+,,0,0,0,,Neden öyle dediniz?!
Dialogue: 0,0:13:16.86,0:13:20.07,Main-207+,,0,0,0,,Hiç rahat hissetmiyorum.
Dialogue: 0,0:13:20.53,0:13:22.61,Main-207+,,0,0,0,,Kendimden nefret ediyorum.
Dialogue: 0,0:13:24.41,0:13:27.20,Main-207+,,0,0,0,,Beni gözünüzde büyütüyorsunuz!
Dialogue: 0,0:13:28.45,0:13:30.96,Main-207+,,0,0,0,,Ben... Ben...
Dialogue: 0,0:13:34.92,0:13:38.80,Main-207+,,0,0,0,,Ben değersiz, aptal...
Dialogue: 0,0:13:38.80,0:13:42.93,Main-207+,,0,0,0,,çelimsiz ve ahmağım.\NKendimi hiç sevmiyorum.
Dialogue: 0,0:13:42.93,0:13:45.30,Main-207+,,0,0,0,,Siz müthişsiniz efendim!
Dialogue: 0,0:13:46.81,0:13:48.77,Main-207+,,0,0,0,,Müthiş falan değilim.
Dialogue: 0,0:13:48.77,0:13:50.60,Main-207+,,0,0,0,,Şu an minik olsanız da...
Dialogue: 0,0:13:51.06,0:13:56.61,Main-207+,,0,0,0,,bir gün büyük bir şogun olacaksınız!
Dialogue: 0,0:13:56.61,0:14:00.69,Main-207+,,0,0,0,,Kozuki Oden'i bile gölgede bırakacak\Nmuhteşem biri olacaksın sen!
Dialogue: 0,0:14:03.36,0:14:06.95,Main-207+,,0,0,0,,Ben öyle... Ben öyle...
Dialogue: 0,0:14:09.95,0:14:12.25,Main-207+,,0,0,0,,Öyle müthiş biri olamam!
Dialogue: 0,0:14:12.96,0:14:14.54,Main-207+,,0,0,0,,Ne?!
Dialogue: 0,0:14:14.54,0:14:15.79,Main-207+,,0,0,0,,Yılan balığı mı?
Dialogue: 0,0:14:15.79,0:14:17.54,Main-207+,,0,0,0,,Momonosuke-{\i1}sama{\i0}!
Dialogue: 0,0:14:18.67,0:14:20.92,Main-207+,,0,0,0,,Bu görünüş...
Dialogue: 0,0:14:21.55,0:14:27.14,Main-207+,,0,0,0,,Heyecanlandığı zaman buna dönüşüyor.
Dialogue: 0,0:14:27.14,0:14:28.22,Main-207+,,0,0,0,,Heh?
Dialogue: 0,0:14:28.22,0:14:31.81,Main-207+,,0,0,0,,Şeytan meyvesi mi yedin acaba?
Dialogue: 0,0:14:32.23,0:14:34.69,Main-207+,,0,0,0,,Evet, yedim...
Dialogue: 0,0:14:45.07,0:14:46.82,Main-207+,,0,0,0,,Kaido demişken...
Dialogue: 0,0:14:47.66,0:14:51.25,Main-207+,,0,0,0,,bir ara Denizciler'in eline düşmüştü.
Dialogue: 0,0:14:53.25,0:14:58.54,Main-207+,,0,0,0,,Vegapunk da bu fırsatı kullanarak\NKaido'nun soy faktörlerini çıkarıp...
Dialogue: 0,0:14:58.54,0:15:01.46,Main-207+,,0,0,0,,insan yapımı bir şeytan meyvesi üretmişti.
Dialogue: 0,0:15:01.80,0:15:05.43,Main-207+,,0,0,0,,Hükûmet onu teslim etmesini istemişti.
Dialogue: 0,0:15:05.43,0:15:09.39,Main-207+,,0,0,0,,Ama sonuçları beğenmediğinden\Nbaşarısızlık olarak görüp...
Dialogue: 0,0:15:09.76,0:15:13.06,Main-207+,,0,0,0,,meyveyi uzun zaman\NPunk Hazard'da saklı tutmuştu.
Dialogue: 0,0:15:14.98,0:15:17.56,Main-207+,,0,0,0,,Ne diye şimdi bunu dile getiriyorsun?
Dialogue: 0,0:15:17.56,0:15:19.57,Main-207+,,0,0,0,,Punk Hazard havaya uçtu.
Dialogue: 0,0:15:19.57,0:15:21.78,Main-207+,,0,0,0,,Geriye bir şey kalmamıştır.
Dialogue: 0,0:15:21.78,0:15:24.65,Main-207+,,0,0,0,,Patlamada yok olduysa sorun yok...
Dialogue: 0,0:15:25.32,0:15:30.41,Main-207+,,0,0,0,,ama G-5'in bildirdiğine göre\Nbir tesis hâlâ faaliyetteymiş.
Dialogue: 0,0:15:34.66,0:15:39.46,Main-207+,,0,0,0,,Başarısızlıkla sonuçlanmasına sevindim sadece.
Dialogue: 0,0:15:51.81,0:15:53.68,Main-207+,,0,0,0,,Kim bizi tedavi etti?
Dialogue: 0,0:15:54.22,0:15:55.81,Main-207+,,0,0,0,,Bilmiyorum.
Dialogue: 0,0:15:56.35,0:15:58.73,Main-207+,,0,0,0,,Kimdi gördüm galiba.
Dialogue: 0,0:15:58.73,0:16:01.11,Main-207+,,0,0,0,,Yok, hayal görmüşümdür.
Dialogue: 0,0:16:02.07,0:16:04.78,Main-207+,,0,0,0,,Öyle bir şey olamaz.
Dialogue: 0,0:16:07.61,0:16:12.37,Main-207+,,0,0,0,,Luffy-{\i1}dono{\i0} ve dostları Kaido'yla savaşıyor.
Dialogue: 0,0:16:12.37,0:16:15.75,Main-207+,,0,0,0,,Burada oturup duramayız.
Dialogue: 0,0:16:16.29,0:16:18.96,Main-207+,,0,0,0,,Adadaki savaş daha bitmedi!
Dialogue: 0,0:16:18.96,0:16:20.33,Main-207+,,0,0,0,,Gidiyoruz!
Dialogue: 0,0:16:20.33,0:16:23.71,Main-207+,,0,0,0,,Hâlâ ruhumuzu teslim etmedik!
Dialogue: 0,0:16:26.38,0:16:27.97,Main-207+,,0,0,0,,Görünüşe göre...
Dialogue: 0,0:16:27.97,0:16:30.59,Main-207+,,0,0,0,,çok pis dayak yemişsiniz.
Dialogue: 0,0:16:30.59,0:16:32.72,Main-207+,,0,0,0,,Sizi çok özledim.
Dialogue: 0,0:16:38.52,0:16:41.27,Main-207+,,0,0,0,,Ne kadar yaşlanmışsınız.
Dialogue: 0,0:16:49.36,0:16:53.74,Main-207+,,0,0,0,,Oden-{\i1}sama{\i0}!
Dialogue: 0,0:16:55.16,0:16:57.12,Main-207+,,0,0,0,,Oden-{\i1}sama{\i0}?
Dialogue: 0,0:17:01.21,0:17:03.84,Main-207+,,0,0,0,,Şaşırmanız gayet doğal.
Dialogue: 0,0:17:03.84,0:17:06.96,Main-207+,,0,0,0,,Toki beni gücüyle geleceğe yolladı.
Dialogue: 0,0:17:06.96,0:17:08.72,Main-207+,,0,0,0,,Sonra açıklarım.
Dialogue: 0,0:17:08.72,0:17:09.93,Main-207+,,0,0,0,,Uzun hikâye.
Dialogue: 0,0:17:10.68,0:17:12.55,Main-207+,,0,0,0,,Oden-{\i1}sama{\i0}!
Dialogue: 0,0:17:12.55,0:17:14.26,Main-207+,,0,0,0,,Sizsiniz demek!
Dialogue: 0,0:17:16.47,0:17:18.64,Main-207+,,0,0,0,,Geç kaldığım için kusura bakmayın.
Dialogue: 0,0:17:18.64,0:17:22.85,Main-207+,,0,0,0,,Tekrar buluşmamızın sevincini sonra yaşarız.
Dialogue: 0,0:17:24.57,0:17:26.23,Main-207+,,0,0,0,,O gün...
Dialogue: 0,0:17:26.23,0:17:29.19,Main-207+,,0,0,0,,deviremediğimiz Kaido'yla yüzleşmeye gidelim!
Dialogue: 0,0:17:30.24,0:17:31.36,Main-207+,,0,0,0,,Elbette!
Dialogue: 0,0:17:31.36,0:17:32.82,Main-207+,,0,0,0,,Sizinle geleceğiz.
Dialogue: 0,0:17:32.82,0:17:34.95,Main-207+,,0,0,0,,Daima tek arzumuz buydu!
Dialogue: 0,0:17:34.95,0:17:36.49,Main-207+,,0,0,0,,Gidelim!
Dialogue: 0,0:17:39.96,0:17:43.25,Main-207+,,0,0,0,,Sizden de bu cevabı beklerdim!
Dialogue: 0,0:17:45.34,0:17:46.71,Main-207+,,0,0,0,,Bekleyin!
Dialogue: 0,0:17:47.92,0:17:50.05,Main-207+,,0,0,0,,Sağ olmana imkân yok!
Dialogue: 0,0:17:50.05,0:17:52.01,Main-207+,,0,0,0,,Sahtekârsın sen!
Dialogue: 0,0:17:52.01,0:17:54.18,Main-207+,,0,0,0,,Ne saçmalıyorsun, Ashura?!
Dialogue: 0,0:17:54.18,0:17:55.05,Main-207+,,0,0,0,,Kin'emon!
Dialogue: 0,0:17:56.93,0:17:58.52,Main-207+,,0,0,0,,Toki-{\i1}sama{\i0} demişti...
Dialogue: 0,0:17:58.64,0:18:02.39,Flashbacks-207+,,0,0,0,,{\3c&HFFFFFF&\4c&HFFFFFF&\t(0,313,1,\3c&H525252&\4c&H000000&)}Geçmişe dönemesek de...{Wano 09 - 18:42}
Dialogue: 0,0:18:02.39,0:18:04.65,Flashbacks-207+,,0,0,0,,{\t(1860,0,1,\3c&HD0D4D4&\4c&HD0D4D4&)}geleceğe gidebiliriz.
Dialogue: 0,0:18:08.90,0:18:11.86,Main-207+,,0,0,0,,"Geçmişe dönmek imkânsızdır"!{Wano 09 - 18:42}
Dialogue: 0,0:18:12.28,0:18:15.70,Main-207+,,0,0,0,,Toki-{\i1}sama{\i0} insanları geleceğe gönderebiliyor.
Dialogue: 0,0:18:15.70,0:18:19.58,Main-207+,,0,0,0,,O gün Oden-{\i1}sama{\i0} öldü.
Dialogue: 0,0:18:19.58,0:18:24.29,Main-207+,,0,0,0,,Gelecekte dahi bu gerçek değişmedi.
Dialogue: 0,0:18:24.29,0:18:28.21,Main-207+,,0,0,0,,Hiç kimse geçmişi değiştiremez!
Dialogue: 0,0:18:30.55,0:18:33.72,Main-207+,,0,0,0,,Ama... gerçekten efendimiz olabilir!
Dialogue: 0,0:18:33.72,0:18:34.76,Main-207+,,0,0,0,,Anlıyorum...
Dialogue: 0,0:18:39.18,0:18:40.60,Main-207+,,0,0,0,,ama...
Dialogue: 0,0:18:45.48,0:18:47.52,Main-207+,,0,0,0,,kendine gel artık, Kin'emon!
Dialogue: 0,0:18:52.15,0:18:53.28,Main-207+,,0,0,0,,Bakın!
Dialogue: 0,0:18:53.28,0:18:55.28,Main-207+,,0,0,0,,Kanı akmıyor!
Dialogue: 0,0:18:56.66,0:18:57.70,Main-207+,,0,0,0,,Nasıl olur?
Dialogue: 0,0:18:59.20,0:19:00.83,Main-207+,,0,0,0,,Ashura...
Dialogue: 0,0:19:00.83,0:19:05.17,Main-207+,,0,0,0,,samurayım olmak için ant içmedin mi?
Dialogue: 0,0:19:07.75,0:19:10.75,Flashbacks-207+,,0,0,0,,{\t(2399,0,1,\3c&HFFFFFF&\4c&HFFFFFF&)}Benim samuraylarım olun!{Wano 35 - 15:12}
Dialogue: 0,0:19:14.30,0:19:15.38,Main-207+,,0,0,0,,Ashura-{\i1}san{\i0}!
Dialogue: 0,0:19:17.72,0:19:18.72,Main-207+,,0,0,0,,Ashura!
Dialogue: 0,0:19:25.77,0:19:29.48,Main-207+,,0,0,0,,Artık sahtekâr olduğu alenen görülüyor!
Dialogue: 0,0:19:31.44,0:19:33.57,Main-207+,,0,0,0,,Hepimizin arzusu aynı yönde.
Dialogue: 0,0:19:33.57,0:19:36.15,Main-207+,,0,0,0,,Karşımızdakinin gerçek olması.
Dialogue: 0,0:19:36.74,0:19:39.95,Main-207+,,0,0,0,,Ama sahtekâr o!
Dialogue: 0,0:19:39.95,0:19:41.54,Main-207+,,0,0,0,,Ne pis bir numara!
Dialogue: 0,0:19:41.54,0:19:44.62,Main-207+,,0,0,0,,Oden-{\i1}sama{\i0}'nın taklidini yapan kim o hâlde?
Dialogue: 0,0:19:44.62,0:19:45.87,Main-207+,,0,0,0,,Efendimiz değil mi?
Dialogue: 0,0:19:45.87,0:19:47.21,Main-207+,,0,0,0,,Böyle işin...
Dialogue: 0,0:19:52.88,0:19:54.72,Main-207+,,0,0,0,,İyi misin, Ashura-{\i1}san{\i0}?!
Dialogue: 0,0:19:55.88,0:19:58.18,Main-207+,,0,0,0,,Ama hâl ve hareketleri...
Dialogue: 0,0:19:58.59,0:20:00.43,Main-207+,,0,0,0,,Oden-{\i1}sama{\i0}'nın kopyası gibi!
Dialogue: 0,0:20:00.93,0:20:03.47,Main-207+,,0,0,0,,Böyle iyi bir taklidi ancak...
Dialogue: 0,0:20:03.47,0:20:04.73,Main-207+,,0,0,0,,bizden biri yapabilir!
Dialogue: 0,0:20:05.23,0:20:06.48,Main-207+,,0,0,0,,Demek sensin...
Dialogue: 0,0:20:09.60,0:20:12.65,Main-207+,,0,0,0,,{\fad(0,1690)}Kanjuro!
Dialogue: 0,0:20:14.65,0:20:17.65,Main-207+,,0,0,0,,Salak olmayın! Ben Oden'im!
Dialogue: 0,0:20:19.11,0:20:20.99,Main-207+,,0,0,0,,Ashura-{\i1}san{\i0}, özür dilerim!
Dialogue: 0,0:20:20.99,0:20:22.45,Main-207+,,0,0,0,,Bütün suç benim!
Dialogue: 0,0:20:22.83,0:20:25.91,Main-207+,,0,0,0,,Kanjuro'nun işini düzgünce bitirseydim...
Dialogue: 0,0:20:26.58,0:20:31.00,Main-207+,,0,0,0,,Keskin bir kılıç dahi\Ndostunu kesmeye kalktığında körelir.
Dialogue: 0,0:20:31.42,0:20:34.13,Main-207+,,0,0,0,,Yüreğin el vermemiş belli ki.
Dialogue: 0,0:20:38.09,0:20:40.84,Main-207+,,0,0,0,,Çizim miymiş bu? Çizer nerede peki?
Dialogue: 0,0:20:43.39,0:20:47.81,Main-207+,,0,0,0,,Oden'i uzaktan yönlendiriyorum.
Dialogue: 0,0:20:47.81,0:20:50.19,Main-207+,,0,0,0,,Çok yorucu bir iş.
Dialogue: 0,0:20:53.57,0:20:54.82,Main-207+,,0,0,0,,Hey, Kiku!
Dialogue: 0,0:20:55.15,0:20:58.20,Main-207+,,0,0,0,,Kılıcın beni kesti.
Dialogue: 0,0:20:58.20,0:21:00.32,Main-207+,,0,0,0,,Ağır yaralıyım.
Dialogue: 0,0:21:00.32,0:21:02.28,Main-207+,,0,0,0,,Muhtemelen bu son gösterim olacak.
Dialogue: 0,0:21:02.70,0:21:05.91,Main-207+,,0,0,0,,Beni şu an kamçılayan şey...
Dialogue: 0,0:21:06.45,0:21:08.91,Main-207+,,0,0,0,,Kozuki Hanesi'ne duyduğum öfke!
Dialogue: 0,0:21:09.62,0:21:12.04,Main-207+,,0,0,0,,Yapacağım son şey de olsa...
Dialogue: 0,0:21:12.04,0:21:15.21,Main-207+,,0,0,0,,Kozuki Hanesi'ni kalbinden vuracağım!
Dialogue: 0,0:21:15.21,0:21:17.84,Main-207+,,0,0,0,,Kurozumi Kanjuro olarak!
Dialogue: 0,0:21:25.31,0:21:27.31,Main-207+,,0,0,0,,Momonosuke-{\i1}sama{\i0} tehlikede!
Dialogue: 0,0:21:27.31,0:21:31.19,Main-207+,,0,0,0,,Sahi, demin... bir ses duydum.
Dialogue: 0,0:21:31.19,0:21:34.90,Main-207+,,0,0,0,,Momonosuke-{\i1}sama{\i0}\Nbir {\i1}kunoichi{\i0}'yle birlikteymiş.
Dialogue: 0,0:21:35.23,0:21:36.94,Main-207+,,0,0,0,,Shinobu olmalı!
Dialogue: 0,0:21:36.94,0:21:39.24,Main-207+,,0,0,0,,İrtibat kurabiliriz öyleyse.
Dialogue: 0,0:21:39.24,0:21:43.16,Main-207+,,0,0,0,,Ölmek üzere olan birinin de\Npeşine düşmezsin be.
Dialogue: 0,0:21:47.29,0:21:52.04,Main-207+,,0,0,0,,Bir şey yapamayacaksınız!\NBurası Kızıl Kınlar'ın mezarı olacak!
Dialogue: 0,0:21:54.33,0:21:57.30,Main-207+,,0,0,0,,Benimle birlikte!
Dialogue: 0,0:22:02.84,0:22:05.80,Main-207+,,0,0,0,,Görkemli bir patlamayla veda edelim!
Dialogue: 0,0:22:11.31,0:22:12.81,Main-207+,,0,0,0,,Millet!
Dialogue: 0,0:22:14.98,0:22:18.73,Main-207+,,0,0,0,,Biz dostuz değil mi?
Dialogue: 0,0:22:37.25,0:22:38.84,Main-207+,,0,0,0,,Ashura!
Dialogue: 0,0:22:38.84,0:22:42.22,Main-207+,,0,0,0,,Buradan uzaklaşın!
Dialogue: 0,0:22:45.55,0:22:48.93,Main-207+,,0,0,0,,Gidip Kanjuro'yu durdurun!
Dialogue: 0,0:22:49.26,0:22:50.52,Main-207+,,0,0,0,,Ne yapıyorsun?
Dialogue: 0,0:22:50.52,0:22:52.48,Main-207+,,0,0,0,,Bırak beni!
Dialogue: 0,0:22:52.48,0:22:55.10,Main-207+,,0,0,0,,Benim için Momonosuke-{\i1}sama{\i0}'yı kurtarın!
Dialogue: 0,0:22:55.10,0:22:57.73,Main-207+,,0,0,0,,Çok üzgünüm, Ashura!
Dialogue: 0,0:22:57.73,0:22:59.48,Main-207+,,0,0,0,,Seni camış!
Dialogue: 0,0:22:59.48,0:23:01.07,Main-207+,,0,0,0,,İşime çomak sokmasana!
Dialogue: 0,0:23:02.49,0:23:05.24,Main-207+,,0,0,0,,Bırak lan beni!
Dialogue: 0,0:23:08.33,0:23:13.66,Main-207+,,0,0,0,,Kozuki Oden'in anısını kirletme artık!
Dialogue: 0,0:23:51.08,0:23:54.25,Main-207+,,0,0,0,,Kanjuro!
Dialogue: 0,0:23:58.33,0:24:02.21,Main-207+,,0,0,0,,Sonunda başrol olarak sahneye çıkma vaktim geldi!
Dialogue: 0,0:24:02.71,0:24:04.84,Main-207+,,0,0,0,,Kozukilerden biri gibi davran...
Dialogue: 0,0:24:04.84,0:24:07.43,Main-207+,,0,0,0,,ve onların sonunu getir.
Dialogue: 0,0:24:07.43,0:24:08.89,Main-207+,,0,0,0,,Sonra da öl!
Dialogue: 0,0:24:09.80,0:24:13.26,Main-207+,,0,0,0,,En büyük oyunun perdesi kapanmak üzere.
Dialogue: 0,0:24:13.26,0:24:17.56,Main-207+,,0,0,0,,Bütün hayatım kalpleri dağlayan bir drama.
Dialogue: 0,0:24:34.45,0:24:36.08,Main-207+,,0,0,0,,Jack!
Dialogue: 0,0:24:36.45,0:24:38.96,Main-207+,,0,0,0,,Şerefsiz! Yine mi kaşınıyorsun?
Dialogue: 0,0:24:39.50,0:24:41.75,Main-207+,,0,0,0,,Vaktimi çaldılar.
Dialogue: 0,0:24:41.75,0:24:44.17,Main-207+,,0,0,0,,Krallarını korumak için...
Dialogue: 0,0:24:44.88,0:24:48.47,Main-207+,,0,0,0,,bu beş para etmezler karşıma dikildi.
Dialogue: 0,0:24:49.93,0:24:53.89,Main-207+,,0,0,0,,Kedi, Raizo sakin olun. Siz önden gidin.
Dialogue: 0,0:24:55.35,0:24:58.85,Main-207+,,0,0,0,,Benim için Momonosuke-{\i1}sama{\i0}'yı kurtarın!
Dialogue: 0,0:24:59.23,0:25:01.35,Main-207+,,0,0,0,,Gidelim, Kin-{\i1}san{\i0}.
Dialogue: 0,0:25:01.35,0:25:02.69,Main-207+,,0,0,0,,Tamam...
Dialogue: 0,0:25:02.69,0:25:06.90,Main-207+,,0,0,0,,Muhakkak bize yetiş, Inuarashi!\NSeni bekleyeceğiz!
Dialogue: 0,0:25:13.62,0:25:17.50,Main-207+,,0,0,0,,Beni tek başına mı halledeceksin,\NGündüz Dükü?
Dialogue: 0,0:25:17.50,0:25:19.75,Main-207+,,0,0,0,,İkimiz de yaralıyız.
Dialogue: 0,0:25:19.75,0:25:21.58,Main-207+,,0,0,0,,Eşit durumdayız!
Dialogue: 0,0:25:22.00,0:25:26.80,Main-207+,,0,0,0,,Husumetimiz için geride kalmadım.
Dialogue: 0,0:25:27.26,0:25:33.72,Main-207+,,0,0,0,,Daha fazla unutulmaz acıya\Nsebep olmayasın diye kaldım, Jack!
Dialogue: 0,0:25:34.35,0:25:36.77,Main-207+,,0,0,0,,Buradan ay'ı göremezsin!
Dialogue: 0,0:25:36.77,0:25:38.89,Main-207+,,0,0,0,,Sen de zehirli gaz kullanamazsın.
Dialogue: 0,0:25:43.06,0:25:46.52,Main-207+,,0,0,0,,İkimiz de elimizdekilerle yetineceğiz.
Dialogue: 0,0:26:02.25,0:26:04.71,Main-207+,,0,0,0,,Hemen söndürmezsek yangın büyüyecek!
Dialogue: 0,0:26:05.71,0:26:09.09,Main-207+,,0,0,0,,Daha çok su lazım! Gidip getirin!
Dialogue: 0,0:26:22.60,0:26:23.69,Main-207+,,0,0,0,,Sen...
Dialogue: 0,0:26:23.69,0:26:27.23,Main-207+,,0,0,0,,Embesillere ders verme vaktidir.
Dialogue: 0,0:26:27.57,0:26:29.82,Main-207+,,0,0,0,,Ölmüştün sen!
Dialogue: 0,0:26:29.82,0:26:32.07,Main-207+,,0,0,0,,Nasıl hayattasın?
Dialogue: 0,0:26:41.54,0:26:46.00,Main-207+,,0,0,0,,Bana ihanet edersin ha Kaido.
Dialogue: 0,0:26:48.75,0:26:51.05,Main-207+,,0,0,0,,Kaido hakikaten...
Dialogue: 0,0:26:51.05,0:26:55.72,Main-207+,,0,0,0,,kafanızı kesti. Bir kez de olsa.
Dialogue: 0,0:26:55.72,0:26:56.89,Main-207+,,0,0,0,,Lakin...
Dialogue: 0,0:26:57.80,0:26:59.93,Main-207+,,0,0,0,,Her şeyi yakacağım!
Dialogue: 0,0:27:00.39,0:27:04.89,Main-207+,,0,0,0,,Onigashima'yı alevlere boğacağım!
Dialogue: 0,0:27:04.89,0:27:07.52,Main-207+,,0,0,0,,Havada kaçamayacak...
Dialogue: 0,0:27:07.52,0:27:09.69,Main-207+,,0,0,0,,ve öleceksiniz!
Dialogue: 0,0:27:13.07,0:27:16.16,Main-207+,,0,0,0,,Herkesi geberteceğim!
Dialogue: 0,0:27:16.16,0:27:18.95,Main-207+,,0,0,0,,Burnunuzdan fitil fitil getireceğim!
Dialogue: 0,0:27:30.38,0:27:31.59,Main-207+,,0,0,0,,Momonosuke-{\i1}kun{\i0}!
Dialogue: 0,0:27:31.59,0:27:33.80,Main-207+,,0,0,0,,Eski hâline dönebilir misin?
Dialogue: 0,0:27:33.80,0:27:35.68,Main-207+,,0,0,0,,Böyle çok göze batıyorsun.
Dialogue: 0,0:27:35.68,0:27:37.22,Main-207+,,0,0,0,,O-Olur.
Dialogue: 0,0:27:43.85,0:27:47.65,Main-207+,,0,0,0,,Bu sefer çıkma ama, Momonosuke-{\i1}kun{\i0}!
Dialogue: 0,0:27:47.65,0:27:48.73,Main-207+,,0,0,0,,Üzgünüm...
Dialogue: 0,0:27:51.82,0:27:55.36,Main-207+,,0,0,0,,Aslına bakarsan,\Nartık bayağı kontrol edebiliyorum.
Dialogue: 0,0:27:56.74,0:27:59.37,Main-207+,,0,0,0,,Luffyler'le ilk karşılaştığımda...
Dialogue: 0,0:27:59.37,0:28:03.37,Main-207+,,0,0,0,,ne zaman şaşırsam ya da üzülsem\Nejderhaya dönüşüyordum.
Dialogue: 0,0:28:03.75,0:28:05.00,Main-207+,,0,0,0,,Çok şaşırtıcı.
Dialogue: 0,0:28:05.00,0:28:07.33,Main-207+,,0,0,0,,Babamınkine benzer bir güç mü acaba?
Dialogue: 0,0:28:07.33,0:28:12.46,Main-207+,,0,0,0,,Onun gibi canavara dönüşebilseydim\Nbir faydam dokunurdu.
Dialogue: 0,0:28:12.46,0:28:16.05,Main-207+,,0,0,0,,Luffy hâlâ Kaido'yla dövüşüyor di' mi?
Dialogue: 0,0:28:16.05,0:28:17.68,Main-207+,,0,0,0,,Ne durumda acaba?
Dialogue: 0,0:28:17.68,0:28:20.64,Main-207+,,0,0,0,,Ben de Oden olarak\NKaido'yu devirmek istiyorum!
Dialogue: 0,0:28:20.64,0:28:24.06,Main-207+,,0,0,0,,Çok zayıflamış dursa da...
Dialogue: 0,0:28:24.06,0:28:26.31,Main-207+,,0,0,0,,niyeyse Luffy iyi durumda.
Dialogue: 0,0:28:26.31,0:28:27.56,Main-207+,,0,0,0,,Şükürler olsun.
Dialogue: 0,0:28:28.81,0:28:29.52,Main-207+,,0,0,0,,Ne?!
Dialogue: 0,0:28:30.90,0:28:33.94,Main-207+,,0,0,0,,Siz nereden biliyorsunuz efendim?
Dialogue: 0,0:28:40.99,0:28:43.53,Main-207+,,0,0,0,,Yok mu bunları yenmenin bir yolu?
Dialogue: 0,0:28:45.75,0:28:49.04,Main-207+,,0,0,0,,Saldırılarımız hiçbir işe\Nyaramıyormuş gibi duruyor.
Dialogue: 0,0:28:50.63,0:28:53.96,Main-207+,,0,0,0,,Namlarının hakkını veriyorlar. Derileri çok sert.
Dialogue: 0,0:28:53.96,0:28:57.88,Main-207+,,0,0,0,,Biraz olsun belirti gösterin artık!
Dialogue: 0,0:29:00.84,0:29:01.97,Main-207+,,0,0,0,,İşe yarıyor!
Dialogue: 0,0:29:02.55,0:29:05.85,Main-207+,,0,0,0,,O kadar darbe yediler,\Nişe yaramamasına imkân yok!
Dialogue: 0,0:29:05.85,0:29:07.43,Main-207+,,0,0,0,,Onlar da bizim gibi insan!
Dialogue: 0,0:29:07.98,0:29:10.10,Main-207+,,0,0,0,,{\fad(150,150)}Lastik-Lastik...
Dialogue: 0,0:29:16.19,0:29:19.65,Main-207+,,0,0,0,,Demin de yememişti bu!\NDüşünmeden atılma!
Dialogue: 0,0:29:20.28,0:29:22.12,Main-207+,,0,0,0,,Aramızda dağlar varken...
Dialogue: 0,0:29:22.12,0:29:24.70,Main-207+,,0,0,0,,nasıl bunlar bizim gibi insan oluyor?
Dialogue: 0,0:29:25.20,0:29:28.91,Main-207+,,0,0,0,,Yenilmeye mi geldiniz o zaman buraya?
Dialogue: 0,0:29:28.91,0:29:31.54,Main-207+,,0,0,0,,Çare arıyoruz işte.
Dialogue: 0,0:29:32.21,0:29:34.67,Main-207+,,0,0,0,,İkisini ayırmamız lazım.
Dialogue: 0,0:29:35.21,0:29:36.63,Main-207+,,0,0,0,,Aynı fikirdeyim.
Dialogue: 0,0:29:36.63,0:29:40.22,Main-207+,,0,0,0,,Bu ikisi yan yanayken...
Dialogue: 0,0:29:43.55,0:29:46.76,Main-207+,,0,0,0,,cehennem ayağına geliyor sanki.
Dialogue: 0,0:30:11.96,0:30:16.00,Main-207+,,0,0,0,,Cehennem mi? Orayı komşu kapısı yaptım!
Dialogue: 0,0:30:17.34,0:30:21.09,Main-207+,,0,0,0,,Gözlerinin feri hiç sönmüyor...
Dialogue: 0,0:30:23.97,0:30:26.26,Main-207+,,0,0,0,,Hasır Şapka!
Dialogue: 0,0:30:26.89,0:30:28.72,Main-207+,,0,0,0,,Avantaj bizde!
