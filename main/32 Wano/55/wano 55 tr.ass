Comment: 0,0:00:00.00,0:00:00.00,Main-207+,,0,0,0,,{=110}===============================DIALOGUE============================
Dialogue: 0,0:01:51.80,0:01:52.93,Main-207+,,0,0,0,,D. mi?
Dialogue: 0,0:01:56.43,0:02:00.68,Main-207+,,0,0,0,,Bir gün seninle tanışacağım\Nhiç aklıma gelmezdi.
Dialogue: 0,0:02:01.14,0:02:03.39,Main-207+,,0,0,0,,"O-Oden"...
Dialogue: 0,0:02:04.02,0:02:06.02,Main-207+,,0,0,0,,Babamın defteri mi o?
Dialogue: 0,0:02:06.56,0:02:12.61,Main-207+,,0,0,0,,Dolu dolu yaşantısı ve dünyayı keşfinin\Ntüm ayrıntıları bu defterde yer alıyor.
Dialogue: 0,0:02:13.74,0:02:17.58,Main-207+,,0,0,0,,Malum gün, bunu Oden Kalesi'nin\Noradaki nehirden aldım.
Dialogue: 0,0:02:17.58,0:02:21.16,Main-207+,,0,0,0,,Biri bunu yangından kurtarmış.
Dialogue: 0,0:02:21.16,0:02:22.79,Main-207+,,0,0,0,,Oden-{\i1}sama{\i0}'nın...
Dialogue: 0,0:02:24.42,0:02:25.75,Main-207+,,0,0,0,,Momonosuke-{\i1}kun{\i0}!
Dialogue: 0,0:02:26.88,0:02:30.71,Main-207+,,0,0,0,,Seninle ilgili de birçok şey yazıyor.
Dialogue: 0,0:02:32.76,0:02:35.64,Main-207+,,0,0,0,,Beyazsakal'ın gemisinde doğmuşsun!
Dialogue: 0,0:02:35.97,0:02:37.76,Main-207+,,0,0,0,,Sonra da Roger'ın gemisine gitmişsin.
Dialogue: 0,0:02:39.01,0:02:40.31,Main-207+,,0,0,0,,Hıhı.
Dialogue: 0,0:02:40.93,0:02:47.23,Main-207+,,0,0,0,,Ama çok küçük olduğumdan\Nhiç hatırlamıyorum.
Dialogue: 0,0:02:47.23,0:02:49.94,Main-207+,,0,0,0,,Beyazsakal, Roger ve Oden.
Dialogue: 0,0:02:52.07,0:02:53.28,Main-207+,,0,0,0,,Ortak bir şey söylediler...
Dialogue: 0,0:02:53.28,0:02:53.32,Main-207+,,0,0,0,,{\clip(m 1078 896 l 1078 912 1100 926 1094 950 1114 958 1126 982 1142.22 995.88 1170.49 1045.31 1060 1054 1029.25 1004.62 1014 984 986 940 968 926 962 902 948 900 918 814 828 832 884 910 902 938 921.81 966.65 946.84 1005.62 975.08 1046.93 980 1072 310 1066.4 390.8 913.6 662 756 938 650 1297.6 896 1354.36 965.15 1349.68 977.22 1352.41 979.94 1366.42 980.72 1375.38 996.68 1375.77 1004.74 1377.57 1009.11 1380.23 1012.18 1389.98 1019.18 1394.31 1029.23 1396.53 1044.56 1400.45 1052.08 1468.81 1068.32 1617.2 1061.03 1613.41 908.48)}Ortak bir şey söylediler...
Dialogue: 0,0:02:53.32,0:02:53.40,Main-207+,,0,0,0,,Ortak bir şey söylediler...
Dialogue: 0,0:02:53.40,0:02:53.44,Main-207+,,0,0,0,,{\clip(m 362.87 964.39 l 381.61 981.13 431.45 1042.13 437.03 1058.87 487.28 1054.49 443.02 985.51 419.49 968.37 415.9 958.8 963.11 862.4 1039.52 948.55 1126.59 1069.34 1149.61 1072.45 1557.5 1074.72 1648.12 832.93)}Ortak bir şey söylediler...
Dialogue: 0,0:02:53.44,0:02:53.49,Main-207+,,0,0,0,,Ortak bir şey söylediler...
Dialogue: 0,0:02:57.12,0:02:59.37,Main-207+,,0,0,0,,"Bundan en az 20 yıl sonra...
Dialogue: 0,0:03:02.25,0:03:06.54,Main-207+,,0,0,0,,genç ve güçlü korsanlar\Nbirbiri ardına Yeni Dünya'ya gelecek."
Dialogue: 0,0:03:08.00,0:03:09.34,Main-207+,,0,0,0,,O vakit geldi!
Dialogue: 0,0:03:12.92,0:03:16.88,Main-207+,,0,0,0,,Onların başının da\NAce olacağına inanıyordum.
Dialogue: 0,0:03:16.88,0:03:22.56,Main-207+,,0,0,0,,Ama o öldüğünde bir şeyi hatırladım.\NO gece dediği bir şeyi!
Dialogue: 0,0:03:25.56,0:03:26.19,Main-207+,,0,0,0,,Ne...?
Dialogue: 0,0:03:28.77,0:03:30.15,Main-207+,,0,0,0,,Hass...
Dialogue: 0,0:03:30.15,0:03:31.73,Main-207+,,0,0,0,,Ağzımdan kaçırdım!
Dialogue: 0,0:03:31.73,0:03:34.44,Main-207+,,0,0,0,,Yanlışlıkla söyledim.
Dialogue: 0,0:03:34.44,0:03:36.15,Main-207+,,0,0,0,,Bunu demedim sayalım!
Dialogue: 0,0:03:36.70,0:03:38.70,Main-207+,,0,0,0,,Bak gülme,
Dialogue: 0,0:03:38.70,0:03:40.78,Main-207+,,0,0,0,,Sabo'yla ben çok kızarız.
Dialogue: 0,0:03:43.49,0:03:47.33,Main-207+,,0,0,0,,Kardeşimin hayali bu.
Dialogue: 0,0:03:49.88,0:03:54.76,Main-207+,,0,0,0,,Luffy bunu dediğinde Sabo'yla gülmüştük.
Dialogue: 0,0:03:54.76,0:03:58.13,Main-207+,,0,0,0,,Ama başkasının gülmesine izin vermeyiz.
Dialogue: 0,0:03:58.13,0:03:59.76,Main-207+,,0,0,0,,Ona inanıyoruz çünkü.
Dialogue: 0,0:03:59.76,0:04:03.51,Main-207+,,0,0,0,,Onda bu potansiyel var, bu yüzden–
Dialogue: 0,0:04:03.51,0:04:04.52,Main-207+,,0,0,0,,Ace!
Dialogue: 0,0:04:06.39,0:04:07.14,Main-207+,,0,0,0,,Ha?
Dialogue: 0,0:04:08.02,0:04:09.15,Main-207+,,0,0,0,,Hey!
Dialogue: 0,0:04:09.15,0:04:10.65,Main-207+,,0,0,0,,Neyin var, Yamato?
Dialogue: 0,0:04:13.52,0:04:16.36,Main-207+,,0,0,0,,Ben gülmeyeceğim.
Dialogue: 0,0:04:17.24,0:04:20.95,Thoughts-207+,,0,0,0,,Korsanlar Kralı da aynısını demişti!
Dialogue: 0,0:04:20.95,0:04:23.74,Thoughts-207+,,0,0,0,,Oden de çok etkilenmişti!
Dialogue: 0,0:04:24.74,0:04:29.96,Main-207+,,0,0,0,,Yolculuğu sırasında Kozuki Oden de\Naynısını diyen büyük bir adam görmüş.
Dialogue: 0,0:04:29.96,0:04:31.58,Main-207+,,0,0,0,,Hayatta gülmem!
Dialogue: 0,0:04:31.58,0:04:33.59,Main-207+,,0,0,0,,Kardeşin inanılmaz biri!
Dialogue: 0,0:04:35.46,0:04:37.09,Main-207+,,0,0,0,,Büyük adam ha?
Dialogue: 0,0:04:37.09,0:04:38.59,Main-207+,,0,0,0,,İyiymiş.
Dialogue: 0,0:04:38.59,0:04:42.05,Main-207+,,0,0,0,,Luffy'yle beraber\Nbir gün onunla içeriz umarım.
Dialogue: 0,0:04:43.22,0:04:45.26,Main-207+,,0,0,0,,Aranızdan su sızmazdı kesin.
Dialogue: 0,0:04:45.97,0:04:47.23,Main-207+,,0,0,0,,Çoktan ölmeseydi.
Dialogue: 0,0:04:47.23,0:04:48.31,Main-207+,,0,0,0,,Öldü mü?
Dialogue: 0,0:04:49.85,0:04:53.15,Main-207+,,0,0,0,,Yazık oldu. Kadeh tokuşturamayacağız.
Dialogue: 0,0:05:00.66,0:05:01.41,Main-207+,,0,0,0,,Bitirdim.
Dialogue: 0,0:05:01.41,0:05:02.07,Main-207+,,0,0,0,,Oh?
Dialogue: 0,0:05:02.07,0:05:04.03,Main-207+,,0,0,0,,Bu senin vivre kartın.
Dialogue: 0,0:05:05.03,0:05:06.79,Main-207+,,0,0,0,,Bu muymuş?
Dialogue: 0,0:05:08.54,0:05:10.12,Main-207+,,0,0,0,,Bildiğin kağıt parçası bu ya.
Dialogue: 0,0:05:10.75,0:05:15.92,Main-207+,,0,0,0,,Evet, bu kağıt parçası\Nbizi tekrar bir araya getirecek.
Dialogue: 0,0:05:17.26,0:05:22.09,Main-207+,,0,0,0,,Ayrılmak istemediğin ya da tekrar görmek\Nistediğin birine bundan bir parça ver.
Dialogue: 0,0:05:22.76,0:05:23.64,Main-207+,,0,0,0,,Anladım!
Dialogue: 0,0:05:23.64,0:05:25.51,Main-207+,,0,0,0,,Öyle yaparım.
Dialogue: 0,0:05:45.37,0:05:48.04,Main-207+,,0,0,0,,Ace!
Dialogue: 0,0:05:55.54,0:05:57.21,Main-207+,,0,0,0,,Yamato?!
Dialogue: 0,0:06:01.59,0:06:03.68,Main-207+,,0,0,0,,Tekrar görüşelim...
Dialogue: 0,0:06:04.05,0:06:06.64,Main-207+,,0,0,0,,Ace!
Dialogue: 0,0:06:14.27,0:06:16.27,Main-207+,,0,0,0,,Elbette!
Dialogue: 0,0:06:23.15,0:06:24.16,Main-207+,,0,0,0,,{\i1}Ama...
Dialogue: 0,0:06:25.07,0:06:27.12,Main-207+,,0,0,0,,{\i1}bu onu son görüşümdü.
Dialogue: 0,0:06:35.42,0:06:40.80,Main-207+,,0,0,0,,O gün dış dünyada\Nneler olup bittiğini bilmesem de...
Dialogue: 0,0:06:41.42,0:06:44.26,Main-207+,,0,0,0,,olanları daha sonra gazeteden okudum.
Dialogue: 0,0:06:44.76,0:06:49.39,Main-207+,,0,0,0,,Ace'in Korsanlar Kralı\NGol D. Roger'ın oğlu olduğunu...
Dialogue: 0,0:06:50.14,0:06:54.85,Main-207+,,0,0,0,,ve kardeşinin cidden korsan olup\Nnam yaptığını öğrendim.
Dialogue: 0,0:06:55.52,0:06:59.52,Main-207+,,0,0,0,,Kardeşi senin buraya getirdiğin Luffy!
Dialogue: 0,0:07:01.78,0:07:03.15,Main-207+,,0,0,0,,Momonosuke-{\i1}kun{\i0}.
Dialogue: 0,0:07:03.61,0:07:06.57,Main-207+,,0,0,0,,Hakkın olarak bunu sana veriyorum.
Dialogue: 0,0:07:06.57,0:07:10.66,Main-207+,,0,0,0,,Oden'in gelecek ile ilgili kaleme aldıkları bunlar...
Dialogue: 0,0:07:19.84,0:07:23.76,Flashbacks-207+,,0,0,0,,Bundan en az 20 yıl sonra...
Dialogue: 0,0:07:28.05,0:07:35.10,Flashbacks-207+,,0,0,0,,gelecek çağa öncülük edecek genç ve güçlü korsanlar, birbiri ardına Yeni Dünya'ya gelecek.
Dialogue: 0,0:07:36.73,0:07:39.11,Flashbacks-207+,,0,0,0,,Şayet ölürsem...
Dialogue: 0,0:07:39.11,0:07:39.23,Flashbacks-207+,,0,0,0,,{\clip(m 762 980 l 794 1000 818 1014 844 1020 880 1038 904 1038 960 1014 906 994 872 944 1132 932 1128 942 1126 950 1096 984 1164 952 1192 926 1202 918 1238 910 1252 894 1514 878 1708 1016 1584 1046 880 1072 578 1064 430 1064 404 862)}Şayet ölürsem...
Dialogue: 0,0:07:39.23,0:07:39.31,Flashbacks-207+,,0,0,0,,{\clip(m 1319.38 1063.34 l 1322.71 1044.83 1338.26 1012.62 1354.92 980.4 1360.48 967.82 1354.55 951.16 1312.71 947.82 1249.39 969.3 1238.28 947.08 1211.62 954.49 1207.54 994.1 1197.18 1017.43 1186.44 1030.39 1174.22 1038.53 1184.96 1057.04 1186.07 1064.45 812.75 1074.95 801.83 1065.1 776.94 1055.99 761.6 1046.43 760.49 1040.43 769.16 1023.53 773.38 1014.2 743.37 1008.86 711.14 998.63 693.8 986.85 676.01 968.62 644 948.39 631.77 938.83 626.66 937.05 623.77 941.28 627.11 949.28 638.44 963.73 645.34 972.4 644.22 973.07 622.44 958.39 586.48 926.2 554.37 927.04 523.1 1063.1)}Şayet ölürsem...
Dialogue: 0,0:07:43.23,0:07:45.99,Flashbacks-207+,,0,0,0,,Kaido'yu...
Dialogue: 0,0:07:47.66,0:07:49.62,Flashbacks-207+,,0,0,0,,onlar devirecek!
Dialogue: 0,0:07:50.24,0:07:52.24,Main-207+,,0,0,0,,Biri daha geldi.
Dialogue: 0,0:07:52.24,0:07:54.50,Main-207+,,0,0,0,,Siz oturun, ben hallederim.
Dialogue: 0,0:07:54.50,0:07:55.71,Main-207+,,0,0,0,,Reddediyorum.
Dialogue: 0,0:07:55.00,0:07:55.71,Secondary-207+,,0,0,0,,Ben de.
Dialogue: 0,0:07:56.37,0:07:58.67,Main-207+,,0,0,0,,Kellesini almalık ne çok kişi geldi.
Dialogue: 0,0:08:01.25,0:08:03.38,Main-207+,,0,0,0,,Hasır Şapka.
Dialogue: 0,0:08:20.31,0:08:21.56,Main-207+,,0,0,0,,Linlin!
Dialogue: 0,0:08:21.56,0:08:25.32,Main-207+,,0,0,0,,Bil bakalım bu velet karşıma geçip\Nne olacağım demiştir.
Dialogue: 0,0:08:25.32,0:08:27.82,Main-207+,,0,0,0,,Küstahın teki.
Dialogue: 0,0:08:28.24,0:08:31.82,Main-207+,,0,0,0,,Bana da haddini aşan sözler söyledi.
Dialogue: 0,0:08:31.82,0:08:35.45,Main-207+,,0,0,0,,Kalemi de yerle bir etti.
Dialogue: 0,0:08:35.45,0:08:38.96,Main-207+,,0,0,0,,Önce özür dile, Hasır Şapka.
Dialogue: 0,0:08:43.84,0:08:45.38,Main-207+,,0,0,0,,Lan velet.
Dialogue: 0,0:08:45.84,0:08:49.68,Main-207+,,0,0,0,,Karşımızdayken...
Dialogue: 0,0:08:49.68,0:08:54.60,Main-207+,,0,0,0,,ne olacaksın bir daha söyle hele!
Dialogue: 0,0:09:05.15,0:09:07.74,Main-207+,,0,0,0,,İyi misin, Kin'emon?
Dialogue: 0,0:09:08.86,0:09:11.16,Main-207+,,0,0,0,,Özür dilerim.
Dialogue: 0,0:09:12.20,0:09:13.74,Main-207+,,0,0,0,,Geç kaldım.
Dialogue: 0,0:09:21.21,0:09:23.63,Main-207+,,0,0,0,,P... Perişanım.
Dialogue: 0,0:09:26.92,0:09:28.88,Main-207+,,0,0,0,,Öteki...
Dialogue: 0,0:09:29.42,0:09:31.22,Main-207+,,0,0,0,,dünyada...
Dialogue: 0,0:09:31.76,0:09:35.93,Main-207+,,0,0,0,,efendime bakacak yüzüm... yok!
Dialogue: 0,0:09:37.31,0:09:38.14,Main-207+,,0,0,0,,Kin'e–
Dialogue: 0,0:09:40.48,0:09:43.35,Main-207+,,0,0,0,,Wano'ya...{Wano 56 16:51}
Dialogue: 0,0:09:44.73,0:09:47.15,Main-207+,,0,0,0,,sahip çıkar mısın?
Dialogue: 0,0:09:49.40,0:09:50.03,Main-207+,,0,0,0,,Ya–
Dialogue: 0,0:09:50.03,0:09:51.15,Main-207+,,0,0,0,,Aptal!
Dialogue: 0,0:09:51.15,0:09:52.70,Main-207+,,0,0,0,,Elbette çıkarım!
Dialogue: 0,0:09:54.20,0:09:55.99,Main-207+,,0,0,0,,Burası dostlarımın ülkesi!
Dialogue: 0,0:10:02.58,0:10:04.83,Main-207+,,0,0,0,,Lan velet.
Dialogue: 0,0:10:07.09,0:10:10.09,Thoughts-207+,,0,0,0,,Luffy-dono...
Dialogue: 0,0:10:11.26,0:10:14.43,Thoughts-207+,,0,0,0,,minnettarım.
Dialogue: 0,0:10:16.18,0:10:16.97,Main-207+,,0,0,0,,Trao!
Dialogue: 0,0:10:16.97,0:10:19.39,Main-207+,,0,0,0,,Hepsini aşağıya yolla!{Wano 56 - 04:55}
Dialogue: 0,0:10:24.65,0:10:27.11,Main-207+,,0,0,0,,Yine ne sarsıntısı bu?
Dialogue: 0,0:10:27.69,0:10:29.11,Main-207+,,0,0,0,,Luffy...
Dialogue: 0,0:10:32.57,0:10:38.03,Flashbacks-207+,,0,0,0,,Sizin haki dediğiniz şey\NWano'da {\i1}ryuo{\i0} olarak biliniyor.{Wano 21 - 08:26}
Dialogue: 0,0:10:38.03,0:10:40.91,Flashbacks-207+,,0,0,0,,"Akış" anlamına geliyor.
Dialogue: 0,0:10:40.91,0:10:44.12,Flashbacks-207+,,0,0,0,,Oden-{\i1}sama{\i0} idam edildi!{Zou 09 - 13:58}
Dialogue: 0,0:10:44.12,0:10:48.34,Flashbacks-207+,,0,0,0,,Wano şogunu tarafından,\Nkorsan Kaido'nun da yardımıyla...
