Dialogue: 0,0:20:57.36,0:21:00.66,Flashbacks-207+,,0,0,0,,Henüz isyan ateşi sönmemiş demek.{Wano 21 - 18:00}
Dialogue: 0,0:21:00.66,0:21:02.70,Flashbacks-207+,,0,0,0,,Tüm gemiler, Onigashima'ya!{Wano 43 - 26:03}
Dialogue: 0,0:21:02.70,0:21:04.03,Flashbacks-207+,,0,0,0,,İleri!
Dialogue: 0,0:21:06.50,0:21:10.42,Flashbacks-207+,,0,0,0,,20 yıl önce Oden,\NKaido tarafından öldürüldüğünde...{Wano 26 - 27:42}
Dialogue: 0,0:21:10.42,0:21:12.83,Flashbacks-207+,,0,0,0,,bu ülke duraklama çağına girmedi mi?
Dialogue: 0,0:21:12.83,0:21:15.96,Flashbacks-207+,,0,0,0,,Kimse ölürken gülünmeyi hak etmez.{Wano 23 - 05:13}
Dialogue: 0,0:21:15.96,0:21:19.26,Flashbacks-207+,,0,0,0,,Yabancıyım diye ülkeyi kurtaramaz mıyım?{Wano 26 - 26:19}
Dialogue: 0,0:21:19.26,0:21:21.76,Flashbacks-207+,,0,0,0,,Konuşsana! Önemli biri değil miydin?!{Zou 09 - 22:02}
Dialogue: 0,0:21:21.76,0:21:25.14,Flashbacks-207+,,0,0,0,,Bu harika insanların lideri değil misin?!
Dialogue: 0,0:21:25.14,0:21:29.31,Flashbacks-207+,,0,0,0,,Kaido'yu devirmek istiyorum!{Zou 09 - 24:02; Wano 27 - 15:25}
Dialogue: 0,0:21:34.82,0:21:38.32,Main-207+,,0,0,0,,{\fad(150,150)}Lastik-Lastik...
Dialogue: 0,0:21:41.82,0:21:43.20,Main-207+,,0,0,0,,{\fad(150,150)}Kızıl...
Dialogue: 0,0:21:44.53,0:21:45.24,Main-207+,,0,0,0,,{\fad(150,0)}Kaya!
Dialogue: 0,0:22:08.64,0:22:11.27,Main-207+,,0,0,0,,Hey, Kaido! Ne yapıyorsun?!
Dialogue: 0,0:22:11.27,0:22:14.69,Main-207+,,0,0,0,,Sen yere düşmezsin!
Dialogue: 0,0:22:17.40,0:22:20.36,Main-207+,,0,0,0,,Ben, Monkey D. Luffy.
Dialogue: 0,0:22:21.03,0:22:23.28,Main-207+,,0,0,0,,Sizi geride bırakacak...
Dialogue: 0,0:22:26.24,0:22:29.20,Main-207+,,0,0,0,,ve Korsanlar Kralı olacağım!
Comment: 0,0:00:00.00,0:00:00.00,Main-207+,,0,0,0,,{=117}===============================DIALOGUE============================
Comment: 0,0:00:00.00,0:00:00.00,Main-207+,,0,0,0,,{=91}==============================KARAOKE==============================
Dialogue: 0,0:00:01.56,0:00:03.73,Main-207+,,0,0,0,,{\i1}Zenginlik, şöhret, güç...
Dialogue: 0,0:00:03.73,0:00:07.99,Main-207+,,0,0,0,,{\i1\q2}Dünyanın sunabileceği her şeyi elde\Neden adam, Korsanlar Kralı, Gold Roger.
Dialogue: 0,0:00:07.99,0:00:11.70,Main-207+,,0,0,0,,{\i1}Son sözleri dünyanın her yerinden\Nmaceracıları denize çekti.
Dialogue: 0,0:00:11.70,0:00:13.74,Main-207+,,0,0,0,,Hazinem mi?
Dialogue: 0,0:00:13.74,0:00:15.58,Main-207+,,0,0,0,,İstiyorsanız, alabilirsiniz.
Dialogue: 0,0:00:15.58,0:00:16.83,Main-207+,,0,0,0,,Arayıp bulun!
Dialogue: 0,0:00:16.83,0:00:19.46,Main-207+,,0,0,0,,Bu dünyanın sunabileceği her şeyi\Norada bıraktım!
Dialogue: 0,0:00:21.75,0:00:26.55,Main-207+,,0,0,0,,{\i1\q2}Artık herkes, hayallerinin peşinde\NGrand Line'a yelken açıyor!
Dialogue: 0,0:00:26.55,0:00:29.68,Main-207+,,0,0,0,,{\i1}Dünya, Büyük Korsan Çağı'na girdi!
