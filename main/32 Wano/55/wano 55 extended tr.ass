Comment: 0,0:00:00.00,0:00:00.00,Main-207+,,0,0,0,,{=116}===============================DIALOGUE============================
Dialogue: 0,0:01:55.01,0:01:57.68,Main-207+,,0,0,0,,Vay canına!
Dialogue: 0,0:01:58.97,0:02:01.73,Main-207+,,0,0,0,,Siz korsanların ilginç numaraları varmış!
Dialogue: 0,0:02:01.73,0:02:04.02,Main-207+,,0,0,0,,Bana da öğretsene!
Dialogue: 0,0:02:05.31,0:02:06.06,Main-207+,,0,0,0,,Ha?
Dialogue: 0,0:02:06.81,0:02:09.28,Main-207+,,0,0,0,,Şey... Alo?
Dialogue: 0,0:02:10.78,0:02:11.36,Main-207+,,0,0,0,,Ne?!
Dialogue: 0,0:02:11.36,0:02:13.32,Main-207+,,0,0,0,,N-N-N-N-Ne?!
Dialogue: 0,0:02:13.32,0:02:15.16,Main-207+,,0,0,0,,Ace!
Dialogue: 0,0:02:15.16,0:02:16.95,Main-207+,,0,0,0,,N'oldu birdenbire?
Dialogue: 0,0:02:16.95,0:02:20.08,Main-207+,,0,0,0,,Daha demin o kadar eğleniyordun!
Dialogue: 0,0:02:20.95,0:02:22.21,Main-207+,,0,0,0,,Yoksa öl–
Dialogue: 0,0:02:22.96,0:02:28.21,Main-207+,,0,0,0,,Aç gözlerini, Ace!
Dialogue: 0,0:02:31.63,0:02:32.97,Main-207+,,0,0,0,,İçim geçmiş.
Dialogue: 0,0:02:32.97,0:02:36.01,Main-207+,,0,0,0,,Korkutmasana beni! Kalbime iniyordu!
Dialogue: 0,0:02:36.01,0:02:38.39,Main-207+,,0,0,0,,Özür dilerim. İsteyerek olmadı.
Dialogue: 0,0:02:39.76,0:02:41.89,Main-207+,,0,0,0,,Çok endişelendim!
Dialogue: 0,0:02:42.89,0:02:46.02,Main-207+,,0,0,0,,Sen yok musun?\NGeceyi sonlandıralım mı?
Dialogue: 0,0:02:46.02,0:02:48.27,Main-207+,,0,0,0,,Sen de yorulmuşa benziyorsun.
Dialogue: 0,0:02:48.27,0:02:50.07,Main-207+,,0,0,0,,Ne diyorsun, Yamato?
Dialogue: 0,0:02:50.07,0:02:52.65,Main-207+,,0,0,0,,Daha sana anlatacak tonla şeyim var!
Dialogue: 0,0:02:53.40,0:02:57.28,Main-207+,,0,0,0,,Sabahleyin benimkilerle buluşacağım.
Dialogue: 0,0:02:57.28,0:02:59.87,Main-207+,,0,0,0,,Geceyi uyuyarak heba etmeyelim.
Dialogue: 0,0:03:03.00,0:03:05.16,Main-207+,,0,0,0,,Bir daha sızmak yok o zaman!
Dialogue: 0,0:03:05.16,0:03:07.04,Main-207+,,0,0,0,,Özür diledim ya.
Dialogue: 0,0:03:07.04,0:03:09.29,Main-207+,,0,0,0,,Peki nerede kalmıştık?
Dialogue: 0,0:03:09.29,0:03:12.05,Main-207+,,0,0,0,,Yine kardeşini anlatıyordun.
Dialogue: 0,0:03:12.92,0:03:17.43,Main-207+,,0,0,0,,Sen de yine Oden olmak\Nistediğini söylüyordun.
Dialogue: 0,0:03:18.05,0:03:19.35,Main-207+,,0,0,0,,Yanlışın var, Ace.
Dialogue: 0,0:03:19.35,0:03:22.10,Main-207+,,0,0,0,,Olmak istemiyorum, olacağım.
Dialogue: 0,0:03:22.52,0:03:24.81,Main-207+,,0,0,0,,Bir gün gerçek olacak bir hayal.
Dialogue: 0,0:03:24.81,0:03:26.56,Main-207+,,0,0,0,,Bu...
Dialogue: 0,0:03:26.56,0:03:28.40,Main-207+,,0,0,0,,bizim geleceğimiz!
Dialogue: 0,0:03:30.69,0:03:31.82,Main-207+,,0,0,0,,D. mi?
Dialogue: 0,0:03:35.32,0:03:39.57,Main-207+,,0,0,0,,Bir gün seninle tanışacağım\Nhiç aklıma gelmezdi.
Dialogue: 0,0:03:40.03,0:03:42.29,Main-207+,,0,0,0,,"O-Oden"...
Dialogue: 0,0:03:42.91,0:03:44.91,Main-207+,,0,0,0,,Babamın defteri mi o?
Dialogue: 0,0:03:45.46,0:03:51.50,Main-207+,,0,0,0,,Dolu dolu yaşantısı ve dünyayı keşfinin\Ntüm ayrıntıları bu defterde yer alıyor.
Dialogue: 0,0:03:52.63,0:03:56.30,Main-207+,,0,0,0,,Malum gün, bunu Oden Kalesi'nin\Noradaki nehirden aldım.
Dialogue: 0,0:03:57.05,0:04:00.64,Main-207+,,0,0,0,,Biri bunu yangından kurtarmış.
Dialogue: 0,0:04:00.64,0:04:02.26,Main-207+,,0,0,0,,Oden-{\i1}sama{\i0}'nın...
Dialogue: 0,0:04:03.89,0:04:05.22,Main-207+,,0,0,0,,Momonosuke-{\i1}kun{\i0}!
Dialogue: 0,0:04:06.35,0:04:10.19,Main-207+,,0,0,0,,Seninle ilgili de birçok şey yazıyor.
Dialogue: 0,0:04:12.23,0:04:15.11,Main-207+,,0,0,0,,Beyazsakal'ın gemisinde doğmuşsun!
Dialogue: 0,0:04:15.44,0:04:17.24,Main-207+,,0,0,0,,Sonra da Roger'ın gemisine gitmişsin.
Dialogue: 0,0:04:18.49,0:04:19.78,Main-207+,,0,0,0,,Hıhı.
Dialogue: 0,0:04:20.41,0:04:26.70,Main-207+,,0,0,0,,Ama çok küçük olduğumdan\Nhiç hatırlamıyorum.
Dialogue: 0,0:04:26.70,0:04:29.96,Main-207+,,0,0,0,,Beyazsakal, Roger ve Oden.
Dialogue: 0,0:04:29.96,0:04:31.29,Main-207+,,0,0,0,,Ortak bir şey söylediler...
Dialogue: 0,0:04:32.04,0:04:34.50,Main-207+,,0,0,0,,"Bundan en az 20 yıl sonra...
Dialogue: 0,0:04:34.50,0:04:39.26,Main-207+,,0,0,0,,genç ve güçlü korsanlar\Nbirbiri ardına Yeni Dünya'ya gelecek."
Dialogue: 0,0:04:39.26,0:04:40.72,Main-207+,,0,0,0,,O vakit geldi!
Dialogue: 0,0:04:45.47,0:04:49.14,Main-207+,,0,0,0,,Onların başının da\NAce olacağına inanıyordum.
Dialogue: 0,0:04:50.44,0:04:54.27,Main-207+,,0,0,0,,Ama o öldüğünde bir şeyi hatırladım.
Dialogue: 0,0:04:55.11,0:04:56.57,Main-207+,,0,0,0,,O gece dediği bir şeyi!
Dialogue: 0,0:04:59.57,0:05:00.20,Main-207+,,0,0,0,,Ne...?
Dialogue: 0,0:05:02.78,0:05:04.16,Main-207+,,0,0,0,,Hass...
Dialogue: 0,0:05:04.16,0:05:05.74,Main-207+,,0,0,0,,Ağzımdan kaçırdım!
Dialogue: 0,0:05:05.74,0:05:08.45,Main-207+,,0,0,0,,Yanlışlıkla söyledim.
Dialogue: 0,0:05:08.45,0:05:10.16,Main-207+,,0,0,0,,Bunu demedim sayalım!
Dialogue: 0,0:05:10.71,0:05:12.71,Main-207+,,0,0,0,,Bak gülme,
Dialogue: 0,0:05:12.71,0:05:14.79,Main-207+,,0,0,0,,Sabo'yla ben çok kızarız.
Dialogue: 0,0:05:16.00,0:05:19.51,Main-207+,,0,0,0,,{\i1}Bu ülkeden hiç çıkmadım.
Dialogue: 0,0:05:19.51,0:05:23.80,Main-207+,,0,0,0,,Kendi gözlerimle gördüğüm hiçbir şey yok.
Dialogue: 0,0:05:24.39,0:05:28.93,Main-207+,,0,0,0,,Ace'in kardeşi olsun,\NOden'in gezdiği geniş dünya olsun...
Dialogue: 0,0:05:30.56,0:05:33.15,Main-207+,,0,0,0,,Ama o an gözlerim...
Dialogue: 0,0:05:33.15,0:05:35.11,Main-207+,,0,0,0,,{\i1}net biçimde bir şey gördü!
Dialogue: 0,0:05:35.98,0:05:39.82,Main-207+,,0,0,0,,Kardeşimin hayali bu.
Dialogue: 0,0:05:44.07,0:05:46.58,Main-207+,,0,0,0,,{\3c&H5C4714&\4c&H56460A&}Bir gün denize açılalım!
Dialogue: 0,0:05:47.08,0:05:50.58,Main-207+,,0,0,0,,{\3c&H5C4714&\4c&H56460A&}Bu ülkeden kurtulup özgürce yaşayalım!
Dialogue: 0,0:05:50.58,0:05:55.88,Main-207+,,0,0,0,,{\3c&H5C4714&\4c&H56460A&}Geniş dünyayı görmek ve bu konuda\Nbir kitap yazmak istiyorum.
Dialogue: 0,0:05:55.88,0:05:58.88,Main-207+,,0,0,0,,{\3c&H5C4714&\4c&H56460A&}Rotacılık dersi verseler\Nhiç sıkılmadan çalışırım.
Dialogue: 0,0:05:58.88,0:06:02.05,Main-207+,,0,0,0,,{\3c&H5C4714&\4c&H56460A&}Kendimizi geliştirip\Ngünün birinde korsan olalım!
Dialogue: 0,0:06:04.30,0:06:07.51,Main-207+,,0,0,0,,{\3c&H5C4714&\4c&H56460A&}Söylemesen olmayacaktım sanki.
Dialogue: 0,0:06:07.93,0:06:14.06,Main-207+,,0,0,0,,{\3c&H5C4714&\4c&H56460A&}Korsanlığa soyunup önüme geleni yenecek\Nve en büyük ben olacağım!
Dialogue: 0,0:06:14.06,0:06:17.27,Main-207+,,0,0,0,,{\3c&H5C4714&\4c&H56460A&}Yaşadığımın kanıtı olur işte.
Dialogue: 0,0:06:17.94,0:06:23.15,Main-207+,,0,0,0,,{\3c&H5C4714&\4c&H56460A&}Tüm dünya varlığımı reddetse de\Nbenden nefret etse de...
Dialogue: 0,0:06:23.53,0:06:26.28,Main-207+,,0,0,0,,{\3c&H5C4714&\4c&H56460A&}yine de tarihe geçecek\Nbir korsan olacağım!
Dialogue: 0,0:06:27.58,0:06:31.50,Main-207+,,0,0,0,,{\3c&H060661&\4c&H02033E&}Hükûmet diyor ki koca bir hazinenin yattığı...{Wano 37 - 23:41}
Dialogue: 0,0:06:31.50,0:06:34.37,Main-207+,,0,0,0,,{\3c&H060661&\4c&H02033E&}son adaya gitmeyin.
Dialogue: 0,0:06:35.33,0:06:38.79,Main-207+,,0,0,0,,{\3c&H060661&\4c&H02033E&}Bu da insanı daha çok çekiyor.{Wano 37 - 23:48}
Dialogue: 0,0:06:39.17,0:06:42.80,Main-207+,,0,0,0,,{\3c&H060661&\4c&H02033E&}Oraya ulaşırsak namımız alır başını gider.{Wano 37 - 23:50}
Dialogue: 0,0:06:42.80,0:06:45.26,Main-207+,,0,0,0,,{\3c&H060661&\4c&H02033E&}Dünyanın en büyüğü oluruz!{Wano 37- 23:54}
Dialogue: 0,0:06:45.76,0:06:47.51,Main-207+,,0,0,0,,{\3c&H060661&\4c&H02033E&}Dünyanın en büyüğü mü?
Dialogue: 0,0:06:49.51,0:06:51.22,Main-207+,,0,0,0,,{\3c&H5C4714&\4c&H56460A&}Çok iyi!
Dialogue: 0,0:06:51.22,0:06:53.39,Main-207+,,0,0,0,,{\3c&H5C4714&\4c&H56460A&}O zaman...
Dialogue: 0,0:06:53.39,0:06:55.06,Main-207+,,0,0,0,,{\3c&H060661&\4c&H02033E&}Evet,
Dialogue: 0,0:06:55.06,0:06:56.73,Main-207+,,0,0,0,,{\3c&H060661&\4c&H02033E&}o zaman...
Dialogue: 0,0:06:58.90,0:07:02.53,Main-207+,,0,0,0,,{\3c&H060661&\4c&H02033E&\t(853,3063,\3cH00000&\4c&H00000&)}– ...ben de...\N{\3c&H5C4714&\4c&H56460A&\t(853,3063,\3cH00000&\4c&H00000&)}– Ben de...
Dialogue: 0,0:07:06.78,0:07:09.66,Main-207+,,0,0,0,,Ciddi ciddi dinliyorum bir de.
Dialogue: 0,0:07:09.66,0:07:11.66,Main-207+,,0,0,0,,Çocukça bir düş bu!{Wano 37 - 24:48}
Dialogue: 0,0:07:13.41,0:07:15.92,Main-207+,,0,0,0,,Bayılıyorum sana, Luffy.
Dialogue: 0,0:07:15.92,0:07:19.04,Main-207+,,0,0,0,,Nasıl biri olacağını görmek için can atıyorum.
Dialogue: 0,0:07:27.22,0:07:32.10,Main-207+,,0,0,0,,Luffy bunu dediğinde Sabo'yla gülmüştük.
Dialogue: 0,0:07:32.10,0:07:35.48,Main-207+,,0,0,0,,Ama başkasının gülmesine izin vermeyiz.
Dialogue: 0,0:07:35.48,0:07:37.10,Main-207+,,0,0,0,,Ona inanıyoruz çünkü.
Dialogue: 0,0:07:37.10,0:07:40.86,Main-207+,,0,0,0,,Onda bu potansiyel var, bu yüzden–
Dialogue: 0,0:07:40.86,0:07:41.86,Main-207+,,0,0,0,,Ace!
Dialogue: 0,0:07:43.73,0:07:44.49,Main-207+,,0,0,0,,Ha?
Dialogue: 0,0:07:45.36,0:07:46.49,Main-207+,,0,0,0,,Hey!
Dialogue: 0,0:07:46.49,0:07:47.99,Main-207+,,0,0,0,,Neyin var, Yamato?
Dialogue: 0,0:07:50.87,0:07:53.70,Main-207+,,0,0,0,,Ben gülmeyeceğim.
Dialogue: 0,0:07:54.58,0:07:58.29,Thoughts-207+,,0,0,0,,Korsanlar Kralı da aynısını demişti!
Dialogue: 0,0:07:58.29,0:08:01.09,Thoughts-207+,,0,0,0,,Oden de çok etkilenmişti!
Dialogue: 0,0:08:02.09,0:08:07.30,Main-207+,,0,0,0,,Yolculuğu sırasında Kozuki Oden de\Naynısını diyen büyük bir adam görmüş.
Dialogue: 0,0:08:07.30,0:08:08.93,Main-207+,,0,0,0,,Hayatta gülmem!
Dialogue: 0,0:08:08.93,0:08:10.93,Main-207+,,0,0,0,,Kardeşin inanılmaz biri!
Dialogue: 0,0:08:12.81,0:08:14.43,Main-207+,,0,0,0,,Büyük adam ha?
Dialogue: 0,0:08:14.43,0:08:15.93,Main-207+,,0,0,0,,İyiymiş.
Dialogue: 0,0:08:15.93,0:08:19.40,Main-207+,,0,0,0,,Luffy'yle beraber\Nbir gün onunla içeriz umarım.
Dialogue: 0,0:08:20.56,0:08:22.61,Main-207+,,0,0,0,,Aranızdan su sızmazdı kesin.
Dialogue: 0,0:08:23.32,0:08:24.57,Main-207+,,0,0,0,,Çoktan ölmeseydi.
Dialogue: 0,0:08:24.57,0:08:25.65,Main-207+,,0,0,0,,Öldü mü?
Dialogue: 0,0:08:27.19,0:08:30.49,Main-207+,,0,0,0,,Yazık oldu. Kadeh tokuşturamayacağız.
Dialogue: 0,0:08:31.70,0:08:32.49,Main-207+,,0,0,0,,Hayırdır?
Dialogue: 0,0:08:32.99,0:08:34.49,Main-207+,,0,0,0,,Şimdi ne var?
Dialogue: 0,0:08:35.12,0:08:36.37,Main-207+,,0,0,0,,Şey,
Dialogue: 0,0:08:36.37,0:08:38.46,Main-207+,,0,0,0,,onun yerine ben gelsem olur mu?
Dialogue: 0,0:08:39.04,0:08:42.29,Main-207+,,0,0,0,,Sen, kardeşin ve ben!
Dialogue: 0,0:08:42.29,0:08:45.05,Main-207+,,0,0,0,,Ne bileyim, bir gün denize açılırsam falan...
Dialogue: 0,0:08:45.05,0:08:46.67,Main-207+,,0,0,0,,Bomba olur.
Dialogue: 0,0:08:46.67,0:08:47.67,Main-207+,,0,0,0,,Sahiden mi?
Dialogue: 0,0:08:47.67,0:08:50.68,Main-207+,,0,0,0,,Peki Yamato,\Ndeniz ne kadar büyük biliyor musun?
Dialogue: 0,0:08:50.68,0:08:54.43,Main-207+,,0,0,0,,Elini çabuk tutmazsan\Nbirbirimizi bir daha göremeyiz.
Dialogue: 0,0:08:54.43,0:08:55.43,Main-207+,,0,0,0,,O hâlde Ace,
Dialogue: 0,0:08:55.43,0:08:57.68,Main-207+,,0,0,0,,tırnağından bir parça veya...
Dialogue: 0,0:08:57.68,0:08:59.48,Main-207+,,0,0,0,,bir tutam saçını verir misin?
Dialogue: 0,0:08:59.48,0:09:00.77,Main-207+,,0,0,0,,Ha?!
Dialogue: 0,0:09:00.77,0:09:03.27,Main-207+,,0,0,0,,İkisinden birini ver işte!
Dialogue: 0,0:09:03.27,0:09:04.27,Main-207+,,0,0,0,,Tamam.
Dialogue: 0,0:09:05.40,0:09:06.57,Main-207+,,0,0,0,,Heh?
Dialogue: 0,0:09:11.82,0:09:12.57,Main-207+,,0,0,0,,Bitirdim.
Dialogue: 0,0:09:12.57,0:09:13.24,Main-207+,,0,0,0,,Oh?
Dialogue: 0,0:09:13.24,0:09:15.20,Main-207+,,0,0,0,,Bu senin vivre kartın.
Dialogue: 0,0:09:16.20,0:09:17.95,Main-207+,,0,0,0,,Bu muymuş?
Dialogue: 0,0:09:19.71,0:09:21.29,Main-207+,,0,0,0,,Bildiğin kağıt parçası bu ya.
Dialogue: 0,0:09:21.92,0:09:27.09,Main-207+,,0,0,0,,Evet, bu kağıt parçası\Nbizi tekrar bir araya getirecek.
Dialogue: 0,0:09:27.09,0:09:28.42,Main-207+,,0,0,0,,Nasıl olacak o iş?
Dialogue: 0,0:09:29.09,0:09:29.97,Main-207+,,0,0,0,,Bak.
Dialogue: 0,0:09:35.22,0:09:40.06,Main-207+,,0,0,0,,Ayrılmak istemediğin ya da tekrar görmek\Nistediğin birine bundan bir parça ver.
Dialogue: 0,0:09:40.73,0:09:41.60,Main-207+,,0,0,0,,Anladım!
Dialogue: 0,0:09:41.60,0:09:43.48,Main-207+,,0,0,0,,Öyle yaparım.
Dialogue: 0,0:09:59.25,0:10:00.66,Main-207+,,0,0,0,,Yamato!
Dialogue: 0,0:10:03.75,0:10:05.88,Main-207+,,0,0,0,,Sakın kaybetme onu!
Dialogue: 0,0:10:22.27,0:10:24.94,Main-207+,,0,0,0,,Ace!
Dialogue: 0,0:10:32.44,0:10:34.11,Main-207+,,0,0,0,,Yamato?!
Dialogue: 0,0:10:38.49,0:10:40.58,Main-207+,,0,0,0,,Tekrar görüşelim...
Dialogue: 0,0:10:40.95,0:10:43.54,Main-207+,,0,0,0,,Ace!
Dialogue: 0,0:10:51.17,0:10:53.17,Main-207+,,0,0,0,,Elbette!
Dialogue: 0,0:11:00.06,0:11:01.06,Main-207+,,0,0,0,,{\i1}Ama...
Dialogue: 0,0:11:01.97,0:11:04.02,Main-207+,,0,0,0,,{\i1}bu onu son görüşümdü.
Dialogue: 0,0:11:13.07,0:11:15.86,Main-207+,,0,0,0,,Hıyar oğlan gene rahat durmuyor.
Dialogue: 0,0:11:15.86,0:11:20.70,Main-207+,,0,0,0,,Neyse, Kızıl Saç yüzünden\Nşu an boş vaktim var.
Dialogue: 0,0:11:21.16,0:11:24.25,Main-207+,,0,0,0,,Öfke krizini ben bastırırım.
Dialogue: 0,0:11:28.46,0:11:31.92,Main-207+,,0,0,0,,Tekrar uğrayacağını söylemiştin.
Dialogue: 0,0:11:37.13,0:11:39.85,Main-207+,,0,0,0,,Neye tutunduğunun önemi yok.
Dialogue: 0,0:11:55.86,0:11:59.03,Main-207+,,0,0,0,,Nasıl olsa bu adadan...
Dialogue: 0,0:11:59.03,0:12:00.74,Main-207+,,0,0,0,,gidemez.
Dialogue: 0,0:12:06.66,0:12:09.21,Main-207+,,0,0,0,,Bu adadan ayrılamıyorum!
Dialogue: 0,0:12:09.21,0:12:12.67,Main-207+,,0,0,0,,Babamın hakkından gelemiyorum!
Dialogue: 0,0:12:14.84,0:12:17.55,Main-207+,,0,0,0,,Tek arkadaşımı...
Dialogue: 0,0:12:18.34,0:12:21.26,Main-207+,,0,0,0,,gidip kurtaramıyorum.
Dialogue: 0,0:12:22.01,0:12:23.43,Main-207+,,0,0,0,,Ben...
Dialogue: 0,0:12:25.22,0:12:27.35,Main-207+,,0,0,0,,özgür değilim.
Dialogue: 0,0:12:28.89,0:12:31.31,Flashbacks-207+,,0,0,0,,Ne diye kalbine de zincir vurduruyorsun?{Wano 54 - 17:15}
Dialogue: 0,0:12:32.56,0:12:34.48,Main-207+,,0,0,0,,Ben de...
Dialogue: 0,0:12:34.48,0:12:37.78,Main-207+,,0,0,0,,Oden gibi özgürce yaşamak istiyorum...
Dialogue: 0,0:12:38.78,0:12:40.07,Main-207+,,0,0,0,,Ace...
Dialogue: 0,0:12:42.41,0:12:45.79,Flashbacks-207+,,0,0,0,,Bundan en az 20 yıl sonra...
Dialogue: 0,0:12:45.79,0:12:52.00,Flashbacks-207+,,0,0,0,,gelecek çağa öncülük edecek genç ve güçlü korsanlar, birbiri ardına Yeni Dünya'ya gelecek.
Dialogue: 0,0:12:52.42,0:12:56.51,Flashbacks-207+,,0,0,0,,Ama en adından söz edilecek adam\Nbirkaç yıla gelecek.{Wano 54 - 19:57}
Dialogue: 0,0:12:57.05,0:12:59.22,Flashbacks-207+,,0,0,0,,Kardeşim olur kendisi!{Wano 54 - 20:01}
Dialogue: 0,0:13:03.80,0:13:05.51,Main-207+,,0,0,0,,Geri dön, Yamato.
Dialogue: 0,0:13:07.60,0:13:12.56,Thoughts-207+,,0,0,0,,Kozuki Oden'in beklediği şeyi\Nben de bekleyeceğim.
Dialogue: 0,0:13:13.19,0:13:15.65,Main-207+,,0,0,0,,Lütfen geri dönün, Genç Efendi Yamato!
Dialogue: 0,0:13:16.03,0:13:18.78,Thoughts-207+,,0,0,0,,Gelecek çağı bekleyeceğim.
Dialogue: 0,0:13:18.78,0:13:20.07,Thoughts-207+,,0,0,0,,Ne kadar sürerse sürsün.
Dialogue: 0,0:13:21.41,0:13:22.78,Main-207+,,0,0,0,,Luffy,
Dialogue: 0,0:13:22.78,0:13:24.74,Main-207+,,0,0,0,,seni bekleyeceğim.
Dialogue: 0,0:13:24.74,0:13:26.95,Thoughts-207+,,0,0,0,,Ama o güne kadar ben...
Dialogue: 0,0:13:28.45,0:13:31.17,Main-207+,,0,0,0,,Laftan anladığın yoksa...
Dialogue: 0,0:13:31.67,0:13:35.50,Main-207+,,0,0,0,,kafana vura vura sokacağım, Yamato.
Dialogue: 0,0:13:35.50,0:13:38.76,Main-207+,,0,0,0,,...asla yılmayacağım!
Dialogue: 0,0:13:47.31,0:13:48.97,Flashbacks-207+,,0,0,0,,Ha şöyle, Yamato!{Wano 54 - 18:44}
Dialogue: 0,0:13:48.97,0:13:53.77,Main-207+,,0,0,0,,Ben Oden'im, uyuz ihtiyar!
Dialogue: 0,0:13:56.90,0:14:02.28,Main-207+,,0,0,0,,O gün dış dünyada\Nneler olup bittiğini bilmesem de...
Dialogue: 0,0:14:02.91,0:14:05.74,Main-207+,,0,0,0,,olanları daha sonra gazeteden okudum.
Dialogue: 0,0:14:06.24,0:14:10.87,Main-207+,,0,0,0,,Ace'in Korsanlar Kralı\NGol D. Roger'ın oğlu olduğunu...
Dialogue: 0,0:14:11.62,0:14:16.34,Main-207+,,0,0,0,,ve kardeşinin cidden korsan olup\Nnam yaptığını öğrendim.
Dialogue: 0,0:14:16.34,0:14:19.30,Main-207+,,0,0,0,,Kardeşi senin buraya getirdiğin Luffy!
Dialogue: 0,0:14:21.17,0:14:22.55,Main-207+,,0,0,0,,Momonosuke-{\i1}kun{\i0}.
Dialogue: 0,0:14:24.26,0:14:27.39,Main-207+,,0,0,0,,Hakkın olarak bunu sana veriyorum.
Dialogue: 0,0:14:28.76,0:14:32.31,Main-207+,,0,0,0,,Oden'in gelecek ile ilgili kaleme aldıkları bunlar...
Comment: 0,0:14:32.31,0:14:32.31,Main-207+,,0,0,0,,{=26}=== Oden Future Typesetting ===
