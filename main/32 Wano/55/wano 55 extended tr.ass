Comment: 0,0:14:32.52,0:14:35.52,Main-207+,,0,0,0,,{=27}=== Oden Future Typesetting ===
Dialogue: 0,0:14:36.02,0:14:38.98,Main-207+,,0,0,0,,"Bundan en az 20 yıl sonra...
Dialogue: 0,0:14:42.95,0:14:46.32,Main-207+,,0,0,0,,gelecek çağa öncülük edecek\Ngenç ve güçlü korsanlar...
Dialogue: 0,0:14:46.95,0:14:49.20,Main-207+,,0,0,0,,birbiri ardına Yeni Dünya'ya gelecek."
Dialogue: 0,0:14:51.37,0:14:53.29,Main-207+,,0,0,0,,"Şayet ölürsem...
Dialogue: 0,0:14:56.58,0:14:59.92,Main-207+,,0,0,0,,Kaido'yu onlar devirecek!"
Dialogue: 0,0:15:03.63,0:15:06.09,Main-207+,,0,0,0,,One Piece...
Dialogue: 0,0:15:08.30,0:15:14.48,Main-207+,,0,0,0,,Siz onun için yarışmanın\Nhayalini bile kuramazsınız.
Dialogue: 0,0:15:18.44,0:15:22.94,Main-207+,,0,0,0,,Hâlâ korsancılık mı oynamak istiyorsunuz?
Dialogue: 0,0:15:22.94,0:15:26.91,Main-207+,,0,0,0,,Ders vermede berbatsın, Kaido.
Dialogue: 0,0:15:26.91,0:15:28.32,Main-207+,,0,0,0,,Bırak ben yapayım.
Dialogue: 0,0:15:34.08,0:15:36.04,Main-207+,,0,0,0,,Evet, biliyorum Killer...
Dialogue: 0,0:15:36.67,0:15:39.38,Main-207+,,0,0,0,,Hislerini anlıyorum.
Dialogue: 0,0:15:40.25,0:15:42.88,Main-207+,,0,0,0,,Sizin için bunca şey getirdim!
Dialogue: 0,0:15:46.30,0:15:49.76,Main-207+,,0,0,0,,Kabul edin, Yonkolar!
Dialogue: 0,0:16:03.90,0:16:05.65,Main-207+,,0,0,0,,Işığı gören geliyor!
Dialogue: 0,0:16:05.65,0:16:07.61,Main-207+,,0,0,0,,Pek bir başına buyruksun.
Dialogue: 0,0:16:07.61,0:16:09.74,Main-207+,,0,0,0,,Tüm Hasır Şapkalar böyle mi?
Dialogue: 0,0:16:09.74,0:16:12.62,Main-207+,,0,0,0,,Suçlusu ben değilim.
Dialogue: 0,0:16:12.62,0:16:15.70,Main-207+,,0,0,0,,En başına buyruğu göremiyorum.
Dialogue: 0,0:16:15.70,0:16:17.21,Main-207+,,0,0,0,,Hasır Şapka-{\i1}ya{\i0} nerede?
Dialogue: 0,0:16:22.46,0:16:24.21,Main-207+,,0,0,0,,Sayıları artıp duruyor.
Dialogue: 0,0:16:24.21,0:16:26.59,Main-207+,,0,0,0,,En Kötü Nesil değil mi bunlar?
Dialogue: 0,0:16:26.59,0:16:30.64,Main-207+,,0,0,0,,Rüzgârda uçan toz gibi dağılacaklar.
Dialogue: 0,0:16:33.85,0:16:38.14,Main-207+,,0,0,0,,Siz bu yarayı açacak seviyede değilsiniz.
Dialogue: 0,0:16:41.23,0:16:45.94,Main-207+,,0,0,0,,Usulca geri çekilin çaylak bozuntuları.
Dialogue: 0,0:16:45.94,0:16:48.95,Main-207+,,0,0,0,,Kızıl Kınlar gibi.
Dialogue: 0,0:16:58.87,0:17:03.04,Flashbacks-207+,,0,0,0,,Bundan en az 20 yıl sonra...{this ep - 14:36}
Dialogue: 0,0:17:07.17,0:17:14.22,Flashbacks-207+,,0,0,0,,gelecek çağa öncülük edecek genç ve güçlü korsanlar, birbiri ardına Yeni Dünya'ya gelecek.
Dialogue: 0,0:17:15.85,0:17:18.23,Flashbacks-207+,,0,0,0,,Şayet ölürsem...
Dialogue: 0,0:17:18.23,0:17:18.35,Flashbacks-207+,,0,0,0,,{\clip(m 762 980 l 794 1000 818 1014 844 1020 880 1038 904 1038 960 1014 906 994 872 944 1132 932 1128 942 1126 950 1096 984 1164 952 1192 926 1202 918 1238 910 1252 894 1514 878 1708 1016 1584 1046 880 1072 578 1064 430 1064 404 862)}Şayet ölürsem...
Dialogue: 0,0:17:18.35,0:17:18.43,Flashbacks-207+,,0,0,0,,{\clip(m 1319.38 1063.34 l 1322.71 1044.83 1338.26 1012.62 1354.92 980.4 1360.48 967.82 1354.55 951.16 1312.71 947.82 1249.39 969.3 1238.28 947.08 1211.62 954.49 1207.54 994.1 1197.18 1017.43 1186.44 1030.39 1174.22 1038.53 1184.96 1057.04 1186.07 1064.45 812.75 1074.95 801.83 1065.1 776.94 1055.99 761.6 1046.43 760.49 1040.43 769.16 1023.53 773.38 1014.2 743.37 1008.86 711.14 998.63 693.8 986.85 676.01 968.62 644 948.39 631.77 938.83 626.66 937.05 623.77 941.28 627.11 949.28 638.44 963.73 645.34 972.4 644.22 973.07 622.44 958.39 586.48 926.2 554.37 927.04 523.1 1063.1)}Şayet ölürsem...
Dialogue: 0,0:17:22.35,0:17:25.11,Flashbacks-207+,,0,0,0,,Kaido'yu...
Dialogue: 0,0:17:26.78,0:17:28.74,Flashbacks-207+,,0,0,0,,onlar devirecek!
Dialogue: 0,0:17:29.36,0:17:31.36,Main-207+,,0,0,0,,Biri daha geldi.
Dialogue: 0,0:17:31.36,0:17:33.62,Main-207+,,0,0,0,,Siz oturun, ben hallederim.
Dialogue: 0,0:17:33.62,0:17:34.83,Main-207+,,0,0,0,,Reddediyorum.
Dialogue: 0,0:17:34.12,0:17:34.83,Secondary-207+,,0,0,0,,Ben de.
Dialogue: 0,0:17:35.49,0:17:37.79,Main-207+,,0,0,0,,Kellesini almalık ne çok kişi geldi.
Dialogue: 0,0:17:40.37,0:17:42.50,Main-207+,,0,0,0,,Hasır Şapka.
Dialogue: 0,0:17:59.43,0:18:00.68,Main-207+,,0,0,0,,Linlin!
Dialogue: 0,0:18:00.68,0:18:04.44,Main-207+,,0,0,0,,Bil bakalım bu velet karşıma geçip\Nne olacağım demiştir.
Dialogue: 0,0:18:04.44,0:18:06.94,Main-207+,,0,0,0,,Küstahın teki.
Dialogue: 0,0:18:07.36,0:18:10.94,Main-207+,,0,0,0,,Bana da haddini aşan sözler söyledi.
Dialogue: 0,0:18:10.94,0:18:14.57,Main-207+,,0,0,0,,Kalemi de yerle bir etti.
Dialogue: 0,0:18:14.57,0:18:18.08,Main-207+,,0,0,0,,Önce özür dile, Hasır Şapka.
Dialogue: 0,0:18:22.96,0:18:24.50,Main-207+,,0,0,0,,Lan velet.
Dialogue: 0,0:18:24.96,0:18:28.80,Main-207+,,0,0,0,,Karşımızdayken...
Dialogue: 0,0:18:28.80,0:18:33.59,Main-207+,,0,0,0,,ne olacaksın bir daha söyle hele!
Dialogue: 0,0:18:38.81,0:18:42.06,Flashbacks-207+,,0,0,0,,Size güveniyoruz...{Wano 30 - 22:01}
Dialogue: 0,0:18:44.69,0:18:45.85,Flashbacks-207+,,0,0,0,,Luffy-{\i1}dono{\i0}!
Dialogue: 0,0:18:50.36,0:18:52.32,Flashbacks-207+,,0,0,0,,Minnettarız!
Dialogue: 0,0:19:01.75,0:19:04.33,Main-207+,,0,0,0,,İyi misin, Kin'emon?
Dialogue: 0,0:19:05.46,0:19:07.75,Main-207+,,0,0,0,,Özür dilerim.
Dialogue: 0,0:19:08.79,0:19:10.34,Main-207+,,0,0,0,,Geç kaldım.
Dialogue: 0,0:19:17.80,0:19:20.22,Main-207+,,0,0,0,,P... Perişanım.
Dialogue: 0,0:19:23.52,0:19:25.48,Main-207+,,0,0,0,,Öteki...
Dialogue: 0,0:19:26.02,0:19:27.81,Main-207+,,0,0,0,,dünyada...
Dialogue: 0,0:19:28.36,0:19:32.53,Main-207+,,0,0,0,,efendime bakacak yüzüm... yok!
Dialogue: 0,0:19:33.90,0:19:34.74,Main-207+,,0,0,0,,Kin'e–
Dialogue: 0,0:19:37.07,0:19:39.95,Main-207+,,0,0,0,,Wano'ya...{Wano 56 16:51}
Dialogue: 0,0:19:41.33,0:19:43.75,Main-207+,,0,0,0,,sahip çıkar mısın?
Dialogue: 0,0:19:46.00,0:19:46.62,Main-207+,,0,0,0,,Ya–
Dialogue: 0,0:19:46.62,0:19:47.75,Main-207+,,0,0,0,,Aptal!
Dialogue: 0,0:19:47.75,0:19:49.29,Main-207+,,0,0,0,,Elbette çıkarım!
Dialogue: 0,0:19:50.79,0:19:52.59,Main-207+,,0,0,0,,Burası dostlarımın ülkesi!
Dialogue: 0,0:19:59.18,0:20:01.43,Main-207+,,0,0,0,,Lan velet.
Dialogue: 0,0:20:03.68,0:20:06.69,Thoughts-207+,,0,0,0,,Luffy-dono...
Dialogue: 0,0:20:07.85,0:20:11.02,Thoughts-207+,,0,0,0,,minnettarım.
Dialogue: 0,0:20:12.77,0:20:13.57,Main-207+,,0,0,0,,Trao!
Dialogue: 0,0:20:13.57,0:20:15.99,Main-207+,,0,0,0,,Hepsini aşağıya yolla!{Wano 56 - 04:55}
Dialogue: 0,0:20:21.24,0:20:23.70,Main-207+,,0,0,0,,Yine ne sarsıntısı bu?
Dialogue: 0,0:20:24.29,0:20:25.70,Main-207+,,0,0,0,,Luffy...
Dialogue: 0,0:20:29.17,0:20:34.63,Flashbacks-207+,,0,0,0,,Sizin haki dediğiniz şey\NWano'da {\i1}ryuo{\i0} olarak biliniyor.{Wano 21 - 08:26}
Dialogue: 0,0:20:34.63,0:20:37.51,Flashbacks-207+,,0,0,0,,"Akış" anlamına geliyor.
Dialogue: 0,0:20:37.51,0:20:40.72,Flashbacks-207+,,0,0,0,,Oden-{\i1}sama{\i0} idam edildi!{Zou 09 - 13:58}
Dialogue: 0,0:20:40.72,0:20:44.93,Flashbacks-207+,,0,0,0,,Wano şogunu tarafından,\Nkorsan Kaido'nun da yardımıyla...
Comment: 0,0:20:44.93,0:20:44.93,Main-207+,,0,0,0,,{=44}=== By the shogun of Wano and the pirate Kaido! ===
