Comment: 0,0:00:00.00,0:00:00.00,Main-207+,,0,0,0,,{=29}===============================DIALOGUE============================
Dialogue: 0,0:01:47.35,0:01:51.84,Main-207+,,0,0,0,,Cevap vermen için son şansın.
Dialogue: 0,0:01:53.21,0:01:56.51,Main-207+,,0,0,0,,Kimsin ve burada ne yapıyorsun?
Dialogue: 0,0:01:58.17,0:02:01.80,Main-207+,,0,0,0,,Dürüst olursan\Nölümün hemen ve acısız olur.
Dialogue: 0,0:02:05.85,0:02:11.67,Main-207+,,0,0,0,,Eğer olmazsan dayanılmaz bir işkenceye maruz kalacaksın.
Dialogue: 0,0:02:14.43,0:02:15.61,Main-207+,,0,0,0,,Benim adım...
Dialogue: 0,0:02:17.09,0:02:18.70,Main-207+,,0,0,0,,İblis Saati Çocuğu.
Dialogue: 0,0:02:19.91,0:02:24.74,Main-207+,,0,0,0,,Çiçek Başkenti'nde finansın\Nnasıl aktığını araştırıyordum.
Dialogue: 0,0:02:29.57,0:02:30.79,Main-207+,,0,0,0,,Anlıyorum.
Dialogue: 0,0:02:30.79,0:02:35.55,Main-207+,,0,0,0,,Yani bir sonraki hedefini belirlemeye çalıştığını mı söylüyorsun?
Dialogue: 0,0:02:37.27,0:02:39.48,Main-207+,,0,0,0,,Akıllıca.
Dialogue: 0,0:02:39.48,0:02:44.31,Main-207+,,0,0,0,,Ancak, bize gerçek ismini vermediğini biliyoruz!
Dialogue: 0,0:03:01.70,0:03:03.61,Main-207+,,0,0,0,,Kaçamazsın!
Dialogue: 0,0:03:04.12,0:03:07.79,Main-207+,,0,0,0,,Hareketlerin, sıradan bir geyşa olmadığını kanıtlıyor.
Dialogue: 0,0:03:07.79,0:03:14.10,Main-207+,,0,0,0,,İblis Saati ismini kullanarak\Ngerçek kimliğini gizliyorsun.
Dialogue: 0,0:03:14.10,0:03:15.34,Main-207+,,0,0,0,,Soğukkanlısın!
Dialogue: 0,0:03:15.34,0:03:20.51,Main-207+,,0,0,0,,Kesinlikle. İblis Saati Çocuğu\Naz önce başkentte görüldü.
Dialogue: 0,0:03:24.33,0:03:26.47,Main-207+,,0,0,0,,Tekrar soruyorum...
Dialogue: 0,0:03:26.85,0:03:31.23,Main-207+,,0,0,0,,Kimsin sen? Burada ne yapıyordun?
Dialogue: 0,0:03:32.94,0:03:36.39,Main-207+,,0,0,0,,İşkence görmeye bu kadar\Nmeraklı olduğunu bilmiyordum.
Dialogue: 0,0:03:37.23,0:03:38.73,Main-207+,,0,0,0,,Öyle olsun.
Dialogue: 0,0:03:45.33,0:03:46.53,Main-207+,,0,0,0,,Başlayın!
Dialogue: 0,0:04:06.19,0:04:06.76,Main-207+,,0,0,0,,Ne?!
Dialogue: 0,0:04:06.76,0:04:08.19,Main-207+,,0,0,0,,Kayboldu?!
Dialogue: 0,0:04:08.19,0:04:09.77,Main-207+,,0,0,0,,Nereye gitti?
Dialogue: 0,0:04:12.23,0:04:15.91,Thoughts-207+,,0,0,0,,Klon kullanmasaydım durum çok kötü olabilirdi.
Dialogue: 0,0:04:17.43,0:04:18.40,Main-207+,,0,0,0,,Ben Orobi.
Dialogue: 0,0:04:19.13,0:04:22.39,Main-207+,,0,0,0,,{\i1}Onami! Shinobu-san! Kemikichi!
Dialogue: 0,0:04:23.25,0:04:25.53,Main-207+,,0,0,0,,{\i1}Üzgünüm. Düşman beni fark etti!
Dialogue: 0,0:04:25.53,0:04:26.29,Main-207+,,0,0,0,,– Ne?\N– Ne?
Dialogue: 0,0:04:26.29,0:04:27.83,Main-207+,,0,0,0,,Robin'i fark ettiler mi?
Dialogue: 0,0:04:27.83,0:04:30.54,Main-207+,,0,0,0,,Olamaz! Bu hiç iyi olmadı!
Dialogue: 0,0:04:30.93,0:04:33.41,Main-207+,,0,0,0,,Orobi-{\i1}san{\i0}'ı fark ettiklerine şaşırdım doğrusu!
Dialogue: 0,0:04:33.41,0:04:38.34,Main-207+,,0,0,0,,Kalede ninjalar var! En az 11 kişiler!
Dialogue: 0,0:04:38.34,0:04:40.25,Main-207+,,0,0,0,,11 Ninja mı?!
Dialogue: 0,0:04:41.33,0:04:43.09,Main-207+,,0,0,0,,Fukurokuju!
Dialogue: 0,0:04:43.09,0:04:46.23,Main-207+,,0,0,0,,Fukurokuju elit bir ninja birliğinin lideridir!
Dialogue: 0,0:04:46.79,0:04:51.01,Main-207+,,0,0,0,,Orochi Oniwabanshu olarak bilinirler,\Nçok korkunçturlar!
Dialogue: 0,0:04:52.03,0:04:56.19,Main-207+,,0,0,0,,Orobi'nin peşini bırakmayacaklarına eminim!\NOna destek olmalıyız, Onami!
Dialogue: 0,0:04:56.59,0:04:59.69,Main-207+,,0,0,0,,Tamam! Robin, neredesin?!
Dialogue: 0,0:04:59.69,0:05:02.49,Main-207+,,0,0,0,,{\i1}Hey! Sen geyşasın, değil mi?
Dialogue: 0,0:05:03.16,0:05:04.36,Main-207+,,0,0,0,,Ah, evet!
Dialogue: 0,0:05:04.36,0:05:06.86,Main-207+,,0,0,0,,Burada ne yapıyorsun? Ah...
Dialogue: 0,0:05:06.86,0:05:09.39,Main-207+,,0,0,0,,Yavaş olun. Adımlarınıza dikkat et.
Dialogue: 0,0:05:10.39,0:05:12.41,Main-207+,,0,0,0,,Çok sarhoşum.
Dialogue: 0,0:05:12.41,0:05:14.99,Main-207+,,0,0,0,,Helaya gidiyordum.
Dialogue: 0,0:05:14.99,0:05:17.71,Main-207+,,0,0,0,,Daha fazla içmeden evvel\Nçişimi yapmam gerek.
Dialogue: 0,0:05:25.71,0:05:26.68,Main-207+,,0,0,0,,Sinyali kaybettik.
Dialogue: 0,0:05:27.03,0:05:29.73,Main-207+,,0,0,0,,Onu kendi başımıza bulmak zorundayız.
Dialogue: 0,0:05:29.73,0:05:31.35,Main-207+,,0,0,0,,Brook, bizi duyabildin mi?
Dialogue: 0,0:05:31.67,0:05:33.79,Main-207+,,0,0,0,,{\i1}Robin'i bul ve ona yardım et.
Dialogue: 0,0:05:33.79,0:05:37.03,Main-207+,,0,0,0,,Tamam, tamam! Bana bırakın.
Dialogue: 0,0:05:39.39,0:05:43.86,Main-207+,,0,0,0,,Tam da erzak toplamak dışında bir işim varken...
Dialogue: 0,0:05:45.11,0:05:48.86,Main-207+,,0,0,0,,Lanetlendiniz!
Dialogue: 0,0:05:50.39,0:05:52.69,Main-207+,,0,0,0,,O da ninja mıydı?
Dialogue: 0,0:05:52.69,0:05:54.33,Main-207+,,0,0,0,,Ya da belki bir hayalet?
Dialogue: 0,0:05:54.33,0:05:59.38,Main-207+,,0,0,0,,İster {\i1}ninjutsu{\i0} olsun ister büyü, gerçek bedeni yakındadır.
Dialogue: 0,0:05:59.78,0:06:00.63,Main-207+,,0,0,0,,Dinleyin!
Dialogue: 0,0:06:01.11,0:06:03.62,Main-207+,,0,0,0,,Orochi-{\i1}sama{\i0} bir ziyafet veriyor!
Dialogue: 0,0:06:03.62,0:06:08.05,Main-207+,,0,0,0,,Cılız bir fare yüzünden büyük\Nbir kargaşaya neden olmayalım!
Dialogue: 0,0:06:08.05,0:06:09.11,Main-207+,,0,0,0,,– Başüstüne!\N– Başüstüne!
Dialogue: 0,0:06:15.64,0:06:19.03,Main-207+,,0,0,0,,Şimdi, içmeye devam!
Dialogue: 0,0:06:19.03,0:06:21.23,Main-207+,,0,0,0,,Yo hayır, daha fazla içmemelisiniz.
Dialogue: 0,0:06:22.97,0:06:26.29,Main-207+,,0,0,0,,Ah, ne kadar da hoş!
Dialogue: 0,0:06:28.65,0:06:32.93,Main-207+,,0,0,0,,Ah, Orobi, yeni kız! Nerelerdeydin?!
Dialogue: 0,0:06:32.93,0:06:33.74,Main-207+,,0,0,0,,Buraya gel!
Dialogue: 0,0:06:33.74,0:06:35.41,Main-207+,,0,0,0,,Tabii, lordum.
Dialogue: 0,0:06:36.83,0:06:39.25,Thoughts-207+,,0,0,0,,"Bilge kişi, yaprağı ormanda saklar."
Dialogue: 0,0:06:39.25,0:06:44.71,Thoughts-207+,,0,0,0,,Artık kaçmam imkânsız,\Noynamam gereken bir rol var.
Dialogue: 0,0:06:46.83,0:06:47.97,Main-207+,,0,0,0,,Üzgünüm...
Dialogue: 0,0:06:47.97,0:06:49.81,Main-207+,,0,0,0,,Geciktim...
Dialogue: 0,0:06:50.37,0:06:51.34,Main-207+,,0,0,0,,lordum!
Dialogue: 0,0:06:57.51,0:07:02.06,Main-207+,,0,0,0,,Onu bulmak için her kemiğin altına bakacağım.
Dialogue: 0,0:07:03.73,0:07:05.40,Main-207+,,0,0,0,,Burada mı?
Dialogue: 0,0:07:05.40,0:07:08.44,Main-207+,,0,0,0,,Yoksa burada mı?
Dialogue: 0,0:07:11.41,0:07:13.16,Main-207+,,0,0,0,,Ah! Hayır!
Dialogue: 0,0:07:13.16,0:07:14.32,Main-207+,,0,0,0,,Sen kimsin?!
Dialogue: 0,0:07:14.32,0:07:15.16,Main-207+,,0,0,0,,Bekle!
Dialogue: 0,0:07:15.16,0:07:17.33,Main-207+,,0,0,0,,Ne yapıyorsun orada?!
Dialogue: 0,0:07:19.20,0:07:20.00,Main-207+,,0,0,0,,Ne?
Dialogue: 0,0:07:20.00,0:07:21.04,Main-207+,,0,0,0,,Nereye gitti?!
Dialogue: 0,0:07:23.92,0:07:27.30,Main-207+,,0,0,0,,Beni gördünüz!
Dialogue: 0,0:07:29.55,0:07:31.69,Main-207+,,0,0,0,,B-B-Bir şey... Burada!
Dialogue: 0,0:07:31.69,0:07:33.51,Main-207+,,0,0,0,,Bu bir hayalet!
Dialogue: 0,0:07:37.33,0:07:41.94,Main-207+,,0,0,0,,Vay! Yani tüm bu harika hazineler\NOnigashima'ya mı götürülecek?
Dialogue: 0,0:07:45.44,0:07:46.48,Main-207+,,0,0,0,,Evet!
Dialogue: 0,0:07:46.48,0:07:50.95,Main-207+,,0,0,0,,Ateş Festivali hakkında daha\Nfazlasını duymak ister misin, Orobi?
Dialogue: 0,0:07:50.95,0:07:56.09,Main-207+,,0,0,0,,Evet... Hakkınızda çok daha fazlasını duymak isterim.
Dialogue: 0,0:07:56.09,0:08:01.01,Main-207+,,0,0,0,,Öyleyse, baş zevcem olma yarışına katılmak ister misin?
Dialogue: 0,0:08:07.17,0:08:08.74,Main-207+,,0,0,0,,Komurasaki!
Dialogue: 0,0:08:08.74,0:08:11.22,Main-207+,,0,0,0,,Kalbimi kırdınız...
Dialogue: 0,0:08:13.43,0:08:17.23,Main-207+,,0,0,0,,Surat asma, surat asma, Komurasaki!
Dialogue: 0,0:08:17.23,0:08:19.56,Main-207+,,0,0,0,,Hayatım, canım sevgilim!
Dialogue: 0,0:08:19.56,0:08:21.14,Main-207+,,0,0,0,,Orochi-{\i1}sama{\i0}...
Dialogue: 0,0:08:21.61,0:08:24.65,Main-207+,,0,0,0,,onun ne kadar iki yüzlü olduğunun farkında mı?
Dialogue: 0,0:08:25.35,0:08:30.33,Main-207+,,0,0,0,,Farkında olsa bile güzelliğinden dolayı bunu görmezden gelirdi.
Dialogue: 0,0:08:30.33,0:08:32.77,Main-207+,,0,0,0,,Ne kadar da sevimli!
Dialogue: 0,0:08:34.85,0:08:37.97,Main-207+,,0,0,0,,Hım? Bir sorun mu var Orobi?
Dialogue: 0,0:08:37.97,0:08:39.08,Main-207+,,0,0,0,,Ah, yok.
Dialogue: 0,0:08:47.42,0:08:49.43,Main-207+,,0,0,0,,İşte, buyrun lordum.
Dialogue: 0,0:08:52.75,0:08:56.80,Main-207+,,0,0,0,,Komurasaki servis yaptığında\Nsake gerçekten iliklerime kadar işliyor!
Dialogue: 0,0:08:58.85,0:09:02.61,Main-207+,,0,0,0,,{\i1}Tayu{\i0} Komurasaki çok güzel!
Dialogue: 0,0:09:02.61,0:09:05.10,Main-207+,,0,0,0,,Orochi-{\i1}sama{\i0}'yı çok kıskanıyorum...
Dialogue: 0,0:09:05.10,0:09:08.81,Main-207+,,0,0,0,,ama onun karanlık tarafı beni korkutuyor!
Dialogue: 0,0:09:10.09,0:09:13.39,Main-207+,,0,0,0,,Unut gitsin! Zaten sana bakmaz!
Dialogue: 0,0:09:13.39,0:09:14.29,Main-207+,,0,0,0,,Değil mi?!
Dialogue: 0,0:09:14.29,0:09:19.70,Main-207+,,0,0,0,,Zevk mekânınızdaki diğer kadınlardan daha eğitimli,
Dialogue: 0,0:09:19.70,0:09:21.79,Main-207+,,0,0,0,,Patron Kyoshiro.
Dialogue: 0,0:09:22.51,0:09:25.87,Main-207+,,0,0,0,,Fahişelerden köpekmiş gibi bahsetme.
Dialogue: 0,0:09:25.87,0:09:27.63,Main-207+,,0,0,0,,İnsanlar çiçek gibidir.
Dialogue: 0,0:09:27.63,0:09:32.71,Main-207+,,0,0,0,,Senin gibi temiz su olmayanlar asla onun gibi bir kadının çiçek açmasını sağlayamaz.
Dialogue: 0,0:09:33.33,0:09:35.33,Main-207+,,0,0,0,,İyi dediniz!
Dialogue: 0,0:09:35.33,0:09:40.30,Main-207+,,0,0,0,,Bu arada, soba aşçısını indirmeleri için\NTobi Roppo'yu gönderdiğini duydum!
Dialogue: 0,0:09:40.30,0:09:42.18,Main-207+,,0,0,0,,Her zamanki gibi acımasızsınız!
Dialogue: 0,0:09:42.18,0:09:48.23,Main-207+,,0,0,0,,Biz yakuzalar, kadeh tokuşturduğumuz astlarımızın babası sayılırız.
Dialogue: 0,0:09:49.21,0:09:54.99,Main-207+,,0,0,0,,Çocuğunuz eve dayak yemiş hâlde gelse\Nsiz ne yapardınız?
Dialogue: 0,0:09:54.99,0:09:57.97,Main-207+,,0,0,0,,Şövalye ruhunuza her zaman\Nhayranlık duymuşumdur.
Dialogue: 0,0:09:57.97,0:10:00.87,Main-207+,,0,0,0,,Kesinlikle haklısın, Kyoshiro!
Dialogue: 0,0:10:02.87,0:10:07.08,Main-207+,,0,0,0,,Düşmanınızı her zaman\Nezici bir güçle ezmelisiniz...
Dialogue: 0,0:10:07.08,0:10:10.50,Main-207+,,0,0,0,,...ki bir daha asla size karşı çıkamasınlar!
Dialogue: 0,0:10:11.19,0:10:12.79,Main-207+,,0,0,0,,Düşman...
Dialogue: 0,0:10:14.30,0:10:17.13,Main-207+,,0,0,0,,hayaletler olsa bile!
Dialogue: 0,0:10:21.47,0:10:24.68,Main-207+,,0,0,0,,Adamlarının dayak yemesi\Nbuzdağının görünen yüzü,
Dialogue: 0,0:10:24.68,0:10:26.45,Main-207+,,0,0,0,,Kyoshiro.
Dialogue: 0,0:10:29.85,0:10:33.52,Main-207+,,0,0,0,,Yabancılar başkente sızıyor!
Dialogue: 0,0:10:35.67,0:10:40.02,Main-207+,,0,0,0,,Dinleyin! Hepiniz burada olduğunuza göre\Nbunu size bir kere söyleyeceğim!
Dialogue: 0,0:10:40.51,0:10:45.12,Main-207+,,0,0,0,,Kozuki Oden'in ölümünün üzerinden 20 yıl geçti!
Dialogue: 0,0:10:45.49,0:10:49.29,Main-207+,,0,0,0,,Karısı Toki dedi ki\Nintikam almak için bu yıl geleceklermiş!
Dialogue: 0,0:10:49.71,0:10:53.45,Main-207+,,0,0,0,,Oden'in mirası yaşıyor!
Dialogue: 0,0:10:59.22,0:11:01.47,Main-207+,,0,0,0,,Yine o eski hayalet hikayesi.
Dialogue: 0,0:11:01.90,0:11:04.51,Main-207+,,0,0,0,,Artık Kozuki'yi kim sikine takıyor ki?
Dialogue: 0,0:11:04.51,0:11:06.69,Main-207+,,0,0,0,,Değil mi, Komurasaki?
Dialogue: 0,0:11:07.20,0:11:13.69,Main-207+,,0,0,0,,Oden'in Dokuz Kızıl Kını'nın ne kadar \Nheybetli olduğunu hatırlıyor musunuz?!
Dialogue: 0,0:11:13.69,0:11:18.15,Main-207+,,0,0,0,,Liderleri Kin'emon,\Nolağanüstü derecede kurnazdır!
Dialogue: 0,0:11:18.15,0:11:24.37,Main-207+,,0,0,0,,Yirmi yıl sonra, Wano'ya geri döndüler ve komplo kuruyorlar!
Dialogue: 0,0:11:29.13,0:11:30.91,Main-207+,,0,0,0,,Gelip...
Dialogue: 0,0:11:38.42,0:11:41.93,Main-207+,,0,0,0,,kellemi alacaklar!
Dialogue: 0,0:11:46.53,0:11:51.80,Main-207+,,0,0,0,,Zaten Oden'le bağlantısı olan sayısız insanı gömdü.
Dialogue: 0,0:11:51.80,0:11:54.63,Main-207+,,0,0,0,,Hâlâ Kozuki Hanesi'nden korkuyor mu?
Dialogue: 0,0:11:57.99,0:12:01.08,Main-207+,,0,0,0,,Kaido bu işi çoktan halletti...
Dialogue: 0,0:12:01.08,0:12:05.37,Main-207+,,0,0,0,,ama bir yokozuna ve Jack'in bazı\Nadamları Kuri'de saldırıya uğradı!
Dialogue: 0,0:12:05.73,0:12:11.17,Main-207+,,0,0,0,,Bir de yakuzalarımıza saldıran şu başkentteki soba aşçısı ile kasabadaki ronin var!
Dialogue: 0,0:12:17.41,0:12:20.95,Main-207+,,0,0,0,,Bunların hepsi Kin'emon'un emriyle yapılmış olabilir!
Dialogue: 0,0:12:27.01,0:12:31.73,Main-207+,,0,0,0,,Tilki Ateşi Kin'emon ve Kızıl Kınlar geri dönerse...
Dialogue: 0,0:12:33.13,0:12:36.19,Main-207+,,0,0,0,,onlarla yüzleşme fırsatını\Nmemnuniyetle kabul ederim!
Dialogue: 0,0:12:36.19,0:12:40.03,Main-207+,,0,0,0,,Size kılıcımın ne kadar\Nkeskin olduğunu göstereceğim!
Dialogue: 0,0:12:45.49,0:12:48.20,Main-207+,,0,0,0,,Çok güven veriyorsun, Kyoshiro!
Dialogue: 0,0:12:48.20,0:12:51.95,Main-207+,,0,0,0,,Oden öldü, hem de gözlerimin önünde!
Dialogue: 0,0:12:52.30,0:12:56.54,Main-207+,,0,0,0,,Ama oğlu Momonosuke hâlâ hayatta!
Dialogue: 0,0:12:58.37,0:13:01.45,Main-207+,,0,0,0,,O veledin cesedi bulunamadı!
Dialogue: 0,0:13:01.45,0:13:05.47,Main-207+,,0,0,0,,Kozuki kanı hâlâ yaşıyor!
Dialogue: 0,0:13:05.47,0:13:09.62,Main-207+,,0,0,0,,Hedefleri Kozuki Hanesi'ni tekrar canlandırmaksa...
Dialogue: 0,0:13:10.26,0:13:14.68,Main-207+,,0,0,0,,Kaido'ya da suikast girişiminde\Nbulunacakları çok açık.
Dialogue: 0,0:13:14.68,0:13:17.77,Main-207+,,0,0,0,,Kesinlikle gelecekler!
Dialogue: 0,0:13:24.38,0:13:27.32,Main-207+,,0,0,0,,Kimse Kaido'yu öldüremez!
Dialogue: 0,0:13:27.76,0:13:30.55,Main-207+,,0,0,0,,Daha ne kadar korkak olabilir?!
Dialogue: 0,0:13:30.55,0:13:32.33,Main-207+,,0,0,0,,Çok fazla içiyorsun!
Dialogue: 0,0:13:32.33,0:13:36.25,Main-207+,,0,0,0,,Seni duyarsa selan okunur!
Dialogue: 0,0:13:36.25,0:13:38.22,Main-207+,,0,0,0,,Otoko-{\i1}chan{\i0}, şimdi de bunu al!
Dialogue: 0,0:13:38.22,0:13:39.25,Main-207+,,0,0,0,,Tamam!
Dialogue: 0,0:13:39.25,0:13:41.22,Main-207+,,0,0,0,,Hey, sakem bitti!
Dialogue: 0,0:13:41.22,0:13:43.11,Main-207+,,0,0,0,,Tamam, hemen geliyor!
Dialogue: 0,0:13:43.11,0:13:44.85,Main-207+,,0,0,0,,Bunları ona götürür müsün?!
Dialogue: 0,0:13:44.85,0:13:45.88,Main-207+,,0,0,0,,Tabii!
Dialogue: 0,0:13:45.88,0:13:49.76,Main-207+,,0,0,0,,Bu dediklerimi bir yere yazın!\NBu yıl o yıldır!
Dialogue: 0,0:13:50.20,0:13:53.23,Main-207+,,0,0,0,,Toki'nin dediklerini hatırlayın!
Dialogue: 0,0:13:53.23,0:13:56.25,Main-207+,,0,0,0,,Gardınızı indirmeyin!
Dialogue: 0,0:13:56.25,0:13:57.60,Main-207+,,0,0,0,,Amma paranoyak.
Dialogue: 0,0:13:57.60,0:13:59.19,Main-207+,,0,0,0,,Ne acınası bir hâlde.
Dialogue: 0,0:13:59.19,0:14:02.36,Main-207+,,0,0,0,,Bu saçma kehanetlere inanmayı ne zaman bırakacak?
Dialogue: 0,0:14:03.17,0:14:06.65,Main-207+,,0,0,0,,"Ey şafaktan bihaber olan Ay!"
Dialogue: 0,0:14:08.32,0:14:11.78,Main-207+,,0,0,0,,İşte yine başlıyoruz...\NSake keyfimizin içine sıçtı.
Dialogue: 0,0:14:12.62,0:14:15.50,Main-207+,,0,0,0,,"Dileğin kabul olsun...
Dialogue: 0,0:14:15.50,0:14:20.50,Main-207+,,0,0,0,,ve yirmi yılı dokuyan o geceye\Ndokuz gölge düşsün...
Dialogue: 0,0:14:20.83,0:14:25.01,Main-207+,,0,0,0,,İşte o vakit, şafağın ihtişamına şahit olacaksın!"
Dialogue: 0,0:14:25.51,0:14:27.59,Main-207+,,0,0,0,,Mesaj gayet net!
Dialogue: 0,0:14:27.59,0:14:30.95,Main-207+,,0,0,0,,Tam 20 yıl sonra, Ay belirdiğinde...
Dialogue: 0,0:14:30.95,0:14:34.51,Main-207+,,0,0,0,,o dokuz samurayın hayaletleri gelecek...
Dialogue: 0,0:14:36.27,0:14:40.07,Main-207+,,0,0,0,,ve beni öldürüp intikamlarını alacaklar!
Dialogue: 0,0:14:40.62,0:14:43.82,Main-207+,,0,0,0,,Ardından Wano'nun kapılarını açacaklar!
Dialogue: 0,0:14:54.13,0:14:57.75,Thoughts-207+,,0,0,0,,Orochi bu kehanete gönülden inanıyor.
Dialogue: 0,0:14:58.43,0:15:01.25,Thoughts-207+,,0,0,0,,Ama astları konuyu hiç ciddiye almıyor gibiler.
Dialogue: 0,0:15:02.13,0:15:03.42,Thoughts-207+,,0,0,0,,Gerçi almamaları normal.
Dialogue: 0,0:15:05.55,0:15:07.13,Main-207+,,0,0,0,,İyice uçmuş bu...
Dialogue: 0,0:15:07.58,0:15:11.13,Main-207+,,0,0,0,,Oden ve Kızıl Kınlar öldü!
Dialogue: 0,0:15:11.13,0:15:13.01,Main-207+,,0,0,0,,Onları hatırlayamıyorum bile.
Dialogue: 0,0:15:13.60,0:15:15.56,Main-207+,,0,0,0,,Ne korkak ama.
Dialogue: 0,0:15:16.16,0:15:19.64,Main-207+,,0,0,0,,Buraya gelip at koşturmalarına izin vermeyeceğiz!
Dialogue: 0,0:15:23.77,0:15:28.47,Main-207+,,0,0,0,,Gevşeme lüksümüz yok...
Dialogue: 0,0:15:35.41,0:15:37.16,Main-207+,,0,0,0,,O da kim?! Kes şunu, aptal!
Dialogue: 0,0:15:39.95,0:15:42.62,Main-207+,,0,0,0,,Gülemezsin! Tut kendini!
Dialogue: 0,0:15:47.35,0:15:49.11,Main-207+,,0,0,0,,O kimdi?!
Dialogue: 0,0:15:50.49,0:15:53.65,Main-207+,,0,0,0,,Biri bana gülmeye mi cüret etti?!
Dialogue: 0,0:15:56.18,0:15:57.47,Main-207+,,0,0,0,,Otoko-{\i1}chan{\i0}!
Dialogue: 0,0:15:57.47,0:16:02.03,Main-207+,,0,0,0,,Herkes onun aptal olduğunu düşünüyor!
Dialogue: 0,0:16:03.39,0:16:06.11,Main-207+,,0,0,0,,Kes şunu! Git artık!
Dialogue: 0,0:16:09.25,0:16:13.60,Main-207+,,0,0,0,,Duramıyorum! Çok üzgünüm!
Dialogue: 0,0:16:13.60,0:16:15.82,Main-207+,,0,0,0,,– Bu bir çocuk!\N– O çocuk, Oiran'ın ayakçısı!
Dialogue: 0,0:16:16.32,0:16:17.62,Main-207+,,0,0,0,,Durdurun onu!
Dialogue: 0,0:16:17.93,0:16:19.08,Main-207+,,0,0,0,,Otoko-{\i1}chan{\i0}!
Dialogue: 0,0:16:20.45,0:16:22.85,Main-207+,,0,0,0,,Gülmemem gerektiğini biliyorum!
Dialogue: 0,0:16:30.37,0:16:32.22,Main-207+,,0,0,0,,Bu ne küstahlık!
Dialogue: 0,0:16:32.69,0:16:35.64,Main-207+,,0,0,0,,Ben şogunum!
Dialogue: 0,0:16:42.99,0:16:44.48,Main-207+,,0,0,0,,Durdurun onu!
Dialogue: 0,0:16:48.97,0:16:52.41,Main-207+,,0,0,0,,20 yıllık bir kinin...
Dialogue: 0,0:16:53.49,0:16:56.07,Main-207+,,0,0,0,,beni korkuttuğunu mu...
Dialogue: 0,0:16:57.01,0:17:01.25,Main-207+,,0,0,0,,sanıyorsun?!
Dialogue: 0,0:17:03.83,0:17:06.46,Main-207+,,0,0,0,,Ben zaferin ta kendisiyim!
Dialogue: 0,0:17:08.43,0:17:09.46,Main-207+,,0,0,0,,Lordum!
Dialogue: 0,0:17:09.46,0:17:11.76,Main-207+,,0,0,0,,Oden'i yenen kişiyim!
Dialogue: 0,0:17:12.18,0:17:13.88,Main-207+,,0,0,0,,Lütfen! Dur artık!
Dialogue: 0,0:17:18.89,0:17:20.26,Main-207+,,0,0,0,,Yeter!
Dialogue: 0,0:17:21.91,0:17:23.20,Main-207+,,0,0,0,,Oiran!
Dialogue: 0,0:17:23.20,0:17:24.60,Main-207+,,0,0,0,,İş çığırından çıktı.
Dialogue: 0,0:17:24.60,0:17:27.56,Main-207+,,0,0,0,,O kötü kalpli kadının elinden hiçbir şey gelmez!
Dialogue: 0,0:17:28.03,0:17:28.81,Main-207+,,0,0,0,,Lordum!
Dialogue: 0,0:17:30.35,0:17:32.11,Main-207+,,0,0,0,,O sadece bir çocuk.
Dialogue: 0,0:17:32.11,0:17:34.82,Main-207+,,0,0,0,,Bu işe karışma, Komurasaki!
Dialogue: 0,0:17:44.57,0:17:46.54,Main-207+,,0,0,0,,Lordum, lütfen onu affedin!
Dialogue: 0,0:17:47.49,0:17:49.71,Main-207+,,0,0,0,,Bana gülmeye nasıl cürret edersin?!
Dialogue: 0,0:17:50.88,0:17:52.69,Main-207+,,0,0,0,,Seni hamamböceği!
Dialogue: 0,0:17:59.33,0:18:03.09,Main-207+,,0,0,0,,Onun gülme tiki var!\NBunu kasten yapmıyor ki!
Dialogue: 0,0:18:03.09,0:18:06.89,Main-207+,,0,0,0,,Yapabileceğimiz bir şey yok!\NUnut artık o kızı!
Dialogue: 0,0:18:06.89,0:18:10.77,Main-207+,,0,0,0,,Lordum! O sadece bir çocuk!\NMerhamet gösterin!
Dialogue: 0,0:18:10.77,0:18:13.91,Main-207+,,0,0,0,,Beni dinliyor musun?!
Dialogue: 0,0:18:14.71,0:18:15.99,Main-207+,,0,0,0,,Gülmeyi kes!
Dialogue: 0,0:18:19.73,0:18:21.11,Main-207+,,0,0,0,,Otoko-{\i1}chan!{\i0}
Dialogue: 0,0:18:52.67,0:18:54.69,Main-207+,,0,0,0,,Komurasaki...
Dialogue: 0,0:18:55.17,0:18:57.15,Main-207+,,0,0,0,,Neden...?
Dialogue: 0,0:18:57.15,0:18:59.95,Main-207+,,0,0,0,,Nasıl bana saldırırsın?!
Dialogue: 0,0:18:59.95,0:19:02.28,Main-207+,,0,0,0,,Af dile, Komurasaki!
Dialogue: 0,0:19:02.69,0:19:06.52,Main-207+,,0,0,0,,Dizlerinin üzerine çök\Nve kafanı yerin dibine sok!
Dialogue: 0,0:19:06.52,0:19:08.08,Main-207+,,0,0,0,,Reddediyorum!
Dialogue: 0,0:19:13.38,0:19:17.84,Main-207+,,0,0,0,,Kendimi kimsenin önünde küçük düşürmeyeceğim!
Dialogue: 0,0:19:19.63,0:19:21.34,Main-207+,,0,0,0,,Nasıl buna cürret ediyor?!
Dialogue: 0,0:19:21.34,0:19:26.31,Main-207+,,0,0,0,,Haklı olduğumu bildiğimde\Nzerre kadar taviz vermem!
Dialogue: 0,0:19:27.63,0:19:30.41,Main-207+,,0,0,0,,Hey, Komurasaki...
Dialogue: 0,0:19:31.57,0:19:33.02,Main-207+,,0,0,0,,Seni tam da...
Dialogue: 0,0:19:34.27,0:19:39.53,Main-207+,,0,0,0,,şogun karısı yapacaktım!
Dialogue: 0,0:19:39.86,0:19:42.41,Main-207+,,0,0,0,,Zayıf bir kadın tercih ediyorsan...
Dialogue: 0,0:19:42.89,0:19:46.11,Main-207+,,0,0,0,,durma, beni şuracıkta öldür!
Dialogue: 0,0:19:48.87,0:19:50.75,Main-207+,,0,0,0,,Ben samuray kızıyım!
Dialogue: 0,0:19:50.75,0:19:52.31,Main-207+,,0,0,0,,Sessizlik!
Dialogue: 0,0:19:52.83,0:19:55.71,Main-207+,,0,0,0,,Utanç içinde yaşamayacağım!
Dialogue: 0,0:19:59.33,0:20:02.38,Main-207+,,0,0,0,,Bu ne küstahlık!
Dialogue: 0,0:20:07.77,0:20:12.35,Main-207+,,0,0,0,,Sen bir fahişeden\Nbaşka bir şey değilsin!
Dialogue: 0,0:20:18.57,0:20:23.07,Main-207+,,0,0,0,,Samuraylık hakkında bir bok biliyormuş gibi davranma!
Dialogue: 0,0:20:32.89,0:20:34.71,Main-207+,,0,0,0,,Orochi-{\i1}sama{\i0}...?!
Dialogue: 0,0:20:37.93,0:20:39.42,Main-207+,,0,0,0,,Dönüştü.
Dialogue: 0,0:20:41.34,0:20:44.47,Main-207+,,0,0,0,,Komurasaki...
Dialogue: 0,0:20:55.35,0:20:57.49,Main-207+,,0,0,0,,Ne büyük hüsran.
Dialogue: 0,0:20:58.40,0:21:01.39,Main-207+,,0,0,0,,Böyle bir güzelliğin ziyan olması çok yazık!
Dialogue: 0,0:21:01.39,0:21:05.27,Main-207+,,0,0,0,,Kafanı koparmak istemiyorum!
Dialogue: 0,0:21:06.36,0:21:08.20,Main-207+,,0,0,0,,Af dile!
Dialogue: 0,0:21:08.20,0:21:11.20,Main-207+,,0,0,0,,Hayatın için yalvarırsan...
Dialogue: 0,0:21:11.20,0:21:14.16,Main-207+,,0,0,0,,cezanı hafifleteceğim!
Dialogue: 0,0:21:19.69,0:21:23.31,Main-207+,,0,0,0,,Ne bekliyorsun?!
Dialogue: 0,0:21:24.99,0:21:28.69,Main-207+,,0,0,0,,Kalpten af dile!
Dialogue: 0,0:21:30.43,0:21:33.06,Main-207+,,0,0,0,,Bazı şeyleri oluruna bırakmayı öğrenmelisin.
Dialogue: 0,0:21:38.65,0:21:41.44,Main-207+,,0,0,0,,Derler ki aşık olan kaybeder.
Dialogue: 0,0:21:42.81,0:21:44.28,Main-207+,,0,0,0,,Ne?!
Dialogue: 0,0:21:44.61,0:21:46.43,Main-207+,,0,0,0,,Sana...
Dialogue: 0,0:21:46.43,0:21:48.71,Main-207+,,0,0,0,,hayatım için yalvarmayacağım!
Dialogue: 0,0:21:51.79,0:21:54.29,Main-207+,,0,0,0,,Resmen onu kışkırtıyor.
Dialogue: 0,0:21:54.29,0:21:56.87,Main-207+,,0,0,0,,Yeter artık, Komurasaki!
Dialogue: 0,0:21:56.87,0:22:01.42,Main-207+,,0,0,0,,Komurasaki!
Dialogue: 0,0:22:08.97,0:22:12.31,Main-207+,,0,0,0,,Kahretsin!
Dialogue: 0,0:22:22.40,0:22:25.28,Main-207+,,0,0,0,,Orochi-{\i1}sama{\i0}, bize niye saldırıyorsunuz?!
Dialogue: 0,0:22:27.63,0:22:31.28,Main-207+,,0,0,0,,Gerçekten çok küstahsın!
Dialogue: 0,0:22:44.33,0:22:47.97,Main-207+,,0,0,0,,Ha? Sen soba dükkânındaki ablasın?!
Dialogue: 0,0:22:47.97,0:22:50.93,Main-207+,,0,0,0,,Otoko-{\i1}chan{\i0}!\Nİyi olmana çok sevindim!
Dialogue: 0,0:22:50.93,0:22:55.59,Main-207+,,0,0,0,,Nereye kayboldu bu büyücü?!
Dialogue: 0,0:22:58.98,0:23:00.81,Main-207+,,0,0,0,,Dur lan!
Dialogue: 0,0:23:01.27,0:23:04.61,Main-207+,,0,0,0,,Bizi atlatabileceğini mi sandın?!
Dialogue: 0,0:23:04.61,0:23:06.94,Main-207+,,0,0,0,,Kadını buldum!
Dialogue: 0,0:23:11.95,0:23:14.33,Main-207+,,0,0,0,,Öyle olsun, Komurasaki!
Dialogue: 0,0:23:15.19,0:23:17.33,Main-207+,,0,0,0,,Dilediğin gibi olsun...
Dialogue: 0,0:23:17.33,0:23:20.46,Main-207+,,0,0,0,,Seni kendi ellerimle öldüreceğim!
Dialogue: 0,0:23:50.95,0:23:53.89,Main-207+,,0,0,0,,Ortalık tam bir kıyamet!
Dialogue: 0,0:24:07.92,0:24:10.17,Main-207+,,0,0,0,,Kendini hazırla...
Dialogue: 0,0:24:13.72,0:24:16.51,Main-207+,,0,0,0,,Komurasaki!
Dialogue: 0,0:24:18.23,0:24:19.06,Main-207+,,0,0,0,,Daikoku!
Dialogue: 0,0:24:20.21,0:24:22.73,Main-207+,,0,0,0,,Siz ninjalar neden\Nşogunu durdurmuyorsunuz?!
Dialogue: 0,0:24:23.06,0:24:24.75,Main-207+,,0,0,0,,Oiranı kurtarın!
Dialogue: 0,0:24:24.75,0:24:28.65,Main-207+,,0,0,0,,İstediğini yapmakta özgür.\NOnu kimse durduramaz.
Dialogue: 0,0:24:30.40,0:24:32.36,Main-207+,,0,0,0,,Her şeyden önemlisi...
Dialogue: 0,0:24:32.36,0:24:36.57,Main-207+,,0,0,0,,şu anda davetsiz bir misafirle uğraşıyoruz!
Dialogue: 0,0:24:36.57,0:24:38.21,Main-207+,,0,0,0,,Davetsiz misafir mi?!
Dialogue: 0,0:24:48.17,0:24:51.40,Main-207+,,0,0,0,,Orobi-{\i1}san{\i0} mı davetsiz misafirmiş?
Dialogue: 0,0:24:51.40,0:24:55.34,Main-207+,,0,0,0,,Şimdi düşününce,\Nonu daha önce hiç görmemiştim.
Dialogue: 0,0:25:00.05,0:25:03.43,Main-207+,,0,0,0,,Hey abla, lütfen oiranı kurtarın!
Dialogue: 0,0:25:03.91,0:25:05.69,Main-207+,,0,0,0,,Yapamam!
Dialogue: 0,0:25:05.69,0:25:10.07,Main-207+,,0,0,0,,Şogunu bu kadar kızdırdıktan sonra\Nseni kurtarabileceğimden bile emin değilim!
Dialogue: 0,0:25:26.58,0:25:28.50,Main-207+,,0,0,0,,Yardım edin!
Dialogue: 0,0:25:30.92,0:25:32.46,Main-207+,,0,0,0,,Ölümle lanetlendik!
Dialogue: 0,0:25:32.88,0:25:34.80,Main-207+,,0,0,0,,Neler oluyor orada?!
Dialogue: 0,0:25:36.72,0:25:40.14,Main-207+,,0,0,0,,Fujin! Raijin! Ne yapıyorsunuz siz?!
Dialogue: 0,0:25:48.33,0:25:50.65,Main-207+,,0,0,0,,B-Bu bir hayalet!
Dialogue: 0,0:25:50.65,0:25:54.61,Main-207+,,0,0,0,,{\i1}Gashadokuro yokai{\i0} gerçekmiş!
Dialogue: 0,0:25:55.78,0:26:02.37,Main-207+,,0,0,0,,Lanetlendiniz!
Dialogue: 0,0:26:02.37,0:26:03.95,Main-207+,,0,0,0,,Nee?!
Dialogue: 0,0:26:05.96,0:26:07.83,Main-207+,,0,0,0,,Hayalet!
Dialogue: 0,0:26:09.29,0:26:10.29,Main-207+,,0,0,0,,Otoko-{\i1}chan{\i0}!
Dialogue: 0,0:26:10.29,0:26:15.13,Main-207+,,0,0,0,,Lanetlendiniz!
Dialogue: 0,0:26:17.51,0:26:19.41,Main-207+,,0,0,0,,Robin-{\i1}san{\i0}, iyi olmana çok sevindim!
Dialogue: 0,0:26:19.41,0:26:21.68,Main-207+,,0,0,0,,Kemikichi, kahramanımsın! Teşekkür ederim!
Dialogue: 0,0:26:23.83,0:26:25.64,Main-207+,,0,0,0,,Harikayım, değil mi?
Dialogue: 0,0:26:26.03,0:26:27.73,Main-207+,,0,0,0,,Aynen, böyle devam!
Dialogue: 0,0:26:27.73,0:26:30.52,Main-207+,,0,0,0,,Hadi çıkalım buradan.
Dialogue: 0,0:26:31.87,0:26:35.65,Main-207+,,0,0,0,,Hayalet onlarla birlikte mi?!
Dialogue: 0,0:26:35.65,0:26:36.82,Main-207+,,0,0,0,,{\fad(150,150)}Bin Çiçek!
Dialogue: 0,0:26:38.79,0:26:40.77,Main-207+,,0,0,0,,{\fad(150,150)}Devasa El!
Dialogue: 0,0:26:47.16,0:26:48.65,Main-207+,,0,0,0,,Nasıl yaparsın...?!
Dialogue: 0,0:26:48.65,0:26:49.42,Main-207+,,0,0,0,,Kahrolası!
Dialogue: 0,0:26:54.03,0:26:54.88,Main-207+,,0,0,0,,Al bakalım!
Dialogue: 0,0:26:57.61,0:26:59.63,Main-207+,,0,0,0,,{\i1}G-Gashadokuro{\i0}!
Dialogue: 0,0:26:59.63,0:27:02.72,Main-207+,,0,0,0,,Size ölüler diyarına kadar eşlik etmeme izin verin,
Dialogue: 0,0:27:02.72,0:27:05.75,Main-207+,,0,0,0,,genç hanım!
Dialogue: 0,0:27:09.97,0:27:11.23,Main-207+,,0,0,0,,Git buradan!
Dialogue: 0,0:27:11.23,0:27:12.86,Main-207+,,0,0,0,,– Hayır!\N– Hayır!
Dialogue: 0,0:27:19.86,0:27:22.53,Main-207+,,0,0,0,,Bunlar Robin ve Brook.
Dialogue: 0,0:27:22.53,0:27:24.20,Main-207+,,0,0,0,,Ne yapmalıyız?!
Dialogue: 0,0:27:24.20,0:27:26.37,Main-207+,,0,0,0,,Artık saklanmanın bir anlamı yok.
Dialogue: 0,0:27:26.92,0:27:28.75,Main-207+,,0,0,0,,Harekete geçelim!
Dialogue: 0,0:27:28.75,0:27:30.33,Main-207+,,0,0,0,,Anlaşıldı, Shinobu-{\i1}chan{\i0}!
Dialogue: 0,0:27:34.61,0:27:36.50,Main-207+,,0,0,0,,Kim var orada?! Ninja mı?!
Dialogue: 0,0:27:40.37,0:27:45.41,Main-207+,,0,0,0,,Az önce sana "Shinobu" mu dedi?!
Dialogue: 0,0:27:45.41,0:27:47.26,Main-207+,,0,0,0,,Yoksa sen misin...
Dialogue: 0,0:27:47.26,0:27:48.18,Main-207+,,0,0,0,,Hanzo?!
Dialogue: 0,0:27:49.73,0:27:53.15,Main-207+,,0,0,0,,Yaşıyorsun! Büyüleyici...
Dialogue: 0,0:27:53.49,0:27:55.36,Main-207+,,0,0,0,,seksi ve baştan çıkarıcı kunoichi.
Dialogue: 0,0:28:09.05,0:28:11.25,Main-207+,,0,0,0,,Erkek Katili Shinobu!
Dialogue: 0,0:28:23.89,0:28:25.84,Main-207+,,0,0,0,,Demek beni tanıdın?
Dialogue: 0,0:28:25.84,0:28:27.10,Main-207+,,0,0,0,,Boşver. Sen değilmişsin.
Dialogue: 0,0:28:27.72,0:28:29.14,Main-207+,,0,0,0,,Unut gitsin!
Dialogue: 0,0:28:29.14,0:28:30.93,Main-207+,,0,0,0,,Benim be işte!
Dialogue: 0,0:28:33.10,0:28:35.99,Main-207+,,0,0,0,,{\fad(150,150)}Ninpo: Testis Ezici!
Dialogue: 0,0:28:35.99,0:28:37.40,Main-207+,,0,0,0,,Bu bir {\i1}ninjutsu{\i0} muydu?!
Dialogue: 0,0:28:40.05,0:28:45.15,Main-207+,,0,0,0,,Demek bu yüzden...\NErkek Katili olarak... biliniyorsun.
Dialogue: 0,0:28:45.15,0:28:46.99,Main-207+,,0,0,0,,Gerçekten bu yüzden mi?!
Dialogue: 0,0:28:46.99,0:28:49.41,Main-207+,,0,0,0,,H-Hareket e-e-edemiyorum!
Dialogue: 0,0:28:49.41,0:28:52.25,Main-207+,,0,0,0,,{\fad(150,150)}Ninpo: Felç Tekniği!
Dialogue: 0,0:28:52.25,0:28:54.42,Main-207+,,0,0,0,,Ne?! Bunu şimdi uydurdun!
Dialogue: 0,0:28:54.82,0:28:56.32,Main-207+,,0,0,0,,Gitmemiz gerekiyor!
Dialogue: 0,0:28:56.32,0:28:57.54,Main-207+,,0,0,0,,Gidelim, Onami!
Dialogue: 0,0:28:57.55,0:28:58.04,Main-207+,,0,0,0,,Ne?
Dialogue: 0,0:28:59.23,0:29:00.63,Main-207+,,0,0,0,,{\fad(150,150)}Seksi Ninpo:
Dialogue: 0,0:29:00.97,0:29:02.63,Main-207+,,0,0,0,,{\fad(150,150)}Çürük Bahçe!
Dialogue: 0,0:29:19.94,0:29:22.52,Main-207+,,0,0,0,,Neden Hanzo çatıdan düştü?
Dialogue: 0,0:29:22.52,0:29:25.32,Main-207+,,0,0,0,,Kim bu kunoichiler?!
Dialogue: 0,0:29:25.32,0:29:27.15,Main-207+,,0,0,0,,Neler oluyor burada?!
Dialogue: 0,0:29:27.15,0:29:29.12,Main-207+,,0,0,0,,Ziyafet salonu harap oldu!
Dialogue: 0,0:29:45.19,0:29:46.97,Main-207+,,0,0,0,,Vay, Onami-{\i1}san{\i0}!
Dialogue: 0,0:29:47.63,0:29:50.89,Main-207+,,0,0,0,,Lanetlendin!
Dialogue: 0,0:29:52.21,0:29:52.97,Main-207+,,0,0,0,,Ben niye?!
Dialogue: 0,0:29:53.58,0:29:54.35,Main-207+,,0,0,0,,Onami!
Dialogue: 0,0:29:54.76,0:29:56.02,Main-207+,,0,0,0,,Yardım için geldim!
Dialogue: 0,0:29:59.59,0:30:03.43,Main-207+,,0,0,0,,Neredesin, Komurasaki?!
Dialogue: 0,0:30:04.49,0:30:06.20,Main-207+,,0,0,0,,İşte buradasın!
Dialogue: 0,0:30:21.91,0:30:23.71,Main-207+,,0,0,0,,Kyoshiro?!
Dialogue: 0,0:30:44.97,0:30:48.27,Main-207+,,0,0,0,,Bu sefer sınırı aştın, Komurasaki.
Dialogue: 0,0:30:52.21,0:30:53.71,Main-207+,,0,0,0,,Hazır mısın?
Dialogue: 0,0:30:53.71,0:30:54.83,Main-207+,,0,0,0,,Hazırım.
Dialogue: 0,0:32:14.49,0:32:17.28,Main-207+,,0,0,0,,O... Oiran...
Dialogue: 0,0:32:18.77,0:32:19.83,Main-207+,,0,0,0,,Abla!
Dialogue: 0,0:32:25.54,0:32:30.13,Main-207+,,0,0,0,,Kyoshiro-{\i1}dono{\i0}, neden yaptın bunu?
Dialogue: 0,0:32:30.13,0:32:33.26,Main-207+,,0,0,0,,Wano'daki en güzel kadındı...
Dialogue: 0,0:32:33.26,0:32:34.76,Main-207+,,0,0,0,,Buna yürek dayanmaz!
Dialogue: 0,0:32:48.39,0:32:50.53,Main-207+,,0,0,0,,Komurasaki...
Dialogue: 0,0:32:57.11,0:32:59.41,Main-207+,,0,0,0,,Ne yaptın sen, Kyoshiro?!
Dialogue: 0,0:33:01.73,0:33:04.71,Main-207+,,0,0,0,,Sana onu öldürmeni söyledim mi?!
Dialogue: 0,0:33:05.73,0:33:09.29,Main-207+,,0,0,0,,Seni piç...
Dialogue: 0,0:33:12.97,0:33:14.47,Main-207+,,0,0,0,,Bunu...
Dialogue: 0,0:33:15.72,0:33:19.51,Main-207+,,0,0,0,,bir samurayın Komurasaki'ye\Ngösterdiği merhamet olarak görün.
Dialogue: 0,0:33:20.31,0:33:24.73,Main-207+,,0,0,0,,Şoguna karşı gelmek kişinin statüsü ne olursa olsun ağır bir suçtur!
Dialogue: 0,0:33:25.91,0:33:28.44,Main-207+,,0,0,0,,Bu demir kuraldır.
Dialogue: 0,0:33:30.32,0:33:33.49,Main-207+,,0,0,0,,Sadakatini göstermek için mi yaptı yani?!
Dialogue: 0,0:33:33.49,0:33:36.53,Main-207+,,0,0,0,,Kyoshiro bu sefer çok ileri gitti...
Dialogue: 0,0:33:57.38,0:33:59.47,Main-207+,,0,0,0,,O veledizinayı...
Dialogue: 0,0:34:01.56,0:34:03.89,Main-207+,,0,0,0,,bana ver!
Dialogue: 0,0:34:06.81,0:34:09.98,Main-207+,,0,0,0,,Onu canlı canlı yiyeceğim!
Dialogue: 0,0:34:13.82,0:34:20.03,Main-207+,,0,0,0,,Bana gülmeseydi bunların hiçbiri olmayacaktı!
Dialogue: 0,0:34:20.03,0:34:21.37,Main-207+,,0,0,0,,Seni bücür!
Dialogue: 0,0:34:23.33,0:34:25.29,Main-207+,,0,0,0,,Ver onu bana, Orobi!
Dialogue: 0,0:34:25.29,0:34:28.17,Main-207+,,0,0,0,,Sen kimsin ki hem?!
Dialogue: 0,0:34:31.42,0:34:32.34,Main-207+,,0,0,0,,Robin!
Dialogue: 0,0:34:32.34,0:34:34.09,Main-207+,,0,0,0,,Çık dışarı, Zeus!
Dialogue: 0,0:34:35.92,0:34:39.80,Main-207+,,0,0,0,,Hey! Beni mi çağırdın, Nami?
Dialogue: 0,0:34:39.80,0:34:42.10,Main-207+,,0,0,0,,Sana biraz hava yumurtası vereceğim.
Dialogue: 0,0:34:42.10,0:34:43.39,Main-207+,,0,0,0,,Gerçekten mi?!
Dialogue: 0,0:34:47.23,0:34:49.19,Main-207+,,0,0,0,,Lanetlendiniz!
Dialogue: 0,0:34:49.19,0:34:52.17,Main-207+,,0,0,0,,Şimdi hayaletle uğraşacak vaktimiz yok!
Dialogue: 0,0:34:52.17,0:34:54.15,Main-207+,,0,0,0,,Lanetlendiniz!
Dialogue: 0,0:34:54.15,0:34:56.55,Main-207+,,0,0,0,,Neden saldırmıyor bu bize?!
Dialogue: 0,0:34:56.55,0:34:59.57,Main-207+,,0,0,0,,Lanetlendiniz!
Dialogue: 0,0:35:01.24,0:35:02.91,Main-207+,,0,0,0,,Ah, olamaz! Farkına vardılar!
Dialogue: 0,0:35:02.91,0:35:05.41,Main-207+,,0,0,0,,Sanırım artık gitme vakti.
Dialogue: 0,0:35:06.91,0:35:09.52,Main-207+,,0,0,0,,Savaş vakti!
Dialogue: 0,0:35:09.52,0:35:11.83,Main-207+,,0,0,0,,Ziyafet salonunda bir sorun var!
Dialogue: 0,0:35:12.24,0:35:15.55,Main-207+,,0,0,0,,Davetsiz misafirleri yakalayın ve {\i1}yokai{\i0}'yi kovun!
Dialogue: 0,0:35:19.68,0:35:22.85,Main-207+,,0,0,0,,Orochi-{\i1}sama'nın{\i0} öfkesini dindirin!
Dialogue: 0,0:35:33.15,0:35:35.27,Main-207+,,0,0,0,,Siper alın!
Dialogue: 0,0:35:35.27,0:35:36.65,Main-207+,,0,0,0,,{\fad(150,150)}Ninpo:
Dialogue: 0,0:35:37.23,0:35:38.57,Main-207+,,0,0,0,,{\fad(150,150)}Yıldırım!
Dialogue: 0,0:35:44.99,0:35:47.45,Main-207+,,0,0,0,,Bu da ne?!
Dialogue: 0,0:36:02.03,0:36:05.05,Main-207+,,0,0,0,,Gençsin fakat çok etkileyici bir ninpoydu!
Dialogue: 0,0:36:05.05,0:36:06.72,Main-207+,,0,0,0,,Ucuz kurtulduk!
Dialogue: 0,0:36:06.72,0:36:08.85,Main-207+,,0,0,0,,Bunu ancak sen yapabilirdin, Onami!
Dialogue: 0,0:36:21.88,0:36:24.11,Main-207+,,0,0,0,,Haydi, Olin-{\i1}san{\i0}! Biraz {\i1}oshiruko{\i0} iç.
Dialogue: 0,0:36:27.99,0:36:30.83,Main-207+,,0,0,0,,Vay! Harika kokuyor!
Dialogue: 0,0:36:30.83,0:36:32.75,Main-207+,,0,0,0,,Teşekkür ederim!
Dialogue: 0,0:36:35.88,0:36:37.34,Main-207+,,0,0,0,,Çok güzel!
Dialogue: 0,0:36:37.67,0:36:39.76,Main-207+,,0,0,0,,Çok lezzetli!
Dialogue: 0,0:36:39.76,0:36:43.59,Main-207+,,0,0,0,,Bu oshiruko çok tatlı ve lezzetliymiş!
Dialogue: 0,0:36:43.59,0:36:46.22,Main-207+,,0,0,0,,Beğendiğine sevindim.
Dialogue: 0,0:36:48.83,0:36:51.85,Main-207+,,0,0,0,,Üzgünüm Olin-{\i1}san{\i0},\Nama elimizdekilerin hepsi buydu...
Dialogue: 0,0:36:51.85,0:36:54.45,Main-207+,,0,0,0,,Keşke daha fazla olsaydı.
Dialogue: 0,0:36:54.45,0:36:58.69,Main-207+,,0,0,0,,Ama elinizdeki imkânlara rağmen beni beslediniz. Teşekkür ederim, Tsuru-{\i1}san{\i0}.
Dialogue: 0,0:37:02.07,0:37:05.41,Main-207+,,0,0,0,,Gerçekten o kadar güçlü mü?
Dialogue: 0,0:37:05.41,0:37:07.93,Main-207+,,0,0,0,,Evet, tahmin edebileceğinden çok daha güçlü.
Dialogue: 0,0:37:07.93,0:37:12.37,Main-207+,,0,0,0,,Madem öyle, ağabeyi kurtarması için onu kullanalım!
Dialogue: 0,0:37:12.37,0:37:13.68,Main-207+,,0,0,0,,Ne?!
Dialogue: 0,0:37:13.68,0:37:15.75,Main-207+,,0,0,0,,Ah, bu harika bir fikir!
Dialogue: 0,0:37:15.75,0:37:17.84,Main-207+,,0,0,0,,Bu o kadar da kolay değil!
Dialogue: 0,0:37:17.84,0:37:21.09,Main-207+,,0,0,0,,Bizi asla dinlemez!
Dialogue: 0,0:37:21.09,0:37:23.77,Main-207+,,0,0,0,,Hadi deneyelim, Choppermon!
Dialogue: 0,0:37:23.77,0:37:25.01,Main-207+,,0,0,0,,Gidelim!
Dialogue: 0,0:37:32.39,0:37:36.73,Main-207+,,0,0,0,,Emin misin? Hafızası geri gelirse yanarız!
Dialogue: 0,0:37:36.73,0:37:39.45,Main-207+,,0,0,0,,Burada oturup beklemekten iyidir!
Dialogue: 0,0:37:39.45,0:37:41.86,Main-207+,,0,0,0,,Gitmek istiyorum! Bu bizim tek şansımız!
Dialogue: 0,0:37:49.19,0:37:50.41,Main-207+,,0,0,0,,Şey...
Dialogue: 0,0:37:50.41,0:37:54.21,Main-207+,,0,0,0,,Ne oldu, küçük, sevimli Choppermon?
Dialogue: 0,0:37:54.21,0:37:54.96,Main-207+,,0,0,0,,Pati ver.
Dialogue: 0,0:37:57.43,0:37:59.42,Main-207+,,0,0,0,,T-Tabii..
Dialogue: 0,0:38:02.07,0:38:04.01,Main-207+,,0,0,0,,Acıktım...
Dialogue: 0,0:38:05.27,0:38:07.88,Main-207+,,0,0,0,,Daha fazla yemek istiyorum.
Dialogue: 0,0:38:07.93,0:38:10.28,Main-207+,,0,0,0,,Korkudan altıma sıçacağım!
Dialogue: 0,0:38:10.78,0:38:12.99,Main-207+,,0,0,0,,Yardımın gerek, Olin.
Dialogue: 0,0:38:12.99,0:38:14.03,Main-207+,,0,0,0,,Ne?!
Dialogue: 0,0:38:14.03,0:38:16.46,Main-207+,,0,0,0,,Haydi Udon'a hep beraber gidelim!
Dialogue: 0,0:38:16.46,0:38:17.60,Main-207+,,0,0,0,,Ne?!
Dialogue: 0,0:38:17.60,0:38:21.69,Main-207+,,0,0,0,,Udon mu? Oraya mı gidiyordum?
Dialogue: 0,0:38:21.69,0:38:23.40,Main-207+,,0,0,0,,Evet!
Dialogue: 0,0:38:23.40,0:38:28.70,Main-207+,,0,0,0,,Udon'dan sorumlu önderin {\i1}oshiruko{\i0}'yu sevdiğini duydum!
Dialogue: 0,0:38:30.59,0:38:34.20,Main-207+,,0,0,0,,Evet, doğru! Muhtemelen orada tonlarca {\i1}oshiruko{\i0} vardır!
Dialogue: 0,0:38:36.61,0:38:39.50,Thoughts-207+,,0,0,0,,Yalanı ağzımdan kaçırıverdim..
Dialogue: 0,0:38:39.50,0:38:41.97,Thoughts-207+,,0,0,0,,Orada hiç {\i1}oshiruko{\i0} yoksa...
Dialogue: 0,0:38:41.97,0:38:45.34,Thoughts-207+,,0,0,0,,beni öldürür!
Dialogue: 0,0:38:45.80,0:38:49.67,Main-207+,,0,0,0,,Orada tonlarca {\i1}oshiruko{\i0} mu var?!
Dialogue: 0,0:38:53.83,0:38:55.06,Main-207+,,0,0,0,,O hâlde hadi gidelim!
Comment: 0,0:00:00.00,0:00:00.00,Main-207+,,0,0,0,,{=30}===============================DIALOGUE============================
