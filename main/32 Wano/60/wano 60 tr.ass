Comment: 0,0:00:00.00,0:00:00.00,Main-207+,,0,0,0,,{=46}===============================DIALOGUE============================
Dialogue: 0,0:00:02.86,0:00:06.11,Main-207+,Linlin,0,0,0,,Şunların feleğini bir şaşırtalım, Kaido!
Dialogue: 0,0:00:07.32,0:00:11.28,Main-207+,Linlin,0,0,0,,Beşinden kaçı hayatta kalacak görelim.
Dialogue: 0,0:00:16.00,0:00:17.58,Main-207+,Kid,0,0,0,,Trafalgar!
Dialogue: 0,0:00:17.58,0:00:21.58,Main-207+,Kid,0,0,0,,Yeteneğinle onlardan birini aşağı yollayamaz mısın?
Dialogue: 0,0:00:21.58,0:00:23.80,Main-207+,Law,0,0,0,,Yapabilseydim çoktan yapmıştım.
Dialogue: 0,0:00:23.80,0:00:28.13,Main-207+,Law,0,0,0,,Hakileri çok güçlü,\Nonları yerlerinden oynatamam.
Dialogue: 0,0:00:28.13,0:00:31.34,Main-207+,Kid,0,0,0,,Biz de onları ayırırız öyleyse!
Dialogue: 0,0:00:35.89,0:00:38.10,Main-207+,Luffy,0,0,0,,Dikkat, büyük bir saldırı geliyor!
Dialogue: 0,0:01:06.50,0:01:10.34,Main-207+,Kaido,0,0,0,,Bacakların güçten düşmemiştir umarım, kocakarı!
Dialogue: 0,0:01:10.34,0:01:13.80,Main-207+,Linlin,0,0,0,,Kiminle konuştuğunu sanıyorsun, yumurcak?
Dialogue: 0,0:01:22.44,0:01:24.02,Main-207+,Kaido+Linlin,0,0,0,,{\fad(150,150)}– Denizin Fethi!\N– Denizin Fethi!
Dialogue: 0,0:01:31.40,0:01:33.28,Main-207+,Zoro,0,0,0,,{\t(1693,0,1,\3c&HFFFFFF&\4c&HFFFFFF&)}Yok artık!
Dialogue: 0,0:01:33.41,0:01:35.95,Main-207+,Killer,0,0,0,,{\t(2269,0,1,\3c&HFFFFFF&\4c&HFFFFFF&)}İmkânı yok! Bunu savuşturamayız!
Dialogue: 0,0:01:47.17,0:01:50.55,Main-207+,Zoro,0,0,0,,Kaçın!
Dialogue: 0,0:02:00.81,0:02:02.89,Main-207+,Zoro,0,0,0,,Kaçmazsanız...
Dialogue: 0,0:02:03.44,0:02:05.36,Main-207+,Zoro,0,0,0,,hepimiz yok olacağız!
Dialogue: 0,0:02:05.36,0:02:07.57,Main-207+,Luffy,0,0,0,,Zoro!
Dialogue: 0,0:02:28.80,0:02:32.63,Main-207+,Kaido,0,0,0,,Ortalıkta göremesem de seslerini işitiyorum.
Dialogue: 0,0:02:32.63,0:02:36.09,Main-207+,Linlin,0,0,0,,Paçayı kurtarmışlar... Takdir ettim.
Dialogue: 0,0:02:38.01,0:02:40.72,Main-207+,Law,0,0,0,,Zoro-{\i1}ya{\i0}, yaşıyor musun?
Dialogue: 0,0:02:43.48,0:02:44.85,Main-207+,Zoro,0,0,0,,Az çok.
Dialogue: 0,0:02:44.85,0:02:47.61,Main-207+,Kid,0,0,0,,Bir anlığına da olsa iyi durdurdun.
Dialogue: 0,0:02:47.61,0:02:49.32,Main-207+,Kid,0,0,0,,Sağ olasın.
Dialogue: 0,0:02:49.90,0:02:50.98,Main-207+,Killer,0,0,0,,Hasır Şapka nerede?
Dialogue: 0,0:02:57.12,0:02:59.37,Main-207+,Luffy,0,0,0,,Kaido!
Dialogue: 0,0:03:07.04,0:03:09.71,Main-207+,Luffy,0,0,0,,{\fad(150,150)}Lastik-Lastik...
Dialogue: 0,0:03:09.71,0:03:10.63,Main-207+,Luffy,0,0,0,,{\fad(150,150)}Kızıl...
Dialogue: 0,0:03:14.42,0:03:16.80,Main-207+,Luffy,0,0,0,,Savuşturdun, Kaido!
Dialogue: 0,0:03:16.80,0:03:19.10,Main-207+,Luffy,0,0,0,,Acıtıyor belli ki!
Dialogue: 0,0:03:29.73,0:03:32.19,Main-207+,Luffy,0,0,0,,Ah, ah, ah...
Dialogue: 0,0:05:17.42,0:05:19.59,Main-207+,Orochi,0,0,0,,İşte böyle! Büyü!
Dialogue: 0,0:05:19.59,0:05:23.14,Main-207+,Orochi,0,0,0,,Daha da büyü!
Dialogue: 0,0:05:24.60,0:05:26.93,Main-207+,Pirate,0,0,0,,Sokayım, hiç etkisi olmuyor!
Dialogue: 0,0:05:26.93,0:05:29.68,Main-207+,Pirate,0,0,0,,Neden hiçbir şey yolunda gitmiyor?!
Dialogue: 0,0:05:29.68,0:05:34.94,Main-207+,Orochi,0,0,0,,Fukurokuju, patlayıcıların\Nkoyulduğu yeri biliyorsun, değil mi?
Dialogue: 0,0:05:34.94,0:05:37.32,Main-207+,Fukurokuju,0,0,0,,Biliyorum, size eşlik edeyim.
Dialogue: 0,0:05:38.78,0:05:41.36,Main-207+,Denjiro,0,0,0,,Bu alevler de ne?
Dialogue: 0,0:05:44.37,0:05:45.83,Main-207+,Orochi,0,0,0,,Geber, Kaido!
Dialogue: 0,0:05:45.83,0:05:48.58,Main-207+,Orochi,0,0,0,,Başlarım Yeni Onigashima Projesi'ne!
Dialogue: 0,0:05:48.58,0:05:49.95,Main-207+,Kin'emon,0,0,0,,Orochi!
Dialogue: 0,0:05:49.95,0:05:52.29,Main-207+,Denjiro,0,0,0,,Bunun arkasında sen mi varsın?
Dialogue: 0,0:05:52.29,0:05:54.67,Main-207+,Orochi,0,0,0,,Buradasınız demek...
Dialogue: 0,0:05:54.67,0:05:57.04,Main-207+,Orochi,0,0,0,,Kozuki'nin hayalet bozuntuları!
Dialogue: 0,0:05:58.17,0:06:00.38,Main-207+,Orochi,0,0,0,,Amacınız ne sizin be?
Dialogue: 0,0:06:00.38,0:06:04.14,Main-207+,Orochi,0,0,0,,Hiç üşenmediniz tam 20 yıl boyunca...
Dialogue: 0,0:06:04.14,0:06:06.60,Main-207+,Orochi,0,0,0,,onca şeyi göğüslediniz!
Dialogue: 0,0:06:06.60,0:06:10.43,Main-207+,Orochi,0,0,0,,Benden nefret ediyor,\Nbana sinir mi oluyorsunuz?
Dialogue: 0,0:06:10.43,0:06:12.06,Main-207+,Fukurokuju,0,0,0,,Orochi-{\i1}sama{\i0}...
Dialogue: 0,0:06:12.06,0:06:15.27,Main-207+,Fukurokuju,0,0,0,,sizin bir defa öldüğünüzden haberleri yok.
Dialogue: 0,0:06:15.27,0:06:16.73,Main-207+,Fukurokuju,0,0,0,,Siz kaçın.
Dialogue: 0,0:06:16.73,0:06:18.11,Main-207+,Fukurokuju,0,0,0,,Onlarla ben–
Dialogue: 0,0:06:18.11,0:06:20.23,Main-207+,Orochi,0,0,0,,Geri çekil, ahmak!
Dialogue: 0,0:06:21.61,0:06:23.86,Main-207+,Orochi,0,0,0,,Bitik hâldesiniz.
Dialogue: 0,0:06:23.86,0:06:25.62,Main-207+,Orochi,0,0,0,,Şaşırtıcı değil tabii!
Dialogue: 0,0:06:25.62,0:06:28.74,Main-207+,Orochi,0,0,0,,Kendi ayağınızla ölüme gittiniz!
Dialogue: 0,0:06:29.12,0:06:32.58,Main-207+,Orochi,0,0,0,,Delirmiş olmalısınız!
Dialogue: 0,0:06:32.58,0:06:35.83,Main-207+,Kin'emon,0,0,0,,Orochi, senin gibi birine\Nayıracak vaktimiz yok.
Dialogue: 0,0:06:35.83,0:06:36.96,Main-207+,Kin'emon,0,0,0,,Çekil.
Dialogue: 0,0:06:36.96,0:06:38.71,Main-207+,Orochi,0,0,0,,Ya hayır dersem?
Dialogue: 0,0:06:38.71,0:06:39.34,Main-207+,Denjiro,0,0,0,,Ne?
Dialogue: 0,0:06:54.73,0:06:58.11,Main-207+,Orochi,0,0,0,,Karşınızda kim var farkında mısınız?
Dialogue: 0,0:06:58.11,0:07:00.52,Main-207+,Orochi,0,0,0,,Haddinizi bilin lan!
Dialogue: 0,0:07:00.52,0:07:03.74,Main-207+,Orochi,0,0,0,,Ben Wano şogunuyum!
Dialogue: 0,0:07:05.86,0:07:07.82,Main-207+,Orochi,0,0,0,,Bu tavırlar ne?
Dialogue: 0,0:07:07.82,0:07:10.37,Main-207+,Orochi,0,0,0,,Ben yanlış bir şey yapmadım!
Dialogue: 0,0:07:11.62,0:07:15.41,Main-207+,Orochi,0,0,0,,Hakkım olarak Kozuki Hanesi'nden\Nöcümü aldım yalnızca!
Dialogue: 0,0:07:15.41,0:07:18.50,Main-207+,Orochi,0,0,0,,Benden alınanı geri aldım!
Dialogue: 0,0:07:26.72,0:07:29.39,Main-207+,Orochi,0,0,0,,Siz aptallar ne anlarsınız!
Dialogue: 0,0:07:29.39,0:07:33.93,Main-207+,Orochi,0,0,0,,Vatandaşlar ve samuraylar\Nşogunun önünde eğilip ona biat etmelidir!
Dialogue: 0,0:07:33.93,0:07:36.19,Main-207+,Orochi,0,0,0,,Burada sözü geçen yegâne kişi benim!
Dialogue: 0,0:07:38.23,0:07:39.86,Main-207+,Raizo,0,0,0,,{\fad(150,150)}Çiçek Shurikeni!
Dialogue: 0,0:07:42.07,0:07:46.53,Main-207+,Orochi,0,0,0,,Yanlış yapan varsa\No da beni dışlayan bu ülkedir!
Dialogue: 0,0:07:53.49,0:07:55.29,Main-207+,Orochi,0,0,0,,B-Bu bakış...
Dialogue: 0,0:07:59.75,0:08:03.50,Main-207+,Orochi,0,0,0,,Yanlış yaptığımı mı ima ediyorsun?
Dialogue: 0,0:08:03.50,0:08:04.88,Main-207+,Orochi,0,0,0,,Bakma...
Dialogue: 0,0:08:04.88,0:08:07.17,Main-207+,Orochi,0,0,0,,Bakma!
Dialogue: 0,0:08:07.88,0:08:10.34,Main-207+,Orochi,0,0,0,,Ben yanlış yapmadım!
Dialogue: 0,0:08:11.60,0:08:15.27,Main-207+,Orochi,0,0,0,,Bana öyle bakmayı kes!
Dialogue: 0,0:08:26.07,0:08:27.36,Main-207+,Fukurokuju,0,0,0,,Orochi-{\i1}sama{\i0}!
Dialogue: 0,0:08:27.90,0:08:30.57,Main-207+,Kin'emon,0,0,0,,Azabını cehennemde çek.
Dialogue: 0,0:08:30.57,0:08:31.37,Main-207+,Kin'emon,0,0,0,,Gidelim!
Dialogue: 0,0:08:34.45,0:08:36.91,Main-207+,Raizo,0,0,0,,Efendinin intikamını mı alacaksın?
Dialogue: 0,0:08:37.66,0:08:39.67,Main-207+,Raizo,0,0,0,,Hakkında yanılmışım, Fukurokuju.
Dialogue: 0,0:08:39.67,0:08:43.59,Main-207+,Raizo,0,0,0,,Gerzeğin teki de olsa\Nson nefesine kadar ona sadıksın.
Dialogue: 0,0:08:43.59,0:08:46.55,Main-207+,Fukurokuju,0,0,0,,Aynı sözleri size iade ediyorum!
Dialogue: 0,0:08:46.55,0:08:51.09,Main-207+,Fukurokuju,0,0,0,,İntikam almam gerekmese dahi\Nikimiz dövüşmeye mecburuz!
Dialogue: 0,0:08:51.09,0:08:53.18,Main-207+,Raizo,0,0,0,,Sebebini biliyorsun değil mi Raizo?
Dialogue: 0,0:08:53.18,0:08:54.18,Main-207+,Raizo,0,0,0,,Evet!
Dialogue: 0,0:08:56.18,0:08:57.22,Main-207+,Luffy,0,0,0,,Hadi!
Dialogue: 0,0:08:57.81,0:08:59.98,Main-207+,Kaido,0,0,0,,Beni hafife alma velet!
Dialogue: 0,0:09:24.54,0:09:26.17,Main-207+,Zoro,0,0,0,,Orada dur!
Dialogue: 0,0:09:29.26,0:09:31.34,Main-207+,Linlin,0,0,0,,Hepiniz birden gelseniz bile boşa!
Dialogue: 0,0:09:40.81,0:09:42.14,Main-207+,Law,0,0,0,,Yürü hadi...
Dialogue: 0,0:09:42.14,0:09:43.52,Main-207+,Kid,0,0,0,,Hergele!
Dialogue: 0,0:09:44.90,0:09:45.69,Main-207+,Luffy,0,0,0,,Sağ olun.
Dialogue: 0,0:09:51.95,0:09:54.12,Main-207+,Luffy,0,0,0,,Kaido!
Dialogue: 0,0:10:11.51,0:10:12.97,Main-207+,Kaido,0,0,0,,{\fad(150,150)}Üç Âlemin Fatihi...
Dialogue: 0,0:10:17.64,0:10:19.64,Main-207+,Kaido,0,0,0,,{\fad(150,150)}Ragnarök!
Dialogue: 0,0:10:26.11,0:10:27.06,Main-207+,Zoro,0,0,0,,Luffy!
Dialogue: 0,0:10:27.86,0:10:30.07,Main-207+,Linlin,0,0,0,,Diğerlerinin de işini bitirelim!
Dialogue: 0,0:10:34.20,0:10:35.16,Main-207+,Kid,0,0,0,,Hazır!
Dialogue: 0,0:10:35.16,0:10:35.87,Main-207+,Law,0,0,0,,Güzel!
Dialogue: 0,0:10:35.87,0:10:37.07,Main-207+,Law,0,0,0,,{\fad(150,150)}Oda!
Dialogue: 0,0:10:37.70,0:10:38.53,Main-207+,Law,0,0,0,,{\fad(150,150)}Değişim!
Dialogue: 0,0:10:40.54,0:10:42.83,Main-207+,Zeus,0,0,0,,Neredeyim ben? Çok karanlık!
Dialogue: 0,0:10:43.58,0:10:44.37,Main-207+,Linlin,0,0,0,,Zeus!
Dialogue: 0,0:10:44.37,0:10:46.38,Main-207+,Killer,0,0,0,,Yapabilecek misin, Roronoa?
Dialogue: 0,0:10:47.17,0:10:49.50,Main-207+,Zoro,0,0,0,,Başka seçeneğim yok!
Dialogue: 0,0:10:54.38,0:10:56.30,Main-207+,Zoro,0,0,0,,Ona dönmene izin vermeyeceğim!
Dialogue: 0,0:10:56.97,0:11:00.22,Main-207+,Zoro,0,0,0,,{\fad(150,150)}Alev Yaran: Altı Yol Kesişimi!
Dialogue: 0,0:11:02.73,0:11:06.15,Main-207+,Napoleon,0,0,0,,Yapmasana, ben kılıcım sadece!
Dialogue: 0,0:11:06.15,0:11:08.98,Main-207+,Zeus+Prometheus+Napoleon,0,0,0,,– Mama, yardım et!\N– Mama, yardım et!
Dialogue: 0,0:11:08.98,0:11:10.07,Main-207+,Linlin,0,0,0,,Çocuklar!
Dialogue: 0,0:11:10.07,0:11:10.86,Main-207+,Kid,0,0,0,,Şimdi!
Dialogue: 0,0:11:10.86,0:11:12.61,Main-207+,Kid,0,0,0,,{\fad(150,150)}Punk Tabancaları!
Dialogue: 0,0:11:14.90,0:11:16.53,Main-207+,Linlin,0,0,0,,Hayrola?!
Dialogue: 0,0:11:16.53,0:11:21.49,Main-207+,Linlin,0,0,0,,Onları ayırınca\Nbeni alt edebileceğinizi mi zannettiniz?
Dialogue: 0,0:11:30.21,0:11:30.92,Main-207+,Kid,0,0,0,,{\fad(150,150)}Geri Püskürt!
Dialogue: 0,0:11:33.84,0:11:34.55,Main-207+,Law,0,0,0,,{\fad(150,150)}Takt!
Dialogue: 0,0:11:38.18,0:11:39.35,Main-207+,Linlin,0,0,0,,Aptallar!
Dialogue: 0,0:11:39.35,0:11:41.72,Main-207+,Linlin,0,0,0,,Beni kaya fırlatarak alt edemezsiniz!
Dialogue: 0,0:11:46.14,0:11:47.39,Main-207+,Zoro,0,0,0,,Geber!
Dialogue: 0,0:11:49.86,0:11:50.86,Main-207+,Linlin,0,0,0,,Hay aksi!
Dialogue: 0,0:11:57.03,0:11:58.24,Main-207+,Zeus,0,0,0,,Mama!
Dialogue: 0,0:11:58.24,0:12:01.41,Main-207+,Law,0,0,0,,Yardımına gelen olmazsa\Nsenden kurtulmuş oluruz!
Dialogue: 0,0:12:03.79,0:12:05.50,Main-207+,Zoro,0,0,0,,Hoşuna gitti mi?!
Dialogue: 0,0:12:08.83,0:12:11.17,Main-207+,Linlin,0,0,0,,Yardım et...
Dialogue: 0,0:12:11.17,0:12:14.17,Main-207+,Linlin,0,0,0,,Zeus!
Dialogue: 0,0:12:16.76,0:12:18.22,Main-207+,Zeus,0,0,0,,Mama!
Dialogue: 0,0:12:18.22,0:12:20.64,Main-207+,Zeus,0,0,0,,N'oldu, Mama?!
Dialogue: 0,0:12:20.64,0:12:22.81,Main-207+,Prometheus,0,0,0,,Mama, hemen geliyor–
Dialogue: 0,0:12:29.77,0:12:31.61,Main-207+,Prometheus,0,0,0,,Mama, geliyor–
Dialogue: 0,0:12:42.32,0:12:44.45,Main-207+,Law,0,0,0,,{\t(1485,0,1,\3c&HFFFFFF&\4c&HFFFFFF&)}Herife bak...
Dialogue: 0,0:12:49.08,0:12:54.92,Main-207+,Law,0,0,0,,Daha demin direkten döndü,\Naz daha tüm kemikleri kırılacaktı!
Dialogue: 0,0:12:55.75,0:12:59.26,Main-207+,Kaido,0,0,0,,Rezilsin, Linlin!
Dialogue: 0,0:13:00.68,0:13:03.14,Main-207+,Kaido,0,0,0,,İş çıkartmasan olmaz.
Dialogue: 0,0:13:05.35,0:13:07.81,Main-207+,Kaido,0,0,0,,Baksana, Korsan Avcısı!
Dialogue: 0,0:13:08.73,0:13:11.19,Main-207+,Kaido,0,0,0,,Prometheus'u rahat bırak!
Dialogue: 0,0:13:13.73,0:13:15.15,Main-207+,Law,0,0,0,,{\fad(150,150)}Değişim!
Dialogue: 0,0:13:18.74,0:13:21.53,Main-207+,Law,0,0,0,,{\fad(150,150)}Enjeksiyon Vuruşu!
Dialogue: 0,0:13:24.78,0:13:28.70,Main-207+,Kaido,0,0,0,,Yeteneğin asabımı bozmaya başladı...
Dialogue: 0,0:13:28.70,0:13:30.87,Main-207+,Kaido,0,0,0,,Trafalgar!
Dialogue: 0,0:13:30.87,0:13:32.29,Main-207+,Law,0,0,0,,{\fad(150,150)}Perde!
Dialogue: 0,0:13:39.97,0:13:41.43,Main-207+,Prometheus,0,0,0,,Mama!
Dialogue: 0,0:13:42.51,0:13:44.01,Main-207+,Napoleon,0,0,0,,Uzak dur!
Dialogue: 0,0:13:45.10,0:13:45.68,Main-207+,Prometheus,0,0,0,,Mama!
Dialogue: 0,0:13:46.10,0:13:47.14,Main-207+,Prometheus,0,0,0,,Mama!
Dialogue: 0,0:13:47.51,0:13:49.81,Main-207+,Prometheus,0,0,0,,Mama!
Dialogue: 0,0:13:55.56,0:13:57.23,Main-207+,Zoro,0,0,0,,Hey, Trao!
Dialogue: 0,0:13:57.94,0:13:59.28,Main-207+,Zoro,0,0,0,,O ateşimsi şey...
Dialogue: 0,0:13:59.69,0:14:02.15,Main-207+,Zoro,0,0,0,,Big Mom'ı kurtarmaya gitti!
Dialogue: 0,0:14:05.28,0:14:07.12,Main-207+,Law,0,0,0,,Bırak gitsin.
Dialogue: 0,0:14:09.16,0:14:11.33,Main-207+,Law,0,0,0,,Biri öleceğine...
Dialogue: 0,0:14:12.66,0:14:15.13,Main-207+,Law,0,0,0,,varsın görev başarısız olsun.
Dialogue: 0,0:14:21.30,0:14:26.10,Main-207+,Kid,0,0,0,,Amaç Big Mom'la Kaido'yu ayırmak.
Dialogue: 0,0:14:27.72,0:14:31.02,Main-207+,Kid,0,0,0,,Bu iş için canınızı tehlikeye atmaya gerek yok!
Dialogue: 0,0:14:36.06,0:14:39.19,Main-207+,Kid,0,0,0,,Big Mom'ı bana bırakın!
Dialogue: 0,0:14:45.91,0:14:47.83,Main-207+,Prometheus,0,0,0,,Son anda!
Dialogue: 0,0:14:48.16,0:14:50.54,Main-207+,Prometheus,0,0,0,,Şükür iyisin, Mama!
Dialogue: 0,0:14:54.50,0:14:57.21,Main-207+,Linlin,0,0,0,,Canım benim.
Dialogue: 0,0:14:57.21,0:15:00.42,Main-207+,Linlin,0,0,0,,Prometheus!
Dialogue: 0,0:15:01.34,0:15:03.30,Main-207+,Linlin,0,0,0,,Peki ya...
Dialogue: 0,0:15:03.30,0:15:06.72,Main-207+,Linlin,0,0,0,,Zeus olacak hayırsız nerede?
Dialogue: 0,0:15:06.72,0:15:09.10,Main-207+,Linlin,0,0,0,,Hiçbir halta yaradığı yok!
Dialogue: 0,0:15:11.31,0:15:13.10,Main-207+,Prometheus,0,0,0,,Ben de...
Dialogue: 0,0:15:13.10,0:15:15.81,Main-207+,Prometheus,0,0,0,,aynı fikirdeyim, Mama!
Dialogue: 0,0:15:16.19,0:15:19.48,Main-207+,Prometheus,0,0,0,,Hep sakar ve uyuşuk biri oldu.
Dialogue: 0,0:15:19.48,0:15:21.23,Main-207+,Linlin,0,0,0,,Katılmamak elde değil.
Dialogue: 0,0:15:23.11,0:15:27.20,Main-207+,Prometheus,0,0,0,,Senden bir şey rica edecektim, Mama!
Dialogue: 0,0:15:28.03,0:15:29.12,Main-207+,Linlin,0,0,0,,Nedir?
Dialogue: 0,0:15:49.60,0:15:53.06,Main-207+,Kaido,0,0,0,,Hasır Şapka'nın yüzüne bakın!
Dialogue: 0,0:15:53.39,0:15:57.39,Main-207+,Kaido,0,0,0,,Geçen de böyleydi.
Dialogue: 0,0:15:57.39,0:16:01.36,Main-207+,Kaido,0,0,0,,Bilincini kaybetse de...
Dialogue: 0,0:16:01.36,0:16:04.94,Main-207+,Kaido,0,0,0,,bana bakmaya devam ediyordu.
Dialogue: 0,0:16:07.91,0:16:09.87,Main-207+,Kaido,0,0,0,,Önce...
Dialogue: 0,0:16:09.87,0:16:13.08,Main-207+,Kaido,0,0,0,,bu gözleri mi parçalasam?
Dialogue: 0,0:16:14.20,0:16:16.29,Main-207+,Kaido,0,0,0,,Yoksa...
Dialogue: 0,0:16:16.29,0:16:17.87,Main-207+,Kaido,0,0,0,,beynini mi?
Dialogue: 0,0:16:18.42,0:16:20.63,Main-207+,Kaido,0,0,0,,Ya da kalbini!
Dialogue: 0,0:16:21.38,0:16:22.59,Main-207+,Zoro,0,0,0,,Trao.
Dialogue: 0,0:16:24.92,0:16:27.34,Main-207+,Zoro,0,0,0,,Şimdi yapacağım şeyle...
Dialogue: 0,0:16:27.67,0:16:29.89,Main-207+,Zoro,0,0,0,,enerjim tükenecek.
Dialogue: 0,0:16:30.51,0:16:31.60,Main-207+,Law,0,0,0,,Zoro-{\i1}ya{\i0}?!
Dialogue: 0,0:16:31.97,0:16:34.31,Main-207+,Zoro,0,0,0,,Dövüş uzadıkça...
Dialogue: 0,0:16:34.31,0:16:36.77,Main-207+,Zoro,0,0,0,,bir bir yıkılacağız.
Dialogue: 0,0:16:38.64,0:16:41.15,Main-207+,Zoro,0,0,0,,İşe yaramazsa...
Dialogue: 0,0:16:41.15,0:16:43.07,Main-207+,Zoro,0,0,0,,öldüm demektir.
Dialogue: 0,0:16:43.48,0:16:44.82,Main-207+,Zoro,0,0,0,,Gerisi...
Dialogue: 0,0:16:46.78,0:16:47.86,Main-207+,Zoro,0,0,0,,sana emanet.
Dialogue: 0,0:16:59.41,0:17:01.33,Main-207+,Zeus,0,0,0,,Hey, Kaido!
Dialogue: 0,0:17:05.55,0:17:09.13,Main-207+,Zoro,0,0,0,,O benim kaptanım!
Dialogue: 0,0:17:10.84,0:17:13.89,Main-207+,Zoro,0,0,0,,Beyin parçalayacaksan...
Dialogue: 0,0:17:14.43,0:17:17.68,Main-207+,Zoro,0,0,0,,ilk sırada ben varım!
Dialogue: 0,0:17:21.98,0:17:24.98,Main-207+,Zoro,0,0,0,,{\fad(150,150)}Şeytani Dokuz Kılıç Stili!
Dialogue: 0,0:17:28.03,0:17:29.15,Main-207+,Zoro,0,0,0,,{\fad(150,150)}Asura!
Dialogue: 0,0:17:30.11,0:17:31.91,Main-207+,Zoro,0,0,0,,{\fad(150,150)}Çekilmiş Kılıçlar!
Dialogue: 0,0:17:53.64,0:17:55.97,Main-207+,Zoro,0,0,0,,{\fad(150,150)}Dokuz Kılıç Stili!
Dialogue: 0,0:18:15.16,0:18:17.83,Main-207+,Zoro,0,0,0,,{\fad(150,150)}Asura: Çekilmiş Kılıçlar...
Dialogue: 0,0:18:18.45,0:18:21.04,Main-207+,Zoro,0,0,0,,{\fad(150,150)}Ölü Adamın Gösterisi!
Dialogue: 0,0:18:49.82,0:18:51.15,Main-207+,Kaido,0,0,0,,Siktir.
Dialogue: 0,0:18:56.20,0:18:57.91,Thoughts-207+,Kaido,0,0,0,,Bu velette...
Dialogue: 0,0:18:58.70,0:19:00.66,Main-207+,Kaido,0,0,0,,Sende de mi...
Dialogue: 0,0:19:00.66,0:19:02.83,Main-207+,Kaido,0,0,0,,kralın hakisi var?
Dialogue: 0,0:19:04.83,0:19:06.79,Main-207+,Zoro,0,0,0,,Ne saçmalıyorsun be?
Dialogue: 0,0:19:08.96,0:19:11.42,Main-207+,Zoro,0,0,0,,Bir bok anlamadım.
Dialogue: 0,0:19:14.01,0:19:17.80,Main-207+,Zoro,0,0,0,,O saldırıya varımı yoğumu koymuştum!
Dialogue: 0,0:19:21.52,0:19:25.60,Main-207+,Zoro,0,0,0,,Yere düşseydin bari.
Dialogue: 0,0:19:26.40,0:19:29.11,Main-207+,Kaido,0,0,0,,Kendinle iftihar et.
Dialogue: 0,0:19:29.11,0:19:31.69,Main-207+,Kaido,0,0,0,,Bu yaranın izi kalacak.
Dialogue: 0,0:19:40.24,0:19:43.50,Main-207+,Kaido,0,0,0,,Nasıl bela bir nesilsiniz.
Dialogue: 0,0:19:49.58,0:19:52.17,Main-207+,Law,0,0,0,,Hey! Zoro-{\i1}ya{\i0}, kaç!
Dialogue: 0,0:19:57.22,0:20:02.22,Main-207+,Kaido,0,0,0,,Sen gelmekle uğraşma.
Dialogue: 0,0:20:02.81,0:20:06.02,Main-207+,Kaido,0,0,0,,{\fad(150,150)}Gök Gürültüsü Bagua!
Dialogue: 0,0:20:30.96,0:20:32.46,Main-207+,Kaido,0,0,0,,Yazık...
Dialogue: 0,0:20:32.46,0:20:36.38,Main-207+,Kaido,0,0,0,,Yanımda yürüseydiniz dünyayı dize getirirdik.
Dialogue: 0,0:20:37.01,0:20:38.76,Main-207+,Luffy,0,0,0,,Yanında mı?
Dialogue: 0,0:20:38.76,0:20:41.47,Main-207+,Luffy,0,0,0,,Yanında asla yürümeyiz, salak!
Dialogue: 0,0:20:44.72,0:20:48.48,Main-207+,Luffy,0,0,0,,Biz samurayların hastasıyız.
Dialogue: 0,0:20:52.65,0:20:55.78,Main-207+,Luffy,0,0,0,,Sana gününü göstereceğim.
Dialogue: 0,0:21:00.03,0:21:02.28,Main-207+,Kaido,0,0,0,,Günümü mü...
Dialogue: 0,0:21:02.28,0:21:04.37,Main-207+,Kaido,0,0,0,,göstereceksin?
Dialogue: 0,0:21:10.50,0:21:12.96,Main-207+,Kaido,0,0,0,,Hodri meydan.
Dialogue: 0,0:21:13.50,0:21:16.59,Main-207+,Kaido,0,0,0,,Gelişigüzel yumruk savurarak...
Dialogue: 0,0:21:17.13,0:21:19.51,Main-207+,Kaido,0,0,0,,nasıl yapacaksın görelim!
Dialogue: 0,0:21:25.68,0:21:27.64,Flashbacks-207+,Hyogoro,0,0,0,,Kendini zorlama!{Wano 21 - 08:53}
Dialogue: 0,0:21:27.64,0:21:34.69,Flashbacks-207+,Hyogoro,0,0,0,,Bu hem görünmez bir zırh hem de\Nsaldırı amaçlı kullanılan devasa bir güçtür.{Wano 25 - 20:49 ("It's" was added for here since its a fragment in 25)}
Dialogue: 0,0:21:35.23,0:21:38.19,Flashbacks-207+,Hyogoro,0,0,0,,{\fad(0,268)}Lakin bir üst seviyeye ulaştığında,{Wano 25 - 20:59}
Dialogue: 0,0:21:38.78,0:21:41.86,Flashbacks-207+,Hyogoro,0,0,0,,seni kaplayan haki daha da güçlenerek...{Wano 25 - 21:03}
Dialogue: 0,0:21:42.53,0:21:46.03,Flashbacks-207+,Hyogoro,0,0,0,,hasmının içine nüfuz ederek\Nonu içeriden paramparça eder.{Wano 25 - 21:06}
Dialogue: 0,0:21:48.75,0:21:50.41,Flashbacks-207+,Hyogoro,0,0,0,,Kaba kuvvetle olmaz.{Wano 21 - 09:11; this ep - 24:00}
Dialogue: 0,0:21:50.41,0:21:54.38,Flashbacks-207+,Hyogoro,0,0,0,,Bedenindeki o atıl hakiyi yumruğuna akıtmalısın!{Wano 21 - 09:13; this ep - 24:01}
Dialogue: 0,0:21:57.17,0:21:59.26,Flashbacks-207+,Luffy,0,0,0,,{\fad(150,150)}Kong Silahı!{Wano 56}
Dialogue: 0,0:22:05.64,0:22:07.89,Main-207+,Luffy,0,0,0,,Hâlâ çok sığ.
Dialogue: 0,0:22:08.56,0:22:12.81,Flashbacks-207+,Hyogoro,0,0,0,,Güç, en karanlık anlarda çiçek açar!{Wano 25 - 16:20}{needs fade maybe}
Dialogue: 0,0:22:15.27,0:22:18.57,Main-207+,Luffy,0,0,0,,Çivili sopanı yiyince bir şey fark ettim.
Dialogue: 0,0:22:21.24,0:22:24.70,Main-207+,Luffy,0,0,0,,Kendini kralın hakisiyle kaplayabiliyorsun değil mi?
Dialogue: 0,0:22:29.87,0:22:33.25,Main-207+,Kaido,0,0,0,,Bunu bilmenin sana ne yararı olacak?
Dialogue: 0,0:22:33.25,0:22:35.13,Main-207+,Kaido,0,0,0,,Yapabilecek misin?
Dialogue: 0,0:22:46.55,0:22:49.35,Main-207+,Kaido,0,0,0,,Bunu ancak...
Dialogue: 0,0:22:49.35,0:22:52.93,Main-207+,Kaido,0,0,0,,bir avuç insan yapabilir...
Dialogue: 0,0:22:52.93,0:22:54.73,Main-207+,Kaido,0,0,0,,seni yürüyen ölü!
Dialogue: 0,0:23:54.62,0:23:56.46,Flashbacks-207+,Hyogoro,0,0,0,,Kaba kuvvetle olmaz.{Wano 21 - 09:11; this ep - 21:54}
Dialogue: 0,0:23:56.46,0:24:00.38,Flashbacks-207+,Hyogoro,0,0,0,,Bedenindeki o atıl hakiyi yumruğuna akıtmalısın!{Wano 21 - 09:13; this ep - 21:55}
Dialogue: 0,0:24:57.81,0:24:59.31,Main-207+,Law,0,0,0,,Ona dokunmadı bile.
Dialogue: 0,0:25:31.93,0:25:33.22,Main-207+,Luffy,0,0,0,,Zoro...
Dialogue: 0,0:25:35.56,0:25:37.06,Main-207+,Luffy,0,0,0,,Trao...
Dialogue: 0,0:25:38.06,0:25:41.52,Main-207+,Luffy,0,0,0,,Beni koruduğunuz için sağ olun.
Dialogue: 0,0:25:42.94,0:25:45.11,Main-207+,Luffy,0,0,0,,Siz aşağı inin!
Dialogue: 0,0:25:45.57,0:25:49.07,Main-207+,Luffy,0,0,0,,Onu ne pahasına olursa olsun yeneceğim!
Dialogue: 0,0:25:55.66,0:25:57.62,Main-207+,Luffy,0,0,0,,Gidip bunu...
Dialogue: 0,0:25:58.24,0:25:59.70,Main-207+,Luffy,0,0,0,,herkese söyleyin!
