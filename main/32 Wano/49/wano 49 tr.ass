Comment: 0,0:00:00.00,0:00:00.00,Main-207+,,0,0,0,,{=28}===============================DIALOGUE============================
Dialogue: 0,0:01:32.70,0:01:34.24,Main-207+,,0,0,0,,Doğru...
Dialogue: 0,0:01:34.24,0:01:40.50,Main-207+,,0,0,0,,Minkler, dolunay gecesinde\NSulong denilen bir hâle bürünüyor!
Dialogue: 0,0:01:53.30,0:01:54.72,Main-207+,,0,0,0,,Jack!
Dialogue: 0,0:02:00.93,0:02:03.98,Main-207+,,0,0,0,,Yapacağınızı yaptınız, samuraylar!
Dialogue: 0,0:02:05.15,0:02:09.11,Main-207+,,0,0,0,,Buraya kadar sızabilmeniz bizim hatamız!
Dialogue: 0,0:02:10.11,0:02:14.91,Main-207+,,0,0,0,,Bir daha asla\NKaido-{\i1}san{\i0}'a yaklaşabileceğinizi düşünmeyin!
Dialogue: 0,0:02:18.20,0:02:20.37,Main-207+,,0,0,0,,Siz-{\i1}gara{\i0}lar durun!
Dialogue: 0,0:02:21.29,0:02:27.50,Main-207+,,0,0,0,,Jack, bin yıllık düklüğümüzü yerle bir\Nettiği anda bizim ezeli düşmanımız oldu.
Dialogue: 0,0:02:27.50,0:02:31.34,Main-207+,,0,0,0,,Kaç kere samuray falan yok dememize rağmen dinlemedi.
Dialogue: 0,0:02:31.34,0:02:35.30,Main-207+,,0,0,0,,Onların yok dediği savaşçı işte karşında, Jack!
Dialogue: 0,0:02:36.64,0:02:37.93,Main-207+,,0,0,0,,Demek sendin!
Dialogue: 0,0:02:38.30,0:02:40.06,Main-207+,,0,0,0,,Korudukları hayatımı...
Dialogue: 0,0:02:40.06,0:02:43.89,Main-207+,,0,0,0,,bu noktada feda etmekten geri durmayacağım!
Dialogue: 0,0:02:57.66,0:02:59.41,Main-207+,,0,0,0,,Efendimiz bekleyin...
Dialogue: 0,0:02:59.41,0:03:01.58,Main-207+,,0,0,0,,Lütfen gücünüzu Kaido'ya saklayın!
Dialogue: 0,0:03:01.58,0:03:03.33,Main-207+,,0,0,0,,Efendimiz, siz de!
Dialogue: 0,0:03:18.01,0:03:20.22,Main-207+,,0,0,0,,O hâlde size bırakıyorum!
Dialogue: 0,0:03:20.60,0:03:22.22,Main-207+,,0,0,0,,Sağ olun!
Dialogue: 0,0:03:22.22,0:03:26.94,Main-207+,,0,0,0,,Öyleyse gücümün her bir zerresini\NKaido'yu alt etmek için kullanacağım!
Dialogue: 0,0:04:36.09,0:04:37.59,Main-207+,,0,0,0,,Korkmayın,
Dialogue: 0,0:04:37.59,0:04:39.80,Main-207+,,0,0,0,,Sulong formlarının ömrü kısadır!
Dialogue: 0,0:04:39.80,0:04:41.47,Main-207+,,0,0,0,,Gelin bakalım,
Dialogue: 0,0:04:41.47,0:04:43.43,Main-207+,,0,0,0,,biz de canavarız!
Dialogue: 0,0:05:07.50,0:05:09.46,Main-207+,,0,0,0,,Başladılar.
Dialogue: 0,0:05:09.79,0:05:13.54,Main-207+,,0,0,0,,Jack adisi yukarı mı çıktı?
Dialogue: 0,0:05:13.54,0:05:16.59,Main-207+,,0,0,0,,Senden farklı o, düşünceli biri.
Dialogue: 0,0:05:16.59,0:05:18.17,Main-207+,,0,0,0,,Heh?!
Dialogue: 0,0:05:18.17,0:05:23.64,Main-207+,,0,0,0,,King, adi herif seni!\NBir karın ağrın falan mı var..
Dialogue: 0,0:05:23.64,0:05:25.72,Main-207+,,0,0,0,,lan?!
Dialogue: 0,0:05:25.72,0:05:27.60,Main-207+,,0,0,0,,Shinobu?!
Dialogue: 0,0:05:28.81,0:05:31.19,Main-207+,,0,0,0,,{\fad(150,150)}Olgun-Olgun Baştan Çıkarma Tekniği!
Dialogue: 0,0:05:39.90,0:05:40.86,Main-207+,,0,0,0,,Sessizce...
Dialogue: 0,0:05:52.62,0:05:53.79,Main-207+,,0,0,0,,Eyvah!
Dialogue: 0,0:05:56.88,0:05:58.05,Main-207+,,0,0,0,,Shinobu!
Dialogue: 0,0:06:02.26,0:06:04.59,Main-207+,,0,0,0,,Fikir fena değildi...
Dialogue: 0,0:06:04.59,0:06:05.97,Main-207+,,0,0,0,,ama...
Dialogue: 0,0:06:05.97,0:06:07.85,Main-207+,,0,0,0,,uygulamada batırdın!
Dialogue: 0,0:06:21.74,0:06:23.32,Main-207+,,0,0,0,,Shinobu!
Dialogue: 0,0:06:28.16,0:06:29.41,Main-207+,,0,0,0,,Shinobu-{\i1}chan{\i0}...
Dialogue: 0,0:06:32.91,0:06:36.00,Main-207+,,0,0,0,,Shinobu!
Dialogue: 0,0:06:36.00,0:06:37.34,Main-207+,,0,0,0,,Momonosuke-{\i1}sama{\i0}...
Dialogue: 0,0:06:40.88,0:06:43.55,Main-207+,,0,0,0,,Yenilmenin utancı içindeyim!
Dialogue: 0,0:06:43.55,0:06:44.80,Main-207+,,0,0,0,,Bir kez daha!
Dialogue: 0,0:06:55.52,0:06:56.56,Main-207+,,0,0,0,,O neydi?
Dialogue: 0,0:06:58.19,0:07:00.57,Main-207+,,0,0,0,,Ne?! Havada süzülüyor!
Dialogue: 0,0:07:00.57,0:07:02.49,Main-207+,,0,0,0,,Yani uçuyor!
Dialogue: 0,0:07:08.74,0:07:09.99,Main-207+,,0,0,0,,Çok yüksek,
Dialogue: 0,0:07:09.99,0:07:12.45,Main-207+,,0,0,0,,korkuyorum!
Dialogue: 0,0:07:15.41,0:07:17.12,Main-207+,,0,0,0,,Momonosuke-{\i1}sama{\i0}...
Dialogue: 0,0:07:17.12,0:07:18.67,Main-207+,,0,0,0,,Neler oluyor?
Dialogue: 0,0:07:24.63,0:07:26.55,Main-207+,,0,0,0,,Kaido-{\i1}san{\i0}'ın yerine...
Dialogue: 0,0:07:26.55,0:07:28.22,Main-207+,,0,0,0,,seni ben infaz edeceğim!
Dialogue: 0,0:07:46.28,0:07:48.20,Main-207+,,0,0,0,,O da ne?!
Dialogue: 0,0:07:48.20,0:07:49.41,Main-207+,,0,0,0,,Harbiden, o ne?
Dialogue: 0,0:08:00.67,0:08:02.38,Main-207+,,0,0,0,,Sangoro!
Dialogue: 0,0:08:02.38,0:08:03.75,Main-207+,,0,0,0,,Sanji-{\i1}kun{\i0}?!
Dialogue: 0,0:08:03.75,0:08:05.63,Main-207+,,0,0,0,,Sanji!
Dialogue: 0,0:08:05.63,0:08:06.92,Main-207+,,0,0,0,,Süpersin!
Dialogue: 0,0:08:10.93,0:08:16.31,Main-207+,,0,0,0,,Çocuğu geri ver! Bu dünyadan mutlak silinmesi gereken biri o!
Dialogue: 0,0:08:34.83,0:08:36.29,Main-207+,,0,0,0,,Momonosuke-{\i1}sama{\i0}!
Dialogue: 0,0:08:42.04,0:08:43.38,Main-207+,,0,0,0,,Hey, Momo!
Dialogue: 0,0:08:44.42,0:08:46.67,Main-207+,,0,0,0,,Az önceki sözlerin...
Dialogue: 0,0:08:46.67,0:08:47.88,Main-207+,,0,0,0,,içime dokundu!
Dialogue: 0,0:08:48.67,0:08:50.13,Main-207+,,0,0,0,,Sangoro...!
Dialogue: 0,0:08:52.26,0:08:54.39,Main-207+,,0,0,0,,Shinobu-{\i1}chan{\i0}, Momo sana emanet!
Dialogue: 0,0:08:54.39,0:08:55.77,Main-207+,,0,0,0,,Pekâlâ!
Dialogue: 0,0:08:56.35,0:08:58.81,Main-207+,,0,0,0,,Sağ ol, Sangoro!
Dialogue: 0,0:08:59.56,0:09:01.35,Main-207+,,0,0,0,,Kozuki ölmeli!
Dialogue: 0,0:09:04.44,0:09:06.86,Main-207+,,0,0,0,,Oo, lan, lan!
Dialogue: 0,0:09:07.44,0:09:09.15,Main-207+,,0,0,0,,Böyle olmayacak,
Dialogue: 0,0:09:09.15,0:09:10.57,Main-207+,,0,0,0,,durum kötü!
Dialogue: 0,0:09:14.66,0:09:16.66,Main-207+,,0,0,0,,Yapma, kuş beyinli seni!
Dialogue: 0,0:09:18.08,0:09:21.87,Main-207+,,0,0,0,,Böyle giderse karnımı delecek ve öleceğim!
Dialogue: 0,0:09:22.33,0:09:25.17,Main-207+,,0,0,0,,Ne delmesi, seni ikiye ayıracağım!
Dialogue: 0,0:09:25.88,0:09:28.34,Main-207+,,0,0,0,,Hani nerede şu dandik gizlenme numaran?!
Dialogue: 0,0:09:29.51,0:09:32.18,Main-207+,,0,0,0,,Sadece bir tür kamuflaj maalesef.
Dialogue: 0,0:09:33.05,0:09:34.80,Main-207+,,0,0,0,,Bırak beni artık!
Dialogue: 0,0:09:34.80,0:09:36.26,Main-207+,,0,0,0,,İşin bitti!
Dialogue: 0,0:09:41.23,0:09:43.19,Main-207+,,0,0,0,,Sanji!
Dialogue: 0,0:09:48.73,0:09:52.74,Main-207+,,0,0,0,,Ne fena bir saldırıydı öyle...
Dialogue: 0,0:09:52.74,0:09:55.28,Main-207+,,0,0,0,,Yamao, Momo sende!
Dialogue: 0,0:09:55.28,0:09:57.16,Main-207+,,0,0,0,,Sahinobu'yla birlikte koruyun onu!
Dialogue: 0,0:09:57.16,0:09:58.33,Main-207+,,0,0,0,,Heh?! Emin misin?
Dialogue: 0,0:09:58.70,0:10:00.45,Main-207+,,0,0,0,,Tabii ki eminim!
Dialogue: 0,0:10:00.45,0:10:03.42,Main-207+,,0,0,0,,Haklısın, olması gereken bu!
Dialogue: 0,0:10:03.42,0:10:05.88,Main-207+,,0,0,0,,Ne de olsa o benim oğlum!
Dialogue: 0,0:10:08.30,0:10:09.67,Main-207+,,0,0,0,,Hemen git!
Dialogue: 0,0:10:09.67,0:10:11.72,Main-207+,,0,0,0,,Bana bırak!
Dialogue: 0,0:10:11.72,0:10:14.93,Main-207+,,0,0,0,,Babalar evlatlarını kurtarır zaten!
Dialogue: 0,0:10:14.93,0:10:16.55,Main-207+,,0,0,0,,Hey, beni yok sayma!
Dialogue: 0,0:10:16.55,0:10:18.39,Main-207+,,0,0,0,,Bekle beni, Momonosuke!
Dialogue: 0,0:10:18.39,0:10:21.43,Main-207+,,0,0,0,,Baban şimdi geliyor!
Dialogue: 0,0:10:19.14,0:10:21.43,Secondary-207+,,0,0,0,,Hey! Dursana be!
Dialogue: 0,0:10:21.43,0:10:24.02,Main-207+,,0,0,0,,Kaçamayacaksın!
Dialogue: 0,0:10:28.15,0:10:30.86,Main-207+,,0,0,0,,Millet,
Dialogue: 0,0:10:30.86,0:10:35.45,Main-207+,,0,0,0,,işgale gelen samurayların hepsini gebertin de...
Dialogue: 0,0:10:35.45,0:10:37.95,Main-207+,,0,0,0,,kutlamaya devam edelim!
Dialogue: 0,0:10:42.62,0:10:43.83,Main-207+,,0,0,0,,Sana gelince...
Dialogue: 0,0:10:44.29,0:10:48.84,Main-207+,,0,0,0,,Düğün, çay partisi, şimdi de bu ziyafet!
Dialogue: 0,0:10:48.84,0:10:53.13,Main-207+,,0,0,0,,Milletin eğlencesini mahvetmekte üstüne yok!
Dialogue: 0,0:10:53.13,0:10:58.72,Main-207+,,0,0,0,,Seni en uygun şekilde öldüreceğim!
Dialogue: 0,0:10:59.35,0:11:03.48,Main-207+,,0,0,0,,Son anların acınası olacak!
Dialogue: 0,0:11:06.02,0:11:08.48,Main-207+,,0,0,0,,{\fad(150,150)}Şanlı Ulus!
Dialogue: 0,0:11:08.48,0:11:09.02,Main-207+,,0,0,0,,Hass!
Dialogue: 0,0:11:29.79,0:11:31.17,Main-207+,,0,0,0,,Canıma mı kastın be?
Dialogue: 0,0:11:40.68,0:11:43.10,Main-207+,,0,0,0,,Canavar mı lan bu kocakarı?
Dialogue: 0,0:11:43.10,0:11:49.44,Main-207+,,0,0,0,,Onun da Kaido gibi, adı çıkmış korsanların\Nkaptanı olduğunu duymuştum!
Dialogue: 0,0:11:49.44,0:11:54.57,Main-207+,,0,0,0,,Ne?! O hâlde düşmanımız iki Kaido mu demek oluyor?
Dialogue: 0,0:11:54.57,0:11:58.78,Main-207+,,0,0,0,,Bir an önce, Momo ve Sanji'yi kurtarmaya gitmek istiyorum...
Dialogue: 0,0:11:58.81,0:12:03.27,Main-207+,,0,0,0,,ama buna izin vermeye niyeti yok gibi!
Dialogue: 0,0:12:03.29,0:12:05.83,Main-207+,,0,0,0,,Kahrolası Hasır Şapka,
Dialogue: 0,0:12:05.83,0:12:08.17,Main-207+,,0,0,0,,iyi kaçındın!
Dialogue: 0,0:12:09.38,0:12:10.71,Main-207+,,0,0,0,,Buraya gel, Zeus!
Dialogue: 0,0:12:16.76,0:12:18.88,Main-207+,,0,0,0,,Zeus, ne oldu?
Dialogue: 0,0:12:19.97,0:12:21.01,Main-207+,,0,0,0,,Sen!
Dialogue: 0,0:12:21.01,0:12:21.85,Main-207+,,0,0,0,,Fark etti!
Dialogue: 0,0:12:21.85,0:12:24.68,Main-207+,,0,0,0,,Nafile, nafile, nafile, nafile, nafile!
Dialogue: 0,0:12:24.68,0:12:27.02,Main-207+,,0,0,0,,Nami, öldürüleceğiz!
Dialogue: 0,0:12:27.52,0:12:29.19,Main-207+,,0,0,0,,Kötü çocuk seni!
Dialogue: 0,0:12:31.06,0:12:34.40,Main-207+,,0,0,0,,Haydi, dön bakalım!
Dialogue: 0,0:12:34.40,0:12:36.99,Main-207+,,0,0,0,,P-Peki, Mama!
Dialogue: 0,0:12:36.99,0:12:38.32,Main-207+,,0,0,0,,Zeus!
Dialogue: 0,0:12:38.32,0:12:40.20,Main-207+,,0,0,0,,Ben mi Big Mom mı,
Dialogue: 0,0:12:40.20,0:12:41.87,Main-207+,,0,0,0,,hangimizi seçeceksin?
Dialogue: 0,0:12:43.20,0:12:45.08,Main-207+,,0,0,0,,Mama'ya karşı gelemem!
Dialogue: 0,0:12:45.08,0:12:47.75,Main-207+,,0,0,0,,Sıktınız artık!
Dialogue: 0,0:12:53.34,0:12:56.55,Main-207+,,0,0,0,,Naaamiii!
Dialogue: 0,0:12:57.01,0:13:00.34,Main-207+,,0,0,0,,Canı çıkasıca Hırsız Kedi seni!
Dialogue: 0,0:13:04.39,0:13:07.02,Main-207+,,0,0,0,,Ben hatalıydım,
Dialogue: 0,0:13:07.02,0:13:08.89,Main-207+,,0,0,0,,özür dilerim Mama!
Dialogue: 0,0:13:08.89,0:13:14.19,Main-207+,,0,0,0,,Bir daha gitmeyeceğim, affet beni!
Dialogue: 0,0:13:14.19,0:13:17.61,Main-207+,,0,0,0,,Bak hele, taraf da değiştirirmiş!
Dialogue: 0,0:13:18.99,0:13:25.58,Main-207+,,0,0,0,,Onun gibi bir kadının peşinden giden birine\Nkim inanır ki?
Dialogue: 0,0:13:26.79,0:13:29.29,Main-207+,,0,0,0,,Ne yapmam lazım benim...
Dialogue: 0,0:13:29.29,0:13:32.21,Main-207+,,0,0,0,,güvenini yeniden kazanmam için?
Dialogue: 0,0:13:32.71,0:13:34.71,Main-207+,,0,0,0,,Belli değil mi?
Dialogue: 0,0:13:35.25,0:13:38.34,Main-207+,,0,0,0,,O kadının hakkından gel!
Dialogue: 0,0:13:41.84,0:13:42.93,Main-207+,,0,0,0,,Saat mi?
Dialogue: 0,0:13:42.93,0:13:45.68,Main-207+,,0,0,0,,{\fad(150,150)}♪ Attım gitti! ♪
Dialogue: 0,0:13:45.68,0:13:48.60,Main-207+,,0,0,0,,{\fad(150,150)}♪ Bana rüzgâr derler! ♪
Dialogue: 0,0:13:51.06,0:13:54.19,Main-207+,,0,0,0,,Anladın, değil mi Zeus?
Dialogue: 0,0:13:54.19,0:13:56.61,Main-207+,,0,0,0,,Elinden geleni yapmazsan silerim seni!
Dialogue: 0,0:13:58.28,0:13:59.57,Main-207+,,0,0,0,,Olamaz!
Dialogue: 0,0:13:59.57,0:14:02.32,Main-207+,,0,0,0,,{\fad(150,150)}Ruh Sensörü: Aktif!
Dialogue: 0,0:14:06.24,0:14:09.08,Main-207+,,0,0,0,,Özür dilerim, Nami!
Dialogue: 0,0:14:09.08,0:14:11.71,Main-207+,,0,0,0,,Huzur içinde uyuyasın!
Dialogue: 0,0:14:11.71,0:14:14.04,Main-207+,,0,0,0,,Senden nefret ediyorum!
Dialogue: 0,0:14:14.04,0:14:16.09,Main-207+,,0,0,0,,Tüm ilişkimiz bitti!
Dialogue: 0,0:14:19.05,0:14:22.09,Main-207+,,0,0,0,,Kurtarın beni!
Dialogue: 0,0:14:22.09,0:14:23.26,Main-207+,,0,0,0,,Kanatlar mı?
Dialogue: 0,0:14:23.26,0:14:25.43,Main-207+,,0,0,0,,{\fad(150,150)}♪ Genişçe açacağım! ♪
Dialogue: 0,0:14:25.43,0:14:27.30,Main-207+,,0,0,0,,{\fad(150,150)}♪ Çünkü ben bir kuşum! ♪
Dialogue: 0,0:14:27.72,0:14:33.23,Main-207+,,0,0,0,,{\fad(150,150)}– ♪ Kanat çırpıp uçacağım! ♪\N– ♪ Kanat çırpıp uçacağım! ♪
Dialogue: 0,0:14:33.23,0:14:39.11,Main-207+,,0,0,0,,{\fad(150,150)}– ♪ Gökyüzünde, rüzgârlarla! ♪\N– ♪ Gökyüzünde, rüzgârlarla! ♪
Dialogue: 0,0:14:40.40,0:14:47.24,Main-207+,,0,0,0,,{\fad(150,150)}♪ Bana derler, özgür sürücü Franky! ♪
Dialogue: 0,0:15:00.63,0:15:02.42,Main-207+,,0,0,0,,İşte, kılıcımın tadına baktın!
Dialogue: 0,0:15:04.30,0:15:05.97,Main-207+,,0,0,0,,– Ne?!\N– Ne?!
Dialogue: 0,0:15:07.18,0:15:08.01,Main-207+,,0,0,0,,Heh?
Dialogue: 0,0:15:13.56,0:15:17.23,Main-207+,,0,0,0,,Tüh! Bir şeyi ezdim gibi.
Dialogue: 0,0:15:20.61,0:15:22.03,Main-207+,,0,0,0,,Gerçi dert değil...
Dialogue: 0,0:15:22.82,0:15:25.15,Main-207+,,0,0,0,,bir çiçek değilse eğer.
Dialogue: 0,0:15:28.41,0:15:30.62,Main-207+,,0,0,0,,Abiciğim!
Dialogue: 0,0:15:33.75,0:15:34.71,Main-207+,,0,0,0,,Mama...!
Dialogue: 0,0:15:35.00,0:15:36.00,Main-207+,,0,0,0,,Mama!
Dialogue: 0,0:15:36.37,0:15:38.50,Main-207+,,0,0,0,,Bittiniz siz!
Dialogue: 0,0:15:38.50,0:15:41.13,Main-207+,,0,0,0,,Artık ölüsünüz!
Dialogue: 0,0:15:43.46,0:15:47.18,Main-207+,,0,0,0,,Motoruyla Big Mom'ı ezdi geçti!
Dialogue: 0,0:15:51.35,0:15:53.39,Main-207+,,0,0,0,,Abiciğim!
Dialogue: 0,0:15:56.39,0:15:58.35,Main-207+,,0,0,0,,Teşekkür ederim, Franky!
Dialogue: 0,0:15:58.81,0:16:00.02,Main-207+,,0,0,0,,Nami!
Dialogue: 0,0:16:00.65,0:16:01.73,Main-207+,,0,0,0,,İyi misin?!
Dialogue: 0,0:16:01.73,0:16:03.61,Main-207+,,0,0,0,,İyiyim iyiyim çok iyiyim!
Dialogue: 0,0:16:04.15,0:16:06.53,Main-207+,,0,0,0,,Abim buradaysa her şey çözülür!
Dialogue: 0,0:16:08.16,0:16:10.03,Main-207+,,0,0,0,,Samuraylarım, saldırın!
Dialogue: 0,0:16:16.41,0:16:18.29,Main-207+,,0,0,0,,Başlamış bile.
Dialogue: 0,0:16:18.83,0:16:20.71,Main-207+,,0,0,0,,Bak hele..
Dialogue: 0,0:16:20.71,0:16:23.09,Main-207+,,0,0,0,,Kocaman bir karmaşa.
Dialogue: 0,0:16:23.09,0:16:25.84,Main-207+,,0,0,0,,Bana biraz yardım et, Nico Robin.
Dialogue: 0,0:16:25.84,0:16:27.97,Main-207+,,0,0,0,,Tabii, memnuniyetle.
Dialogue: 0,0:16:29.59,0:16:31.01,Main-207+,,0,0,0,,Çok iyi!
Dialogue: 0,0:16:31.01,0:16:33.22,Main-207+,,0,0,0,,Franky ve Brook'tan beklediğim gibi.
Dialogue: 0,0:16:33.22,0:16:35.56,Main-207+,,0,0,0,,O hâlde ben de...
Dialogue: 0,0:16:36.23,0:16:38.14,Main-207+,,0,0,0,,Kin'emon'un olduğu yere...
Dialogue: 0,0:16:38.48,0:16:39.60,Main-207+,,0,0,0,,gidiyorum!
Dialogue: 0,0:16:44.53,0:16:45.57,Main-207+,,0,0,0,,Buldum sizi!
Dialogue: 0,0:16:47.69,0:16:49.20,Main-207+,,0,0,0,,Çok şükür iyisiniz!
Dialogue: 0,0:16:49.20,0:16:51.32,Main-207+,,0,0,0,,Kozuki Momonosuke!
Dialogue: 0,0:16:54.16,0:16:55.12,Main-207+,,0,0,0,,Sen de kimsin?
Dialogue: 0,0:17:02.63,0:17:04.38,Main-207+,,0,0,0,,Hey, Shinobu!
Dialogue: 0,0:17:05.63,0:17:07.76,Main-207+,,0,0,0,,O bizim müttefikimiz,
Dialogue: 0,0:17:07.76,0:17:09.26,Main-207+,,0,0,0,,ona güvenebilirsin!
Dialogue: 0,0:17:09.26,0:17:11.55,Main-207+,,0,0,0,,Ne? Müttefik mi?
Dialogue: 0,0:17:14.51,0:17:17.56,Main-207+,,0,0,0,,Yanınızda olması daha güvenli!
Dialogue: 0,0:17:20.10,0:17:21.23,Main-207+,,0,0,0,,Görüşürüz!
Dialogue: 0,0:17:24.90,0:17:26.82,Main-207+,,0,0,0,,Gerçekten müttefik misin?
Dialogue: 0,0:17:26.82,0:17:28.03,Main-207+,,0,0,0,,Evet!
Dialogue: 0,0:17:31.91,0:17:33.28,Main-207+,,0,0,0,,Peki.
Dialogue: 0,0:17:33.28,0:17:34.49,Main-207+,,0,0,0,,Sana inanıyorum.
Dialogue: 0,0:17:34.49,0:17:36.37,Main-207+,,0,0,0,,İsmin nedir?
Dialogue: 0,0:17:38.20,0:17:39.08,Main-207+,,0,0,0,,– Ne?!\N– Ne?!
Dialogue: 0,0:17:40.25,0:17:41.42,Main-207+,,0,0,0,,Ben...
Dialogue: 0,0:17:46.67,0:17:49.17,Main-207+,,0,0,0,,Ben Kozuki Oden!
Dialogue: 0,0:17:51.80,0:17:53.80,Main-207+,,0,0,0,,Seni koruyacağım!
Dialogue: 0,0:17:57.01,0:17:58.47,Main-207+,,0,0,0,,Baba...
Dialogue: 0,0:17:59.73,0:18:01.35,Main-207+,,0,0,0,,Oden-{\i1}sama{\i0}...
Dialogue: 0,0:18:07.98,0:18:10.19,Main-207+,,0,0,0,,Ba... ba?
Dialogue: 0,0:18:11.07,0:18:12.03,Main-207+,,0,0,0,,Meme...
Dialogue: 0,0:18:12.53,0:18:13.91,Main-207+,,0,0,0,,Boynuz...
Dialogue: 0,0:18:13.91,0:18:16.83,Main-207+,,0,0,0,,Böyle baba mı olur be?
Dialogue: 0,0:18:16.83,0:18:20.16,Main-207+,,0,0,0,,Aşırı şüphe çekici, kesin düşmansın sen!
Dialogue: 0,0:18:20.16,0:18:21.29,Main-207+,,0,0,0,,Ne?!
Dialogue: 0,0:18:23.46,0:18:25.25,Main-207+,,0,0,0,,{\fad(150,150)}Duman Kaçış Tekniği!
Dialogue: 0,0:18:25.25,0:18:26.29,Main-207+,,0,0,0,,Bekleyin!
Dialogue: 0,0:18:27.09,0:18:29.09,Main-207+,,0,0,0,,Neden kaçtılar ki?
Dialogue: 0,0:18:41.64,0:18:43.31,Main-207+,,0,0,0,,Sayıları bizden çok fazla,
Dialogue: 0,0:18:43.31,0:18:45.15,Main-207+,,0,0,0,,sonsuza kadar sürer bu!
Dialogue: 0,0:18:45.15,0:18:46.81,Main-207+,,0,0,0,,Sahiden de!
Dialogue: 0,0:18:46.81,0:18:50.98,Main-207+,,0,0,0,,Bu piyonlarla uğraşmaya değmez!
Dialogue: 0,0:18:50.98,0:18:55.49,Main-207+,,0,0,0,,Denjiro'nun sözünü ettiği\NTobi Roppo dinazorlarının...
Dialogue: 0,0:18:55.49,0:18:57.87,Main-207+,,0,0,0,,kellelerini almaya mı gitsek acaba?
Dialogue: 0,0:18:58.16,0:19:00.33,Main-207+,,0,0,0,,Gücümüz yetmeyebilir ama...
Dialogue: 0,0:19:01.29,0:19:04.75,Main-207+,,0,0,0,,onları oyalayabiliriz!
Dialogue: 0,0:19:06.17,0:19:11.38,Main-207+,,0,0,0,,Hayret bir şey, geldiklerini göremedim!
Dialogue: 0,0:19:11.38,0:19:13.55,Main-207+,,0,0,0,,Big Mom delirmek üzere!
Dialogue: 0,0:19:13.55,0:19:15.55,Main-207+,,0,0,0,,Kaçın!
Dialogue: 0,0:19:28.81,0:19:32.57,Main-207+,,0,0,0,,Bir bir ortaya çıkıyorsunuz...
Dialogue: 0,0:19:34.07,0:19:36.70,Main-207+,,0,0,0,,Hasır Şapka tayfası sizi!
Dialogue: 0,0:19:40.12,0:19:43.58,Main-207+,,0,0,0,,Ruh Kralı, uzun zaman oldu.
Dialogue: 0,0:19:44.37,0:19:49.54,Main-207+,,0,0,0,,Sahiden de tayfanızda birçok ender yaratık var.
Dialogue: 0,0:19:51.42,0:19:52.88,Main-207+,,0,0,0,,Zevklerin güzelmiş!
Dialogue: 0,0:19:53.88,0:19:57.76,Main-207+,,0,0,0,,Demirden bedenimi sevdin mi, kocakarı seni?
Dialogue: 0,0:19:58.68,0:20:00.68,Main-207+,,0,0,0,,Benim adım...
Dialogue: 0,0:20:04.68,0:20:06.60,Main-207+,,0,0,0,,Franky!
Dialogue: 0,0:20:07.69,0:20:09.19,Main-207+,,0,0,0,,Bir sayborgum!
Dialogue: 0,0:20:13.07,0:20:15.40,Main-207+,,0,0,0,,Ender ve güçlüyüm!
Dialogue: 0,0:20:15.69,0:20:17.57,Main-207+,,0,0,0,,Durun, ikiniz de!
Dialogue: 0,0:20:18.03,0:20:20.20,Main-207+,,0,0,0,,Kaçalım, o bir Yonko!
Dialogue: 0,0:20:21.28,0:20:22.70,Main-207+,,0,0,0,,Yonko mu?
Dialogue: 0,0:20:24.12,0:20:26.00,Main-207+,,0,0,0,,Bu yüzden mi kaçmalıyız?
Dialogue: 0,0:20:28.00,0:20:29.75,Main-207+,,0,0,0,,Hey, Nami.
Dialogue: 0,0:20:29.75,0:20:30.88,Main-207+,,0,0,0,,İstemez misin...
Dialogue: 0,0:20:32.04,0:20:33.75,Main-207+,,0,0,0,,kaptanımız...
Dialogue: 0,0:20:36.51,0:20:41.64,Main-207+,,0,0,0,,Korsanlar Kralı olsun?
Dialogue: 0,0:20:50.35,0:20:52.77,Main-207+,,0,0,0,,{\fad(150,150)}Franky...
Dialogue: 0,0:20:53.90,0:20:56.53,Main-207+,,0,0,0,,{\fad(150,150)}Radikal...
Dialogue: 0,0:20:56.53,0:20:57.65,Main-207+,,0,0,0,,{\fad(150,0)}Işın–
Dialogue: 0,0:21:00.53,0:21:01.70,Main-207+,,0,0,0,,Şu...
Dialogue: 0,0:21:01.70,0:21:04.41,Main-207+,,0,0,0,,Şu devler de ne böyle?
Dialogue: 0,0:21:08.62,0:21:09.96,Main-207+,,0,0,0,,Hey!
Dialogue: 0,0:21:09.96,0:21:13.17,Main-207+,,0,0,0,,Size ayrılan kutlama yeri burası değil!
Dialogue: 0,0:21:14.67,0:21:16.38,Main-207+,,0,0,0,,Numbers!
Dialogue: 0,0:21:22.59,0:21:24.47,Main-207+,,0,0,0,,Hayır!
Dialogue: 0,0:21:24.47,0:21:26.64,Main-207+,,0,0,0,,Oars kadar büyükler,
Dialogue: 0,0:21:26.64,0:21:28.10,Main-207+,,0,0,0,,nedir bunlar?
Dialogue: 0,0:21:30.02,0:21:32.48,Main-207+,,0,0,0,,Thriller Bark geldi aklıma!
Dialogue: 0,0:21:36.07,0:21:41.99,Main-207+,,0,0,0,,Onlar, Kaido'nun Punk Hazard'dan aldığı...
Dialogue: 0,0:21:41.99,0:21:45.08,Main-207+,,0,0,0,,antik devlerin başarısız denemeleri demek?!
Dialogue: 0,0:21:46.33,0:21:48.29,Main-207+,,0,0,0,,Güzel!
Dialogue: 0,0:21:50.58,0:21:53.04,Main-207+,,0,0,0,,O canavarın elindeki şey...
Dialogue: 0,0:21:53.75,0:21:55.59,Main-207+,,0,0,0,,Brachio Tankı!
Dialogue: 0,0:21:55.59,0:21:57.34,Main-207+,,0,0,0,,Usopp'un ekibi!
Dialogue: 0,0:21:57.34,0:22:03.26,Main-207+,,0,0,0,,Bırak o elindekini, koca köstebek seni!
Dialogue: 0,0:22:05.51,0:22:07.39,Main-207+,,0,0,0,,{\fad(150,150)}Franky...
Dialogue: 0,0:22:09.89,0:22:12.10,Main-207+,,0,0,0,,{\fad(150,150)}Radikal...
Dialogue: 0,0:22:14.06,0:22:16.40,Main-207+,,0,0,0,,{\fad(150,150)}Işını!
Dialogue: 0,0:22:31.50,0:22:34.25,Main-207+,,0,0,0,,Lazer ışınım...
Dialogue: 0,0:22:34.25,0:22:36.04,Main-207+,,0,0,0,,artık durdurulamaz!
Dialogue: 0,0:22:37.54,0:22:40.63,Main-207+,,0,0,0,,Vurmak istediğin taraf burası değil miydi...
Dialogue: 0,0:22:41.63,0:22:43.76,Main-207+,,0,0,0,,Demir Adam?
Dialogue: 0,0:22:48.76,0:22:50.47,Main-207+,,0,0,0,,Kolunu ödünç alıyorum!
Dialogue: 0,0:22:51.31,0:22:53.64,Main-207+,,0,0,0,,{\fad(150,150)}Balıkadam Jujutsu...
Dialogue: 0,0:22:54.10,0:22:55.48,Main-207+,,0,0,0,,{\fad(150,150)}Bin Çiçek...
Dialogue: 0,0:23:01.03,0:23:06.41,Main-207+,,0,0,0,,{\fad(150,150)}...Girdaplı Omuz Fırlatışı!
Dialogue: 0,0:23:10.74,0:23:12.37,Main-207+,,0,0,0,,{\fad(150,150)}...Hezaren Çiçeği!
Dialogue: 0,0:23:14.92,0:23:17.88,Main-207+,,0,0,0,,Kahrolası, Jinbe!
Dialogue: 0,0:23:17.88,0:23:20.00,Main-207+,,0,0,0,,Filoma yaptıklarını unutmadım!
Dialogue: 0,0:23:20.46,0:23:23.88,Main-207+,,0,0,0,,Seni de geberteceğim!
Dialogue: 0,0:23:27.76,0:23:29.89,Main-207+,,0,0,0,,Bana uyar!
Dialogue: 0,0:23:36.35,0:23:37.52,Main-207+,,0,0,0,,Nasıldı?
Dialogue: 0,0:23:40.77,0:23:42.78,Main-207+,,0,0,0,,Düşündüğümden de iyiydi!
Dialogue: 0,0:23:42.78,0:23:45.24,Main-207+,,0,0,0,,Daha kızgın dönecektir!
Dialogue: 0,0:23:47.49,0:23:50.28,Main-207+,,0,0,0,,Sahiden de korkutucu bir kadınsın!
Dialogue: 0,0:23:50.28,0:23:52.04,Main-207+,,0,0,0,,Kusuruma bakmayın...
Dialogue: 0,0:23:52.04,0:23:55.37,Main-207+,,0,0,0,,ve sağ olun, Jinbe, Robin!
Comment: 0,0:23:55.37,0:23:56.92,Main-207+,,0,0,0,,Hıhı.
Dialogue: 0,0:23:56.92,0:23:58.75,Main-207+,,0,0,0,,İyisin ya yeter!
Dialogue: 0,0:23:59.42,0:24:01.13,Main-207+,,0,0,0,,Evet...
Dialogue: 0,0:24:05.67,0:24:08.18,Main-207+,,0,0,0,,şimdi de beklediğiniz an!
Dialogue: 0,0:24:17.52,0:24:20.77,Main-207+,,0,0,0,,{\i1}Durum raporu ver, Komutan Chopper!{\i}
Dialogue: 0,0:24:23.15,0:24:24.28,Main-207+,,0,0,0,,Usopp!
Dialogue: 0,0:24:24.28,0:24:26.40,Main-207+,,0,0,0,,Kendine gel, Usopp!
Dialogue: 0,0:24:27.03,0:24:28.70,Main-207+,,0,0,0,,Franky'den çağrı aldık!
Dialogue: 0,0:24:29.07,0:24:31.45,Main-207+,,0,0,0,,{\i1}Hey, siz iyi misiniz?{\i}
Dialogue: 0,0:24:33.45,0:24:37.96,Main-207+,,0,0,0,,Brachio Tankı dünyanın en...
Dialogue: 0,0:24:39.25,0:24:41.29,Main-207+,,0,0,0,,Sözümüzü hatırlıyor musunuz?
Dialogue: 0,0:24:42.84,0:24:44.92,Main-207+,,0,0,0,,Söz mü?
Dialogue: 0,0:24:45.27,0:24:47.34,Main-207+,,0,0,0,,Demirden yapılan korsan...
Dialogue: 0,0:24:47.34,0:24:50.09,Main-207+,,0,0,0,,Demir Korsan!
Dialogue: 0,0:24:50.09,0:24:52.05,Main-207+,,0,0,0,,Haydi birleşelim!
Dialogue: 0,0:24:52.39,0:24:53.22,Main-207+,,0,0,0,,Birleş...
Dialogue: 0,0:24:53.76,0:24:55.43,Main-207+,,0,0,0,,me mi?
Dialogue: 0,0:25:00.85,0:25:04.57,Main-207+,,0,0,0,,– Birleşme!\N– Birleşme!
Dialogue: 0,0:25:06.86,0:25:08.95,Main-207+,,0,0,0,,Gökyüzünü görebiliyorum.
Dialogue: 0,0:25:09.32,0:25:12.07,Main-207+,,0,0,0,,Güzel, buradan çıksam iyi olur.
Dialogue: 0,0:25:14.12,0:25:15.20,Main-207+,,0,0,0,,Kımıldama!
Dialogue: 0,0:25:15.99,0:25:17.37,Main-207+,,0,0,0,,Queen-{\i1}sama{\i0}!
Dialogue: 0,0:25:17.37,0:25:19.75,Main-207+,,0,0,0,,Kes sesini, moladayım.
Dialogue: 0,0:25:19.75,0:25:20.71,Main-207+,,0,0,0,,Hasır Şapka burada!
Dialogue: 0,0:25:22.58,0:25:24.17,Main-207+,,0,0,0,,Ne?! Hasır Şapka mı?
Dialogue: 0,0:25:26.30,0:25:28.09,Main-207+,,0,0,0,,Başkası da mı varmış?
Dialogue: 0,0:25:28.59,0:25:30.47,Main-207+,,0,0,0,,Hey, Zoro!
Dialogue: 0,0:25:30.47,0:25:31.97,Main-207+,,0,0,0,,Luffy sen misin?
Dialogue: 0,0:25:31.97,0:25:33.30,Main-207+,,0,0,0,,Nereye gidiyorsun?
Dialogue: 0,0:25:33.30,0:25:35.01,Main-207+,,0,0,0,,Kaido'nun yanına!
Dialogue: 0,0:25:35.97,0:25:37.31,Main-207+,,0,0,0,,Ben de geliyorum!
Dialogue: 0,0:25:37.31,0:25:39.18,Main-207+,,0,0,0,,İzin vermem!
Dialogue: 0,0:25:48.07,0:25:50.36,Main-207+,,0,0,0,,Altımızdaki kocaman dev de neyin nesi?
Dialogue: 0,0:25:51.95,0:25:52.99,Main-207+,,0,0,0,,Pekâlâ!
Dialogue: 0,0:25:55.62,0:25:58.24,Main-207+,,0,0,0,,{\fad(150,150)}Lastik-Lastik...
Dialogue: 0,0:25:58.24,0:26:00.79,Main-207+,,0,0,0,,{\fad(150,150)}Roket!
Dialogue: 0,0:26:02.21,0:26:03.58,Main-207+,,0,0,0,,Güzel, başarabiliriz!
Dialogue: 0,0:26:03.96,0:26:05.42,Main-207+,,0,0,0,,Kaido yukarıda mı?
Dialogue: 0,0:26:05.42,0:26:08.92,Main-207+,,0,0,0,,Evet, Kin'emon ve diğerleri\Nyukarıda onunla dövüşüyor!
Dialogue: 0,0:26:08.92,0:26:10.88,Main-207+,,0,0,0,,Az kaldı!
Dialogue: 0,0:26:18.77,0:26:20.98,Main-207+,,0,0,0,,Kahretsin!
Dialogue: 0,0:26:21.81,0:26:24.31,Main-207+,,0,0,0,,Kaçamayacaksınız, aptallar sizi!
Dialogue: 0,0:26:27.15,0:26:29.61,Main-207+,,0,0,0,,Buradan ileriye gidemeyeceksiniz!
Dialogue: 0,0:26:33.49,0:26:35.74,Main-207+,,0,0,0,,Hiçbir açıklık yok!
Dialogue: 0,0:26:35.74,0:26:38.16,Main-207+,,0,0,0,,Havada bir sürü uçan düşman var!
Dialogue: 0,0:27:01.39,0:27:03.94,Main-207+,,0,0,0,,İşte, işte, işte, işte!
Dialogue: 0,0:27:03.94,0:27:06.44,Main-207+,,0,0,0,,Yapıyoruz!
Dialogue: 0,0:27:08.11,0:27:11.15,Main-207+,,0,0,0,,{\fad(150,150)}– Birleşme Düzeni!\N– Birleşme Düzeni!
Dialogue: 0,0:27:19.70,0:27:21.04,Main-207+,,0,0,0,,{\fad(150,150)}Kara Gergedan: Hazır!
Dialogue: 0,0:27:23.50,0:27:26.92,Main-207+,,0,0,0,,{\fad(150,150)}– Brachio Kafası: Değiş!\N– Brachio Kafası: Değiş!
Dialogue: 0,0:27:29.09,0:27:31.71,Main-207+,,0,0,0,,Kusura bakmayın, bu robot tek kişilik!
Dialogue: 0,0:27:31.71,0:27:33.21,Main-207+,,0,0,0,,Ne?!
Dialogue: 0,0:27:33.21,0:27:35.68,Main-207+,,0,0,0,,Bunu yapamazsın!
Dialogue: 0,0:27:35.68,0:27:37.34,Main-207+,,0,0,0,,Şunlar...
Dialogue: 0,0:27:37.34,0:27:39.76,Main-207+,,0,0,0,,Usohachi-{\i1}san{\i0} ve Chopperemon-{\i1}san{\i0}!
Dialogue: 0,0:27:40.18,0:27:41.68,Main-207+,,0,0,0,,İyi misiniz?
Dialogue: 0,0:27:41.68,0:27:46.69,Main-207+,,0,0,0,,Zevk mekânından sizin sayenizde kurtulmuştuk!
Dialogue: 0,0:27:46.69,0:27:49.61,Main-207+,,0,0,0,,Beyler, şimdilik bunu bir kenara bırakalım!
Dialogue: 0,0:27:49.61,0:27:50.98,Main-207+,,0,0,0,,Kenara bırakalım!
Dialogue: 0,0:27:50.98,0:27:53.94,Main-207+,,0,0,0,,Gözünüz birleşmede olsun!
Dialogue: 0,0:27:53.94,0:27:54.82,Main-207+,,0,0,0,,{\fad(0,150}Olsun!
Dialogue: 0,0:28:10.13,0:28:12.75,Main-207+,,0,0,0,,{\fad(150,150)\i1}Demir Korsan...
Dialogue: 0,0:28:13.50,0:28:16.59,Main-207+,,0,0,0,,{\fad(150,150)\i1}General Franky!
Dialogue: 0,0:28:20.80,0:28:22.39,Main-207+,,0,0,0,,{\i1}Başlıyorum!
Dialogue: 0,0:28:23.51,0:28:25.43,Main-207+,,0,0,0,,{\fad(150,150)\i1}Franky Topu!
Dialogue: 0,0:28:27.23,0:28:29.35,Main-207+,,0,0,0,,Düşündüğüm gibi, ateşleyici senmişsin!
Dialogue: 0,0:28:29.35,0:28:30.36,Main-207+,,0,0,0,,Senmişsin!
Dialogue: 0,0:28:36.15,0:28:38.20,Main-207+,,0,0,0,,{\i1}Süper!
Dialogue: 0,0:28:38.20,0:28:40.16,Main-207+,,0,0,0,,Jaki'yi hakladılar!
Dialogue: 0,0:28:40.16,0:28:42.03,Main-207+,,0,0,0,,Hey, durum kötü!
Dialogue: 0,0:28:42.03,0:28:44.66,Main-207+,,0,0,0,,Şimdilik buradan çıksak iyi olur!
Dialogue: 0,0:28:44.66,0:28:45.79,Main-207+,,0,0,0,,Haklısın!
Dialogue: 0,0:28:51.17,0:28:52.04,Main-207+,,0,0,0,,Momo...
Dialogue: 0,0:28:53.59,0:28:54.71,Main-207+,,0,0,0,,Kaçtı mı acaba?
Dialogue: 0,0:28:55.38,0:28:57.76,Main-207+,,0,0,0,,Bu kıyafet de amma sağlammış!
Dialogue: 0,0:29:01.39,0:29:03.01,Main-207+,,0,0,0,,Kusuruma bakmayın.
Dialogue: 0,0:29:03.01,0:29:06.72,Main-207+,,0,0,0,,Bu vaziyet beni epey eğlendirdi!
Dialogue: 0,0:29:07.27,0:29:09.94,Main-207+,,0,0,0,,Hâlâ her yanımız düşman kaynıyor!
Dialogue: 0,0:29:10.73,0:29:13.11,Main-207+,,0,0,0,,Ama neden bilmem...
Dialogue: 0,0:29:13.11,0:29:15.36,Main-207+,,0,0,0,,kaybetmeyecekmişiz gibi geliyor.
Dialogue: 0,0:29:15.36,0:29:16.61,Main-207+,,0,0,0,,Sahiden de!
Dialogue: 0,0:29:16.61,0:29:18.24,Main-207+,,0,0,0,,Aynen öyle!
Dialogue: 0,0:29:18.24,0:29:21.49,Main-207+,,0,0,0,,Garip, niye böyle düşünüyorsunuz?
Dialogue: 0,0:29:21.49,0:29:23.49,Main-207+,,0,0,0,,Belli değil mi?
Dialogue: 0,0:29:23.49,0:29:26.58,Main-207+,,0,0,0,,Hasır Şapkalı genç bizle çünkü!
Dialogue: 0,0:29:29.87,0:29:32.75,Main-207+,,0,0,0,,Zıplayarak çıkarım sanmıştım.
Dialogue: 0,0:29:32.75,0:29:34.63,Main-207+,,0,0,0,,Kahretsin, kolay olmayacak.
Dialogue: 0,0:29:35.30,0:29:36.55,Main-207+,,0,0,0,,Ben de geliyorum.
Dialogue: 0,0:29:37.80,0:29:39.59,Main-207+,,0,0,0,,Her hâlükârda çıkmalıyız.
Dialogue: 0,0:29:42.47,0:29:44.68,Main-207+,,0,0,0,,Ne eziyet ama...
Dialogue: 0,0:29:44.68,0:29:47.68,Main-207+,,0,0,0,,Hepsi uçabiliyor mu bunların?
Dialogue: 0,0:29:48.10,0:29:51.39,Main-207+,,0,0,0,,Kanatlarını kopardığımızda\Nsıradan böceklere dönerler.
Dialogue: 0,0:29:51.39,0:29:54.52,Main-207+,,0,0,0,,Düşünce şeklin\Nbeni her zamanki gibi korkutuyor!
Dialogue: 0,0:29:56.57,0:30:00.53,Main-207+,,0,0,0,,Herkesin konuştuğu Önderler şunlar demek.
Dialogue: 0,0:30:04.37,0:30:08.83,Main-207+,,0,0,0,,Güçlü görünseler de\Nbizim kaptanımız daha güçlü!
Dialogue: 0,0:30:08.83,0:30:10.12,Main-207+,,0,0,0,,Evet!
Dialogue: 0,0:30:10.12,0:30:14.58,Main-207+,,0,0,0,,Kaptanı, gitmek istediği yere götürmek\Nrotacı olarak bana düşer.
Dialogue: 0,0:30:18.25,0:30:20.55,Main-207+,,0,0,0,,{\i1}Süper, bana bırakın!
Dialogue: 0,0:30:20.55,0:30:23.89,Main-207+,,0,0,0,,{\i1}General Franky yolu sizin için açacaktır!
Dialogue: 0,0:30:26.68,0:30:28.51,Main-207+,,0,0,0,,Gidelim, Kaptan!
Dialogue: 0,0:30:31.27,0:30:34.23,Main-207+,,0,0,0,,Evet! Bir kez daha, gidiyoruz!
Dialogue: 0,0:30:35.15,0:30:38.32,Main-207+,,0,0,0,,Millet, gerisini size bırakıyorum!
Dialogue: 0,0:30:38.32,0:30:40.07,Main-207+,,0,0,0,,Bize destek olun!
Dialogue: 0,0:30:55.33,0:30:57.09,Main-207+,,0,0,0,,Ben Kaido'yu...
Dialogue: 0,0:30:58.34,0:31:00.38,Main-207+,,0,0,0,,mahvetmeye gidiyorum!
Comment: 0,0:00:00.00,0:00:00.00,Main-207+,,0,0,0,,{=29}===============================DIALOGUE============================
