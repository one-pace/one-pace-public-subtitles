Comment: 0,0:00:00.00,0:00:00.00,Main-207+,,0,0,0,,{=16}===============================DIALOGUE============================
Dialogue: 0,0:00:00.00,0:00:01.31,Main-207+,,0,0,0,,Hadi, dans edin!
Dialogue: 0,0:00:01.31,0:00:02.48,Main-207+,,0,0,0,,İçin!
Dialogue: 0,0:00:02.81,0:00:05.31,Main-207+,,0,0,0,,Yiyin! Utanmayın!
Dialogue: 0,0:00:44.89,0:00:48.48,Main-207+,,0,0,0,,Ah, bedenim olmadan daha hafif hissediyorum.
Dialogue: 0,0:00:48.48,0:00:51.47,Main-207+,,0,0,0,,Gerçi bir bedenim yok ya!
Dialogue: 0,0:00:51.47,0:00:53.99,Main-207+,,0,0,0,,Ben sadece iskeletim.
Dialogue: 0,0:00:53.99,0:00:57.81,Main-207+,,0,0,0,,İskelet şakasını yapmanın\Nyalnız olunca pek bir anlamı olmuyor.
Dialogue: 0,0:00:57.81,0:00:59.83,Main-207+,,0,0,0,,Az araştırma yapayım!
Dialogue: 0,0:01:19.71,0:01:22.64,Main-207+,,0,0,0,,Çok şüpheli görünen korunaklı bir kapı.
Dialogue: 0,0:01:22.64,0:01:24.18,Main-207+,,0,0,0,,Burnuma pis kokular geliyor.
Dialogue: 0,0:01:24.52,0:01:26.41,Main-207+,,0,0,0,,Hem de burnum olmamasına rağmen.
Dialogue: 0,0:01:30.37,0:01:33.41,Main-207+,,0,0,0,,Bunlar da neymiş böyle?
Dialogue: 0,0:01:36.49,0:01:39.33,Main-207+,,0,0,0,,Poneglif mi?!
Dialogue: 0,0:03:30.23,0:03:33.52,Main-207+,,0,0,0,,{\fad(150,150)}Şanlı Ulus!
Dialogue: 0,0:03:35.03,0:03:37.15,Main-207+,,0,0,0,,Görüntüyü kaybettik!
Dialogue: 0,0:03:37.15,0:03:40.36,Main-207+,,0,0,0,,Başka bir kameraya geçin!
Dialogue: 0,0:03:42.07,0:03:42.86,Main-207+,,0,0,0,,Öf be...
Dialogue: 0,0:03:47.49,0:03:48.47,Main-207+,,0,0,0,,Ne?!
Dialogue: 0,0:03:51.00,0:03:56.42,Main-207+,,0,0,0,,Son savunma hattını da geçmişler\Nve şelaleyi tırmanıyorlar!
Dialogue: 0,0:03:56.59,0:03:58.55,Main-207+,,0,0,0,,Neee?!
Dialogue: 0,0:04:02.72,0:04:04.26,Main-207+,,0,0,0,,İlerleyin!
Dialogue: 0,0:04:05.34,0:04:07.69,Main-207+,,0,0,0,,Balıklar şelaleyi tırmanıyor!
Dialogue: 0,0:04:08.21,0:04:11.37,Main-207+,,0,0,0,,İnanılmaz-{\i1}perorin{\i0}.
Dialogue: 0,0:04:11.37,0:04:14.40,Main-207+,,0,0,0,,Hay sokayım!\NSiz gerzekler ne yapıyorsunuz?!
Dialogue: 0,0:04:14.40,0:04:17.27,Main-207+,,0,0,0,,Adaya ayak basmalarına müsaade edemeyiz!
Dialogue: 0,0:04:17.27,0:04:21.19,Main-207+,,0,0,0,,Ama şelalenin üst noktasında birliklerimiz yok!
Dialogue: 0,0:04:21.19,0:04:24.20,Main-207+,,0,0,0,,Ayrıca düşman da son derece güçlü!
Dialogue: 0,0:04:24.57,0:04:28.45,Main-207+,,0,0,0,,Onları alt edebilecek silahları konuşlandıracak zamanımız yok!
Dialogue: 0,0:04:29.51,0:04:31.41,Main-207+,,0,0,0,,Panik yapmayın!
Dialogue: 0,0:04:32.85,0:04:33.87,Main-207+,,0,0,0,,Kaido-{\i1}sama!{\io}
Dialogue: 0,0:04:37.01,0:04:42.63,Main-207+,,0,0,0,,Kahrolası Linlin,\Nyanında veletlerini de getirmişsin.
Dialogue: 0,0:04:48.72,0:04:51.60,Main-207+,,0,0,0,,Hazırlanın beyler!
Dialogue: 0,0:04:57.69,0:05:01.69,Main-207+,,0,0,0,,Topyekûn savaşa giriyoruz!
Dialogue: 0,0:05:08.31,0:05:10.91,Main-207+,,0,0,0,,Oturup onları beklemeye gerek yok.
Dialogue: 0,0:05:36.45,0:05:39.56,Main-207+,,0,0,0,,Tek bir geminin icabına bakmak o kadar mı zor?!
Dialogue: 0,0:05:43.82,0:05:44.86,Main-207+,,0,0,0,,Ben hallederim.
Dialogue: 0,0:05:52.16,0:05:53.74,Main-207+,,0,0,0,,Neredeyse tepeye ulaştık!
Dialogue: 0,0:05:54.75,0:05:56.71,Main-207+,,0,0,0,,Vardık varacağız!
Dialogue: 0,0:05:57.62,0:06:00.75,Main-207+,,0,0,0,,Geldim, Kaido!
Dialogue: 0,0:06:02.38,0:06:03.59,Main-207+,,0,0,0,,O da ne?!
Dialogue: 0,0:06:05.55,0:06:08.18,Main-207+,,0,0,0,,King mi?
Dialogue: 0,0:06:08.18,0:06:09.59,Main-207+,,0,0,0,,Bir pteranodon?!
Dialogue: 0,0:06:09.89,0:06:11.47,Main-207+,,0,0,0,,İndirin onu!
Dialogue: 0,0:06:24.40,0:06:26.40,Main-207+,,0,0,0,,Aşağılık, nasıl da kaçtı!
Dialogue: 0,0:06:44.41,0:06:47.67,Main-207+,,0,0,0,,Wano'ya vardık!
Dialogue: 0,0:06:47.67,0:06:51.84,Main-207+,,0,0,0,,Haydi, Hasır Şapka'yı öldürelim!
Dialogue: 0,0:06:53.85,0:06:55.10,Main-207+,,0,0,0,,Hâlâ burada!
Dialogue: 0,0:07:01.87,0:07:03.19,Main-207+,,0,0,0,,Yoksa...
Dialogue: 0,0:07:08.78,0:07:09.49,Main-207+,,0,0,0,,Olamaz!
Dialogue: 0,0:07:17.91,0:07:20.96,Main-207+,,0,0,0,,King, seni piç..!
Dialogue: 0,0:07:23.21,0:07:26.25,Main-207+,,0,0,0,,Wano'ya ayak basmana izin vermeyeceğim!
Dialogue: 0,0:07:29.85,0:07:31.88,Main-207+,,0,0,0,,Sıçayım!
Dialogue: 0,0:07:31.88,0:07:32.97,Main-207+,,0,0,0,,Mama!
Dialogue: 0,0:07:38.87,0:07:42.06,Main-207+,,0,0,0,,Heh. Boğul bakalım!
Dialogue: 0,0:08:03.85,0:08:06.17,Main-207+,,0,0,0,,Acele et, Franosuke!
Dialogue: 0,0:08:06.17,0:08:09.46,Main-207+,,0,0,0,,Söyle, niye koşmak zorundayız?!
Dialogue: 0,0:08:09.85,0:08:12.22,Main-207+,,0,0,0,,Soba aşçısı Sangoro'yu aramıyorlar mı?!
Dialogue: 0,0:08:12.69,0:08:18.76,Main-207+,,0,0,0,,Sen de Kyoshiro Ailesi'nden birini patakladın!
Dialogue: 0,0:08:23.43,0:08:24.56,Main-207+,,0,0,0,,Özür, dayanamadım!
Dialogue: 0,0:08:26.41,0:08:28.32,Main-207+,,0,0,0,,Hepsi Orochi'ye bağlı.
Dialogue: 0,0:08:28.32,0:08:33.40,Main-207+,,0,0,0,,Bu yüzden Canavar Korsanları'ndan\NTobi Roppo intikam için buraya geldi!
Dialogue: 0,0:08:35.74,0:08:39.66,Main-207+,,0,0,0,,Olamaz! Düşman mı?! Lanet olsun!
Dialogue: 0,0:08:45.85,0:08:48.72,Main-207+,,0,0,0,,Şükürler olsun. Sizmişsiniz.
Dialogue: 0,0:08:48.72,0:08:50.75,Main-207+,,0,0,0,,Burası güvenli değil. Bu taraftan!
Dialogue: 0,0:08:50.75,0:08:52.17,Main-207+,,0,0,0,,Tamam!
Dialogue: 0,0:08:52.17,0:08:56.29,Main-207+,,0,0,0,,Durum vahim. Mesele artık bunu neyin ateşlediği değil.
Dialogue: 0,0:08:56.29,0:08:59.23,Main-207+,,0,0,0,,Biriniz yakalanır ve kimliği açığa çıkarsa...
Dialogue: 0,0:08:59.23,0:09:00.68,Main-207+,,0,0,0,,işler fena karışır.
Dialogue: 0,0:09:01.65,0:09:04.35,Main-207+,,0,0,0,,Tayfanızın geri kalanını aramaya başlarlar!
Dialogue: 0,0:09:04.35,0:09:07.90,Main-207+,,0,0,0,,Olamaz! Nami-{\i1}san{\io} ve\NRobin-{\i1}chan{\io} tehlikede olurlar!
Dialogue: 0,0:09:08.60,0:09:11.15,Main-207+,,0,0,0,,Umarım sadece siz üçünüzün peşindeler!
Dialogue: 0,0:09:12.11,0:09:15.20,Main-207+,,0,0,0,,Sizi yakalayıp Kozuki klanıyla\Nilişkili olduğunuzu anlarlarsa...
Dialogue: 0,0:09:15.20,0:09:18.53,Main-207+,,0,0,0,,20 yıllık intikam planı suya düşer!
Dialogue: 0,0:09:19.20,0:09:20.33,Main-207+,,0,0,0,,Yani...
Dialogue: 0,0:09:21.45,0:09:23.75,Main-207+,,0,0,0,,yakalanır ve işkence görürseniz...
Dialogue: 0,0:09:23.75,0:09:25.12,Main-207+,,0,0,0,,Ha..?
Dialogue: 0,0:09:25.12,0:09:29.08,Main-207+,,0,0,0,,...onlara samuraylardan veya\Nminklerden bahsetmeyin.
Dialogue: 0,0:09:30.87,0:09:32.46,Main-207+,,0,0,0,,Çenenizi kapalı tutun ve...
Dialogue: 0,0:09:32.85,0:09:34.05,Main-207+,,0,0,0,,ölmeye bakın!
Dialogue: 0,0:09:34.05,0:09:35.47,Main-207+,,0,0,0,,Çok kötüsün!
Dialogue: 0,0:09:35.47,0:09:38.09,Main-207+,,0,0,0,,Luffy asla böyle bir şey söylemezdi!
Dialogue: 0,0:09:38.09,0:09:39.80,Main-207+,,0,0,0,,Ben daha gerçekçiyim.
Dialogue: 0,0:09:39.80,0:09:42.85,Main-207+,,0,0,0,,Kim olduğumuzu çakmadıkları\Nsürece sıkıntı olmaz, ha?
Dialogue: 0,0:09:42.85,0:09:44.49,Main-207+,,0,0,0,,O hâlde...
Dialogue: 0,0:09:49.37,0:09:51.86,Main-207+,,0,0,0,,neden yüzümüzü gizleyip de savaşmıyoruz?!
Dialogue: 0,0:09:55.25,0:09:57.11,Main-207+,,0,0,0,,Gerekmedikçe savaşa girmeyin.
Dialogue: 0,0:09:57.11,0:09:59.82,Main-207+,,0,0,0,,Kaptanımızmışsın gibi davranmayı bırak!
Dialogue: 0,0:09:59.82,0:10:01.87,Main-207+,,0,0,0,,Eğer yakalanırsam...
Dialogue: 0,0:10:01.87,0:10:04.33,Main-207+,,0,0,0,,ağzımda bakla ıslanmayacağına\Nemin olabilirsin!
Dialogue: 0,0:10:04.33,0:10:05.91,Main-207+,,0,0,0,,Sıçayım sana!
Dialogue: 0,0:10:06.26,0:10:07.93,Main-207+,,0,0,0,,O zaman seni ölümüne korurum!
Dialogue: 0,0:10:07.93,0:10:09.22,Main-207+,,0,0,0,,İşe yaradı!
Dialogue: 0,0:10:09.22,0:10:10.71,Main-207+,,0,0,0,,Hay dostluğunuza!
Dialogue: 0,0:10:20.63,0:10:21.55,Main-207+,,0,0,0,,Bir hanım!
Dialogue: 0,0:10:33.09,0:10:34.34,Main-207+,,0,0,0,,Bu hiç iyi değil!
Dialogue: 0,0:10:34.34,0:10:36.07,Main-207+,,0,0,0,,Çoktan fark ettiler mi?!
Dialogue: 0,0:10:52.39,0:10:55.67,Main-207+,,0,0,0,,Lütfen durun!\NBunun bizimle hiçbir ilgisi yok!
Dialogue: 0,0:11:00.22,0:11:04.73,Main-207+,,0,0,0,,Soba satıyoruz tamam da\NSangoro ile bir bağımız yok!
Dialogue: 0,0:11:04.73,0:11:06.85,Main-207+,,0,0,0,,Dükkânımızı nasıl yerle bir edersiniz?!
Dialogue: 0,0:11:06.85,0:11:09.67,Main-207+,,0,0,0,,O olmadan şehirde barınamayız!
Dialogue: 0,0:11:13.79,0:11:18.03,Main-207+,,0,0,0,,Birilerini suçlamak istiyorsanız\No sersem Sangoro'yu suçlayın.
Dialogue: 0,0:11:20.21,0:11:22.94,Main-207+,,0,0,0,,Bana diğer soba dükkânlarının yerini söyleyin!
Dialogue: 0,0:11:22.94,0:11:27.79,Main-207+,,0,0,0,,Ya da Sangoro'yu çağırın!
Dialogue: 0,0:11:28.50,0:11:31.75,Main-207+,,0,0,0,,O mankafa, Kyoshiro Ailesi'ne bulaştı.
Dialogue: 0,0:11:33.46,0:11:36.71,Main-207+,,0,0,0,,Çağırmazsanız...
Dialogue: 0,0:11:37.21,0:11:39.09,Main-207+,,0,0,0,,sizi de yerim!
Dialogue: 0,0:11:42.30,0:11:45.27,Main-207+,,0,0,0,,Sangoro!
Dialogue: 0,0:11:45.56,0:11:47.64,Main-207+,,0,0,0,,Sangoro!
Dialogue: 0,0:11:51.64,0:11:53.31,Main-207+,,0,0,0,,Hey!
Dialogue: 0,0:11:53.87,0:11:56.49,Main-207+,,0,0,0,,Sangoro, çık ortaya!
Dialogue: 0,0:12:00.28,0:12:02.79,Main-207+,,0,0,0,,– Sangoro!\N– Sangoro!
Dialogue: 0,0:12:02.79,0:12:05.17,Main-207+,,0,0,0,,Belki de cidden işe yarayacağı yoktur!
Dialogue: 0,0:12:07.13,0:12:10.16,Main-207+,,0,0,0,,Korkağın tekiyse kendini asla göstermez!
Dialogue: 0,0:12:10.16,0:12:12.97,Main-207+,,0,0,0,,Sangoro!
Dialogue: 0,0:12:14.41,0:12:19.00,Main-207+,,0,0,0,,Ah, canım şimdi de\Ntatlı bir şeyler yemek istiyor!
Dialogue: 0,0:12:19.40,0:12:21.75,Main-207+,,0,0,0,,İşte böyle kirli oynuyorlar!
Dialogue: 0,0:12:22.29,0:12:24.13,Main-207+,,0,0,0,,Şimdilik önceliğimiz buradan kaçmak!
Dialogue: 0,0:12:26.09,0:12:27.87,Main-207+,,0,0,0,,Benden...
Dialogue: 0,0:12:28.67,0:12:30.81,Main-207+,,0,0,0,,bunu yapmamı nasıl beklersin?
Dialogue: 0,0:12:33.51,0:12:36.02,Main-207+,,0,0,0,,Hey, bekle, Sanji!
Dialogue: 0,0:12:37.13,0:12:39.82,Main-207+,,0,0,0,,Durun! Bizim de onunla bir bağımız yok!
Dialogue: 0,0:12:40.18,0:12:42.29,Main-207+,,0,0,0,,O hâlde çağırın onu...
Dialogue: 0,0:12:42.29,0:12:43.90,Main-207+,,0,0,0,,hepiniz!
Dialogue: 0,0:12:45.78,0:12:48.49,Main-207+,,0,0,0,,Bana soba aşçısı Songoro'yu çağırın!
Dialogue: 0,0:12:56.15,0:12:57.29,Main-207+,,0,0,0,,İşte...
Dialogue: 0,0:12:58.41,0:13:00.55,Main-207+,,0,0,0,,buradayım!
Dialogue: 0,0:13:01.38,0:13:03.55,Main-207+,,0,0,0,,{\fad(150,150)}Şeytan Bacağı:
Dialogue: 0,0:13:03.55,0:13:05.63,Main-207+,,0,0,0,,{\fad(150,150)}Kıyım!
Dialogue: 0,0:13:20.73,0:13:22.59,Main-207+,,0,0,0,,Bu o...
Dialogue: 0,0:13:22.59,0:13:23.49,Main-207+,,0,0,0,,O...
Dialogue: 0,0:13:23.49,0:13:26.35,Main-207+,,0,0,0,,Özel Sobacı Sangoro!
Dialogue: 0,0:13:32.49,0:13:34.51,Main-207+,,0,0,0,,Demek o soba aşçısı sensin.
Dialogue: 0,0:13:35.93,0:13:40.21,Main-207+,,0,0,0,,Sonunda geldin.\Nİşimi daha da zorlaştırma.
Dialogue: 0,0:13:40.77,0:13:46.31,Main-207+,,0,0,0,,Alo, ben Page One.\NHedef ikinci bölge, altıncı blokta!
Dialogue: 0,0:13:46.31,0:13:49.39,Main-207+,,0,0,0,,{\i1}Anlaşıldı! En kısa zamanda orada olacağız.{\i0}
Dialogue: 0,0:13:51.33,0:13:53.81,Main-207+,,0,0,0,,Artık kaçamazsın.
Dialogue: 0,0:13:54.65,0:13:56.87,Main-207+,,0,0,0,,Dinazor güçleri, ha?
Dialogue: 0,0:14:02.63,0:14:03.82,Main-207+,,0,0,0,,Seni piç.
Dialogue: 0,0:14:08.61,0:14:10.37,Main-207+,,0,0,0,,Ne yapıyorsun, Sangoro?!
Dialogue: 0,0:14:10.71,0:14:14.49,Main-207+,,0,0,0,,Boşver gitsin!\NDrake ya da Hawkins seni görürse biteriz!
Dialogue: 0,0:14:15.35,0:14:16.58,Main-207+,,0,0,0,,Biliyorum.
Dialogue: 0,0:14:23.19,0:14:24.00,Main-207+,,0,0,0,,Yine de...
Dialogue: 0,0:14:24.79,0:14:27.22,Main-207+,,0,0,0,,bu herifin kim olduğumu bilmediğine eminim.
Dialogue: 0,0:14:27.22,0:14:30.70,Main-207+,,0,0,0,,Yani bu herifin işini çabucak bitirirsem...
Dialogue: 0,0:14:30.70,0:14:33.31,Main-207+,,0,0,0,,kimse farkına varmadan güvende olurum.
Dialogue: 0,0:14:41.49,0:14:43.73,Main-207+,,0,0,0,,Fazla müttefike sahip olmak güzel...
Dialogue: 0,0:14:45.40,0:14:48.57,Main-207+,,0,0,0,,ancak düşmanın sayısını\Nazaltmak da güzel olur.
Dialogue: 0,0:14:49.67,0:14:52.12,Main-207+,,0,0,0,,Gevezeliği kes!
Dialogue: 0,0:15:00.23,0:15:02.67,Main-207+,,0,0,0,,Beyler, siz önden gidin!
Dialogue: 0,0:15:02.67,0:15:03.59,Main-207+,,0,0,0,,– Ne?\N– Ne?
Dialogue: 0,0:15:11.55,0:15:13.73,Main-207+,,0,0,0,,Kimliğimi gizlediğim sürece...
Dialogue: 0,0:15:19.03,0:15:21.52,Main-207+,,0,0,0,,sorun yoktu, değil mi?
Dialogue: 0,0:15:21.52,0:15:23.77,Main-207+,,0,0,0,,Soba aşçısı gerçekten geldi mi?!
Dialogue: 0,0:15:23.77,0:15:26.07,Main-207+,,0,0,0,,Aptal mı ki?! Ölmek mi istiyor?!
Dialogue: 0,0:15:28.97,0:15:31.86,Main-207+,,0,0,0,,Dönüşüm için mükemmel zaman.
Dialogue: 0,0:15:34.21,0:15:37.37,Main-207+,,0,0,0,,Nedir o? Kutu içecek falan mı?
Dialogue: 0,0:15:39.37,0:15:45.89,Main-207+,,0,0,0,,Bunu giymek beni\NGerma'nın bir parçası yapmayacak!
Dialogue: 0,0:15:47.07,0:15:49.76,Main-207+,,0,0,0,,Sadece üstüme oturacak mı merak ediyorum.
Dialogue: 0,0:15:50.41,0:15:53.17,Main-207+,,0,0,0,,Kasabadan ayrılmış olmalıydı.
Dialogue: 0,0:15:53.17,0:15:56.01,Main-207+,,0,0,0,,Ne yapıyor o?!
Dialogue: 0,0:15:56.47,0:15:58.75,Main-207+,,0,0,0,,Yonko biriyle savaşa girmek üzereyiz...
Dialogue: 0,0:15:59.85,0:16:04.48,Main-207+,,0,0,0,,İnatçı olmayı bir kenara bırakmalıyım.
Dialogue: 0,0:16:04.48,0:16:09.40,Main-207+,,0,0,0,,İnsanların hayatları buna bağlı,\No yüzden gururumu bir köşeye atacağım!
Dialogue: 0,0:16:09.40,0:16:12.62,Main-207+,,0,0,0,,İyice zırvalamaya başladın!
Dialogue: 0,0:16:16.57,0:16:20.75,Main-207+,,0,0,0,,Bu şeyin bana yardım edecek gücü olabilir!
Dialogue: 0,0:16:21.83,0:16:22.75,Main-207+,,0,0,0,,Başlayalım!
Dialogue: 0,0:16:50.36,0:16:52.57,Main-207+,,0,0,0,,Ne yapıyorsun?!
Dialogue: 0,0:16:52.89,0:16:55.03,Main-207+,,0,0,0,,Az önce havada üzerini mi değiştin?
Dialogue: 0,0:16:55.46,0:16:56.78,Main-207+,,0,0,0,,Kara Bacak-{\i1}ya!{\i0}
Dialogue: 0,0:16:56.78,0:17:01.04,Main-207+,,0,0,0,,Ah, dönüşüm mü geçirdi?! Süper!
Dialogue: 0,0:17:01.13,0:17:03.71,Main-207+,,0,0,0,,Çok havalı! Nasıl çalışıyor bu?!
Dialogue: 0,0:17:04.55,0:17:08.59,Main-207+,,0,0,0,,Bekle, o kostümü bir yerlerden biliyorum.
Dialogue: 0,0:17:12.61,0:17:14.97,Main-207+,,0,0,0,,Ah, evet! Ama...
Dialogue: 0,0:17:15.46,0:17:19.14,Main-207+,,0,0,0,,neden o kostüm onda?!
Dialogue: 0,0:17:19.14,0:17:23.22,Main-207+,,0,0,0,,Bu kesinlikle Deniz Savaşçısı Sora'nın düşmanı!
Dialogue: 0,0:17:24.51,0:17:28.31,Main-207+,,0,0,5,,Şeytani ordu,\NGerma 66'nın üç numaralı üyesi...
Dialogue: 0,0:17:28.31,0:17:29.97,Main-207+,,0,0,0,,Gizli Kara!
Dialogue: 0,0:17:32.81,0:17:34.78,Main-207+,,0,0,0,,Hey, bu kadar şeyi nasıl biliyorsun?!
Dialogue: 0,0:17:35.13,0:17:38.07,Main-207+,,0,0,0,,Elbette biliyorum! Kuzey Mavi'den herkes bilir!
Dialogue: 0,0:17:38.56,0:17:40.57,Main-207+,,0,0,0,,Her neyse!
Dialogue: 0,0:17:40.57,0:17:44.95,Main-207+,,0,0,0,,Dinle! Beni bir daha Germa olarak çağırma! Anladın mı?!
Dialogue: 0,0:17:45.45,0:17:49.56,Main-207+,,0,0,0,,Deniz Savaşçısı Sora'nın sadık bir hayranıydım!
Dialogue: 0,0:17:49.56,0:17:53.17,Main-207+,,0,0,0,,Germa'dan nefret ediyordum,\Nbeş para etmez kötü adamlardı.
Dialogue: 0,0:17:53.17,0:17:54.47,Main-207+,,0,0,0,,Ben de nefret ediyorum!
Dialogue: 0,0:17:54.47,0:17:55.67,Main-207+,,0,0,0,,Hey, sen!
Dialogue: 0,0:17:56.34,0:18:00.35,Main-207+,,0,0,0,,Sıradan bir soba aşçısı değilsin.
Dialogue: 0,0:18:00.35,0:18:01.89,Main-207+,,0,0,0,,Kimsin?!
Dialogue: 0,0:18:06.25,0:18:07.69,Main-207+,,0,0,0,,Ben...
Dialogue: 0,0:18:12.41,0:18:14.49,Main-207+,,0,0,0,,Osoba Maskesi'yim!
Dialogue: 0,0:18:16.59,0:18:18.32,Main-207+,,0,0,0,,Osoba Maskesi...
Dialogue: 0,0:18:18.32,0:18:21.07,Main-207+,,0,0,0,,Hayır... o kesinlikle Germa.
Dialogue: 0,0:18:22.41,0:18:25.99,Main-207+,,0,0,0,,Bu berbat! Hemen değiştir ismini!
Dialogue: 0,0:18:25.99,0:18:28.87,Main-207+,,0,0,0,,Lütfen hiç değilse ismini biz koyalım!
Dialogue: 0,0:18:28.87,0:18:33.63,Main-207+,,0,0,0,,Osoba Maskesi mi dedin sen?!\NDalga geçmeyi kes!
Dialogue: 0,0:18:40.72,0:18:43.84,Main-207+,,0,0,0,,Nereye gitti?
Dialogue: 0,0:18:43.84,0:18:45.22,Main-207+,,0,0,0,,Ne?!
Dialogue: 0,0:18:45.22,0:18:47.98,Main-207+,,0,0,0,,Havada süzülüyor!
Dialogue: 0,0:18:49.51,0:18:50.90,Main-207+,,0,0,0,,Bu mümkün mü?!
Dialogue: 0,0:18:50.90,0:18:55.65,Main-207+,,0,0,0,,Hiç şüphe yok.\NBu kesinlikle Germa teknolojisi.
Dialogue: 0,0:18:55.65,0:18:59.57,Main-207+,,0,0,0,,Topuklarındaki cihazlar\Nhavada süzülmelerini sağlıyor.
Dialogue: 0,0:18:59.57,0:19:01.28,Main-207+,,0,0,0,,Ne de olsa, onlardan biri.
Dialogue: 0,0:19:03.57,0:19:05.03,Main-207+,,0,0,0,,Bu harika!
Dialogue: 0,0:19:07.07,0:19:09.91,Main-207+,,0,0,0,,Çocuk oyuncağı bu be!
Dialogue: 0,0:19:42.57,0:19:44.66,Main-207+,,0,0,0,,İşte bu, Osoba Maskesi!
Dialogue: 0,0:19:53.12,0:19:57.25,Main-207+,,0,0,0,,Tüm bu küçük numaraların beni sinirlendiriyor.
Dialogue: 0,0:20:09.89,0:20:11.56,Main-207+,,0,0,0,,Bu soktuğumun şeyi de ne?!
Dialogue: 0,0:20:12.79,0:20:14.15,Main-207+,,0,0,0,,Vay!
Dialogue: 0,0:20:14.15,0:20:16.27,Main-207+,,0,0,0,,Yumruğu işlemiyor!
Dialogue: 0,0:20:16.82,0:20:19.13,Main-207+,,0,0,0,,Germa 66'nın giydiği pelerinler...
Dialogue: 0,0:20:19.85,0:20:22.03,Main-207+,,0,0,0,,ayrıca bir kalkan görevi görüyor.
Dialogue: 0,0:20:26.51,0:20:30.33,Main-207+,,0,0,0,,Artık tüm numaralarını biliyorum!\NBana tekrar vuramayacaksın!
Dialogue: 0,0:20:33.12,0:20:34.85,Main-207+,,0,0,0,,Olamaz!
Dialogue: 0,0:20:36.51,0:20:41.17,Main-207+,,0,0,0,,Gerçekten Gizli Kara'ysa onu kullanacaktır!
Dialogue: 0,0:20:42.35,0:20:44.22,Main-207+,,0,0,0,,Artık kaçmana izin vermeyeceğim!
Dialogue: 0,0:20:47.10,0:20:48.10,Main-207+,,0,0,0,,Kayboldu?!
Dialogue: 0,0:20:48.58,0:20:50.14,Main-207+,,0,0,0,,İmkânsız!
Dialogue: 0,0:20:51.35,0:20:55.53,Main-207+,,0,0,0,,İnsanlar öylece ortadan kaybolamaz!\NNerede?! Nereye gitti?
Dialogue: 0,0:20:55.53,0:20:57.61,Main-207+,,0,0,0,,Çık ortaya!
Dialogue: 0,0:20:57.61,0:20:59.32,Main-207+,,0,0,0,,Tahmin ettiğim gibi!
Dialogue: 0,0:21:11.03,0:21:13.68,Main-207+,,0,0,0,,Vay be! Ha? Nerede?!
Dialogue: 0,0:21:13.68,0:21:15.42,Main-207+,,0,0,0,,O kadar hızlı ki göremiyorum!
Dialogue: 0,0:21:15.85,0:21:21.13,Main-207+,,0,0,0,,Hayır, bu Germa 66'dan\NGizli Kara'nın özel yeteneği.
Dialogue: 0,0:21:21.13,0:21:25.43,Main-207+,,0,0,0,,Arka planı vücuduna yansıtarak görünmez olabiliyor!
Dialogue: 0,0:21:27.85,0:21:31.93,Main-207+,,0,0,0,,Deniz Savaşçısı Sora bile onun karşısında epey zorlanmıştı...
Dialogue: 0,0:21:36.13,0:21:38.03,Main-207+,,0,0,0,,Soktuğumun Germa'sı...!
Dialogue: 0,0:21:38.03,0:21:40.43,Main-207+,,0,0,0,,Kimin tarafındasın sen?
Dialogue: 0,0:21:40.43,0:21:43.20,Main-207+,,0,0,0,,Bu konu hakkında çok fazla şey biliyorsun!
Dialogue: 0,0:21:43.20,0:21:45.36,Main-207+,,0,0,0,,Kuzey Mavi'den herkes bunları bilir.
Dialogue: 0,0:21:53.87,0:21:58.12,Main-207+,,0,0,0,,Kostümün nesi var böyle?\NBeni görünmez mi yaptı?!
Dialogue: 0,0:21:59.19,0:22:01.71,Main-207+,,0,0,0,,Tıpkı Görünmezlik Meyvesi gibi..
Dialogue: 0,0:22:03.29,0:22:07.18,Thoughts-207+,,0,0,0,,Hep hayalini kurduğum meyve...
Dialogue: 0,0:22:07.71,0:22:11.53,Flashbacks-207+,,0,0,0,,Görünmezlik Meyvesi ile görünmez olabilirim.
Dialogue: 0,0:22:12.43,0:22:15.25,Main-207+,,0,0,0,,Bir zamanlar o hayali çok önemsiyordum.
Dialogue: 0,0:22:16.85,0:22:21.44,Flashbacks-207+,,0,0,0,,Bu doğru. Hayalimi benden çaldın!
Dialogue: 0,0:22:21.83,0:22:25.89,Flashbacks-207+,,0,0,0,,Böyle bir şey yaptığımı hatırlamıyorum.\NYanılıyor olmalısın.
Dialogue: 0,0:22:26.47,0:22:31.45,Flashbacks-207+,,0,0,0,,Görünmez adam olmak istiyordum!
Dialogue: 0,0:22:31.45,0:22:38.08,Flashbacks-207+,,0,0,0,,Ama Görünmezlik Meyvesi'ni sen yediğin için\Nhayalimi yerle bir ettin, anladın mı?!
Dialogue: 0,0:22:38.08,0:22:40.46,Flashbacks-207+,,0,0,0,,N-Ne?!
Dialogue: 0,0:22:40.50,0:22:42.96,Flashbacks-207+,,0,0,0,,– Onun ne suçu var be?!\N– Onun ne suçu var be?!
Dialogue: 0,0:22:43.97,0:22:46.46,Main-207+,,0,0,0,,Kaybettiğimi sandığım hayal...
Dialogue: 0,0:22:46.88,0:22:51.52,Main-207+,,0,0,0,,nefret ettiğim Germa teknolojisi\Nsayesinde artık mümkün mü?
Dialogue: 0,0:22:51.52,0:22:53.05,Main-207+,,0,0,0,,İroniye bak...
Dialogue: 0,0:22:55.41,0:22:58.61,Main-207+,,0,0,0,,Bu yetenek kesinlikle çok kullanışlı olacak...
Dialogue: 0,0:22:59.25,0:23:01.65,Main-207+,,0,0,0,,Bunu kadınlar hamamında kullanabilirim.
Dialogue: 0,0:23:01.65,0:23:02.73,Main-207+,,0,0,0,,Hayır, hayır!
Dialogue: 0,0:23:03.77,0:23:08.24,Main-207+,,0,0,0,,Arkadaşlarımı korumak için kullanacağım! İkileme bak be!
Dialogue: 0,0:23:20.37,0:23:25.04,Main-207+,,0,0,0,,Görünmez adam mı?\Nİşler garipleşmeye başladı.
Dialogue: 0,0:23:25.75,0:23:28.46,Main-207+,,0,0,0,,Kimsin sen?!
Dialogue: 0,0:23:28.46,0:23:33.93,Main-207+,,0,0,0,,Bu form senin gibi bir rakiple\Ndövüşmeye daha uygun görünüyor.
Dialogue: 0,0:23:35.39,0:23:38.37,Main-207+,,0,0,0,,Seninle biraz eğlenecektim...
Dialogue: 0,0:23:38.37,0:23:41.95,Main-207+,,0,0,0,,ama şimdi, öldürsem daha iyi olur\Ndiye düşünüyorum.
Dialogue: 0,0:24:01.49,0:24:03.33,Main-207+,,0,0,0,,Hey, Dikenli!
Dialogue: 0,0:24:07.41,0:24:10.38,Main-207+,,0,0,0,,Eminim hâlâ biraz dangon vardır!
Dialogue: 0,0:24:10.78,0:24:13.71,Main-207+,,0,0,0,,Hadi, Dikenli! Uyuyormuş gibi yapma!
Dialogue: 0,0:24:16.55,0:24:19.03,Main-207+,,0,0,0,,Beni duyabildiğini biliyorum, Dikenli!
Dialogue: 0,0:24:38.71,0:24:42.09,Thoughts-207+,,0,0,0,,Ne tuhaf, eski bir oda.
Dialogue: 0,0:24:43.21,0:24:46.01,Thoughts-207+,,0,0,0,,Bu ülke, yüzyıllardır izole edilmiş durumda.
Dialogue: 0,0:24:50.57,0:24:53.56,Thoughts-207+,,0,0,0,,Ve poneglifler burada icat edilmiş.
Dialogue: 0,0:24:53.56,0:24:55.65,Thoughts-207+,,0,0,0,,Eminim buralarda bir tane vardır.
Dialogue: 0,0:24:57.05,0:24:59.97,Thoughts-207+,,0,0,0,,Buralarda bir yerlerde gizli bir kapı olmalı.
Dialogue: 0,0:25:04.13,0:25:06.23,Main-207+,,0,0,0,,Bir şey mi arıyordun?
Dialogue: 0,0:25:08.29,0:25:10.78,Thoughts-207+,,0,0,0,,Mümkün değil! Nasıl fark edemedim?
Dialogue: 0,0:25:14.41,0:25:15.74,Secondary-207+,,0,0,0,,Güzel!
Dialogue: 0,0:25:16.11,0:25:18.37,Main-207+,,0,0,0,,Güzel, güzel, güzel, güzel...
Dialogue: 0,0:25:19.35,0:25:23.50,Main-207+,,0,0,0,,Komurasaki, şimdi o besteyi çalmanı istiyorum!
Dialogue: 0,0:25:23.50,0:25:26.19,Main-207+,,0,0,0,,Nasıl arzu ederseniz...
Dialogue: 0,0:25:43.06,0:25:46.39,Main-207+,,0,0,0,,Otama, hadi adil bir dövüş yapalım!
Dialogue: 0,0:25:46.39,0:25:49.61,Main-207+,,0,0,0,,Daha fazlasını isteyemezdim, Chopperemon!
Dialogue: 0,0:25:52.73,0:25:55.49,Main-207+,,0,0,0,,{\fad(150,150)}Ninpo: Ağaç Yaprağı Tekniği!
Dialogue: 0,0:25:56.36,0:25:57.20,Main-207+,,0,0,0,,{\fad(150,150)}Ninpo...
Dialogue: 0,0:25:59.49,0:26:02.08,Main-207+,,0,0,0,,{\fad(150,150)}Zikzak Koşusu!
Dialogue: 0,0:26:02.08,0:26:03.83,Main-207+,,0,0,0,,Al bakalım!
Dialogue: 0,0:26:14.45,0:26:18.26,Main-207+,,0,0,0,,Büyüleyici bir kunoichi\Nolacaksam önümde zorlu bir yol var.
Dialogue: 0,0:26:20.65,0:26:23.51,Main-207+,,0,0,0,,Hepsinden bir şekilde kaçmayı başardım.
Dialogue: 0,0:26:24.87,0:26:26.73,Main-207+,,0,0,0,,İkiniz de mükemmeldiniz!
Dialogue: 0,0:26:26.73,0:26:30.41,Main-207+,,0,0,0,,Hâlâ Luffy ağabey için endişeleniyorum.
Dialogue: 0,0:26:30.41,0:26:33.77,Main-207+,,0,0,0,,O iyi olacak! Endişelenme!
Dialogue: 0,0:26:39.61,0:26:44.71,Main-207+,,0,0,0,,Raizo'dan da henüz bir haber yok.\NBiraz endişelenmemek elde değil.
Dialogue: 0,0:26:44.71,0:26:51.09,Main-207+,,0,0,0,,Muhterem ustam, Udon hapishanesinden kimsenin kaçamadığını söylemişti...
Dialogue: 0,0:26:51.09,0:26:54.50,Main-207+,,0,0,0,,O iyi olacak dedim! {\i1}Nin-nin{\i}!
Dialogue: 0,0:26:54.50,0:26:57.88,Main-207+,,0,0,0,,Şimdilik tek yapabileceğimiz kendimizi eğitmek!
Dialogue: 0,0:26:58.29,0:27:00.93,Main-207+,,0,0,0,,{\fad(150,150)}Ninpo: Ağaca Tırmanma Tekniği!
Dialogue: 0,0:27:00.93,0:27:02.18,Main-207+,,0,0,0,,{\i1}Nin! Nin-nin!{\i0}
Dialogue: 0,0:27:02.18,0:27:05.64,Main-207+,,0,0,0,,Daha güçlü olsaydım\Nhemen gidip onu kurtarırdım.
Dialogue: 0,0:27:06.27,0:27:07.00,Main-207+,,0,0,0,,{\i1}Nin{\i0}!
Dialogue: 0,0:27:08.27,0:27:09.59,Main-207+,,0,0,0,,Ya?
Dialogue: 0,0:27:10.27,0:27:13.11,Main-207+,,0,0,0,,O da ne?
Dialogue: 0,0:27:14.93,0:27:16.40,Main-207+,,0,0,0,,{\i1}Nin! Nin!{\i0}
Dialogue: 0,0:27:21.74,0:27:23.03,Main-207+,,0,0,0,,Çok ilginç.
Dialogue: 0,0:27:23.03,0:27:28.16,Main-207+,,0,0,0,,Komurasaki abla ne zaman bu şarkıyı çalsa\Nhep aynı maskeyi takıyor.
Dialogue: 0,0:27:32.92,0:27:36.59,Main-207+,,0,0,0,,İşte bu! İşte bu! Şarkı dediğin budur!
Dialogue: 0,0:27:36.96,0:27:38.59,Main-207+,,0,0,0,,Bayıldım!
Dialogue: 0,0:27:43.14,0:27:47.43,Main-207+,,0,0,0,,Ninjaların yanında şüpheli faaliyetlerde bulunmak bir hatadır.
Dialogue: 0,0:27:49.31,0:27:51.19,Main-207+,,0,0,0,,Ne kadar da safsın.
Dialogue: 0,0:27:53.02,0:27:55.69,Main-207+,,0,0,0,,Ninjaların ne olduğunu bilmiyor musun?
Dialogue: 0,0:27:57.27,0:27:59.28,Main-207+,,0,0,0,,Dışarıdan bir yabancı olabilir.
Dialogue: 0,0:28:14.79,0:28:17.18,Main-207+,,0,0,0,,Merhabalar.
Dialogue: 0,0:28:17.18,0:28:19.30,Main-207+,,0,0,0,,Oldukça baş belası bir geyşasın.
Dialogue: 0,0:28:20.51,0:28:22.47,Main-207+,,0,0,0,,Sana açıklama fırsatı veriyorum.
Dialogue: 0,0:28:24.85,0:28:28.39,Main-207+,,0,0,2,,{\an8}Yalnızca tek bir şansın var.
Dialogue: 0,0:28:55.21,0:28:57.59,Main-207+,,0,0,0,,İyi misin, Sangoro?!
Dialogue: 0,0:28:57.59,0:29:01.09,Main-207+,,0,0,0,,Zaten Antik Zoan'dan daha azını beklemezdim ama...
Dialogue: 0,0:29:01.49,0:29:04.71,Main-207+,,0,0,0,,bu Gizli Kara'yı durdurmak için yeterli değil.
Dialogue: 0,0:29:11.33,0:29:15.19,Main-207+,,0,0,0,,Biraz acıdı ancak bu şey, gayet dayanıklı.
Dialogue: 0,0:29:17.95,0:29:20.94,Main-207+,,0,0,0,,Ama kasaba daha fazlasını kaldıramaz.
Dialogue: 0,0:29:24.71,0:29:28.26,Main-207+,,0,0,0,,Hey, neden Sangoro'yu geride bırakıyoruz?
Dialogue: 0,0:29:28.26,0:29:30.21,Main-207+,,0,0,0,,Bize devam etmemizi söyledi.
Dialogue: 0,0:29:30.21,0:29:32.45,Main-207+,,0,0,0,,Tamam dedi de...!
Dialogue: 0,0:29:34.53,0:29:39.28,Main-207+,,0,0,0,,Pekâlâ, cesedini Patron Kyoshiro'ya\Nteslim etme zamanı.
Dialogue: 0,0:29:39.28,0:29:41.13,Main-207+,,0,0,0,,Hem kimdi o herif?
Dialogue: 0,0:29:50.10,0:29:54.02,Main-207+,,0,0,0,,Diğerleri peşimize düşecek ve işler çığırından çıkacak.
Dialogue: 0,0:29:54.69,0:29:58.90,Main-207+,,0,0,0,,Şimdilik başkenti terk etmeliyiz.\NEbisu'ya sığınalım!
Dialogue: 0,0:30:31.43,0:30:35.39,Main-207+,,0,0,0,,{\fad(150,150)}Kayan Yıldız Osoba Tekmesi!
Dialogue: 0,0:30:38.52,0:30:39.69,Main-207+,,0,0,0,,Ne?!
Dialogue: 0,0:30:59.63,0:31:01.92,Main-207+,,0,0,0,,Peh. Oldukça sert çıktı.
Dialogue: 0,0:31:05.37,0:31:06.42,Main-207+,,0,0,0,,Neredesin?!
Dialogue: 0,0:31:06.75,0:31:11.89,Main-207+,,0,0,0,,Nereye gittin?!\NGöster kendini, Osoba Maskesi!
Dialogue: 0,0:31:12.99,0:31:15.18,Main-207+,,0,0,0,,Osoba Maskesi, he?
Dialogue: 0,0:31:15.58,0:31:19.61,Main-207+,,0,0,0,,Franosuke ve Usohachi'den bunu\Nyeniden tasarlamalarını istemeliyim!
Dialogue: 0,0:31:31.59,0:31:34.66,Main-207+,,0,0,0,,Nedir o?! Bir insan mı?!
Dialogue: 0,0:31:34.66,0:31:37.57,Main-207+,,0,0,0,,Ne büyük bir insan!
Dialogue: 0,0:31:38.93,0:31:41.50,Main-207+,,0,0,0,,Yine de bir devden daha küçük!
Dialogue: 0,0:31:41.50,0:31:45.53,Main-207+,,0,0,0,,S-Sence Kaido mu yoksa o mu daha büyük?
Dialogue: 0,0:31:46.05,0:31:49.17,Main-207+,,0,0,0,,O bir kadın mı?
Dialogue: 0,0:31:55.22,0:31:56.22,Main-207+,,0,0,0,,Olamaz!
Dialogue: 0,0:32:07.82,0:32:09.86,Main-207+,,0,0,0,,Big Mo–
Dialogue: 0,0:32:15.47,0:32:17.05,Main-207+,,0,0,0,,Sorun ne?
Dialogue: 0,0:32:18.01,0:32:20.08,Main-207+,,0,0,0,,Konuşma! Onu uyandıracaksın!
Dialogue: 0,0:32:20.50,0:32:23.33,Main-207+,,0,0,0,,Kaçmamız gerek! Uyanırsa biteriz!
Dialogue: 0,0:32:23.92,0:32:29.18,Main-207+,,0,0,0,,Hayır, iş işten geçti!\NBizi bulduysa artık kaçamayız.
Dialogue: 0,0:32:29.18,0:32:31.23,Main-207+,,0,0,0,,Neden bahsediyorsun?
Dialogue: 0,0:32:31.23,0:32:34.18,Main-207+,,0,0,0,,Onu tanıyor musun?
Dialogue: 0,0:32:34.18,0:32:36.89,Main-207+,,0,0,0,,Herkes tanır! Bu...
Dialogue: 0,0:32:38.67,0:32:40.64,Main-207+,,0,0,0,,Neee?!
Dialogue: 0,0:32:41.13,0:32:43.48,Main-207+,,0,0,0,,Meşhur Big Mom bu mu?!
Dialogue: 0,0:32:43.48,0:32:44.73,Main-207+,,0,0,0,,Sesini alçalt!
Dialogue: 0,0:32:46.33,0:32:48.56,Main-207+,,0,0,0,,Big Mom kim?
Dialogue: 0,0:32:48.56,0:32:50.78,Main-207+,,0,0,0,,Size daha sonra açıklarım!
Dialogue: 0,0:32:56.45,0:32:59.54,Main-207+,,0,0,0,,Onun işini kendim bitireceğim!
Dialogue: 0,0:32:59.54,0:33:02.43,Main-207+,,0,0,0,,Evet! Ona Kaido'ymuş gibi davranacağım!
Dialogue: 0,0:33:02.43,0:33:04.21,Main-207+,,0,0,0,,Zaten onunla aynı!
Dialogue: 0,0:33:12.72,0:33:14.59,Main-207+,,0,0,0,,Ç-Çok geç!
Dialogue: 0,0:33:14.59,0:33:17.35,Main-207+,,0,0,0,,Sadece koşun!
Dialogue: 0,0:33:25.05,0:33:27.25,Main-207+,,0,0,0,,Nerede...?
Dialogue: 0,0:33:28.47,0:33:31.85,Main-207+,,0,0,0,,Neredeyim... ben?
Dialogue: 0,0:33:41.83,0:33:43.95,Main-207+,,0,0,0,,Ben...
Dialogue: 0,0:33:46.03,0:33:47.50,Main-207+,,0,0,0,,kimim?!
Dialogue: 0,0:34:00.25,0:34:01.40,Main-207+,,0,0,0,,Haaa?!
