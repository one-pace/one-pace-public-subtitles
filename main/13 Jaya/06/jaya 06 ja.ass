Comment: 0,0:00:00.00,0:00:00.00,Main-207-,,0,0,0,,{=10}===============================DIALOGUE============================
Dialogue: 0,0:02:02.37,0:02:03.77,Main-207-,,0,0,0,,来るぞ！よけろ！
Dialogue: 0,0:02:17.43,0:02:20.08,Main-207-,,0,0,0,,おかしいだろ　こんなカマキリ！
Dialogue: 0,0:02:21.93,0:02:24.08,Main-207-,,0,0,0,,–　ああっ　網が！\N–　何なんだこの森は！
Dialogue: 0,0:02:29.81,0:02:30.63,Main-207-,,0,0,0,,あいつだよ！
Dialogue: 0,0:02:30.63,0:02:31.55,Main-207-,,0,0,0,,何が！
Dialogue: 0,0:02:31.55,0:02:34.55,Main-207-,,0,0,0,,サウスバードが\N虫たちの司令塔なんだ
Dialogue: 0,0:02:34.55,0:02:36.86,Main-207-,,0,0,0,,何で鳥が？虫の？
Dialogue: 0,0:02:45.81,0:02:48.27,Main-207-,,0,0,0,,いるぞ　どこからだ？
Dialogue: 0,0:02:52.28,0:02:56.49,Main-207-,,0,0,0,,うん？何だ？\N何か別の音も聞こえるぞ
Dialogue: 0,0:02:56.49,0:02:57.91,Main-207-,,0,0,0,,上だ！
Dialogue: 0,0:02:57.91,0:02:58.99,Main-207-,,0,0,0,,何だ？岩か？
Dialogue: 0,0:02:58.99,0:03:00.49,Main-207-,,0,0,0,,転がってくる
Dialogue: 0,0:03:00.49,0:03:02.33,Main-207-,,0,0,0,,フンコロガシのフンか？
Dialogue: 0,0:03:02.33,0:03:03.91,Main-207-,,0,0,0,,違うわ　虫よ！
Dialogue: 0,0:03:03.91,0:03:05.37,Main-207-,,0,0,0,,テントウムシだ！
Dialogue: 0,0:03:05.92,0:03:08.21,Main-207-,,0,0,0,,でっ　でけえよ　痛え！
Dialogue: 0,0:03:08.21,0:03:09.29,Main-207-,,0,0,0,,この…
Dialogue: 0,0:03:14.44,0:03:15.93,Main-207-,,0,0,0,,キリがねえ
Dialogue: 0,0:03:15.93,0:03:19.30,Main-207-,,0,0,0,,何でかかってくるんだよ\Nこのオケラ軍団！
Dialogue: 0,0:03:19.30,0:03:22.64,Main-207-,,0,0,0,,邪魔だぞ！\N俺に勝てそうか？ああ？
Dialogue: 0,0:03:24.74,0:03:28.10,Main-207-,,0,0,0,,鳴き声はするのに\N姿はないわね
Dialogue: 0,0:03:28.66,0:03:29.52,Main-207-,,0,0,0,,ナメクジだ！
Dialogue: 0,0:03:29.52,0:03:30.73,Main-207-,,0,0,0,,塩まけ　塩！
Dialogue: 0,0:03:30.73,0:03:33.40,Main-207-,,0,0,0,,うわあっ　サンジ\Nサマーソルトキックだ！
Dialogue: 0,0:03:33.40,0:03:34.49,Main-207-,,0,0,0,,よーし…
Dialogue: 0,0:03:34.49,0:03:36.13,Main-207-,,0,0,0,,関係あるか！
Dialogue: 0,0:03:37.36,0:03:40.83,Main-207-,,0,0,0,,もう嫌だ　逃げてばっかり！\Nかかってこい！
Dialogue: 0,0:03:41.41,0:03:44.79,Main-207-,,0,0,0,,ダメだよルフィ\Nクマバチは猛毒を持っている
Comment: 0,0:03:41.41,0:03:44.79,Main-207-,,0,0,0,,{\pos(711.99,520)}
Dialogue: 0,0:03:45.79,0:03:47.29,Main-207-,,0,0,0,,–　ホタルだ\N–　きれい
Dialogue: 0,0:03:47.29,0:03:48.79,Main-207-,,0,0,0,,いやっ！ゴキブリ！
Dialogue: 0,0:03:49.29,0:03:50.50,Main-207-,,0,0,0,,ブタ～！
Dialogue: 0,0:04:01.30,0:04:06.06,Main-207-,,0,0,0,,ほう…　見ろよこいつは\N見事な金塊だ
Dialogue: 0,0:04:07.45,0:04:12.86,Main-207-,,0,0,0,,お前らに\Nその黄金を持つ資格はねえ
Dialogue: 0,0:04:14.53,0:04:15.53,Main-207-,,0,0,0,,資格？
Dialogue: 0,0:04:15.53,0:04:17.99,Main-207-,,0,0,0,,これじゃ資格にならねえか？
Dialogue: 0,0:04:20.21,0:04:21.01,Main-207-,,0,0,0,,{\fad(150,150)}ビッグチョップ！
Dialogue: 0,0:04:26.10,0:04:27.66,Main-207-,,0,0,0,,バカ野郎が
Dialogue: 0,0:04:30.22,0:04:32.92,Main-207-,,0,0,0,,おめえらより\N俺たちのほうが強え
Dialogue: 0,0:04:32.92,0:04:37.55,Main-207-,,0,0,0,,宝を奪うためにこれ以外\Nどんな資格が必要なんだ？
Dialogue: 0,0:04:37.55,0:04:39.26,Main-207-,,0,0,0,,ええ？ジジイ
Dialogue: 0,0:04:39.26,0:04:41.39,Main-207-,,0,0,0,,おやっさんよけてろ！
Dialogue: 0,0:04:42.30,0:04:44.51,Main-207-,,0,0,0,,{\fad(150,150)}ハボック･ソナー！
Dialogue: 0,0:04:55.23,0:04:56.90,Main-207-,,0,0,0,,くっ…　この野郎
Dialogue: 0,0:04:56.90,0:04:58.74,Main-207-,,0,0,0,,待てサーキース
Dialogue: 0,0:04:58.74,0:05:00.66,Main-207-,,0,0,0,,俺が息の根を止めてやる
Dialogue: 0,0:05:02.78,0:05:04.37,Main-207-,,0,0,0,,またあれか
Dialogue: 0,0:05:04.88,0:05:07.91,Main-207-,,0,0,0,,バネバネの実の力…
Dialogue: 0,0:05:07.91,0:05:09.75,Main-207-,,0,0,0,,逃げろショウジョウ！
Dialogue: 0,0:05:09.97,0:05:11.21,Main-207-,,0,0,0,,{\fad(150,150)}スプリング…
Dialogue: 0,0:05:13.50,0:05:15.85,Main-207-,,0,0,0,,{\fad(150,150)}スナイプ！
Dialogue: 0,0:05:17.67,0:05:20.26,Main-207-,,0,0,0,,ショウジョウ！
Dialogue: 0,0:05:32.52,0:05:37.44,Flashbacks-207-,,0,0,0,,おやっさん！見つけたぞ黄金\N鐘型のインゴットだ
Dialogue: 0,0:05:48.24,0:05:53.37,Flashbacks-207-,,0,0,0,,ほら見ろ！日誌の文と一致するぜ\N鐘のことが書いてある
Dialogue: 0,0:05:58.34,0:06:01.80,Main-207-,,0,0,0,,さあ　行こうぜ\N金を積み込め
Dialogue: 0,0:06:01.80,0:06:04.22,Main-207-,,0,0,0,,ジジイ大人になれよ
Dialogue: 0,0:06:05.22,0:06:09.81,Main-207-,,0,0,0,,黄金郷は\Nノーランドが思い描いた空想の産物
Dialogue: 0,0:06:09.81,0:06:14.02,Main-207-,,0,0,0,,この先の\N新時代を行く海賊になりたきゃ
Dialogue: 0,0:06:14.02,0:06:16.77,Main-207-,,0,0,0,,夢は決して\Nかなわねえと知るべきだ
Dialogue: 0,0:06:20.88,0:06:22.95,Flashbacks-207-,,0,0,0,,黄金郷はあるんだ
Dialogue: 0,0:06:25.16,0:06:27.66,Flashbacks-207-,,0,0,0,,おいおい\N暴れるな狭い家で
Dialogue: 0,0:06:30.30,0:06:32.41,Main-207-,,0,0,0,,待て若造
Dialogue: 0,0:06:44.05,0:06:48.68,Main-207-,,0,0,0,,幻想にケンカを売る\N度胸もねえひよっこが
Dialogue: 0,0:06:48.68,0:06:51.14,Main-207-,,0,0,0,,海賊を語るんじゃねえ
Dialogue: 0,0:06:52.77,0:06:55.10,Main-207-,,0,0,0,,何だと？
Dialogue: 0,0:07:02.92,0:07:06.45,Main-207-,,0,0,0,,ダメだ\N姿すら１羽も確認できなかった
Dialogue: 0,0:07:06.45,0:07:08.55,Main-207-,,0,0,0,,俺たちは見たんだけどよ
Dialogue: 0,0:07:08.55,0:07:11.02,Main-207-,,0,0,0,,虫だらけで鳥どころじゃねえんだ
Dialogue: 0,0:07:12.12,0:07:14.33,Main-207-,,0,0,0,,走ってばっか…
Dialogue: 0,0:07:14.33,0:07:17.80,Main-207-,,0,0,0,,まいったな\N７人いてゼロだと？
Dialogue: 0,0:07:17.80,0:07:19.38,Main-207-,,0,0,0,,しっかりしろおめえら
Dialogue: 0,0:07:19.38,0:07:20.25,Main-207-,,0,0,0,,いやてめえもだろ
Dialogue: 0,0:07:21.96,0:07:24.84,Main-207-,,0,0,0,,私もうこれ以上走れないわよ
Dialogue: 0,0:07:32.72,0:07:36.44,Main-207-,,0,0,0,,“お前らなんかに捕まるか\Nバーカ”って
Dialogue: 0,0:07:36.44,0:07:40.19,Main-207-,,0,0,0,,何を！わざわざ\Nそれ言いに来やがったのか！
Dialogue: 0,0:07:40.19,0:07:42.48,Main-207-,,0,0,0,,こんちくしょう\N撃ち落としてやる
Dialogue: 0,0:07:48.78,0:07:50.74,Main-207-,,0,0,0,,姿さえ見えれば
Dialogue: 0,0:07:55.75,0:07:58.18,Main-207-,,0,0,0,,おっさん\N鳥を捕まえて…
Dialogue: 0,0:07:59.21,0:08:01.38,Main-207-,,0,0,0,,ひし形のおっさん！
Dialogue: 0,0:08:01.38,0:08:02.84,Main-207-,,0,0,0,,マシラ！
Dialogue: 0,0:08:02.84,0:08:04.23,Main-207-,,0,0,0,,ショウジョウ！
Dialogue: 0,0:08:05.05,0:08:07.94,Main-207-,,0,0,0,,一体　何があったの？
Dialogue: 0,0:08:08.55,0:08:11.64,Main-207-,,0,0,0,,クソッ\N何者の仕業だ
Dialogue: 0,0:08:11.64,0:08:12.76,Main-207-,,0,0,0,,おい手伝え
Dialogue: 0,0:08:12.76,0:08:13.51,Main-207-,,0,0,0,,うん
Dialogue: 0,0:08:13.51,0:08:17.60,Main-207-,,0,0,0,,わーっ　見ろ！\Nゴーイング･メリー号が！
Dialogue: 0,0:08:17.60,0:08:22.82,Main-207-,,0,0,0,,何てこった！誰だこんなことしやがったのは！\Nちくしょう！誰だ！
Dialogue: 0,0:08:22.82,0:08:24.23,Main-207-,,0,0,0,,すまん
Dialogue: 0,0:08:24.23,0:08:25.19,Main-207-,,0,0,0,,おっさん！
Dialogue: 0,0:08:26.99,0:08:30.20,Main-207-,,0,0,0,,おいおっさん！気が付いたか
Dialogue: 0,0:08:28.28,0:08:30.20,Secondary-207-,,0,0,0,,ホントにすまん
Dialogue: 0,0:08:30.20,0:08:32.91,Main-207-,,0,0,0,,俺たちがついていながら情けねえ
Dialogue: 0,0:08:32.91,0:08:37.41,Main-207-,,0,0,0,,だがよちゃんと…\Nまだ時間はある
Dialogue: 0,0:08:37.41,0:08:41.38,Main-207-,,0,0,0,,日が昇る前にちゃんと船を強化してよ…
Dialogue: 0,0:08:39.75,0:08:41.38,Secondary-207-,,0,0,0,,待てっておっさん
Dialogue: 0,0:08:41.38,0:08:43.21,Main-207-,,0,0,0,,とにかく何があったか話せよ
Dialogue: 0,0:08:44.15,0:08:48.84,Main-207-,,0,0,0,,いや　いいんだ\N気にするな　もう何でもねえ
Dialogue: 0,0:08:48.84,0:08:51.09,Main-207-,,0,0,0,,それよりお前ら…
Dialogue: 0,0:08:53.65,0:08:57.93,Main-207-,,0,0,0,,そうだ\Nよく捕まえてこれたなサウスバード…
Dialogue: 0,0:08:57.93,0:08:59.06,Main-207-,,0,0,0,,それでいい
Dialogue: 0,0:08:59.85,0:09:01.19,Main-207-,,0,0,0,,ルフィ！
Dialogue: 0,0:09:00.69,0:09:01.19,Secondary-207-,,0,0,0,,あっ？
Dialogue: 0,0:09:01.19,0:09:03.94,Main-207-,,0,0,0,,金塊が　取られてる
Dialogue: 0,0:09:09.75,0:09:15.16,Main-207-,,0,0,0,,ああ…　ああいいんだ\Nそんなのはよ　忘れろ　これは…
Dialogue: 0,0:09:15.16,0:09:16.70,Main-207-,,0,0,0,,それよりお前ら…
Dialogue: 0,0:09:16.70,0:09:19.08,Main-207-,,0,0,0,,“そんなのは”って何だよ！
Dialogue: 0,0:09:19.08,0:09:22.54,Main-207-,,0,0,0,,おやっさん10年も\N体イカれるまで海に潜り続けて
Dialogue: 0,0:09:22.54,0:09:25.00,Main-207-,,0,0,0,,やっと見つけた黄金じゃねえか！
Dialogue: 0,0:09:25.00,0:09:25.88,Main-207-,,0,0,0,,それをそんな…
Dialogue: 0,0:09:25.88,0:09:27.00,Main-207-,,0,0,0,,黙れこら！
Dialogue: 0,0:09:29.97,0:09:34.47,Main-207-,,0,0,0,,いいんだ\Nこれは俺たちの問題だ
Dialogue: 0,0:09:34.47,0:09:35.26,Main-207-,,0,0,0,,聞け
Dialogue: 0,0:09:36.16,0:09:39.14,Main-207-,,0,0,0,,猿山連合軍総出でかかりゃ
Dialogue: 0,0:09:39.14,0:09:42.52,Main-207-,,0,0,0,,あんな船の修繕\N強化なんざ訳はねえ
Dialogue: 0,0:09:42.52,0:09:44.81,Main-207-,,0,0,0,,朝までには間に合わせる
Dialogue: 0,0:09:44.81,0:09:48.73,Main-207-,,0,0,0,,お前らの出航に支障は出さねえ
Dialogue: 0,0:09:48.73,0:09:53.70,Main-207-,,0,0,0,,いいか　お前らは必ず\N俺たちが空へ送ってやる
Dialogue: 0,0:09:54.20,0:09:55.42,Main-207-,,0,0,0,,おやっさん
Dialogue: 0,0:09:57.37,0:09:58.37,Main-207-,,0,0,0,,おいルフィ
Dialogue: 0,0:10:05.64,0:10:07.25,Main-207-,,0,0,0,,ベラミーのマーク
Dialogue: 0,0:10:09.21,0:10:10.67,Main-207-,,0,0,0,,手伝おうか？
Dialogue: 0,0:10:11.38,0:10:12.62,Main-207-,,0,0,0,,いいよ　１人で
Comment: 0,0:10:12.72,0:10:18.16,Main-207-,,0,0,0,,ダメよルフィ　バカなこと考えちゃ！\N出航予定までもう３時間ないんだから！
Dialogue: 0,0:10:12.62,0:10:15.18,Main-207-,,0,0,0,,ダメよルフィ\Nバカなこと考えちゃ！
Dialogue: 0,0:10:15.18,0:10:17.60,Main-207-,,0,0,0,,出航予定までもう\N３時間ないんだから！
Dialogue: 0,0:10:21.49,0:10:25.23,Main-207-,,0,0,0,,海岸に沿ってったら\N昼間の町に着くかな？
Dialogue: 0,0:10:25.23,0:10:26.52,Main-207-,,0,0,0,,ええ　着くわよ
Dialogue: 0,0:10:29.36,0:10:31.94,Main-207-,,0,0,0,,おい小僧\Nどこへ行く？
Dialogue: 0,0:10:32.40,0:10:36.74,Main-207-,,0,0,0,,てめえ余計なまねすんじゃねえぞ\N相手が誰だか分かってる…
Dialogue: 0,0:10:37.45,0:10:39.58,Main-207-,,0,0,0,,止めたきゃこれ使えよ
Dialogue: 0,0:10:40.87,0:10:43.00,Main-207-,,0,0,0,,こっ　小僧
Dialogue: 0,0:10:46.79,0:10:49.25,Main-207-,,0,0,0,,朝までには戻る
Dialogue: 0,0:10:51.51,0:10:53.07,Main-207-,,0,0,0,,出た出た
Dialogue: 0,0:10:54.22,0:10:57.47,Main-207-,,0,0,0,,体の水分全部出しちまった
Dialogue: 0,0:10:57.47,0:11:01.02,Main-207-,,0,0,0,,これじゃあもう汗の１滴も出ねえ
Dialogue: 0,0:11:01.02,0:11:04.69,Main-207-,,0,0,0,,カラカラカラ～の\Nスッカラカ～ンってな
Dialogue: 0,0:11:06.98,0:11:10.65,Main-207-,,0,0,0,,お酒の神様\N今日もありがとうってか？
Dialogue: 0,0:11:12.86,0:11:14.95,Main-207-,,0,0,0,,いねえかそんなの
Dialogue: 0,0:11:19.24,0:11:20.74,Main-207-,,0,0,0,,新聞か
Dialogue: 0,0:11:20.74,0:11:24.41,Main-207-,,0,0,0,,どれどれ　今日は\Nどんな悪いニュースが載ってっかな？
Dialogue: 0,0:11:25.12,0:11:29.38,Main-207-,,0,0,0,,ああ？違うな\N手配書の束か…
Dialogue: 0,0:11:29.38,0:11:32.38,Main-207-,,0,0,0,,まったくここは無法の町だぜ
Dialogue: 0,0:11:32.38,0:11:35.76,Main-207-,,0,0,0,,悪人のご紹介なんざ\Nうんざりだってのに…
Dialogue: 0,0:11:37.76,0:11:40.47,Main-207-,,0,0,0,,こりゃ昼間の腰抜け小僧どもじゃねえか
Dialogue: 0,0:11:41.47,0:11:45.48,Main-207-,,0,0,0,,しかしあの空島発言にゃ\N笑わせてもらったね
Dialogue: 0,0:11:45.48,0:11:47.44,Main-207-,,0,0,0,,額は確か3000万…
Dialogue: 0,0:11:48.44,0:11:49.06,Main-207-,,0,0,0,,あっ？
Dialogue: 0,0:11:50.73,0:11:53.61,Main-207-,,0,0,0,,いかん　いかん\Nちょっと飲みすぎたか
Dialogue: 0,0:11:53.61,0:11:54.44,Main-207-,,0,0,0,,えっと
Dialogue: 0,0:11:54.44,0:11:55.15,Main-207-,,0,0,0,,一
Dialogue: 0,0:11:55.15,0:11:55.78,Main-207-,,0,0,0,,十
Dialogue: 0,0:11:55.78,0:11:56.32,Main-207-,,0,0,0,,百
Dialogue: 0,0:11:56.32,0:11:56.99,Main-207-,,0,0,0,,千
Dialogue: 0,0:11:56.99,0:11:58.07,Main-207-,,0,0,0,,万
Dialogue: 0,0:11:58.07,0:11:59.03,Main-207-,,0,0,0,,十万
Dialogue: 0,0:11:59.03,0:12:00.16,Main-207-,,0,0,0,,百万
Dialogue: 0,0:12:00.16,0:12:01.34,Main-207-,,0,0,0,,千万
Dialogue: 0,0:12:01.95,0:12:04.95,Main-207-,,0,0,0,,いやいやいかん\N飲みすぎた！
Dialogue: 0,0:12:06.58,0:12:07.33,Main-207-,,0,0,0,,一
Dialogue: 0,0:12:07.33,0:12:07.96,Main-207-,,0,0,0,,十
Dialogue: 0,0:12:07.96,0:12:08.67,Main-207-,,0,0,0,,百
Dialogue: 0,0:12:08.67,0:12:09.71,Main-207-,,0,0,0,,千
Dialogue: 0,0:12:09.71,0:12:10.58,Main-207-,,0,0,0,,万
Dialogue: 0,0:12:10.58,0:12:11.71,Main-207-,,0,0,0,,十万
Dialogue: 0,0:12:11.71,0:12:13.09,Main-207-,,0,0,0,,百万
Dialogue: 0,0:12:13.09,0:12:14.42,Main-207-,,0,0,0,,千万
Dialogue: 0,0:12:15.21,0:12:17.05,Main-207-,,0,0,0,,一億！？
Dialogue: 0,0:12:19.90,0:12:21.68,Flashbacks-207-,,0,0,0,,３時間よルフィ
Dialogue: 0,0:12:25.27,0:12:27.60,Flashbacks-207-,,0,0,0,,それ以上出航を延ばしたら…
Dialogue: 0,0:12:31.87,0:12:35.58,Flashbacks-207-,,0,0,0,,空島へのチャンスを\Nあんたが逃すことになるのよ
Dialogue: 0,0:12:36.82,0:12:40.82,Flashbacks-207-,,0,0,0,,{Jaya 04 - 09:27, though with different wording?}この人はきっと\Nその気泡が体から消える間もないくらい
Dialogue: 0,0:12:40.82,0:12:44.66,Flashbacks-207-,,0,0,0,,毎日毎日ムチャな潜り方を\N続けてきたんだ
Dialogue: 0,0:12:47.68,0:12:53.13,Flashbacks-207-,,0,0,0,,{Jaya 04 - 15:58, also with slightly different wording}俺の人生を狂わせた男との\Nこれは決闘なのさ
Dialogue: 0,0:12:56.01,0:12:58.92,Flashbacks-207-,,0,0,0,,{this ep - 08:22}すまん\Nホントにすまん
Dialogue: 0,0:12:58.92,0:13:02.47,Flashbacks-207-,,0,0,0,,{this ep - 08:27}俺たちがついていながら情けねえ
Dialogue: 0,0:13:04.56,0:13:06.93,Main-207-,,0,0,0,,あんにゃろー！
Dialogue: 0,0:13:11.16,0:13:13.98,Main-207-,,0,0,0,,あの時の大猿たちにゃ笑ったよ
Dialogue: 0,0:13:13.98,0:13:18.36,Main-207-,,0,0,0,,あのずうたいで傷だらけの顔に\N涙と鼻水垂れ流して
Dialogue: 0,0:13:18.36,0:13:20.95,Main-207-,,0,0,0,,“おやっさーん！”だ
Dialogue: 0,0:13:22.41,0:13:25.45,Main-207-,,0,0,0,,そんなに大事なら\Nしっかり守ってやれってんだ
Dialogue: 0,0:13:26.37,0:13:27.49,Main-207-,,0,0,0,,そうだろ？
Dialogue: 0,0:13:27.49,0:13:28.83,Main-207-,,0,0,0,,ダッサ～
Dialogue: 0,0:13:29.66,0:13:31.79,Main-207-,,0,0,0,,そう言ってやるなよ
Dialogue: 0,0:13:31.79,0:13:34.08,Main-207-,,0,0,0,,相手がお前やベラミーじゃしょうがねえ
Dialogue: 0,0:13:34.08,0:13:39.88,Main-207-,,0,0,0,,何たって　うちの船長は\N懸賞金5500万ベリーの大型ルーキーだ
Dialogue: 0,0:13:41.76,0:13:43.26,Main-207-,,0,0,0,,大変だ！
Dialogue: 0,0:13:43.26,0:13:45.39,Main-207-,,0,0,0,,おい何だ？この夜中に
Dialogue: 0,0:13:47.72,0:13:50.85,Main-207-,,0,0,0,,昼間この店にいたヤツらはすぐ…
Dialogue: 0,0:13:50.85,0:13:52.81,Main-207-,,0,0,0,,あっ　ベラミー！
Dialogue: 0,0:13:52.81,0:13:55.48,Main-207-,,0,0,0,,あんたまだここにいたのか！
Dialogue: 0,0:13:56.02,0:13:59.94,Main-207-,,0,0,0,,すぐ逃げたほうがいいぜ\Nあんた…　あんたが一番危ねえ！
Dialogue: 0,0:14:00.94,0:14:02.95,Main-207-,,0,0,0,,何の話だ？
Dialogue: 0,0:14:02.95,0:14:04.95,Main-207-,,0,0,0,,俺が危ねえだ？
Dialogue: 0,0:14:23.13,0:14:24.61,Main-207-,,0,0,0,,１億…
Dialogue: 0,0:14:25.64,0:14:27.64,Main-207-,,0,0,0,,6000万！？
Dialogue: 0,0:14:30.06,0:14:33.31,Main-207-,,0,0,0,,そうさ\N昼間のあいつら２人とも
Dialogue: 0,0:14:33.31,0:14:37.56,Main-207-,,0,0,0,,あんたより懸賞金が上なんだよベラミー！
Dialogue: 0,0:14:37.56,0:14:39.07,Main-207-,,0,0,0,,殺されるぞ
Dialogue: 0,0:14:39.57,0:14:43.70,Main-207-,,0,0,0,,ウソだろ？やべっ\Nえれえヤツを笑っちまった俺たち
Dialogue: 0,0:14:43.70,0:14:47.03,Main-207-,,0,0,0,,顔を覚えられてねえかな？\Nここにいるとまずいぞ
Dialogue: 0,0:14:50.66,0:14:54.08,Main-207-,,0,0,0,,１億の賞金首なんて会ったことねえよ
Dialogue: 0,0:15:00.38,0:15:03.76,Main-207-,,0,0,0,,おいおいおいおい\Nバカどもが
Dialogue: 0,0:15:03.76,0:15:06.39,Main-207-,,0,0,0,,そんな紙切れにおびえやがって
Dialogue: 0,0:15:06.89,0:15:09.39,Main-207-,,0,0,0,,てめえらの目は節穴かよ
Dialogue: 0,0:15:09.39,0:15:11.68,Main-207-,,0,0,0,,張本人を見ただろ？
Dialogue: 0,0:15:13.48,0:15:14.64,Main-207-,,0,0,0,,着いた
Dialogue: 0,0:15:15.06,0:15:18.11,Main-207-,,0,0,0,,過去にこんな\N海賊がいたのを知ってるか？
Dialogue: 0,0:15:18.11,0:15:23.69,Main-207-,,0,0,0,,てめえの手配書をてめえで偽造して\Nはったりだけで名を上げた海賊
Dialogue: 0,0:15:23.69,0:15:29.95,Main-207-,,0,0,0,,相手はその額を見て縮み上がり\N何もせずただ降伏するってわけさ
Dialogue: 0,0:15:29.95,0:15:32.49,Main-207-,,0,0,0,,戦えば本来勝てるものを
Dialogue: 0,0:15:32.49,0:15:34.66,Main-207-,,0,0,0,,今のおめえらのようにだ
Dialogue: 0,0:15:34.66,0:15:39.67,Main-207-,,0,0,0,,当人の弱さを目の\N当たりにしておきながらこのザマだ
Dialogue: 0,0:15:39.67,0:15:40.92,Main-207-,,0,0,0,,情けねえ
Dialogue: 0,0:15:41.38,0:15:44.59,Main-207-,,0,0,0,,そうだったのか\Nビビらせやがってあの野郎ども！
Dialogue: 0,0:15:44.98,0:15:49.09,Main-207-,,0,0,0,,だがしかし　ベラミーの言うとおり\N億なんて額になるヤツは
Dialogue: 0,0:15:49.09,0:15:52.56,Main-207-,,0,0,0,,相当やべえヤマに\N関わってるはずだってのに
Dialogue: 0,0:15:52.56,0:15:55.98,Main-207-,,0,0,0,,新聞沙汰にすら\Nなっちゃいねえってのがおかしいぜ
Dialogue: 0,0:15:55.98,0:15:59.69,Main-207-,,0,0,0,,違えねえ\N“麦わら”なんて聞いたことねえや
Dialogue: 0,0:15:59.69,0:16:02.94,Main-207-,,0,0,0,,何だ　そうか\N脅かしやがって
Dialogue: 0,0:16:09.66,0:16:13.62,Secondary-207-,,0,0,0,,ベラミー！どこだ！
Dialogue: 0,0:16:27.51,0:16:29.13,Main-207-,,0,0,0,,ご指名とは
Dialogue: 0,0:16:37.41,0:16:38.23,Secondary-207-,,0,0,0,,おい！
Dialogue: 0,0:16:44.65,0:16:48.15,Main-207-,,0,0,0,,今お前のウワサをしていたとこさ
Dialogue: 0,0:16:48.15,0:16:50.51,Main-207-,,0,0,0,,俺に何か用か？
Dialogue: 0,0:16:51.03,0:16:55.49,Main-207-,,0,0,0,,そうだ\Nひし形のおっさんの金塊を返せ
Comment: 0,0:00:00.00,0:00:00.00,Main-207-,,0,0,0,,{=11}===============================DIALOGUE============================
