Comment: 0,0:00:00.00,0:00:00.00,Main-207-,,0,0,0,,{=70}===============================DIALOGUE============================
Dialogue: 0,0:00:14.74,0:00:15.83,Main-207-,,0,0,0,,Eh? Piove?{Cora}
Dialogue: 0,0:00:15.83,0:00:17.68,Main-207-,,0,0,0,,No, non è pioggia...{Cora}
Dialogue: 0,0:00:17.68,0:00:19.29,Main-207-,,0,0,0,,Grandine?
Dialogue: 0,0:00:19.90,0:00:22.25,Main-207-,,0,0,0,,No... sta cadendo qualcosa...{Cora}
Dialogue: 0,0:00:23.88,0:00:25.80,Main-207-,,0,0,0,,– Eh?!\N– Eh?!{Cora}
Dialogue: 0,0:02:39.85,0:02:40.81,Main-207-,,0,0,0,,Reggetevi!
Dialogue: 0,0:02:41.31,0:02:42.69,Main-207-,,0,0,0,,Aggrappatevi alla nave!
Dialogue: 0,0:02:45.06,0:02:47.82,Main-207-,,0,0,0,,Cosa? Ma che cos'è?\N Che sta succedendo?{Cora}
Dialogue: 0,0:02:52.40,0:02:54.45,Main-207-,,0,0,0,,{Un sogno! Esatto, questo è un sogno! - OG}{\q2}È un sogno! \NSì, sto sicuramente sognando!{Cora}{la seconda sarebbe meglio "Sì, è sicuramente un sogno!" -angy}
Dialogue: 0,0:02:54.45,0:02:55.66,Main-207-,,0,0,0,,Un sogno? Che sollie–{Cora}
Dialogue: 0,0:02:59.87,0:03:02.04,Main-207-,,0,0,0,,Ehi, continua a cadere qualcosa!{Cora}
Dialogue: 0,0:03:02.50,0:03:03.79,Main-207-,,0,0,0,,Attenti!
Dialogue: 0,0:03:05.04,0:03:06.88,Main-207-,,0,0,0,,Il timone! Qualcuno viri la nave!{Cora}
Dialogue: 0,0:03:06.88,0:03:08.50,Main-207-,,0,0,0,,È inutile con queste onde!{Cora}
Dialogue: 0,0:03:08.50,0:03:10.67,Main-207-,,0,0,0,,Luffy, proteggi la nave!\N Non resisterà a lungo!{Cora}
Dialogue: 0,0:03:10.67,0:03:11.42,Main-207-,,0,0,0,,Ok!
Dialogue: 0,0:03:11.42,0:03:12.84,Main-207-,,0,0,0,,Eh? Usopp?
Dialogue: 0,0:03:13.17,0:03:14.55,Main-207-,,0,0,0,,Non c'è nulla da temere.{Cora}
Dialogue: 0,0:03:14.55,0:03:17.55,Main-207-,,0,0,0,,{\q2}Basta darsi una calmata, chiudere gli occhi...
Dialogue: 0,0:03:17.55,0:03:20.06,Main-207-,,0,0,0,,riaprire lentamente le palpebre,{Cora}
Dialogue: 0,0:03:20.06,0:03:22.52,Main-207-,,0,0,0,,e ci sarà una grande calma–{Cora}
Dialogue: 0,0:03:25.40,0:03:26.60,Main-207-,,0,0,0,,Uno scheletro!
Dialogue: 0,0:03:26.60,0:03:28.65,Main-207-,,0,0,0,,Idiota! Non buttarlo di qua!{Cora}
Dialogue: 0,0:03:28.65,0:03:30.36,Main-207-,,0,0,0,,Non smettono di cadere!{Cora}
Dialogue: 0,0:03:30.36,0:03:31.32,Main-207-,,0,0,0,,Uno scheletro!
Dialogue: 0,0:03:31.32,0:03:32.82,Main-207-,,0,0,0,,{\t(-200,1500,\3c&HFFFFFF&\4c&HFFFFFF&)}Idiota! Non buttarlo di qua!{Cora}
Dialogue: 0,0:03:37.82,0:03:41.16,Main-207-,,0,0,0,,Perché è caduta una nave dal cielo?{Tony}
Dialogue: 0,0:03:41.16,0:03:42.75,Main-207-,,0,0,0,,È assurdo.{Cora}
Dialogue: 0,0:03:42.75,0:03:44.08,Main-207-,,0,0,0,,Nel cielo non c'è niente.
Dialogue: 0,0:03:44.33,0:03:48.00,Main-207-,,0,0,0,,Ma si può sapere che razza \Ndi posto è la Grand Line?!{Cora}
Dialogue: 0,0:03:48.46,0:03:50.00,Main-207-,,0,0,0,,Che succede, Nami?
Dialogue: 0,0:03:50.00,0:03:51.25,Main-207-,,0,0,0,,Abbiamo un problema.
Dialogue: 0,0:03:51.88,0:03:53.55,Main-207-,,0,0,0,,Il Log Pose si è rotto!
Dialogue: 0,0:03:53.55,0:03:54.97,Main-207-,,0,0,0,,Punta in su e non si muove.
Dialogue: 0,0:03:55.34,0:03:56.30,Main-207-,,0,0,0,,Ti sbagli.{Cora}
Dialogue: 0,0:03:56.30,0:04:00.39,Main-207-,,0,0,0,,{\q2}Un'isola con un campo magnetico più forte \Nha sovrascritto quello registrato nel Log.{Cora}
Dialogue: 0,0:04:00.39,0:04:01.06,Main-207-,,0,0,0,,Eh?{Cora}
Dialogue: 0,0:04:01.06,0:04:02.43,Main-207-,,0,0,0,,Se l'ago punta in su,
Dialogue: 0,0:04:03.52,0:04:06.39,Main-207-,,0,0,0,,significa che ha registrato \Nun'isola nel cielo.{Cora}
Dialogue: 0,0:04:07.06,0:04:09.06,Main-207-,,0,0,0,,– "Un'isola nel cielo"?!\N– "Un'isola nel cielo"?!
Dialogue: 0,0:04:09.06,0:04:10.40,Main-207-,,0,0,0,,E cosa sarebbe?
Dialogue: 0,0:04:10.40,0:04:12.36,Main-207-,,0,0,0,,Le isole possono volare?!
Dialogue: 0,0:04:12.36,0:04:15.95,Main-207-,,0,0,0,,Q-Q-Quella nave e lo scheletro\N sono caduti da là?{Cora}
Dialogue: 0,0:04:15.95,0:04:19.24,Main-207-,,0,0,0,,Però... in cielo non vedo niente\N che somigli a un'isola...{Cora}
Dialogue: 0,0:04:19.62,0:04:20.87,Main-207-,,0,0,0,,Non è proprio così.
Dialogue: 0,0:04:22.03,0:04:24.95,Main-207-,,0,0,0,,Per la precisione, \Nquello che "vola" è un mare.{Tony}
Dialogue: 0,0:04:24.95,0:04:25.66,Main-207-,,0,0,0,,"Un mare"?{Cora}
Dialogue: 0,0:04:28.37,0:04:30.13,Main-207-,,0,0,0,,Ci sto capendo sempre di meno.
Dialogue: 0,0:04:30.13,0:04:34.05,Main-207-,,0,0,0,,Figata! Quindi c'è un mare che \Nvola nel cielo e ha delle isole!{Tony}{per me figata per quel verso che fa è eccessivo. avevo proposto wow, ma avete messo figata comunque -angy}
Dialogue: 0,0:04:34.05,0:04:35.26,Main-207-,,0,0,0,,Bene, andiamoci subito!
Dialogue: 0,0:04:35.26,0:04:38.59,Main-207-,,0,0,0,,{\i1}Alright!{\i0} Ciurma, rotta verso il cielo!{Cora}
Dialogue: 0,0:04:39.30,0:04:41.55,Main-207-,,0,0,0,,Tutta ad altobordo!
Dialogue: 0,0:04:43.56,0:04:46.52,Main-207-,,0,0,0,,A prescindere, è impossibile \Npuntare il timone in alto, "capitano".
Dialogue: 0,0:04:47.23,0:04:51.44,Main-207-,,0,0,0,,{\q2}A dire il vero... per quanto riguarda le isole \Nnel cielo non ne so molto neanche io,{Cora}
Dialogue: 0,0:04:51.44,0:04:52.94,Main-207-,,0,0,0,,tantomeno ne ho mai vista una.
Dialogue: 0,0:04:52.94,0:04:57.20,Main-207-,,0,0,0,,Ma è ovvio! Non possono esistere \Nun mare o un'isola capaci di volare.{Tony}
Dialogue: 0,0:04:57.20,0:04:59.20,Main-207-,,0,0,0,,Il Log Pose deve essersi rotto.{Tony}
Dialogue: 0,0:04:59.20,0:05:00.78,Main-207-,,0,0,0,,No, signorina navigatrice.
Dialogue: 0,0:05:01.07,0:05:06.12,Main-207-,,0,0,0,,{\q2}In questo momento, la cosa più importante \Nnon è capire se il Log Pose è rotto o meno...{Tony}
Dialogue: 0,0:05:06.70,0:05:08.37,Main-207-,,0,0,0,,ma come raggiungere il cielo.{Tony}
Dialogue: 0,0:05:09.79,0:05:17.01,Main-207-,,0,0,0,,{\q2}A priori dalle situazioni che coinvolgeranno\N questa nave... strane o inquietanti che siano, {Cora}
Dialogue: 0,0:05:17.01,0:05:19.55,Main-207-,,0,0,0,,del Log Pose ci si deve sempre fidare.{Tony}
Dialogue: 0,0:05:19.55,0:05:20.89,Main-207-,,0,0,0,,È una regola inviolabile.
Dialogue: 0,0:05:21.43,0:05:25.85,Main-207-,,0,0,0,,{\q2}In queste acque, se dovete dubitare \Ndi qualcosa, è del vostro buonsenso.{Tony}
Dialogue: 0,0:05:27.31,0:05:30.65,Main-207-,,0,0,0,,Là dove punta quell'ago... \Nc'è sicuramente un'isola.{Tony}
Dialogue: 0,0:05:39.90,0:05:43.12,Main-207-,,0,0,0,,{\q2}Ma deve proprio guardare\N dentro la bara, quella lì?{Tony}
Dialogue: 0,0:05:47.08,0:05:48.50,Main-207-,,0,0,0,,Ci hai capito qualcosa?{Cora}
Dialogue: 0,0:05:48.50,0:05:49.37,Main-207-,,0,0,0,,Non ancora.{Cora}
Dialogue: 0,0:05:49.37,0:05:52.17,Main-207-,,0,0,0,,{Hai un pessimo gusto, lo sai? - OG}Sei proprio di cattivo gusto, lo sai?{Cora}{non sei, non è giusto manco in italiano. hai pessimo gusto si dice, sei di cattivo gusto non l'ho mai sentito -angy}
Dialogue: 0,0:05:52.17,0:05:55.50,Main-207-,,0,0,0,,I cadaveri e le belle donne si \Nabbinano stranamente bene~{Cora}
Dialogue: 0,0:05:56.59,0:05:58.46,Main-207-,,0,0,0,,Mhm? Luffy dov'è?
Dialogue: 0,0:05:58.46,0:05:59.97,Main-207-,,0,0,0,,Luffy, salta!
Dialogue: 0,0:06:00.51,0:06:03.22,Main-207-,,0,0,0,,Che stanno facendo quelli stavolta?
Dialogue: 0,0:06:03.22,0:06:04.39,Main-207-,,0,0,0,,Esplorano, hanno detto.{Cora}
Dialogue: 0,0:06:05.68,0:06:07.81,Main-207-,,0,0,0,,Ah, ricostruzione completata.
Dialogue: 0,0:06:08.52,0:06:11.31,Main-207-,,0,0,0,,Questi fori sono di causa umana.{Cora}
Dialogue: 0,0:06:11.31,0:06:14.81,Main-207-,,0,0,0,,Oh... quindi questo tipo è morto\N dopo essere stato trafitto lì?{Cora}
Dialogue: 0,0:06:15.36,0:06:18.32,Main-207-,,0,0,0,,No, sono stati inflitti nel corso \Ndi un trattamento medico.{Lett: sono la conseguenza di un trattamento medico}{No, + lett -angy}{per me così è troppo lontano. sono stati inflitti non lo dice e also slight cps -angy}
Dialogue: 0,0:06:18.32,0:06:20.53,Main-207-,,0,0,0,,{\q2}Trapanazione cranica,\Ngiusto? Signor medico?{Cora}
Dialogue: 0,0:06:20.86,0:06:25.87,Main-207-,,0,0,0,,{\q2}Sì. Un tempo per trattare i tumori \Ncerebrali si usava fare dei buchi nel cranio.
Dialogue: 0,0:06:25.87,0:06:28.49,Main-207-,,0,0,0,,{\q2}Però, è una pratica medica\Ndi tantissimo tempo fa!{Cora}
Dialogue: 0,0:06:29.04,0:06:33.50,Main-207-,,0,0,0,,Esatto. Dovrebbero essere trascorsi\N duecento anni dalla sua morte.{Cora}
Dialogue: 0,0:06:36.00,0:06:38.71,Main-207-,,0,0,0,,Era circa sulla trentina.
Dialogue: 0,0:06:41.05,0:06:44.55,Main-207-,,0,0,0,,{\q2}Si è ammalato durante il viaggio ed è morto.
Dialogue: 0,0:06:48.76,0:06:53.14,Main-207-,,0,0,0,,I suoi denti si sono conservati\N meglio del resto delle ossa...{Cora}
Dialogue: 0,0:06:55.15,0:06:57.19,Main-207-,,0,0,0,,perché li aveva coperti di catrame.
Dialogue: 0,0:06:57.19,0:07:01.07,Main-207-,,0,0,0,,{\q2}È un'usanza tipica di una specifica\Nregione del South Blue. Di conseguenza,{4Eyes}
Dialogue: 0,0:07:01.07,0:07:06.03,Main-207-,,0,0,0,,{\q2}considerando i precedenti storici, quella nave\N doveva appartenere ad una squadra di esploratori.{Cora}
Dialogue: 0,0:07:08.28,0:07:13.75,Main-207-,,0,0,0,,Trovata. È la Saint Briss del\NRegno di Briss, nel South Blue.{Cora}
Dialogue: 0,0:07:13.75,0:07:15.50,Main-207-,,0,0,0,,È salpata duecentootto anni fa.{Cora}
Dialogue: 0,0:07:16.04,0:07:17.88,Main-207-,,0,0,0,,{\q2}È identica alla nave che ci è caduta addosso.
Dialogue: 0,0:07:17.88,0:07:20.42,Main-207-,,0,0,0,,{\q2}Ora che mi ci fai pensare,\N aveva un marchio simile.{Cora}
Dialogue: 0,0:07:20.42,0:07:24.47,Main-207-,,0,0,0,,Questa nave ha girovagato nel \Ncielo per almeno duecento anni.{Cora}
Dialogue: 0,0:07:24.72,0:07:27.89,Main-207-,,0,0,0,,Riesci davvero a capire tutto \Nquesto solo da un mucchio di ossa?{Cora}
Dialogue: 0,0:07:28.64,0:07:32.22,Main-207-,,0,0,0,,{\q2}Le spoglie non parlano,\Nma contengono informazioni.{Cora}
Dialogue: 0,0:07:32.22,0:07:37.06,Main-207-,,0,0,0,,{\q2}Essendo la nave di una squadra di esploratori,\Ndovrebbe avere registri e documenti vari.{Cora}
Dialogue: 0,0:07:37.06,0:07:39.69,Main-207-,,0,0,0,,Certo, ma la nave è affon–
Dialogue: 0,0:07:40.02,0:07:43.24,Main-207-,,0,0,0,,Ma che diavolo state facendo voi!{Cora}
Dialogue: 0,0:07:40.52,0:07:42.69,Secondary-207-,,0,0,0,,{\an8}Luffy! Risali!{Cora}
Dialogue: 0,0:07:42.69,0:07:44.40,Secondary-207-,,0,0,0,,{\an8}Aiuto!
Dialogue: 0,0:07:46.16,0:07:47.99,Main-207-,,0,0,0,,Ehi, ragazzi!
Dialogue: 0,0:07:48.45,0:07:50.33,Main-207-,,0,0,0,,Ce l'abbiamo fatta!
Dialogue: 0,0:07:51.12,0:07:53.00,Main-207-,,0,0,0,,{[/q2]Abbiamo trovato qualcosa di fantastico! - una figata!}{lascierei fantastico qui sinceramente -angy}Abbiamo trovato qualcosa di assurdo!{Cora}{meglio fantastico qua, non è assurdo -angy}
Dialogue: 0,0:07:53.00,0:07:53.75,Main-207-,,0,0,0,,Guardate!
Comment: 0,0:07:53.75,0:07:55.29,Main-207-,,0,0,0,,– Ah!\N– Ah!
Dialogue: 0,0:07:56.46,0:07:58.96,Main-207-,,0,0,0,,– La mappa di un'isola nel cielo?!\N– La mappa di un'isola nel cielo?!{Cora}
Dialogue: 0,0:07:59.42,0:08:00.67,Main-207-,,0,0,0,,"Skypiea".
Dialogue: 0,0:08:00.67,0:08:01.71,Main-207-,,0,0,0,,Visto?! Visto?!{Cora}
Dialogue: 0,0:08:01.71,0:08:03.92,Main-207-,,0,0,0,,Quindi nel cielo c'è {\i1}davvero{\i0} un'isola?
Dialogue: 0,0:08:04.38,0:08:07.93,Main-207-,,0,0,0,,– {\i1}Yahoo{\i0}!\N– {\i1}Yahoo{\i0}!{Cora}
Dialogue: 0,0:08:07.93,0:08:10.55,Main-207-,,0,0,0,,Evviva! L'isola nel cielo esiste!
Dialogue: 0,0:08:10.55,0:08:13.52,Main-207-,,0,0,0,,È un'isola dei sogni! \NPossiamo andare su un'isola dei sogni!
Dialogue: 0,0:08:13.52,0:08:15.39,Main-207-,,0,0,0,,– Isola dei sogni~!\N– Isola dei sogni~!
Dialogue: 0,0:08:16.23,0:08:20.15,Main-207-,,0,0,0,,Fate troppo casino! Non abbiamo \Nancora nessuna certezza.{Cora}
Dialogue: 0,0:08:20.15,0:08:22.61,Main-207-,,0,0,0,,Dopotutto di mappe finte \Nce ne sono tante in giro.
Dialogue: 0,0:08:24.94,0:08:28.61,Main-207-,,0,0,0,,Aah, scusate. Esiste, esiste. \NEsiste sicuramente, però...
Dialogue: 0,0:08:29.45,0:08:30.53,Main-207-,,0,0,0,,Ascolta Luffy!
Dialogue: 0,0:08:30.99,0:08:32.49,Secondary-207-,,0,0,0,,{\an8}Ehi, Nami...
Dialogue: 0,0:08:32.49,0:08:34.33,Secondary-207-,,0,0,0,,{\an8}la nave trattamela con cura.
Dialogue: 0,0:08:34.87,0:08:35.79,Secondary-207-,,0,0,0,,{\an8}Ok?
Dialogue: 0,0:08:30.53,0:08:33.45,Main-207-,,0,0,0,,Ti sto dicendo che non abbiamo \Nancora idea di come arrivarci!{Cora}
Dialogue: 0,0:08:33.45,0:08:35.54,Main-207-,,0,0,0,,{\q2}Sei tu la navigatrice, no? Inventati qualcosa!
Dialogue: 0,0:08:36.08,0:08:40.50,Secondary-207-,,0,0,0,,{\an8}{\q2}Nami è proprio un amore quando è arrabbiata~{carina -ngy}{a me è un amore non piace ed è sbagliato. sarebbe è troppo carina -angy}
Dialogue: 0,0:08:35.54,0:08:38.46,Main-207-,,0,0,0,,{\q2}Certe volte è impossibile "inventarsi qualcosa"!{Cora}
Dialogue: 0,0:08:38.46,0:08:40.50,Main-207-,,0,0,0,,Chissene!{lett: non importa} Noi andremo in cielo!{sì, eviterei chissene. al massimo "chi se ne importa"  -angy} {Invece mi piace chissene, è molto colloquiale, si confà bene a Luffy -Cora}{per me non si confà per niente -angy}
Dialogue: 0,0:08:42.00,0:08:43.63,Main-207-,,0,0,0,,Discutere ora non serve a nulla.{Cora}
Dialogue: 0,0:08:43.63,0:08:46.22,Main-207-,,0,0,0,,Più che altro, ora come ora\N non c'è modo di continuare.{Cora}
Dialogue: 0,0:08:46.22,0:08:49.18,Main-207-,,0,0,0,,Do ragione a Robin, quello che\N ci serve ora sono informazioni.{Cora}
Dialogue: 0,0:08:49.93,0:08:52.68,Main-207-,,0,0,0,,Se quella nave enorme è\N davvero andata in cielo,
Dialogue: 0,0:08:52.68,0:08:55.43,Main-207-,,0,0,0,,c'è sicuramente un modo per \Nandarci anche con questa nave.{Cora}
Dialogue: 0,0:08:56.14,0:09:00.40,Main-207-,,0,0,0,,{\q2}Dobbiamo controllare in qualche modo \Ni documenti rimasti sulla nave di prima.{Cora}
Dialogue: 0,0:09:00.98,0:09:03.73,Main-207-,,0,0,0,,La nave però è \Ncompletamente affondata, no?{Cora}
Dialogue: 0,0:09:04.40,0:09:06.61,Main-207-,,0,0,0,,{\q2}Se è affondata, effettueremo un {\i1}salvage{\i0}!{Cora}
Dialogue: 0,0:09:06.61,0:09:08.40,Main-207-,,0,0,0,,– Andiamo!\N– Andiamo!{Cora}
Dialogue: 0,0:09:08.40,0:09:09.70,Main-207-,,0,0,0,,Come pensate di farcela?!{Cora}
Dialogue: 0,0:09:10.49,0:09:12.03,Main-207-,,0,0,0,,Che cos'è un "{\i1}salvage{\i0}"?{Cora}
Dialogue: 0,0:09:12.03,0:09:14.66,Main-207-,,0,0,0,,È un'operazione per far \Nriemergere una nave affondata.{Cora}
Dialogue: 0,0:09:14.66,0:09:17.58,Main-207-,,0,0,0,,{\q2}Però è impossibile farlo con quella nave, \Nè troppo grande.
Dialogue: 0,0:09:24.80,0:09:26.09,Main-207-,,0,0,0,,Bene, bene, bene, bene...
Dialogue: 0,0:09:26.42,0:09:28.97,Main-207-,,0,0,0,,Certo che ci fai proprio \Nfare una cosa assurda.{Cora}
Dialogue: 0,0:09:28.97,0:09:29.59,Main-207-,,0,0,0,,Già.
Dialogue: 0,0:09:29.59,0:09:31.14,Main-207-,,0,0,0,,Nami, tesoro~!
Dialogue: 0,0:09:31.14,0:09:34.06,Main-207-,,0,0,0,,Ti prometto che troverò indizi\N su come arrivare in cielo per te!{non sarebbe specifico che lo fa per lei -angy}{sottolineo ancora che non è specificatamente per lei che lo fa -angy}
Dialogue: 0,0:09:34.39,0:09:35.77,Main-207-,,0,0,0,,Conto su di te!{Cora}
Dialogue: 0,0:09:35.77,0:09:39.56,Main-207-,,0,0,0,,State tranquilli~!\NIl design delle mie tute non ha difetti!{Cora}{tute non lo dice -angy}
Dialogue: 0,0:09:44.40,0:09:46.03,Main-207-,,0,0,0,,Allora, vi auguro...{Cora}
Dialogue: 0,0:09:46.57,0:09:47.82,Main-207-,,0,0,0,,buona fortuna!
Dialogue: 0,0:09:53.82,0:09:55.16,Main-207-,,0,0,0,,Ehi, ehi, ehi...{Cora}
Dialogue: 0,0:09:55.41,0:09:58.12,Main-207-,,0,0,0,,Qui Chopper.\N Ragazzi, rispondete.{Cora}
Dialogue: 0,0:09:58.66,0:10:01.58,Main-207-,,0,0,0,,{\i1}Qui Luffy! \NCi sono un sacco di mostri, passo!{Cora}
Dialogue: 0,0:10:01.58,0:10:03.83,Main-207-,,0,0,0,,{{\i1}Che sia un nido di \Nserpenti marini giganti?{Cora}
Dialogue: 0,0:10:03.83,0:10:06.00,Main-207-,,0,0,0,,{\i1}Qui Sanji. \NAh! Si è girato verso di me!{Cora}
Dialogue: 0,0:10:06.50,0:10:07.38,Main-207-,,0,0,0,,Okay.
Dialogue: 0,0:10:07.38,0:10:08.09,Main-207-,,0,0,0,,Non è okay!{Cora}
Dialogue: 0,0:10:08.76,0:10:11.09,Main-207-,,0,0,0,,In qualche modo se la caveranno, \Nva tutto bene.{Cora}
Dialogue: 0,0:10:11.51,0:10:14.01,Main-207-,,0,0,0,,Chopper, tieni le mani sul freno!{Tony}
Dialogue: 0,0:10:14.01,0:10:14.76,Main-207-,,0,0,0,,Sì.
Dialogue: 0,0:10:14.76,0:10:16.97,Main-207-,,0,0,0,,Per fortuna che non sono andato io...
Comment: 0,0:10:21.27,0:10:22.64,Main-207-,,0,0,0,,Cosa?{eh? ed è già commento -angy}
Dialogue: 0,0:10:22.65,0:10:30.61,Main-207-,,0,0,0,,{\fnFOT-Greco Std B Strp\fs75\b1}♪ {\i1}Salvage! Salvage! Salvage!{\i0} ♪{Cora}
Dialogue: 0,0:10:31.03,0:10:32.53,Main-207-,,0,0,0,,Ma che roba è quella?{Cora}
Dialogue: 0,0:10:33.28,0:10:36.16,Main-207-,,0,0,0,,{\fnFOT-Greco Std B Strp\fs75\b1}♪ {\i1}Salvage～ {\i0}! ♪{Noto che la ~ la mette in alto, non so perché -Cora}{questione di font、c'ho messo quella jp così è più al suo posto}
Dialogue: 0,0:10:36.16,0:10:40.37,Main-207-,,0,0,0,,{\fnFOT-Greco Std B Strp\fs75\b1}♪ {\i1}Salvage! Salvage!{\i0} ♪{Cora}
Dialogue: 0,0:10:41.71,0:10:44.25,Main-207-,,0,0,0,,{\fnFOT-Greco Std B Strp\fs75\b1}♪ {\i1}Salvage{\i0}! ♪{Cora}
Dialogue: 0,0:10:44.71,0:10:49.96,Secondary-207-,,0,0,0,,{\fnFOT-Greco Std B Strp\fs75\b1\an8}♪ {\i1}Salvage! Salvage!{\i0} ♪{Cora}
Dialogue: 0,0:10:44.71,0:10:48.21,Main-207-,,0,0,0,,Arresto completo!
Dialogue: 0,0:10:50.63,0:10:52.72,Main-207-,,0,0,0,,– Sissignore!\N– Sissignore!
Dialogue: 0,0:10:52.72,0:10:55.55,Main-207-,,0,0,0,,È qui che è affondata la nave?
Dialogue: 0,0:10:55.55,0:10:57.97,Main-207-,,0,0,0,,– Sissignore! Boss!\N– Sissignore! Boss!
Dialogue: 0,0:10:58.97,0:11:02.94,Main-207-,,0,0,0,,Boss... \Nquindi stanno parlando di me!{Cora}
Dialogue: 0,0:11:03.52,0:11:05.31,Main-207-,,0,0,0,,Preparatevi a tirarla su!
Dialogue: 0,0:11:05.31,0:11:08.36,Main-207-,,0,0,0,,{\q2}La nave affondata appartiene \Nal Boss dei Pirati Masira,
Dialogue: 0,0:11:08.36,0:11:11.28,Main-207-,,0,0,0,,ovvero me, Masira il Re del Salvage!
Dialogue: 0,0:11:15.57,0:11:18.87,Main-207-,,0,0,0,,Doveva apparire proprio adesso,\N questo stramboide?
Dialogue: 0,0:11:19.12,0:11:21.70,Main-207-,,0,0,0,,Ehi, voi! Che state facendo là?
Dialogue: 0,0:11:21.70,0:11:23.58,Main-207-,,0,0,0,,Questo è il mio territorio!
Dialogue: 0,0:11:23.96,0:11:25.04,Main-207-,,0,0,0,,Territorio?
Dialogue: 0,0:11:25.29,0:11:26.54,Main-207-,,0,0,0,,Esattamente.
Dialogue: 0,0:11:26.54,0:11:30.34,Main-207-,,0,0,0,,Qualsiasi nave affondata in questo\N territorio appartiene a me!
Dialogue: 0,0:11:30.34,0:11:33.01,Main-207-,,0,0,0,,Voialtri non l'avrete mica\N già toccata, vero?
Dialogue: 0,0:11:33.51,0:11:36.93,Main-207-,,0,0,0,,Sembra che quella persona abbia \Nintenzione di fare un {\i1}salvage{\i0}.{Cora}
Dialogue: 0,0:11:36.93,0:11:39.05,Main-207-,,0,0,0,,Già, ha detto qualcosa del genere.{Cora}
Dialogue: 0,0:11:39.05,0:11:41.60,Main-207-,,0,0,0,,{\q2}Che facciamo? \NForse dovremmo cogliere l'opportunità?{Cora}{no. è "korette chance nano?" cioè " "che sia un'opportunità?". @Cora l'hai resa troppo lunga}
Dialogue: 0,0:11:41.60,0:11:43.52,Main-207-,,0,0,0,,Smettetela di borbottare!
Dialogue: 0,0:11:43.52,0:11:46.90,Main-207-,,0,0,0,,Rispondete immediatamente \Nalla mia domanda!
Dialogue: 0,0:11:47.52,0:11:50.15,Main-207-,,0,0,0,,Scusi! Posso chiederle una cosa?{Cora}
Dialogue: 0,0:11:50.15,0:11:51.36,Main-207-,,0,0,0,,{\i1}Tu{\i0} fai le domande ora?{Cora}
Dialogue: 0,0:11:51.86,0:11:54.40,Main-207-,,0,0,0,,Va bene!\N Chiedimi pure quello che vuoi.{Cora}
Dialogue: 0,0:11:54.40,0:11:57.16,Main-207-,,0,0,0,,Vuole fare un {\i1}salvage{\i0} per\N caso, signor scimmia?{ vedi sotto -Cora}
Dialogue: 0,0:11:57.16,0:11:58.07,Main-207-,,0,0,0,,{Pun, non so che vogliamo fare. Il verbo che indica il modo di parlare cortese che usa Nami finisce per "saru", che significa scimmia.}{eh, non funzionera mai... l'unica è mettere "E... seguire?" e poi aggiungerci una nota -angy}"Signor scimmia"?! {ho trovato questo modo per adattarlo, non è 100% accurate but still -Cora}{a me non piace -angy}
Dialogue: 0,0:12:00.99,0:12:04.66,Main-207-,,0,0,0,,Ehi, sono così tanto {\i1}scimmialto{\i0}?{Cora}
Dialogue: 0,0:12:04.66,0:12:05.50,Main-207-,,0,0,0,,"{\i1}Scimmialto{\i0}"?{Cora}
Dialogue: 0,0:12:05.50,0:12:08.00,Main-207-,,0,0,0,,Significa "uomo affascinante".\N Lo pensi davvero?
Dialogue: 0,0:12:08.75,0:12:09.79,Main-207-,,0,0,0,,Certo...
Dialogue: 0,0:12:09.79,0:12:12.67,Main-207-,,0,0,0,,Ah, mi fai arrossire così~{Cora}
Dialogue: 0,0:12:12.67,0:12:14.30,Main-207-,,0,0,0,,Ma quella parola neanche esiste...{Cora}
Dialogue: 0,0:12:15.22,0:12:17.97,Main-207-,,0,0,0,,Quindi? Fai il {\i1}salvage{\i0} o no?{Cora}
Dialogue: 0,0:12:17.97,0:12:23.97,Main-207-,,0,0,0,,{\q2}Ehi ragazzino, io sono il tipo di uomo che\N se vede una nave affondata la riporta su!{Cora}
Dialogue: 0,0:12:23.97,0:12:27.19,Main-207-,,0,0,0,,Se galleggia ancora, \Nte la affondo e poi te la riporto su!{Cora}
Dialogue: 0,0:12:27.19,0:12:30.40,Main-207-,,0,0,0,,Non c'è nave che sfugge \Nal nostro trattamento!{Cora}
Dialogue: 0,0:12:31.27,0:12:34.40,Main-207-,,0,0,0,,Ci permetterebbe di osservarla\N per imparare come si fa?{Cora}
Dialogue: 0,0:12:34.40,0:12:39.07,Main-207-,,0,0,0,,Aah, capisco. \NQuindi il {\i1}salvage{\i0} vi è nuovo, eh?{Cora}
Dialogue: 0,0:12:39.91,0:12:41.87,Main-207-,,0,0,0,,Va bene allora! Guardate bene!
Dialogue: 0,0:12:42.58,0:12:45.87,Main-207-,,0,0,0,,Bene. Per ora, vediamo come \Nsi sviluppa la situazione, gente.{Cora}
Dialogue: 0,0:12:46.54,0:12:49.83,Main-207-,,0,0,0,,F-Fate attenzione...{Cora}
Dialogue: 0,0:12:50.29,0:12:51.63,Main-207-,,0,0,0,,Boss! C'è un problema!
Dialogue: 0,0:12:51.63,0:12:52.63,Main-207-,,0,0,0,,Che succede?{Cora}
Dialogue: 0,0:12:52.63,0:12:55.55,Main-207-,,0,0,0,,L'equipaggio che si è sommerso \Nper posizionare la culla...!
Dialogue: 0,0:12:55.88,0:12:57.76,Main-207-,,0,0,0,,È stato attaccato da un Re del Mare?{Cora}
Dialogue: 0,0:12:57.76,0:13:00.89,Main-207-,,0,0,0,,No... sembra più che siano \Nstati picchiati da una persona...
Dialogue: 0,0:13:00.89,0:13:04.27,Main-207-,,0,0,0,,Cosa?! Mi stai dicendo che c'è \Nqualcuno sul fondo del mare?{Cora}
Dialogue: 0,0:13:04.27,0:13:05.43,Main-207-,,0,0,0,,Quei tre...
Dialogue: 0,0:13:05.43,0:13:06.98,Main-207-,,0,0,0,,Qui si mette male...
Dialogue: 0,0:13:06.98,0:13:08.39,Main-207-,,0,0,0,,Allora...
Dialogue: 0,0:13:08.39,0:13:10.23,Main-207-,,0,0,0,,Ehi, voialtri!
Dialogue: 0,0:13:10.23,0:13:11.36,Main-207-,,0,0,0,,Ah, ecco...{Cora}
Dialogue: 0,0:13:11.36,0:13:14.53,Main-207-,,0,0,0,,C'è qualcuno sul fondo del mare! \NFate attenzione!
Dialogue: 0,0:13:14.53,0:13:15.73,Main-207-,,0,0,0,,O-Ok...!{Cora}
Dialogue: 0,0:13:15.73,0:13:17.32,Thoughts-207-,,0,0,0,,– Per fortuna è uno scemo.\N– Per fortuna è uno scemo.{Cora}
Dialogue: 0,0:13:17.61,0:13:18.78,Main-207-,,0,0,0,,Uomini!
Dialogue: 0,0:13:18.78,0:13:20.86,Main-207-,,0,0,0,,Sbrigatevi a disporre la culla!
Dialogue: 0,0:13:21.37,0:13:23.70,Main-207-,,0,0,0,,Diamo inizio al {\i1}salvage{\i0}!{Cora}
Dialogue: 0,0:13:23.70,0:13:25.33,Main-207-,,0,0,0,,– Sissignore!\N– Sissignore!
Dialogue: 0,0:13:41.64,0:13:43.10,Main-207-,,0,0,0,,Ci sta salutando con la mano.
Dialogue: 0,0:13:43.10,0:13:45.26,Main-207-,,0,0,0,,Non deve accorgersi del\N tubo per l'aria, Usopp.{Cora}
Dialogue: 0,0:13:45.26,0:13:46.77,Main-207-,,0,0,0,,Lo-so-bene.{Cora}
Dialogue: 0,0:13:46.77,0:13:48.31,Main-207-,,0,0,0,,Ehi, uomini.{Cora}
Dialogue: 0,0:13:48.31,0:13:50.44,Main-207-,,0,0,0,,Fate finta che siano delle zucche!{Cora}
Dialogue: 0,0:13:50.44,0:13:52.40,Main-207-,,0,0,0,,{\q2}Solo perché abbiamo degli spettatori...
Dialogue: 0,0:13:53.40,0:13:56.53,Main-207-,,0,0,0,,non è mica il caso di essere nervosi!
Dialogue: 0,0:13:56.53,0:13:58.24,Main-207-,,0,0,0,,– Sissignore!\N– Sissignore!
Dialogue: 0,0:13:58.24,0:14:00.40,Main-207-,,0,0,0,,Immergete la culla!
Dialogue: 0,0:14:00.40,0:14:01.70,Main-207-,,0,0,0,,– Sissignore!\N– Sissignore!
Dialogue: 0,0:14:04.70,0:14:06.41,Main-207-,,0,0,0,,State attenti ai nemici misteriosi!{Cora}
Dialogue: 0,0:14:06.41,0:14:07.58,Main-207-,,0,0,0,,– Sissignore!\N– Sissignore!
Dialogue: 0,0:14:09.54,0:14:12.75,Main-207-,,0,0,0,,{\q2}Sembra proprio che abbia una sorta di orgoglio.
Dialogue: 0,0:14:12.75,0:14:15.50,Main-207-,,0,0,0,,{\q2}Stanno solo cercando di\N fare buona impressione...{Cora}
Dialogue: 0,0:14:16.05,0:14:17.96,Main-207-,,0,0,0,,Non distraetevi neanche un secondo!
Dialogue: 0,0:14:17.96,0:14:19.47,Main-207-,,0,0,0,,– Sissignore!\N– Sissignore!
Dialogue: 0,0:15:31.41,0:15:32.08,Main-207-,,0,0,0,,Ehi!
Comment: 0,0:15:32.08,0:15:33.21,Main-207-,,0,0,0,,Che?{eh? -angy}
Dialogue: 0,0:15:33.21,0:15:33.96,Main-207-,,0,0,0,,Quello.
Dialogue: 0,0:15:59.61,0:16:01.94,Main-207-,,0,0,0,,Culla in posizione, confermata!{Cora}
Dialogue: 0,0:16:03.49,0:16:04.74,Main-207-,,0,0,0,,Che cavolo–?{Cora}
Comment: 0,0:16:04.74,0:16:05.65,Main-207-,,0,0,0,,Eh?
Dialogue: 0,0:16:07.32,0:16:08.70,Main-207-,,0,0,0,,C-Cos...
Dialogue: 0,0:16:08.70,0:16:10.28,Main-207-,,0,0,0,,Cos'è esattamente quella scimmia?
Dialogue: 0,0:16:10.62,0:16:12.62,Main-207-,,0,0,0,,Cos'è quella scimmia?{Cora}
Dialogue: 0,0:16:12.62,0:16:13.75,Main-207-,,0,0,0,,Ah, questa?
Dialogue: 0,0:16:15.29,0:16:17.37,Main-207-,,0,0,0,,Hai proprio un buon occhio tu.
Dialogue: 0,0:16:17.37,0:16:19.71,Main-207-,,0,0,0,,{\q2}Già, questa non è una polena qualsiasi.{dice prua ma parla della polena, boh}{eh, ma lascerei prua... alla fine sta a prua comunque -angy} {è più corretto polena però se dice prua... -Cora}{io voto polena -Tony}{dice prua -angy}
Dialogue: 0,0:16:21.55,0:16:23.59,Main-207-,,0,0,0,,Lancio...!
Dialogue: 0,0:16:23.59,0:16:25.17,Main-207-,,0,0,0,,del Barco-Hunter!
Dialogue: 0,0:16:25.55,0:16:27.80,Main-207-,,0,0,0,,– Sissignore!\N– Sissignore!
