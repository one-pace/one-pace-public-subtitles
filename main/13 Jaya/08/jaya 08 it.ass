Comment: 0,0:00:00.00,0:00:00.00,Main-207-,,0,0,0,,{=39}===============================DIALOGUE============================
Dialogue: 0,0:01:54.76,0:01:58.72,Main-207-,,0,0,0,,Ma che sta facendo quel tizio?! \NÈ mattina ormai, mattina!
Dialogue: 0,0:01:59.43,0:02:04.48,Main-207-,,0,0,0,,{\q2}È in ritardo di ben quarantasei minuti dall'orario \Nconcordato! Perderemo la corrente marina!
Dialogue: 0,0:02:04.48,0:02:08.73,Main-207-,,0,0,0,,{\q2}Che poi, tornando avrà i lingotti d'oro, \Nquindi ci metterà di più perché sono pesanti!
Dialogue: 0,0:02:08.73,0:02:11.86,Main-207-,,0,0,0,,Non è capace di fare quel tipo di \Ncalcolo con la testa che si ritrova!{cps}
Dialogue: 0,0:02:11.86,0:02:15.24,Main-207-,,0,0,0,,No, beh, non penso abbia fatto \Nalcun calcolo temporale dall'inizio...
Dialogue: 0,0:02:15.24,0:02:16.70,Main-207-,,0,0,0,,Già, hai ragione al 100%.
Dialogue: 0,0:02:16.70,0:02:19.45,Main-207-,,0,0,0,,Non è che sia stato sconfitto in città?
Dialogue: 0,0:02:19.83,0:02:21.50,Main-207-,,0,0,0,,Da quel Bellamy?!
Dialogue: 0,0:02:21.50,0:02:24.42,Main-207-,,0,0,0,,Se avesse perso, non lo perdonerò \Nnemmeno se faremo in tempo!{a tempo? in tempo? ho sempre il dubbio}
Dialogue: 0,0:02:24.92,0:02:26.92,Main-207-,,0,0,0,,Ma che hai?{meh, non mi viene...}
Dialogue: 0,0:02:30.67,0:02:33.68,Main-207-,,0,0,0,,Eeehi!
Dialogue: 0,0:02:37.64,0:02:40.47,Main-207-,,0,0,0,,È lui! Che sollievo, è tornato!
Dialogue: 0,0:02:40.47,0:02:42.35,Main-207-,,0,0,0,,Ce l'ho fatta!
Dialogue: 0,0:02:42.35,0:02:45.73,Main-207-,,0,0,0,,Luffy, sbrigati! L'orario di \Npartenza è già passato!
Dialogue: 0,0:02:45.73,0:02:47.27,Main-207-,,0,0,0,,Guardate qua!
Dialogue: 0,0:02:47.27,0:02:51.32,Main-207-,,0,0,0,,Eracle! \NCi è voluto un po' per trovarlo!{G personaggi per scrupolo, ma non particolarmente utile. volendo "hercules", in jp lo chiamano herakuresu -angy}
Dialogue: 0,0:02:51.32,0:02:52.69,Main-207-,,0,0,0,,Un coleottero?!
Dialogue: 0,0:02:52.69,0:02:54.07,Main-207-,,0,0,0,,Ma lo stavi cercando?!
Dialogue: 0,0:03:02.66,0:03:05.04,Main-207-,,0,0,0,,Wah! Che figata!
Dialogue: 0,0:03:05.04,0:03:07.83,Main-207-,,0,0,0,,È la Going Merry Flying Model!
Dialogue: 0,0:03:07.83,0:03:09.71,Main-207-,,0,0,0,,Sembra possa volare!{ew}
Dialogue: 0,0:03:09.71,0:03:13.01,Main-207-,,0,0,0,,O no~?! Sono stati loro a farla!
Dialogue: 0,0:03:17.72,0:03:18.72,Main-207-,,0,0,0,,Lasciamoli fare...{idk}
Dialogue: 0,0:03:18.72,0:03:21.47,Main-207-,,0,0,0,,A me solo a vederla fa venire l'ansia.
Dialogue: 0,0:03:21.47,0:03:22.60,Main-207-,,0,0,0,,Beh, in effetti.
Dialogue: 0,0:03:23.22,0:03:26.94,Main-207-,,0,0,0,,Un piccione almeno potrebbe \Nvolare davvero, non come il gallo...{meh, venuta malissimo -angy}
Dialogue: 0,0:03:26.94,0:03:29.73,Main-207-,,0,0,0,,Ma non è mica quello il \Nproblema più grande, brutto idiota!
Dialogue: 0,0:03:29.73,0:03:33.40,Main-207-,,0,0,0,,Forza, facciamo partire la nave! \NSiete pronti, uomini?!
Dialogue: 0,0:03:33.40,0:03:34.74,Main-207-,,0,0,0,,– Uoh!\N– {\i1}Aye, sir{\i0}!
Dialogue: 0,0:03:40.45,0:03:42.95,Main-207-,,0,0,0,,Veloci, salite sulla nave. \NNon c'è tempo.
Dialogue: 0,0:03:42.95,0:03:47.04,Main-207-,,0,0,0,,Volete sprecare l'occasione di \Nandare in cielo, brutti scemi?
Dialogue: 0,0:03:47.46,0:03:49.46,Main-207-,,0,0,0,,Sì! Grazie per la nave!
Dialogue: 0,0:03:53.09,0:03:55.55,Main-207-,,0,0,0,,Ringrazia loro!
Dialogue: 0,0:03:56.26,0:03:58.72,Main-207-,,0,0,0,,Giusto! Grazie!
Dialogue: 0,0:03:58.72,0:04:01.22,Main-207-,,0,0,0,,Vi darò Ercole!
Dialogue: 0,0:04:01.64,0:04:05.73,Main-207-,,0,0,0,,{\q2}– Oh! Sicuro vada bene! Sei davvero un così...\N– Oh! Sicuro vada bene! Sei davvero un così...
Dialogue: 0,0:04:05.73,0:04:08.10,Main-207-,,0,0,0,,– un bravo ragazzo!\N– un bravo ragazzo!
Dialogue: 0,0:04:08.10,0:04:11.31,Main-207-,,0,0,0,,Comunque, sbrighiamoci! Salite sulla \Nnave! Non faremo a tempo!
Dialogue: 0,0:04:11.31,0:04:14.19,Main-207-,,0,0,0,,{\q2}Vi faremo noi da guida, quindi seguiteci!
Dialogue: 0,0:04:14.57,0:04:16.07,Main-207-,,0,0,0,,Luffy, veloce!
Dialogue: 0,0:04:16.07,0:04:17.45,Main-207-,,0,0,0,,Sì!
Dialogue: 0,0:04:23.66,0:04:28.12,Flashbacks-207-,,0,0,0,,{Flashback to Jaya 06 @06:05}Il Paese dell'Oro è frutto \Ndell'immaginazione di Noland.
Dialogue: 0,0:04:29.75,0:04:31.50,Main-207-,,0,0,0,,Forze Alleate Saruyama!
Dialogue: 0,0:04:34.75,0:04:36.46,Main-207-,,0,0,0,,Non fate pasticci!{fesserie?}
Dialogue: 0,0:04:36.96,0:04:41.72,Main-207-,,0,0,0,,Non importa cosa succeda, \Ndate tutto di voi per il loro bene!
Dialogue: 0,0:04:41.72,0:04:43.89,Main-207-,,0,0,0,,– Sì!\N– Sì!
Dialogue: 0,0:04:46.39,0:04:47.89,Main-207-,,0,0,0,,Bene! Andiamo!
Dialogue: 0,0:04:51.77,0:04:53.44,Main-207-,,0,0,0,,Ragazzi, si parte!
Dialogue: 0,0:04:53.44,0:04:54.40,Main-207-,,0,0,0,,Evviva!
Dialogue: 0,0:04:54.40,0:04:56.23,Main-207-,,0,0,0,,Sì, cara Nami~!
Dialogue: 0,0:05:08.41,0:05:11.92,Main-207-,,0,0,0,,Moccioso! Noi ci separiamo qui.
Dialogue: 0,0:05:12.92,0:05:13.96,Main-207-,,0,0,0,,Sì!
Dialogue: 0,0:05:14.71,0:05:18.92,Main-207-,,0,0,0,,{\q2}Solo una cosa. Solo su questo non ci sono dubbi.{ottimisti gli inglesi, ci sta a malapena su una riga}
Dialogue: 0,0:05:18.30,0:05:18.92,Secondary-207-,,0,0,0,,Eh?
Dialogue: 0,0:05:19.55,0:05:25.89,Main-207-,,0,0,0,,{\q2}Nessuno in passato è mai riuscito a dimostrare che\N il Paese dell'Oro e l'Isola nel Cielo esistano davvero.{da abbrevviare, è troppo sui limiti... che odio il 4:3}
Dialogue: 0,0:05:25.89,0:05:26.89,Main-207-,,0,0,0,,Già!
Dialogue: 0,0:05:28.18,0:05:33.94,Main-207-,,0,0,0,,La gente dirà che è non c'è alcuna \Nlogica e riderà, ma che importa?{direbbe che la logica è "assurda"}
Dialogue: 0,0:05:33.94,0:05:36.61,Main-207-,,0,0,0,,È proprio quello il fascino!{l'odio per "roman" al momento, difficile da spiegare... perché romantico/romanticismo non lo usiamo in questo senso noi}
Dialogue: 0,0:05:36.61,0:05:38.07,Main-207-,,0,0,0,,Il fascino, eh?
Dialogue: 0,0:05:40.44,0:05:41.70,Main-207-,,0,0,0,,Esatto!
Dialogue: 0,0:05:45.70,0:05:48.83,Main-207-,,0,0,0,,Grazie... per l'oro.
Dialogue: 0,0:05:50.20,0:05:53.54,Main-207-,,0,0,0,,Voialtri... vedete di \Nnon cadere dal cielo!
Dialogue: 0,0:05:56.00,0:05:57.92,Main-207-,,0,0,0,,Ci si vede, vecchio!{ciao, arrivederci -angy}
Dialogue: 0,0:05:57.92,0:06:00.46,Main-207-,,0,0,0,,Grazie per tutto, signor Cricket!
Dialogue: 0,0:06:00.46,0:06:05.26,Main-207-,,0,0,0,,Mastro! \NIl Paese dell'Oro esiste di sicuro!
Dialogue: 0,0:06:05.26,0:06:08.43,Main-207-,,0,0,0,,Vecchio! Non esagerare!
Dialogue: 0,0:06:08.43,0:06:10.73,Main-207-,,0,0,0,,Fatti gli affari tuoi!
Dialogue: 0,0:06:18.19,0:06:20.40,Main-207-,,0,0,0,,Ormai è mattina!
Dialogue: 0,0:06:20.82,0:06:23.20,Main-207-,,0,0,0,,Allora? Vedete qualcosa?
Dialogue: 0,0:06:23.70,0:06:26.57,Main-207-,,0,0,0,,Non si vede nemmeno \Nl'ombra dell'altra sponda!{idk}
Dialogue: 0,0:06:26.57,0:06:29.66,Main-207-,,0,0,0,,Andranno davvero nell'Isola \Nnel Cielo quei tizi?
Dialogue: 0,0:06:30.16,0:06:32.00,Main-207-,,0,0,0,,Sì, così avevano detto.
Dialogue: 0,0:06:32.00,0:06:36.46,Main-207-,,0,0,0,,Seguirli sarebbe una seccatura. \NSistemiamoli primo che accada.
Dialogue: 0,0:06:37.08,0:06:40.50,Main-207-,,0,0,0,,Ascoltate bene! \NSono le sette di mattina!
Dialogue: 0,0:06:40.50,0:06:45.05,Main-207-,,0,0,0,,Probabilmente arriveremo verso \Nil posto intorno alle undici!{lo chiama "genba" che io l'ho sentito solo in riferimento a scene del crimine, ma non mi pare il caso}
Dialogue: 0,0:06:45.05,0:06:49.51,Main-207-,,0,0,0,,Proprio come ha detto il mastro, \Nla posizione della Knock Up Stream
Dialogue: 0,0:06:49.51,0:06:56.52,Main-207-,,0,0,0,,{\q2}cambia ogni volta! Bisogna arrivare in anticipo\N e cercare con precisione la posizione corretta!
Dialogue: 0,0:06:57.02,0:06:58.77,Main-207-,,0,0,0,,Guardate, guardate!
Dialogue: 0,0:06:58.77,0:07:01.98,Main-207-,,0,0,0,,{\q2}Abbiamo tardato rispetto al previsto, ma...
Dialogue: 0,0:07:01.98,0:07:05.61,Main-207-,,0,0,0,,Ehi! State ascoltando \Nla mia spiegazione?!
Dialogue: 0,0:07:05.61,0:07:07.82,Main-207-,,0,0,0,,Visto, visto, visto?! \NSi è girato davanti!
Dialogue: 0,0:07:08.99,0:07:12.20,Main-207-,,0,0,0,,Ci sono proprio uccelli strani eh...
Dialogue: 0,0:07:12.20,0:07:17.33,Main-207-,,0,0,0,,Guarda davvero solo verso sud! \NÈ come una bussola! Che divertente!
Dialogue: 0,0:07:21.59,0:07:22.67,Main-207-,,0,0,0,,Cos'ha detto?
Dialogue: 0,0:07:23.17,0:07:26.59,Main-207-,,0,0,0,,"Guarderò in una direzione diversa \Ndal sud per mettervi in difficoltà".
Dialogue: 0,0:07:28.26,0:07:29.64,Main-207-,,0,0,0,,Provaci pure!
Dialogue: 0,0:07:32.60,0:07:34.98,Main-207-,,0,0,0,,Oh! Si è girato verso nord!
Dialogue: 0,0:07:43.07,0:07:45.36,Main-207-,,0,0,0,,{\q2}Non riesce a rilassarsi se non guarda a sud!
Dialogue: 0,0:07:45.36,0:07:50.53,Main-207-,,0,0,0,,Ehi, voialtri! Non fate \Narrabbiare il grande boss!
Dialogue: 0,0:07:51.28,0:07:57.00,Main-207-,,0,0,0,,{\q2}Dai, va bene così, va bene così! Anche se\N il loro modo di fare mi fa venire l'ansia!
Dialogue: 0,0:07:57.23,0:07:58.96,Main-207-,,0,0,0,,Cosa? Che c'è?
Dialogue: 0,0:08:00.13,0:08:03.25,Main-207-,,0,0,0,,Beh, non serve a niente agitarsi tanto!
Dialogue: 0,0:08:03.96,0:08:05.67,Main-207-,,0,0,0,,Prendiamocela con calma!
Dialogue: 0,0:08:05.67,0:08:07.93,Main-207-,,0,0,0,,E chi è che ci ha fatto tardare?
Dialogue: 0,0:08:08.43,0:08:13.51,Main-207-,,0,0,0,,Ma anche questo è vero! \NNon serve a niente restare tesi per ore!
Dialogue: 0,0:08:13.51,0:08:18.52,Main-207-,,0,0,0,,Capisco! Bene, uomini! Andiamo \Na tutta velocità senza stressarci!
Dialogue: 0,0:08:21.36,0:08:23.90,Main-207-,,0,0,0,,Ah~! Che bella giornata!
Dialogue: 0,0:08:27.03,0:08:28.49,Main-207-,,0,0,0,,Sicuri vada bene? Ehi.
Dialogue: 0,0:08:28.90,0:08:31.70,Main-207-,,0,0,0,,Boss! Siamo nei guai!
Dialogue: 0,0:08:30.79,0:08:31.70,Secondary-207-,,0,0,0,,Che succede?!
Dialogue: 0,0:08:31.70,0:08:35.16,Main-207-,,0,0,0,,Arriva la notte da sud-ovest! \NÈ il cumulo imperiale!{c'è un ? sul glossario, dunque da vedere(ep di Nikki)-angy}
Dialogue: 0,0:08:35.16,0:08:37.58,Main-207-,,0,0,0,,Davvero?! Che ore sono adesso?!
Dialogue: 0,0:08:37.58,0:08:40.75,Main-207-,,0,0,0,,Le dieci! \NMolto prima di quanto previsto!
Dialogue: 0,0:08:40.75,0:08:43.13,Main-207-,,0,0,0,,Così non va... Shoujou, puoi farcela?!
Dialogue: 0,0:08:43.13,0:08:45.70,Main-207-,,0,0,0,,Utan Divers! Entrate subito in acqua!{nel mare}
Dialogue: 0,0:08:45.70,0:08:47.17,Main-207-,,0,0,0,,Cercate la corrente marina!
Dialogue: 0,0:08:50.30,0:08:52.01,Main-207-,,0,0,0,,Quello è... il cumulo imperiale!
Dialogue: 0,0:08:52.80,0:08:54.39,Main-207-,,0,0,0,,Che c'è? Che c'è?!
Dialogue: 0,0:08:55.51,0:09:00.60,Main-207-,,0,0,0,,{\q2}Il cumulo imperiale sia apparso prima del previsto\N anche se non si sa ancora dov'è la corrente!{ho tagliato un "pare che" all'inizio perché non ci stava a schermo}
Dialogue: 0,0:09:08.32,0:09:12.70,Main-207-,,0,0,0,,{\q2}Ho trovato il riverbero{riflesso?}! Scoperta una \Ncorrente di grandi dimensioni a ore dodici!
Dialogue: 0,0:09:12.70,0:09:16.66,Main-207-,,0,0,0,,Rilevate giganti creature ad ore nove! \NPenso siano Re del Mare!{o singolare, fate voi -angy}
Dialogue: 0,0:09:17.37,0:09:20.62,Main-207-,,0,0,0,,{\q2}A ore dieci le onde vanno contro corrente!
Dialogue: 0,0:09:20.62,0:09:22.67,Main-207-,,0,0,0,,Credo sia un vortice gigantesco!
Dialogue: 0,0:09:22.67,0:09:26.13,Main-207-,,0,0,0,,È quello! Puntate la nave a ore dieci!
Dialogue: 0,0:09:26.13,0:09:29.92,Main-207-,,0,0,0,,{\q2}È un segno che sta per esplodere! \NPrendete il vortice e non tiratevi indietro!
Dialogue: 0,0:09:34.72,0:09:35.85,Main-207-,,0,0,0,,Che succede?!
Dialogue: 0,0:09:35.85,0:09:39.10,Main-207-,,0,0,0,,{\q2}Le onde sono diventate improvvisamente più alte!{anche qua ottimisti gli inglesi a farcela stare in una riga}
Dialogue: 0,0:09:37.54,0:09:39.10,Secondary-207-,,0,0,0,,Affonderemo!
Dialogue: 0,0:09:41.06,0:09:43.94,Main-207-,,0,0,0,,È il presagio dell'esplosione! \NState attenti!
Dialogue: 0,0:09:43.94,0:09:45.56,Main-207-,,0,0,0,,E-Esplosione?!
Dialogue: 0,0:09:46.07,0:09:47.02,Main-207-,,0,0,0,,Signorina navigatrice!
Dialogue: 0,0:09:47.69,0:09:49.24,Main-207-,,0,0,0,,Cosa dice il Log Pose?
Dialogue: 0,0:09:52.07,0:09:53.84,Main-207-,,0,0,0,,Continua a puntare a quella nuvola!
Dialogue: 0,0:09:54.84,0:09:57.49,Main-207-,,0,0,0,,Lassù c'è l'Isola nel Cielo?!
Dialogue: 0,0:09:58.20,0:09:59.79,Main-207-,,0,0,0,,La direzione del vento è perfetta!
Dialogue: 0,0:09:59.79,0:10:02.50,Main-207-,,0,0,0,,Il cumulo imperiale si sta \Ndirigendo al centro del vortice!{cps}
Dialogue: 0,0:10:02.50,0:10:05.92,Main-207-,,0,0,0,,Ehi, che intendi con "vortice"? \NDove sarebbe?
Dialogue: 0,0:10:06.59,0:10:09.76,Main-207-,,0,0,0,,Pare che questa volta ci \Nabbiamo preso, fratello!
Dialogue: 0,0:10:09.76,0:10:13.18,Main-207-,,0,0,0,,Già! E le dimensioni dell'esplosione \Nsembra saranno perfette!
Dialogue: 0,0:10:13.18,0:10:14.55,Main-207-,,0,0,0,,Ce la faremo?
Dialogue: 0,0:10:14.55,0:10:15.97,Main-207-,,0,0,0,,Sì, ce la farete!
Dialogue: 0,0:10:18.06,0:10:18.85,Main-207-,,0,0,0,,Cos'è?
Dialogue: 0,0:10:18.85,0:10:21.14,Main-207-,,0,0,0,,Vi porteremo nel flusso del vortice!
Dialogue: 0,0:10:21.64,0:10:23.56,Main-207-,,0,0,0,,E poi?! Cosa dovremmo fare?!
Dialogue: 0,0:10:23.56,0:10:27.94,Main-207-,,0,0,0,,{\q2}Salite sulla corrente! Se andrete fino in \Nfondo senza opporvi, andrà tutto bene!
Dialogue: 0,0:10:29.40,0:10:31.40,Main-207-,,0,0,0,,Questo enorme vortice...
Dialogue: 0,0:10:36.03,0:10:38.37,Main-207-,,0,0,0,,Non mi era stato detto che\N saremmo stati inghiottiti!{cps}
Dialogue: 0,0:10:38.78,0:10:41.87,Main-207-,,0,0,0,,Va tutto bene! \NNami, Robin, vi proteggo io!{lascio a voi eventuali cara/dolce}
Dialogue: 0,0:10:42.58,0:10:44.54,Main-207-,,0,0,0,,È la prima volta che vedo \Nun vortice così grande!{cps}
Dialogue: 0,0:10:47.42,0:10:50.88,Main-207-,,0,0,0,,Wah! Fermi, fermi! Torniamo indietro! \NFatemi tornare a casa!
Dialogue: 0,0:10:50.88,0:10:54.18,Main-207-,,0,0,0,,Rassegnati, Usopp. È troppo tardi.\N Qualcuno è già salito.{??? sull'ultima}
Dialogue: 0,0:10:54.59,0:10:56.68,Main-207-,,0,0,0,,Andiamo sull'Isola nel Cielo!
Dialogue: 0,0:11:19.33,0:11:20.95,Main-207-,,0,0,0,,Allora ragazzi!
Dialogue: 0,0:11:20.95,0:11:24.96,Main-207-,,0,0,0,,Ora dovrete arrangiarvi \Ncon le vostre forze!
Dialogue: 0,0:11:24.96,0:11:28.08,Main-207-,,0,0,0,,Sì! Grazie per averci portati qui!
Dialogue: 0,0:11:27.33,0:11:28.08,Secondary-207-,,0,0,0,,Aspettate!
Dialogue: 0,0:11:28.58,0:11:32.34,Main-207-,,0,0,0,,Risparmiatemi! Fa paura!
Dialogue: 0,0:11:32.34,0:11:34.26,Main-207-,,0,0,0,,Lasciatemi tornare indietro, bastardi!
Dialogue: 0,0:11:34.26,0:11:36.09,Main-207-,,0,0,0,,Moriremo subito così!
Dialogue: 0,0:11:36.09,0:11:39.51,Main-207-,,0,0,0,,{\q2}Non mi avevate detto di questo \Nenorme vortice! È una truffa, una truffa!
Dialogue: 0,0:11:39.51,0:11:41.06,Main-207-,,0,0,0,,È diventato notte!
Dialogue: 0,0:11:41.06,0:11:44.56,Main-207-,,0,0,0,,{\q2}Il vortice ci sta risucchiando sempre di più!
Dialogue: 0,0:11:44.56,0:11:48.06,Main-207-,,0,0,0,,Torniamo indietro, Luffy! \NFacciamo ancora in tempo!
Dialogue: 0,0:11:48.06,0:11:51.86,Main-207-,,0,0,0,,Dovresti capirlo guardando! Questo \Nvortice è sufficiente per ucciderci!{per morire in realtà}
Dialogue: 0,0:11:51.86,0:11:53.69,Main-207-,,0,0,0,,{\q2}L'Isola nel Cielo è un sogno irrealizzabile!{cps}
Dialogue: 0,0:11:53.69,0:11:56.20,Main-207-,,0,0,0,,Un sogno irrealizzabile?\NHai proprio ragione.
Dialogue: 0,0:11:56.20,0:11:59.53,Main-207-,,0,0,0,,Infatti, Luffy! \NPenso anch'io sia impossibile!
Dialogue: 0,0:11:59.91,0:12:01.91,Main-207-,,0,0,0,,Un isola da sogno irrealizzabile...
Dialogue: 0,0:12:01.91,0:12:05.79,Main-207-,,0,0,0,,{\q2}Se ci lasciamo scappare quest'avventura, \Nce ne pentiremo per sempre!
Dialogue: 0,0:12:06.50,0:12:09.42,Main-207-,,0,0,0,,– S-Sembra divertirsi...\N– S-Sembra divertirsi...
Dialogue: 0,0:12:13.42,0:12:16.22,Main-207-,,0,0,0,,Ehi! Mentre continuate\N a opporvi inutilmente,
Dialogue: 0,0:12:16.22,0:12:17.38,Main-207-,,0,0,0,,"Mentre" cosa?
Dialogue: 0,0:12:20.84,0:12:22.64,Main-207-,,0,0,0,,Il vortice ci sta risucchiando.
Dialogue: 0,0:12:25.06,0:12:28.73,Main-207-,,0,0,0,,Forza, mia cara Nami! \NVieni tra le mie braccia, veloce!
Dialogue: 0,0:12:30.65,0:12:31.79,Main-207-,,0,0,0,,Cadiamo!
Dialogue: 0,0:12:36.36,0:12:38.82,Main-207-,,0,0,0,,Cosa? È scomparso? Ma perché?!
Dialogue: 0,0:12:38.82,0:12:39.91,Main-207-,,0,0,0,,Cos'è successo?
Dialogue: 0,0:12:39.91,0:12:44.83,Main-207-,,0,0,0,,Q-Quell'enorme buco del vortice... \Ndov'è andato?!
Dialogue: 0,0:12:50.71,0:12:54.34,Main-207-,,0,0,0,,No! Sta già iniziando!
Dialogue: 0,0:12:54.34,0:12:55.46,Main-207-,,0,0,0,,Eh?
Dialogue: 0,0:12:56.13,0:12:58.80,Main-207-,,0,0,0,,Il vortice è solo sparito sul fondale!
Dialogue: 0,0:13:00.38,0:13:03.30,Main-207-,,0,0,0,,P-Possibile che....
Dialogue: 0,0:13:03.30,0:13:05.81,Main-207-,,0,0,0,,Aspettate!
Dialogue: 0,0:13:08.85,0:13:09.85,Main-207-,,0,0,0,,Ehi, Zoro!
Dialogue: 0,0:13:10.48,0:13:11.35,Main-207-,,0,0,0,,Quello...
Dialogue: 0,0:13:19.15,0:13:23.62,Main-207-,,0,0,0,,Ti abbiamo raggiunto, \NLuffy Cappello di Paglia!
Dialogue: 0,0:13:24.20,0:13:26.20,Main-207-,,0,0,0,,Quello era a Mock Town!
Dialogue: 0,0:13:28.41,0:13:29.33,Main-207-,,0,0,0,,Ma chi è?
Dialogue: 0,0:13:29.33,0:13:34.29,Main-207-,,0,0,0,,Sono venuto a prendermi la tua \Ntesta da cento milioni! Arrenditi!
Dialogue: 0,0:13:39.59,0:13:42.34,Main-207-,,0,0,0,,Ehi, chi sono quelli? Degli amici?
Dialogue: 0,0:13:43.18,0:13:44.97,Main-207-,,0,0,0,,Chissà, non lo so.
Dialogue: 0,0:13:48.93,0:13:50.77,Main-207-,,0,0,0,,Perché è così buio da queste parti?
Dialogue: 0,0:13:50.77,0:13:53.90,Main-207-,,0,0,0,,La mia testa? \NChe intendi con cento milioni?
Dialogue: 0,0:13:53.90,0:13:56.27,Main-207-,,0,0,0,,Quindi non lo sai, eh?
Dialogue: 0,0:13:56.90,0:14:01.65,Main-207-,,0,0,0,,Sulla tua testa c'è una taglia \Nda cento milioni di berry!
Dialogue: 0,0:14:01.65,0:14:05.95,Main-207-,,0,0,0,,E poi, Zoro il Cacciatore di Pirati... \Nla tua vale sessanta milioni!
Dialogue: 0,0:14:05.95,0:14:08.95,Main-207-,,0,0,0,,È vero! Sono delle nuove taglie!
Dialogue: 0,0:14:08.95,0:14:12.08,Main-207-,,0,0,0,,Zoro! Sei diventato un ricercato!
Dialogue: 0,0:14:12.08,0:14:16.29,Main-207-,,0,0,0,,Cosa?! Ehi, aspetta! E la mia? \NC'è anche la mia, no?!
Dialogue: 0,0:14:16.29,0:14:17.88,Main-207-,,0,0,0,,Ehm... non c'è!
Dialogue: 0,0:14:17.88,0:14:19.38,Main-207-,,0,0,0,,Guarda bene!
Dialogue: 0,0:14:20.01,0:14:20.84,Main-207-,,0,0,0,,Non c'è.
Dialogue: 0,0:14:23.09,0:14:27.01,Main-207-,,0,0,0,,{\q2}Giusto... Dopo quanto successo \Nad Alabasta, la cifra è salita.
Dialogue: 0,0:14:27.01,0:14:28.68,Main-207-,,0,0,0,,Ma cento milioni...
Dialogue: 0,0:14:30.27,0:14:31.77,Main-207-,,0,0,0,,Cento milioni!
Dialogue: 0,0:14:31.77,0:14:34.40,Main-207-,,0,0,0,,Hai sentito?! Io valgo cento milioni!
Dialogue: 0,0:14:34.40,0:14:36.73,Main-207-,,0,0,0,,Sessanta milioni, eh? Troppo poco.{sarebbe non sono contento -angy}
Dialogue: 0,0:14:36.73,0:14:38.69,Main-207-,,0,0,0,,Non rallegratevi laggiù!
Dialogue: 0,0:14:39.90,0:14:43.20,Main-207-,,0,0,0,,Ehi, voialtri! Non distraetevi!
Dialogue: 0,0:14:47.07,0:14:51.16,Main-207-,,0,0,0,,Arriva... la Knock Up Stream!
Dialogue: 0,0:14:51.70,0:14:54.12,Main-207-,,0,0,0,,Preparatevi!
Dialogue: 0,0:14:56.58,0:14:57.46,Main-207-,,0,0,0,,Cosa?
Dialogue: 0,0:14:58.04,0:15:01.00,Main-207-,,0,0,0,,Aggrappatevi tutti alla nave o \Nrifugiatevi sottocoperta!{circa}
Dialogue: 0,0:15:01.00,0:15:07.09,Main-207-,,0,0,0,,La nave... verrà spazzata via!
Dialogue: 0,0:15:44.34,0:15:47.43,Main-207-,,0,0,0,,Oh no! La nave verrà capovolta!
Dialogue: 0,0:15:49.89,0:15:51.85,Main-207-,,0,0,0,,Tenete duro!
Dialogue: 0,0:15:51.85,0:15:53.60,Main-207-,,0,0,0,,Non fatevi sbalzare fuori!
Dialogue: 0,0:15:57.27,0:16:00.44,Main-207-,,0,0,0,,– Andate sull'Isola nel Cielo!\N– Andate sull'Isola nel Cielo!
Dialogue: 0,0:16:02.40,0:16:03.86,Main-207-,,0,0,0,,Ma che succede?!
Dialogue: 0,0:16:03.86,0:16:07.32,Main-207-,,0,0,0,,{\q2}La nave sta correndo \Nperpendicolarmente sulla colonna d'acqua!{ew}
Dialogue: 0,0:16:07.32,0:16:08.36,Main-207-,,0,0,0,,Che divertente!{interessante}
Dialogue: 0,0:16:08.36,0:16:10.37,Main-207-,,0,0,0,,Ma come funziona?!
Dialogue: 0,0:16:12.37,0:16:13.33,Main-207-,,0,0,0,,Il vento!
Dialogue: 0,0:16:13.91,0:16:20.33,Main-207-,,0,0,0,,Bene! Così \Nraggiungeremo il cielo! Vai, Merry!
Dialogue: 0,0:16:22.29,0:16:25.76,Main-207-,,0,0,0,,Aspettate un attimo! \NNon sembra andrà così bene!
Dialogue: 0,0:16:25.76,0:16:27.05,Main-207-,,0,0,0,,C-C-Che succede?!
Dialogue: 0,0:16:27.05,0:16:29.22,Main-207-,,0,0,0,,Che c'è? Hai dimenticato qualcosa?
Dialogue: 0,0:16:29.22,0:16:31.47,Main-207-,,0,0,0,,La nave sta iniziando a staccarsi!{ew}
Dialogue: 0,0:16:31.47,0:16:32.55,Main-207-,,0,0,0,,Eh?!
Dialogue: 0,0:16:32.55,0:16:35.56,Main-207-,,0,0,0,,Di questo passo, \Nfiniremo scaraventati via!
Dialogue: 0,0:16:35.56,0:16:41.31,Main-207-,,0,0,0,,{\q2}P-P-Perché dici così? C-Che dovremmo fare?!\NSiamo a malapena in grado di tenerci!{meh, circa, specie l'ultima}
Dialogue: 0,0:16:41.31,0:16:43.27,Main-207-,,0,0,0,,Ah! Ma cos'è quello?!
Dialogue: 0,0:16:44.32,0:16:45.40,Main-207-,,0,0,0,,Un Re del Mare!
Dialogue: 0,0:16:45.40,0:16:47.61,Main-207-,,0,0,0,,Quello che era stato \Ninghiottito dal vortice?!
Dialogue: 0,0:16:51.91,0:16:55.54,Main-207-,,0,0,0,,Guardate! È solo questione di tempo \Nprima che succeda anche a noi!
Dialogue: 0,0:16:55.54,0:17:01.04,Main-207-,,0,0,0,,{\q2}Ehi, ehi! Puoi dire quello che vuoi, \Nma ormai siamo saliti fin qui con l'esplosione,
Dialogue: 0,0:17:01.04,0:17:02.50,Main-207-,,0,0,0,,quindi non possiamo far nulla da soli.{meh e cps}
Dialogue: 0,0:17:02.50,0:17:05.46,Main-207-,,0,0,0,,Quindi è davvero solo \Nun disastro naturale?!
Dialogue: 0,0:17:07.84,0:17:09.80,Main-207-,,0,0,0,,Stanno cadendo un sacco di cose!
Dialogue: 0,0:17:10.34,0:17:13.47,Main-207-,,0,0,0,,Sono vittime della Knock Up Stream!
Dialogue: 0,0:17:13.47,0:17:18.52,Main-207-,,0,0,0,,È la fine anche per noi! Cadremo tutti \Nin mare, ci schianteremo e moriremo!
Comment: 0,0:17:20.98,0:17:22.81,Main-207-,,0,0,0,,
Dialogue: 0,0:17:20.98,0:17:22.81,Main-207-,,0,0,0,,Spiegate le vele immediatamente!
Dialogue: 0,0:17:23.48,0:17:27.94,Main-207-,,0,0,0,,{\q2}Questo è il mare! Non è solo una colonna\N d'acqua! È una corrente che sale!{lasciate che sale, usa dopo la terminologia giusta}
Dialogue: 0,0:17:27.94,0:17:30.24,Main-207-,,0,0,0,,E il vento che soffia dal basso...
Dialogue: 0,0:17:30.24,0:17:33.53,Main-207-,,0,0,0,,{\q2}crea una corrente ascensionale grazie \Nall'energia geotermica e all'esplosione del vapore!{booooooooooooooh e cps grave}
Dialogue: 0,0:17:34.07,0:17:36.83,Main-207-,,0,0,0,,Se gli avversari sono il vento \Ne il mare, navigherò!{ew}
Dialogue: 0,0:17:37.20,0:17:39.25,Main-207-,,0,0,0,,Chi è la navigatrice di questa nave?
Dialogue: 0,0:17:41.04,0:17:43.25,Main-207-,,0,0,0,,Sei tu, cara Nami!{circa}
Dialogue: 0,0:17:43.25,0:17:46.38,Main-207-,,0,0,0,,Ehi, uomini! \NFate subito come dice Nami!
Dialogue: 0,0:17:46.38,0:17:47.71,Main-207-,,0,0,0,,– Sì!\N– Sì!
Dialogue: 0,0:17:47.71,0:17:51.68,Main-207-,,0,0,0,,{\q2}Prendete il vento da tribordo e girate il timone \Na babordo! Allineate la nave alla corrente!{boh e cps}
Dialogue: 0,0:17:51.68,0:17:52.38,Main-207-,,0,0,0,,– {\i1}Yessir{\i0}!\N– {\i1}Yessir{\i0}!
Dialogue: 0,0:17:54.39,0:17:57.35,Main-207-,,0,0,0,,Wah! Oddio! La nave si sta \Nallontanando dall'acqua!
Dialogue: 0,0:17:57.76,0:18:00.81,Main-207-,,0,0,0,,Cadremo! Cadremo, Nami! \NFa' qualcosa, Nami!
Dialogue: 0,0:18:00.81,0:18:02.77,Main-207-,,0,0,0,,No, ce la faremo!
Dialogue: 0,0:18:06.48,0:18:08.15,Main-207-,,0,0,0,,Stiamo volando!
Dialogue: 0,0:18:10.36,0:18:13.07,Main-207-,,0,0,0,,Che figata! \NLa nave sta volando nel cielo!
Dialogue: 0,0:18:13.57,0:18:14.45,Main-207-,,0,0,0,,Sul serio?!
Dialogue: 0,0:18:17.16,0:18:18.37,Main-207-,,0,0,0,,Ce l'ho fatta!
Dialogue: 0,0:18:18.37,0:18:19.79,Main-207-,,0,0,0,,Eeh.
Dialogue: 0,0:18:19.79,0:18:22.21,Main-207-,,0,0,0,,Mia cara Nami sei magnifica!
Dialogue: 0,0:18:22.91,0:18:25.67,Main-207-,,0,0,0,,E poi... ti amo!{solo perché è Sanji. suki è più un mi piaci che un ti amo}
Dialogue: 0,0:18:26.29,0:18:30.59,Thoughts-207-,,0,0,0,,Andate! Verso i confini di \Nun sogno inesplorato!{ew}
Dialogue: 0,0:18:35.51,0:18:37.97,Main-207-,,0,0,0,,Andate!
Dialogue: 0,0:18:38.43,0:18:42.39,Main-207-,,0,0,0,,Una volta capiti il vento e la corrente,\N possiamo salire ovunque!{ew}
Dialogue: 0,0:18:42.98,0:18:46.15,Main-207-,,0,0,0,,Ehi, Nami! Stiamo arrivando \Nsull'Isola nel Cielo?!
Dialogue: 0,0:18:46.61,0:18:49.51,Main-207-,,0,0,0,,Se c'è, è oltre a quella nuvola!
Dialogue: 0,0:18:51.03,0:18:52.36,Main-207-,,0,0,0,,Sopra la nuvola, eh?
Dialogue: 0,0:18:52.64,0:18:55.32,Main-207-,,0,0,0,,Cosa ci sarà lassù?
Dialogue: 0,0:18:55.70,0:18:58.37,Main-207-,,0,0,0,,Sfondiamo oltre il cumulo imperiale!
Comment: 0,0:00:00.00,0:00:00.00,Main-207-,,0,0,0,,{=40}===============================DIALOGUE============================
