Comment: 0,0:00:00.00,0:00:00.00,Main-207+,,0,0,0,,{=8}===============================DIALOGUE============================
Dialogue: 0,0:00:06.36,0:00:08.45,Narrator-207+,,0,0,0,,Rikkaus, maine, valta...
Dialogue: 0,0:00:08.45,0:00:12.62,Narrator-207+,,0,0,0,,"Merirosvokuningas" Gold Roger\Nsaavutti ne kaikki.
Dialogue: 0,0:00:12.62,0:00:16.62,Narrator-207+,,0,0,0,,Hänen viimeiset sanansa ajoivat \Nvaltavan määrän ihmisiä merille.
Dialogue: 0,0:00:16.62,0:00:18.50,Flashbacks-207+,,0,0,0,,{\an8}Aarteeniko?
Dialogue: 0,0:00:18.50,0:00:20.25,Flashbacks-207+,,0,0,0,,{\an8}Sen kun otatte.
Dialogue: 0,0:00:20.25,0:00:21.25,Flashbacks-207+,,0,0,0,,{\an8}Sopii etsiä!
Dialogue: 0,0:00:21.25,0:00:24.46,Flashbacks-207+,,0,0,0,,{\an8}Siinä on koko maailman rikkaudet.
Dialogue: 0,0:00:24.46,0:00:29.13,Narrator-207+,,0,0,0,,Ihmiset suuntasivat kohti Grand Linea\Nunelmiensa perässä.
Dialogue: 0,0:00:29.13,0:00:31.97,Narrator-207+,,0,0,0,,Se oli alku merirosvojen ajalle!
Dialogue: 0,0:00:33.30,0:00:34.22,Narrator-207+,,0,0,0,,Mutta silti...
Dialogue: 0,0:00:43.44,0:00:44.40,Main-207+,,0,0,0,,Ei täältä näe!
Dialogue: 0,0:00:44.40,0:00:45.11,Main-207+,,0,0,0,,Älä tuupi!
Dialogue: 0,0:00:45.11,0:00:45.69,Main-207+,,0,0,0,,– Nyt loppu!\N– Nyt loppu!
Dialogue: 0,0:00:45.69,0:00:47.86,Main-207+,,0,0,0,,Viekää nämä pois tukkimasta ja sassiin!
Dialogue: 0,0:00:46.44,0:00:47.86,Secondary-207+,,0,0,0,,Jumissako ne ovat?!
Dialogue: 0,0:00:51.07,0:00:52.07,Main-207+,,0,0,0,,Olen helvetissä.
Dialogue: 0,0:00:52.07,0:00:52.57,Main-207+,,0,0,0,,Perhana!
Dialogue: 0,0:00:52.57,0:00:53.45,Main-207+,,0,0,0,,Mikä fiasko!
Dialogue: 0,0:00:53.45,0:00:54.37,Main-207+,,0,0,0,,Jo alkaa riittää...
Dialogue: 0,0:00:54.37,0:00:56.74,Main-207+,,0,0,0,,Pahuksen piraatit...
Dialogue: 0,0:00:56.74,0:01:03.96,Narrator-207+,,0,0,0,,{\q2\fad(0,1480)}Edes tällaisena aikana useimpien unelmiin\Nei kuulu merirosvous tai One Piecen etsiminen.
Dialogue: 0,0:01:04.17,0:01:06.63,Narrator-207+,,0,0,0,,Niin, juuri kuten näiden henkilöiden...
Dialogue: 0,0:01:13.72,0:01:15.22,Thoughts-207+,,0,0,0,,"Arvon Nami,
Dialogue: 0,0:01:15.22,0:01:17.64,Thoughts-207+,,0,0,0,,olet erityislaatuinen merirosvo.
Dialogue: 0,0:01:17.64,0:01:20.56,Thoughts-207+,,0,0,0,,Nykymaailmassa valtaa pitävät\Nsellaiset moukat,
Dialogue: 0,0:01:20.56,0:01:23.73,Thoughts-207+,,0,0,0,,joille pirunmarjat ja raaka voima\Novat kaikki kaikessa.
Dialogue: 0,0:01:24.52,0:01:28.03,Thoughts-207+,,0,0,0,,Mutta sinä päihität heidät\Nälylläsi ja nokkeluudellasi!
Dialogue: 0,0:01:28.03,0:01:31.07,Thoughts-207+,,0,0,0,,Nami, olet minun toivoni!"
Dialogue: 0,0:01:31.07,0:01:32.91,Main-207+,,0,0,0,,Hei! Toimitus vietävänä!
Dialogue: 0,0:01:32.91,0:01:36.95,Thoughts-207+,,0,0,0,,"Toivottavasti pystyt tästedes\Njatkamaan mahtavia seikkailujasi!"
Dialogue: 0,0:01:36.95,0:01:37.74,Main-207+,,0,0,0,,Toimitus!
Dialogue: 0,0:01:37.74,0:01:39.87,Main-207+,,0,0,0,,Jukra! Koputtaisitko joskus?!
Dialogue: 0,0:01:39.87,0:01:44.00,Main-207+,,0,0,0,,Mihinkäs lasit jäivät, nuori neiti?\NSatutat vielä itsesi tätä kuljettaessa.
Dialogue: 0,0:01:44.00,0:01:45.88,Main-207+,,0,0,0,,En ehdi. On muita kiireitä.
Dialogue: 0,0:01:45.88,0:01:46.84,Main-207+,,0,0,0,,Mitäh...?!
Dialogue: 0,0:01:46.84,0:01:49.96,Main-207+,,0,0,0,,Olen lähtemässä elämäni\Nsuurimpaan seikkailuun!
Dialogue: 0,0:01:50.47,0:01:51.05,Main-207+,,0,0,0,,Heippa!
Dialogue: 0,0:01:51.05,0:01:51.88,Main-207+,,0,0,0,,Kuules nyt.
Dialogue: 0,0:01:51.88,0:01:54.09,Main-207+,,0,0,0,,Eivät ihmiset yksinään pärjää.
Dialogue: 0,0:01:54.09,0:01:58.60,Main-207+,,0,0,0,,{\q2}Vihanneskauppiaan pojat tukevat\Nvanhempiansa ja saivat vielä ylennyksenkin!
Dialogue: 0,0:01:58.60,0:02:02.02,Main-207+,,0,0,0,,Minussa ja niissä karpaaseissa\Nei ole mitään yhteistä!
Dialogue: 0,0:02:02.02,0:02:04.90,Main-207+,,0,0,0,,Niinpä, ei lainkaan!\N{\i1}He{\i0} työskentelevät ahkerasti, kun–
Dialogue: 0,0:02:05.98,0:02:09.57,Main-207+,,0,0,0,,Olivat kuulemma vailla vertaa\Ntaistelussa maailman huipulla!
Dialogue: 0,0:02:12.03,0:02:13.49,Main-207+,,0,0,0,,Tekee mieli ottaa loparit...
Dialogue: 0,0:02:13.49,0:02:14.91,Main-207+,,0,0,0,,Peräännymmekö toistaiseksi?
Dialogue: 0,0:02:14.91,0:02:16.82,Main-207+,,0,0,0,,Ei! Kiertäkää te toista reittiä edeltä.
Dialogue: 0,0:02:16.82,0:02:17.66,Main-207+,,0,0,0,,Selvä!
Dialogue: 0,0:02:20.62,0:02:21.83,Main-207+,,0,0,0,,Isoveli!
Dialogue: 0,0:02:22.33,0:02:24.58,Main-207+,,0,0,0,,Mikäs taktiikka tuon kuuluu olla?
Dialogue: 0,0:02:27.46,0:02:30.21,Main-207+,,0,0,0,,Tämän vuoksi et etene\Nuralla minun tahtiini.
Dialogue: 0,0:02:30.88,0:02:33.26,Main-207+,,0,0,0,,Höllentäisit vähän!
Dialogue: 0,0:02:43.94,0:02:47.06,Main-207+,,0,0,0,,Kukas muukaan kuin\NDracule Mihawk tietenkin!
Dialogue: 0,0:02:47.06,0:02:49.94,Main-207+,,0,0,0,,Näin ne haukansilmät niin läheltä,\Njoten olen vuorenvarma!
Dialogue: 0,0:02:49.94,0:02:51.57,Main-207+,,0,0,0,,Kukkaismiekkain Vista se on.
Dialogue: 0,0:02:51.57,0:02:52.57,Main-207+,,0,0,0,,Ehei.
Dialogue: 0,0:02:52.57,0:02:55.07,Main-207+,,0,0,0,,Maailman mahtavin miekkamies\Non Roronoa Zoro!
Dialogue: 0,0:02:55.07,0:02:56.20,Main-207+,,0,0,0,,Roronoa?
Dialogue: 0,0:02:56.20,0:02:58.57,Main-207+,,0,0,0,,Eikös se jo heittänyt veivinsä?
Dialogue: 0,0:02:58.57,0:02:59.33,Main-207+,,0,0,0,,Niinhän?
Dialogue: 0,0:02:59.33,0:02:59.95,Main-207+,,0,0,0,,Elää se.
Dialogue: 0,0:02:59.95,0:03:00.58,Main-207+,,0,0,0,,Kuollutpas.
Dialogue: 0,0:03:00.58,0:03:01.74,Main-207+,,0,0,0,,Hengissä se on!
Dialogue: 0,0:03:01.74,0:03:03.00,Main-207+,,0,0,0,,Se on kuollut!
Dialogue: 0,0:03:03.00,0:03:06.00,Main-207+,,0,0,0,,Niin lehdessä luki!\NSiinä sanottiin sen olevan mennyttä!
Dialogue: 0,0:03:06.00,0:03:08.00,Main-207+,,0,0,0,,Hei! Täällä ei ilmaiseksi lueskella.
Dialogue: 0,0:03:08.00,0:03:08.75,Main-207+,,0,0,0,,Se on Afro!
Dialogue: 0,0:03:08.75,0:03:10.25,Main-207+,,0,0,0,,Mene hiiteen, Afro!
Dialogue: 0,0:03:10.25,0:03:11.63,Main-207+,,0,0,0,,Pirun nulikat...!
Dialogue: 0,0:03:12.92,0:03:15.51,Main-207+,,0,0,0,,{\i1}Kyborgilaivapuuseppä Franky!
Dialogue: 0,0:03:15.51,0:03:20.51,Main-207+,,0,0,0,,{\i1}Kaivamme esiin totuuden hänen\Nkatoamisestaan kaksi vuotta sitten!
Dialogue: 0,0:03:21.01,0:03:22.01,Main-207+,,0,0,10,,Franky?
Dialogue: 0,0:03:22.01,0:03:25.14,Main-207+,,0,0,10,,{\q2}Tjaa... Kysykääpä ehkä laivanrakennusalueelta?
Dialogue: 0,0:03:25.14,0:03:27.40,Main-207+,,0,0,10,,{\q2}Kysykää moista herra Iceburgilta!
Dialogue: 0,0:03:27.40,0:03:28.98,Main-207+,,0,0,10,,Vain ajanvarauksella, kiitos.
Dialogue: 0,0:03:30.11,0:03:31.65,Main-207+,,0,0,0,,{\i1}Olimme umpikujassa.
Dialogue: 0,0:03:31.65,0:03:37.03,Main-207+,,0,0,0,,{\i1}Mutta onnistuimme nappaamaan kuvan\NFrankyn upeista piirteistä!
Dialogue: 0,0:03:38.45,0:03:39.49,Main-207+,,0,0,0,,{\i1}Mitä he–
Dialogue: 0,0:03:40.49,0:03:41.99,Main-207+,,0,0,0,,Kuka tätä moskaa lukee...
Dialogue: 0,0:03:41.99,0:03:43.24,Main-207+,,0,0,0,,Niinpä.
Dialogue: 0,0:03:49.79,0:03:53.25,Thoughts-207+,,0,0,0,,"Ai niin, Nami, huomasin toki myös kapteeni Luffyn viestin!
Dialogue: 0,0:03:53.25,0:03:57.34,Thoughts-207+,,0,0,0,,'{\s1}3D{\s0}2Y'! Se julkaistiin sanomalehdessäkin!
Dialogue: 0,0:03:57.97,0:04:02.10,Thoughts-207+,,0,0,0,,Tiesin myös, että sen oli tarkoitus\Nhuiputtaa merivoimia!
Dialogue: 0,0:04:02.72,0:04:04.97,Thoughts-207+,,0,0,0,,Sen kertoi Luffyn kellonsoittojen määrä!
Dialogue: 0,0:04:04.97,0:04:09.02,Thoughts-207+,,0,0,0,,Luku viittasi nokkelasti Sabaodyn\Nmerimakkaroiden kutuaikaan!
Dialogue: 0,0:04:09.02,0:04:11.40,Thoughts-207+,,0,0,0,,Ja sen aika on juuri tänään!
Dialogue: 0,0:04:11.40,0:04:16.53,Thoughts-207+,,0,0,0,,Olkihattupiraattien jälleentapaaminen\NSabaody-saarilla koittaa tänään!
Dialogue: 0,0:04:16.53,0:04:22.16,Thoughts-207+,,0,0,0,,Niinpä tiesin odottaa teitä satamassa\Njotta saisit vastaan kirjeeni!
Dialogue: 0,0:04:28.92,0:04:32.79,Main-207+,,0,0,0,,Eihän tällaista tungosta\Ntäällä yleensä ole...
Dialogue: 0,0:04:33.92,0:04:35.92,Main-207+,,0,0,0,,Varasuunnitelman aika siis!
Dialogue: 0,0:04:39.38,0:04:39.88,Main-207+,,0,0,0,,Pahoit–
Dialogue: 0,0:04:40.38,0:04:42.76,Main-207+,,0,0,0,,K-Kallo murtuu...
Dialogue: 0,0:04:42.76,0:04:44.14,Main-207+,,0,0,0,,Olet kalsiumin tarpeessa.
Dialogue: 0,0:04:44.14,0:04:47.64,Main-207+,,0,0,0,,Pitäisi hörppiä maitoa niin paljon\Nettä täytyy luu-tuta lattia!
Dialogue: 0,0:04:47.64,0:04:50.14,Main-207+,,0,0,0,,Oliko toi skull joke? Eikä!
Dialogue: 0,0:04:50.14,0:04:52.02,Main-207+,,0,0,0,,Mikä teitä vaivaa?!
Dialogue: 0,0:04:53.11,0:04:54.52,Main-207+,,0,0,0,,Olen tyhjäntoimittaja...
Dialogue: 0,0:04:54.52,0:04:56.23,Main-207+,,0,0,0,,Huoneeni pursuaa fanituotteita...
Dialogue: 0,0:04:56.23,0:04:58.11,Main-207+,,0,0,0,,Suuta soukemmalle!
Dialogue: 0,0:04:56.23,0:04:57.86,Secondary-207+,,0,0,0,,Ostan aina sama rihkamaa...
Dialogue: 0,0:04:57.86,0:04:58.11,Secondary-207+,,0,0,0,,En kuuntele muita biisejä...
Dialogue: 0,0:04:58.11,0:05:01.82,Main-207+,,0,0,0,,{\q2}Lähtiköhän hän edes oikean laivan suuntaan...
Dialogue: 0,0:04:58.11,0:05:01.82,Secondary-207+,,0,0,0,,En kuuntele muita biisejä...
Dialogue: 0,0:05:01.82,0:05:03.20,Main-207+,,0,0,0,,Zoro on elossa.
Dialogue: 0,0:05:03.20,0:05:06.95,Main-207+,,0,0,0,,Se on satavarmasti vahvistumassa\Njossain päin maailmaa!
Dialogue: 0,0:05:06.95,0:05:08.33,Main-207+,,0,0,0,,Ohihuhheihhauh!
Dialogue: 0,0:05:08.33,0:05:09.33,Main-207+,,0,0,0,,Että mitä?
Dialogue: 0,0:05:09.33,0:05:10.21,Main-207+,,0,0,0,,Ohitusleikkaus.
Dialogue: 0,0:05:10.21,0:05:12.08,Main-207+,,0,0,0,,Eikä!
Dialogue: 0,0:05:10.96,0:05:12.08,Secondary-207+,,0,0,0,,Pilkkaako teette?
Dialogue: 0,0:05:12.08,0:05:13.58,Main-207+,,0,0,0,,Miksi se aina jäystää miekkaa?
Dialogue: 0,0:05:13.58,0:05:15.46,Main-207+,,0,0,0,,Kaksikin riittäisi!
Dialogue: 0,0:05:15.46,0:05:16.34,Main-207+,,0,0,0,,Hahhah...
Dialogue: 0,0:05:16.34,0:05:16.96,Main-207+,,0,0,0,,Täh?
Dialogue: 0,0:05:16.96,0:05:17.59,Main-207+,,0,0,0,,Sammal.
Dialogue: 0,0:05:17.59,0:05:18.59,Main-207+,,0,0,0,,Että kuinka?!
Dialogue: 0,0:05:18.59,0:05:20.22,Main-207+,,0,0,0,,Äijän kuontalo on sammalta!
Dialogue: 0,0:05:24.35,0:05:26.47,Main-207+,,0,0,0,,Mistäs {\i1}se{\i0} oikein suuttui?
Dialogue: 0,0:05:26.89,0:05:29.06,Main-207+,,0,0,0,,Tuo ei ole mikä tahansa kortti.
Dialogue: 0,0:05:29.06,0:05:32.23,Main-207+,,0,0,0,,Se on avain Sabaodyn\Nturvaamiseen tulevaisuudessa.
Dialogue: 0,0:05:32.23,0:05:33.98,Main-207+,,0,0,0,,Toimita se ripeästi.
Dialogue: 0,0:05:33.98,0:05:35.61,Main-207+,,0,0,0,,Käsittele sitä varoen.
Dialogue: 0,0:05:35.61,0:05:37.48,Main-207+,,0,0,0,,Mitä käy jos se sattuu tippumaan?
Dialogue: 0,0:05:38.99,0:05:40.36,Main-207+,,0,0,0,,En pudota sitä!
Dialogue: 0,0:05:41.86,0:05:43.49,Main-207+,,0,0,0,,Miten karmiva kaveri.
Dialogue: 0,0:05:43.49,0:05:45.70,Main-207+,,0,0,0,,Miksi ihmeessä vinoilisit hänen edessä?!
Dialogue: 0,0:05:45.70,0:05:51.50,Main-207+,,0,0,0,,{\q2}Taistelussa maailman huipulla hän kannatteli\Nyksin jäälohkaretta joka oli murskaamassa laivamme.
Dialogue: 0,0:05:51.50,0:05:56.75,Main-207+,,0,0,0,,"Aaltojen hyvänsuopa kuningas"\Non epäilemättä vankka ja sisukas!{Reference to 仁王 (Niō) in Japanese: https://en.wikipedia.org/wiki/Nio_(Buddhism)}
Dialogue: 0,0:05:58.63,0:06:00.13,Thoughts-207+,,0,0,0,,Miten söpö!
Dialogue: 0,0:06:00.55,0:06:03.63,Thoughts-207+,,0,0,0,,Kauhistus! Hänen suloisuutensa\Nällistyttää joka kerta.
Dialogue: 0,0:06:03.63,0:06:07.35,Thoughts-207+,,0,0,0,,Mutta Chopper on merirosvo\Nkun taas minä olen merisotilas...
Dialogue: 0,0:06:07.35,0:06:09.02,Thoughts-207+,,0,0,0,,Olemme täydet vastakohdat...!
Dialogue: 0,0:06:09.35,0:06:12.73,Thoughts-207+,,0,0,0,,Mutta en ikinä kykenisi\Nottamaan sinua kiinni!
Dialogue: 0,0:06:13.60,0:06:14.23,Main-207+,,0,0,0,,Päivää.
Dialogue: 0,0:06:14.23,0:06:18.32,Main-207+,,0,0,0,,{\i1}Mitenkäs on uuden\Nantipiraattiaseen avainkortin laita?
Dialogue: 0,0:06:18.32,0:06:20.53,Main-207+,,0,0,0,,Se on paraikaa miehen matkassa.
Dialogue: 0,0:06:20.53,0:06:25.32,Main-207+,,0,0,0,,{\i1}Jos koe onnistuu, voimme tyystin\Nhävittää kaikki piraatit Sabaodylta!
Dialogue: 0,0:06:25.32,0:06:27.07,Main-207+,,0,0,0,,{\i1}Sinulla on luottamukseni.
Dialogue: 0,0:06:28.83,0:06:30.95,Thoughts-207+,,0,0,0,,Voi, Chopper...
Dialogue: 0,0:06:30.95,0:06:33.04,Thoughts-207+,,0,0,0,,Missä lienet...
Dialogue: 0,0:06:33.92,0:06:35.71,Thoughts-207+,,0,0,0,,Mikä ihmeen otus...?
Dialogue: 0,0:06:35.71,0:06:37.88,Main-207+,,0,0,0,,"Franky-spesiaali"?! Upeaa!
Dialogue: 0,0:06:37.88,0:06:40.71,Thoughts-207+,,0,0,0,,Ai jaa... Onko toi robotti kuuluisa tai jotain?
Dialogue: 0,0:06:38.29,0:06:40.71,Secondary-207+,,0,0,0,,"Frankyn anatomia"...
Dialogue: 0,0:06:40.71,0:06:42.21,Main-207+,,0,0,0,,Onko hän kunnossa?!
Dialogue: 0,0:06:42.21,0:06:44.51,Main-207+,,0,0,0,,Hirveää!
Dialogue: 0,0:06:47.22,0:06:48.55,Main-207+,,0,0,0,,Ei sekään sitä ostanut.
Dialogue: 0,0:06:48.55,0:06:50.93,Main-207+,,0,0,0,,Jätit avaimen kiinni takaoven lukkoon!
Dialogue: 0,0:06:51.56,0:06:52.68,Main-207+,,0,0,0,,Ja toissa päivänä...
Dialogue: 0,0:06:55.85,0:06:58.48,Thoughts-207+,,0,0,0,,Synkistelin puoli tuntia!
Dialogue: 0,0:06:58.48,0:07:01.23,Thoughts-207+,,0,0,0,,Jos myöhästyn, koittaa maailmanloppu!
Dialogue: 0,0:07:00.40,0:07:01.23,Secondary-207+,,0,0,0,,{\an8}Hupsis.
Dialogue: 0,0:07:01.23,0:07:01.98,Main-207+,,0,0,0,,Antee–
Dialogue: 0,0:07:02.74,0:07:04.36,Thoughts-207+,,0,0,0,,Pikkuveli-vihanneskauppias!
Dialogue: 0,0:07:07.16,0:07:08.12,Main-207+,,0,0,0,,Huhhuh!
Dialogue: 0,0:07:08.12,0:07:10.49,Main-207+,,0,0,0,,En jaksaisi törmätä tuohon maanvaivaan...
Dialogue: 0,0:07:11.12,0:07:11.70,Main-207+,,0,0,0,,Hetkonen...!
Dialogue: 0,0:07:11.70,0:07:14.62,Main-207+,,0,0,0,,Ehei. Ei koskaan pudonnut...
Dialogue: 0,0:07:15.00,0:07:16.08,Main-207+,,0,0,0,,Tuohan on minun–
Dialogue: 0,0:07:18.54,0:07:20.92,Main-207+,,0,0,0,,Aijai...!
Dialogue: 0,0:07:20.92,0:07:24.30,Main-207+,,0,0,0,,Miten epätasaista tämä maa onkaan.
Dialogue: 0,0:07:24.30,0:07:25.42,Main-207+,,0,0,0,,Sinä...!
Dialogue: 0,0:07:34.06,0:07:34.93,Main-207+,,0,0,0,,Siirrä tavarasi.
Dialogue: 0,0:07:39.40,0:07:43.48,Main-207+,,0,0,0,,Kaltaisesi pikku itikan kuuluisi\Npysyä poissa muiden silmistä.
Dialogue: 0,0:07:54.83,0:07:56.00,Main-207+,,0,0,0,,Hei, oliko tämä...?
Dialogue: 0,0:08:00.13,0:08:02.63,Main-207+,,0,0,0,,Vohou! M-Mikä hätänä? Kirpaiseeko?!
Dialogue: 0,0:08:02.63,0:08:05.63,Main-207+,,0,0,0,,Ei, on vaan ollut rankka päivä...
Dialogue: 0,0:08:05.63,0:08:09.14,Main-207+,,0,0,0,,Merisotilas nappasi kirjeeni, ja...
Dialogue: 0,0:08:09.14,0:08:12.01,Main-207+,,0,0,0,,Kuljin juuri äskettäin sellaisen kaverin ohi.
Dialogue: 0,0:08:12.01,0:08:12.76,Main-207+,,0,0,0,,M-Mitäh?!
Dialogue: 0,0:08:12.76,0:08:14.68,Main-207+,,0,0,0,,Se meni tuonne päin.
Dialogue: 0,0:08:19.48,0:08:22.57,Main-207+,,0,0,0,,Okei, annapa kun opetan\Nsinulle taikalauseen.
Dialogue: 0,0:08:22.57,0:08:24.03,Main-207+,,0,0,0,,Valmiina?
Dialogue: 0,0:08:24.03,0:08:26.78,Main-207+,,0,0,0,,"Odottelen jotakuta,\Njoten vain vettä, kiitos!"
Dialogue: 0,0:08:26.78,0:08:28.49,Main-207+,,0,0,0,,...joten vain vettä, kiitos!
Dialogue: 0,0:08:28.49,0:08:30.36,Main-207+,,0,0,0,,Ala vetään, kersa!
Dialogue: 0,0:08:30.36,0:08:32.49,Main-207+,,0,0,0,,{\q2}Keltanokkako olet?! Valkoparta oli mahtavin!
Dialogue: 0,0:08:32.49,0:08:34.99,Main-207+,,0,0,0,,Ei se miekkamies ollut,\Nse käytti {\i1}naginataa{\i0}!
Dialogue: 0,0:08:34.99,0:08:37.12,Main-207+,,0,0,0,,Se on Mihawk! Ihan ite näin!
Dialogue: 0,0:08:37.12,0:08:38.87,Main-207+,,0,0,0,,Näit hänen "haukansilmät". Niinpä niin.
Dialogue: 0,0:08:38.87,0:08:41.21,Main-207+,,0,0,0,,Ikiomin silmin!
Dialogue: 0,0:08:41.58,0:08:43.21,Main-207+,,0,0,0,,Olette ihan kuutamolla.
Dialogue: 0,0:08:43.21,0:08:44.80,Main-207+,,0,0,0,,Mahtavin on...
Dialogue: 0,0:08:44.80,0:08:45.84,Main-207+,,0,0,0,,Akainu, tietenkin.
Dialogue: 0,0:08:45.84,0:08:47.84,Main-207+,,0,0,0,,{\q2}– Puhutaan mahtavimmasta {\i1}miekkamiehestä{\i0}!\N– Puhutaan mahtavimmasta {\i1}miekkamiehestä{\i0}!
Dialogue: 0,0:08:47.84,0:08:49.88,Main-207+,,0,0,0,,Ei noilla ole silmää tällaiseen...
Dialogue: 0,0:08:49.88,0:08:53.22,Main-207+,,0,0,0,,Sen on oltava Zoro jos potentiaali\Notetaan huomioon, eikö?
Dialogue: 0,0:08:53.22,0:08:56.22,Main-207+,,0,0,0,,Miten voitte puhua Leväpäästä\Nmainitsematta Mustajalkaa?
Dialogue: 0,0:08:47.84,0:08:50.09,Secondary-207+,,0,0,0,,{\an8}Selvästi se on Mustaparta\Nkun äijä kaatoi Valkoparran!
Dialogue: 0,0:08:50.09,0:08:52.68,Secondary-207+,,0,0,0,,{\an8}Aina sä vaan menet\N"parta sitä" ja "parta tätä"!
Dialogue: 0,0:08:52.68,0:08:55.14,Secondary-207+,,0,0,0,,{\an8}Keisarin on oltava kaapparilordia\Nmahtavampi! Punatukka se on!
Dialogue: 0,0:08:55.14,0:08:56.22,Secondary-207+,,0,0,0,,{\an8}Elikä Buggy-klovni...?!
Dialogue: 0,0:08:59.35,0:09:00.10,Main-207+,,0,0,0,,Ei tuu kesää!
Dialogue: 0,0:09:00.10,0:09:01.73,Main-207+,,0,0,0,,Sen palkkio on Zoroa pienempi!
Dialogue: 0,0:09:01.73,0:09:04.48,Main-207+,,0,0,0,,{\i1}Tämäkö{\i0} on muka maailman mahtavin?!
Dialogue: 0,0:09:08.36,0:09:10.99,Main-207+,,0,0,0,,Mistäs {\i1}se{\i0} oikein suuttui?
Dialogue: 0,0:09:11.74,0:09:14.08,Main-207+,,0,0,0,,{\an8}Ottakaa iisisti, muuten\Ntämä ei koskaan ratkea.
Dialogue: 0,0:09:14.08,0:09:16.45,Main-207+,,0,0,0,,{\an8}Kavennetaan vaihtoehdot\Nnuoriin tulokkaisiin.
Dialogue: 0,0:09:15.08,0:09:16.45,Main-207+,,0,0,0,,Kas niin!
Dialogue: 0,0:09:16.45,0:09:17.75,Main-207+,,0,0,0,,{\an8}Eli siis pahin sukupolvi?
Dialogue: 0,0:09:18.12,0:09:20.25,Main-207+,,0,0,0,,{\an8}Trafalgar, Captain Kid...
Dialogue: 0,0:09:20.25,0:09:20.75,Main-207+,,0,0,0,,{\an8}Zoro!
Dialogue: 0,0:09:20.75,0:09:22.12,Main-207+,,0,0,0,,{\an8}Ja Olkihattu.
Dialogue: 0,0:09:20.75,0:09:22.12,Main-207+,,0,0,0,,Ei kun se toinen!
Dialogue: 0,0:09:22.12,0:09:23.63,Main-207+,,0,0,0,,{\an8}Täällähän sinä laiskottelet!
Dialogue: 0,0:09:26.75,0:09:28.38,Main-207+,,0,0,0,,{\an8}Isoveli!
Dialogue: 0,0:09:28.38,0:09:29.76,Main-207+,,0,0,0,,{\an8}Mikset ole töissä?
Dialogue: 0,0:09:29.76,0:09:32.72,Main-207+,,0,0,0,,{\an8}Koska sen uuden aseen kohtalo\Non minun käsissäni.
Dialogue: 0,0:09:32.72,0:09:35.14,Main-207+,,0,0,0,,{\an8}Nyt se pois! Tuo on luottamuksellista!
Dialogue: 0,0:09:35.14,0:09:35.89,Main-207+,,0,0,0,,Joten...
Dialogue: 0,0:09:35.89,0:09:38.43,Main-207+,,0,0,0,,kukas sun mielestä on mahtavin?
Dialogue: 0,0:09:38.43,0:09:41.81,Main-207+,,0,0,0,,Tiedän kuka sen suosikki on!\NOlkihattu-Luffy!
Dialogue: 0,0:09:41.81,0:09:42.94,Main-207+,,0,0,0,,– Oho?!\N– Oho?!
Dialogue: 0,0:09:42.94,0:09:44.44,Main-207+,,0,0,0,,Selitäpäs!
Dialogue: 0,0:09:42.94,0:09:44.44,Secondary-207+,,0,0,0,,Olkihattu?!
Dialogue: 0,0:09:44.44,0:09:47.69,Main-207+,,0,0,0,,Myötäilettekö te lurjukset piraatteja?
Dialogue: 0,0:09:48.32,0:09:50.07,Main-207+,,0,0,0,,– Ehei!\N– Ei tässä siitä ole kyse!
Dialogue: 0,0:09:50.07,0:09:53.03,Main-207+,,0,0,0,,{\q2}Noh noh... Hän vaan on välillä ilonpilaaja...
Dialogue: 0,0:09:53.03,0:09:55.83,Main-207+,,0,0,0,,Tämän vuoksi et etene\Nuralla minun tahtiini.
Dialogue: 0,0:09:55.83,0:09:58.62,Main-207+,,0,0,0,,Ai mitä? Onko pikkubroidilla\Nisompi sotilasarvo?
Dialogue: 0,0:09:58.62,0:10:01.96,Thoughts-207+,,0,0,0,,Aina siltä lipsahtaa jotain! Mikä mäntti!
Dialogue: 0,0:09:59.41,0:10:01.33,Secondary-207+,,0,0,0,,{\an8}Tiedätkös, veljeksistä nuorempana...
Dialogue: 0,0:10:01.33,0:10:04.92,Secondary-207+,,0,0,0,,{\an8}En veljeen paljoa törmännyt,\Nmutta päädyin korkeampaan asemaan!
Dialogue: 0,0:10:04.92,0:10:07.13,Secondary-207+,,0,0,0,,{\an8}Olitteks te kaverit\Ntaistelussa maailman huipulla?
Dialogue: 0,0:10:07.13,0:10:10.71,Secondary-207+,,0,0,0,,{\an8}Oltiinhan me! Isoveli jäi jumiin jäille!
Dialogue: 0,0:10:10.71,0:10:12.47,Secondary-207+,,0,0,0,,{\an8}Melkoista, eikö?
Dialogue: 0,0:10:12.47,0:10:13.72,Secondary-207+,,0,0,0,,{\an8}Noh, miten sen nyt sanoisi...
Dialogue: 0,0:10:01.96,0:10:05.46,Thoughts-207+,,0,0,0,,Ja kuten aina, isoveli\Nantaa hänen piikitellä.
Dialogue: 0,0:10:05.46,0:10:09.34,Thoughts-207+,,0,0,0,,Voitko muka vielä rakastaa\Nnoin mänttiä pikkuveljeä?
Dialogue: 0,0:10:10.71,0:10:13.72,Thoughts-207+,,0,0,0,,En voi sietää veljeäni.
Dialogue: 0,0:10:13.72,0:10:15.55,Main-207+,,0,0,0,,{\an8}Höllentäminen ei pahaa tekisi!
Dialogue: 0,0:10:15.55,0:10:16.43,Flashbacks-207+,,0,0,0,,Höllennä.
Dialogue: 0,0:10:16.43,0:10:17.30,Flashbacks-207+,,0,0,0,,Höllennä!
Dialogue: 0,0:10:17.30,0:10:18.18,Flashbacks-207+,,0,0,0,,Höllennä.
Dialogue: 0,0:10:18.18,0:10:20.77,Flashbacks-207+,,0,0,0,,Höllentäisit vähän!
Dialogue: 0,0:10:24.02,0:10:24.94,Thoughts-207+,,0,0,0,,En...
Dialogue: 0,0:10:26.11,0:10:28.07,Thoughts-207+,,0,0,0,,voi sietää veljeäni.
Dialogue: 0,0:10:39.54,0:10:41.91,Main-207+,,0,0,0,,M-Mitä nyt...?!
Dialogue: 0,0:11:15.03,0:11:17.28,Main-207+,,0,0,0,,Isoveli!
Dialogue: 0,0:11:17.87,0:11:20.78,Main-207+,,0,0,0,,Missä olet, isoveli?!
Dialogue: 0,0:11:29.71,0:11:32.67,Main-207+,,0,0,0,,Isoveli!
Dialogue: 0,0:11:41.31,0:11:44.18,Main-207+,,0,0,0,,{\an8}Mä olen sun pikkuveljesi!
Dialogue: 0,0:11:45.52,0:11:47.52,Flashbacks-207+,,0,0,0,,Hihnahan irtoaa helposti.
Dialogue: 0,0:11:48.06,0:11:50.90,Flashbacks-207+,,0,0,0,,Ne jos mitkään vakiovarusteet on syvältä!
Dialogue: 0,0:11:50.90,0:11:52.07,Flashbacks-207+,,0,0,0,,Ei ole tarvetta.
Dialogue: 0,0:11:52.07,0:11:53.94,Flashbacks-207+,,0,0,0,,Olkapäätkin on ihan viistossa.
Dialogue: 0,0:11:54.90,0:11:57.28,Flashbacks-207+,,0,0,0,,Höllentäisit vähän!
Dialogue: 0,0:11:59.70,0:12:00.82,Main-207+,,0,0,0,,Isoveli...!
Dialogue: 0,0:12:02.20,0:12:05.58,Main-207+,,0,0,0,,Pakene!
Dialogue: 0,0:12:15.71,0:12:20.01,Thoughts-207+,,0,0,0,,Jos Gold Roger ei olisi pannut alkua\Nmerirosvojen aikakaudelle...
Dialogue: 0,0:12:22.01,0:12:24.01,Thoughts-207+,,0,0,0,,Jos Tulinyrkki Ace ei olisi jäänyt kiinni...
Dialogue: 0,0:12:25.98,0:12:29.02,Thoughts-207+,,0,0,0,,Jos meitä ei olisi kutsuttu tähän sotaan...
Dialogue: 0,0:12:32.77,0:12:35.53,Thoughts-207+,,0,0,0,,Jos en olisi jäänyt jumiin\Njättiläisen jalan alle...
Dialogue: 0,0:12:37.61,0:12:40.03,Thoughts-207+,,0,0,0,,Jos hihna ei olisi katkennut...
Dialogue: 0,0:12:41.20,0:12:43.78,Thoughts-207+,,0,0,0,,Jos en olisi kuullut sen pojan ääntä...
Dialogue: 0,0:12:45.66,0:12:50.42,Thoughts-207+,,0,0,0,,Nämä pienet asiat muuttavat\Nelämääni askel askeleelta.
Dialogue: 0,0:12:52.33,0:12:54.80,Thoughts-207+,,0,0,0,,Jos selviän ja pääsen takaisin kotiin...
Dialogue: 0,0:12:54.80,0:12:59.55,Thoughts-207+,,0,0,0,,voisinko minäkin saada aikaan\Nmuutoksen jonkun elämässä?
Dialogue: 0,0:13:05.68,0:13:07.56,Thoughts-207+,,0,0,0,,Juuri hänen laillaan.
Dialogue: 0,0:13:11.69,0:13:14.94,Thoughts-207+,,0,0,0,,Veljeni on vielä elossa Olkihatun ansiosta.
Dialogue: 0,0:13:14.94,0:13:19.45,Thoughts-207+,,0,0,0,,Mutta hän menetti veljensä Acen\Naivan silmiensä edessä.
Dialogue: 0,0:13:19.86,0:13:21.99,Thoughts-207+,,0,0,0,,Hän on ollut kadoksissa siitä lähtien.
Dialogue: 0,0:13:22.74,0:13:25.16,Thoughts-207+,,0,0,0,,Mitenköhän hän voi nyt?
Dialogue: 0,0:13:25.78,0:13:29.04,Main-207+,,0,0,0,,{\i1}Tärkeä tiedotus!\NOlkihattupiraatit on havaittu!
Dialogue: 0,0:13:29.04,0:13:30.50,Main-207+,,0,0,0,,– Olkihattu?!\N– Olkihattu?!
Dialogue: 0,0:13:30.50,0:13:34.13,Main-207+,,0,0,0,,{\i1}He ovat ilmeisesti kokoontumassa\Nuusine jäsenineen 46. grovessa!
Dialogue: 0,0:13:35.13,0:13:36.50,Main-207+,,0,0,0,,Voin siis...
Dialogue: 0,0:13:37.00,0:13:38.26,Main-207+,,0,0,0,,tavata Namin!
Dialogue: 0,0:13:39.76,0:13:43.43,Main-207+,,0,0,0,,Missä on Nami?!
Dialogue: 0,0:13:44.05,0:13:47.81,Main-207+,,0,0,0,,Merisotilaat ryntäsivät tänne ja alkoivat kahinoimaan piraattien kanssa!
Dialogue: 0,0:13:48.43,0:13:50.64,Main-207+,,0,0,0,,Ja nuo ovat ilmiselviä petkuttajia!
Dialogue: 0,0:13:50.64,0:13:53.69,Main-207+,,0,0,0,,Siis oikeasti?! Tuon kuuluisi\Nmuka olla Nami?!
Dialogue: 0,0:13:53.69,0:13:55.81,Main-207+,,0,0,0,,Tehkää vähän taustatutkimusta!
Dialogue: 0,0:13:55.81,0:13:57.82,Main-207+,,0,0,0,,Jos olisin hänen asemassaan...
Dialogue: 0,0:13:57.82,0:14:00.19,Main-207+,,0,0,0,,Mitä? Mitä? Ei...
Dialogue: 0,0:14:00.19,0:14:01.82,Main-207+,,0,0,0,,Putoan!
Dialogue: 0,0:14:01.82,0:14:04.32,Main-207+,,0,0,0,,Perhana!
Dialogue: 0,0:14:04.32,0:14:06.99,Main-207+,,0,0,0,,Soul Kingin viimeinen\Nnäytös oli loppuunmyyty...
Dialogue: 0,0:14:06.99,0:14:08.20,Main-207+,,0,0,0,,– No niin!\N– Jee!
Dialogue: 0,0:14:08.20,0:14:09.12,Main-207+,,0,0,0,,Ilmaista lukemista!
Dialogue: 0,0:14:09.12,0:14:12.12,Main-207+,,0,0,0,,Mennään pläräilemään!
Dialogue: 0,0:14:16.42,0:14:17.59,Main-207+,,0,0,0,,Se itkee...
Dialogue: 0,0:14:18.09,0:14:20.09,Main-207+,,0,0,0,,Pahuksen moukat!
Dialogue: 0,0:14:21.80,0:14:24.43,Main-207+,,0,0,0,,Pacifistoja!
Dialogue: 0,0:14:29.85,0:14:31.35,Main-207+,,0,0,0,,{\an8\fad(150,150)}Gumigumi...
Dialogue: 0,0:14:33.60,0:14:35.35,Main-207+,,0,0,0,,{\an8\fad(150,150)}Teho...
Dialogue: 0,0:14:36.86,0:14:39.40,Main-207+,,0,0,0,,{\an8\fad(150,150)}Pyssy!
Dialogue: 0,0:14:41.32,0:14:42.07,Main-207+,,0,0,0,,Kappas...
Dialogue: 0,0:14:42.65,0:14:44.07,Main-207+,,0,0,0,,Voimissaanhan se on.
Dialogue: 0,0:14:48.33,0:14:52.58,Main-207+,,0,0,0,,{\i1}Olkihattu Luffy tuhosi\NPacifistan yhdellä iskulla?!
Dialogue: 0,0:14:52.58,0:14:53.83,Main-207+,,0,0,0,,{\i1}Erinomaista...!
Dialogue: 0,0:14:53.83,0:14:55.83,Main-207+,,0,0,0,,{\i1}Aktivoi se, kapteeniluutnantti!
Dialogue: 0,0:14:55.83,0:15:01.55,Main-207+,,0,0,0,,{\q2}Mutta se asehan päästää mereen myrkkyä\Njoka hajottaa laivat päällysteineen päivineen!
Dialogue: 0,0:15:01.55,0:15:03.42,Main-207+,,0,0,0,,Se voi vaikuttaa ympäristöön...
Dialogue: 0,0:15:03.42,0:15:04.80,Main-207+,,0,0,0,,{\i1}Leipäläpi umpeen!
Dialogue: 0,0:15:04.80,0:15:07.47,Main-207+,,0,0,0,,{\i1}Tee kaikkesi jotta Olkihattu\Nuppoaa merenpohjaan!
Dialogue: 0,0:15:09.30,0:15:12.72,Thoughts-207+,,0,0,0,,Pitikin olla juuri se laiva,\Njonka kyydissä Chopper on...
Dialogue: 0,0:15:12.72,0:15:14.48,Thoughts-207+,,0,0,0,,Mutta kun minä...!
Dialogue: 0,0:15:14.48,0:15:17.23,Thoughts-207+,,0,0,0,,Minä...!
Dialogue: 0,0:15:17.23,0:15:20.02,Main-207+,,0,0,0,,– Voit vielä nähdä Soul Kingin!\N– Voit vielä nähdä Soul Kingin!
Dialogue: 0,0:15:20.02,0:15:21.57,Main-207+,,0,0,0,,Soul King on Brook!
Dialogue: 0,0:15:21.57,0:15:23.15,Main-207+,,0,0,0,,Ne meni 42. groveen!
Dialogue: 0,0:15:23.15,0:15:24.32,Main-207+,,0,0,0,,Se on osa Olkihattuja!
Dialogue: 0,0:15:24.32,0:15:26.28,Main-207+,,0,0,0,,Lensi sinne suoraan keikalta!
Dialogue: 0,0:15:26.28,0:15:28.82,Main-207+,,0,0,0,,– Me viedään sut sinne!\N– Me viedään sut sinne!
Dialogue: 0,0:15:29.41,0:15:30.78,Main-207+,,0,0,0,,Ei, kiitos vain!
Dialogue: 0,0:15:30.78,0:15:31.79,Main-207+,,0,0,0,,Älä ujostele!
Dialogue: 0,0:15:31.79,0:15:33.58,Main-207+,,0,0,0,,Me otetaan sut...
Dialogue: 0,0:15:33.58,0:15:34.58,Main-207+,,0,0,0,,panttivan–
Dialogue: 0,0:15:38.17,0:15:39.92,Thoughts-207+,,0,0,0,,Äh! Isoveli-vihanneskauppias!
Dialogue: 0,0:15:39.92,0:15:42.30,Main-207+,,0,0,0,,Hetkonen...! Oletko sen\Ntukkukauppiaan lapsi?!
Dialogue: 0,0:15:41.55,0:15:42.92,Main-207+,,0,0,0,,{\an8}Erehdyt henkilöstä!
Dialogue: 0,0:15:42.92,0:15:44.47,Main-207+,,0,0,0,,Mitä sinä oikein täällä?
Dialogue: 0,0:15:44.47,0:15:45.55,Main-207+,,0,0,0,,Olet vaarassa!
Dialogue: 0,0:15:45.55,0:15:46.30,Main-207+,,0,0,0,,Hei!
Dialogue: 0,0:15:46.30,0:15:46.84,Main-207+,,0,0,0,,Häh?
Dialogue: 0,0:15:46.84,0:15:47.97,Main-207+,,0,0,0,,Emme pääse pidemmälle.
Dialogue: 0,0:15:47.97,0:15:49.85,Main-207+,,0,0,0,,"Haades" Rayleigh on tiellä!
Dialogue: 0,0:15:49.18,0:15:49.85,Secondary-207+,,0,0,0,,Rayleigh?!
Dialogue: 0,0:15:50.47,0:15:52.22,Main-207+,,0,0,0,,Se on vielä hengissä?
Dialogue: 0,0:15:52.22,0:15:53.31,Main-207+,,0,0,0,,Kierretään ympäri.
Dialogue: 0,0:15:53.31,0:15:56.10,Main-207+,,0,0,0,,Täältä kestää 30 minuuttia 42. groveen.
Dialogue: 0,0:15:57.60,0:15:58.85,Main-207+,,0,0,0,,Tehdään sopimus.
Dialogue: 0,0:15:58.85,0:16:01.02,Main-207+,,0,0,0,,Pääsen sinne 10 minuutissa.
Dialogue: 0,0:16:01.40,0:16:04.78,Main-207+,,0,0,0,,Sinun tekee mieli ottaa\NOlkihattu kiinni, eikös?
Dialogue: 0,0:16:04.78,0:16:06.90,Main-207+,,0,0,0,,Sanoin: "Tehdään sopimus"!
Dialogue: 0,0:16:06.90,0:16:09.03,Main-207+,,0,0,0,,Miten muka voisin vaarantaa sinut noin?!
Dialogue: 0,0:16:09.03,0:16:10.66,Main-207+,,0,0,0,,Mennääs kotio äidin luo.
Dialogue: 0,0:16:10.66,0:16:12.28,Main-207+,,0,0,0,,Älä lässytä kuin lapselle!
Dialogue: 0,0:16:12.28,0:16:14.50,Main-207+,,0,0,0,,Olen jo viisitoista!
Dialogue: 0,0:16:14.50,0:16:17.96,Main-207+,,0,0,0,,Uskokaa jo! Ei me olla merirosvoja!
Dialogue: 0,0:16:19.42,0:16:23.05,Main-207+,,0,0,0,,Täh? Mitä ne nyt pakeni...?
Dialogue: 0,0:16:25.80,0:16:29.18,Main-207+,,0,0,0,,– Mun Franky!\N– Mun Zoro!
Dialogue: 0,0:16:30.30,0:16:33.56,Main-207+,,0,0,0,,Pääsimme jo aukion ohi näin nopeasti...
Dialogue: 0,0:16:33.56,0:16:35.56,Main-207+,,0,0,0,,Niinpä! Sopimus siis pitää!
Dialogue: 0,0:16:35.56,0:16:36.56,Main-207+,,0,0,0,,Ei käy!
Dialogue: 0,0:16:36.56,0:16:38.56,Main-207+,,0,0,0,,Miksi ei?!
Dialogue: 0,0:16:37.18,0:16:38.56,Secondary-207+,,0,0,0,,Aika mennä kot–
Dialogue: 0,0:16:47.53,0:16:48.65,Main-207+,,0,0,0,,Mistä nuo jättihyönteiset tuli?!
Dialogue: 0,0:16:48.65,0:16:49.78,Main-207+,,0,0,0,,Miksi ne meitä jahtaa?
Dialogue: 0,0:16:49.78,0:16:52.28,Main-207+,,0,0,0,,Se tuijottaa suoraan sinua päin!\NOletko tehnyt jotain?!
Dialogue: 0,0:16:52.28,0:16:55.66,Main-207+,,0,0,0,,Äh! Minun on tavattava Nami,\Njoten lakkaa aiheuttamasta ongelmia!
Dialogue: 0,0:16:55.66,0:16:56.79,Main-207+,,0,0,0,,Et saa mennä.
Dialogue: 0,0:16:56.79,0:17:00.04,Main-207+,,0,0,0,,Velvollisuuteni on puolustaa\Nsiviilejä vaarallisilta pira–
Dialogue: 0,0:17:00.04,0:17:02.04,Main-207+,,0,0,0,,Ei Nami ole vaarallinen piraatti!
Dialogue: 0,0:17:02.04,0:17:03.79,Main-207+,,0,0,0,,Piraatti se kumminkin on.
Dialogue: 0,0:17:03.79,0:17:05.80,Main-207+,,0,0,0,,Niin. Piraatti.
Dialogue: 0,0:17:05.80,0:17:06.80,Main-207+,,0,0,0,,Mutta hän on erilainen...
Dialogue: 0,0:17:07.55,0:17:10.47,Main-207+,,0,0,0,,Nami käänsi elämäni ympäri!
Dialogue: 0,0:17:11.18,0:17:15.31,Main-207+,,0,0,0,,Minulla ei ole pirunmarjavoimia\Ntai sinun lihaksiasi!
Dialogue: 0,0:17:15.81,0:17:19.94,Main-207+,,0,0,0,,Aikana jolloin vahvuus\Non kaikki kaikessa...
Dialogue: 0,0:17:21.94,0:17:25.44,Main-207+,,0,0,0,,luulin että kaltaiseni ruipelo\Nei voisi elää kuten haluaa!
Dialogue: 0,0:17:27.44,0:17:33.45,Main-207+,,0,0,0,,{\q2}Nami on minulle arvokas. Hän näytti, miten\Nminäkin voin päästä omille seikkailuilleni.
Dialogue: 0,0:17:33.82,0:17:35.62,Main-207+,,0,0,0,,Siksi haluan kannustaa häntä!
Dialogue: 0,0:17:35.62,0:17:36.54,Main-207+,,0,0,0,,Mutta sinä...
Dialogue: 0,0:17:39.62,0:17:41.42,Main-207+,,0,0,0,,Ette voi tavata kasvotusten...
Dialogue: 0,0:17:41.42,0:17:43.79,Main-207+,,0,0,0,,mutta sallin sinun\Nnäkevän hänet kauempaa.
Dialogue: 0,0:17:43.79,0:17:44.71,Main-207+,,0,0,0,,Häh?!
Dialogue: 0,0:17:44.71,0:17:47.09,Main-207+,,0,0,0,,Ilmoitan oikotiestä merivoimille.
Dialogue: 0,0:17:47.50,0:17:50.22,Main-207+,,0,0,0,,Teemme parhaamme, jotta\NOlkihattu jää kiikkiin.
Dialogue: 0,0:17:50.84,0:17:53.89,Main-207+,,0,0,0,,Miten tuon kertominen nyt auttaa?
Dialogue: 0,0:17:56.35,0:17:58.72,Main-207+,,0,0,0,,Joku jätti avaimen...
Dialogue: 0,0:17:58.72,0:18:00.14,Main-207+,,0,0,0,,takaoveen?!
Dialogue: 0,0:18:01.27,0:18:04.40,Main-207+,,0,0,0,,{\an8\fad(150,150)\fnCocon M}♪ Sankari, mä kerron tarinaasi! ♪
Dialogue: 0,0:18:04.94,0:18:08.65,Main-207+,,0,0,0,,{\q2\an8\fad(150,150)\fnCocon M}– ♪ Ei epäilystä, nouset kuninkaaksi! ♪\N– ♪ Ei epäilystä, nouset kuninkaaksi! ♪
Dialogue: 0,0:18:04.94,0:18:06.77,Main-207+,,0,0,0,,Olen minäkin matkalla!
Dialogue: 0,0:18:07.15,0:18:08.65,Main-207+,,0,0,0,,Tuli vaan pieni viivästys...
Dialogue: 0,0:18:08.65,0:18:11.78,Main-207+,,0,0,0,,{\an8}Hei!
Dialogue: 0,0:18:11.78,0:18:13.28,Main-207+,,0,0,0,,Taivaalla on valtava lintu!
Dialogue: 0,0:18:13.28,0:18:15.99,Main-207+,,0,0,0,,Monkey D. Luffy on havaittu sen selässä!
Dialogue: 0,0:18:15.99,0:18:19.16,Main-207+,,0,0,0,,Olkihatut tulevat kohtaamaan jälleen!
Dialogue: 0,0:18:19.16,0:18:21.75,Main-207+,,0,0,0,,Kiitos! Taidan vielä ehtiä!
Dialogue: 0,0:18:21.75,0:18:23.42,Main-207+,,0,0,0,,Ette silti saa tavata kasvotusten!
Dialogue: 0,0:18:25.33,0:18:28.30,Main-207+,,0,0,0,,Tiedätkös, olet tainnut muuttua hiukan.
Dialogue: 0,0:18:28.88,0:18:31.34,Main-207+,,0,0,0,,Onko se sodan seurausta?
Dialogue: 0,0:18:31.34,0:18:33.68,Main-207+,,0,0,0,,Niinkin voisi sanoa.
Dialogue: 0,0:18:34.05,0:18:35.18,Main-207+,,0,0,0,,Sen pojan ansiosta–
Dialogue: 0,0:18:39.31,0:18:41.93,Main-207+,,0,0,0,,Kiitos kun kyyditsit tänne asti!
Dialogue: 0,0:18:41.93,0:18:44.44,Main-207+,,0,0,0,,Etenen uralla niin hitaasti...
Dialogue: 0,0:18:57.03,0:19:00.49,Main-207+,,0,0,0,,Pomo, nappasin kiinni itikan.
Dialogue: 0,0:19:00.49,0:19:01.66,Main-207+,,0,0,0,,Se käy!
Dialogue: 0,0:19:01.66,0:19:03.37,Main-207+,,0,0,0,,Pidä häntä siellä silmällä.
Dialogue: 0,0:19:03.37,0:19:06.00,Main-207+,,0,0,0,,Oivallinen tehtävä lellipojalle.
Dialogue: 0,0:19:07.92,0:19:09.67,Main-207+,,0,0,0,,Älkää vähätelkö...
Dialogue: 0,0:19:09.67,0:19:14.01,Main-207+,,0,0,0,,Oivallinen tehtävä {\i1}minulle{\i0} olisi saada\Nmainetta upottamalla Olkihattujen laivan!
Dialogue: 0,0:19:14.01,0:19:15.05,Main-207+,,0,0,0,,Upottamalla?
Dialogue: 0,0:19:15.05,0:19:17.05,Main-207+,,0,0,0,,Ei! Niin ei voi tehdä!
Dialogue: 0,0:19:20.89,0:19:21.81,Main-207+,,0,0,0,,Nami...!
Dialogue: 0,0:19:21.81,0:19:22.60,Main-207+,,0,0,0,,Nami kuolee–
Dialogue: 0,0:19:34.03,0:19:37.66,Main-207+,,0,0,0,,Kaltaisesi pikku itikan\Nei tule inistä korvissani.
Dialogue: 0,0:19:50.63,0:19:53.17,Thoughts-207+,,0,0,0,,En pääse tapaamaan häntä...
Dialogue: 0,0:19:53.71,0:19:57.05,Thoughts-207+,,0,0,0,,Tuijotan vain kaukaa kun\Nheidän laivansa uppoaa...
Dialogue: 0,0:19:58.05,0:20:02.56,Thoughts-207+,,0,0,0,,En edes saa kirjettäni perille hänen luo...
Dialogue: 0,0:20:19.20,0:20:21.12,Main-207+,,0,0,0,,Siviilit käyvät kimppuun!
Dialogue: 0,0:20:20.20,0:20:21.87,Main-207+,,0,0,0,,{\an8}Näen vielä Soul Kingin!
Dialogue: 0,0:20:21.87,0:20:23.33,Main-207+,,0,0,0,,{\an8}Päästä irti!
Dialogue: 0,0:20:22.83,0:20:23.33,Main-207+,,0,0,0,,Täh?
Dialogue: 0,0:20:31.54,0:20:33.50,Main-207+,,0,0,0,,A-Avainkortti!
Dialogue: 0,0:20:33.50,0:20:35.46,Main-207+,,0,0,0,,O-Ottakaa se kiinni!
Dialogue: 0,0:20:35.46,0:20:36.84,Main-207+,,0,0,0,,Napatkaa se ja sassiin!
Dialogue: 0,0:20:36.84,0:20:39.09,Main-207+,,0,0,0,,Muuten asetta ei aktivoida ajoissa!
Dialogue: 0,0:20:39.09,0:20:41.85,Main-207+,,0,0,0,,Mikä mättää, ääliöt?!\NLapsi se vain on!
Dialogue: 0,0:20:47.98,0:20:50.44,Main-207+,,0,0,0,,A-Aaltojen hyvänsuopa kuningas!
Dialogue: 0,0:20:55.36,0:20:58.99,Thoughts-207+,,0,0,0,,"Nami, olet minun toivoni!
Dialogue: 0,0:21:00.41,0:21:05.24,Thoughts-207+,,0,0,0,,{\q2}Vaikka päältäni tallottaisiin maailmassa,\Njossa vahvuus on kaikki kaikessa...
Dialogue: 0,0:21:05.24,0:21:10.17,Thoughts-207+,,0,0,0,,pyristelen, säntään ja elän niin vapaasti kuin ikinä haluan.
Dialogue: 0,0:21:10.17,0:21:14.00,Thoughts-207+,,0,0,0,,Aloin uskomaan siihen sinun ansiostasi.
Dialogue: 0,0:21:16.51,0:21:17.67,Thoughts-207+,,0,0,0,,Toivottavasti...
Dialogue: 0,0:21:17.67,0:21:20.26,Thoughts-207+,,0,0,0,,pystyt tästedes jatkamaan...
Dialogue: 0,0:21:20.26,0:21:22.01,Thoughts-207+,,0,0,0,,mahtavia seikkailujasi!"
Dialogue: 0,0:21:31.23,0:21:35.86,Main-207+,,0,0,0,,{\an8\fad(0,1000)}Matkaan!
Dialogue: 0,0:21:53.92,0:21:58.55,Main-207+,,0,0,0,,O-Olkihattujen alus on\Nkantaman ulkopuolella...
Dialogue: 0,0:22:01.05,0:22:03.47,Main-207+,,0,0,0,,Senkin...! Mitä pirua kuvittelet tekeväsi?!
Dialogue: 0,0:22:03.47,0:22:05.76,Main-207+,,0,0,0,,Noh, noh... Lapset ovat melko äkkipikaisia.
Dialogue: 0,0:22:05.76,0:22:07.18,Main-207+,,0,0,0,,"Äkkipikaisia"?! Ja hitot!
Dialogue: 0,0:22:07.18,0:22:09.39,Main-207+,,0,0,0,,Hän tuhosi luottamuksellista materiaalia!
Dialogue: 0,0:22:09.39,0:22:10.93,Main-207+,,0,0,0,,Se on epäilemättä rikos!
Dialogue: 0,0:22:07.68,0:22:09.14,Secondary-207+,,0,0,0,,Pahus...!
Dialogue: 0,0:22:09.14,0:22:10.93,Secondary-207+,,0,0,0,,Pääsivät pakoon...!
Dialogue: 0,0:22:11.31,0:22:12.81,Main-207+,,0,0,0,,Tämä on vakavan luokan...
Dialogue: 0,0:22:12.81,0:22:14.19,Main-207+,,0,0,0,,Mistä oikein on kyse?
Dialogue: 0,0:22:14.19,0:22:15.06,Main-207+,,0,0,0,,Täh?!
Dialogue: 0,0:22:15.52,0:22:16.77,Main-207+,,0,0,0,,Tämä...
Dialogue: 0,0:22:16.77,0:22:19.07,Main-207+,,0,0,0,,on kirjoittamani kirje.
Dialogue: 0,0:22:19.07,0:22:19.82,Main-207+,,0,0,0,,Mitäh?!
Dialogue: 0,0:22:23.45,0:22:27.08,Main-207+,,0,0,0,,Koitin vain saada takaisin sen,\Nmikä minulta vietiin.
Dialogue: 0,0:22:28.20,0:22:29.83,Main-207+,,0,0,0,,Eräälle rakkaalle osoitettu...
Dialogue: 0,0:22:30.20,0:22:32.21,Main-207+,,0,0,0,,fanikirje!
Dialogue: 0,0:24:00.13,0:24:01.50,Main-207+,,0,0,0,,{\an8}Matkaan!
Dialogue: 0,0:24:01.50,0:24:05.26,Flashbacks-207+,,0,0,0,,{\an8\fad(0,1397)}Matkaan!
Dialogue: 0,0:24:06.26,0:24:07.88,Main-207+,,0,0,0,,Jeah!
Dialogue: 0,0:24:06.26,0:24:09.39,Flashbacks-207+,,0,0,0,,{\an8\t(2145,0,1,\3c&HFFFFFF&\4c&HFFFFFF&)}– Jeah!\N– Jeah!
