Dialogue: 0,0:01:50.63,0:01:53.38,Flashbacks-207-,,0,0,0,,{\fad(150,150)}Gumigumi... Sinko!
Dialogue: 0,0:01:55.72,0:01:58.14,Flashbacks-207-,,0,0,0,,Perääntykää, miehet!
Dialogue: 0,0:01:58.14,0:02:01.14,Flashbacks-207-,,0,0,0,,{\q2}Paetkaa keinolla\Nmillä hyvänsä, kaverit!
Dialogue: 0,0:02:01.73,0:02:04.27,Main-207-,,0,0,0,,{\q2}– Odottakaa!\N– Odottakaa!
Dialogue: 0,0:02:07.73,0:02:09.32,Main-207-,,0,0,0,,Ovatko kaikki täällä?!
Dialogue: 0,0:02:09.32,0:02:12.61,Main-207-,,0,0,0,,{\q2}Ovathan kaikki laivalta\Npoistuneet mukana?!
Dialogue: 0,0:02:12.61,0:02:14.32,Main-207-,,0,0,0,,Juu!
Dialogue: 0,0:02:14.32,0:02:15.49,Main-207-,,0,0,0,,Täällä ollaan.
Dialogue: 0,0:02:15.49,0:02:16.62,Main-207-,,0,0,0,,Näin on.
Dialogue: 0,0:02:16.62,0:02:17.58,Main-207-,,0,0,0,,Jep!
Dialogue: 0,0:02:18.12,0:02:19.70,Main-207-,,0,0,0,,Kapteeni Buggy...
Dialogue: 0,0:02:19.70,0:02:21.91,Main-207-,,0,0,0,,Kapteeni Buggy ei ole kyydissä!
Dialogue: 0,0:02:26.00,0:02:28.50,Main-207-,,0,0,0,,No niin!
Dialogue: 0,0:02:28.96,0:02:31.26,Main-207-,,0,0,0,,{\q2}Räväkkä lauttani\Non vihdoin valmis!
Dialogue: 0,0:02:34.63,0:02:36.14,Main-207-,,0,0,0,,Menoksi!
Dialogue: 0,0:02:36.14,0:02:38.76,Main-207-,,0,0,0,,Matkaan!
Dialogue: 0,0:02:44.48,0:02:46.19,Main-207-,,0,0,0,,Nytkö jo on tällainen riesana?!
Dialogue: 0,0:02:46.65,0:02:49.86,Main-207-,,0,0,0,,En antaudu teille, piru vieköön!
Dialogue: 0,0:03:01.24,0:03:02.20,Main-207-,,0,0,0,,Syön sut!
Dialogue: 0,0:03:10.59,0:03:12.26,Main-207-,,0,0,0,,{\fad(150,150)}Palapalakanuuna!
Dialogue: 0,0:03:19.93,0:03:21.64,Main-207-,,0,0,0,,Lakkaa rimpuilemasta!
Dialogue: 0,0:03:22.14,0:03:23.43,Main-207-,,0,0,0,,Hyväksy kohtalosi!
Dialogue: 0,0:03:33.36,0:03:36.32,Main-207-,,0,0,0,,Anteeksi! Pahoittelut!
Dialogue: 0,0:03:37.41,0:03:40.12,Main-207-,,0,0,0,,Anna anteeksi!
Dialogue: 0,0:03:52.42,0:03:53.63,Thoughts-207-,,0,0,0,,Tule vain!
Dialogue: 0,0:03:54.13,0:03:56.76,Thoughts-207-,,0,0,0,,Suunnitelmani on luodinvarma!
Dialogue: 0,0:04:02.47,0:04:04.02,Main-207-,,0,0,0,,{\fad(0,276)}Tollo! Tollo! Tollo!
Dialogue: 0,0:04:11.48,0:04:12.65,Main-207-,,0,0,0,,Kiinni jäi!
Dialogue: 0,0:04:13.11,0:04:15.03,Main-207-,,0,0,0,,{\i1}Minä{\i0} jäin kiinni?! Täh?! Mitäh?!
Dialogue: 0,0:04:16.36,0:04:18.61,Main-207-,,0,0,0,,{\q2}Miten asiat ottivat\Ntällaisen käänteen?!
Dialogue: 0,0:04:18.61,0:04:20.78,Main-207-,,0,0,0,,Seis! Seis! Au, au, au!
Dialogue: 0,0:04:20.78,0:04:24.20,Main-207-,,0,0,0,,Tämäkö on jo loppuni?!
Dialogue: 0,0:04:24.20,0:04:24.95,Main-207-,,0,0,0,,Älä–
Dialogue: 0,0:04:39.43,0:04:41.26,Main-207-,,0,0,0,,Missäs minä nyt olen?
Dialogue: 0,0:04:43.97,0:04:46.14,Main-207-,,0,0,0,,{\i1}Poistu.{\i0}
Dialogue: 0,0:04:47.06,0:04:47.89,Main-207-,,0,0,0,,Kuka siellä?!
Dialogue: 0,0:04:48.56,0:04:51.98,Main-207-,,0,0,0,,{\i1}Jos henkesi on kallis, poistu!{\i0}
Dialogue: 0,0:04:55.82,0:04:57.49,Main-207-,,0,0,0,,Mitäs ihmettä nämä...?
Dialogue: 0,0:04:57.49,0:04:59.57,Main-207-,,0,0,0,,{\i1}Tämän metsän otuksia.{\i0}
Dialogue: 0,0:04:59.57,0:05:02.95,Main-207-,,0,0,0,,{\q2}{\i1}Pidä tassusi irti niistä\Nellet halua kuolla!{\i0}
Dialogue: 0,0:05:02.95,0:05:03.95,Main-207-,,0,0,0,,Vai niin?
Dialogue: 0,0:05:03.95,0:05:07.37,Main-207-,,0,0,0,,{\q2}Ovat kyllä räväköitä\Nja kiehtovia eläimiä...
Dialogue: 0,0:05:07.91,0:05:10.50,Main-207-,,0,0,0,,Kielsin etenemästä pidemmälle!
Dialogue: 0,0:05:12.63,0:05:13.63,Main-207-,,0,0,0,,Pentele!
Dialogue: 0,0:05:13.63,0:05:15.71,Main-207-,,0,0,0,,Alkoi vain yhtäkkiä laukomaan!
Dialogue: 0,0:05:15.71,0:05:17.42,Main-207-,,0,0,0,,Pahus! Ohi meni!
Dialogue: 0,0:05:18.01,0:05:19.17,Main-207-,,0,0,0,,Siellähän sinä!
Dialogue: 0,0:05:21.18,0:05:22.22,Main-207-,,0,0,0,,Mitä himskattia?!
Dialogue: 0,0:05:23.47,0:05:25.01,Main-207-,,0,0,0,,Sainpas!
Dialogue: 0,0:05:25.56,0:05:27.97,Main-207-,,0,0,0,,Tule esiin!
Dialogue: 0,0:05:26.10,0:05:27.97,Secondary-207-,,0,0,0,,Au! Au! Au!
Dialogue: 0,0:05:27.97,0:05:30.81,Main-207-,,0,0,0,,{\q2}Saakutti! Sullahan\Non pirunmarjavoima!
Dialogue: 0,0:05:31.19,0:05:32.85,Main-207-,,0,0,0,,Ja mitä siitä?!
Dialogue: 0,0:05:32.85,0:05:33.94,Main-207-,,0,0,0,,Et sinä...
Dialogue: 0,0:05:34.65,0:05:36.02,Main-207-,,0,0,0,,Sinä...
Dialogue: 0,0:05:36.73,0:05:38.11,Main-207-,,0,0,0,,{\i1}Mikä{\i0} sinä olet?
Dialogue: 0,0:05:43.28,0:05:45.45,Main-207-,,0,0,0,,Oletko jonkun aarre?
Dialogue: 0,0:05:45.45,0:05:49.12,Main-207-,,0,0,0,,Jep... Yleensä oon lukossa ja...
Dialogue: 0,0:05:49.12,0:05:50.29,Main-207-,,0,0,0,,Pöljäkö oot!
Dialogue: 0,0:05:50.29,0:05:52.12,Main-207-,,0,0,0,,Toi vitsi on jo käynyt vanhaks!
Dialogue: 0,0:05:52.50,0:05:54.96,Main-207-,,0,0,0,,Äläs sää nyt rupea nokkavaks!
Dialogue: 0,0:05:54.96,0:05:59.67,Main-207-,,0,0,0,,{\q2}En näytä armoo niille\Njotka loukkaa näitä elukoita!
Dialogue: 0,0:06:00.46,0:06:02.97,Main-207-,,0,0,0,,Niinkö? Haastatko riitaa vai?
Dialogue: 0,0:06:02.97,0:06:06.80,Main-207-,,0,0,0,,{\q2}Arvostan rohkeuttasi, mutta älä\Nala parkumaan kun heität henkesi!
Dialogue: 0,0:06:16.40,0:06:18.19,Main-207-,,0,0,0,,Kiinni jäit!
Dialogue: 0,0:06:18.19,0:06:19.73,Main-207-,,0,0,0,,Samperi!
Dialogue: 0,0:06:22.65,0:06:24.99,Main-207-,,0,0,0,,Huijari! Käytät kättä pidempää!
Dialogue: 0,0:06:24.99,0:06:27.66,Main-207-,,0,0,0,,Eikös {\i1}sun{\i0} käsi vasta pitkällä oo?!
Dialogue: 0,0:06:27.66,0:06:29.49,Main-207-,,0,0,0,,Lakkaa olemasta noin itsekäs!
Dialogue: 0,0:06:29.49,0:06:30.62,Main-207-,,0,0,0,,Sano hyvästit!
Dialogue: 0,0:06:46.68,0:06:49.43,Main-207-,,0,0,0,,{\fad(150,150)}Palapalaevakuointi!
Dialogue: 0,0:06:49.89,0:06:51.35,Main-207-,,0,0,0,,Autsis!
Dialogue: 0,0:06:51.35,0:06:57.19,Main-207-,,0,0,0,,Kehtaatkin! Piru vie! Auts!
Dialogue: 0,0:06:54.31,0:06:57.19,Secondary-207-,,0,0,0,,Että mitä kehtaan?! Häh?!
Dialogue: 0,0:07:06.91,0:07:10.83,Main-207-,,0,0,0,,{\q2}Näiden eläinten häiritseminen\Non anteeksantamatonta!
Dialogue: 0,0:07:10.83,0:07:15.41,Main-207-,,0,0,0,,{\q2}Sää tulit tälle saarelle\Notusten perässä, ryökäle!
Dialogue: 0,0:07:15.41,0:07:17.17,Main-207-,,0,0,0,,Miksi minä sellaista?!
Dialogue: 0,0:07:17.17,0:07:19.38,Main-207-,,0,0,0,,{\q2}En edes ole täällä\Nomasta tahdostani!
Dialogue: 0,0:07:20.75,0:07:23.30,Main-207-,,0,0,0,,Et siis oo salametsästäjä vai?
Dialogue: 0,0:07:36.77,0:07:38.56,Main-207-,,0,0,0,,Maukasta, eikö?
Dialogue: 0,0:07:38.56,0:07:40.86,Main-207-,,0,0,0,,Itse tehtyä sakeeta viinaa!
Dialogue: 0,0:07:40.86,0:07:42.98,Main-207-,,0,0,0,,Oikein maittavaa!
Dialogue: 0,0:07:42.98,0:07:45.49,Main-207-,,0,0,0,,Viime kerrasta onkin jo aikaa...
Dialogue: 0,0:07:45.49,0:07:49.74,Main-207-,,0,0,0,,Sen kun juot sydämes kyllyydestä!
Dialogue: 0,0:07:49.74,0:07:52.83,Main-207-,,0,0,0,,Ja pahoittelut aiemmasta.
Dialogue: 0,0:07:53.24,0:07:55.50,Main-207-,,0,0,0,,Teit kyllä melkoisen kierosti,
Dialogue: 0,0:07:55.50,0:07:57.67,Main-207-,,0,0,0,,mutta mitä menneistä!
Dialogue: 0,0:07:57.67,0:07:59.04,Main-207-,,0,0,0,,{\q2}– Kippis!\N– Kippis!
Dialogue: 0,0:08:09.51,0:08:13.60,Main-207-,,0,0,0,,{\q2}Anteeksi että pistin sinut vielä\Nauttamaan lautan rakentamisessa.
Dialogue: 0,0:08:13.60,0:08:16.73,Main-207-,,0,0,0,,Mitäs siitä. Ilo on mun puolellani.
Dialogue: 0,0:08:17.73,0:08:20.06,Main-207-,,0,0,0,,Kas niin. Jaksamisia!
Dialogue: 0,0:08:20.06,0:08:21.40,Main-207-,,0,0,0,,Samoin!
Dialogue: 0,0:08:34.58,0:08:36.29,Main-207-,,0,0,0,,Hyvästi, kaveri!
Dialogue: 0,0:08:37.00,0:08:38.12,Main-207-,,0,0,0,,Pärjäile!
Dialogue: 0,0:08:41.08,0:08:42.84,Main-207-,,0,0,0,,Joo...
Dialogue: 0,0:08:42.84,0:08:44.80,Main-207-,,0,0,0,,Sinä myös!
Dialogue: 0,0:08:47.72,0:08:49.88,Main-207-,,0,0,0,,Matkaan!
Dialogue: 0,0:08:53.26,0:08:55.72,Main-207-,,0,0,0,,No niin!
Dialogue: 0,0:08:56.97,0:08:58.23,Thoughts-207-,,0,0,0,,Buggy...
Dialogue: 0,0:08:59.48,0:09:03.15,Thoughts-207-,,0,0,0,,{\q2}Näis vesissä asustelee\Nkaikenlaisii omituisii otuksia.
Dialogue: 0,0:09:03.65,0:09:07.11,Thoughts-207-,,0,0,0,,Erittäin turvallista matkaa!
Dialogue: 0,0:09:11.07,0:09:13.91,Main-207-,,0,0,0,,Eikä, mähän unohdin kertoa sen!
Dialogue: 0,0:09:23.25,0:09:25.88,Main-207-,,0,0,0,,Pakoon, Buggy!
Dialogue: 0,0:09:27.80,0:09:29.59,Main-207-,,0,0,0,,Varo!
Dialogue: 0,0:09:29.59,0:09:32.59,Main-207-,,0,0,0,,Pakene! Karkuun täältä ja sassiin!
Dialogue: 0,0:09:36.51,0:09:38.06,Main-207-,,0,0,0,,Mikäs toi on?
Dialogue: 0,0:10:01.46,0:10:02.87,Thoughts-207-,,0,0,0,,Nätti...
Dialogue: 0,0:10:04.00,0:10:05.67,Main-207-,,0,0,0,,Kukas se siellä?
Dialogue: 0,0:10:06.04,0:10:08.71,Main-207-,,0,0,0,,Miten hemaiseva typy!
Dialogue: 0,0:10:08.71,0:10:12.76,Main-207-,,0,0,0,,Noh, kaveri tais sentään pelastua.
Dialogue: 0,0:10:13.38,0:10:15.93,Main-207-,,0,0,0,,Mä olin oikein hermorauniona!
Dialogue: 0,0:10:19.52,0:10:26.48,Main-207-,,0,0,0,,{\q2}{\fad(0,3941)}Mut, joka tapauksessa,\Npidä ittestäs huolta!
Dialogue: 0,0:10:26.77,0:10:29.65,Main-207-,,0,0,0,,Kiitoksia kun avitit!
Dialogue: 0,0:10:29.65,0:10:32.19,Main-207-,,0,0,0,,{\q2}Luulin jo olleeni\Nräväkästi mennyttä!
Dialogue: 0,0:10:32.19,0:10:34.07,Main-207-,,0,0,0,,Kiitoksille ei ole tarvetta.
Dialogue: 0,0:10:35.11,0:10:36.95,Main-207-,,0,0,0,,Olet Buggy-klovni, eikö?
Dialogue: 0,0:10:37.49,0:10:39.12,Main-207-,,0,0,0,,M-Mistä tiesit?!
Dialogue: 0,0:10:39.83,0:10:41.29,Main-207-,,0,0,0,,Kuka ihme olet?
Dialogue: 0,0:10:41.29,0:10:44.04,Main-207-,,0,0,0,,Etsin erästä miestä.
Dialogue: 0,0:10:45.12,0:10:46.75,Main-207-,,0,0,0,,Taidatte tuntea toisenne.
Dialogue: 0,0:10:47.71,0:10:49.04,Main-207-,,0,0,0,,Se riivattu kumikakara!
Dialogue: 0,0:10:49.04,0:10:50.38,Main-207-,,0,0,0,,Mokoma!
Dialogue: 0,0:10:50.38,0:10:52.88,Main-207-,,0,0,0,,Tasoitan vielä tilit kanssasi!
Dialogue: 0,0:10:52.88,0:10:54.68,Main-207-,,0,0,0,,Odotas vain!
Dialogue: 0,0:10:56.01,0:10:58.01,Main-207-,,0,0,0,,Tätäkö tyyppiä etsit?
Dialogue: 0,0:11:00.51,0:11:02.64,Main-207-,,0,0,0,,Vai niin.
Dialogue: 0,0:11:02.64,0:11:05.44,Main-207-,,0,0,0,,Siksi siis päätit auttaa minua.
Dialogue: 0,0:11:05.44,0:11:06.77,Main-207-,,0,0,0,,Mitä sanot?
Dialogue: 0,0:11:07.44,0:11:08.86,Main-207-,,0,0,0,,Lyöttäydytäänkö yhteen?
Dialogue: 0,0:11:12.69,0:11:13.82,Main-207-,,0,0,0,,Mikä ettei.
Dialogue: 0,0:11:13.82,0:11:15.82,Main-207-,,0,0,0,,Onhan meillä sama tavoite.
Dialogue: 0,0:11:15.82,0:11:17.74,Main-207-,,0,0,0,,Pysytään hyvissä väleissä.
Dialogue: 0,0:11:17.74,0:11:20.58,Main-207-,,0,0,0,,Mainiota. Kippis sitten!
Dialogue: 0,0:11:21.49,0:11:22.62,Main-207-,,0,0,0,,Kippis!
Dialogue: 0,0:11:32.76,0:11:34.59,Main-207-,,0,0,0,,Kapteeni Buggy!
Dialogue: 0,0:11:37.59,0:11:42.68,Main-207-,,0,0,0,,{\q2}Hän tuntui eläessään\Nusein kylmäveriseltä ja hirmuisalta...
Dialogue: 0,0:11:42.68,0:11:48.02,Main-207-,,0,0,0,,{\q2}mutta nyt tajuan hänen olleen urhoollinen\Nja avomielinen piraattien esikuva!
Dialogue: 0,0:11:48.02,0:11:51.52,Main-207-,,0,0,0,,{\q2}Nyt kun mietin, saimme ryöväillä\Nsydämemme kyllyydestä
Dialogue: 0,0:11:51.52,0:11:54.65,Main-207-,,0,0,0,,{\q2}vain kapteeni Buggyn\Ntuen ansiosta!
Dialogue: 0,0:11:55.19,0:12:01.12,Main-207-,,0,0,0,,{\q2}Tänään pidämme hulppeimmat ja\Nräväkimmät hautajaiset kapteeni Buggylle!
Dialogue: 0,0:12:03.33,0:12:06.16,Main-207-,,0,0,0,,Lepää rauhassa, kapteeni.
Dialogue: 0,0:12:06.62,0:12:09.67,Main-207-,,0,0,0,## AUTOMATIC LINEBREAK ##,Tästedes minä, Buggyn joukkion adjutantti,
Dialogue: 0,0:12:09.67,0:12:12.96,Main-207-,,0,0,0,,{\q2}jonglööri Cabaji,\Npidän huolen kaikesta!
Dialogue: 0,0:12:13.80,0:12:17.42,Main-207-,,0,0,0,,{\q2}Vannon jälleenrakentavani\NBuggyn joukkion!
Dialogue: 0,0:12:17.42,0:12:19.05,Main-207-,,0,0,0,,Seis siihen!
Dialogue: 0,0:12:19.68,0:12:21.97,Main-207-,,0,0,0,,Cabaji!
Dialogue: 0,0:12:20.43,0:12:21.97,Secondary-207-,,0,0,0,,Mitäh?!
Dialogue: 0,0:12:22.30,0:12:27.81,Main-207-,,0,0,0,,{\q2}Kapteeni Buggyn seuraajan\Nkuuluisi päivänselvästi olla minä,
Dialogue: 0,0:12:27.81,0:12:32.36,Main-207-,,0,0,0,,{\q2}perämies ja mahtava\Npedonkesyttäjä Mohji!
Dialogue: 0,0:12:32.86,0:12:35.32,Main-207-,,0,0,0,,Kapteeni olen minä!
Dialogue: 0,0:12:36.32,0:12:37.44,Main-207-,,0,0,0,,Hei, kaverit!
Dialogue: 0,0:12:37.44,0:12:40.28,Main-207-,,0,0,0,,{\q2}Voimainkoitos päättää\Nkumpi nousee kapteeniksi!
Dialogue: 0,0:12:41.57,0:12:43.37,Main-207-,,0,0,0,,Sopii minulle!
Dialogue: 0,0:12:49.83,0:12:52.88,Main-207-,,0,0,0,,{\q2}{\an8\fad(440,0)}– Mohji! Mohji! Mohji!\N– Mohji! Mohji! Mohji!
Dialogue: 0,0:12:53.71,0:12:56.63,Main-207-,,0,0,0,,{\q2}{\an8}– Cabaji! Cabaji! Cabaji!\N– Cabaji! Cabaji! Cabaji!
Dialogue: 0,0:12:56.63,0:12:58.59,Main-207-,,0,0,0,,{\q2}– Mohji! Mohji!\N– Mohji! Mohji!
Dialogue: 0,0:12:58.59,0:13:00.47,Main-207-,,0,0,0,,{\q2}– Cabaji! Cabaji!\N– Cabaji! Cabaji!
Dialogue: 0,0:13:00.47,0:13:02.59,Main-207-,,0,0,0,,{\q2}– Mohji! Mohji!\N– Mohji! Mohji!
Dialogue: 0,0:13:02.59,0:13:04.47,Main-207-,,0,0,0,,{\q2}– Cabaji! Cabaji!\N– Cabaji! Cabaji!
Dialogue: 0,0:13:04.47,0:13:06.93,Main-207-,,0,0,0,,{\q2}– Mohji! Mohji!\N– Mohji! Mohji!
Dialogue: 0,0:13:23.87,0:13:27.87,Main-207-,,0,0,0,,{\q2}Meidän on näköjään taisteltava\Nsiihen asti kunnes luhistut.
Dialogue: 0,0:13:27.87,0:13:30.50,Main-207-,,0,0,0,,{\q2}Niin, tämä vasta on\Npariakrobatiaa.
Dialogue: 0,0:13:30.50,0:13:32.83,Main-207-,,0,0,0,## OVERWIDTH WITH FORCED WRAP ##,{\q2}Isken sinut kanveesiin paljain käsin!
Dialogue: 0,0:13:45.39,0:13:50.85,Main-207-,,0,0,0,,Ryökäle... L-luovuttaisit jo.
Dialogue: 0,0:13:50.85,0:13:54.15,Main-207-,,0,0,0,,E-Ei, vaan sinä luovutat.
Dialogue: 0,0:14:17.34,0:14:20.67,Main-207-,,0,0,0,,{\q2}– Jee! Meidän kapteeni Richie!\N– Jee! Meidän kapteeni Richie!
Dialogue: 0,0:14:50.45,0:14:52.83,Main-207-,,0,0,0,,{\q2}– Kapteeni Richie! Kapteeni Richie!\N– Kapteeni Richie! Kapteeni Richie!
Dialogue: 0,0:14:52.83,0:14:54.96,Main-207-,,0,0,0,,{\q2}– Suuri kapteenimme!\N– Suuri kapteenimme!
Dialogue: 0,0:14:54.96,0:14:57.42,Secondary-207-,,0,0,0,,{\q2}{\an8}– Kapteeni Richie! Kapteeni Richie!\N– Kapteeni Richie! Kapteeni Richie!
Dialogue: 0,0:14:57.42,0:14:59.67,Secondary-207-,,0,0,0,,{\q2}{\an8}– Suuri kapteenimme!\N– Suuri kapteenimme!
Dialogue: 0,0:14:59.67,0:15:00.42,Secondary-207-,,0,0,0,,{\q2}{\an8}– Kapteeni Richie! Kapteeni Richie!\N– Kapteeni Richie! Kapteeni Richie!
Dialogue: 0,0:15:00.42,0:15:01.63,Main-207-,,0,0,0,,{\q2}– Kapteeni Richie! Kapteeni Richie!\N– Kapteeni Richie! Kapteeni Richie!
Dialogue: 0,0:15:01.63,0:15:03.80,Main-207-,,0,0,0,,{\q2}– Suuri kapteenimme!\N– Suuri kapteenimme!
Dialogue: 0,0:14:54.96,0:14:56.58,Main-207-,,0,0,0,,Kapteeni Buggyn menehdyttyä...
Dialogue: 0,0:14:56.58,0:15:00.42,Main-207-,,0,0,0,,{\q2}meistä pätevin hänen\Nrooliinsa on kapteeni Richie!
Dialogue: 0,0:15:03.80,0:15:05.88,Main-207-,,0,0,0,,{\q2}– Kapteeni Richie! Kapteeni Richie!\N– Kapteeni Richie! Kapteeni Richie!
Dialogue: 0,0:15:05.88,0:15:08.60,Main-207-,,0,0,0,,{\q2}– Suuri kapteenimme!\N– Suuri kapteenimme!
Dialogue: 0,0:15:08.60,0:15:10.56,Main-207-,,0,0,0,,{\an8\q2}– Kapteeni Richie! Kapteeni Richie!\N– Kapteeni Richie! Kapteeni Richie!
Dialogue: 0,0:15:10.56,0:15:12.85,Main-207-,,0,0,0,,{\q2}{\an8}– Suuri kapteenimme!\N– Suuri kapteenimme!
Dialogue: 0,0:15:12.85,0:15:14.56,Main-207-,,0,0,0,,{\an8\q2}– Kapteeni Richie! Kapteeni Richie!\N– Kapteeni Richie! Kapteeni Richie!
Dialogue: 0,0:15:15.10,0:15:17.23,Main-207-,,0,0,0,,{\q2}– Suuri kapteenimme!\N– Suuri kapteenimme!
Dialogue: 0,0:15:17.23,0:15:19.44,Main-207-,,0,0,0,,{\q2}– Kapteeni Richie! Kapteeni Richie!\N– Kapteeni Richie! Kapteeni Richie!
Dialogue: 0,0:15:19.44,0:15:21.69,Main-207-,,0,0,0,,{\q2}– Suuri kapteenimme!\N– Suuri kapteenimme!
Dialogue: 0,0:15:21.69,0:15:23.86,Main-207-,,0,0,0,,{\q2}– Kapteeni Richie! Kapteeni Richie!\N– Kapteeni Richie! Kapteeni Richie!
Dialogue: 0,0:15:23.86,0:15:26.28,Main-207-,,0,0,0,,{\q2}– Suuri kapteenimme!\N– Suuri kapteenimme!
Dialogue: 0,0:15:41.09,0:15:45.80,Main-207-,,0,0,0,,{\q2}Tämä saari kuuluu\NKarhuntassu-heimolle, tiedättekös?!
Dialogue: 0,0:15:47.43,0:15:48.43,Main-207-,,0,0,0,,Kapteeni!
Dialogue: 0,0:15:53.89,0:15:56.06,Main-207-,,0,0,0,,Huvittavaa. Tekeekö mieli otella?
Dialogue: 0,0:16:14.79,0:16:16.66,Main-207-,,0,0,0,,M-me antaudumme.
Dialogue: 0,0:16:22.84,0:16:24.84,Main-207-,,0,0,0,,Löytyikö jotakin hyvää?
Dialogue: 0,0:16:24.84,0:16:26.80,Main-207-,,0,0,0,,Joo! Sehän on...
Dialogue: 0,0:16:27.47,0:16:31.93,Main-207-,,0,0,0,,{\q2}Buggyn joukkion\Nerittäin räväkkä alus!
Dialogue: 0,0:16:32.80,0:16:36.35,Main-207-,,0,0,0,,{\q2}Kuka oikein teki tämän?\NMiten surkea mäihä!
Dialogue: 0,0:16:36.93,0:16:40.48,Main-207-,,0,0,0,,{\q2}Ja tuohan on kaiken päälle\Nvanha etsintäkuulutus.
Dialogue: 0,0:16:40.94,0:16:43.86,Main-207-,,0,0,0,,Kappas? Tuolla lojuu joku.
Dialogue: 0,0:16:44.90,0:16:46.15,Main-207-,,0,0,0,,Mi...?!
Dialogue: 0,0:16:46.61,0:16:49.03,Main-207-,,0,0,0,,Mohji! Cabaji!
Dialogue: 0,0:16:49.03,0:16:50.61,Main-207-,,0,0,0,,Mitä teille kävi?!
Dialogue: 0,0:16:51.11,0:16:54.58,Main-207-,,0,0,0,,K-Kapteeni Buggy...
Dialogue: 0,0:16:55.08,0:16:58.54,Main-207-,,0,0,0,,O-Oikein hyvä nähdä sinua...
Dialogue: 0,0:16:59.79,0:17:02.50,Main-207-,,0,0,0,,{\q2}Olen niin onnellinen\Nettä olet hengissä!
Dialogue: 0,0:17:02.50,0:17:04.92,Main-207-,,0,0,0,,{\q2}Luulin, että emme\Nenää koskaan tapaisi!
Dialogue: 0,0:17:04.92,0:17:07.55,Main-207-,,0,0,0,,O-Olen minäkin onnellinen.
Dialogue: 0,0:17:09.01,0:17:13.10,Main-207-,,0,0,0,## OVERWIDTH WITH FORCED WRAP ##,{\q2}Mutta mitä pirua täällä oikein kävi?
Dialogue: 0,0:17:14.22,0:17:16.01,Main-207-,,0,0,0,,Kenen tekosia tämä on?!
Dialogue: 0,0:17:16.01,0:17:17.27,Main-207-,,0,0,0,,Täh?
Dialogue: 0,0:17:17.27,0:17:20.77,Main-207-,,0,0,0,,Meitä iskettiin ihan puskista.
Dialogue: 0,0:17:21.14,0:17:25.07,Main-207-,,0,0,0,,{\q2}Nöyryyttävää se on, mutta\Nemme muista hölkäsen pöläystä.
Dialogue: 0,0:17:25.82,0:17:29.74,Main-207-,,0,0,0,,Heidät päihitti Karhuntassu-heimo.
Dialogue: 0,0:17:30.28,0:17:32.91,Main-207-,,0,0,0,,{\q2}Jos haluat pelastaa heidät,\Nparasta kiirehtiä.
Dialogue: 0,0:17:34.87,0:17:38.25,Main-207-,,0,0,0,,{\q2}Heimon jäsenten ruokavalio\Non näet omalaatuinen.
Dialogue: 0,0:17:51.68,0:17:55.05,Main-207-,,0,0,0,,{\q2}Kapteenin mukaan\Nleijonat maistuu pahalta!
Dialogue: 0,0:17:55.05,0:17:56.97,Main-207-,,0,0,0,,Niin mekin!
Dialogue: 0,0:17:56.97,0:17:58.72,Main-207-,,0,0,0,,Musta ei tule maukasta ateriaa!
Dialogue: 0,0:17:58.72,0:18:01.44,Main-207-,,0,0,0,,{\q2}Tämä kaveri näyttää\Nsyömäkelpoisemmalta!
Dialogue: 0,0:18:00.23,0:18:01.44,Secondary-207-,,0,0,0,,Valetta! Valetta!
Dialogue: 0,0:18:01.44,0:18:03.27,Main-207-,,0,0,0,,Hän on paljon herkullisempi!
Dialogue: 0,0:18:03.27,0:18:06.57,Main-207-,,0,0,0,,{\q2}Olen pelkkä luuviulu!\NEi minussa yhtään lihaa ole!
Dialogue: 0,0:18:08.78,0:18:10.28,Main-207-,,0,0,0,,Ei haittaa!
Dialogue: 0,0:18:10.28,0:18:13.28,Main-207-,,0,0,0,,{\q2}Me Karhuntassu-heimolaiset\Nolemme rautaisia kokkeja!{https://en.wikipedia.org/wiki/Iron_Chef}
Dialogue: 0,0:18:13.28,0:18:15.74,Main-207-,,0,0,0,,{\q2}Viinillä ja mausteilla\Nlöyhkä saadaan pois!
Dialogue: 0,0:18:20.58,0:18:22.62,Main-207-,,0,0,0,,Mitä tälle ruoalle tehdään?
Dialogue: 0,0:18:22.62,0:18:24.00,Main-207-,,0,0,0,,Mitäs nämä?
Dialogue: 0,0:18:24.00,0:18:26.21,Main-207-,,0,0,0,,{\q2}En ole nähnytkään\Nnoin outoja aineosia.
Dialogue: 0,0:18:26.67,0:18:28.17,Main-207-,,0,0,0,,Keitetäänkö muiden kanssa?
Dialogue: 0,0:18:28.80,0:18:31.01,Main-207-,,0,0,0,,{\q2}Kunpa ei vain antaisi\Nvatsanväänteitä.
Dialogue: 0,0:18:31.01,0:18:32.47,Main-207-,,0,0,0,,{\fad(150,150)}Palapalapala...
Dialogue: 0,0:18:37.05,0:18:39.01,Main-207-,,0,0,0,,{\fad(150,150)}Palapalapalapala...
Dialogue: 0,0:19:06.42,0:19:08.09,Main-207-,,0,0,0,,Onko tuo...?!
Dialogue: 0,0:19:10.67,0:19:12.96,Main-207-,,0,0,0,,{\fad(150,150)}...Räväkkä kokoonpano!
Dialogue: 0,0:19:41.33,0:19:44.50,Main-207-,,0,0,8,,Olen elpynyt!
Dialogue: 0,0:19:45.37,0:19:49.38,Main-207-,,0,0,0,,{\q2}– Kapteeni Buggy!\N– Kapteeni Buggy!
Dialogue: 0,0:19:51.42,0:19:54.09,Main-207-,,0,0,0,,Pahoittelut viivästyksestä, kaveri!
Dialogue: 0,0:19:55.42,0:19:59.43,Main-207-,,0,0,0,,{\q2}Aika elävöittää tunnelmaa\Nsuperräväkällä Buggykuulalla!
Dialogue: 0,0:20:08.73,0:20:10.52,Main-207-,,0,0,0,,Richie!
Dialogue: 0,0:20:18.95,0:20:22.87,Main-207-,,0,0,0,## OVERWIDTH WITH FORCED WRAP ##,{\fad(150,150)\q2}Jonglöörin "Kuolema vaanii sumussa"!
Dialogue: 0,0:20:22.87,0:20:26.12,Main-207-,,0,0,0,,Pedonkesytysnäytös alkakoon!
Dialogue: 0,0:20:33.25,0:20:37.59,Main-207-,,0,0,0,,{\q2}Luuletteko voivanne osua {\i1}minuun{\i0},\Nmahtavaan Buggy-klovniin?!
Dialogue: 0,0:20:39.97,0:20:44.39,Main-207-,,0,0,0,,{\q2}Minun on henkilökohtaisesti\Nkiitettävä teitä miehistöni kohtelusta.
Dialogue: 0,0:20:45.02,0:20:47.43,Main-207-,,0,0,0,,Täältä tullaan ja räväkästi!
Dialogue: 0,0:20:48.81,0:20:50.90,Main-207-,,0,0,0,,{\fad(150,150)}Palapalapotku!
Dialogue: 0,0:20:56.53,0:20:58.86,Main-207-,,0,0,0,,{\fad(150,150)}Palapalaisku!
Dialogue: 0,0:21:00.70,0:21:02.62,Main-207-,,0,0,0,,Siinä on kapteenimme!
Dialogue: 0,0:21:06.79,0:21:11.29,Main-207-,,0,0,0,,{\q2}– Kapteeni Buggy!\N– Kapteeni Buggy!
Dialogue: 0,0:21:13.75,0:21:15.67,Main-207-,,0,0,0,,Onneksi olet kunnossa!
Dialogue: 0,0:21:16.55,0:21:20.63,Main-207-,,0,0,0,,{\q2}Olen aiheuttanut teille paljon\Nkärsimystä, rakkaat alamaiseni!
Dialogue: 0,0:21:21.01,0:21:24.97,Main-207-,,0,0,0,,Ei me piitata kivuistamme!
Dialogue: 0,0:21:30.02,0:21:34.44,Main-207-,,0,0,0,,{\q2}Kaikki kohtaamanne\Nvaikeudet johtuvat...
Dialogue: 0,0:21:34.44,0:21:36.69,Main-207-,,0,0,0,,siitä kirotusta Olkihatusta!
Dialogue: 0,0:21:38.03,0:21:41.66,Main-207-,,0,0,0,,Muuten, kuka tuo ihana neiti on?
Dialogue: 0,0:21:42.36,0:21:46.33,Main-207-,,0,0,0,,{\q2}Tämä mukava nainen pelasti\Nhenkeni! Hän on nimeltään...
Dialogue: 0,0:21:47.04,0:21:48.37,Main-207-,,0,0,0,,Tuota...
Dialogue: 0,0:21:48.37,0:21:50.33,Main-207-,,0,0,0,,Öh, pahoittelut.
Dialogue: 0,0:21:50.33,0:21:52.54,Main-207-,,0,0,0,,Mikä nimesi olikaan?
Dialogue: 0,0:21:55.29,0:21:56.67,Main-207-,,0,0,0,,Kaverit!
Dialogue: 0,0:21:56.67,0:21:59.80,Main-207-,,0,0,0,## OVERWIDTH WITH FORCED WRAP ##,{\q2}Buggyn joukkio on jälleen vauhdissa!
Dialogue: 0,0:22:01.88,0:22:05.51,Main-207-,,0,0,0,,{\q2}Kapteeni! Mikä on\Nensimmäinen käskynne?
Dialogue: 0,0:22:05.51,0:22:09.93,Main-207-,,0,0,0,## OVERWIDTH WITH FORCED WRAP ##,{\q2}Noudamme Monkey D. Luffyn pään!
