Dialogue: 0,0:01:47.22,0:01:48.20,Main,,0,0,0,,Cora.
Dialogue: 0,0:01:48.85,0:01:51.50,Flashbacks,,0,0,0,,Tu ne vis que pour la destruction,
Dialogue: 0,0:01:51.68,0:01:54.40,Flashbacks,,0,0,0,,il n'a rien à gagner\Nen restant avec toi.
Dialogue: 0,0:01:54.66,0:01:56.62,Flashbacks,,0,0,0,,Laisse-le en paix.
Dialogue: 0,0:01:56.81,0:01:59.92,Thoughts,,0,0,0,,Maintenant, il est libre !
Dialogue: 0,0:02:04.86,0:02:07.40,Thoughts,,0,0,0,,Je ne serai libre
Dialogue: 0,0:02:08.50,0:02:10.66,Thoughts,,0,0,0,,que lorsque ton rêve sera réalisé.
Dialogue: 0,0:02:10.80,0:02:11.62,Main,,0,0,0,,{\fad(150,150)}Room.
Dialogue: 0,0:02:12.82,0:02:15.07,Thoughts,,0,0,0,,Lorsque Doflamingo mordra la poussière !
Dialogue: 0,0:02:16.55,0:02:20.25,Main,,0,0,0,,– Que penses-tu de Monkey D. Luffy ?\N– Hein ?
Dialogue: 0,0:02:20.58,0:02:22.54,Main,,0,0,0,,Aujourd'hui, j'ai découvert une chose.
Dialogue: 0,0:02:22.94,0:02:25.32,Main,,0,0,0,,Tu es un Dragon Céleste !
Dialogue: 0,0:02:25.82,0:02:26.84,Main,,0,0,0,,Shambles.
Dialogue: 0,0:02:29.82,0:02:32.38,Main,,0,0,0,,Que penses-tu du D. ?
Dialogue: 0,0:02:41.80,0:02:43.31,Main,,0,0,0,,Ça...
Dialogue: 0,0:02:45.08,0:02:46.84,Main,,0,0,0,,Ça ne te regarde pas.
Dialogue: 0,0:02:47.34,0:02:49.25,Main,,0,0,0,,Luffy au chapeau de paille ?
Dialogue: 0,0:02:49.43,0:02:52.32,Main,,0,0,0,,Tu crois quoi ?\NQue le destin l'a guidé jusqu'ici ?
Dialogue: 0,0:02:52.68,0:02:57.78,Main,,0,0,0,,Qu'il est là pour me châtier,\Nmoi qui suis de sang divin ?
Dialogue: 0,0:02:58.44,0:02:59.82,Main,,0,0,0,,Ne me fais pas rire !
Dialogue: 0,0:03:03.35,0:03:07.52,Flashbacks,,0,0,0,,Certains ont un autre qualificatif\Npour les porteurs de ce nom.
Dialogue: 0,0:03:08.30,0:03:10.39,Flashbacks,,0,0,0,,« Les ennemis jurés des dieux. »
Dialogue: 0,0:03:11.27,0:03:13.34,Main,,0,0,0,,Moi aussi, je suis un D. !
Dialogue: 0,0:03:23.62,0:03:26.41,Main,,0,0,0,,Comment se déroule la bataille, Viola ?
Dialogue: 0,0:03:27.00,0:03:29.78,Main,,0,0,0,,Plutôt mal, pour le combat\Nau dernier étage du palais.
Dialogue: 0,0:03:30.18,0:03:32.90,Main,,0,0,0,,Le Chapeau de paille a été refoulé\Nun étage plus bas.
Dialogue: 0,0:03:33.08,0:03:36.16,Main,,0,0,0,,Law peine, face à Doflamingo.
Dialogue: 0,0:03:36.40,0:03:41.06,Main,,0,0,0,,La bataille pour ce royaume se déroule\Nsur trois fronts principaux.
Dialogue: 0,0:03:42.00,0:03:44.10,Main,,0,0,0,,Sur le mont du palais.
Dialogue: 0,0:03:45.30,0:03:46.98,Main,,0,0,0,,Autour de la statue de Pica.
Dialogue: 0,0:03:48.38,0:03:50.32,Main,,0,0,0,,Et devant la fabrique de Smiles.
Dialogue: 0,0:03:50.90,0:03:52.34,Main,,0,0,0,,Éteignez les flammes !
Dialogue: 0,0:03:52.50,0:03:53.84,Main,,0,0,0,,Stop, pitié !
Dialogue: 0,0:03:54.02,0:03:56.18,Main,,0,0,0,,Maîtrisez tous les fous furieux !
Dialogue: 0,0:03:57.45,0:03:59.70,Main,,0,0,0,,Tant que les combats continueront,
Dialogue: 0,0:04:00.50,0:04:02.59,Main,,0,0,0,,les victimes seront\Ntoujours plus nombreuses.
Dialogue: 0,0:04:03.00,0:04:04.92,Main,,0,0,0,,Vi... Viola...
Dialogue: 0,0:04:07.70,0:04:10.24,Main,,0,0,0,,Des lieutenants\Nde la Don Quichotte Family,
Dialogue: 0,0:04:10.42,0:04:12.40,Main,,0,0,0,,y en a encore combien debout ?
Dialogue: 0,0:04:13.45,0:04:15.53,Main,,0,0,0,,Beaucoup trop.
Dialogue: 0,0:04:16.85,0:04:21.20,Main,,0,0,0,,Celui qui protège la fabrique de Smiles,\Nl'un des principaux fronts,
Dialogue: 0,0:04:21.52,0:04:24.84,Main,,0,0,0,,c'est l'homme-barboteur,\NSeñor Pink.
Dialogue: 0,0:04:30.92,0:04:34.56,Main,,0,0,0,,Du côté de la statue de Pica,\Nc'est un lieutenant-chef.
Dialogue: 0,0:04:38.72,0:04:41.64,Main,,0,0,0,,{\an8}L'homme qui peut se fondre\Ndans la pierre, Pica.
Dialogue: 0,0:04:42.90,0:04:46.46,Main,,0,0,0,,Et sur le troisième front,\Ncelui du mont du palais,
Dialogue: 0,0:04:47.30,0:04:49.25,Main,,0,0,0,,au tout dernier étage...
Dialogue: 0,0:04:51.20,0:04:53.28,Main,,0,0,0,,Il y a le souverain de ce royaume,
Dialogue: 0,0:04:53.50,0:04:55.97,Main,,0,0,0,,le maître des fils, Doflamingo.
Dialogue: 0,0:04:59.90,0:05:01.81,Main,,0,0,0,,Le chef des troupes,\Nl'homme-mucus.
Dialogue: 0,0:05:01.99,0:05:03.30,Main,,0,0,0,,Trébol.
Dialogue: 0,0:05:04.57,0:05:06.82,Main,,0,0,0,,Au 4e niveau, dans le champ de fleurs,
Dialogue: 0,0:05:07.44,0:05:10.27,Main,,0,0,0,,c'est l'homme-bannière,\Nle héros du Colosseum.
Dialogue: 0,0:05:12.55,0:05:14.02,Main,,0,0,0,,Diamante.
Dialogue: 0,0:05:15.96,0:05:19.50,Main,,0,0,0,,Au 3e niveau, l'homme-explosif\Net ses troupes.
Dialogue: 0,0:05:22.10,0:05:23.28,Main,,0,0,0,,Gladius.
Dialogue: 0,0:05:25.95,0:05:28.32,Main,,0,0,0,,Au 2e niveau,\Npas moins de quatre lieutenants.
Dialogue: 0,0:05:30.75,0:05:33.72,Main,,0,0,0,,Mi-homme, mi-rascaille,\NDellinger.
Dialogue: 0,0:05:35.70,0:05:37.35,Main,,0,0,0,,Le maître du Poing Gâteux,
Dialogue: 0,0:05:38.04,0:05:39.23,Main,,0,0,0,,Lao G..
Dialogue: 0,0:05:41.18,0:05:43.23,Main,,0,0,0,,L'homme super-extra-lourd,
Dialogue: 0,0:05:45.48,0:05:47.01,Main,,0,0,0,,Machvise.
Dialogue: 0,0:05:49.81,0:05:51.40,Main,,0,0,0,,La femme arme-fatale,
Dialogue: 0,0:05:53.14,0:05:54.76,Main,,0,0,0,,Baby-5.
Dialogue: 0,0:05:57.35,0:06:01.38,Main,,0,0,0,,Plus de dix lieutenants\Nsont encore debout.
Dialogue: 0,0:06:17.90,0:06:19.89,Main,,0,0,0,,Attends, me dis pas que...
Dialogue: 0,0:06:30.22,0:06:33.09,Main,,0,0,0,,Cette fichue brise\Nm'a collé une poussière dans l'œil.
Dialogue: 0,0:06:33.57,0:06:36.75,Main,,0,0,0,,Oh là là !\NQuels hommes !
Dialogue: 0,0:06:45.90,0:06:47.74,Main,,0,0,0,,Nos valeureux défenseurs...
Dialogue: 0,0:06:49.90,0:06:52.86,Main,,0,0,0,,Ils sont tous meurtris et éprouvés.
Dialogue: 0,0:06:55.22,0:06:58.82,Main,,0,0,0,,L'heure de vérité est proche.
Dialogue: 0,0:07:14.36,0:07:16.57,Main,,0,0,0,,Tu oses ?
Dialogue: 0,0:07:26.56,0:07:29.70,Main,,0,0,0,,{\fad(150,150)}Étendard.
Dialogue: 0,0:07:38.12,0:07:39.31,Main,,0,0,0,,Le sol se soulève !
Dialogue: 0,0:07:43.90,0:07:47.07,Main,,0,0,0,,Que dites-vous de ça ?\NLe sol ondule au vent, tel un étendard.
Dialogue: 0,0:07:47.28,0:07:49.50,Main,,0,0,0,,Ça ne va pas être facile\Nde tenir debout.
Dialogue: 0,0:08:06.60,0:08:07.50,Main,,0,0,0,,{\fad(150,150)}Clutch.
Dialogue: 0,0:08:08.90,0:08:09.75,Thoughts,,0,0,0,,Rebecca.
Dialogue: 0,0:08:09.93,0:08:14.12,Main,,0,0,0,,Je sais ce qui te travaille.\NVas-y, je reste ici.
Dialogue: 0,0:08:14.52,0:08:17.35,Main,,0,0,0,,– Tu es sûr, Poussin ?\N– Allez, file !
Dialogue: 0,0:08:18.70,0:08:19.56,Main,,0,0,0,,Bien.
Dialogue: 0,0:08:20.82,0:08:22.58,Main,,0,0,0,,{\fad(150,150)}Pierna fleurs.
Dialogue: 0,0:08:39.80,0:08:40.75,Main,,0,0,0,,Franchement !
Dialogue: 0,0:08:40.99,0:08:43.84,Main,,0,0,0,,Vos attaques minables\Nsont d'un soporifique...
Dialogue: 0,0:08:44.60,0:08:46.37,Main,,0,0,0,,En garde, Gladius.
Dialogue: 0,0:09:03.50,0:09:04.90,Main,,0,0,0,,{\fad(150,150)}Canon Destructeur !
Dialogue: 0,0:09:07.26,0:09:09.06,Main,,0,0,0,,Tu m'auras pas !
Dialogue: 0,0:09:22.50,0:09:25.25,Main,,0,0,0,,{\fad(150,150)}10 tonnes...
Dialogue: 0,0:09:25.99,0:09:28.96,Main,,0,0,0,,{\fad(150,150)}Vise !
Dialogue: 0,0:09:37.10,0:09:38.90,Main,,0,0,0,,Et boum !
Dialogue: 0,0:09:40.95,0:09:42.47,Main,,0,0,0,,Ce que tu viens de dire...
Dialogue: 0,0:09:43.64,0:09:44.72,Main,,0,0,0,,Tu as recommencé !
Dialogue: 0,0:10:04.00,0:10:05.50,Main,,0,0,0,,En avant, toute !
Dialogue: 0,0:10:06.24,0:10:08.20,Main,,0,0,0,,Princesse Manshelly !
Dialogue: 0,0:10:13.30,0:10:14.59,Main,,0,0,0,,Tout va bien ?
Dialogue: 0,0:10:14.75,0:10:17.33,Main,,0,0,0,,Oui, merci à vous !
Dialogue: 0,0:10:17.95,0:10:19.90,Main,,0,0,0,,Allez vite vous réfugier en lieu sûr.
Dialogue: 0,0:10:20.75,0:10:22.84,Thoughts,,0,0,0,,Mais y a-t-il encore un endroit sûr ?
Dialogue: 0,0:10:33.90,0:10:36.18,Main,,0,0,0,,Tant que Doflamingo est debout,
Dialogue: 0,0:10:36.35,0:10:39.90,Main,,0,0,0,,nous resterons pris au piège de la Cage.
Dialogue: 0,0:10:40.38,0:10:44.36,Main,,0,0,0,,Est-ce bien raisonnable de confier\Nle salut de ce pays à des pirates ?
Dialogue: 0,0:10:54.35,0:10:56.38,Main,,0,0,0,,Tu es un D. ?
Dialogue: 0,0:10:56.56,0:10:57.67,Main,,0,0,0,,C'était un nom secret ?
Dialogue: 0,0:10:58.32,0:11:01.91,Main,,0,0,0,,Et tu veux me faire croire\Nque le destin t'a mené ici ?
Dialogue: 0,0:11:03.18,0:11:06.34,Main,,0,0,0,,Tu crois qu'un D. peut m'arrêter ?
Dialogue: 0,0:11:06.65,0:11:09.88,Main,,0,0,0,,Les porteurs du D.\Nsont les ennemis jurés des dieux ?
Dialogue: 0,0:11:10.92,0:11:13.52,Main,,0,0,0,,Balivernes ! Superstitions !
Dialogue: 0,0:11:15.96,0:11:18.88,Main,,0,0,0,,Oh non, Doffy !\NFais attention !
Dialogue: 0,0:11:19.14,0:11:21.56,Main,,0,0,0,,T'es dans la sphère de pouvoir\Nde Law !
Dialogue: 0,0:11:21.76,0:11:23.38,Main,,0,0,0,,{\fad(150,150)}Injection...
Dialogue: 0,0:11:26.12,0:11:27.46,Main,,0,0,0,,{\fad(150,150)}Shot !
Dialogue: 0,0:11:35.36,0:11:39.44,Main,,0,0,0,,Cora ne se faisait pas d'illusions\Nà ce sujet.
Dialogue: 0,0:11:40.50,0:11:44.38,Main,,0,0,0,,Si mon nom pouvait suffire à te vaincre,\Nce serait trop facile.
Dialogue: 0,0:11:46.72,0:11:49.52,Main,,0,0,0,,Si je suis là,\Nc'est à cause de ce fameux jour.
Dialogue: 0,0:11:52.00,0:11:52.96,Main,,0,0,0,,Tu sais...
Dialogue: 0,0:11:55.74,0:12:00.18,Main,,0,0,0,,Cora était trop gentil\Npour appuyer sur la détente.
Dialogue: 0,0:12:01.30,0:12:03.96,Main,,0,0,0,,Je suis venu pour le faire à sa place !
Dialogue: 0,0:12:14.76,0:12:15.98,Main,,0,0,0,,Doffy !
Dialogue: 0,0:12:29.09,0:12:31.04,Main,,0,0,0,,Je ne suis pas franchement charmé.
Dialogue: 0,0:12:31.53,0:12:32.50,Main,,0,0,0,,{\fad(150,150)}Room !
Dialogue: 0,0:12:34.69,0:12:38.45,Main,,0,0,0,,Tu me déçois vraiment.
Dialogue: 0,0:12:43.73,0:12:44.44,Main,,0,0,0,,{\fad(150,150)}Tact !
Dialogue: 0,0:12:46.28,0:12:49.53,Main,,0,0,0,,Doffy !\NAttention à la tour des remparts !
Dialogue: 0,0:12:49.87,0:12:52.79,Main,,0,0,0,,Elle fonce sur nous !
Dialogue: 0,0:12:56.63,0:12:58.09,Main,,0,0,0,,{\fad(150,150)}Toile d'Araignée.
Dialogue: 0,0:13:19.73,0:13:20.91,Main,,0,0,0,,Shambles.
Dialogue: 0,0:13:22.15,0:13:23.03,Main,,0,0,0,,{\fad(150,150)}Scalpel !
Dialogue: 0,0:13:28.09,0:13:31.76,Main,,0,0,0,,Cesse de t'entêter\Navec ces attaques infructueuses.
Dialogue: 0,0:13:32.40,0:13:37.42,Main,,0,0,0,,T'es vraiment devenu une tête brûlée\Nfacile à cerner.
Dialogue: 0,0:13:39.47,0:13:42.45,Main,,0,0,0,,Tu n'as pas de vue d'ensemble.
Dialogue: 0,0:13:43.33,0:13:46.77,Main,,0,0,0,,Tu perds toujours ton temps\Nen pinaillages,
Dialogue: 0,0:13:46.95,0:13:50.39,Main,,0,0,0,,c'est pour ça que tu es incapable\Nde te décider au moment crucial.
Dialogue: 0,0:13:50.65,0:13:54.16,Main,,0,0,0,,Les faibles se perdent\Ndans les soucis des autres
Dialogue: 0,0:13:54.34,0:13:56.61,Main,,0,0,0,,et ainsi, ils s'autodétruisent.
Dialogue: 0,0:13:57.23,0:14:02.15,Main,,0,0,0,,Si tu voulais vraiment me tuer,
Dialogue: 0,0:14:02.33,0:14:06.47,Main,,0,0,0,,tu aurais dû t'en tenir à ton plan\Nde monter Kaido contre moi.
Dialogue: 0,0:14:06.89,0:14:09.62,Main,,0,0,0,,Il y a toutes sortes de moyens\Npour se débarrasser
Dialogue: 0,0:14:09.80,0:14:11.77,Main,,0,0,0,,d'un adversaire plus fort que toi.
Dialogue: 0,0:14:11.95,0:14:15.43,Main,,0,0,0,,Mais le souvenir de Corazón\Nt'a rendu sentimental.
Dialogue: 0,0:14:15.61,0:14:19.93,Main,,0,0,0,,Dès l'instant où tu as décidé\Nde t'en prendre directement à moi,
Dialogue: 0,0:14:21.00,0:14:23.79,Main,,0,0,0,,tu as signé ton arrêt de mort.
Dialogue: 0,0:14:28.59,0:14:32.68,Main,,0,0,0,,Tu te souviens du fameux rapport ?
Dialogue: 0,0:14:35.81,0:14:39.09,Flashbacks,,0,0,0,,Les informations\Nqu'il contient vont pouvoir sauver
Dialogue: 0,0:14:39.27,0:14:42.06,Flashbacks,,0,0,0,,un lointain royaume,\Ndu nom de Dressrosa.
Dialogue: 0,0:14:42.24,0:14:43.41,Flashbacks,,0,0,0,,Un royaume ?
Dialogue: 0,0:14:44.22,0:14:47.27,Flashbacks,,0,0,0,,Quelqu'un t'a confié ça ?\NMerci.
Dialogue: 0,0:14:47.89,0:14:51.10,Flashbacks,,0,0,0,,Je m'en occupe.\NC'est bon, ne t'inquiète pas.
Dialogue: 0,0:14:55.09,0:14:59.99,Main,,0,0,0,,Corazón voulait sauver\Nce royaume de Dressrosa.
Dialogue: 0,0:15:01.59,0:15:05.81,Main,,0,0,0,,Si seulement tu n'avais pas tout gâché,\Nce jour-là...
Dialogue: 0,0:15:07.92,0:15:13.49,Main,,0,0,0,,Si Corazón est mort,\Nc'est à cause de toi.
Dialogue: 0,0:15:14.79,0:15:17.39,Main,,0,0,0,,Si cette lettre\Nétait arrivée à bon port,
Dialogue: 0,0:15:18.41,0:15:22.41,Main,,0,0,0,,les innombrables tragédies\Nqui ont frappé ce royaume
Dialogue: 0,0:15:22.77,0:15:25.93,Main,,0,0,0,,auraient sans doute pu être évitées.
Dialogue: 0,0:15:28.11,0:15:30.39,Main,,0,0,0,,Tu veux me faire croire ça ?
Dialogue: 0,0:15:35.29,0:15:38.57,Main,,0,0,0,,Tu as gardé ton calme, bravo.\NTu es plutôt intelligent.
Dialogue: 0,0:15:39.73,0:15:41.33,Main,,0,0,0,,Bien vu !
Dialogue: 0,0:15:41.69,0:15:45.32,Main,,0,0,0,,Si tu veux mon avis,\Nce rapport n'aurait rien changé.
Dialogue: 0,0:15:45.50,0:15:49.23,Main,,0,0,0,,J'aurai modifié mes plans\Net conquis ce royaume quand même !
Dialogue: 0,0:15:59.12,0:16:02.30,Main,,0,0,0,,Tous les beaux et nobles sacrifices\Nde Corazón
Dialogue: 0,0:16:02.48,0:16:04.83,Main,,0,0,0,,auront été vains, en fin de compte.
Dialogue: 0,0:16:05.10,0:16:07.30,Main,,0,0,0,,Pas si j'ai mon mot à dire !
Dialogue: 0,0:16:10.45,0:16:15.61,Main,,0,0,0,,Tout ce que je ferai jusqu'à ma mort,\Nce sera à porter au crédit de Cora.
Dialogue: 0,0:16:15.92,0:16:19.59,Main,,0,0,0,,Je vois.\NJ'en ai presque les larmes aux yeux.
Dialogue: 0,0:16:22.03,0:16:23.30,Main,,0,0,0,,Fais-toi une raison.
Dialogue: 0,0:16:23.55,0:16:25.71,Main,,0,0,0,,Toutes ces tragédies, tous ces morts...
Dialogue: 0,0:16:26.07,0:16:29.05,Main,,0,0,0,,Tout ce qui s'est produit est bien réel.
Dialogue: 0,0:16:29.23,0:16:32.87,Main,,0,0,0,,Tu as avalé le Fruit du Bistouri,\Net tu t'es enfui, c'est un fait.
Dialogue: 0,0:16:33.05,0:16:35.56,Main,,0,0,0,,Tu m'as défié à Punk Hazard
Dialogue: 0,0:16:35.74,0:16:38.05,Main,,0,0,0,,et tu es venu jusqu'ici,\Nc'est un autre fait !
Dialogue: 0,0:16:51.07,0:16:52.38,Main,,0,0,0,,Bien joué !
Dialogue: 0,0:16:54.29,0:16:56.35,Main,,0,0,0,,Fil-Scie ! Fil-Scie !
Dialogue: 0,0:16:57.85,0:17:00.93,Main,,0,0,0,,Tu t'es laissé influencer\Npar l'autre D. ?
Dialogue: 0,0:17:01.11,0:17:04.19,Main,,0,0,0,,Tu t'en es ouvertement pris à moi.
Dialogue: 0,0:17:04.37,0:17:06.29,Main,,0,0,0,,Ça aussi, c'est un fait.
Dialogue: 0,0:17:06.79,0:17:09.35,Main,,0,0,0,,C'est donc pour ça\Nque je vais te pardonner.
Dialogue: 0,0:17:12.07,0:17:15.81,Main,,0,0,0,,De la même manière que j'ai pardonné\Nà mon père et à mon frère.
Dialogue: 0,0:17:18.30,0:17:20.53,Main,,0,0,0,,En te donnant la mort.
Dialogue: 0,0:17:20.71,0:17:23.46,Main,,0,0,0,,{\fad(150,150)}Gum Gum...
Dialogue: 0,0:17:23.82,0:17:25.06,Main,,0,0,0,,Ordure !
Dialogue: 0,0:17:25.69,0:17:26.81,Main,,0,0,0,,{\fad(150,150)}Jet...
Dialogue: 0,0:17:27.69,0:17:30.19,Main,,0,0,0,,{\fad(150,150)}Gatling !
Dialogue: 0,0:17:30.37,0:17:34.89,Main,,0,0,0,,Pour une exécution,\Nrien de tel que des balles de plomb.
Dialogue: 0,0:17:45.29,0:17:47.23,Main,,0,0,0,,C'est la doublure !
Dialogue: 0,0:17:50.13,0:17:51.17,Main,,0,0,0,,Mingo !
Dialogue: 0,0:17:52.39,0:17:54.65,Main,,0,0,0,,Ramène-toi !
Dialogue: 0,0:17:57.09,0:17:58.26,Main,,0,0,0,,Le Pailleux.
Dialogue: 0,0:18:00.47,0:18:03.99,Main,,0,0,0,,La doublure de fils est en charpie !
Dialogue: 0,0:18:10.50,0:18:13.45,Main,,0,0,0,,Je crois que ma cage va être\Ntrop petite
Dialogue: 0,0:18:18.95,0:18:22.67,Main,,0,0,0,,pour contenir une telle chose.
Dialogue: 0,0:18:23.41,0:18:25.13,Main,,0,0,0,,Tu m'écoutes ?
Dialogue: 0,0:18:34.61,0:18:35.57,Main,,0,0,0,,Bellamy ?
Dialogue: 0,0:18:49.19,0:18:50.11,Main,,0,0,0,,Ordure !
Dialogue: 0,0:18:51.54,0:18:54.38,Main,,0,0,0,,Hep, Mingo !\NRelâche Bellamy !
Dialogue: 0,0:18:54.66,0:18:55.87,Main,,0,0,0,,Il va y rester !
Dialogue: 0,0:18:56.82,0:18:59.48,Main,,0,0,0,,Tiens, tiens...\NTu es encore en vie ?
Dialogue: 0,0:19:01.39,0:19:02.81,Main,,0,0,0,,Comme tu voudras.
Dialogue: 0,0:19:06.03,0:19:06.62,Main,,0,0,0,,Bellamy !
Dialogue: 0,0:19:06.82,0:19:08.79,Main,,0,0,0,,Do... Doflamingo...
Dialogue: 0,0:19:08.96,0:19:11.70,Main,,0,0,0,,Ça suffit, Bellamy.
Dialogue: 0,0:19:11.88,0:19:14.03,Main,,0,0,0,,Je te rends ta liberté.
Dialogue: 0,0:19:14.21,0:19:16.60,Main,,0,0,0,,Enfin, je ne t'ai jamais retenu.
Dialogue: 0,0:19:22.75,0:19:24.06,Flashbacks,,0,0,0,,Vous êtes d'où ?
Dialogue: 0,0:19:24.50,0:19:26.71,Flashbacks,,0,0,0,,On est tous de Nortis.
Dialogue: 0,0:19:26.89,0:19:29.57,Flashbacks,,0,0,0,,C'est une ville de riches !\NVous avez la belle vie.
Dialogue: 0,0:19:29.80,0:19:32.18,Flashbacks,,0,0,0,,On s'ennuie à mourir,\Ndans ce bled.
Dialogue: 0,0:19:32.61,0:19:36.03,Flashbacks,,0,0,0,,La Don Quichotte Family,\Nc'est la fierté de tout North Blue !
Dialogue: 0,0:19:37.39,0:19:41.53,Flashbacks,,0,0,0,,On veut devenir des pirates\Naussi craints et réputés que vous !
Dialogue: 0,0:19:41.69,0:19:46.10,Flashbacks,,0,0,0,,On n'est pas comme tous ces idiots\Nde pirates rêveurs du coin.
Dialogue: 0,0:19:47.17,0:19:49.95,Flashbacks,,0,0,0,,Si c'est mon pavillon que tu veux,\Npas de problème.
Dialogue: 0,0:19:50.65,0:19:51.49,Flashbacks,,0,0,0,,Doffy ?
Dialogue: 0,0:19:52.03,0:19:55.53,Flashbacks,,0,0,0,,Mais à la moindre défaite,\Ntu devras l'abandonner.
Dialogue: 0,0:19:55.80,0:19:58.45,Flashbacks,,0,0,0,,Sérieux ? Super !
Dialogue: 0,0:20:02.75,0:20:05.57,Flashbacks,,0,0,0,,Je n'ai pas besoin de faiblards\Ndans mon équipage.
Dialogue: 0,0:20:06.00,0:20:08.87,Flashbacks,,0,0,0,,T'en fais pas, personne ne me vaincra.
Dialogue: 0,0:20:11.79,0:20:13.12,Main,,0,0,0,,Hé, Bellamy !
Dialogue: 0,0:20:13.30,0:20:14.29,Main,,0,0,0,,Ça va aller ?
Dialogue: 0,0:20:15.00,0:20:16.56,Main,,0,0,0,,T'as l'air d'en baver salement.
Dialogue: 0,0:20:17.53,0:20:21.09,Flashbacks,,0,0,0,,L'époque où les pirates avaient un rêve\Nest révolue !
Dialogue: 0,0:20:21.69,0:20:24.16,Flashbacks,,0,0,0,,Tu auras beau te démener,\Ntu ne pourras pas échapper
Dialogue: 0,0:20:24.34,0:20:25.67,Flashbacks,,0,0,0,,au Fruit du Ressort.
Dialogue: 0,0:20:29.59,0:20:31.97,Flashbacks,,0,0,0,,{\fad(150,150)}Spring...
Dialogue: 0,0:20:32.15,0:20:34.05,Flashbacks,,0,0,0,,{\fad(150,150)}Hopper !
Dialogue: 0,0:20:53.67,0:20:54.90,Flashbacks,,0,0,0,,Chapeau de paille.
Dialogue: 0,0:20:55.70,0:20:58.43,Flashbacks,,0,0,0,,Je me suis rendu aux Îles Célestes.
Dialogue: 0,0:20:59.21,0:21:01.20,Flashbacks,,0,0,0,,J'ai perdu mes camarades,
Dialogue: 0,0:21:01.38,0:21:04.53,Flashbacks,,0,0,0,,mais ça a bouleversé\Nma vision du monde.
Dialogue: 0,0:21:04.81,0:21:07.67,Flashbacks,,0,0,0,,En tout cas,\Nsache que je ne t'en veux plus.
Dialogue: 0,0:21:08.23,0:21:11.10,Flashbacks,,0,0,0,,Je ne me moquerai plus de toi.
Dialogue: 0,0:21:12.95,0:21:13.68,Flashbacks,,0,0,0,,Bellamy ?
Dialogue: 0,0:21:13.95,0:21:15.51,Flashbacks,,0,0,0,,T'as changé, Bellamy.
Dialogue: 0,0:21:16.90,0:21:18.44,Main,,0,0,0,,Vas-y doucement !
Dialogue: 0,0:21:18.87,0:21:19.92,Main,,0,0,0,,Reste allongé.
Dialogue: 0,0:21:23.56,0:21:26.65,Flashbacks,,0,0,0,,Joker veut que ce soit moi\Nqui tue le Chapeau de paille ?
Dialogue: 0,0:21:26.83,0:21:29.19,Flashbacks,,0,0,0,,Le bon cœur de Doffy le perdra.
Dialogue: 0,0:21:29.70,0:21:34.20,Flashbacks,,0,0,0,,Considère ça comme une occasion\Nde racheter ta défaite au tournoi.
Dialogue: 0,0:21:34.47,0:21:36.07,Flashbacks,,0,0,0,,Tu as de la chance, Bellamy.
Dialogue: 0,0:21:38.55,0:21:41.09,Flashbacks,,0,0,0,,Bah, vu que c'est toi,
Dialogue: 0,0:21:41.27,0:21:44.83,Flashbacks,,0,0,0,,je me doutais que t'allais rater\Nl'assassinat du Chapeau de paille.
Dialogue: 0,0:21:47.11,0:21:48.42,Main,,0,0,0,,Encore une sacrée secousse !
Dialogue: 0,0:21:52.55,0:21:55.98,Flashbacks,,0,0,0,,Ne me force pas\Nà te mettre les points sur les i, Bellamy.
Dialogue: 0,0:21:56.37,0:21:59.36,Flashbacks,,0,0,0,,Toi et moi,\Non ne poursuit pas le même but.
Dialogue: 0,0:22:04.68,0:22:08.05,Flashbacks,,0,0,0,,Je peux pas te faire ça !\NT'es un ami !
Dialogue: 0,0:22:11.09,0:22:12.29,Main,,0,0,0,,Hé, Bellamy !
Dialogue: 0,0:22:12.75,0:22:15.05,Main,,0,0,0,,Désolé, mais je dois te laisser.
Dialogue: 0,0:22:15.23,0:22:16.95,Main,,0,0,0,,Je m'inquiète pour Traffy.
Dialogue: 0,0:22:17.20,0:22:19.61,Main,,0,0,0,,Mingo et le tas de morve sont là-haut.
Dialogue: 0,0:22:19.97,0:22:22.99,Main,,0,0,0,,Si je n'y vais pas,\NTraffy va morfler.
Dialogue: 0,0:22:23.40,0:22:27.53,Main,,0,0,0,,– Je vais rosser Mingo pour toi !\N– Attends.
Dialogue: 0,0:22:29.35,0:22:31.20,Main,,0,0,0,,Cette attaque...
Dialogue: 0,0:22:31.85,0:22:33.43,Main,,0,0,0,,Ça te dit quelque chose ?
Dialogue: 0,0:22:34.35,0:22:36.87,Main,,0,0,0,,Battons-nous, Chapeau de paille !
Dialogue: 0,0:22:37.05,0:22:39.51,Main,,0,0,0,,{\fad(150,150)}Spring...
Dialogue: 0,0:22:39.69,0:22:41.47,Main,,0,0,0,,{\fad(150,150)}Hopper !
Dialogue: 0,0:22:43.60,0:22:47.13,Main,,0,0,0,,T'es peut-être devenu plus fort,\Nmais t'es pas le seul !
Dialogue: 0,0:22:48.99,0:22:53.57,Main,,0,0,0,,Cette attaque\Nest bien plus destructrice qu'autrefois !
Dialogue: 0,0:22:53.93,0:22:57.19,Main,,0,0,0,,T'es pas en état !\NTu vas te tuer, si tu continues.
Dialogue: 0,0:23:00.56,0:23:03.89,Main,,0,0,0,,La ferme !\NT'inquiète pas pour ton ennemi !
Dialogue: 0,0:23:05.37,0:23:06.91,Main,,0,0,0,,Je sais bien !
Dialogue: 0,0:23:07.27,0:23:09.65,Main,,0,0,0,,J'adulais pas la bonne personne.
Dialogue: 0,0:23:09.83,0:23:12.22,Main,,0,0,0,,Je suis un bouffon, j'ai pigé !
Dialogue: 0,0:23:18.93,0:23:19.86,Flashbacks,,0,0,0,,Non.
Dialogue: 0,0:23:20.57,0:23:23.55,Flashbacks,,0,0,0,,Ce sera au vainqueur de décider.
Dialogue: 0,0:23:24.14,0:23:28.34,Flashbacks,,0,0,0,,Vois-tu, il est venu me trouver\Npour que je le tue.
Dialogue: 0,0:23:28.65,0:23:30.56,Flashbacks,,0,0,0,,Pas vrai, Bellamy ?
Dialogue: 0,0:23:33.07,0:23:37.19,Main,,0,0,0,,Je vais pas tourner le dos\Nà mon idéal
Dialogue: 0,0:23:37.37,0:23:40.90,Main,,0,0,0,,juste parce que je l'ai mauvaise !
Dialogue: 0,0:23:41.08,0:23:43.77,Main,,0,0,0,,Je vais quand même pas sombrer\Naussi bas !
Dialogue: 0,0:23:44.62,0:23:47.13,Main,,0,0,0,,Je suis peut-être idiot...
Dialogue: 0,0:23:47.31,0:23:50.25,Main,,0,0,0,,mais j'ai mes principes !
Dialogue: 0,0:23:50.83,0:23:52.03,Main,,0,0,0,,Chapeau de paille.
Dialogue: 0,0:23:52.21,0:23:54.39,Main,,0,0,0,,Ceci est mon dernier combat...
Dialogue: 0,0:23:54.60,0:23:56.80,Main,,0,0,0,,Et je te veux en tant qu'adversaire !
Dialogue: 0,0:01:42.65,0:01:46.56,Title,,0,0,0,,{\fad(250,250)\fs(145)\pos(960,820)\bord2.9}Bellamy le pirate
